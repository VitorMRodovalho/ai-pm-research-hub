# ═══════════════════════════════════════════════════════════════
# AI & PM Hub — Variáveis de ambiente
# Copie para .env e preencha. NUNCA commite .env.
# Replicação: docs/REPLICATION_GUIDE.md
# ═══════════════════════════════════════════════════════════════

# ─── Obrigatório (build + runtime) ────────────────────────────
# Supabase: Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Dashboards (opcional) ─────────────────────────────────────
# Sem elas: placeholders ou tabelas nativas nas rotas admin
# PostHog: embed em /admin/analytics
# PUBLIC_POSTHOG_PRODUCT_DASHBOARD_URL=https://us.posthog.com/...

# Looker: embed em /admin/analytics e /admin/comms
# PUBLIC_LOOKER_COMMS_DASHBOARD_URL=https://lookerstudio.google.com/...

# ─── Edge Functions / Backend ──────────────────────────────────
# Para deploy de funções e automações; não necessárias para build frontend

# sync-comms-metrics: secret para autenticar chamadas (gerar UUID)
# SYNC_COMMS_METRICS_SECRET=
# COMMS_METRICS_SOURCE_URL=   # URL que retorna JSON de métricas
# COMMS_METRICS_SOURCE_TOKEN= # Bearer opcional para a URL acima

# GitHub Actions: Credly Auto Sync, Knowledge Insights
# SUPABASE_SERVICE_ROLE_KEY=   # Service role (Dashboard → API)
# SYNC_KNOWLEDGE_INSIGHTS_SECRET=
# KNOWLEDGE_INSIGHTS_FUNCTION_NAME=sync-knowledge-insights  # default

# ─── Banco (opcional, para dump/schema) ────────────────────────
# Connection string direta; usada por psql / supabase db dump
# Obtenha em: Supabase Dashboard → Project Settings → Database → URI
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
