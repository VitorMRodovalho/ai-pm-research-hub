---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
import LoadingSkeleton from '../../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const { id } = Astro.params;
const tribeId = parseInt(id || '0', 10);
if (tribeId < 1 || tribeId > 8) return Astro.redirect('/');
const TRIBE_I18N = {
  membersTab: t('tribe.membersTab', lang),
  deliverablesTab: t('tribe.deliverablesTab', lang),
  resourcesTab: t('tribe.resourcesTab', lang),
  commsHubTab: t('tribe.commsHubTab', lang),
  meetingSchedule: t('tribe.meetingSchedule', lang),
  noMembers: t('tribe.noMembers', lang),
  noDeliverables: t('tribe.noDeliverables', lang),
  noResources: t('tribe.noResources', lang),
  addDeliverable: t('tribe.addDeliverable', lang),
  statusPlanned: t('tribe.statusPlanned', lang),
  statusInProgress: t('tribe.statusInProgress', lang),
  statusCompleted: t('tribe.statusCompleted', lang),
  statusCancelled: t('tribe.statusCancelled', lang),
  loading: t('tribe.loading', lang),
  notFound: t('tribe.notFound', lang),
  leader: t('tribe.leader', lang),
  quadrant: t('tribe.quadrant', lang),
  dueDate: t('tribe.dueDate', lang),
  noDueDate: t('tribe.noDueDate', lang),
  assignee: t('tribe.assignee', lang),
  unassigned: t('tribe.unassigned', lang),
  openLink: t('tribe.openLink', lang),
  dateLocale: t('tribe.dateLocale', lang),
  error: t('tribe.error', lang),
  tribeName: t(`data.tribe${tribeId}.name`, lang),
  tribeDesc: t(`data.tribe${tribeId}.desc`, lang),
  quadrantLabel: t(`data.tribe${tribeId}.quadrantLabel`, lang),
  modalAddTitle: t('tribe.modal.addTitle', lang),
  modalEditTitle: t('tribe.modal.editTitle', lang),
  modalLabelTitle: t('tribe.modal.labelTitle', lang),
  modalLabelDescription: t('tribe.modal.labelDescription', lang),
  modalLabelStatus: t('tribe.modal.labelStatus', lang),
  modalLabelAssignee: t('tribe.modal.labelAssignee', lang),
  modalLabelDueDate: t('tribe.modal.labelDueDate', lang),
  modalLabelArtifact: t('tribe.modal.labelArtifact', lang),
  modalSelectMember: t('tribe.modal.selectMember', lang),
  modalSelectArtifact: t('tribe.modal.selectArtifact', lang),
  modalCancel: t('tribe.modal.cancel', lang),
  modalSave: t('tribe.modal.save', lang),
  modalTitleRequired: t('tribe.modal.titleRequired', lang),
  msgSaved: t('tribe.msg.saved', lang),
  msgSaveError: t('tribe.msg.saveError', lang),
  msgStatusUpdated: t('tribe.msg.statusUpdated', lang),
  msgStatusError: t('tribe.msg.statusError', lang),
  progressCompleted: t('tribe.progress.completed', lang),
  progressInProgress: t('tribe.progress.inProgress', lang),
  progressPlanned: t('tribe.progress.planned', lang),
  editDeliverable: t('tribe.editDeliverable', lang),
  moveToInProgress: t('tribe.moveTo.in_progress', lang),
  moveToCompleted: t('tribe.moveTo.completed', lang),
  moveToPlanned: t('tribe.moveTo.planned', lang),
  moveToCancelled: t('tribe.moveTo.cancelled', lang),
  joinWhatsApp: t('tribe.joinWhatsApp', lang),
  chatWhatsApp: t('tribe.chatWhatsApp', lang),
  broadcastTab: t('tribe.broadcastTab', lang),
  broadcast: {
    title: t('tribe.broadcast.title', lang),
    subtitle: t('tribe.broadcast.subtitle', lang),
    subject: t('tribe.broadcast.subject', lang),
    subjectPlaceholder: t('tribe.broadcast.subjectPlaceholder', lang),
    body: t('tribe.broadcast.body', lang),
    bodyPlaceholder: t('tribe.broadcast.bodyPlaceholder', lang),
    send: t('tribe.broadcast.send', lang),
    sending: t('tribe.broadcast.sending', lang),
    sent: t('tribe.broadcast.sent', lang),
    error: t('tribe.broadcast.error', lang),
    confirmTitle: t('tribe.broadcast.confirmTitle', lang),
    confirmMsg: t('tribe.broadcast.confirmMsg', lang),
    confirmYes: t('tribe.broadcast.confirmYes', lang),
    confirmNo: t('tribe.broadcast.confirmNo', lang),
    historyTitle: t('tribe.broadcast.historyTitle', lang),
    historyEmpty: t('tribe.broadcast.historyEmpty', lang),
    historyRecipients: t('tribe.broadcast.historyRecipients', lang),
    subjectRequired: t('tribe.broadcast.subjectRequired', lang),
    bodyRequired: t('tribe.broadcast.bodyRequired', lang),
    rateLimit: t('tribe.broadcast.rateLimit', lang),
  },
  commsHub: {
    title: t('tribe.commsHub.title', lang),
    subtitle: t('tribe.commsHub.subtitle', lang),
    loading: t('tribe.commsHub.loading', lang),
    empty: t('tribe.commsHub.empty', lang),
    colDate: t('tribe.commsHub.colDate', lang),
    colChannel: t('tribe.commsHub.colChannel', lang),
    colAudience: t('tribe.commsHub.colAudience', lang),
    colReach: t('tribe.commsHub.colReach', lang),
    colEngagement: t('tribe.commsHub.colEngagement', lang),
    colLeads: t('tribe.commsHub.colLeads', lang),
  },
  oproleLabels: {
    manager: t('profile.oprole.manager', lang),
    deputy_manager: t('profile.oprole.deputyManager', lang),
    tribe_leader: t('profile.oprole.tribeLeader', lang),
    researcher: t('profile.oprole.researcher', lang),
    facilitator: t('profile.oprole.facilitator', lang),
    communicator: t('profile.oprole.communicator', lang),
    none: t('profile.oprole.none', lang),
    guest: t('profile.oprole.guest', lang),
  },
  dayNames: [
    t('common.days.sun', lang), t('common.days.mon', lang), t('common.days.tue', lang),
    t('common.days.wed', lang), t('common.days.thu', lang), t('common.days.fri', lang),
    t('common.days.sat', lang),
  ],
};
const pageTitle = t('tribe.meta', lang).replace('{name}', `T${tribeId}`);
---
<BaseLayout title={pageTitle} activePage="tribes">
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <!-- Header -->
    <div id="tribe-header" class="mb-6">
      <LoadingSkeleton variant="profile" />
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-5 flex-wrap" id="tribe-tabs">
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
              data-tab="members" data-action="switch-tab">{t('tribe.membersTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
              data-tab="deliverables" data-action="switch-tab">{t('tribe.deliverablesTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
              data-tab="resources" data-action="switch-tab">{t('tribe.resourcesTab', lang)}</button>
    </div>

    <!-- Tab panels -->
    <div id="panel-members">
      <LoadingSkeleton variant="card" count={4} />
    </div>
    <div id="panel-deliverables" class="hidden">
      <LoadingSkeleton variant="card" count={3} />
    </div>
    <div id="panel-resources" class="hidden">
      <LoadingSkeleton variant="card" count={3} />
    </div>
    <!-- Comms Hub panel (conditionally shown for comms_team members) -->
    <div id="panel-commshub" class="hidden"></div>
    <!-- Broadcast panel (conditionally shown for tribe leader + admin) -->
    <div id="panel-broadcast" class="hidden"></div>
  </div>

  <!-- Deliverable Modal -->
  <div id="deliverable-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" data-action="close-deliverable-modal"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
      <h2 id="deliverable-modal-title" class="text-lg font-extrabold text-navy mb-4"></h2>
      <form id="deliverable-form" class="flex flex-col gap-3">
        <input type="hidden" id="dlv-id" />
        <div>
          <label for="dlv-title" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-title"></label>
          <input type="text" id="dlv-title" required class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
        </div>
        <div>
          <label for="dlv-description" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-description"></label>
          <textarea id="dlv-description" rows="3" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="dlv-status" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-status"></label>
            <select id="dlv-status" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
          </div>
          <div>
            <label for="dlv-due-date" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-due-date"></label>
            <input type="date" id="dlv-due-date" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
          </div>
        </div>
        <div>
          <label for="dlv-assignee" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-assignee"></label>
          <select id="dlv-assignee" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
        </div>
        <div>
          <label for="dlv-artifact" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-artifact"></label>
          <select id="dlv-artifact" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
        </div>
        <div class="flex justify-end gap-3 mt-2">
          <button type="button" data-action="close-deliverable-modal" class="px-4 py-2 text-sm font-semibold text-slate-500 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition-all" id="btn-dlv-cancel"></button>
          <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-navy rounded-lg cursor-pointer border-0 hover:opacity-90 transition-all" id="btn-dlv-save"></button>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ TRIBE_I18N, tribeId }}>
  window.__TRIBE_I18N = typeof TRIBE_I18N !== 'undefined' ? TRIBE_I18N : {};
  window.__TRIBE_ID = typeof tribeId !== 'undefined' ? tribeId : 0;
</script>
<script>
  const I18N = (typeof window !== 'undefined' && (window as any).__TRIBE_I18N) || {};
  const TRIBE_ID: number = (typeof window !== 'undefined' && (window as any).__TRIBE_ID) || 0;

  const OPROLE_LABELS: Record<string, string> = I18N.oproleLabels || {};
  const OPROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', deputy_manager: '#FF610F', tribe_leader: '#4F17A8', researcher: '#EC4899',
    facilitator: '#06B6D4', communicator: '#8B5CF6', none: '#94A3B8', guest: '#94A3B8'
  };
  const STATUS_COLORS: Record<string, { bg: string; text: string }> = {
    planned:     { bg: 'bg-slate-100', text: 'text-slate-600' },
    in_progress: { bg: 'bg-blue-50', text: 'text-blue-700' },
    completed:   { bg: 'bg-emerald-50', text: 'text-emerald-700' },
    cancelled:   { bg: 'bg-red-50', text: 'text-red-600' },
  };
  const STATUS_LABELS: Record<string, string> = {
    planned: I18N.statusPlanned, in_progress: I18N.statusInProgress,
    completed: I18N.statusCompleted, cancelled: I18N.statusCancelled,
  };
  const TYPE_ICONS: Record<string, string> = {
    'Curso': '🎓', 'Referência': '📘', 'Webinar': '▶️', 'Outro': '📎',
    'Course': '🎓', 'Reference': '📘',
  };
  const DAY_NAMES: string[] = I18N.dayNames || ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const HIGH_MGMT_ROLES = ['manager', 'deputy_manager'];

  function isHighManagement(m: any): boolean {
    if (!m) return false;
    return m.is_superadmin === true || HIGH_MGMT_ROLES.includes(m.operational_role);
  }

  function escapeHtml(s: string): string {
    return String(s || '')
      .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  let sb: any = null;
  let currentMember: any = null;
  let membersMap: Map<string, any> = new Map();
  let canEdit = false;
  let tribeData: any = null;
  let allDeliverables: any[] = [];
  let publishedArtifacts: any[] = [];
  let commsHubShown = false;

  // ── Tab switching ──
  function switchTab(tabName: string) {
    const panels = ['members', 'deliverables', 'resources', 'commshub', 'broadcast'];
    panels.forEach(p => {
      const el = document.getElementById(`panel-${p}`);
      if (el) el.classList.toggle('hidden', p !== tabName);
    });
    document.querySelectorAll('.tribe-tab').forEach(btn => {
      const isActive = (btn as HTMLElement).dataset.tab === tabName;
      btn.classList.toggle('bg-navy', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-navy', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-slate-500', !isActive);
      btn.classList.toggle('border-slate-200', !isActive);
    });
  }


  // ── Comms Hub tab (R2: conditional for comms_team designation) ──
  function showCommsHubTab() {
    if (commsHubShown) return;
    commsHubShown = true;
    const tabsContainer = document.getElementById('tribe-tabs');
    if (!tabsContainer) return;
    const btn = document.createElement('button');
    btn.className = 'tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all';
    btn.dataset.tab = 'commshub';
    btn.dataset.action = 'switch-tab';
    btn.textContent = I18N.commsHubTab || '\u{1F4E1} Comms Hub';
    tabsContainer.appendChild(btn);
  }

  function renderCommsHub() {
    const el = document.getElementById('panel-commshub');
    if (!el) return;
    const ch = I18N.commsHub || {};
    el.innerHTML = `
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100">
          <h2 class="text-base font-extrabold text-navy">${escapeHtml(ch.title || 'Comms Hub')}</h2>
          <p class="text-[13px] text-slate-500">${escapeHtml(ch.subtitle || '')}</p>
        </div>
        <div id="commshub-table-area" class="p-5">
          <div class="text-center py-8 text-slate-400 text-sm" id="commshub-loading">${escapeHtml(ch.loading || 'Loading...')}</div>
        </div>
      </div>`;
    loadCommsMetrics();
  }

  async function loadCommsMetrics() {
    const ch = I18N.commsHub || {};
    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 14 });
      const area = document.getElementById('commshub-table-area');
      if (!area) return;
      if (error || !data?.length) {
        area.innerHTML = `<div class="text-center py-8 text-slate-500 text-sm">${escapeHtml(ch.empty || 'No data')}</div>`;
        return;
      }
      const rows = data.map((r: any) => `
        <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
          <td class="px-3 py-2.5 text-[13px]">${escapeHtml(r.metric_date || '\u2014')}</td>
          <td class="px-3 py-2.5 text-[13px] font-medium">${escapeHtml(r.channel || '\u2014')}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.audience ?? '\u2014'}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.reach ?? '\u2014'}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.engagement != null ? (Number(r.engagement) * 100).toFixed(2) + '%' : '\u2014'}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.leads ?? '\u2014'}</td>
        </tr>`).join('');
      area.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full text-[13px] border-collapse">
            <thead>
              <tr class="border-b border-slate-200 text-left">
                <th class="px-3 py-2 font-semibold text-slate-600">${escapeHtml(ch.colDate || 'Date')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600">${escapeHtml(ch.colChannel || 'Channel')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colAudience || 'Audience')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colReach || 'Reach')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colEngagement || 'Engagement')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colLeads || 'Leads')}</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>`;
    } catch (e: any) {
      const area = document.getElementById('commshub-table-area');
      if (area) area.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">${escapeHtml(e?.message || 'Error')}</div>`;
    }
  }

  // ── Header render ──
  function renderHeader(_tribe: any, leader: any, slots: any[]) {
    const el = document.getElementById('tribe-header');
    if (!el) return;

    const leaderName = leader ? escapeHtml(leader.name) : '—';
    const leaderPhoto = leader?.photo_url
      ? `<img src="${escapeHtml(leader.photo_url)}" class="w-8 h-8 rounded-full object-cover border border-slate-100" alt="">`
      : leader
        ? `<div class="w-8 h-8 rounded-full bg-purple/20 flex items-center justify-center text-purple text-xs font-bold">${escapeHtml(leader.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase())}</div>`
        : '';

    let scheduleHtml = '';
    if (slots?.length) {
      scheduleHtml = slots.map(s => {
        const day = DAY_NAMES[s.day_of_week] || '?';
        const start = s.time_start?.substring(0, 5) || '';
        const end = s.time_end?.substring(0, 5) || '';
        return `${day} ${start}–${end}`;
      }).join(' · ');
    } else {
      scheduleHtml = '<span class="text-slate-400 italic">—</span>';
    }

    el.innerHTML = `
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <div class="flex items-start gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <h1 class="text-xl font-extrabold text-navy">T${TRIBE_ID}: ${escapeHtml(I18N.tribeName)}</h1>
              <span class="px-2 py-0.5 rounded-md text-[11px] font-bold uppercase tracking-wide bg-purple/10 text-purple">${escapeHtml(I18N.quadrantLabel)}</span>
            </div>
            <p class="text-[13px] text-slate-500 leading-relaxed mb-3">${escapeHtml(I18N.tribeDesc)}</p>
            <div class="flex flex-wrap gap-x-5 gap-y-2 text-[13px]">
              <div class="flex items-center gap-2">
                ${leaderPhoto}
                <span class="text-slate-400 font-semibold">${I18N.leader}:</span>
                <span class="font-semibold text-navy">${leaderName}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-slate-400 font-semibold">📅 ${I18N.meetingSchedule}:</span>
                <span class="text-navy font-medium">${scheduleHtml}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div id="tribe-wa-cta" class="hidden mt-3"></div>`;

    // WhatsApp CTA: show only if tribe has whatsapp_url AND user belongs to tribe (or is admin)
    if (_tribe?.whatsapp_url && currentMember) {
      const isTribeMember = currentMember.tribe_id === TRIBE_ID
        || membersMap.has(currentMember.id);
      const isAdmin = isHighManagement(currentMember);
      if (isTribeMember || isAdmin) {
        const ctaEl = document.getElementById('tribe-wa-cta');
        if (ctaEl) {
          ctaEl.classList.remove('hidden');
          ctaEl.innerHTML = `
            <a href="${escapeHtml(_tribe.whatsapp_url)}" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#25D366] text-white rounded-xl text-[14px] font-bold no-underline hover:bg-[#1FAD53] transition-all shadow-sm">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              ${I18N.joinWhatsApp || 'Entrar no Grupo do WhatsApp'}
            </a>`;
        }
      }
    }
  }

  // ── Members tab ──
  function renderMembers(members: any[]) {
    const el = document.getElementById('panel-members');
    if (!el) return;

    if (!members.length) {
      el.innerHTML = `
        <div class="text-center py-14">
          <div class="text-4xl mb-3">👥</div>
          <div class="font-semibold text-slate-500 text-sm">${I18N.noMembers}</div>
        </div>`;
      return;
    }

    el.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${members.map(memberCardHtml).join('')}</div>`;
  }

  function memberCardHtml(m: any): string {
    const initials = (m.name || '?').split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
    const photo = m.photo_url
      ? `<img src="${escapeHtml(m.photo_url)}" class="w-12 h-12 rounded-full object-cover border-2 border-slate-100" alt="">`
      : `<div class="w-12 h-12 rounded-full bg-teal/20 flex items-center justify-center text-teal text-sm font-bold">${escapeHtml(initials)}</div>`;

    const opRole = m.operational_role || 'researcher';
    const roleColor = OPROLE_COLORS[opRole] || '#94A3B8';
    const roleLabel = OPROLE_LABELS[opRole] || opRole;
    const roleBadge = opRole !== 'none' && opRole !== 'guest'
      ? `<span class="inline-block px-2 py-0.5 rounded-md text-[.6rem] font-bold uppercase" style="background:${roleColor}22;color:${roleColor}">${escapeHtml(roleLabel)}</span>`
      : '';

    const desigs: string[] = m.designations || [];
    const desigBadges = desigs.map((d: string) =>
      `<span class="inline-block px-2 py-0.5 rounded-md text-[.6rem] font-bold uppercase bg-slate-100 text-slate-500">${escapeHtml(d)}</span>`
    ).join(' ');

    return `
      <div class="bg-white rounded-2xl border border-slate-100 p-5 flex items-start gap-3 hover:border-slate-300 hover:shadow-sm transition-all">
        ${photo}
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-navy leading-tight mb-1">${escapeHtml(m.name || '—')}</div>
          <div class="text-[12px] text-slate-400 mb-1.5">${escapeHtml(m.chapter || '')}</div>
          <div class="flex flex-wrap gap-1">${roleBadge} ${desigBadges}</div>
          ${waButton(m)}
        </div>
      </div>`;
  }

  function waButton(m: any): string {
    if (!m.share_whatsapp) return '';
    if (!currentMember) return '';
    const isSelf = currentMember.id === m.id;
    if (isSelf) return '';
    const isPeer = currentMember.tribe_id === TRIBE_ID
      || membersMap.has(currentMember.id)
      || isHighManagement(currentMember);
    if (!isPeer) return '';
    return `<a href="#" data-action="open-wa" data-member-id="${m.id}"
      class="inline-flex items-center gap-1 mt-1.5 px-2 py-1 rounded-lg bg-[#25D366]/10 text-[#25D366] text-[.65rem] font-bold no-underline hover:bg-[#25D366]/20 transition-all"
      title="${I18N.chatWhatsApp || 'WhatsApp'}">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      ${I18N.chatWhatsApp || 'WhatsApp'}
    </a>`;
  }

  // ── Progress bar ──
  function progressBarHtml(items: any[]): string {
    const total = items.length;
    if (total === 0) return '';

    const completed = items.filter(d => d.status === 'completed').length;
    const inProgress = items.filter(d => d.status === 'in_progress').length;
    const planned = items.filter(d => d.status === 'planned').length;
    const pctCompleted = Math.round((completed / total) * 100);
    const pctInProgress = Math.round((inProgress / total) * 100);

    return `
      <div class="bg-white rounded-2xl border border-slate-200 p-4 mb-4">
        <div class="flex items-center gap-3 text-[13px] font-semibold mb-2 flex-wrap">
          <span class="text-emerald-700">${completed}/${total} ${I18N.progressCompleted}</span>
          <span class="text-slate-300">|</span>
          <span class="text-blue-700">${inProgress} ${I18N.progressInProgress}</span>
          <span class="text-slate-300">|</span>
          <span class="text-slate-500">${planned} ${I18N.progressPlanned}</span>
        </div>
        <div class="w-full h-2.5 bg-slate-100 rounded-full overflow-hidden flex">
          <div class="h-full bg-emerald-500 transition-all" style="width:${pctCompleted}%"></div>
          <div class="h-full bg-blue-400 transition-all" style="width:${pctInProgress}%"></div>
        </div>
      </div>`;
  }

  // ── Deliverables tab ──
  function renderDeliverables(items: any[]) {
    const el = document.getElementById('panel-deliverables');
    if (!el) return;

    allDeliverables = items;

    const addBtn = canEdit
      ? `<div class="flex justify-end mb-4"><button data-action="add-deliverable" class="px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">${I18N.addDeliverable}</button></div>`
      : '';

    if (!items.length) {
      el.innerHTML = `
        ${addBtn}
        <div class="text-center py-14">
          <div class="text-4xl mb-3">📦</div>
          <div class="font-semibold text-slate-500 text-sm">${I18N.noDeliverables}</div>
        </div>`;
      return;
    }

    el.innerHTML = `
      ${addBtn}
      ${progressBarHtml(items)}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${items.map(deliverableCardHtml).join('')}</div>`;
  }

  const STATUS_TRANSITIONS: Record<string, string[]> = {
    planned:     ['in_progress', 'cancelled'],
    in_progress: ['completed', 'planned'],
    completed:   ['in_progress'],
    cancelled:   ['planned'],
  };
  const MOVE_LABELS: Record<string, string> = {
    in_progress: I18N.moveToInProgress || 'Start',
    completed: I18N.moveToCompleted || 'Complete',
    planned: I18N.moveToPlanned || 'Replan',
    cancelled: I18N.moveToCancelled || 'Cancel',
  };
  const MOVE_STYLES: Record<string, string> = {
    in_progress: 'bg-blue-50 text-blue-700 hover:bg-blue-100',
    completed: 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100',
    planned: 'bg-slate-50 text-slate-600 hover:bg-slate-100',
    cancelled: 'bg-red-50 text-red-600 hover:bg-red-100',
  };

  function deliverableCardHtml(d: any): string {
    const status = d.status || 'planned';
    const sc = STATUS_COLORS[status] || STATUS_COLORS.planned;
    const statusLabel = STATUS_LABELS[status] || status;

    const assignee = d.assigned_member_id && membersMap.has(d.assigned_member_id)
      ? escapeHtml(membersMap.get(d.assigned_member_id)?.name || '')
      : `<span class="text-slate-400">${I18N.unassigned}</span>`;

    const dueDateStr = d.due_date
      ? new Date(d.due_date + 'T00:00:00').toLocaleDateString(I18N.dateLocale || 'pt-BR', { day: '2-digit', month: 'short' })
      : I18N.noDueDate;

    let actionsHtml = '';
    if (canEdit) {
      const transitions = STATUS_TRANSITIONS[status] || [];
      const toggleBtns = transitions.map(s =>
        `<button data-action="status-toggle" data-deliverable-id="${d.id}" data-new-status="${s}" class="px-2 py-0.5 rounded text-[10px] font-bold cursor-pointer border-0 transition-all ${MOVE_STYLES[s] || ''}">${MOVE_LABELS[s] || s}</button>`
      ).join('');
      actionsHtml = `
        <div class="flex items-center gap-1.5 flex-wrap mt-2 pt-2 border-t border-slate-100">
          <button data-action="edit-deliverable" data-deliverable-id="${d.id}" class="px-2 py-0.5 rounded text-[10px] font-bold cursor-pointer border-0 bg-purple/10 text-purple hover:bg-purple/20 transition-all">${I18N.editDeliverable || 'Edit'}</button>
          ${toggleBtns}
        </div>`;
    }

    return `
      <div class="bg-white rounded-2xl border border-slate-100 p-5 flex flex-col hover:border-slate-300 hover:shadow-sm transition-all">
        <div class="flex items-center justify-between gap-2 mb-2">
          <span class="text-[11px] font-bold uppercase tracking-wide text-slate-400">${I18N.dueDate}: ${escapeHtml(dueDateStr)}</span>
          <span class="${sc.bg} ${sc.text} px-2.5 py-0.5 rounded-full text-[11px] font-bold">${escapeHtml(statusLabel)}</span>
        </div>
        <h3 class="text-[15px] font-bold text-navy leading-snug mb-1">${escapeHtml(d.title)}</h3>
        ${d.description ? `<p class="text-[12.5px] text-slate-500 leading-relaxed mb-2">${escapeHtml(d.description.length > 140 ? d.description.slice(0, 137) + '…' : d.description)}</p>` : ''}
        <div class="mt-auto pt-3 text-[12px] text-slate-400">
          <span class="font-semibold">${I18N.assignee}:</span> ${assignee}
        </div>
        ${actionsHtml}
      </div>`;
  }

  // ── Resources tab ──
  function renderResources(items: any[]) {
    const el = document.getElementById('panel-resources');
    if (!el) return;

    if (!items.length) {
      el.innerHTML = `
        <div class="text-center py-14">
          <div class="text-4xl mb-3">📚</div>
          <div class="font-semibold text-slate-500 text-sm">${I18N.noResources}</div>
        </div>`;
      return;
    }

    el.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${items.map(resourceCardHtml).join('')}</div>`;
  }

  function resourceCardHtml(r: any): string {
    const icon = TYPE_ICONS[r.asset_type] || '📎';
    const desc = r.description
      ? escapeHtml(r.description.length > 120 ? r.description.slice(0, 117) + '…' : r.description)
      : '';
    const link = r.url
      ? `<a href="${escapeHtml(r.url)}" target="_blank" rel="noopener"
            class="inline-flex items-center gap-1 text-teal text-[13px] font-semibold no-underline hover:underline mt-auto pt-3">${I18N.openLink}</a>`
      : '';
    return `
      <div class="bg-white rounded-2xl border border-slate-100 p-5 flex flex-col hover:border-slate-300 hover:shadow-sm transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xl leading-none">${icon}</span>
          <span class="text-[11px] font-bold uppercase tracking-wide text-slate-400">${escapeHtml(r.asset_type)}</span>
        </div>
        <h3 class="text-[15px] font-bold text-navy leading-snug mb-1">${escapeHtml(r.title)}</h3>
        ${desc ? `<p class="text-[12.5px] text-slate-500 leading-relaxed mb-0">${desc}</p>` : ''}
        ${link}
      </div>`;
  }

  // ── Modal helpers ──
  function openDeliverableModal(deliverable?: any) {
    const modal = document.getElementById('deliverable-modal');
    if (!modal) return;

    const titleEl = document.getElementById('deliverable-modal-title') as HTMLElement;
    const idInput = document.getElementById('dlv-id') as HTMLInputElement;
    const titleInput = document.getElementById('dlv-title') as HTMLInputElement;
    const descInput = document.getElementById('dlv-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('dlv-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('dlv-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('dlv-assignee') as HTMLSelectElement;
    const artifactSelect = document.getElementById('dlv-artifact') as HTMLSelectElement;

    // Labels
    titleEl.textContent = deliverable ? I18N.modalEditTitle : I18N.modalAddTitle;
    (document.getElementById('lbl-dlv-title') as HTMLElement).textContent = I18N.modalLabelTitle;
    (document.getElementById('lbl-dlv-description') as HTMLElement).textContent = I18N.modalLabelDescription;
    (document.getElementById('lbl-dlv-status') as HTMLElement).textContent = I18N.modalLabelStatus;
    (document.getElementById('lbl-dlv-due-date') as HTMLElement).textContent = I18N.modalLabelDueDate;
    (document.getElementById('lbl-dlv-assignee') as HTMLElement).textContent = I18N.modalLabelAssignee;
    (document.getElementById('lbl-dlv-artifact') as HTMLElement).textContent = I18N.modalLabelArtifact;
    (document.getElementById('btn-dlv-cancel') as HTMLElement).textContent = I18N.modalCancel;
    (document.getElementById('btn-dlv-save') as HTMLElement).textContent = I18N.modalSave;

    // Status dropdown
    statusSelect.innerHTML = [
      { v: 'planned', l: I18N.statusPlanned },
      { v: 'in_progress', l: I18N.statusInProgress },
      { v: 'completed', l: I18N.statusCompleted },
      { v: 'cancelled', l: I18N.statusCancelled },
    ].map(o => `<option value="${o.v}">${escapeHtml(o.l)}</option>`).join('');

    // Assignee dropdown
    assigneeSelect.innerHTML = `<option value="">${escapeHtml(I18N.modalSelectMember)}</option>` +
      Array.from(membersMap.values())
        .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''))
        .map((m: any) => `<option value="${m.id}">${escapeHtml(m.name)}</option>`)
        .join('');

    // Artifact dropdown
    artifactSelect.innerHTML = `<option value="">${escapeHtml(I18N.modalSelectArtifact)}</option>` +
      publishedArtifacts
        .map((a: any) => `<option value="${a.id}">${escapeHtml(a.title)}</option>`)
        .join('');

    // Fill values
    idInput.value = deliverable?.id || '';
    titleInput.value = deliverable?.title || '';
    descInput.value = deliverable?.description || '';
    statusSelect.value = deliverable?.status || 'planned';
    dueDateInput.value = deliverable?.due_date || '';
    assigneeSelect.value = deliverable?.assigned_member_id || '';
    artifactSelect.value = deliverable?.artifact_id || '';

    modal.classList.remove('hidden');
  }

  function closeDeliverableModal() {
    document.getElementById('deliverable-modal')?.classList.add('hidden');
  }

  async function saveDeliverable() {
    const idInput = document.getElementById('dlv-id') as HTMLInputElement;
    const titleInput = document.getElementById('dlv-title') as HTMLInputElement;
    const descInput = document.getElementById('dlv-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('dlv-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('dlv-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('dlv-assignee') as HTMLSelectElement;
    const artifactSelect = document.getElementById('dlv-artifact') as HTMLSelectElement;

    const title = titleInput.value.trim();
    if (!title) {
      (window as any).toast?.(I18N.modalTitleRequired, 'error');
      return;
    }

    const params: any = {
      p_tribe_id: TRIBE_ID,
      p_cycle_code: 'cycle_3',
      p_title: title,
      p_description: descInput.value.trim() || null,
      p_status: statusSelect.value,
      p_assigned_member_id: assigneeSelect.value || null,
      p_artifact_id: artifactSelect.value || null,
      p_due_date: dueDateInput.value || null,
    };

    if (idInput.value) params.p_id = idInput.value;

    const { error } = await sb.rpc('upsert_tribe_deliverable', params);
    if (error) {
      console.error('upsert_tribe_deliverable error:', error);
      (window as any).toast?.(I18N.msgSaveError, 'error');
      return;
    }

    (window as any).toast?.(I18N.msgSaved, 'success');
    closeDeliverableModal();
    await reloadDeliverables();
  }

  async function toggleDeliverableStatus(deliverableId: string, newStatus: string) {
    const d = allDeliverables.find((x: any) => x.id === deliverableId);
    if (!d) return;

    const { error } = await sb.rpc('upsert_tribe_deliverable', {
      p_id: deliverableId,
      p_tribe_id: TRIBE_ID,
      p_cycle_code: d.cycle_code || 'cycle_3',
      p_title: d.title,
      p_description: d.description,
      p_status: newStatus,
      p_assigned_member_id: d.assigned_member_id,
      p_artifact_id: d.artifact_id,
      p_due_date: d.due_date,
    });

    if (error) {
      console.error('status toggle error:', error);
      (window as any).toast?.(I18N.msgStatusError, 'error');
      return;
    }

    (window as any).toast?.(I18N.msgStatusUpdated, 'success');
    await reloadDeliverables();
  }

  async function reloadDeliverables() {
    const { data } = await sb.rpc('list_tribe_deliverables', { p_tribe_id: TRIBE_ID, p_cycle_code: 'cycle_3' });
    renderDeliverables(Array.isArray(data) ? data : []);
  }

  // ── Event delegation ──
  if (!(window as any).__tribeDelegationBound) {
    (window as any).__tribeDelegationBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      const action = target.dataset.action;

      if (action === 'switch-tab') {
        const tab = target.dataset.tab;
        if (tab) switchTab(tab);
      }

      if (action === 'add-deliverable') {
        openDeliverableModal();
      }

      if (action === 'edit-deliverable') {
        const dId = target.dataset.deliverableId;
        const d = allDeliverables.find((x: any) => x.id === dId);
        if (d) openDeliverableModal(d);
      }

      if (action === 'status-toggle') {
        const dId = target.dataset.deliverableId;
        const newStatus = target.dataset.newStatus;
        if (dId && newStatus) toggleDeliverableStatus(dId, newStatus);
      }

      if (action === 'close-deliverable-modal') {
        closeDeliverableModal();
      }

      if (action === 'send-broadcast') {
        sendBroadcast();
      }

      if (action === 'open-wa') {
        e.preventDefault();
        const memberId = target.dataset.memberId;
        if (!memberId || !sb) return;
        (async () => {
          const { data } = await sb.rpc('resolve_whatsapp_link', { p_member_id: memberId });
          if (data?.success && data?.url) {
            window.open(data.url, '_blank', 'noopener');
          } else {
            (window as any).toast?.(data?.error || 'Error', 'error');
          }
        })();
      }
    });

    document.addEventListener('submit', (e: SubmitEvent) => {
      if ((e.target as HTMLElement)?.id === 'deliverable-form') {
        e.preventDefault();
        saveDeliverable();
      }
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeDeliverableModal();
    });
  }

  // ── Broadcast tab (leader + admin only) ──
  let broadcastShown = false;

  function showBroadcastTab() {
    if (broadcastShown) return;
    broadcastShown = true;
    const tabs = document.getElementById('tribe-tabs');
    if (tabs) {
      const btn = document.createElement('button');
      btn.className = 'tribe-tab px-4 py-2 rounded-xl text-[13px] font-semibold cursor-pointer border-0 bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all';
      btn.dataset.action = 'switch-tab';
      btn.dataset.tab = 'broadcast';
      btn.textContent = I18N.broadcastTab || 'Comunicados';
      tabs.appendChild(btn);
    }
  }

  function checkBroadcastAccess() {
    if (!currentMember) return;
    const isLeaderOfThisTribe = currentMember.operational_role === 'tribe_leader'
      && currentMember.tribe_id === TRIBE_ID;
    if (isLeaderOfThisTribe || isHighManagement(currentMember)) {
      showBroadcastTab();
      renderBroadcastPanel();
    }
  }

  function renderBroadcastPanel() {
    const el = document.getElementById('panel-broadcast');
    if (!el) return;
    const BC = I18N.broadcast || {};
    el.innerHTML = `
      <div class="space-y-6">
        <div class="bg-white rounded-2xl border border-slate-200 p-6">
          <h2 class="text-lg font-extrabold text-navy mb-1">${BC.title || 'Enviar Comunicado'}</h2>
          <p class="text-[13px] text-slate-400 mb-4">${BC.subtitle || ''}</p>
          <div class="space-y-3">
            <div>
              <label class="text-[13px] font-semibold text-slate-600 block mb-1">${BC.subject || 'Assunto'}</label>
              <input type="text" id="bc-subject" placeholder="${BC.subjectPlaceholder || ''}"
                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
            </div>
            <div>
              <label class="text-[13px] font-semibold text-slate-600 block mb-1">${BC.body || 'Mensagem'}</label>
              <textarea id="bc-body" rows="6" placeholder="${BC.bodyPlaceholder || ''}"
                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40 resize-y"></textarea>
            </div>
            <div class="flex justify-end">
              <button data-action="send-broadcast" id="btn-send-broadcast"
                class="px-5 py-2.5 bg-purple text-white rounded-xl text-[14px] font-bold cursor-pointer border-0 hover:opacity-90 transition-all">
                ${BC.send || 'Enviar'}
              </button>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-6">
          <h3 class="text-[15px] font-bold text-navy mb-3">${BC.historyTitle || 'Histórico'}</h3>
          <div id="bc-history-list" class="text-center py-6 text-slate-400 text-sm">${BC.historyEmpty || 'Nenhum comunicado.'}</div>
        </div>
      </div>`;
    loadBroadcastHistory();
  }

  async function loadBroadcastHistory() {
    if (!sb) return;
    const { data } = await sb
      .from('broadcast_log')
      .select('id, subject, recipient_count, status, sent_at')
      .eq('tribe_id', TRIBE_ID)
      .order('sent_at', { ascending: false })
      .limit(20);
    const el = document.getElementById('bc-history-list');
    if (!el) return;
    const BC = I18N.broadcast || {};
    if (!data?.length) {
      el.innerHTML = `<div class="text-center py-6 text-slate-400 text-sm">${BC.historyEmpty || 'Nenhum comunicado.'}</div>`;
      return;
    }
    const locale = I18N.dateLocale || 'pt-BR';
    el.innerHTML = `<div class="divide-y divide-slate-100">${data.map((b: any) => {
      const date = new Date(b.sent_at).toLocaleString(locale, { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit' });
      const statusColor = b.status === 'sent' ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-600';
      return `<div class="flex items-center gap-3 py-3">
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-[13px] text-navy truncate">${escapeHtml(b.subject)}</div>
          <div class="text-[11px] text-slate-400">${date} · ${b.recipient_count} ${BC.historyRecipients || 'destinatários'}</div>
        </div>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded ${statusColor} uppercase">${b.status}</span>
      </div>`;
    }).join('')}</div>`;
  }

  async function sendBroadcast() {
    if (!sb || !currentMember) return;
    const BC = I18N.broadcast || {};
    const subjectEl = document.getElementById('bc-subject') as HTMLInputElement;
    const bodyEl = document.getElementById('bc-body') as HTMLTextAreaElement;
    const btnEl = document.getElementById('btn-send-broadcast') as HTMLButtonElement;
    if (!subjectEl || !bodyEl) return;

    const subject = subjectEl.value.trim();
    const body = bodyEl.value.trim();

    if (!subject) { (window as any).toast?.(BC.subjectRequired || 'Assunto obrigatório', 'error'); return; }
    if (!body) { (window as any).toast?.(BC.bodyRequired || 'Mensagem obrigatória', 'error'); return; }

    if (!confirm((BC.confirmMsg || 'Enviar para todos os membros ativos?'))) return;

    if (btnEl) { btnEl.disabled = true; btnEl.textContent = BC.sending || 'Enviando...'; }

    try {
      const sess = await sb.auth.getSession();
      const jwt = sess?.data?.session?.access_token || '';
      if (!jwt) { (window as any).toast?.('Sessao expirada', 'error'); return; }

      const fnBase = (sb as any).functionsUrl?.toString?.() || (sb as any).supabaseUrl + '/functions/v1';
      const fnUrl = fnBase.replace(/\/$/, '') + '/send-tribe-broadcast';
      const ak = (sb as any).supabaseKey || '';

      console.log('[broadcast] POST', fnUrl, 'jwt:', jwt.length, 'ak:', ak.length);

      const res = await fetch(fnUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt, 'apikey': ak },
        body: JSON.stringify({ tribe_id: TRIBE_ID, subject: subject, body: body }),
      });

      const txt = await res.text();
      console.log('[broadcast] status:', res.status, 'body:', txt);

      let data: any = {};
      try { data = JSON.parse(txt); } catch (_) { data = { success: false, error: 'Resposta invalida: ' + txt.substring(0, 200) }; }

      if (!res.ok || !data.success) {
        (window as any).toast?.(data.error || data.detail || BC.error || 'Erro', 'error');
        return;
      }

      const msg = (BC.sent || 'Enviado para {count} membros!').replace('{count}', String(data.recipient_count));
      (window as any).toast?.(msg, 'success');
      subjectEl.value = '';
      bodyEl.value = '';
      loadBroadcastHistory();
    } catch (e: any) {
      (window as any).toast?.(BC.error || 'Erro ao enviar', 'error');
      console.error('Broadcast error:', e);
    } finally {
      if (btnEl) { btnEl.disabled = false; btnEl.textContent = BC.send || 'Enviar'; }
    }
  }

  // ── Boot ──
  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    try {
      // Resolve current user for edit permissions
      const m = (window as any).navGetMember?.();
      if (m) {
        currentMember = m;
      } else {
        const { data: { session } } = await sb.auth.getSession();
        if (session) {
          const { data } = await sb.rpc('get_member_by_auth');
          if (data) currentMember = data;
        }
      }

      // Also listen for async member resolution
      window.addEventListener('nav:member', ((evt: Event) => {
        const e = evt as CustomEvent;
        currentMember = e.detail;
        checkEditPermission();
        checkCommsHubAccess();
        checkBroadcastAccess();
      }) as EventListener);

      checkEditPermission();
      checkCommsHubAccess();
      checkBroadcastAccess();

      // Load all tribe data in parallel
      const [tribeRes, slotsRes, membersRes, selectionsRes, delivRes, resourcesRes, artifactsRes] = await Promise.all([
        sb.from('tribes').select('*').eq('id', TRIBE_ID).single(),
        sb.from('tribe_meeting_slots').select('day_of_week, time_start, time_end').eq('tribe_id', TRIBE_ID).eq('is_active', true).order('day_of_week'),
        sb.from('public_members').select('id, name, photo_url, chapter, operational_role, designations, tribe_id, share_whatsapp').eq('tribe_id', TRIBE_ID),
        sb.from('tribe_selections').select('member_id').eq('tribe_id', TRIBE_ID),
        sb.rpc('list_tribe_deliverables', { p_tribe_id: TRIBE_ID, p_cycle_code: 'cycle_3' }),
        sb.from('hub_resources').select('*').eq('tribe_id', TRIBE_ID).eq('is_active', true).order('created_at', { ascending: false }),
        sb.from('artifacts').select('id, title').eq('status', 'published').order('title'),
      ]);

      publishedArtifacts = artifactsRes.data || [];

      tribeData = tribeRes.data;

      // Find tribe leader
      const allDirectMembers: any[] = membersRes.data || [];
      const leader = allDirectMembers.find((m: any) => m.operational_role === 'tribe_leader') || null;

      // Render header
      renderHeader(tribeRes.data, leader, slotsRes.data || []);

      // Merge members: direct (tribe_id set) + selections
      const directIds = new Set(allDirectMembers.map((m: any) => m.id));
      const selectionMemberIds = (selectionsRes.data || [])
        .map((s: any) => s.member_id)
        .filter((id: string) => !directIds.has(id));

      let selectionMembers: any[] = [];
      if (selectionMemberIds.length > 0) {
        const { data } = await sb.from('public_members')
          .select('id, name, photo_url, chapter, operational_role, designations, tribe_id, share_whatsapp')
          .in('id', selectionMemberIds);
        selectionMembers = data || [];
      }

      const allMembers = [...allDirectMembers, ...selectionMembers];
      allMembers.sort((a: any, b: any) => {
        if (a.operational_role === 'tribe_leader') return -1;
        if (b.operational_role === 'tribe_leader') return 1;
        return (a.name || '').localeCompare(b.name || '');
      });

      // Build members map for deliverable assignee lookup
      allMembers.forEach((m: any) => membersMap.set(m.id, m));

      renderMembers(allMembers);

      // Deliverables
      const deliverables = Array.isArray(delivRes.data) ? delivRes.data : [];
      renderDeliverables(deliverables);

      // Resources
      renderResources(resourcesRes.data || []);

    } catch (e: any) {
      console.error('Tribe dashboard error:', e);
      (window as any).toast?.(I18N.error, 'error');
      const header = document.getElementById('tribe-header');
      if (header) {
        header.innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-2xl p-6 text-center">
            <div class="text-2xl mb-2">⚠️</div>
            <p class="font-semibold text-red-700 text-sm">${I18N.error}</p>
          </div>`;
      }
    }
  }

  // R1: Admin global — PM, Deputy PM and SuperAdmin can edit any tribe
  function checkEditPermission() {
    if (!currentMember) return;
    canEdit = isHighManagement(currentMember) ||
      (currentMember.operational_role === 'tribe_leader' && currentMember.tribe_id === TRIBE_ID);
  }

  // R2: Comms Hub tab — shown if member has comms_team designation or is high management
  function checkCommsHubAccess() {
    if (!currentMember) return;
    const desigs: string[] = currentMember.designations || [];
    if (desigs.includes('comms_team') || isHighManagement(currentMember)) {
      showCommsHubTab();
      renderCommsHub();
    }
  }

  boot();
</script>
