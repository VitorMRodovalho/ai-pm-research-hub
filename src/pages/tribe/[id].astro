  async function loadBroadcastHistory() {
    if (!sb || !INITIATIVE_ID) return;
    const { data } = await sb.from('broadcast_log')
      .select('id, subject, recipient_count, status, sent_at')
      .eq('initiative_id', INITIATIVE_ID)
      .order('sent_at', { ascending: false })
      .limit(20);
    const el = document.getElementById('bc-history-list');
    if (!el) return;
    const BC = I18N.broadcast || {};
    if (!data?.length) {
      el.innerHTML = `<div class="text-center py-6 text-[var(--text-muted)] text-sm">${BC.historyEmpty || 'Nenhum comunicado.'}</div>`;
      return;
    }
    const locale = I18N.dateLocale || 'pt-BR';
    el.innerHTML = `<div class="divide-y divide-[var(--border-subtle)]">${data.map((b: any) => {
      const date = new Date(b.sent_at).toLocaleString(locale, { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit' });
      const statusColor = b.status === 'sent' ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-600';
      return `<div class="flex items-center gap-3 py-3">
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-[13px] text-navy truncate">${escapeHtml(b.subject)}</div>
          <div class="text-[11px] text-[var(--text-muted)]">${date} · ${b.recipient_count} ${BC.historyRecipients || 'destinatários'}</div>
        </div>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded ${statusColor} uppercase">${b.status}</span>
      </div>`;
    }).join('')}</div>`;
  }

  async function sendBroadcast() {
    if (!sb || !currentMember) return;
    const BC = I18N.broadcast || {};
    const subjectEl = document.getElementById('bc-subject') as HTMLInputElement;
    const bodyEl = document.getElementById('bc-body') as HTMLTextAreaElement;
    const btnEl = document.getElementById('btn-send-broadcast') as HTMLButtonElement;
    if (!subjectEl || !bodyEl) return;

    const subject = subjectEl.value.trim();
    const body = bodyEl.value.trim();

    if (!subject) { (window as any).toast?.(BC.subjectRequired || 'Assunto obrigatório', 'error'); return; }
    if (!body) { (window as any).toast?.(BC.bodyRequired || 'Mensagem obrigatória', 'error'); return; }

    if (!(await (window as any).confirmAction((BC.confirmMsg || 'Enviar para todos os membros ativos?')))) return;

    if (btnEl) { btnEl.disabled = true; btnEl.textContent = BC.sending || 'Enviando...'; }

    try {
      const sess = await sb.auth.getSession();
      const jwt = sess?.data?.session?.access_token || '';
      if (!jwt) { (window as any).toast?.('Sessao expirada', 'error'); return; }

      const fnBase = (sb as any).functionsUrl?.toString?.() || (sb as any).supabaseUrl + '/functions/v1';
      const fnUrl = fnBase.replace(/\/$/, '') + '/send-tribe-broadcast';
      const ak = (sb as any).supabaseKey || '';

      if (import.meta.env.DEV) console.log('[broadcast] POST', fnUrl, 'jwt:', jwt.length, 'ak:', ak.length);

      const res = await fetch(fnUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt, 'apikey': ak },
        body: JSON.stringify({
          tribe_id: TRIBE_ID,
          subject: subject,
          body: body,
          cc_management: (document.getElementById('bc-cc-mgmt') as HTMLInputElement)?.checked !== false,
        }),
      });

      const txt = await res.text();
      if (import.meta.env.DEV) console.log('[broadcast] status:', res.status, 'body:', txt);

      let data: any = {};
      try { data = JSON.parse(txt); } catch (_) { data = { success: false, error: 'Resposta invalida: ' + txt.substring(0, 200) }; }

      if (!res.ok || !data.success) {
        (window as any).toast?.(data.error || data.detail || BC.error || 'Erro', 'error');
        return;
      }

      const msg = (BC.sent || 'Enviado para {count} membros!').replace('{count}', String(data.recipient_count));
      (window as any).toast?.(msg, 'success');
      subjectEl.value = '';
      bodyEl.value = '';
      loadBroadcastHistory();
    } catch (e: any) {
      (window as any).toast?.(BC.error || 'Erro ao enviar', 'error');
      console.error('Broadcast error:', e);
    } finally {
      if (btnEl) { btnEl.disabled = false; btnEl.textContent = BC.send || 'Enviar'; }
    }
  }

  // ── Boot ──
  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    // Register nav:member listener early so late-injected auth (e.g. E2E mocks) can reveal shell
    const onNavMember = (async (evt: Event) => {
      const e = evt as CustomEvent;
      currentMember = e.detail;
      if (!canExploreTribes(currentMember)) {
        showDenied(I18N.accessRestricted || 'Access restricted to active platform members.');
        return;
      }
      revealTribeShell();
      checkEditPermission();
      checkBroadcastAccess();
      renderAccessNote();
      if (currentMember && !Object.keys(contactData).length
          && (isHighManagement(currentMember)
              || (hasPermission(currentMember, 'board.edit_tribe_items')
                  && currentMember.tribe_id === TRIBE_ID))) {
        try {
          const { data: cd } = INITIATIVE_ID
              ? await sb.rpc('get_initiative_member_contacts', { p_initiative_id: INITIATIVE_ID })
              : await sb.rpc('get_tribe_member_contacts', { p_tribe_id: TRIBE_ID });
          const parsed = typeof cd === 'string' ? JSON.parse(cd) : cd;
          if (parsed && typeof parsed === 'object') {
            contactData = parsed;
            const members = Array.from(membersMap.values());
            members.sort((a: any, b: any) => {
              if (a.operational_role === 'tribe_leader') return -1;
              if (b.operational_role === 'tribe_leader') return 1;
              if (a.operational_role === 'comms_leader') return -1;
              if (b.operational_role === 'comms_leader') return 1;
              return (a.name || '').localeCompare(b.name || '');
            });
            renderMembers(members);
          }
        } catch (_) { /* non-critical */ }
      }
    }) as EventListener;
    if (!(window as any).__tribe_nav_member_bound) {
      (window as any).__tribe_nav_member_bound = true;
      window.addEventListener('nav:member', onNavMember);
    }

    try {
      const cycles = await loadCycles(sb);
      currentCycleCode = getCurrentCycle(cycles)?.cycle_code || '';

      // Resolve current user for edit permissions
      const m = (window as any).navGetMember?.();
      if (m) {
        currentMember = m;
      } else {
        const { data: { session } } = await sb.auth.getSession();
        if (session) {
          const { data } = await sb.rpc('get_member_by_auth');
          if (data) currentMember = data;
        }
      }

      if (!canExploreTribes(currentMember)) {
        showDenied(I18N.accessRestricted || 'Access restricted to active platform members.');
        return;
      }

      // V4: resolve initiative_id early (non-blocking, used by _by_initiative RPCs below)
      await resolveInitiativeId();

      revealTribeShell();
      const urlTab = new URLSearchParams(window.location.search).get('tab');
      const validTabs = ['general', 'board', 'members', 'gamification', 'attendance'];
      switchTab(urlTab && validTabs.includes(urlTab) ? urlTab : 'general');
      checkEditPermission();
      checkBroadcastAccess();
      renderAccessNote();

      // Load all tribe data in parallel
      const activeCycleCode = getActiveCycleCode();
      const [tribeRes, slotsRes, membersRes, selectionsRes, delivRes, resourcesRes, artifactsRes] = await Promise.all([
        sb.from('tribes').select('*').eq('id', TRIBE_ID).single(),
        sb.from('tribe_meeting_slots').select('day_of_week, time_start, time_end').eq('tribe_id', TRIBE_ID).eq('is_active', true).order('day_of_week'),
        INITIATIVE_ID
          ? sb.from('public_members')
              .select('id, name, photo_url, chapter, operational_role, designations, tribe_id, initiative_id, share_whatsapp, current_cycle_active, is_active')
              .eq('initiative_id', INITIATIVE_ID)
              .eq('current_cycle_active', true)
              .eq('is_active', true)
          : sb.from('public_members')
              .select('id, name, photo_url, chapter, operational_role, designations, tribe_id, initiative_id, share_whatsapp, current_cycle_active, is_active')
              .eq('tribe_id', TRIBE_ID)
              .eq('current_cycle_active', true)
              .eq('is_active', true),
        sb.from('tribe_selections').select('member_id').eq('tribe_id', TRIBE_ID),
        activeCycleCode
          ? (INITIATIVE_ID
              ? sb.rpc('list_initiative_deliverables', { p_initiative_id: INITIATIVE_ID, p_cycle_code: activeCycleCode })
              : sb.rpc('list_tribe_deliverables', { p_tribe_id: TRIBE_ID, p_cycle_code: activeCycleCode }))
          : Promise.resolve({ data: [] }),
        INITIATIVE_ID
          ? sb.from('hub_resources').select('*').eq('initiative_id', INITIATIVE_ID).eq('is_active', true).order('created_at', { ascending: false })
          : Promise.resolve({ data: [] }),
        sb.from('artifacts').select('id, title').eq('status', 'published').order('title'),
      ]);

      publishedArtifacts = artifactsRes.data || [];

      tribeData = tribeRes.data;
      if (!tribeData) {
        showDenied(I18N.notFound || 'Tribo não encontrada.');
        return;
      }
      if (tribeData.is_active === false) {
        if (!canSeeInactiveTribes(currentMember)) {
          showDenied(I18N.tribeInactive || 'This research stream is inactive this cycle.');
          return;
        }
        // Superadmin can see but show banner
        const bannerEl = document.createElement('div');
        bannerEl.className = 'rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 mb-4 text-sm text-amber-800';
        bannerEl.innerHTML = '⚠️ <strong>' + (I18N.tribeInactiveBanner || 'Inactive') + '</strong>';
        const content = document.getElementById('tribe-content');
        if (content) content.prepend(bannerEl);
      }

      // Find tribe leader
      const allDirectMembers: any[] = membersRes.data || [];
      headerLeader = allDirectMembers.find((m: any) => m.operational_role === 'tribe_leader') || null;
      headerSlots = slotsRes.data || [];

      // Render header
      renderHeader(tribeRes.data, headerLeader, headerSlots);

      // G6: Auto-complete 'meet_tribe' onboarding step when visiting own tribe
      if (currentMember && currentMember.tribe_id === TRIBE_ID) {
        Promise.resolve(getSb()?.rpc('complete_onboarding_step', { p_step_id: 'meet_tribe' })).catch(() => {});
      }

      // Cross-tribe banner (defensive — never breaks page load)
      try {
        if (currentMember) {
          const tp = getTribePermissions(currentMember, TRIBE_ID);
          const banner = document.getElementById('cross-tribe-banner');
          const tribeName = tribeData?.name || `Tribo ${TRIBE_ID}`;
          if (banner) {
            if (tp.showCuratorBanner) {
              banner.className = 'rounded-xl px-4 py-3 text-sm mb-4 flex items-center gap-2 bg-purple-50 border border-purple-200 text-purple-800';
              banner.innerHTML = `<span class="text-base">🔍</span> <span><strong>${I18N.curatorAccess || 'Acesso de Curadoria'}:</strong> ${tribeName}</span>`;
              banner.classList.remove('hidden');
            } else if (tp.showCrossTribeBanner) {
              banner.className = 'rounded-xl px-4 py-3 text-sm mb-4 flex items-center gap-2 bg-blue-50 border border-blue-200 text-blue-800';
              banner.innerHTML = `<span class="text-base">🔍</span> <span><strong>${I18N.viewingOther || 'Visualizando'}:</strong> ${tribeName}</span>`;
              banner.classList.remove('hidden');
            }
          }
        }
      } catch (bannerErr) { console.warn('Cross-tribe banner error:', bannerErr); }

      // Merge members: direct (tribe_id set) + selections
      const directIds = new Set(allDirectMembers.map((m: any) => m.id));
      const selectionMemberIds = (selectionsRes.data || [])
        .map((s: any) => s.member_id)
        .filter((id: string) => !directIds.has(id));

      let selectionMembers: any[] = [];
      if (selectionMemberIds.length > 0) {
        const { data } = await sb.from('public_members')
          .select('id, name, photo_url, chapter, operational_role, designations, tribe_id, share_whatsapp, current_cycle_active, is_active')
          .in('id', selectionMemberIds)
          .eq('current_cycle_active', true)
          .eq('is_active', true);
        selectionMembers = data || [];
      }

      const allMembers = [...allDirectMembers, ...selectionMembers];
      if (!canSeeInactiveTribes(currentMember) && tribeData.is_active !== true && allMembers.length === 0 && !isAssignedToCurrentTribe(currentMember)) {
        showDenied('Esta tribo não está ativa no ciclo atual para exploração geral.');
        return;
      }
      allMembers.sort((a: any, b: any) => {
        if (a.operational_role === 'tribe_leader') return -1;
        if (b.operational_role === 'tribe_leader') return 1;
        if (a.operational_role === 'comms_leader') return -1;
        if (b.operational_role === 'comms_leader') return 1;
        return (a.name || '').localeCompare(b.name || '');
      });

      // Build members map for deliverable assignee lookup
      allMembers.forEach((m: any) => membersMap.set(m.id, m));

      // Load contact data for leaders/admins (LGPD-gated RPC)
      if (currentMember && (isHighManagement(currentMember) || (hasPermission(currentMember, 'board.edit_tribe_items') && currentMember.tribe_id === TRIBE_ID))) {
        try {
          const { data: cd } = INITIATIVE_ID
              ? await sb.rpc('get_initiative_member_contacts', { p_initiative_id: INITIATIVE_ID })
              : await sb.rpc('get_tribe_member_contacts', { p_tribe_id: TRIBE_ID });
          const parsed = typeof cd === 'string' ? JSON.parse(cd) : cd;
          if (parsed && typeof parsed === 'object') { contactData = parsed; }
        } catch (_) { /* non-critical */ }
      }

      renderMembers(allMembers);

      // Geral: Radar Global first (uses innerHTML), then Events Timeline (prepends), then Stats (prepends)
      await loadRadarGlobal();
      loadEventsTimeline();
      loadTribeStats();

      // Minutes editor: delegate clicks on edit buttons
      document.getElementById('panel-general')?.addEventListener('click', (evt) => {
        const btn = (evt.target as HTMLElement).closest('[data-action="open-minutes-editor"]') as HTMLElement;
        if (!btn) return;
        window.dispatchEvent(new CustomEvent('open-event-editor', {
          detail: {
            eventId: btn.dataset.eventId,
            eventTitle: btn.dataset.eventTitle,
            mode: btn.dataset.mode || 'minutes',
            initialContent: btn.dataset.content || '',
            initialUrl: '',
          },
        }));
      });

      // Refresh timeline after minutes save
      window.addEventListener('event-editor-saved', () => {
        loadEventsTimeline();
      });

      // Project Board is now handled by React island (TribeKanbanIsland).

    } catch (e: any) {
      console.error('Tribe dashboard error:', e);
      (window as any).toast?.(I18N.error, 'error');
      const header = document.getElementById('tribe-header');
      if (header) {
        header.innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-2xl p-6 text-center">
            <div class="text-2xl mb-2">⚠️</div>
            <p class="font-semibold text-red-700 text-sm">${I18N.error}</p>
          </div>`;
      }
    }
  }

  // R1: Admin global — PM, Deputy PM and SuperAdmin can edit any tribe
  function isCommunicationOperationalTribe(): boolean {
    if (!tribeData) return false;
    const workstream = String(tribeData.workstream_type || '').toLowerCase();
    const name = String(tribeData.name || '').toLowerCase();
    return workstream === 'operational' && name.includes('comunica');
  }

  function checkEditPermission() {
    if (!currentMember) return;
    if (hasPermission(currentMember, 'admin.access')) { canEdit = true; return; }
    const desigs: string[] = currentMember.designations || [];
    const canOperateComms = isCommunicationOperationalTribe()
      && (
        currentMember.operational_role === 'communicator'
        || desigs.includes('comms_team')
        || desigs.includes('comms_leader')
        || desigs.includes('comms_member')
      );
    canEdit = isHighManagement(currentMember) ||
      (hasPermission(currentMember, 'board.edit_tribe_items') && currentMember.tribe_id === TRIBE_ID) ||
      canOperateComms;
  }

  // Comms Hub access check removed — Comms Hub lives at /admin/comms-ops

  // Board/Kanban is handled by TribeKanbanIsland (React dnd-kit)

  document.addEventListener('click', (e: MouseEvent) => {
    const panel = document.getElementById('tribe-context-switch');
    if (!panel || panel.classList.contains('hidden')) return;
    const trigger = (e.target as HTMLElement).closest('[data-action="toggle-context-switch"]');
    if (trigger) return;
    if (!panel.contains(e.target as Node)) {
      panel.classList.add('hidden');
    }
  });

  boot();
