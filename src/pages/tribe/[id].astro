                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
            </div>
            <div>
              <label class="text-[13px] font-semibold text-slate-600 block mb-1">${BC.body || 'Mensagem'}</label>
              <textarea id="bc-body" rows="6" placeholder="${BC.bodyPlaceholder || ''}"
                class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40 resize-y"></textarea>
            </div>
            <div class="flex items-center gap-3 pt-2">
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <input type="checkbox" id="bc-cc-mgmt" checked
                  class="w-4 h-4 rounded border-slate-300 text-purple focus:ring-purple/40" />
                <span class="text-[12px] text-slate-500">${BC.ccMgmt || 'Enviar copia para o time de gestao'}</span>
              </label>
            </div>
            <div class="flex justify-end">
              <button data-action="send-broadcast" id="btn-send-broadcast"
                class="px-5 py-2.5 bg-purple text-white rounded-xl text-[14px] font-bold cursor-pointer border-0 hover:opacity-90 transition-all">
                ${BC.send || 'Enviar'}
              </button>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-6">
          <h3 class="text-[15px] font-bold text-navy mb-3">${BC.historyTitle || 'Histórico'}</h3>
          <div id="bc-history-list" class="text-center py-6 text-slate-400 text-sm">${BC.historyEmpty || 'Nenhum comunicado.'}</div>
        </div>
      </div>`;
    loadBroadcastHistory();
  }

  async function loadBroadcastHistory() {
    if (!sb) return;
    const { data } = await sb
      .from('broadcast_log')
      .select('id, subject, recipient_count, status, sent_at')
      .eq('tribe_id', TRIBE_ID)
      .order('sent_at', { ascending: false })
      .limit(20);
    const el = document.getElementById('bc-history-list');
    if (!el) return;
    const BC = I18N.broadcast || {};
    if (!data?.length) {
      el.innerHTML = `<div class="text-center py-6 text-slate-400 text-sm">${BC.historyEmpty || 'Nenhum comunicado.'}</div>`;
      return;
    }
    const locale = I18N.dateLocale || 'pt-BR';
    el.innerHTML = `<div class="divide-y divide-slate-100">${data.map((b: any) => {
      const date = new Date(b.sent_at).toLocaleString(locale, { day: '2-digit', month: '2-digit', year: '2-digit', hour: '2-digit', minute: '2-digit' });
      const statusColor = b.status === 'sent' ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-600';
      return `<div class="flex items-center gap-3 py-3">
        <div class="flex-1 min-w-0">
          <div class="font-semibold text-[13px] text-navy truncate">${escapeHtml(b.subject)}</div>
          <div class="text-[11px] text-slate-400">${date} · ${b.recipient_count} ${BC.historyRecipients || 'destinatários'}</div>
        </div>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded ${statusColor} uppercase">${b.status}</span>
      </div>`;
    }).join('')}</div>`;
  }

  async function sendBroadcast() {
    if (!sb || !currentMember) return;
    const BC = I18N.broadcast || {};
    const subjectEl = document.getElementById('bc-subject') as HTMLInputElement;
    const bodyEl = document.getElementById('bc-body') as HTMLTextAreaElement;
    const btnEl = document.getElementById('btn-send-broadcast') as HTMLButtonElement;
    if (!subjectEl || !bodyEl) return;

    const subject = subjectEl.value.trim();
    const body = bodyEl.value.trim();

    if (!subject) { (window as any).toast?.(BC.subjectRequired || 'Assunto obrigatório', 'error'); return; }
    if (!body) { (window as any).toast?.(BC.bodyRequired || 'Mensagem obrigatória', 'error'); return; }

    if (!confirm((BC.confirmMsg || 'Enviar para todos os membros ativos?'))) return;

    if (btnEl) { btnEl.disabled = true; btnEl.textContent = BC.sending || 'Enviando...'; }

    try {
      const sess = await sb.auth.getSession();
      const jwt = sess?.data?.session?.access_token || '';
      if (!jwt) { (window as any).toast?.('Sessao expirada', 'error'); return; }

      const fnBase = (sb as any).functionsUrl?.toString?.() || (sb as any).supabaseUrl + '/functions/v1';
      const fnUrl = fnBase.replace(/\/$/, '') + '/send-tribe-broadcast';
      const ak = (sb as any).supabaseKey || '';

      console.log('[broadcast] POST', fnUrl, 'jwt:', jwt.length, 'ak:', ak.length);

      const res = await fetch(fnUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + jwt, 'apikey': ak },
        body: JSON.stringify({
          tribe_id: TRIBE_ID,
          subject: subject,
          body: body,
          cc_management: (document.getElementById('bc-cc-mgmt') as HTMLInputElement)?.checked !== false,
        }),
      });

      const txt = await res.text();
      console.log('[broadcast] status:', res.status, 'body:', txt);

      let data: any = {};
      try { data = JSON.parse(txt); } catch (_) { data = { success: false, error: 'Resposta invalida: ' + txt.substring(0, 200) }; }

      if (!res.ok || !data.success) {
        (window as any).toast?.(data.error || data.detail || BC.error || 'Erro', 'error');
        return;
      }

      const msg = (BC.sent || 'Enviado para {count} membros!').replace('{count}', String(data.recipient_count));
      (window as any).toast?.(msg, 'success');
      subjectEl.value = '';
      bodyEl.value = '';
      loadBroadcastHistory();
    } catch (e: any) {
      (window as any).toast?.(BC.error || 'Erro ao enviar', 'error');
      console.error('Broadcast error:', e);
    } finally {
      if (btnEl) { btnEl.disabled = false; btnEl.textContent = BC.send || 'Enviar'; }
    }
  }

  // ── Boot ──
  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    try {
      const cycles = await loadCycles(sb);
      currentCycleCode = getCurrentCycle(cycles)?.cycle_code || '';

      // Resolve current user for edit permissions
      const m = (window as any).navGetMember?.();
      if (m) {
        currentMember = m;
      } else {
        const { data: { session } } = await sb.auth.getSession();
        if (session) {
          const { data } = await sb.rpc('get_member_by_auth');
          if (data) currentMember = data;
        }
      }

      if (!canExploreTribes(currentMember)) {
        showDenied('Acesso restrito a membros ativos da plataforma.');
        return;
      }

      revealTribeShell();

      // Also listen for async member resolution — reload contacts if privileged
      window.addEventListener('nav:member', (async (evt: Event) => {
        const e = evt as CustomEvent;
        currentMember = e.detail;
        if (!canExploreTribes(currentMember)) {
          showDenied('Acesso restrito a membros ativos da plataforma.');
          return;
        }
        revealTribeShell();
        checkEditPermission();
        checkCommsHubAccess();
        checkBroadcastAccess();
        renderAccessNote();
        // Late-bind LGPD contacts if the member turns out to be privileged
        if (currentMember && !Object.keys(contactData).length
            && (isHighManagement(currentMember)
                || (currentMember.operational_role === 'tribe_leader'
                    && currentMember.tribe_id === TRIBE_ID))) {
          try {
            const { data: cd } = await sb.rpc('get_tribe_member_contacts', { p_tribe_id: TRIBE_ID });
            const parsed = typeof cd === 'string' ? JSON.parse(cd) : cd;
            if (parsed && typeof parsed === 'object') {
              contactData = parsed;
              const members = Array.from(membersMap.values());
              members.sort((a: any, b: any) => {
                if (a.operational_role === 'tribe_leader') return -1;
                if (b.operational_role === 'tribe_leader') return 1;
                return (a.name || '').localeCompare(b.name || '');
              });
              renderMembers(members);
            }
          } catch (_) { /* non-critical */ }
        }
      }) as EventListener);

      checkEditPermission();
      checkCommsHubAccess();
      checkBroadcastAccess();
      renderAccessNote();

      // Load all tribe data in parallel
      const activeCycleCode = getActiveCycleCode();
      const [tribeRes, slotsRes, membersRes, selectionsRes, delivRes, resourcesRes, artifactsRes] = await Promise.all([
        sb.from('tribes').select('*').eq('id', TRIBE_ID).single(),
        sb.from('tribe_meeting_slots').select('day_of_week, time_start, time_end').eq('tribe_id', TRIBE_ID).eq('is_active', true).order('day_of_week'),
        sb.from('public_members')
          .select('id, name, photo_url, chapter, operational_role, designations, tribe_id, share_whatsapp, current_cycle_active, is_active')
          .eq('tribe_id', TRIBE_ID)
          .eq('current_cycle_active', true)
          .eq('is_active', true),
        sb.from('tribe_selections').select('member_id').eq('tribe_id', TRIBE_ID),
        activeCycleCode
          ? sb.rpc('list_tribe_deliverables', { p_tribe_id: TRIBE_ID, p_cycle_code: activeCycleCode })
          : Promise.resolve({ data: [] }),
        sb.from('hub_resources').select('*').eq('tribe_id', TRIBE_ID).eq('is_active', true).order('created_at', { ascending: false }),
        sb.from('artifacts').select('id, title').eq('status', 'published').order('title'),
      ]);

      publishedArtifacts = artifactsRes.data || [];

      tribeData = tribeRes.data;
      if (!tribeData) {
        showDenied(I18N.notFound || 'Tribo não encontrada.');
        return;
      }
      if (!canSeeInactiveTribes(currentMember) && tribeData.is_active === false) {
        showDenied('Esta tribo está inativa e visível apenas para Superadmin.');
        return;
      }

      // Find tribe leader
      const allDirectMembers: any[] = membersRes.data || [];
      const leader = allDirectMembers.find((m: any) => m.operational_role === 'tribe_leader') || null;

      // Render header
      renderHeader(tribeRes.data, leader, slotsRes.data || []);

      // Merge members: direct (tribe_id set) + selections
      const directIds = new Set(allDirectMembers.map((m: any) => m.id));
      const selectionMemberIds = (selectionsRes.data || [])
        .map((s: any) => s.member_id)
        .filter((id: string) => !directIds.has(id));

      let selectionMembers: any[] = [];
      if (selectionMemberIds.length > 0) {
        const { data } = await sb.from('public_members')
          .select('id, name, photo_url, chapter, operational_role, designations, tribe_id, share_whatsapp, current_cycle_active, is_active')
          .in('id', selectionMemberIds)
          .eq('current_cycle_active', true)
          .eq('is_active', true);
        selectionMembers = data || [];
      }

      const allMembers = [...allDirectMembers, ...selectionMembers];
      if (!canSeeInactiveTribes(currentMember) && tribeData.is_active !== true && allMembers.length === 0 && !isAssignedToCurrentTribe(currentMember)) {
        showDenied('Esta tribo não está ativa no ciclo atual para exploração geral.');
        return;
      }
      allMembers.sort((a: any, b: any) => {
        if (a.operational_role === 'tribe_leader') return -1;
        if (b.operational_role === 'tribe_leader') return 1;
        return (a.name || '').localeCompare(b.name || '');
      });

      // Build members map for deliverable assignee lookup
      allMembers.forEach((m: any) => membersMap.set(m.id, m));

      // Load contact data for leaders/admins (LGPD-gated RPC)
      if (currentMember && (isHighManagement(currentMember) || (currentMember.operational_role === 'tribe_leader' && currentMember.tribe_id === TRIBE_ID))) {
        try {
          const { data: cd } = await sb.rpc('get_tribe_member_contacts', { p_tribe_id: TRIBE_ID });
          const parsed = typeof cd === 'string' ? JSON.parse(cd) : cd;
          if (parsed && typeof parsed === 'object') { contactData = parsed; }
        } catch (_) { /* non-critical */ }
      }

      renderMembers(allMembers);

      // Deliverables
      const deliverables = Array.isArray(delivRes.data) ? delivRes.data : [];
      renderDeliverables(deliverables);

      // Resources
      renderResources(resourcesRes.data || []);

      // Project Board
      loadProjectBoard();

    } catch (e: any) {
      console.error('Tribe dashboard error:', e);
      (window as any).toast?.(I18N.error, 'error');
      const header = document.getElementById('tribe-header');
      if (header) {
        header.innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-2xl p-6 text-center">
            <div class="text-2xl mb-2">⚠️</div>
            <p class="font-semibold text-red-700 text-sm">${I18N.error}</p>
          </div>`;
      }
    }
  }

  // R1: Admin global — PM, Deputy PM and SuperAdmin can edit any tribe
  function isCommunicationOperationalTribe(): boolean {
    if (!tribeData) return false;
    const workstream = String(tribeData.workstream_type || '').toLowerCase();
    const name = String(tribeData.name || '').toLowerCase();
    return workstream === 'operational' && name.includes('comunica');
  }

  function checkEditPermission() {
    if (!currentMember) return;
    const desigs: string[] = currentMember.designations || [];
    const canOperateComms = isCommunicationOperationalTribe()
      && (
        currentMember.operational_role === 'communicator'
        || desigs.includes('comms_team')
        || desigs.includes('comms_leader')
        || desigs.includes('comms_member')
      );
    canEdit = isHighManagement(currentMember) ||
      (currentMember.operational_role === 'tribe_leader' && currentMember.tribe_id === TRIBE_ID) ||
      canOperateComms;
  }

  // R2: Comms Hub tab — shown if member has comms_team designation or is high management
  function checkCommsHubAccess() {
    if (!currentMember) return;
    const desigs: string[] = currentMember.designations || [];
    if (desigs.includes('comms_team') || isHighManagement(currentMember)) {
      showCommsHubTab();
      renderCommsHub();
    }
  }

  // ── Project Board (Kanban) ──
  let currentBoardId: number | null = null;
  const BOARD_COLS = ['backlog', 'todo', 'in_progress', 'review', 'done'] as const;

  async function loadProjectBoard() {
    if (!sb) return;
    const loadEl = document.getElementById('board-loading');
    const emptyEl = document.getElementById('board-empty');
    const kanbanEl = document.getElementById('board-kanban');
    const createBtn = document.getElementById('board-create-btn');

    try {
      const { data: boards } = await sb.rpc('list_project_boards', { p_tribe_id: TRIBE_ID });
      if (!boards || boards.length === 0) {
        if (loadEl) loadEl.classList.add('hidden');
        if (emptyEl) emptyEl.classList.remove('hidden');
        if (createBtn && canEdit) createBtn.classList.remove('hidden');
        return;
      }

      currentBoardId = boards[0].id;
      const { data: items } = await sb.rpc('list_board_items', { p_board_id: currentBoardId });
      renderBoardItems(items || []);
    } catch (e: any) {
      console.error('Board load error:', e);
      if (loadEl) loadEl.innerHTML = '<span class="text-red-500 text-sm">Erro ao carregar quadro</span>';
    }
  }

  function renderBoardItems(items: any[]) {
    const loadEl = document.getElementById('board-loading');
    const kanbanEl = document.getElementById('board-kanban');
    if (loadEl) loadEl.classList.add('hidden');
    if (kanbanEl) kanbanEl.classList.remove('hidden');

    currentBoardItems = Array.isArray(items) ? items : [];
    BOARD_COLS.forEach(col => {
      const drop = kanbanEl?.querySelector(`.board-drop[data-col="${col}"]`);
      const countEl = kanbanEl?.querySelector(`.board-col[data-col="${col}"] .bcol-count`);
      if (!drop) return;
      const colItems = items.filter((i: any) => i.status === col);
      if (countEl) countEl.textContent = String(colItems.length);
      drop.innerHTML = colItems.map((item: any) => boardCardHtml(item)).join('');
    });

    if (canEdit) setupBoardDragDrop();
  }

  function boardCardHtml(item: any) {
    const tags = (item.tags || []).map((t: string) => `<span class="text-[10px] bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded">${escapeHtml(t)}</span>`).join('');
    const labelsRaw = Array.isArray(item.labels)
      ? item.labels
      : (typeof item.labels === 'string'
        ? (() => { try { const parsed = JSON.parse(item.labels); return Array.isArray(parsed) ? parsed : []; } catch { return []; } })()
        : []);
    const labels = labelsRaw.map((label: any) => `<span class="text-[10px] bg-purple-50 text-purple px-1.5 py-0.5 rounded">${escapeHtml(String(label))}</span>`).join('');
    const checklistRaw = Array.isArray(item.checklist)
      ? item.checklist
      : (typeof item.checklist === 'string'
        ? (() => { try { const parsed = JSON.parse(item.checklist); return Array.isArray(parsed) ? parsed : []; } catch { return []; } })()
        : []);
    const checklistDone = checklistRaw.filter((c: any) => c && typeof c === 'object' && c.done === true).length;
    const checklistTotal = checklistRaw.length;
    const checklistBadge = checklistTotal > 0
      ? `<span class="text-[10px] bg-emerald-50 text-emerald-700 px-1.5 py-0.5 rounded">✓ ${checklistDone}/${checklistTotal}</span>`
      : '';
    const assignee = item.assignee_name ? `<span class="text-[11px] text-slate-400">${escapeHtml(item.assignee_name)}</span>` : '';
    const due = item.due_date ? `<span class="text-[10px] text-slate-400">${new Date(item.due_date).toLocaleDateString(I18N.dateLocale || 'pt-BR')}</span>` : '';
    const priorityColors: Record<string, string> = { high: 'border-l-red-400', medium: 'border-l-amber-400', low: 'border-l-blue-300' };
    const borderClass = priorityColors[item.priority] || 'border-l-slate-300';
    return `<div class="board-card bg-white rounded-xl border border-slate-200 border-l-4 ${borderClass} p-3 shadow-sm cursor-grab select-none hover:shadow-md transition-shadow"
                 draggable="${canEdit}" data-item-id="${item.id}">
      <p class="text-[13px] font-semibold text-navy leading-tight mb-1">${escapeHtml(item.title)}</p>
      ${item.description ? `<p class="text-[11px] text-slate-400 mb-1.5 line-clamp-2">${escapeHtml(item.description)}</p>` : ''}
      <div class="flex flex-wrap items-center gap-1">${tags}${labels}${checklistBadge}${assignee}${due}</div>
      ${canEdit ? `<button data-action="open-board-item" data-item-id="${item.id}" class="mt-2 text-[10px] font-bold text-purple hover:underline cursor-pointer border-0 bg-transparent p-0">Editar detalhes</button>` : ''}
    </div>`;
  }

  function getBoardItemById(itemId: string): any | null {
    return currentBoardItems.find((item: any) => String(item.id) === String(itemId)) || null;
  }

  function openBoardItemModal(item?: any, seedStatus?: string) {
    if (!canEdit) return;
    const modal = document.getElementById('board-item-modal');
    const titleEl = document.getElementById('board-item-modal-title');
    const idInput = document.getElementById('bi-id') as HTMLInputElement;
    const titleInput = document.getElementById('bi-title') as HTMLInputElement;
    const descriptionInput = document.getElementById('bi-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('bi-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('bi-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('bi-assignee') as HTMLSelectElement;
    const tagsInput = document.getElementById('bi-tags') as HTMLInputElement;
    const labelsInput = document.getElementById('bi-labels') as HTMLInputElement;
    const checklistInput = document.getElementById('bi-checklist') as HTMLTextAreaElement;
    const seedInput = document.getElementById('bi-status-seed') as HTMLInputElement;
    const deleteBtn = document.getElementById('bi-delete-btn');

    if (!modal || !titleEl || !idInput || !titleInput || !descriptionInput || !statusSelect || !dueDateInput || !assigneeSelect || !tagsInput || !labelsInput || !checklistInput || !seedInput || !deleteBtn) return;

    titleEl.textContent = item ? 'Editar card' : 'Novo card';
    idInput.value = item?.id || '';
    seedInput.value = seedStatus || '';
    titleInput.value = item?.title || '';
    descriptionInput.value = item?.description || '';
    statusSelect.value = item?.status || seedStatus || 'backlog';
    dueDateInput.value = item?.due_date ? String(item.due_date).slice(0, 10) : '';
    tagsInput.value = Array.isArray(item?.tags) ? item.tags.join(', ') : '';
    const parsedLabels = Array.isArray(item?.labels)
      ? item.labels
      : (typeof item?.labels === 'string'
        ? (() => { try { const parsed = JSON.parse(item.labels); return Array.isArray(parsed) ? parsed : []; } catch { return []; } })()
        : []);
    labelsInput.value = parsedLabels.join(', ');
    const parsedChecklist = Array.isArray(item?.checklist)
      ? item.checklist
      : (typeof item?.checklist === 'string'
        ? (() => { try { const parsed = JSON.parse(item.checklist); return Array.isArray(parsed) ? parsed : []; } catch { return []; } })()
        : []);
    checklistInput.value = parsedChecklist.map((c: any) => (typeof c?.text === 'string' ? c.text : String(c || ''))).join('\n');
    deleteBtn.classList.toggle('hidden', !item);

    assigneeSelect.innerHTML = `<option value="">Não atribuído</option>` +
      Array.from(membersMap.values())
        .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''))
        .map((m: any) => `<option value="${m.id}">${escapeHtml(m.name || '—')}</option>`)
        .join('');
    assigneeSelect.value = item?.assignee_id || '';

    modal.classList.remove('hidden');
  }

  function closeBoardItemModal() {
    document.getElementById('board-item-modal')?.classList.add('hidden');
  }

  async function saveBoardItemFromModal() {
    if (!sb || !currentBoardId) return;
    const idInput = document.getElementById('bi-id') as HTMLInputElement;
    const titleInput = document.getElementById('bi-title') as HTMLInputElement;
    const descriptionInput = document.getElementById('bi-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('bi-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('bi-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('bi-assignee') as HTMLSelectElement;
    const tagsInput = document.getElementById('bi-tags') as HTMLInputElement;
    const labelsInput = document.getElementById('bi-labels') as HTMLInputElement;
    const checklistInput = document.getElementById('bi-checklist') as HTMLTextAreaElement;

    const title = titleInput.value.trim();
    if (!title) {
      (window as any).toast?.('Título do card é obrigatório.', 'error');
      return;
    }

    const tags = tagsInput.value
      .split(',')
      .map((tag: string) => tag.trim())
      .filter((tag: string) => !!tag);
    const labels = labelsInput.value
      .split(',')
      .map((label: string) => label.trim())
      .filter((label: string) => !!label);
    const checklist = checklistInput.value
      .split('\n')
      .map((row: string) => row.trim())
      .filter((row: string) => !!row)
      .map((text: string) => ({ text, done: false }));

    const { error } = await sb.rpc('upsert_board_item', {
      p_item_id: idInput.value || null,
      p_board_id: currentBoardId,
      p_title: title,
      p_description: descriptionInput.value.trim() || null,
      p_status: statusSelect.value || 'backlog',
      p_assignee_id: assigneeSelect.value || null,
      p_due_date: dueDateInput.value || null,
      p_tags: tags.length ? tags : null,
      p_labels: labels,
      p_checklist: checklist,
    });
    if (error) {
      console.error('upsert_board_item error', error);
      (window as any).toast?.('Não foi possível salvar o card.', 'error');
      return;
    }
    closeBoardItemModal();
    await loadProjectBoard();
    (window as any).toast?.('Card salvo com sucesso.', 'success');
  }

  async function archiveBoardItemFromModal() {
    if (!sb) return;
    const idInput = document.getElementById('bi-id') as HTMLInputElement;
    const itemId = idInput?.value || '';
    if (!itemId) return;
    if (!confirm('Arquivar este card? Você poderá restaurar pelo painel de governança.')) return;

    const { error } = await sb.rpc('admin_archive_board_item', {
      p_item_id: itemId,
      p_reason: 'Archived from tribe kanban modal',
    });
    if (error) {
      console.error('admin_archive_board_item error', error);
      (window as any).toast?.('Não foi possível arquivar o card.', 'error');
      return;
    }
    closeBoardItemModal();
    await loadProjectBoard();
    (window as any).toast?.('Card arquivado.', 'success');
  }

  function setupBoardDragDrop() {
    const kanbanEl = document.getElementById('board-kanban');
    if (!kanbanEl) return;
    let dragId: number | null = null;

    kanbanEl.querySelectorAll('.board-card').forEach(card => {
      card.addEventListener('dragstart', (e: Event) => {
        const ev = e as DragEvent;
        dragId = parseInt((card as HTMLElement).dataset.itemId || '0', 10);
        (card as HTMLElement).classList.add('opacity-40');
        ev.dataTransfer?.setData('text/plain', String(dragId));
      });
      card.addEventListener('dragend', () => {
        (card as HTMLElement).classList.remove('opacity-40');
        dragId = null;
      });
    });

    kanbanEl.querySelectorAll('.board-drop').forEach(zone => {
      zone.addEventListener('dragover', (e: Event) => { e.preventDefault(); (zone as HTMLElement).classList.add('bg-purple-50'); });
      zone.addEventListener('dragleave', () => { (zone as HTMLElement).classList.remove('bg-purple-50'); });
      zone.addEventListener('drop', async (e: Event) => {
        e.preventDefault();
        (zone as HTMLElement).classList.remove('bg-purple-50');
        const col = (zone as HTMLElement).dataset.col;
        if (!dragId || !col || !sb) return;
        try {
          await sb.rpc('move_board_item', { p_item_id: dragId, p_new_status: col });
          loadProjectBoard();
        } catch (err: any) {
          console.error('Board move error:', err);
          (window as any).toast?.('Erro ao mover item', 'error');
        }
      });
    });
  }

  document.getElementById('board-create-btn')?.addEventListener('click', async () => {
    if (!sb || !canEdit) return;
    const btn = document.getElementById('board-create-btn') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Criando...'; }
    try {
      const { error } = await sb.from('project_boards').insert({
        tribe_id: TRIBE_ID,
        board_name: I18N.tribeName + ' – Quadro',
        created_by: currentMember?.id,
      });
      if (error) throw error;
      loadProjectBoard();
      const emptyEl = document.getElementById('board-empty');
      if (emptyEl) emptyEl.classList.add('hidden');
    } catch (e: any) {
      console.error('Board create error:', e);
      (window as any).toast?.('Erro ao criar quadro', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Criar Quadro'; }
    }
  });

  document.addEventListener('click', (e: MouseEvent) => {
    const panel = document.getElementById('tribe-context-switch');
    if (!panel || panel.classList.contains('hidden')) return;
    const trigger = (e.target as HTMLElement).closest('[data-action="toggle-context-switch"]');
    if (trigger) return;
    if (!panel.contains(e.target as Node)) {
      panel.classList.add('hidden');
    }
  });

  boot();
</script>
