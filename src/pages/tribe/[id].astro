  // ── Progress bar ──
  function progressBarHtml(items: any[]): string {
    const total = items.length;
    if (total === 0) return '';

    const completed = items.filter(d => d.status === 'completed').length;
    const inProgress = items.filter(d => d.status === 'in_progress').length;
    const planned = items.filter(d => d.status === 'planned').length;
    const pctCompleted = Math.round((completed / total) * 100);
    const pctInProgress = Math.round((inProgress / total) * 100);

    return `
      <div class="bg-white rounded-2xl border border-slate-200 p-4 mb-4">
        <div class="flex items-center gap-3 text-[13px] font-semibold mb-2 flex-wrap">
          <span class="text-emerald-700">${completed}/${total} ${I18N.progressCompleted}</span>
          <span class="text-slate-300">|</span>
          <span class="text-blue-700">${inProgress} ${I18N.progressInProgress}</span>
          <span class="text-slate-300">|</span>
          <span class="text-slate-500">${planned} ${I18N.progressPlanned}</span>
        </div>
        <div class="w-full h-2.5 bg-slate-100 rounded-full overflow-hidden flex">
          <div class="h-full bg-emerald-500 transition-all" style="width:${pctCompleted}%"></div>
          <div class="h-full bg-blue-400 transition-all" style="width:${pctInProgress}%"></div>
        </div>
      </div>`;
  }

  // ── Deliverables tab ──
  function renderDeliverables(items: any[]) {
    const el = document.getElementById('panel-deliverables');
    if (!el) return;

    allDeliverables = items;

    const addBtn = canEdit
      ? `<div class="flex justify-end mb-4"><button data-action="add-deliverable" class="px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">${I18N.addDeliverable}</button></div>`
      : '';

    if (!items.length) {
      el.innerHTML = `
        ${addBtn}
        <div class="text-center py-14">
          <div class="text-4xl mb-3">📦</div>
          <div class="font-semibold text-slate-500 text-sm">${I18N.noDeliverables}</div>
        </div>`;
      return;
    }

    el.innerHTML = `
      ${addBtn}
      ${progressBarHtml(items)}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${items.map(deliverableCardHtml).join('')}</div>`;
  }

  const STATUS_TRANSITIONS: Record<string, string[]> = {
    planned:     ['in_progress', 'cancelled'],
    in_progress: ['completed', 'planned'],
    completed:   ['in_progress'],
    cancelled:   ['planned'],
  };
  const MOVE_LABELS: Record<string, string> = {
    in_progress: I18N.moveToInProgress || 'Start',
    completed: I18N.moveToCompleted || 'Complete',
    planned: I18N.moveToPlanned || 'Replan',
    cancelled: I18N.moveToCancelled || 'Cancel',
  };
  const MOVE_STYLES: Record<string, string> = {
    in_progress: 'bg-blue-50 text-blue-700 hover:bg-blue-100',
    completed: 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100',
    planned: 'bg-slate-50 text-slate-600 hover:bg-slate-100',
    cancelled: 'bg-red-50 text-red-600 hover:bg-red-100',
  };

  function deliverableCardHtml(d: any): string {
    const status = d.status || 'planned';
    const sc = STATUS_COLORS[status] || STATUS_COLORS.planned;
    const statusLabel = STATUS_LABELS[status] || status;

    const assignee = d.assigned_member_id && membersMap.has(d.assigned_member_id)
      ? escapeHtml(membersMap.get(d.assigned_member_id)?.name || '')
      : `<span class="text-slate-400">${I18N.unassigned}</span>`;

    const dueDateStr = d.due_date
      ? new Date(d.due_date + 'T00:00:00').toLocaleDateString(I18N.dateLocale || 'pt-BR', { day: '2-digit', month: 'short' })
      : I18N.noDueDate;

    let actionsHtml = '';
    if (canEdit) {
      const transitions = STATUS_TRANSITIONS[status] || [];
      const toggleBtns = transitions.map(s =>
        `<button data-action="status-toggle" data-deliverable-id="${d.id}" data-new-status="${s}" class="px-2 py-0.5 rounded text-[10px] font-bold cursor-pointer border-0 transition-all ${MOVE_STYLES[s] || ''}">${MOVE_LABELS[s] || s}</button>`
      ).join('');
      actionsHtml = `
        <div class="flex items-center gap-1.5 flex-wrap mt-2 pt-2 border-t border-slate-100">
          <button data-action="edit-deliverable" data-deliverable-id="${d.id}" class="px-2 py-0.5 rounded text-[10px] font-bold cursor-pointer border-0 bg-purple/10 text-purple hover:bg-purple/20 transition-all">${I18N.editDeliverable || 'Edit'}</button>
          ${toggleBtns}
        </div>`;
    }

    return `
      <div class="bg-white rounded-2xl border border-slate-100 p-5 flex flex-col hover:border-slate-300 hover:shadow-sm transition-all">
        <div class="flex items-center justify-between gap-2 mb-2">
          <span class="text-[11px] font-bold uppercase tracking-wide text-slate-400">${I18N.dueDate}: ${escapeHtml(dueDateStr)}</span>
          <span class="${sc.bg} ${sc.text} px-2.5 py-0.5 rounded-full text-[11px] font-bold">${escapeHtml(statusLabel)}</span>
        </div>
        <h3 class="text-[15px] font-bold text-navy leading-snug mb-1">${escapeHtml(d.title)}</h3>
        ${d.description ? `<p class="text-[12.5px] text-slate-500 leading-relaxed mb-2">${escapeHtml(d.description.length > 140 ? d.description.slice(0, 137) + '…' : d.description)}</p>` : ''}
        <div class="mt-auto pt-3 text-[12px] text-slate-400">
          <span class="font-semibold">${I18N.assignee}:</span> ${assignee}
        </div>
        ${actionsHtml}
      </div>`;
  }

  // ── Resources tab ──
  function renderResources(items: any[]) {
    const el = document.getElementById('panel-resources');
    if (!el) return;

    if (!items.length) {
      el.innerHTML = `
        <div class="text-center py-14">
          <div class="text-4xl mb-3">📚</div>
          <div class="font-semibold text-slate-500 text-sm">${I18N.noResources}</div>
        </div>`;
      return;
    }

    el.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${items.map(resourceCardHtml).join('')}</div>`;
  }

  function resourceCardHtml(r: any): string {
    const icon = TYPE_ICONS[r.asset_type] || '📎';
    const desc = r.description
      ? escapeHtml(r.description.length > 120 ? r.description.slice(0, 117) + '…' : r.description)
      : '';
    const link = r.url
      ? `<a href="${escapeHtml(r.url)}" target="_blank" rel="noopener"
            class="inline-flex items-center gap-1 text-teal text-[13px] font-semibold no-underline hover:underline mt-auto pt-3">${I18N.openLink}</a>`
      : '';
    return `
      <div class="bg-white rounded-2xl border border-slate-100 p-5 flex flex-col hover:border-slate-300 hover:shadow-sm transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xl leading-none">${icon}</span>
          <span class="text-[11px] font-bold uppercase tracking-wide text-slate-400">${escapeHtml(r.asset_type)}</span>
        </div>
        <h3 class="text-[15px] font-bold text-navy leading-snug mb-1">${escapeHtml(r.title)}</h3>
        ${desc ? `<p class="text-[12.5px] text-slate-500 leading-relaxed mb-0">${desc}</p>` : ''}
        ${link}
      </div>`;
  }

  // ── Modal helpers ──
  function openDeliverableModal(deliverable?: any) {
    const modal = document.getElementById('deliverable-modal');
    if (!modal) return;

    const titleEl = document.getElementById('deliverable-modal-title') as HTMLElement;
    const idInput = document.getElementById('dlv-id') as HTMLInputElement;
    const titleInput = document.getElementById('dlv-title') as HTMLInputElement;
    const descInput = document.getElementById('dlv-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('dlv-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('dlv-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('dlv-assignee') as HTMLSelectElement;
    const artifactSelect = document.getElementById('dlv-artifact') as HTMLSelectElement;

    // Labels
    titleEl.textContent = deliverable ? I18N.modalEditTitle : I18N.modalAddTitle;
    (document.getElementById('lbl-dlv-title') as HTMLElement).textContent = I18N.modalLabelTitle;
    (document.getElementById('lbl-dlv-description') as HTMLElement).textContent = I18N.modalLabelDescription;
    (document.getElementById('lbl-dlv-status') as HTMLElement).textContent = I18N.modalLabelStatus;
    (document.getElementById('lbl-dlv-due-date') as HTMLElement).textContent = I18N.modalLabelDueDate;
    (document.getElementById('lbl-dlv-assignee') as HTMLElement).textContent = I18N.modalLabelAssignee;
    (document.getElementById('lbl-dlv-artifact') as HTMLElement).textContent = I18N.modalLabelArtifact;
    (document.getElementById('btn-dlv-cancel') as HTMLElement).textContent = I18N.modalCancel;
    (document.getElementById('btn-dlv-save') as HTMLElement).textContent = I18N.modalSave;

    // Status dropdown
    statusSelect.innerHTML = [
      { v: 'planned', l: I18N.statusPlanned },
      { v: 'in_progress', l: I18N.statusInProgress },
      { v: 'completed', l: I18N.statusCompleted },
      { v: 'cancelled', l: I18N.statusCancelled },
    ].map(o => `<option value="${o.v}">${escapeHtml(o.l)}</option>`).join('');

    // Assignee dropdown
    assigneeSelect.innerHTML = `<option value="">${escapeHtml(I18N.modalSelectMember)}</option>` +
      Array.from(membersMap.values())
        .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''))
        .map((m: any) => `<option value="${m.id}">${escapeHtml(m.name)}</option>`)
        .join('');

    // Artifact dropdown
    artifactSelect.innerHTML = `<option value="">${escapeHtml(I18N.modalSelectArtifact)}</option>` +
      publishedArtifacts
        .map((a: any) => `<option value="${a.id}">${escapeHtml(a.title)}</option>`)
        .join('');

    // Fill values
    idInput.value = deliverable?.id || '';
    titleInput.value = deliverable?.title || '';
    descInput.value = deliverable?.description || '';
    statusSelect.value = deliverable?.status || 'planned';
    dueDateInput.value = deliverable?.due_date || '';
    assigneeSelect.value = deliverable?.assigned_member_id || '';
    artifactSelect.value = deliverable?.artifact_id || '';

    modal.classList.remove('hidden');
  }

  function closeDeliverableModal() {
    document.getElementById('deliverable-modal')?.classList.add('hidden');
  }

  async function saveDeliverable() {
    const idInput = document.getElementById('dlv-id') as HTMLInputElement;
    const titleInput = document.getElementById('dlv-title') as HTMLInputElement;
    const descInput = document.getElementById('dlv-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('dlv-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('dlv-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('dlv-assignee') as HTMLSelectElement;
    const artifactSelect = document.getElementById('dlv-artifact') as HTMLSelectElement;

    const title = titleInput.value.trim();
    if (!title) {
      (window as any).toast?.(I18N.modalTitleRequired, 'error');
      return;
    }

    const activeCycleCode = getActiveCycleCode();
    if (!activeCycleCode) {
      (window as any).toast?.(I18N.error, 'error');
      return;
    }

    const params: any = {
      p_tribe_id: TRIBE_ID,
      p_cycle_code: activeCycleCode,
      p_title: title,
      p_description: descInput.value.trim() || null,
      p_status: statusSelect.value,
      p_assigned_member_id: assigneeSelect.value || null,
      p_artifact_id: artifactSelect.value || null,
      p_due_date: dueDateInput.value || null,
    };

    if (idInput.value) params.p_id = idInput.value;

    const { error } = await sb.rpc('upsert_tribe_deliverable', params);
    if (error) {
      console.error('upsert_tribe_deliverable error:', error);
      (window as any).toast?.(I18N.msgSaveError, 'error');
      return;
    }

    (window as any).toast?.(I18N.msgSaved, 'success');
    closeDeliverableModal();
    await reloadDeliverables();
  }

  async function toggleDeliverableStatus(deliverableId: string, newStatus: string) {
    const d = allDeliverables.find((x: any) => x.id === deliverableId);
    if (!d) return;

    const { error } = await sb.rpc('upsert_tribe_deliverable', {
      p_id: deliverableId,
      p_tribe_id: TRIBE_ID,
      p_cycle_code: d.cycle_code || getActiveCycleCode(),
      p_title: d.title,
      p_description: d.description,
      p_status: newStatus,
      p_assigned_member_id: d.assigned_member_id,
      p_artifact_id: d.artifact_id,
      p_due_date: d.due_date,
    });

    if (error) {
      console.error('status toggle error:', error);
      (window as any).toast?.(I18N.msgStatusError, 'error');
      return;
    }

    (window as any).toast?.(I18N.msgStatusUpdated, 'success');
    await reloadDeliverables();
  }

  async function reloadDeliverables() {
    const activeCycleCode = getActiveCycleCode();
    if (!activeCycleCode) {
      renderDeliverables([]);
      return;
    }
    const { data } = await sb.rpc('list_tribe_deliverables', { p_tribe_id: TRIBE_ID, p_cycle_code: activeCycleCode });
    renderDeliverables(Array.isArray(data) ? data : []);
  }

  // ── Event delegation ──
  if (!(window as any).__tribeDelegationBound) {
    (window as any).__tribeDelegationBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      const action = target.dataset.action;

      if (action === 'switch-tab') {
        const tab = target.dataset.tab;
        if (tab) switchTab(tab);
      }

      if (action === 'add-deliverable') {
        openDeliverableModal();
      }

      if (action === 'edit-deliverable') {
        const dId = target.dataset.deliverableId;
        const d = allDeliverables.find((x: any) => x.id === dId);
        if (d) openDeliverableModal(d);
      }

      if (action === 'status-toggle') {
        const dId = target.dataset.deliverableId;
        const newStatus = target.dataset.newStatus;
        if (dId && newStatus) toggleDeliverableStatus(dId, newStatus);
      }

      if (action === 'close-deliverable-modal') {
        closeDeliverableModal();
      }

      if (action === 'open-board-item') {
        const itemId = target.dataset.itemId;
        if (!itemId) return;
        const item = getBoardItemById(itemId);
        if (item) openBoardItemModal(item);
      }

      if (action === 'add-board-card') {
        const status = target.dataset.col || 'backlog';
        openBoardItemModal(null, status);
      }

      if (action === 'close-board-item-modal') {
        closeBoardItemModal();
      }

      if (action === 'delete-board-item') {
        archiveBoardItemFromModal();
      }

      if (action === 'send-broadcast') {
        sendBroadcast();
      }

      if (action === 'open-wa') {
        e.preventDefault();
        const memberId = target.dataset.memberId;
        if (!memberId || !sb) return;
        (async () => {
          const { data } = await sb.rpc('resolve_whatsapp_link', { p_member_id: memberId });
          if (data?.success && data?.url) {
            window.open(data.url, '_blank', 'noopener');
          } else {
            (window as any).toast?.(data?.error || 'Error', 'error');
          }
        })();
      }

      if (action === 'toggle-context-switch') {
        const switcher = document.getElementById('tribe-context-switch');
        if (!switcher) return;
        const opening = switcher.classList.contains('hidden');
        switcher.classList.toggle('hidden');
        if (opening) {
          ensureContextSwitchData();
        }
      }
    });

    document.addEventListener('submit', (e: SubmitEvent) => {
      if ((e.target as HTMLElement)?.id === 'deliverable-form') {
        e.preventDefault();
        saveDeliverable();
      }
      if ((e.target as HTMLElement)?.id === 'board-item-form') {
        e.preventDefault();
        saveBoardItemFromModal();
      }
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeDeliverableModal();
      if (e.key === 'Escape') closeBoardItemModal();
    });
  }

  // ── Broadcast tab (leader + admin only) ──
  let broadcastShown = false;

  function showBroadcastTab() {
    if (broadcastShown) return;
    broadcastShown = true;
    const tabs = document.getElementById('tribe-tabs');
    if (tabs) {
      const btn = document.createElement('button');
      btn.className = 'tribe-tab px-4 py-2 rounded-xl text-[13px] font-semibold cursor-pointer border-0 bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all';
      btn.dataset.action = 'switch-tab';
      btn.dataset.tab = 'broadcast';
      btn.textContent = I18N.broadcastTab || 'Comunicados';
      tabs.appendChild(btn);
    }
  }

  function checkBroadcastAccess() {
    if (!currentMember) return;
    const isLeaderOfThisTribe = currentMember.operational_role === 'tribe_leader'
      && currentMember.tribe_id === TRIBE_ID;
    if (isLeaderOfThisTribe || isHighManagement(currentMember)) {
      showBroadcastTab();
      renderBroadcastPanel();
    }
  }

