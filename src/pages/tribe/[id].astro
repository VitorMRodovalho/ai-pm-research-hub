---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
import LoadingSkeleton from '../../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import PresentationLayer from '../../components/ui/PresentationLayer.astro';
import { getStaticTribeFallback } from '../../lib/tribes/catalog';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const { id } = Astro.params;
const tribeId = parseInt(id || '0', 10);
if (tribeId < 1) return Astro.redirect('/');
const staticFallback = getStaticTribeFallback(tribeId, lang);
const TRIBE_I18N = {
  membersTab: t('tribe.membersTab', lang),
  deliverablesTab: t('tribe.deliverablesTab', lang),
  resourcesTab: t('tribe.resourcesTab', lang),
  commsHubTab: t('tribe.commsHubTab', lang),
  meetingSchedule: t('tribe.meetingSchedule', lang),
  noMembers: t('tribe.noMembers', lang),
  noDeliverables: t('tribe.noDeliverables', lang),
  noResources: t('tribe.noResources', lang),
  addDeliverable: t('tribe.addDeliverable', lang),
  statusPlanned: t('tribe.statusPlanned', lang),
  statusInProgress: t('tribe.statusInProgress', lang),
  statusCompleted: t('tribe.statusCompleted', lang),
  statusCancelled: t('tribe.statusCancelled', lang),
  loading: t('tribe.loading', lang),
  notFound: t('tribe.notFound', lang),
  leader: t('tribe.leader', lang),
  quadrant: t('tribe.quadrant', lang),
  dueDate: t('tribe.dueDate', lang),
  noDueDate: t('tribe.noDueDate', lang),
  assignee: t('tribe.assignee', lang),
  unassigned: t('tribe.unassigned', lang),
  openLink: t('tribe.openLink', lang),
  dateLocale: t('tribe.dateLocale', lang),
  error: t('tribe.error', lang),
  tribeName: staticFallback?.name || '',
  tribeDesc: staticFallback?.description || '',
  quadrantLabel: staticFallback?.quadrantLabel || '',
  tribePrefix: t('workspace.tribePrefix', lang),
  noDescription: t('tribe.noResources', lang),
  modalAddTitle: t('tribe.modal.addTitle', lang),
  modalEditTitle: t('tribe.modal.editTitle', lang),
  modalLabelTitle: t('tribe.modal.labelTitle', lang),
  modalLabelDescription: t('tribe.modal.labelDescription', lang),
  modalLabelStatus: t('tribe.modal.labelStatus', lang),
  modalLabelAssignee: t('tribe.modal.labelAssignee', lang),
  modalLabelDueDate: t('tribe.modal.labelDueDate', lang),
  modalLabelArtifact: t('tribe.modal.labelArtifact', lang),
  modalSelectMember: t('tribe.modal.selectMember', lang),
  modalSelectArtifact: t('tribe.modal.selectArtifact', lang),
  modalCancel: t('tribe.modal.cancel', lang),
  modalSave: t('tribe.modal.save', lang),
  modalTitleRequired: t('tribe.modal.titleRequired', lang),
  msgSaved: t('tribe.msg.saved', lang),
  msgSaveError: t('tribe.msg.saveError', lang),
  msgStatusUpdated: t('tribe.msg.statusUpdated', lang),
  msgStatusError: t('tribe.msg.statusError', lang),
  progressCompleted: t('tribe.progress.completed', lang),
  progressInProgress: t('tribe.progress.inProgress', lang),
  progressPlanned: t('tribe.progress.planned', lang),
  editDeliverable: t('tribe.editDeliverable', lang),
  moveToInProgress: t('tribe.moveTo.in_progress', lang),
  moveToCompleted: t('tribe.moveTo.completed', lang),
  moveToPlanned: t('tribe.moveTo.planned', lang),
  moveToCancelled: t('tribe.moveTo.cancelled', lang),
  joinWhatsApp: t('tribe.joinWhatsApp', lang),
  chatWhatsApp: t('tribe.chatWhatsApp', lang),
  lgpdMask: t('tribe.lgpdMask', lang),
  lgpdTooltip: t('tribe.lgpdTooltip', lang),
  broadcastTab: t('tribe.broadcastTab', lang),
  broadcast: {
    title: t('tribe.broadcast.title', lang),
    subtitle: t('tribe.broadcast.subtitle', lang),
    subject: t('tribe.broadcast.subject', lang),
    subjectPlaceholder: t('tribe.broadcast.subjectPlaceholder', lang),
    body: t('tribe.broadcast.body', lang),
    bodyPlaceholder: t('tribe.broadcast.bodyPlaceholder', lang),
    send: t('tribe.broadcast.send', lang),
    sending: t('tribe.broadcast.sending', lang),
    sent: t('tribe.broadcast.sent', lang),
    error: t('tribe.broadcast.error', lang),
    confirmTitle: t('tribe.broadcast.confirmTitle', lang),
    confirmMsg: t('tribe.broadcast.confirmMsg', lang),
    confirmYes: t('tribe.broadcast.confirmYes', lang),
    confirmNo: t('tribe.broadcast.confirmNo', lang),
    historyTitle: t('tribe.broadcast.historyTitle', lang),
    historyEmpty: t('tribe.broadcast.historyEmpty', lang),
    historyRecipients: t('tribe.broadcast.historyRecipients', lang),
    subjectRequired: t('tribe.broadcast.subjectRequired', lang),
    bodyRequired: t('tribe.broadcast.bodyRequired', lang),
    ccMgmt: t('tribe.broadcast.ccMgmt', lang),
    rateLimit: t('tribe.broadcast.rateLimit', lang),
  },
  commsHub: {
    title: t('tribe.commsHub.title', lang),
    subtitle: t('tribe.commsHub.subtitle', lang),
    loading: t('tribe.commsHub.loading', lang),
    empty: t('tribe.commsHub.empty', lang),
    colDate: t('tribe.commsHub.colDate', lang),
    colChannel: t('tribe.commsHub.colChannel', lang),
    colAudience: t('tribe.commsHub.colAudience', lang),
    colReach: t('tribe.commsHub.colReach', lang),
    colEngagement: t('tribe.commsHub.colEngagement', lang),
    colLeads: t('tribe.commsHub.colLeads', lang),
  },
  oproleLabels: {
    manager: t('profile.oprole.manager', lang),
    deputy_manager: t('profile.oprole.deputyManager', lang),
    tribe_leader: t('profile.oprole.tribeLeader', lang),
    researcher: t('profile.oprole.researcher', lang),
    facilitator: t('profile.oprole.facilitator', lang),
    communicator: t('profile.oprole.communicator', lang),
    none: t('profile.oprole.none', lang),
    guest: t('profile.oprole.guest', lang),
  },
  dayNames: [
    t('common.days.sun', lang), t('common.days.mon', lang), t('common.days.tue', lang),
    t('common.days.wed', lang), t('common.days.thu', lang), t('common.days.fri', lang),
    t('common.days.sat', lang),
  ],
};
const pageTitle = t('tribe.meta', lang).replace('{name}', staticFallback?.name || `T${tribeId}`);
---
<BaseLayout title={pageTitle} activePage="tribes">
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div id="tribe-loading" class="text-center py-10 text-slate-400">{t('tribe.loading', lang)}</div>
    <div id="tribe-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">Acesso restrito a membros ativos da plataforma.</p>
      <p class="text-sm text-amber-700 mt-1">Tribos ativas podem ser exploradas em modo leitura por membros ativos; ações seguem restritas pela liderança e gestão.</p>
      <a href="/profile" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90 transition-all">Abrir perfil</a>
    </div>
    <div id="tribe-shell" class="hidden">
    <!-- Header -->
    <div id="tribe-header" class="mb-6">
      <LoadingSkeleton variant="profile" />
    </div>
    <div id="tribe-access-note" class="hidden mb-4"></div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-5 flex-wrap" id="tribe-tabs">
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
              data-tab="members" data-action="switch-tab">{t('tribe.membersTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
              data-tab="deliverables" data-action="switch-tab">{t('tribe.deliverablesTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
              data-tab="resources" data-action="switch-tab">{t('tribe.resourcesTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
              data-tab="board" data-action="switch-tab">Quadro de Projeto</button>
    </div>

    <!-- Tab panels -->
    <div id="panel-members">
      <LoadingSkeleton variant="card" count={4} />
    </div>
    <div id="panel-deliverables" class="hidden">
      <LoadingSkeleton variant="card" count={3} />
    </div>
    <div id="panel-resources" class="hidden">
      <LoadingSkeleton variant="card" count={3} />
    </div>
    <!-- Project Board panel -->
    <div id="panel-board" class="hidden">
      <div id="board-loading" class="text-center py-10 text-slate-400">Carregando quadro...</div>
      <div id="board-empty" class="hidden bg-slate-50 border border-slate-200 rounded-2xl p-8 text-center">
        <div class="text-4xl mb-3 opacity-50">&#x1f4cb;</div>
        <p class="font-semibold text-slate-600 mb-2">Nenhum quadro de projeto</p>
        <p class="text-sm text-slate-400 mb-4">Esta tribo ainda não possui um quadro de projeto.</p>
        <button id="board-create-btn" class="hidden px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold hover:opacity-90 transition-opacity">Criar Quadro</button>
      </div>
      <div id="board-kanban" class="hidden grid grid-cols-1 md:grid-cols-5 gap-3" style="min-height:350px">
        <div class="board-col" data-col="backlog">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2.5 h-2.5 rounded-full bg-slate-400"></div>
            <h4 class="text-[12px] font-bold text-slate-600 uppercase">Backlog</h4>
            <span class="bcol-count text-[10px] bg-slate-100 text-slate-500 px-1.5 py-0.5 rounded-full font-bold">0</span>
            <button data-action="add-board-card" data-col="backlog" class="ml-auto w-5 h-5 rounded-md bg-slate-100 text-slate-500 text-xs font-bold cursor-pointer border-0 hover:bg-slate-200 transition-all">+</button>
          </div>
          <div class="board-drop space-y-2 min-h-[150px] p-1.5 rounded-xl border-2 border-dashed border-slate-200 bg-slate-50/50" data-col="backlog"></div>
        </div>
        <div class="board-col" data-col="todo">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2.5 h-2.5 rounded-full bg-blue-400"></div>
            <h4 class="text-[12px] font-bold text-blue-600 uppercase">To Do</h4>
            <span class="bcol-count text-[10px] bg-blue-100 text-blue-600 px-1.5 py-0.5 rounded-full font-bold">0</span>
            <button data-action="add-board-card" data-col="todo" class="ml-auto w-5 h-5 rounded-md bg-blue-100 text-blue-700 text-xs font-bold cursor-pointer border-0 hover:bg-blue-200 transition-all">+</button>
          </div>
          <div class="board-drop space-y-2 min-h-[150px] p-1.5 rounded-xl border-2 border-dashed border-blue-200 bg-blue-50/30" data-col="todo"></div>
        </div>
        <div class="board-col" data-col="in_progress">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2.5 h-2.5 rounded-full bg-amber-400"></div>
            <h4 class="text-[12px] font-bold text-amber-700 uppercase">Em Progresso</h4>
            <span class="bcol-count text-[10px] bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded-full font-bold">0</span>
            <button data-action="add-board-card" data-col="in_progress" class="ml-auto w-5 h-5 rounded-md bg-amber-100 text-amber-700 text-xs font-bold cursor-pointer border-0 hover:bg-amber-200 transition-all">+</button>
          </div>
          <div class="board-drop space-y-2 min-h-[150px] p-1.5 rounded-xl border-2 border-dashed border-amber-200 bg-amber-50/30" data-col="in_progress"></div>
        </div>
        <div class="board-col" data-col="review">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2.5 h-2.5 rounded-full bg-purple-400"></div>
            <h4 class="text-[12px] font-bold text-purple-600 uppercase">Revisão</h4>
            <span class="bcol-count text-[10px] bg-purple-100 text-purple-600 px-1.5 py-0.5 rounded-full font-bold">0</span>
            <button data-action="add-board-card" data-col="review" class="ml-auto w-5 h-5 rounded-md bg-purple-100 text-purple-700 text-xs font-bold cursor-pointer border-0 hover:bg-purple-200 transition-all">+</button>
          </div>
          <div class="board-drop space-y-2 min-h-[150px] p-1.5 rounded-xl border-2 border-dashed border-purple-200 bg-purple-50/30" data-col="review"></div>
        </div>
        <div class="board-col" data-col="done">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2.5 h-2.5 rounded-full bg-emerald-500"></div>
            <h4 class="text-[12px] font-bold text-emerald-700 uppercase">Concluído</h4>
            <span class="bcol-count text-[10px] bg-emerald-100 text-emerald-700 px-1.5 py-0.5 rounded-full font-bold">0</span>
            <button data-action="add-board-card" data-col="done" class="ml-auto w-5 h-5 rounded-md bg-emerald-100 text-emerald-700 text-xs font-bold cursor-pointer border-0 hover:bg-emerald-200 transition-all">+</button>
          </div>
          <div class="board-drop space-y-2 min-h-[150px] p-1.5 rounded-xl border-2 border-dashed border-emerald-200 bg-emerald-50/30" data-col="done"></div>
        </div>
      </div>
    </div>
    <div id="board-item-modal" class="fixed inset-0 z-50 hidden">
      <div class="absolute inset-0 bg-black/40" data-action="close-board-item-modal"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white dark:bg-slate-900 rounded-2xl shadow-xl w-full max-w-xl p-6 max-h-[90vh] overflow-y-auto border border-slate-200 dark:border-slate-700">
        <h2 id="board-item-modal-title" class="text-lg font-extrabold text-navy dark:text-slate-100 mb-4">Detalhes do card</h2>
        <form id="board-item-form" class="flex flex-col gap-3">
          <input type="hidden" id="bi-id" />
          <input type="hidden" id="bi-status-seed" />
          <div>
            <label for="bi-title" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Título</label>
            <input type="text" id="bi-title" required class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
          </div>
          <div>
            <label for="bi-description" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Descrição</label>
            <textarea id="bi-description" rows="4" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></textarea>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label for="bi-status" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Status</label>
              <select id="bi-status" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40">
                <option value="backlog">Backlog</option>
                <option value="todo">To Do</option>
                <option value="in_progress">Em Progresso</option>
                <option value="review">Revisão</option>
                <option value="done">Concluído</option>
              </select>
            </div>
            <div>
              <label for="bi-due-date" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Prazo</label>
              <input type="date" id="bi-due-date" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
            </div>
          </div>
          <div>
            <label for="bi-assignee" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Responsável</label>
            <select id="bi-assignee" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
          </div>
          <div>
            <label for="bi-tags" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Tags (separadas por vírgula)</label>
            <input type="text" id="bi-tags" placeholder="kanban, prioridade, ux" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
          </div>
          <div>
            <label for="bi-labels" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Labels (separadas por vírgula)</label>
            <input type="text" id="bi-labels" placeholder="prioridade alta, bloqueado" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
          </div>
          <div>
            <label for="bi-checklist" class="text-[13px] font-semibold text-slate-600 dark:text-slate-300 mb-1 block">Checklist (uma linha por item)</label>
            <textarea id="bi-checklist" rows="3" placeholder="- Definir owner&#10;- Revisar copy final" class="w-full px-3 py-2 border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-slate-100 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></textarea>
          </div>
          <div class="flex justify-between items-center gap-3 mt-2">
            <button type="button" id="bi-delete-btn" data-action="delete-board-item" class="px-4 py-2 text-sm font-semibold text-red-600 border border-red-200 rounded-lg cursor-pointer hover:bg-red-50 transition-all hidden">🗑️ Arquivar card</button>
            <div class="flex gap-3 ml-auto">
              <button type="button" data-action="close-board-item-modal" class="px-4 py-2 text-sm font-semibold text-slate-500 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition-all">Cancelar</button>
              <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-navy rounded-lg cursor-pointer border-0 hover:opacity-90 transition-all">Salvar</button>
            </div>
          </div>
        </form>
      </div>
    </div>
    <!-- Comms Hub panel (conditionally shown for comms_team members) -->
    <div id="panel-commshub" class="hidden"></div>
    <!-- Broadcast panel (conditionally shown for tribe leader + admin) -->
    <div id="panel-broadcast" class="hidden"></div>
    </div>
  </div>

  <!-- Deliverable Modal -->
  <div id="deliverable-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" data-action="close-deliverable-modal"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-white rounded-2xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
      <h2 id="deliverable-modal-title" class="text-lg font-extrabold text-navy mb-4"></h2>
      <form id="deliverable-form" class="flex flex-col gap-3">
        <input type="hidden" id="dlv-id" />
        <div>
          <label for="dlv-title" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-title"></label>
          <input type="text" id="dlv-title" required class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
        </div>
        <div>
          <label for="dlv-description" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-description"></label>
          <textarea id="dlv-description" rows="3" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="dlv-status" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-status"></label>
            <select id="dlv-status" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
          </div>
          <div>
            <label for="dlv-due-date" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-due-date"></label>
            <input type="date" id="dlv-due-date" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
          </div>
        </div>
        <div>
          <label for="dlv-assignee" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-assignee"></label>
          <select id="dlv-assignee" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
        </div>
        <div>
          <label for="dlv-artifact" class="text-[13px] font-semibold text-slate-600 mb-1 block" id="lbl-dlv-artifact"></label>
          <select id="dlv-artifact" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
        </div>
        <div class="flex justify-end gap-3 mt-2">
          <button type="button" data-action="close-deliverable-modal" class="px-4 py-2 text-sm font-semibold text-slate-500 border border-slate-200 rounded-lg cursor-pointer hover:bg-slate-50 transition-all" id="btn-dlv-cancel"></button>
          <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-navy rounded-lg cursor-pointer border-0 hover:opacity-90 transition-all" id="btn-dlv-save"></button>
        </div>
      </form>
    </div>
  </div>
  <PresentationLayer context="tribe" tribeId={tribeId} lang={lang} />
</BaseLayout>

<script is:inline define:vars={{ TRIBE_I18N, tribeId }}>
  window.__TRIBE_I18N = typeof TRIBE_I18N !== 'undefined' ? TRIBE_I18N : {};
  window.__TRIBE_ID = typeof tribeId !== 'undefined' ? tribeId : 0;
</script>
<script>
  import { getCurrentCycle, loadCycles } from '../../lib/cycles';
  import { canExploreTribes, canManageTribeLifecycle, canSeeInactiveTribes } from '../../lib/tribes/access';
  import { buildTribeLabel } from '../../lib/tribes/catalog';

  const I18N = (typeof window !== 'undefined' && (window as any).__TRIBE_I18N) || {};
  const TRIBE_ID: number = (typeof window !== 'undefined' && (window as any).__TRIBE_ID) || 0;

  const OPROLE_LABELS: Record<string, string> = I18N.oproleLabels || {};
  const OPROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', deputy_manager: '#FF610F', tribe_leader: '#4F17A8', researcher: '#EC4899',
    facilitator: '#06B6D4', communicator: '#8B5CF6', none: '#94A3B8', guest: '#94A3B8'
  };
  const STATUS_COLORS: Record<string, { bg: string; text: string }> = {
    planned:     { bg: 'bg-slate-100', text: 'text-slate-600' },
    in_progress: { bg: 'bg-blue-50', text: 'text-blue-700' },
    completed:   { bg: 'bg-emerald-50', text: 'text-emerald-700' },
    cancelled:   { bg: 'bg-red-50', text: 'text-red-600' },
  };
  const STATUS_LABELS: Record<string, string> = {
    planned: I18N.statusPlanned, in_progress: I18N.statusInProgress,
    completed: I18N.statusCompleted, cancelled: I18N.statusCancelled,
  };
  const TYPE_ICONS: Record<string, string> = {
    'Curso': '🎓', 'Referência': '📘', 'Webinar': '▶️', 'Outro': '📎',
    'Course': '🎓', 'Reference': '📘',
  };
  const DAY_NAMES: string[] = I18N.dayNames || ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const HIGH_MGMT_ROLES = ['manager', 'deputy_manager'];

  function isHighManagement(m: any): boolean {
    return canManageTribeLifecycle(m);
  }

  function isAssignedToCurrentTribe(m: any): boolean {
    if (!m) return false;
    return Number(m.tribe_id || 0) === TRIBE_ID || Number(m.selected_tribe_id || 0) === TRIBE_ID;
  }

  function showDenied(message?: string) {
    document.getElementById('tribe-loading')?.classList.add('hidden');
    document.getElementById('tribe-shell')?.classList.add('hidden');
    const denied = document.getElementById('tribe-denied');
    if (!denied) return;
    denied.classList.remove('hidden');
    if (message) {
      const body = denied.querySelector('p');
      if (body) body.textContent = message;
    }
  }

  function revealTribeShell() {
    document.getElementById('tribe-loading')?.classList.add('hidden');
    document.getElementById('tribe-denied')?.classList.add('hidden');
    document.getElementById('tribe-shell')?.classList.remove('hidden');
  }

  function renderAccessNote() {
    const note = document.getElementById('tribe-access-note');
    if (!note || !currentMember) return;
    if (isAssignedToCurrentTribe(currentMember)) {
      note.classList.add('hidden');
      note.innerHTML = '';
      return;
    }
    note.classList.remove('hidden');
    if (canEdit) {
      note.className = 'mb-4 rounded-2xl border border-purple-200 bg-purple-50 px-4 py-3 text-sm text-purple-800';
      note.innerHTML = 'Modo gestão cruzada: você está em outra tribo com permissão de coordenação. Edições continuam restritas aos controles de gestão e liderança.';
      return;
    }
    note.className = 'mb-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700';
    note.innerHTML = 'Modo exploração: você pode consultar os membros ativos, recursos e quadro desta tribo, mas as ações seguem restritas à liderança local e à gestão.';
  }

  function escapeHtml(s: string): string {
    return String(s || '')
      .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  let sb: any = null;
  let currentMember: any = null;
  let membersMap: Map<string, any> = new Map();
  let canEdit = false;
  let tribeData: any = null;
  let currentCycleCode = '';
  let allDeliverables: any[] = [];
  let publishedArtifacts: any[] = [];
  let commsHubShown = false;
  let contactData: Record<string, {email?:string, phone?:string}> = {};
  let contextSwitchLoaded = false;
  let contextCatalog: { active: any[]; operational: any[]; legacy: any[] } = { active: [], operational: [], legacy: [] };
  let currentBoardItems: any[] = [];

  function getActiveCycleCode(): string {
    return currentCycleCode || allDeliverables.find((item: any) => item?.cycle_code)?.cycle_code || '';
  }

  // ── Tab switching ──
  function switchTab(tabName: string) {
    const panels = ['members', 'deliverables', 'resources', 'board', 'commshub', 'broadcast'];
    panels.forEach(p => {
      const el = document.getElementById(`panel-${p}`);
      if (el) el.classList.toggle('hidden', p !== tabName);
    });
    document.querySelectorAll('.tribe-tab').forEach(btn => {
      const isActive = (btn as HTMLElement).dataset.tab === tabName;
      btn.classList.toggle('bg-navy', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-navy', isActive);
      btn.classList.toggle('bg-white', !isActive);
      btn.classList.toggle('text-slate-500', !isActive);
      btn.classList.toggle('border-slate-200', !isActive);
    });
  }


  // ── Comms Hub tab (R2: conditional for comms_team designation) ──
  function showCommsHubTab() {
    if (commsHubShown) return;
    commsHubShown = true;
    const tabsContainer = document.getElementById('tribe-tabs');
    if (!tabsContainer) return;
    const btn = document.createElement('button');
    btn.className = 'tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all';
    btn.dataset.tab = 'commshub';
    btn.dataset.action = 'switch-tab';
    btn.textContent = I18N.commsHubTab || '\u{1F4E1} Comms Hub';
    tabsContainer.appendChild(btn);
  }

  function renderCommsHub() {
    const el = document.getElementById('panel-commshub');
    if (!el) return;
    const ch = I18N.commsHub || {};
    el.innerHTML = `
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100">
          <h2 class="text-base font-extrabold text-navy">${escapeHtml(ch.title || 'Comms Hub')}</h2>
          <p class="text-[13px] text-slate-500">${escapeHtml(ch.subtitle || '')}</p>
        </div>
        <div id="commshub-table-area" class="p-5">
          <div class="text-center py-8 text-slate-400 text-sm" id="commshub-loading">${escapeHtml(ch.loading || 'Loading...')}</div>
        </div>
      </div>`;
    loadCommsMetrics();
  }

  async function loadCommsMetrics() {
    const ch = I18N.commsHub || {};
    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 14 });
      const area = document.getElementById('commshub-table-area');
      if (!area) return;
      if (error || !data?.length) {
        area.innerHTML = `<div class="text-center py-8 text-slate-500 text-sm">${escapeHtml(ch.empty || 'No data')}</div>`;
        return;
      }
      const rows = data.map((r: any) => `
        <tr class="border-b border-slate-50 hover:bg-slate-50 transition-colors">
          <td class="px-3 py-2.5 text-[13px]">${escapeHtml(r.metric_date || '\u2014')}</td>
          <td class="px-3 py-2.5 text-[13px] font-medium">${escapeHtml(r.channel || '\u2014')}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.audience ?? '\u2014'}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.reach ?? '\u2014'}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.engagement != null ? (Number(r.engagement) * 100).toFixed(2) + '%' : '\u2014'}</td>
          <td class="px-3 py-2.5 text-[13px] text-right">${r.leads ?? '\u2014'}</td>
        </tr>`).join('');
      area.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full text-[13px] border-collapse">
            <thead>
              <tr class="border-b border-slate-200 text-left">
                <th class="px-3 py-2 font-semibold text-slate-600">${escapeHtml(ch.colDate || 'Date')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600">${escapeHtml(ch.colChannel || 'Channel')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colAudience || 'Audience')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colReach || 'Reach')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colEngagement || 'Engagement')}</th>
                <th class="px-3 py-2 font-semibold text-slate-600 text-right">${escapeHtml(ch.colLeads || 'Leads')}</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>`;
    } catch (e: any) {
      const area = document.getElementById('commshub-table-area');
      if (area) area.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">${escapeHtml(e?.message || 'Error')}</div>`;
    }
  }

  // ── Header render ──
  function renderHeader(_tribe: any, leader: any, slots: any[]) {
    const el = document.getElementById('tribe-header');
    if (!el) return;

    const leaderName = leader ? escapeHtml(leader.name) : '—';
    const leaderPhoto = leader?.photo_url
      ? `<img src="${escapeHtml(leader.photo_url)}" class="w-8 h-8 rounded-full object-cover border border-slate-100" alt="">`
      : leader
        ? `<div class="w-8 h-8 rounded-full bg-purple/20 flex items-center justify-center text-purple text-xs font-bold">${escapeHtml(leader.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase())}</div>`
        : '';

    let scheduleHtml = '';
    if (slots?.length) {
      scheduleHtml = slots.map(s => {
        const day = DAY_NAMES[s.day_of_week] || '?';
        const start = s.time_start?.substring(0, 5) || '';
        const end = s.time_end?.substring(0, 5) || '';
        return `${day} ${start}–${end}`;
      }).join(' · ');
    } else {
      scheduleHtml = '<span class="text-slate-400 italic">—</span>';
    }

    const tribeName = buildTribeLabel(_tribe, { prefix: I18N.tribePrefix || 'Tribo' });
    const quadrantLabel = _tribe?.quadrant_name || I18N.quadrantLabel || '';
    const tribeDescription = _tribe?.notes || I18N.tribeDesc || '—';

    el.innerHTML = `
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <div class="flex items-start gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <h1 class="text-xl font-extrabold text-navy">T${TRIBE_ID}: ${escapeHtml(tribeName)}</h1>
              <button data-action="toggle-context-switch" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-[11px] font-bold bg-slate-100 text-slate-600 border border-slate-200 hover:bg-slate-200 transition-all cursor-pointer">
                Trocar contexto ▾
              </button>
              ${quadrantLabel ? `<span class="px-2 py-0.5 rounded-md text-[11px] font-bold uppercase tracking-wide bg-purple/10 text-purple">${escapeHtml(quadrantLabel)}</span>` : ''}
            </div>
            <div id="tribe-context-switch" class="hidden mt-2 rounded-xl border border-slate-200 bg-white shadow-sm p-3 max-w-xl"></div>
            <p class="text-[13px] text-slate-500 leading-relaxed mb-3">${escapeHtml(tribeDescription)}</p>
            <div class="flex flex-wrap gap-x-5 gap-y-2 text-[13px]">
              <div class="flex items-center gap-2">
                ${leaderPhoto}
                <span class="text-slate-400 font-semibold">${I18N.leader}:</span>
                <span class="font-semibold text-navy">${leaderName}</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-slate-400 font-semibold">📅 ${I18N.meetingSchedule}:</span>
                <span class="text-navy font-medium">${scheduleHtml}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div id="tribe-wa-cta" class="hidden mt-3"></div>`;

    // WhatsApp CTA: show only if tribe has whatsapp_url AND user belongs to tribe (or is admin)
    if (_tribe?.whatsapp_url && currentMember) {
      const isTribeMember = currentMember.tribe_id === TRIBE_ID
        || membersMap.has(currentMember.id);
      const isAdmin = isHighManagement(currentMember);
      if (isTribeMember || isAdmin) {
        const ctaEl = document.getElementById('tribe-wa-cta');
        if (ctaEl) {
          ctaEl.classList.remove('hidden');
          ctaEl.innerHTML = `
            <a href="${escapeHtml(_tribe.whatsapp_url)}" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#25D366] text-white rounded-xl text-[14px] font-bold no-underline hover:bg-[#1FAD53] transition-all shadow-sm">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              ${I18N.joinWhatsApp || 'Entrar no Grupo do WhatsApp'}
            </a>`;
        }
      }
    }
  }

  function renderContextSection(title: string, items: string[]): string {
    if (!items.length) return '';
    return `<div class="mb-2">
      <div class="text-[10px] font-bold uppercase tracking-wide text-slate-400 mb-1">${title}</div>
      <div class="space-y-1">${items.join('')}</div>
    </div>`;
  }

  function renderContextSwitchMenu() {
    const el = document.getElementById('tribe-context-switch');
    if (!el) return;
    const activeLinks = contextCatalog.active.map((tribe: any) => `
      <a href="/tribe/${tribe.id}" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-slate-700 hover:bg-slate-50 no-underline transition-all">
        <span class="w-4 h-4 rounded-full bg-navy/10 text-navy text-[10px] flex items-center justify-center font-bold">${tribe.id}</span>
        ${escapeHtml(buildTribeLabel(tribe, { prefix: I18N.tribePrefix || 'Tribo' }))}
      </a>
    `);

    const opLinks = contextCatalog.operational.map((tribe: any) => `
      <a href="/tribe/${tribe.id}" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-slate-700 hover:bg-slate-50 no-underline transition-all">
        <span class="w-4 h-4 rounded-full bg-purple/10 text-purple text-[10px] flex items-center justify-center font-bold">${tribe.id}</span>
        ${escapeHtml(buildTribeLabel(tribe, { prefix: I18N.tribePrefix || 'Tribo' }))}
      </a>
    `);
    const webinars = `<a href="/webinars" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-slate-700 hover:bg-slate-50 no-underline transition-all">🎙️ Webinars</a>`;
    const opWithWebinars = [webinars, ...opLinks];

    const legacyLinks = contextCatalog.legacy.map((legacy: any) => `
      <a href="/#team" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-slate-500 hover:bg-slate-50 no-underline transition-all">
        <span class="text-[10px]">🏛️</span>
        ${escapeHtml(legacy.legacy_name || `Legado #${legacy.id}`)}
      </a>
    `);

    el.innerHTML = [
      renderContextSection('Ativas (Pesquisa)', activeLinks),
      renderContextSection('Subprojetos (Operação)', opWithWebinars),
      renderContextSection('Legado (Read-only)', legacyLinks),
    ].join('');
  }

  async function ensureContextSwitchData() {
    if (contextSwitchLoaded || !sb) return;
    const [{ data: tribes }, { data: legacy }] = await Promise.all([
      sb.from('tribes').select('id, name, is_active, workstream_type').order('id'),
      sb.from('legacy_tribes').select('id, legacy_name').order('id'),
    ]);

    const visibleTribes = (tribes || []).filter((tribe: any) => canSeeInactiveTribes(currentMember) || tribe.is_active !== false);
    contextCatalog.active = visibleTribes.filter((tribe: any) => String(tribe.workstream_type || 'research') === 'research');
    contextCatalog.operational = visibleTribes.filter((tribe: any) => String(tribe.workstream_type || '') === 'operational');
    contextCatalog.legacy = legacy || [];
    contextSwitchLoaded = true;
    renderContextSwitchMenu();
  }

  // ── Members tab ──
  function renderMembers(members: any[]) {
    const el = document.getElementById('panel-members');
    if (!el) return;

    if (!members.length) {
      el.innerHTML = `
        <div class="text-center py-14">
          <div class="text-4xl mb-3">👥</div>
          <div class="font-semibold text-slate-500 text-sm">${I18N.noMembers}</div>
        </div>`;
      return;
    }

    el.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${members.map(memberCardHtml).join('')}</div>`;
  }

  function memberCardHtml(m: any): string {
    const initials = (m.name || '?').split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
    const photo = m.photo_url
      ? `<img src="${escapeHtml(m.photo_url)}" class="w-12 h-12 rounded-full object-cover border-2 border-slate-100" alt="">`
      : `<div class="w-12 h-12 rounded-full bg-teal/20 flex items-center justify-center text-teal text-sm font-bold">${escapeHtml(initials)}</div>`;

    const opRole = m.operational_role || 'researcher';
    const roleColor = OPROLE_COLORS[opRole] || '#94A3B8';
    const roleLabel = OPROLE_LABELS[opRole] || opRole;
    const roleBadge = opRole !== 'none' && opRole !== 'guest'
      ? `<span class="inline-block px-2 py-0.5 rounded-md text-[.6rem] font-bold uppercase" style="background:${roleColor}22;color:${roleColor}">${escapeHtml(roleLabel)}</span>`
      : '';

    const desigs: string[] = m.designations || [];
    const desigBadges = desigs.map((d: string) =>
      `<span class="inline-block px-2 py-0.5 rounded-md text-[.6rem] font-bold uppercase bg-slate-100 text-slate-500">${escapeHtml(d)}</span>`
    ).join(' ');


    const contact = contactData[m.id];
    const hasContact = contact && (contact.email || contact.phone);
    const canSeeContacts = currentMember && (isHighManagement(currentMember) || (currentMember.operational_role === 'tribe_leader' && currentMember.tribe_id === TRIBE_ID));

    let contactHtml = '';
    if (canSeeContacts && hasContact) {
      const emailLine = contact.email ? '<div class="flex items-center gap-1 text-[11px] text-slate-500 truncate"><svg class="w-3 h-3 shrink-0 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>' + escapeHtml(contact.email) + '</div>' : '';
      const phoneLine = contact.phone ? '<div class="flex items-center gap-1 text-[11px] text-slate-500"><svg class="w-3 h-3 shrink-0 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>' + escapeHtml(contact.phone) + '</div>' : '';
      contactHtml = '<div class="mt-1.5 space-y-0.5">' + emailLine + phoneLine + '</div>';
    } else if (currentMember && !canSeeContacts) {
      const tip = escapeHtml(I18N.lgpdTooltip || 'Acesso restrito por LGPD');
      const lbl = escapeHtml(I18N.lgpdMask || 'LGPD');
      contactHtml = '<div class="mt-1.5 flex items-center gap-1 text-[10px] text-slate-400" title="' + tip + '"><svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg><span>***-*** <span class="underline decoration-dotted cursor-help">' + lbl + '</span></span></div>';
    }
    return `
      <div class="bg-white rounded-2xl border border-slate-100 p-5 flex items-start gap-3 hover:border-slate-300 hover:shadow-sm transition-all">
        ${photo}
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-navy leading-tight mb-1">${escapeHtml(m.name || '—')}</div>
          <div class="text-[12px] text-slate-400 mb-1.5">${escapeHtml(m.chapter || '')}</div>
          <div class="flex flex-wrap gap-1">${roleBadge} ${desigBadges}</div>
          ${contactHtml}
          ${waButton(m)}
        </div>
      </div>`;
  }

  function waButton(m: any): string {
    if (!m.share_whatsapp) return '';
    if (!currentMember) return '';
    const isSelf = currentMember.id === m.id;
    if (isSelf) return '';
    const isPeer = currentMember.tribe_id === TRIBE_ID
      || membersMap.has(currentMember.id)
      || isHighManagement(currentMember);
    if (!isPeer) return '';
    return `<a href="#" data-action="open-wa" data-member-id="${m.id}"
