---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
import ConfirmModal from '../../components/ui/ConfirmModal.astro';
import LoadingSkeleton from '../../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
import PresentationLayer from '../../components/ui/PresentationLayer.astro';
import TribeKanbanIsland from '../../components/boards/TribeKanbanIsland';
import BoardEngine from '../../components/islands/BoardEngine';
import TribeGamificationTab from '../../components/tribes/TribeGamificationTab';
import TribeAttendanceTab from '../../components/tribes/TribeAttendanceTab';
import EventMinutesIsland from '../../components/events/EventMinutesIsland';
import { getStaticTribeFallback } from '../../lib/tribes/catalog';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.kanban', 'comp.common', 'comp.board', 'comp.card', 'comp.tribe', 'tribe_dashboard', 'common'], lang);
const { id } = Astro.params;
const tribeId = parseInt(id || '0', 10);
if (tribeId < 1) return Astro.redirect('/');
const staticFallback = getStaticTribeFallback(tribeId, lang);
const TRIBE_I18N = {
  membersTab: t('tribe.membersTab', lang),
  deliverablesTab: t('tribe.deliverablesTab', lang),
  boardTab: t('tribe.boardTab', lang),
  resourcesTab: t('tribe.resourcesTab', lang),
  commsHubTab: t('tribe.commsHubTab', lang),
  meetingSchedule: t('tribe.meetingSchedule', lang),
  editMeetingSchedule: t('tribe.editMeetingSchedule', lang),
  meetingSchedulePlaceholder: t('tribe.meetingSchedulePlaceholder', lang),
  meetingScheduleSaved: t('tribe.meetingScheduleSaved', lang),
  noMembers: t('tribe.noMembers', lang),
  noDeliverables: t('tribe.noDeliverables', lang),
  noResources: t('tribe.noResources', lang),
  addDeliverable: t('tribe.addDeliverable', lang),
  statusPlanned: t('tribe.statusPlanned', lang),
  statusInProgress: t('tribe.statusInProgress', lang),
  statusCompleted: t('tribe.statusCompleted', lang),
  statusCancelled: t('tribe.statusCancelled', lang),
  loading: t('tribe.loading', lang),
  notFound: t('tribe.notFound', lang),
  tribeInactive: t('members.tribe_inactive', lang),
  tribeInactiveBanner: t('members.tribe_inactive', lang),
  leader: t('tribe.leader', lang),
  quadrant: t('tribe.quadrant', lang),
  dueDate: t('tribe.dueDate', lang),
  noDueDate: t('tribe.noDueDate', lang),
  assignee: t('tribe.assignee', lang),
  unassigned: t('tribe.unassigned', lang),
  openLink: t('tribe.openLink', lang),
  dateLocale: t('tribe.dateLocale', lang),
  error: t('tribe.error', lang),
  tribeName: staticFallback?.name || '',
  tribeDesc: staticFallback?.description || '',
  quadrantLabel: staticFallback?.quadrantLabel || '',
  tribePrefix: t('workspace.tribePrefix', lang),
  noDescription: t('tribe.noResources', lang),
  modalAddTitle: t('tribe.modal.addTitle', lang),
  modalEditTitle: t('tribe.modal.editTitle', lang),
  modalLabelTitle: t('tribe.modal.labelTitle', lang),
  modalLabelDescription: t('tribe.modal.labelDescription', lang),
  modalLabelStatus: t('tribe.modal.labelStatus', lang),
  modalLabelAssignee: t('tribe.modal.labelAssignee', lang),
  modalLabelDueDate: t('tribe.modal.labelDueDate', lang),
  modalLabelArtifact: t('tribe.modal.labelArtifact', lang),
  modalSelectMember: t('tribe.modal.selectMember', lang),
  modalSelectArtifact: t('tribe.modal.selectArtifact', lang),
  modalCancel: t('tribe.modal.cancel', lang),
  modalSave: t('tribe.modal.save', lang),
  requestReview: t('tribe.requestReview', lang),
  approvePeer: t('tribe.approvePeer', lang),
  approveForCuration: t('tribe.approveForCuration', lang),
  selectReviewer: t('tribe.selectReviewer', lang),
  modalTitleRequired: t('tribe.modal.titleRequired', lang),
  msgSaved: t('tribe.msg.saved', lang),
  msgSaveError: t('tribe.msg.saveError', lang),
  msgStatusUpdated: t('tribe.msg.statusUpdated', lang),
  msgStatusError: t('tribe.msg.statusError', lang),
  progressCompleted: t('tribe.progress.completed', lang),
  progressInProgress: t('tribe.progress.inProgress', lang),
  progressPlanned: t('tribe.progress.planned', lang),
  editDeliverable: t('tribe.editDeliverable', lang),
  moveToInProgress: t('tribe.moveTo.in_progress', lang),
  moveToCompleted: t('tribe.moveTo.completed', lang),
  moveToPlanned: t('tribe.moveTo.planned', lang),
  moveToCancelled: t('tribe.moveTo.cancelled', lang),
  joinWhatsApp: t('tribe.joinWhatsApp', lang),
  chatWhatsApp: t('tribe.chatWhatsApp', lang),
  lgpdMask: t('tribe.lgpdMask', lang),
  lgpdTooltip: t('tribe.lgpdTooltip', lang),
  broadcastTab: t('tribe.broadcastTab', lang),
  generalTab: t('tribe.generalTab', lang),
  viewingOther: t('tribe.viewingOther', lang),
  curatorAccess: t('tribe.curatorAccess', lang),
  upcomingEvents: t('tribe.upcomingEvents', lang),
  pastMeetings: t('tribe.pastMeetings', lang),
  recordingAvailable: t('tribe.recordingAvailable', lang),
  noRecording: t('tribe.noRecording', lang),
  createEvent: t('tribe.createEvent', lang),
  viewAllEvents: t('tribe.viewAllEvents', lang),
  viewAllMinutes: t('tribe.viewAllMinutes', lang),
  eligibleMembers: t('tribe.eligibleMembers', lang),
  joinMeet: t('tribe.joinMeet', lang),
  noUpcoming: t('tribe.noUpcoming', lang),
  recurringSlot: t('tribe.recurringSlot', lang),
  eligible: t('tribe.eligible', lang),
  attendees: t('tribe.attendees', lang),
  viewMinutes: t('events.view_minutes', lang),
  viewAgenda: t('events.view_agenda', lang),
  watchRecording: t('events.watch_recording', lang),
  radarGlobal: t('tribe.radarGlobal', lang),
  radarWebinars: t('tribe.radarWebinars', lang),
  radarPublications: t('tribe.radarPublications', lang),
  radarEmpty: t('tribe.radarEmpty', lang),
  broadcast: {
    title: t('tribe.broadcast.title', lang),
    subtitle: t('tribe.broadcast.subtitle', lang),
    subject: t('tribe.broadcast.subject', lang),
    subjectPlaceholder: t('tribe.broadcast.subjectPlaceholder', lang),
    body: t('tribe.broadcast.body', lang),
    bodyPlaceholder: t('tribe.broadcast.bodyPlaceholder', lang),
    send: t('tribe.broadcast.send', lang),
    sending: t('tribe.broadcast.sending', lang),
    sent: t('tribe.broadcast.sent', lang),
    error: t('tribe.broadcast.error', lang),
    confirmTitle: t('tribe.broadcast.confirmTitle', lang),
    confirmMsg: t('tribe.broadcast.confirmMsg', lang),
    confirmYes: t('tribe.broadcast.confirmYes', lang),
    confirmNo: t('tribe.broadcast.confirmNo', lang),
    historyTitle: t('tribe.broadcast.historyTitle', lang),
    historyEmpty: t('tribe.broadcast.historyEmpty', lang),
    historyRecipients: t('tribe.broadcast.historyRecipients', lang),
    subjectRequired: t('tribe.broadcast.subjectRequired', lang),
    bodyRequired: t('tribe.broadcast.bodyRequired', lang),
    ccMgmt: t('tribe.broadcast.ccMgmt', lang),
    rateLimit: t('tribe.broadcast.rateLimit', lang),
  },
  commsHub: {
    title: t('tribe.commsHub.title', lang),
    subtitle: t('tribe.commsHub.subtitle', lang),
    loading: t('tribe.commsHub.loading', lang),
    empty: t('tribe.commsHub.empty', lang),
    colDate: t('tribe.commsHub.colDate', lang),
    colChannel: t('tribe.commsHub.colChannel', lang),
    colAudience: t('tribe.commsHub.colAudience', lang),
    colReach: t('tribe.commsHub.colReach', lang),
    colEngagement: t('tribe.commsHub.colEngagement', lang),
    colLeads: t('tribe.commsHub.colLeads', lang),
  },
  oproleLabels: {
    manager: t('profile.oprole.manager', lang),
    deputy_manager: t('profile.oprole.deputyManager', lang),
    tribe_leader: t('profile.oprole.tribeLeader', lang),
    researcher: t('profile.oprole.researcher', lang),
    facilitator: t('profile.oprole.facilitator', lang),
    communicator: t('profile.oprole.communicator', lang),
    none: t('profile.oprole.none', lang),
    guest: t('profile.oprole.guest', lang),
  },
  dayNames: [
    t('common.days.sun', lang), t('common.days.mon', lang), t('common.days.tue', lang),
    t('common.days.wed', lang), t('common.days.thu', lang), t('common.days.fri', lang),
    t('common.days.sat', lang),
  ],
  accessRestricted: t('tribe.accessRestricted', lang),
  crossManagementMode: t('tribe.crossManagementMode', lang),
  explorationMode: t('tribe.explorationMode', lang),
  highlights: t('tribe.highlights', lang),
  highlightsDesc: t('tribe.highlightsDesc', lang),
  sharedRefs: t('tribe.sharedRefs', lang),
  showcase: t('tribe.showcase', lang),
  webinarsEvents: t('tribe.webinarsEvents', lang),
  knowledgeBase: t('tribe.knowledgeBase', lang),
  ctxResearch: t('tribe.ctxResearch', lang),
  ctxOperations: t('tribe.ctxOperations', lang),
  ctxLegacy: t('tribe.ctxLegacy', lang),
};
const pageTitle = t('tribe.meta', lang).replace('{name}', staticFallback?.name || `T${tribeId}`);
---
<BaseLayout title={pageTitle} activePage="tribes" lang={lang}>
  <Toast />
  <ConfirmModal />
  <div class="max-w-[1400px] mx-auto px-4 py-8">
    <div id="tribe-loading" class="text-center py-10 text-[var(--text-muted)]">{t('tribe.loading', lang)}</div>
    <div id="tribe-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">{TRIBE_I18N.accessRestricted}</p>
      <p class="text-sm text-amber-700 mt-1">{t('tribe.deniedExplore', lang)}</p>
      <a href="/profile" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90 transition-all">{t('tribe.openProfile', lang)}</a>
    </div>
    <div id="tribe-shell" class="hidden">
    <!-- Header -->
    <div id="tribe-header" class="mb-6">
      <LoadingSkeleton variant="profile" />
    </div>
    <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
    <div id="tribe-access-note" class="hidden mb-4"></div>

    <!-- Cross-tribe viewing banner -->
    <div id="cross-tribe-banner" class="hidden rounded-xl px-4 py-3 text-sm mb-4 flex items-center gap-2">
    </div>

    <!-- Tabs: Cockpit simplificado [Geral | Kanban | Membros] -->
    <div class="flex gap-2 mb-5 flex-wrap" id="tribe-tabs">
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
              data-tab="general" data-action="switch-tab">{t('tribe.generalTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
              data-tab="board" data-action="switch-tab">{TRIBE_I18N.boardTab}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
              data-tab="members" data-action="switch-tab">{t('tribe.membersTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
              data-tab="gamification" data-action="switch-tab">🏆 {t('tribe.gamificationTab', lang)}</button>
      <button class="tribe-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
              data-tab="attendance" data-action="switch-tab">📋 {t('tribe.attendanceTab', lang)}</button>
    </div>

    <!-- Tab panels -->
    <div id="panel-general">
      <LoadingSkeleton variant="card" count={2} />
    </div>
    <div id="panel-board" class="hidden">
      <BoardEngine client:load domainKey="research_delivery" tribeId={tribeId} />
    </div>
    <div id="panel-members" class="hidden">
      <LoadingSkeleton variant="card" count={4} />
    </div>
    <div id="panel-gamification" class="hidden">
      <TribeGamificationTab client:load tribeId={tribeId} />
    </div>
    <div id="panel-attendance" class="hidden">
      <TribeAttendanceTab client:load tribeId={tribeId} />
    </div>
    <div id="panel-broadcast" class="hidden"></div>
    <EventMinutesIsland client:load />
    </div>
  </div>

  <!-- Deliverable Modal -->
  <div id="deliverable-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" data-action="close-deliverable-modal"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[var(--surface-elevated)] rounded-2xl shadow-xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto border border-[var(--border-default)]">
      <h2 id="deliverable-modal-title" class="text-lg font-extrabold text-navy mb-4"></h2>
      <form id="deliverable-form" class="flex flex-col gap-3">
        <input type="hidden" id="dlv-id" />
        <div>
          <label for="dlv-title" class="text-[13px] font-semibold text-[var(--text-secondary)] mb-1 block" id="lbl-dlv-title"></label>
          <input type="text" id="dlv-title" required class="w-full px-3 py-2 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
        </div>
        <div>
          <label for="dlv-description" class="text-[13px] font-semibold text-[var(--text-secondary)] mb-1 block" id="lbl-dlv-description"></label>
          <textarea id="dlv-description" rows="3" class="w-full px-3 py-2 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></textarea>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label for="dlv-status" class="text-[13px] font-semibold text-[var(--text-secondary)] mb-1 block" id="lbl-dlv-status"></label>
            <select id="dlv-status" class="w-full px-3 py-2 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
          </div>
          <div>
            <label for="dlv-due-date" class="text-[13px] font-semibold text-[var(--text-secondary)] mb-1 block" id="lbl-dlv-due-date"></label>
            <input type="date" id="dlv-due-date" class="w-full px-3 py-2 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
          </div>
        </div>
        <div>
          <label for="dlv-assignee" class="text-[13px] font-semibold text-[var(--text-secondary)] mb-1 block" id="lbl-dlv-assignee"></label>
          <select id="dlv-assignee" class="w-full px-3 py-2 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
        </div>
        <div>
          <label for="dlv-artifact" class="text-[13px] font-semibold text-[var(--text-secondary)] mb-1 block" id="lbl-dlv-artifact"></label>
          <select id="dlv-artifact" class="w-full px-3 py-2 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40"></select>
        </div>
        <div class="flex justify-end gap-3 mt-2">
          <button type="button" data-action="close-deliverable-modal" class="px-4 py-2 text-sm font-semibold text-[var(--text-secondary)] border border-[var(--border-default)] rounded-lg cursor-pointer hover:bg-[var(--surface-hover)] transition-all" id="btn-dlv-cancel"></button>
          <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-navy rounded-lg cursor-pointer border-0 hover:opacity-90 transition-all" id="btn-dlv-save"></button>
        </div>
      </form>
    </div>
  </div>

  <!-- Meeting Schedule Edit Modal (Radix-style inline) -->
  <div id="meeting-schedule-modal" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/40" data-action="close-meeting-schedule-modal"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-[var(--surface-elevated)] rounded-2xl shadow-xl w-full max-w-md p-6 border border-[var(--border-default)]">
      <h2 class="text-lg font-extrabold text-navy mb-4">{t('tribe.editMeetingSchedule', lang)}</h2>
      <div class="flex flex-col gap-3">
        <input type="text" id="meeting-schedule-input" placeholder={t('tribe.meetingSchedulePlaceholder', lang)}
          class="w-full px-3 py-2.5 border border-[var(--border-default)] bg-[var(--surface-input)] text-[var(--text-primary)] rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-purple/40" />
        <div class="flex justify-end gap-2">
          <button type="button" data-action="close-meeting-schedule-modal" class="px-4 py-2 text-sm font-semibold text-[var(--text-secondary)] border border-[var(--border-default)] rounded-lg cursor-pointer hover:bg-[var(--surface-hover)] transition-all">{t('tribe.modal.cancel', lang)}</button>
          <button type="button" data-action="save-meeting-schedule" class="px-4 py-2 text-sm font-semibold text-white bg-navy rounded-lg cursor-pointer border-0 hover:opacity-90 transition-all">{t('tribe.modal.save', lang)}</button>
        </div>
      </div>
    </div>
  </div>
  <PresentationLayer context="tribe" tribeId={tribeId} lang={lang} />
</BaseLayout>

<script is:inline define:vars={{ TRIBE_I18N, tribeId }}>
  window.__TRIBE_I18N = typeof TRIBE_I18N !== 'undefined' ? TRIBE_I18N : {};
  window.__TRIBE_ID = typeof tribeId !== 'undefined' ? tribeId : 0;
</script>
<script>
  import { getCurrentCycle, loadCycles } from '../../lib/cycles';
  import { canExploreTribes, canManageTribeLifecycle, canSeeInactiveTribes } from '../../lib/tribes/access';
  import { buildTribeLabel } from '../../lib/tribes/catalog';
  import { hasPermission } from '../../lib/permissions';
  import { getTribePermissions } from '../../lib/tribePermissions';
  import { marked } from 'marked';

  const I18N = (typeof window !== 'undefined' && (window as any).__TRIBE_I18N) || {};
  const TRIBE_ID: number = (typeof window !== 'undefined' && (window as any).__TRIBE_ID) || 0;
  // V4: initiative_id resolved on load (set by resolveInitiativeId below)
  let INITIATIVE_ID: string | null = null;

  // Supabase client helper — used throughout the tribe dashboard
  function getSb() { return (window as any).navGetSb?.(); }

  // V4: resolve tribe integer → initiative UUID once on load
  async function resolveInitiativeId() {
    const sb = getSb();
    if (!sb || !TRIBE_ID) return;
    const { data } = await sb.rpc('resolve_initiative_id', { p_tribe_id: TRIBE_ID });
    if (data) INITIATIVE_ID = data;
  }

  const OPROLE_LABELS: Record<string, string> = I18N.oproleLabels || {};
  const OPROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', deputy_manager: '#FF610F', tribe_leader: '#4F17A8', comms_leader: '#06B6D4', researcher: '#EC4899',
    facilitator: '#06B6D4', communicator: '#8B5CF6', none: '#94A3B8', guest: '#94A3B8'
  };
  const STATUS_COLORS: Record<string, { bg: string; text: string }> = {
    planned:     { bg: 'bg-[var(--surface-section-cool)]', text: 'text-[var(--text-secondary)]' },
    in_progress: { bg: 'bg-blue-50', text: 'text-blue-700' },
    completed:   { bg: 'bg-emerald-50', text: 'text-emerald-700' },
    cancelled:   { bg: 'bg-red-50', text: 'text-red-600' },
  };
  const STATUS_LABELS: Record<string, string> = {
    planned: I18N.statusPlanned, in_progress: I18N.statusInProgress,
    completed: I18N.statusCompleted, cancelled: I18N.statusCancelled,
  };
  const TYPE_ICONS: Record<string, string> = {
    'Curso': '🎓', 'Referência': '📘', 'Webinar': '▶️', 'Outro': '📎',
    'Course': '🎓', 'Reference': '📘',
  };
  const DAY_NAMES: string[] = I18N.dayNames || ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  const HIGH_MGMT_ROLES = ['manager', 'deputy_manager'];

  function isHighManagement(m: any): boolean {
    return canManageTribeLifecycle(m);
  }

  function isAssignedToCurrentTribe(m: any): boolean {
    if (!m) return false;
    return Number(m.tribe_id || 0) === TRIBE_ID || Number(m.selected_tribe_id || 0) === TRIBE_ID;
  }

  function showDenied(message?: string) {
    document.getElementById('tribe-loading')?.classList.add('hidden');
    document.getElementById('tribe-shell')?.classList.add('hidden');
    const denied = document.getElementById('tribe-denied');
    if (!denied) return;
    denied.classList.remove('hidden');
    if (message) {
      const body = denied.querySelector('p');
      if (body) body.textContent = message;
    }
  }

  function revealTribeShell() {
    document.getElementById('tribe-loading')?.classList.add('hidden');
    document.getElementById('tribe-denied')?.classList.add('hidden');
    document.getElementById('tribe-shell')?.classList.remove('hidden');
  }

  function renderAccessNote() {
    const note = document.getElementById('tribe-access-note');
    if (!note || !currentMember) return;
    if (isAssignedToCurrentTribe(currentMember)) {
      note.classList.add('hidden');
      note.innerHTML = '';
      return;
    }
    note.classList.remove('hidden');
    if (canEdit) {
      note.className = 'mb-4 rounded-2xl border border-purple-200 bg-purple-50 px-4 py-3 text-sm text-purple-800';
      note.innerHTML = I18N.crossManagementMode || 'Cross-management mode: you are in another stream with coordination permission.';
      return;
    }
    note.className = 'mb-4 rounded-2xl border border-[var(--border-default)] bg-[var(--surface-base)] px-4 py-3 text-sm text-[var(--text-secondary)]';
    note.innerHTML = I18N.explorationMode || 'Exploration mode: you can browse members, resources and board, but actions remain restricted to local leadership.';
  }

  function escapeHtml(s: string): string {
    return String(s || '')
      .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  let sb: any = null;
  let currentMember: any = null;
  let membersMap: Map<string, any> = new Map();
  let canEdit = false;
  let tribeData: any = null;
  let currentCycleCode = '';
  let allDeliverables: any[] = [];
  let publishedArtifacts: any[] = [];
  let contactData: Record<string, {email?:string, phone?:string}> = {};
  let contextSwitchLoaded = false;
  let headerLeader: any = null;
  let headerSlots: any[] = [];
  let contextCatalog: { active: any[]; operational: any[]; legacy: any[] } = { active: [], operational: [], legacy: [] };
  function getActiveCycleCode(): string {
    return currentCycleCode || allDeliverables.find((item: any) => item?.cycle_code)?.cycle_code || '';
  }

  // ── Tab switching ──
  function switchTab(tabName: string) {
    const panels = ['general', 'board', 'members', 'commshub', 'broadcast', 'gamification', 'attendance'];
    panels.forEach(p => {
      const el = document.getElementById(`panel-${p}`);
      if (el) el.classList.toggle('hidden', p !== tabName);
    });
    document.querySelectorAll('.tribe-tab').forEach(btn => {
      const isActive = (btn as HTMLElement).dataset.tab === tabName;
      btn.classList.toggle('bg-navy', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-navy', isActive);
      btn.classList.toggle('bg-[var(--surface-card)]', !isActive);
      btn.classList.toggle('text-[var(--text-secondary)]', !isActive);
      btn.classList.toggle('border-[var(--border-default)]', !isActive);
    });
  }


  // Comms Hub removed from tribe pages — lives exclusively at /admin/comms-ops

  // ── Header render (Landing Page design system parity) ──
  const QUAD_COLORS: Record<string, string> = { q1: '#00799E', q2: '#FF610F', q3: '#4F17A8', q4: '#10B981' };
  function renderHeader(_tribe: any, leader: any, slots: any[]) {
    const el = document.getElementById('tribe-header');
    if (!el) return;

    const leaderName = leader ? escapeHtml(leader.name) : '—';
    const leaderInitials = leader
      ? escapeHtml(leader.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase())
      : '?';
    const qColor = QUAD_COLORS[_tribe?.quadrant || 'q3'];
    const leaderPhotoHtml = leader?.photo_url
      ? `<img src="${escapeHtml(leader.photo_url)}" class="w-[42px] h-[42px] rounded-xl object-cover" alt="${leaderName}">`
      : `<div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center text-white font-extrabold text-base" style="background:${qColor}">${leaderInitials}</div>`;

    let scheduleHtml = '';
    if (_tribe?.meeting_schedule && String(_tribe.meeting_schedule).trim()) {
      scheduleHtml = escapeHtml(String(_tribe.meeting_schedule).trim());
    } else if (slots?.length) {
      scheduleHtml = slots.map(s => {
        const day = DAY_NAMES[s.day_of_week] || '?';
        const start = (s.time_start || '').substring(0, 5).replace(/:00$/, 'h').replace(/:(\d\d)$/, 'h$1');
        const end = (s.time_end || '').substring(0, 5).replace(/:00$/, 'h').replace(/:(\d\d)$/, 'h$1');
        return `${day} · ${start}–${end}`;
      }).join(' · ');
    } else {
      scheduleHtml = '<span class="text-[var(--text-muted)] italic">—</span>';
    }
    const editBtnHtml = canEdit
      ? ` <button data-action="open-meeting-schedule-modal" type="button" class="inline-flex items-center justify-center w-6 h-6 rounded-lg text-[var(--text-muted)] hover:bg-[var(--surface-hover)] hover:text-navy transition-all cursor-pointer" title="${escapeHtml(I18N.editMeetingSchedule || 'Editar horário')}"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg></button>`
      : '';

    const tribeName = buildTribeLabel(_tribe, { prefix: I18N.tribePrefix || 'Tribo' });
    const quadrantLabel = _tribe?.quadrant_name || I18N.quadrantLabel || '';
    const tribeDescription = _tribe?.notes || I18N.tribeDesc || '—';
    const memberCount = membersMap.size;
    const linkedIn = leader?.linkedin_url || '';

    el.innerHTML = `
      <div class="bg-[var(--surface-card)] rounded-2xl overflow-hidden border border-[var(--border-subtle)] hover:shadow-md transition-all duration-300">
        <div class="flex items-center gap-4 px-5 py-4">
          <div class="flex-shrink-0">${leaderPhotoHtml}</div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-[.95rem] font-bold text-[var(--text-primary)] truncate">${escapeHtml(tribeName)}</h1>
              ${quadrantLabel ? `<span class="px-2 py-0.5 rounded-md text-[.68rem] font-bold uppercase tracking-wide" style="color:${qColor};background:${qColor}15">${escapeHtml(quadrantLabel)}</span>` : ''}
              <button data-action="toggle-context-switch" class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[.68rem] font-bold text-[var(--text-secondary)] bg-[var(--surface-section-cool)] border border-[var(--border-default)] hover:bg-[var(--surface-hover)] transition-all cursor-pointer">
                Trocar ▾
              </button>
            </div>
            <div id="tribe-context-switch" class="hidden mt-2 rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] shadow-lg p-3 max-w-xl absolute z-20"></div>
            <div class="text-[.82rem] text-[var(--text-secondary)] mt-0.5">
              ${leaderName}${linkedIn ? ` <a href="${escapeHtml(linkedIn)}" target="_blank" rel="noopener" class="text-teal no-underline text-[.75rem] ml-1">🔗</a>` : ''}
            </div>
          </div>
          <div class="flex-shrink-0 text-center">
            <div class="text-[.68rem] text-[var(--text-secondary)] font-semibold">👥 ${memberCount}</div>
          </div>
        </div>
        <div class="px-5 pb-4 pt-0 border-t border-[var(--border-subtle)]">
          <p class="text-[.88rem] text-[var(--text-secondary)] mb-3 line-clamp-2">${escapeHtml(tribeDescription)}</p>
          <div class="flex flex-wrap gap-x-5 gap-y-2 text-[.82rem]">
            <div class="flex items-center gap-1.5" id="tribe-schedule-cell">
              <strong class="text-[var(--text-secondary)]">📅 ${I18N.meetingSchedule}:</strong>
              <span class="text-[var(--text-muted)]">${scheduleHtml}</span>${editBtnHtml}
            </div>
          </div>
        </div>
      </div>
      <div id="tribe-wa-cta" class="hidden mt-3"></div>`;

    // WhatsApp CTA: show only if tribe has whatsapp_url AND user belongs to tribe (or is admin)
    if (_tribe?.whatsapp_url && currentMember) {
      const isTribeMember = currentMember.tribe_id === TRIBE_ID
        || membersMap.has(currentMember.id);
      const isAdmin = isHighManagement(currentMember);
      if (isTribeMember || isAdmin) {
        const ctaEl = document.getElementById('tribe-wa-cta');
        if (ctaEl) {
          ctaEl.classList.remove('hidden');
          ctaEl.innerHTML = `
            <a href="${escapeHtml(_tribe.whatsapp_url)}" target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#25D366] text-white rounded-xl text-[14px] font-bold no-underline hover:bg-[#1FAD53] transition-all shadow-sm">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              ${I18N.joinWhatsApp || 'Entrar no Grupo do WhatsApp'}
            </a>`;
        }
      }
    }
  }

  function renderContextSection(title: string, items: string[]): string {
    if (!items.length) return '';
    return `<div class="mb-2">
      <div class="text-[10px] font-bold uppercase tracking-wide text-[var(--text-muted)] mb-1">${title}</div>
      <div class="space-y-1">${items.join('')}</div>
    </div>`;
  }

  function renderContextSwitchMenu() {
    const el = document.getElementById('tribe-context-switch');
    if (!el) return;
    const activeLinks = contextCatalog.active.map((tribe: any) => `
      <a href="/tribe/${tribe.id}" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] no-underline transition-all">
        <span class="w-4 h-4 rounded-full bg-navy/10 text-navy text-[10px] flex items-center justify-center font-bold">${tribe.id}</span>
        ${escapeHtml(buildTribeLabel(tribe, { prefix: I18N.tribePrefix || 'Tribo' }))}
      </a>
    `);

    const opLinks = contextCatalog.operational.map((tribe: any) => `
      <a href="/tribe/${tribe.id}" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] no-underline transition-all">
        <span class="w-4 h-4 rounded-full bg-purple/10 text-purple text-[10px] flex items-center justify-center font-bold">${tribe.id}</span>
        ${escapeHtml(buildTribeLabel(tribe, { prefix: I18N.tribePrefix || 'Tribo' }))}
      </a>
    `);
    const webinars = `<a href="/webinars" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] no-underline transition-all">🎙️ Webinars</a>`;
    const opWithWebinars = [webinars, ...opLinks];

    const legacyLinks = contextCatalog.legacy.map((legacy: any) => `
      <a href="/#team" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[12px] font-medium text-[var(--text-secondary)] hover:bg-[var(--surface-hover)] no-underline transition-all">
        <span class="text-[10px]">🏛️</span>
        ${escapeHtml(legacy.legacy_name || `Legado #${legacy.id}`)}
      </a>
    `);

    el.innerHTML = [
      renderContextSection(I18N.ctxResearch || 'Active (Research)', activeLinks),
      renderContextSection(I18N.ctxOperations || 'Sub-projects (Operations)', opWithWebinars),
      renderContextSection(I18N.ctxLegacy || 'Legacy (Read-only)', legacyLinks),
    ].join('');
  }

  async function ensureContextSwitchData() {
    if (contextSwitchLoaded || !sb) return;
    const [{ data: tribes }, { data: dimRows }] = await Promise.all([
      sb.from('tribes').select('id, name, is_active, workstream_type').order('id'),
      sb.from('cycle_tribe_dim').select('tribe_name, cycle_code').not('cycle_code', 'eq', 'cycle_3').order('dim_id'),
    ]);

    const visibleTribes = (tribes || []).filter((tribe: any) => canSeeInactiveTribes(currentMember) || tribe.is_active !== false);
    contextCatalog.active = visibleTribes.filter((tribe: any) => String(tribe.workstream_type || 'research') === 'research');
    contextCatalog.operational = visibleTribes.filter((tribe: any) => String(tribe.workstream_type || '') === 'operational');
    // Build legacy list from cycle_tribe_dim (replaces legacy_tribes table)
    const seen = new Set<string>();
    contextCatalog.legacy = (dimRows || []).filter((r: any) => { if (seen.has(r.tribe_name)) return false; seen.add(r.tribe_name); return true; }).map((r: any) => ({ id: r.tribe_name, legacy_name: r.tribe_name }));
    contextSwitchLoaded = true;
    renderContextSwitchMenu();
  }

  // ── Tribe Stats KPI cards ──
  async function loadTribeStats() {
    const el = document.getElementById('panel-general');
    if (!el || !sb) return;
    try {
      const { data } = INITIATIVE_ID
        ? await sb.rpc('get_initiative_stats', { p_initiative_id: INITIATIVE_ID })
        : await sb.rpc('get_tribe_stats', { p_tribe_id: TRIBE_ID });
      if (!data) return;
      const rateColor = (data.attendance_rate || 0) >= 75 ? '#10B981' : (data.attendance_rate || 0) >= 50 ? '#D97706' : '#BE2027';
      const statsHtml = `<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
          <div class="text-2xl font-extrabold text-navy">${data.member_count}</div>
          <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Membros</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
          <div class="text-2xl font-extrabold" style="color:${rateColor}">${data.attendance_rate ?? 0}%</div>
          <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Presenca</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
          <div class="text-2xl font-extrabold text-[var(--color-teal)]">${data.impact_hours ?? 0}h</div>
          <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Horas</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
          <div class="text-lg font-extrabold text-[var(--text-primary)]">
            <span class="text-green-600">${data.cards_done}</span>
            <span class="text-[var(--text-muted)]">/</span>
            <span class="text-blue-600">${data.cards_in_progress}</span>
            <span class="text-[var(--text-muted)]">/</span>
            <span class="text-gray-400">${data.cards_backlog}</span>
          </div>
          <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Cards (feito/prog/backlog)</div>
        </div>
      </div>
      ${Array.isArray(data.top_contributors) && data.top_contributors.length > 0 ? `
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 mb-6">
        <h4 class="text-xs font-bold text-[var(--text-secondary)] uppercase mb-2">Presenca por Membro</h4>
        <div class="space-y-1.5">
          ${data.top_contributors.map((c: any) => {
            const barColor = (c.rate || 0) >= 75 ? '#10B981' : (c.rate || 0) >= 50 ? '#D97706' : '#BE2027';
            return `<div class="flex items-center gap-2">
              <span class="text-[11px] font-medium text-[var(--text-primary)] w-[140px] truncate">${c.name?.split(' ').slice(0, 2).join(' ')}</span>
              <div class="flex-1 h-2 bg-gray-100 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style="width:${c.rate}%;background:${barColor}"></div>
              </div>
              <span class="text-[10px] font-bold w-[35px] text-right" style="color:${barColor}">${c.rate}%</span>
            </div>`;
          }).join('')}
        </div>
      </div>` : ''}`;
      el.insertAdjacentHTML('afterbegin', statsHtml);
    } catch {}
  }

  // ── Geral tab: Events Timeline ──
  async function loadEventsTimeline() {
    const el = document.getElementById('panel-general');
    if (!el || !sb) return;
    try {
      const { data, error } = INITIATIVE_ID
        ? await sb.rpc('get_initiative_events_timeline', { p_initiative_id: INITIATIVE_ID, p_upcoming_limit: 3, p_past_limit: 5 })
        : await sb.rpc('get_tribe_events_timeline', { p_tribe_id: TRIBE_ID, p_upcoming_limit: 3, p_past_limit: 5 });
      if (error || !data) return;

      const today = new Date().toISOString().slice(0, 10);
      const tomorrow = new Date(Date.now() + 86400000).toISOString().slice(0, 10);
      const locale = I18N.dateLocale || 'pt-BR';
      const perms = currentMember ? getTribePermissions(currentMember, TRIBE_ID) : null;

      // Minutes edit permission: superadmin, GP, deputy, tribe leader, or researcher for own tribe
      const canEditMinutes = (evtTribeId: number | null) => {
        if (!currentMember) return false;
        if (currentMember.is_superadmin) return true;
        if (['manager'].includes(currentMember.operational_role)) return true;
        if ((currentMember.designations || []).includes('deputy_manager')) return true;
        if ((currentMember.operational_role === 'tribe_leader' || currentMember.operational_role === 'comms_leader') && currentMember.tribe_id === evtTribeId) return true;
        if (currentMember.operational_role === 'researcher' && currentMember.tribe_id === evtTribeId) return true;
        return false;
      };

      const typeIcon = (t: string) => t === 'geral' ? '🌐' : t === 'lideranca' ? '👥' : '🔬';

      // Upcoming events
      const upcoming = Array.isArray(data.upcoming) ? data.upcoming : [];
      let upcomingHtml = '';
      if (upcoming.length > 0) {
        upcomingHtml = upcoming.map((e: any) => {
          const d = new Date(e.date + 'T12:00:00').toLocaleDateString(locale, { weekday: 'short', day: '2-digit', month: 'short' });
          const dur = e.duration_minutes ? `${e.duration_minutes}min` : '';
          const showMeetLink = e.meeting_link && (e.date === today || e.date === tomorrow);
          return `<div class="flex items-start gap-3 py-2.5 border-b border-[var(--border-subtle)] last:border-0">
            <span class="text-base mt-0.5">${typeIcon(e.type)}</span>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-semibold text-[var(--text-primary)]">${escapeHtml(e.title)}</div>
              <div class="text-xs text-[var(--text-secondary)] flex flex-wrap gap-x-3 mt-0.5">
                <span>📅 ${d}</span>
                ${dur ? `<span>⏱️ ${dur}</span>` : ''}
                <span>👥 ${e.eligible_count} ${I18N.eligibleMembers || 'elegíveis'}</span>
              </div>
            </div>
            ${showMeetLink ? `<a href="${escapeHtml(e.meeting_link)}" target="_blank" rel="noopener" class="shrink-0 px-3 py-1.5 rounded-lg bg-teal text-white text-xs font-semibold no-underline hover:opacity-90">${I18N.joinMeet || 'Entrar'} →</a>` : ''}
          </div>`;
        }).join('');
      } else if (data.next_recurring) {
        const nr = data.next_recurring;
        upcomingHtml = `<div class="py-4 text-center text-sm text-[var(--text-muted)]">${I18N.noUpcoming || 'Nenhum evento agendado.'}<br><span class="text-xs">${I18N.recurringSlot || 'Slot recorrente'}: ${nr.day_name_pt} ${(nr.time_start || '').substring(0, 5)}-${(nr.time_end || '').substring(0, 5)}</span></div>`;
      } else {
        upcomingHtml = `<div class="py-4 text-center text-sm text-[var(--text-muted)]">${I18N.noUpcoming || 'Nenhum evento agendado.'}</div>`;
      }

      const createEventBtn = perms?.canCreateEvent
        ? `<a href="/attendance?tribe=${TRIBE_ID}" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-navy text-white text-xs font-semibold no-underline hover:opacity-90 mt-2">+ ${I18N.createEvent || 'Criar Evento'}</a>`
        : '';

      // Past meetings
      const past = Array.isArray(data.past) ? data.past : [];
      let pastHtml = '';
      if (past.length > 0) {
        pastHtml = past.map((e: any) => {
          const d = new Date(e.date + 'T12:00:00').toLocaleDateString(locale, { day: '2-digit', month: 'short' });
          const recUrl = e.youtube_url || e.recording_url || '';
          const recLabel = e.has_recording
            ? `<a href="${escapeHtml(recUrl)}" target="_blank" rel="noopener" class="text-xs font-semibold text-teal no-underline hover:underline">▶️ ${I18N.recordingAvailable || 'Gravação'}</a>`
            : `<span class="text-xs text-[var(--text-muted)]">⚠️ ${I18N.noRecording || 'Sem gravação'}</span>`;
          // Content badges
          const badges: string[] = [];
          if (e.minutes_text) badges.push('<span class="px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-green-100 text-green-700">📝 Ata</span>');
          if (e.has_recording) badges.push('<span class="px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-blue-100 text-blue-700">🎥</span>');
          if (e.agenda_text) badges.push('<span class="px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-yellow-100 text-yellow-700">📋 Pauta</span>');
          const badgesHtml = badges.length ? `<div class="flex gap-1 mt-1">${badges.join('')}</div>` : '';
          // Expandable minutes (parse Markdown → HTML, then render with prose class)
          const minutesRendered = e.minutes_text ? marked.parse(e.minutes_text) : '';
          const minutesHtml = e.minutes_text
            ? `<details class="mt-2 rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-section-cool)] overflow-hidden"><summary class="px-3 py-2 text-[.65rem] font-bold uppercase tracking-wider text-[var(--text-muted)] cursor-pointer hover:bg-[var(--surface-hover)]">${I18N.viewMinutes || 'Ver ata'}</summary><div class="px-3 pb-2 text-sm text-[var(--text-secondary)] prose prose-sm max-w-none">${minutesRendered}</div></details>`
            : '';
          // Edit buttons (permission-gated)
          const showEditBtn = canEditMinutes(e.tribe_id);
          const editMinutesBtn = showEditBtn
            ? `<button data-action="open-minutes-editor" data-event-id="${e.id}" data-event-title="${escapeHtml(e.title)}" data-mode="minutes" data-content="${escapeHtml(e.minutes_text || '')}" class="text-[.65rem] font-semibold text-navy hover:underline cursor-pointer border-0 bg-transparent px-0">${e.minutes_text ? '✏️ Editar ata' : '📝 Adicionar ata'}</button>`
            : '';
          return `<div class="py-2.5 border-b border-[var(--border-subtle)] last:border-0">
            <div class="flex items-start gap-3">
              <span class="text-base mt-0.5">${typeIcon(e.type)}</span>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-[var(--text-primary)]">${escapeHtml(e.title)}</div>
                <div class="text-xs text-[var(--text-secondary)] flex flex-wrap gap-x-3 mt-0.5">
                  <span>${d}</span>
                  ${recLabel}
                  <span>📊 ${e.attendee_count}/${e.eligible_count}</span>
                  ${e.duration_minutes ? `<span>⏱️ ${e.duration_minutes}min</span>` : ''}
                </div>
                ${badgesHtml}
                ${editMinutesBtn ? `<div class="mt-1">${editMinutesBtn}</div>` : ''}
              </div>
            </div>
            ${minutesHtml}
          </div>`;
        }).join('');
      }

      // Insert timeline blocks at the top of panel-general
      const timelineEl = document.createElement('div');
      timelineEl.className = 'space-y-4 mb-6';
      timelineEl.innerHTML = `
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] overflow-hidden">
          <div class="px-5 py-3.5 border-b border-[var(--border-subtle)] flex items-center gap-2">
            <span class="text-lg">📅</span>
            <h3 class="text-sm font-bold text-navy">${I18N.upcomingEvents || 'Próximos Eventos'}</h3>
          </div>
          <div class="px-5 py-2">${upcomingHtml}</div>
          ${createEventBtn ? `<div class="px-5 pb-3">${createEventBtn}</div>` : ''}
        </div>
        ${pastHtml ? `<div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] overflow-hidden">
          <div class="px-5 py-3.5 border-b border-[var(--border-subtle)] flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-lg">📼</span>
              <h3 class="text-sm font-bold text-navy">${I18N.pastMeetings || 'Reuniões Anteriores'}</h3>
            </div>
            <div class="flex items-center gap-3">
              <a href="/meetings" class="text-xs font-semibold text-teal-600 no-underline hover:underline">📝 ${I18N.viewAllMinutes || 'Ver Atas'}</a>
              <a href="/attendance" class="text-xs font-semibold text-navy no-underline hover:underline">${I18N.viewAllEvents || 'Ver todos'} →</a>
            </div>
          </div>
          <div class="px-5 py-2">${pastHtml}</div>
        </div>` : ''}
      `;
      el.prepend(timelineEl);
    } catch (e: any) {
      console.warn('Events timeline load failed:', e);
    }
  }

  // ── Geral tab (Radar Global) ──
  async function loadRadarGlobal() {
    const el = document.getElementById('panel-general');
    if (!el || !sb) return;
    try {
      const { data, error } = await sb.rpc('list_radar_global', { p_webinars_limit: 5, p_publications_limit: 5 });
      if (error) throw new Error(error.message);
      renderGeneralPanel(data || { webinars: [], publications: [] });
    } catch (e: any) {
      el.innerHTML = `
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-6">
          <h2 class="text-base font-extrabold text-navy mb-4">${escapeHtml(I18N.radarGlobal || 'Radar Global')}</h2>
          <p class="text-sm text-[var(--text-secondary)]">${escapeHtml(e?.message || I18N.error || 'Erro ao carregar.')}</p>
        </div>`;
    }
  }

  function renderGeneralPanel(radar: { webinars?: any[]; publications?: any[] }) {
    const el = document.getElementById('panel-general');
    if (!el) return;
    const webinars = Array.isArray(radar.webinars) ? radar.webinars : [];
    const publications = Array.isArray(radar.publications) ? radar.publications : [];
    const today = new Date().toISOString().slice(0, 10);
    const upcomingWebinars = webinars
      .filter((w: any) => String(w?.date || '').slice(0, 10) >= today)
      .sort((a: any, b: any) => String(a?.date || '').localeCompare(String(b?.date || '')))
      .slice(0, 5);
    const recentPubs = publications.slice(0, 5);

    function renderItemRow(title: string, subtitle: string, href?: string): string {
      const label = href
        ? `<a href="${escapeHtml(href)}" target="_blank" rel="noopener" class="text-navy font-semibold hover:underline">${escapeHtml(title)}</a>`
        : `<span class="font-medium text-[var(--text-primary)]">${escapeHtml(title)}</span>`;
      return `<div class="flex justify-between items-center gap-3 py-2.5 border-b border-[var(--border-subtle)] last:border-0">${label}<span class="text-[11px] text-[var(--text-muted)] shrink-0">${escapeHtml(subtitle)}</span></div>`;
    }

    const webinarItems = upcomingWebinars.length
      ? upcomingWebinars.map((w: any) => {
          const d = w.date ? new Date(w.date + 'T12:00:00').toLocaleDateString(I18N.dateLocale || 'pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) : '—';
          return renderItemRow(w.title || 'Webinar', d, w.meeting_link || undefined);
        }).join('')
      : `<div class="py-6 text-center text-[var(--text-muted)] text-sm">${escapeHtml(I18N.radarEmpty || 'Nenhum item.')}</div>`;

    const pubItems = recentPubs.length
      ? recentPubs.map((p: any) => {
          const upd = p.updated_at ? new Date(p.updated_at).toLocaleDateString(I18N.dateLocale || 'pt-BR', { day: '2-digit', month: 'short' }) : '';
          return renderItemRow(p.title || 'Publicação', upd);
        }).join('')
      : `<div class="py-6 text-center text-[var(--text-muted)] text-sm">${escapeHtml(I18N.radarEmpty || 'Nenhum item.')}</div>`;

    el.innerHTML = `
      <div class="space-y-6">
        <div>
          <h2 class="text-xl font-semibold text-navy mb-4">${escapeHtml(I18N.highlights || 'Destaques do Núcleo')}</h2>
          <p class="text-[13px] text-[var(--text-secondary)] mb-4">${escapeHtml(I18N.highlightsDesc || 'Artefatos oficiais, webinars e publicações aprovadas pela curadoria.')}</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] overflow-hidden">
              <div class="px-5 py-3.5 border-b border-[var(--border-subtle)] flex items-center gap-2">
                <span class="text-lg">🎙️</span>
                <h3 class="text-sm font-bold text-navy">${escapeHtml(I18N.radarWebinars || 'Próximos Webinars')}</h3>
              </div>
              <div class="px-5 py-2 max-h-[260px] overflow-y-auto">${webinarItems}</div>
            </div>
            <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] overflow-hidden">
              <div class="px-5 py-3.5 border-b border-[var(--border-subtle)] flex items-center gap-2">
                <span class="text-lg">📄</span>
                <h3 class="text-sm font-bold text-navy">${escapeHtml(I18N.radarPublications || 'Publicações Oficiais')}</h3>
              </div>
              <div class="px-5 py-2 max-h-[260px] overflow-y-auto">${pubItems}</div>
            </div>
          </div>
        </div>
        <div>
          <h2 class="text-xl font-semibold text-navy mb-4">${escapeHtml(I18N.sharedRefs || 'Referências Compartilhadas')}</h2>
          <p class="text-[13px] text-[var(--text-secondary)] mb-4">Materiais de estudo, rascunhos públicos e recursos curados pela comunidade.</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <a href="/publications" class="group flex flex-col items-center gap-2 p-5 rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] hover:border-navy/30 hover:shadow-md transition-all no-underline">
              <span class="text-2xl">📚</span>
              <span class="text-sm font-bold text-navy group-hover:underline">${escapeHtml(I18N.showcase || 'Vitrine de Publicações')}</span>
              <span class="text-[11px] text-[var(--text-muted)]">Todos os artefatos publicados</span>
            </a>
            <a href="/webinars" class="group flex flex-col items-center gap-2 p-5 rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] hover:border-navy/30 hover:shadow-md transition-all no-underline">
              <span class="text-2xl">🎓</span>
              <span class="text-sm font-bold text-navy group-hover:underline">${escapeHtml(I18N.webinarsEvents || 'Webinars & Eventos')}</span>
              <span class="text-[11px] text-[var(--text-muted)]">Agenda e gravações</span>
            </a>
            <a href="/admin/knowledge" class="group flex flex-col items-center gap-2 p-5 rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] hover:border-navy/30 hover:shadow-md transition-all no-underline">
              <span class="text-2xl">🔗</span>
              <span class="text-sm font-bold text-navy group-hover:underline">${escapeHtml(I18N.knowledgeBase || 'Base de Conhecimento')}</span>
              <span class="text-[11px] text-[var(--text-muted)]">Artigos, cursos e referências</span>
            </a>
          </div>
        </div>
      </div>`;
  }

  // ── Members tab ──
  async function renderMembers(members: any[]) {
    const el = document.getElementById('panel-members');
    if (!el) return;

    if (!members.length) {
      el.innerHTML = `
        <div class="text-center py-14">
          <div class="text-4xl mb-3">👥</div>
          <div class="font-semibold text-[var(--text-secondary)] text-sm">${I18N.noMembers}</div>
        </div>`;
      return;
    }

    let html = `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${members.map(memberCardHtml).join('')}</div>`;

    // Fetch observers for this tribe
    try {
      const sb = getSb();
      if (sb) {
        const { data: observers } = await sb.from('public_members')
          .select('id, name, photo_url, chapter, operational_role, member_status')
          .eq('tribe_id', TRIBE_ID)
          .eq('member_status', 'observer');
        if (observers && observers.length > 0) {
          html += `<div class="mt-6 pt-4 border-t border-[var(--border-subtle)]">
            <h3 class="text-xs font-bold text-[var(--text-muted)] uppercase tracking-wider mb-3">👁 Observadores (${observers.length})</h3>
            <div class="flex flex-wrap gap-3">${observers.map((o: any) => `<div class="flex items-center gap-2 px-3 py-2 rounded-lg bg-[var(--surface-base)] border border-[var(--border-subtle)]">
              <span class="text-xs text-[var(--text-secondary)]">${escapeHtml(o.name)}</span>
              <span class="text-[9px] px-1.5 py-0.5 rounded-full bg-blue-100 text-blue-600 font-semibold">Observer</span>
            </div>`).join('')}</div>
          </div>`;
        }
      }
    } catch (_) { /* non-critical */ }

    el.innerHTML = html;
  }

  function memberCardHtml(m: any): string {
    const initials = (m.name || '?').split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
    const photo = m.photo_url
      ? `<img src="${escapeHtml(m.photo_url)}" class="w-12 h-12 rounded-full object-cover border-2 border-[var(--border-subtle)]" alt="">`
      : `<div class="w-12 h-12 rounded-full bg-teal/20 flex items-center justify-center text-teal text-sm font-bold">${escapeHtml(initials)}</div>`;

    const opRole = m.operational_role || 'researcher';
    const roleColor = OPROLE_COLORS[opRole] || '#94A3B8';
    const roleLabel = OPROLE_LABELS[opRole] || opRole;
    const roleBadge = opRole !== 'none' && opRole !== 'guest'
      ? `<span class="inline-block px-2 py-0.5 rounded-md text-[.6rem] font-bold uppercase" style="background:${roleColor}22;color:${roleColor}">${escapeHtml(roleLabel)}</span>`
      : '';

    const desigs: string[] = m.designations || [];
    const desigBadges = desigs.map((d: string) =>
      `<span class="inline-block px-2 py-0.5 rounded-md text-[.6rem] font-bold uppercase bg-[var(--surface-section-cool)] text-[var(--text-secondary)]">${escapeHtml(d)}</span>`
    ).join(' ');


    const contact = contactData[m.id];
    const hasContact = contact && (contact.email || contact.phone);
    const canSeeContacts = currentMember && (isHighManagement(currentMember) || (hasPermission(currentMember, 'board.edit_tribe_items') && currentMember.tribe_id === TRIBE_ID));

    let contactHtml = '';
    if (canSeeContacts && hasContact) {
      const emailLine = contact.email ? '<div class="flex items-center gap-1 text-[11px] text-[var(--text-secondary)] truncate"><svg class="w-3 h-3 shrink-0 text-[var(--text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>' + escapeHtml(contact.email) + '</div>' : '';
      const phoneLine = contact.phone ? '<div class="flex items-center gap-1 text-[11px] text-[var(--text-secondary)]"><svg class="w-3 h-3 shrink-0 text-[var(--text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>' + escapeHtml(contact.phone) + '</div>' : '';
      contactHtml = '<div class="mt-1.5 space-y-0.5">' + emailLine + phoneLine + '</div>';
    } else if (currentMember && !canSeeContacts) {
      const tip = escapeHtml(I18N.lgpdTooltip || 'Acesso restrito por LGPD');
      const lbl = escapeHtml(I18N.lgpdMask || 'LGPD');
      contactHtml = '<div class="mt-1.5 flex items-center gap-1 text-[10px] text-[var(--text-muted)]" title="' + tip + '"><svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg><span>***-*** <span class="underline decoration-dotted cursor-help">' + lbl + '</span></span></div>';
    }
    return `
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-subtle)] p-5 flex items-start gap-3 hover:border-[var(--border-default)] hover:shadow-sm transition-all">
        ${photo}
        <div class="flex-1 min-w-0">
          <div class="font-bold text-[15px] text-navy leading-tight mb-1">${escapeHtml(m.name || '—')}</div>
          <div class="text-[12px] text-[var(--text-muted)] mb-1.5">${escapeHtml(m.chapter || '')}</div>
          <div class="flex flex-wrap gap-1">${roleBadge} ${desigBadges}</div>
          ${contactHtml}
          ${waButton(m)}
        </div>
      </div>`;
  }

  function waButton(m: any): string {
    if (!m.share_whatsapp) return '';
    if (!currentMember) return '';
    const isSelf = currentMember.id === m.id;
    if (isSelf) return '';
    const isPeer = currentMember.tribe_id === TRIBE_ID
      || membersMap.has(currentMember.id)
      || isHighManagement(currentMember);
    if (!isPeer) return '';
    return `<a href="#" data-action="open-wa" data-member-id="${m.id}"
      class="inline-flex items-center gap-1 mt-1.5 px-2 py-1 rounded-lg bg-[#25D366]/10 text-[#25D366] text-[.65rem] font-bold no-underline hover:bg-[#25D366]/20 transition-all"
      title="${I18N.chatWhatsApp || 'WhatsApp'}">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      ${I18N.chatWhatsApp || 'WhatsApp'}
    </a>`;
  }

  // ── Progress bar ──
  function progressBarHtml(items: any[]): string {
    const total = items.length;
    if (total === 0) return '';

    const completed = items.filter(d => d.status === 'completed').length;
    const inProgress = items.filter(d => d.status === 'in_progress').length;
    const planned = items.filter(d => d.status === 'planned').length;
    const pctCompleted = Math.round((completed / total) * 100);
    const pctInProgress = Math.round((inProgress / total) * 100);

    return `
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-4 mb-4">
        <div class="flex items-center gap-3 text-[13px] font-semibold mb-2 flex-wrap">
          <span class="text-emerald-700">${completed}/${total} ${I18N.progressCompleted}</span>
          <span class="text-[var(--text-muted)]">|</span>
          <span class="text-blue-700">${inProgress} ${I18N.progressInProgress}</span>
          <span class="text-[var(--text-muted)]">|</span>
          <span class="text-[var(--text-secondary)]">${planned} ${I18N.progressPlanned}</span>
        </div>
        <div class="w-full h-2.5 bg-[var(--surface-section-cool)] rounded-full overflow-hidden flex">
          <div class="h-full bg-emerald-500 transition-all" style="width:${pctCompleted}%"></div>
          <div class="h-full bg-blue-400 transition-all" style="width:${pctInProgress}%"></div>
        </div>
      </div>`;
  }

  // ── Deliverables tab ──
  function renderDeliverables(items: any[]) {
    const el = document.getElementById('panel-deliverables');
    if (!el) return;

    allDeliverables = items;

    const addBtn = canEdit
      ? `<div class="flex justify-end mb-4"><button data-action="add-deliverable" class="px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">${I18N.addDeliverable}</button></div>`
      : '';

    if (!items.length) {
      el.innerHTML = `
        ${addBtn}
        <div class="text-center py-14">
          <div class="text-4xl mb-3">📦</div>
          <div class="font-semibold text-[var(--text-secondary)] text-sm">${I18N.noDeliverables}</div>
        </div>`;
      return;
    }

    el.innerHTML = `
      ${addBtn}
      ${progressBarHtml(items)}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${items.map(deliverableCardHtml).join('')}</div>`;
  }

  const STATUS_TRANSITIONS: Record<string, string[]> = {
    planned:     ['in_progress', 'cancelled'],
    in_progress: ['completed', 'planned'],
    completed:   ['in_progress'],
    cancelled:   ['planned'],
  };
  const MOVE_LABELS: Record<string, string> = {
    in_progress: I18N.moveToInProgress || 'Start',
    completed: I18N.moveToCompleted || 'Complete',
    planned: I18N.moveToPlanned || 'Replan',
    cancelled: I18N.moveToCancelled || 'Cancel',
  };
  const MOVE_STYLES: Record<string, string> = {
    in_progress: 'bg-blue-50 text-blue-700 hover:bg-blue-100',
    completed: 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100',
    planned: 'bg-[var(--surface-base)] text-[var(--text-secondary)] hover:bg-[var(--surface-hover)]',
    cancelled: 'bg-red-50 text-red-600 hover:bg-red-100',
  };

  function deliverableCardHtml(d: any): string {
    const status = d.status || 'planned';
    const sc = STATUS_COLORS[status] || STATUS_COLORS.planned;
    const statusLabel = STATUS_LABELS[status] || status;

    const assignee = d.assigned_member_id && membersMap.has(d.assigned_member_id)
      ? escapeHtml(membersMap.get(d.assigned_member_id)?.name || '')
      : `<span class="text-[var(--text-muted)]">${I18N.unassigned}</span>`;

    const dueDateStr = d.due_date
      ? new Date(d.due_date + 'T00:00:00').toLocaleDateString(I18N.dateLocale || 'pt-BR', { day: '2-digit', month: 'short' })
      : I18N.noDueDate;

    let actionsHtml = '';
    if (canEdit) {
      const transitions = STATUS_TRANSITIONS[status] || [];
      const toggleBtns = transitions.map(s =>
        `<button data-action="status-toggle" data-deliverable-id="${d.id}" data-new-status="${s}" class="px-2 py-0.5 rounded text-[10px] font-bold cursor-pointer border-0 transition-all ${MOVE_STYLES[s] || ''}">${MOVE_LABELS[s] || s}</button>`
      ).join('');
      actionsHtml = `
        <div class="flex items-center gap-1.5 flex-wrap mt-2 pt-2 border-t border-[var(--border-subtle)]">
          <button data-action="edit-deliverable" data-deliverable-id="${d.id}" class="px-2 py-0.5 rounded text-[10px] font-bold cursor-pointer border-0 bg-purple/10 text-purple hover:bg-purple/20 transition-all">${I18N.editDeliverable || 'Edit'}</button>
          ${toggleBtns}
        </div>`;
    }

    return `
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-subtle)] p-5 flex flex-col hover:border-[var(--border-default)] hover:shadow-sm transition-all">
        <div class="flex items-center justify-between gap-2 mb-2">
          <span class="text-[11px] font-bold uppercase tracking-wide text-[var(--text-muted)]">${I18N.dueDate}: ${escapeHtml(dueDateStr)}</span>
          <span class="${sc.bg} ${sc.text} px-2.5 py-0.5 rounded-full text-[11px] font-bold">${escapeHtml(statusLabel)}</span>
        </div>
        <h3 class="text-[15px] font-bold text-navy leading-snug mb-1">${escapeHtml(d.title)}</h3>
        ${d.description ? `<p class="text-[12.5px] text-[var(--text-secondary)] leading-relaxed mb-2">${escapeHtml(d.description.length > 140 ? d.description.slice(0, 137) + '…' : d.description)}</p>` : ''}
        <div class="mt-auto pt-3 text-[12px] text-[var(--text-muted)]">
          <span class="font-semibold">${I18N.assignee}:</span> ${assignee}
        </div>
        ${actionsHtml}
      </div>`;
  }

  // ── Resources tab ──
  function renderResources(items: any[]) {
    const el = document.getElementById('panel-resources');
    if (!el) return;

    if (!items.length) {
      el.innerHTML = `
        <div class="text-center py-14">
          <div class="text-4xl mb-3">📚</div>
          <div class="font-semibold text-[var(--text-secondary)] text-sm">${I18N.noResources}</div>
        </div>`;
      return;
    }

    el.innerHTML = `<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">${items.map(resourceCardHtml).join('')}</div>`;
  }

  function resourceCardHtml(r: any): string {
    const icon = TYPE_ICONS[r.asset_type] || '📎';
    const desc = r.description
      ? escapeHtml(r.description.length > 120 ? r.description.slice(0, 117) + '…' : r.description)
      : '';
    const link = r.url
      ? `<a href="${escapeHtml(r.url)}" target="_blank" rel="noopener"
            class="inline-flex items-center gap-1 text-teal text-[13px] font-semibold no-underline hover:underline mt-auto pt-3">${I18N.openLink}</a>`
      : '';
    return `
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-subtle)] p-5 flex flex-col hover:border-[var(--border-default)] hover:shadow-sm transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xl leading-none">${icon}</span>
          <span class="text-[11px] font-bold uppercase tracking-wide text-[var(--text-muted)]">${escapeHtml(r.asset_type)}</span>
        </div>
        <h3 class="text-[15px] font-bold text-navy leading-snug mb-1">${escapeHtml(r.title)}</h3>
        ${desc ? `<p class="text-[12.5px] text-[var(--text-secondary)] leading-relaxed mb-0">${desc}</p>` : ''}
        ${link}
      </div>`;
  }

  // ── Modal helpers ──
  function openDeliverableModal(deliverable?: any) {
    const modal = document.getElementById('deliverable-modal');
    if (!modal) return;

    const titleEl = document.getElementById('deliverable-modal-title') as HTMLElement;
    const idInput = document.getElementById('dlv-id') as HTMLInputElement;
    const titleInput = document.getElementById('dlv-title') as HTMLInputElement;
    const descInput = document.getElementById('dlv-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('dlv-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('dlv-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('dlv-assignee') as HTMLSelectElement;
    const artifactSelect = document.getElementById('dlv-artifact') as HTMLSelectElement;

    // Labels
    titleEl.textContent = deliverable ? I18N.modalEditTitle : I18N.modalAddTitle;
    (document.getElementById('lbl-dlv-title') as HTMLElement).textContent = I18N.modalLabelTitle;
    (document.getElementById('lbl-dlv-description') as HTMLElement).textContent = I18N.modalLabelDescription;
    (document.getElementById('lbl-dlv-status') as HTMLElement).textContent = I18N.modalLabelStatus;
    (document.getElementById('lbl-dlv-due-date') as HTMLElement).textContent = I18N.modalLabelDueDate;
    (document.getElementById('lbl-dlv-assignee') as HTMLElement).textContent = I18N.modalLabelAssignee;
    (document.getElementById('lbl-dlv-artifact') as HTMLElement).textContent = I18N.modalLabelArtifact;
    (document.getElementById('btn-dlv-cancel') as HTMLElement).textContent = I18N.modalCancel;
    (document.getElementById('btn-dlv-save') as HTMLElement).textContent = I18N.modalSave;

    // Status dropdown
    statusSelect.innerHTML = [
      { v: 'planned', l: I18N.statusPlanned },
      { v: 'in_progress', l: I18N.statusInProgress },
      { v: 'completed', l: I18N.statusCompleted },
      { v: 'cancelled', l: I18N.statusCancelled },
    ].map(o => `<option value="${o.v}">${escapeHtml(o.l)}</option>`).join('');

    // Assignee dropdown
    assigneeSelect.innerHTML = `<option value="">${escapeHtml(I18N.modalSelectMember)}</option>` +
      Array.from(membersMap.values())
        .sort((a: any, b: any) => (a.name || '').localeCompare(b.name || ''))
        .map((m: any) => `<option value="${m.id}">${escapeHtml(m.name)}</option>`)
        .join('');

    // Artifact dropdown
    artifactSelect.innerHTML = `<option value="">${escapeHtml(I18N.modalSelectArtifact)}</option>` +
      publishedArtifacts
        .map((a: any) => `<option value="${a.id}">${escapeHtml(a.title)}</option>`)
        .join('');

    // Fill values
    idInput.value = deliverable?.id || '';
    titleInput.value = deliverable?.title || '';
    descInput.value = deliverable?.description || '';
    statusSelect.value = deliverable?.status || 'planned';
    dueDateInput.value = deliverable?.due_date || '';
    assigneeSelect.value = deliverable?.assigned_member_id || '';
    artifactSelect.value = deliverable?.artifact_id || '';

    modal.classList.remove('hidden');
  }

  function closeDeliverableModal() {
    document.getElementById('deliverable-modal')?.classList.add('hidden');
  }

  async function saveDeliverable() {
    const idInput = document.getElementById('dlv-id') as HTMLInputElement;
    const titleInput = document.getElementById('dlv-title') as HTMLInputElement;
    const descInput = document.getElementById('dlv-description') as HTMLTextAreaElement;
    const statusSelect = document.getElementById('dlv-status') as HTMLSelectElement;
    const dueDateInput = document.getElementById('dlv-due-date') as HTMLInputElement;
    const assigneeSelect = document.getElementById('dlv-assignee') as HTMLSelectElement;
    const artifactSelect = document.getElementById('dlv-artifact') as HTMLSelectElement;

    const title = titleInput.value.trim();
    if (!title) {
      (window as any).toast?.(I18N.modalTitleRequired, 'error');
      return;
    }

    const activeCycleCode = getActiveCycleCode();
    if (!activeCycleCode) {
      (window as any).toast?.(I18N.error, 'error');
      return;
    }

    const params: any = {
      p_tribe_id: TRIBE_ID,
      p_cycle_code: activeCycleCode,
      p_title: title,
      p_description: descInput.value.trim() || null,
      p_status: statusSelect.value,
      p_assigned_member_id: assigneeSelect.value || null,
      p_artifact_id: artifactSelect.value || null,
      p_due_date: dueDateInput.value || null,
    };

    if (idInput.value) params.p_id = idInput.value;

    const { error } = await sb.rpc('upsert_tribe_deliverable', params);
    if (error) {
      console.error('upsert_tribe_deliverable error:', error);
      (window as any).toast?.(I18N.msgSaveError, 'error');
      return;
    }

    (window as any).toast?.(I18N.msgSaved, 'success');
    closeDeliverableModal();
    await reloadDeliverables();
  }

  async function toggleDeliverableStatus(deliverableId: string, newStatus: string) {
    const d = allDeliverables.find((x: any) => x.id === deliverableId);
    if (!d) return;

    const { error } = await sb.rpc('upsert_tribe_deliverable', {
      p_id: deliverableId,
      p_tribe_id: TRIBE_ID,
      p_cycle_code: d.cycle_code || getActiveCycleCode(),
      p_title: d.title,
      p_description: d.description,
      p_status: newStatus,
      p_assigned_member_id: d.assigned_member_id,
      p_artifact_id: d.artifact_id,
      p_due_date: d.due_date,
    });

    if (error) {
      console.error('status toggle error:', error);
      (window as any).toast?.(I18N.msgStatusError, 'error');
      return;
    }

    (window as any).toast?.(I18N.msgStatusUpdated, 'success');
    await reloadDeliverables();
  }

  async function saveMeetingSchedule() {
    if (!sb || !canEdit) return;
    const input = document.getElementById('meeting-schedule-input') as HTMLInputElement;
    if (!input) return;
    const value = input.value.trim();
    const { error } = await sb.from('tribes').update({
      meeting_schedule: value || null,
      updated_at: new Date().toISOString(),
    }).eq('id', TRIBE_ID);
    if (error) {
      console.error('meeting_schedule update error:', error);
      (window as any).toast?.(I18N.msgSaveError || 'Erro ao salvar', 'error');
      return;
    }
    tribeData = { ...tribeData, meeting_schedule: value || null };
    document.getElementById('meeting-schedule-modal')?.classList.add('hidden');
    (window as any).toast?.(I18N.meetingScheduleSaved || 'Horário atualizado', 'success');
    renderHeader(tribeData, headerLeader, headerSlots);
  }

  async function reloadDeliverables() {
    const activeCycleCode = getActiveCycleCode();
    if (!activeCycleCode) {
      renderDeliverables([]);
      return;
    }
    const { data } = INITIATIVE_ID
      ? await sb.rpc('list_initiative_deliverables', { p_initiative_id: INITIATIVE_ID, p_cycle_code: activeCycleCode })
      : await sb.rpc('list_tribe_deliverables', { p_tribe_id: TRIBE_ID, p_cycle_code: activeCycleCode });
    renderDeliverables(Array.isArray(data) ? data : []);
  }

  // ── Event delegation ──
  if (!(window as any).__tribeDelegationBound) {
    (window as any).__tribeDelegationBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      const action = target.dataset.action;

      if (action === 'switch-tab') {
        const tab = target.dataset.tab;
        if (tab) switchTab(tab);
      }

      if (action === 'add-deliverable') {
        openDeliverableModal();
      }

      if (action === 'edit-deliverable') {
        const dId = target.dataset.deliverableId;
        const d = allDeliverables.find((x: any) => x.id === dId);
        if (d) openDeliverableModal(d);
      }

      if (action === 'status-toggle') {
        const dId = target.dataset.deliverableId;
        const newStatus = target.dataset.newStatus;
        if (dId && newStatus) toggleDeliverableStatus(dId, newStatus);
      }

      if (action === 'close-deliverable-modal') {
        closeDeliverableModal();
      }

      if (action === 'send-broadcast') {
        sendBroadcast();
      }

      if (action === 'open-wa') {
        e.preventDefault();
        const memberId = target.dataset.memberId;
        if (!memberId || !sb) return;
        (async () => {
          const { data } = await sb.rpc('resolve_whatsapp_link', { p_member_id: memberId });
          if (data?.success && data?.url) {
            window.open(data.url, '_blank', 'noopener');
          } else {
            (window as any).toast?.(data?.error || 'Error', 'error');
          }
        })();
      }

      if (action === 'toggle-context-switch') {
        const switcher = document.getElementById('tribe-context-switch');
        if (!switcher) return;
        const opening = switcher.classList.contains('hidden');
        switcher.classList.toggle('hidden');
        if (opening) {
          ensureContextSwitchData();
        }
      }

      if (action === 'open-meeting-schedule-modal') {
        const modal = document.getElementById('meeting-schedule-modal');
        const input = document.getElementById('meeting-schedule-input') as HTMLInputElement;
        if (modal && input) {
          input.value = tribeData?.meeting_schedule || '';
          modal.classList.remove('hidden');
          input.focus();
        }
      }

      if (action === 'close-meeting-schedule-modal') {
        document.getElementById('meeting-schedule-modal')?.classList.add('hidden');
      }

      if (action === 'save-meeting-schedule') {
        saveMeetingSchedule();
      }
    });

    document.addEventListener('submit', (e: SubmitEvent) => {
      if ((e.target as HTMLElement)?.id === 'deliverable-form') {
        e.preventDefault();
        saveDeliverable();
      }
    });

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') closeDeliverableModal();
      if (e.key === 'Escape') document.getElementById('meeting-schedule-modal')?.classList.add('hidden');
    });
  }

