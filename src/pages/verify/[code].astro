---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromURL, t, type Lang } from '../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const { code } = Astro.params;
---

<BaseLayout title={t('verify.title', lang)} lang={lang}>
  <main class="max-w-[560px] mx-auto px-4 py-12">
    <div class="text-center mb-8">
      <div class="text-4xl mb-3">🔍</div>
      <h1 class="text-xl font-bold text-[var(--text-primary)]">{t('verify.title', lang)}</h1>
    </div>

    <div id="verify-loading" class="text-center py-8 text-[var(--text-muted)] text-sm">...</div>
    <div id="verify-result" class="hidden"></div>

    <div class="mt-8 pt-6 border-t border-[var(--border-subtle)]">
      <form id="verify-form" class="flex gap-2">
        <input id="verify-input" type="text" value={code || ''}
          class="flex-1 px-4 py-2.5 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm text-[var(--text-primary)] focus:outline-none focus:border-navy"
          placeholder={t('verify.searchPlaceholder', lang)} />
        <button type="submit"
          class="px-5 py-2.5 rounded-lg bg-navy text-white text-sm font-semibold border-0 cursor-pointer hover:opacity-90">
          {t('verify.search', lang)}
        </button>
      </form>
    </div>

    <div class="text-center mt-6 text-[8px] text-[var(--text-muted)]">PMI®, PMBOK®, PMP® e PMI-CPMAI™ são marcas registradas do PMI, Inc.</div>
  </main>
</BaseLayout>

<script is:inline define:vars={{ lang, code }}>
  window.__verifyLang = lang;
  window.__verifyCode = code || '';
</script>

<script>
  import { getSupabase } from '../../lib/supabase';
  import { t } from '../../i18n/utils';
  import type { Lang } from '../../i18n/utils';

  function esc(s: any): string { return String(s || '').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

  function fmtDate(dateStr: string, lang: Lang): string {
    if (!dateStr) return '';
    const clean = String(dateStr).slice(0, 10);
    const d = new Date(clean + 'T12:00:00');
    if (isNaN(d.getTime())) return String(dateStr);
    const locale = lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es-ES' : 'pt-BR';
    return d.toLocaleDateString(locale, { day: '2-digit', month: 'long', year: 'numeric' });
  }

  function row(label: string, value: string): string {
    return `<div class="flex justify-between items-center gap-4 py-1.5"><span class="text-[var(--text-muted)] shrink-0 text-sm">${label}</span><span class="font-medium text-[var(--text-primary)] text-sm text-right">${value}</span></div>`;
  }

  function renderResult(data: any, lang: Lang): string {
    if (!data || data.error === 'not_found') {
      return `<div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-6 text-center">
        <div class="text-3xl mb-2">\u26A0\uFE0F</div>
        <p class="font-semibold text-amber-800 dark:text-amber-300">${t('verify.notFound', lang)}</p>
        <p class="text-sm text-amber-600 dark:text-amber-400 mt-1">${t('verify.notFoundHint', lang)}</p>
      </div>`;
    }

    if (data.revoked) {
      return `<div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-6">
        <div class="text-center mb-4"><div class="text-3xl mb-2">\u274C</div>
          <p class="font-bold text-red-800 dark:text-red-300 text-lg">${t('verify.revoked', lang)}</p></div>
        <div class="divide-y divide-[var(--border-subtle)]">
          ${row(t('verify.type', lang), esc(data.title))}
          ${row(t('verify.issuedTo', lang), esc(data.member_name))}
          ${data.revoked_at ? row(t('verify.revokedAt', lang), `<span class="text-red-600 dark:text-red-400">${fmtDate(data.revoked_at, lang)}</span>`) : ''}
          ${data.revoked_reason ? row(t('verify.revokedReason', lang), esc(data.revoked_reason)) : ''}
        </div>
      </div>`;
    }

    const rows = [
      row(t('verify.type', lang), esc(data.type || data.title)),
      row(t('verify.issuedTo', lang), `<span class="font-bold">${esc(data.member_name)}</span>`),
      data.issued_at ? row(t('verify.issuedAt', lang), fmtDate(data.issued_at, lang)) : '',
      data.issued_by ? row(t('verify.issuedBy', lang), esc(data.issued_by)) : '',
      data.counter_signed_by ? row(t('verify.counterSignedBy', lang), esc(data.counter_signed_by)) : '',
      data.cycle ? row(t('verify.cycle', lang), `${data.cycle}${data.period_start && data.period_end ? ` (${data.period_start} — ${data.period_end})` : ''}`) : '',
      row(t('verify.code', lang), `<code class="text-[12px] bg-[var(--surface-hover)] px-2 py-0.5 rounded font-mono">${esc(data.verification_code)}</code>`),
    ].filter(Boolean).join('');

    return `<div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 rounded-xl p-6">
      <div class="text-center mb-4"><div class="text-3xl mb-2">\u2705</div>
        <p class="font-bold text-emerald-800 dark:text-emerald-300 text-lg">${t('verify.valid', lang)}</p></div>
      <div class="divide-y divide-[var(--border-subtle)]">${rows}</div>
    </div>`;
  }

  async function doVerify(code: string) {
    const lang = ((window as any).__verifyLang || 'pt-BR') as Lang;
    const loading = document.getElementById('verify-loading');
    const result = document.getElementById('verify-result');
    if (!result) return;

    if (!code?.trim()) {
      if (loading) loading.classList.add('hidden');
      result.classList.add('hidden');
      return;
    }

    if (loading) { loading.classList.remove('hidden'); loading.textContent = '...'; }
    result.classList.add('hidden');

    let sb = (window as any).navGetSb?.();
    if (!sb) { try { sb = getSupabase(); } catch { /* noop */ } }
    if (!sb) {
      if (loading) loading.classList.add('hidden');
      result.classList.remove('hidden');
      result.innerHTML = renderResult(null, lang);
      return;
    }

    try {
      const { data, error } = await sb.rpc('verify_certificate', { p_code: code.trim() });
      if (error) throw error;
      if (loading) loading.classList.add('hidden');
      result.classList.remove('hidden');
      result.innerHTML = renderResult(data, lang);
    } catch (err) {
      console.error('Verify failed:', err);
      if (loading) loading.classList.add('hidden');
      result.classList.remove('hidden');
      result.innerHTML = renderResult(null, lang);
    }
  }

  document.getElementById('verify-form')?.addEventListener('submit', (e: Event) => {
    e.preventDefault();
    const input = document.getElementById('verify-input') as HTMLInputElement;
    if (input?.value?.trim()) {
      history.replaceState(null, '', `/verify/${encodeURIComponent(input.value.trim())}`);
      doVerify(input.value.trim());
    }
  });

  // Auto-verify if code in URL
  const initialCode = (window as any).__verifyCode;
  if (initialCode) {
    const waitAndVerify = () => {
      const sb = (window as any).navGetSb?.();
      if (sb) { doVerify(initialCode); }
      else { setTimeout(waitAndVerify, 300); }
    };
    setTimeout(waitAndVerify, 500);
  } else {
    document.getElementById('verify-loading')?.classList.add('hidden');
  }
</script>
