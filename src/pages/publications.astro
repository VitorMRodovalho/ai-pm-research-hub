---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('nav.publications', lang)} activePage="publications">
  <div id="pub-loading" class="max-w-[1200px] mx-auto px-4 py-12 text-center text-slate-400">
    Carregando painel global de publicações...
  </div>

  <div id="pub-content" class="hidden max-w-[1200px] mx-auto px-4 pb-10 space-y-4">
    <section class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <div class="p-6 sm:p-8">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 border border-indigo-200 text-[.72rem] font-semibold text-indigo-700 mb-3">
              <span>Governança global</span>
              <span class="text-indigo-400">•</span>
              <span>Curadoria → Submissão externa</span>
            </div>
            <h1 class="text-2xl font-extrabold text-navy dark:text-slate-100 mb-2">Publicações & Submissões</h1>
            <p class="text-sm text-slate-500 dark:text-slate-300 leading-relaxed">
              Quadro global para acompanhar artigos aprovados na Curadoria até o envio e publicação no ecossistema PMI.
              Este fluxo não pertence a uma tribo específica.
            </p>
          </div>
          <a href="/admin/curatorship" class="px-4 py-2.5 rounded-xl bg-navy text-white text-[.78rem] font-semibold no-underline text-center hover:opacity-90 transition-all">
            Abrir Curadoria
          </a>
        </div>
      </div>
    </section>

    <section id="pub-board" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4"></section>
  </div>

  <div id="pub-denied" class="hidden max-w-[900px] mx-auto px-4 py-16 text-center">
    <div class="text-4xl mb-3">🔒</div>
    <p class="font-semibold text-slate-600">Acesso restrito a lideranças, curadoria e operação de comunicação.</p>
    <a href="/" class="inline-block mt-4 px-5 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
      Voltar
    </a>
  </div>
</BaseLayout>

<script>
  import { canAccessPublicationsWorkspace } from '../lib/admin/constants';

  let sb: any = null;
  let member: any = null;
  let board: any = null;
  let items: any[] = [];
  let canEdit = false;

  const COLUMNS: Array<{ key: string; label: string; tone: string }> = [
    { key: 'backlog', label: 'Backlog', tone: 'border-slate-200 bg-slate-50/40' },
    { key: 'todo', label: 'A fazer', tone: 'border-blue-200 bg-blue-50/40' },
    { key: 'in_progress', label: 'Em progresso', tone: 'border-amber-200 bg-amber-50/40' },
    { key: 'review', label: 'Em revisão', tone: 'border-purple-200 bg-purple-50/40' },
    { key: 'done', label: 'Concluído', tone: 'border-emerald-200 bg-emerald-50/40' },
  ];

  function showDenied() {
    document.getElementById('pub-loading')?.classList.add('hidden');
    document.getElementById('pub-content')?.classList.add('hidden');
    document.getElementById('pub-denied')?.classList.remove('hidden');
  }

  function showPanel() {
    document.getElementById('pub-loading')?.classList.add('hidden');
    document.getElementById('pub-denied')?.classList.add('hidden');
    document.getElementById('pub-content')?.classList.remove('hidden');
  }

  function escapeHtml(value: unknown): string {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function cardHtml(item: any): string {
    const desc = String(item.description || '').trim();
    const due = item.due_date ? `<span class="text-[10px] text-amber-700 bg-amber-100 px-1.5 py-0.5 rounded-full">Prazo: ${escapeHtml(item.due_date)}</span>` : '';
    const tags = Array.isArray(item.tags)
      ? item.tags.map((tag: string) => `<span class="px-1.5 py-0.5 rounded-full text-[10px] bg-slate-100 text-slate-600">${escapeHtml(tag)}</span>`).join(' ')
      : '';

    return `<article class="pub-card rounded-xl border border-slate-200 bg-white p-3 shadow-sm cursor-grab active:cursor-grabbing"
      draggable="${canEdit ? 'true' : 'false'}"
      data-id="${escapeHtml(item.id)}"
      data-status="${escapeHtml(item.status || 'backlog')}">
      <h3 class="text-[12px] font-bold text-navy mb-1">${escapeHtml(item.title || 'Sem título')}</h3>
      ${desc ? `<p class="text-[11px] text-slate-500 mb-2 line-clamp-3">${escapeHtml(desc)}</p>` : ''}
      <div class="flex items-center gap-1 flex-wrap">
        ${due}
        ${tags}
      </div>
    </article>`;
  }

  function setupDragDrop() {
    if (!canEdit) return;

    document.querySelectorAll('.pub-card').forEach((card) => {
      card.addEventListener('dragstart', (event) => {
        const element = card as HTMLElement;
        (event as DragEvent).dataTransfer?.setData('text/plain', JSON.stringify({
          id: element.dataset.id,
          status: element.dataset.status,
        }));
        element.classList.add('opacity-50');
      });
      card.addEventListener('dragend', () => {
        (card as HTMLElement).classList.remove('opacity-50');
      });
    });

    document.querySelectorAll('.pub-drop').forEach((drop) => {
      drop.addEventListener('dragover', (event) => {
        event.preventDefault();
        (drop as HTMLElement).classList.add('ring-2', 'ring-navy/30');
      });
      drop.addEventListener('dragleave', () => {
        (drop as HTMLElement).classList.remove('ring-2', 'ring-navy/30');
      });
      drop.addEventListener('drop', async (event) => {
        event.preventDefault();
        (drop as HTMLElement).classList.remove('ring-2', 'ring-navy/30');
        const payload = (event as DragEvent).dataTransfer?.getData('text/plain');
        if (!payload) return;
        const parsed = JSON.parse(payload);
        const nextStatus = (drop as HTMLElement).dataset.status || 'backlog';
        if (!parsed?.id || parsed.status === nextStatus) return;
        await moveItem(parsed.id, nextStatus);
      });
    });
  }

  function renderBoard() {
    const boardEl = document.getElementById('pub-board');
    if (!boardEl) return;

    const html = COLUMNS.map((col) => {
      const colItems = items.filter((item) => String(item.status || 'backlog') === col.key);
      return `<section class="rounded-2xl border ${col.tone} p-3">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-[12px] font-bold text-slate-700">${col.label}</h2>
          <span class="text-[10px] px-2 py-0.5 rounded-full bg-white border border-slate-200 text-slate-500">${colItems.length}</span>
        </div>
        <div class="pub-drop min-h-[220px] space-y-2" data-status="${col.key}">
          ${colItems.length ? colItems.map((item) => cardHtml(item)).join('') : '<div class="text-[11px] text-slate-400 py-6 text-center">Sem cards</div>'}
        </div>
      </section>`;
    }).join('');

    boardEl.innerHTML = html;
    setupDragDrop();
  }

  async function moveItem(itemId: string, nextStatus: string) {
    try {
      const { error } = await sb.rpc('move_board_item', {
        p_item_id: itemId,
        p_new_status: nextStatus,
        p_position: 0,
      });
      if (error) throw new Error(error.message);
      items = items.map((item) => item.id === itemId ? { ...item, status: nextStatus } : item);
      renderBoard();
      (window as any).toast?.('Status atualizado', 'success');
    } catch (error: any) {
      (window as any).toast?.(error?.message || 'Falha ao mover card', 'error');
    }
  }

  async function loadData() {
    const { data: boardsData, error: boardsError } = await sb.rpc('list_project_boards', { p_tribe_id: null });
    if (boardsError) throw new Error(boardsError.message);
    const boards = Array.isArray(boardsData) ? boardsData : [];

    board = boards.find((entry: any) => String(entry?.domain_key || '') === 'publications_submissions');
    if (!board) {
      throw new Error('Quadro global de publicações não encontrado');
    }

    const { data: boardItems, error: boardItemsError } = await sb.rpc('list_board_items', {
      p_board_id: board.id,
      p_status: null,
    });
    if (boardItemsError) throw new Error(boardItemsError.message);
    items = Array.isArray(boardItems) ? boardItems.filter((item: any) => item.status !== 'archived') : [];
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    member = (window as any).navGetMember?.();
    if (!sb || !member) {
      window.addEventListener('nav:member', () => boot(), { once: true });
      return;
    }

    if (!canAccessPublicationsWorkspace(member)) {
      showDenied();
      return;
    }
    canEdit = true;

    try {
      await loadData();
      showPanel();
      renderBoard();
    } catch (error: any) {
      console.warn('publications boot error', error);
      showDenied();
    }
  }

  boot();
</script>
