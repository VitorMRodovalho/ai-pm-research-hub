---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { buildPageI18n } from '../i18n/pageI18n';
import PublicationsBoardIsland from '../components/boards/PublicationsBoardIsland';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.pubBoard', 'comp.common'], lang);
---

<BaseLayout title={t('publications.publicTitle', lang)} activePage="publications">
  <!-- ── Public Publications Section (no login required) ── -->
  <div class="max-w-[1200px] mx-auto px-4 pt-8 pb-6">
    <div class="mb-2 text-[.73rem] font-bold tracking-[.15em] uppercase text-indigo-600">
      {t('publications.publicLabel', lang)}
    </div>
    <h1 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-2 text-navy">
      {t('publications.publicTitle', lang)}
    </h1>
    <p class="text-base text-[var(--text-secondary)] max-w-[700px] mb-6">
      {t('publications.publicSubtitle', lang)}
    </p>

    <!-- Stats bar -->
    <div id="pub-stats" class="hidden flex flex-wrap gap-4 mb-6">
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-6" id="pub-filters">
      <select id="pub-filter-type" class="px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-card)]">
        <option value="">{t('publications.filterAllTypes', lang)}</option>
        <option value="article">{t('publications.typeArticle', lang)}</option>
        <option value="framework">{t('publications.typeFramework', lang)}</option>
        <option value="toolkit">{t('publications.typeToolkit', lang)}</option>
        <option value="case_study">{t('publications.typeCaseStudy', lang)}</option>
        <option value="webinar_recording">{t('publications.typeWebinar', lang)}</option>
      </select>
      <input type="search" id="pub-search" placeholder={t('publications.searchPlaceholder', lang)}
        class="px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-card)] min-w-[200px]">
    </div>

    <!-- Loading -->
    <div id="pub-public-loading" class="text-center py-8 text-[var(--text-muted)] text-sm">
      {t('common.loading', lang)}
    </div>

    <!-- Empty -->
    <div id="pub-public-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-3">&#x1F4DA;</div>
      <p class="text-[var(--text-secondary)]">{t('publications.publicEmpty', lang)}</p>
    </div>

    <!-- Publications grid -->
    <div id="pub-public-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
    </div>

    <!-- CTA -->
    <div id="pub-cta" class="hidden text-center py-6 border-t border-[var(--border-subtle)]">
      <p class="text-sm text-[var(--text-secondary)] mb-3">{t('publications.ctaText', lang)}</p>
      <a href="/teams" class="inline-block px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('publications.ctaButton', lang)}
      </a>
    </div>
  </div>

  <!-- ── My Submissions (researcher self-service, hidden until auth + permission check) ── -->
  <div id="pub-my-submissions" class="hidden max-w-[1200px] mx-auto px-4 pb-8 space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="text-xl font-extrabold text-navy">{t('publications.mySubmissions', lang)}</h2>
      <button id="btn-my-new-sub" class="px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold hover:opacity-90 cursor-pointer">
        + {t('publications.new', lang)}
      </button>
    </div>
    <div id="my-subs-loading" class="text-center py-8 text-[var(--text-muted)] text-sm">{t('common.loading', lang)}</div>
    <div id="my-subs-empty" class="hidden text-center py-8">
      <p class="text-sm text-[var(--text-secondary)]">{t('publications.publicEmpty', lang)}</p>
    </div>
    <div id="my-subs-list" class="hidden space-y-3"></div>
  </div>

  <!-- My Submission Detail Modal -->
  <div id="my-detail-modal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-[var(--surface-card)] rounded-2xl shadow-xl max-w-lg w-full max-h-[80vh] overflow-y-auto p-6 relative">
      <button id="my-detail-close" class="absolute top-3 right-3 text-xl text-[var(--text-muted)] cursor-pointer bg-transparent border-0 hover:text-navy">&times;</button>
      <div id="my-detail-body"></div>
    </div>
  </div>

  <!-- My New Submission Modal -->
  <div id="my-new-modal" class="hidden fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
    <div class="bg-[var(--surface-card)] rounded-2xl shadow-xl max-w-lg w-full max-h-[80vh] overflow-y-auto p-6 relative">
      <button id="my-new-close" class="absolute top-3 right-3 text-xl text-[var(--text-muted)] cursor-pointer bg-transparent border-0 hover:text-navy">&times;</button>
      <h3 class="text-lg font-bold text-navy mb-4">+ {t('publications.new', lang)}</h3>
      <form id="my-new-form" class="space-y-3">
        <div>
          <label class="text-[.7rem] font-semibold text-[var(--text-muted)] block mb-1">{t('publications.formTitle', lang)}</label>
          <input name="title" required class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-sm">
        </div>
        <div>
          <label class="text-[.7rem] font-semibold text-[var(--text-muted)] block mb-1">{t('publications.formAbstract', lang)}</label>
          <textarea name="abstract" rows="3" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-sm"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-[.7rem] font-semibold text-[var(--text-muted)] block mb-1">{t('publications.formTargetType', lang)}</label>
            <select name="target_type" required class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-sm">
              <option value="pmi_global_conference">{t('publications.target.pmi_global', lang)}</option>
              <option value="pmi_chapter_event">{t('publications.target.pmi_chapter', lang)}</option>
              <option value="academic_journal">{t('publications.target.journal', lang)}</option>
              <option value="academic_conference">{t('publications.target.conference', lang)}</option>
              <option value="webinar">{t('publications.target.webinar', lang)}</option>
              <option value="blog_post">{t('publications.target.blog', lang)}</option>
              <option value="other">Outro</option>
            </select>
          </div>
          <div>
            <label class="text-[.7rem] font-semibold text-[var(--text-muted)] block mb-1">{t('publications.formTargetName', lang)}</label>
            <input name="target_name" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-sm">
          </div>
        </div>
        <div>
          <label class="text-[.7rem] font-semibold text-[var(--text-muted)] block mb-1">{t('publications.estimatedCost', lang)}</label>
          <input name="estimated_cost" type="number" step="0.01" min="0" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-sm">
        </div>
        <button type="submit" class="w-full py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer hover:opacity-90">Salvar</button>
      </form>
    </div>
  </div>

  <!-- ── Internal Board (login required, hidden for anonymous) ── -->
  <div id="pub-internal" class="hidden max-w-[1200px] mx-auto px-4 pb-10 space-y-4">
    <section class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
      <div class="p-6 sm:p-8">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 border border-indigo-200 text-[.72rem] font-semibold text-indigo-700 mb-3">
              <span>Governança global</span>
              <span class="text-indigo-400">&bull;</span>
              <span>{t('publications.badgeFlow', lang)}</span>
            </div>
            <h2 class="text-xl font-extrabold text-navy mb-2">{t('publications.title', lang)}</h2>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              {t('publications.subtitle', lang)}
            </p>
          </div>
          <a href="/admin/curatorship" class="px-4 py-2.5 rounded-xl bg-navy text-white text-[.78rem] font-semibold no-underline text-center hover:opacity-90 transition-all">
            {t('publications.openCuratorship', lang)}
          </a>
        </div>
      </div>
    </section>
    <section id="pub-board-island">
      <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
      <PublicationsBoardIsland client:load />
    </section>
  </div>
</BaseLayout>

<!-- Hidden i18n strings for JS -->
<span id="pub-i18n-views" class="hidden">{t('publications.views', lang)}</span>
<span id="pub-i18n-bibtex" class="hidden">BibTeX</span>
<span id="pub-i18n-read" class="hidden">{t('publications.readMore', lang)}</span>
<span id="pub-i18n-featured" class="hidden">{t('publications.featured', lang)}</span>

<script>
  import { hasPermission } from '../lib/permissions';
  const TYPE_ICONS: Record<string, string> = {
    article: '\u{1F4C4}', framework: '\u{1F3D7}\uFE0F', toolkit: '\u{1F9F0}',
    case_study: '\u{1F4CB}', webinar_recording: '\u{1F3AC}', ebook: '\u{1F4D6}', podcast: '\u{1F3A7}'
  };
  const TYPE_LABELS: Record<string, string> = {
    article: 'Artigo', framework: 'Framework', toolkit: 'Toolkit',
    case_study: 'Case Study', webinar_recording: 'Webinar', ebook: 'E-book', podcast: 'Podcast'
  };

  function escHtml(s: string) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function generateBibtex(pub: any): string {
    const firstAuthor = (pub.authors?.[0] || 'Unknown').split(' ');
    const surname = firstAuthor[firstAuthor.length - 1].toLowerCase();
    const year = pub.publication_date ? new Date(pub.publication_date).getFullYear() : 'nd';
    const key = `${surname}${year}`;
    const authorsFormatted = (pub.authors || []).map((a: string) => {
      const parts = a.trim().split(' ');
      return parts.length > 1 ? `${parts[parts.length-1]}, ${parts.slice(0,-1).join(' ')}` : a;
    }).join(' and ');
    const safeTitle = (pub.title || '').replace(/&/g, '\\&');
    return `@article{${key},\n  title={${safeTitle}},\n  author={${authorsFormatted}},\n  year={${year}},\n  publisher={Núcleo IA \\& GP — PMI Brazilian Chapters}${pub.external_url ? `,\n  url={${pub.external_url}}` : ''}${pub.doi ? `,\n  doi={${pub.doi}}` : ''}\n}`;
  }

  function copyBibtex(pub: any) {
    const bib = generateBibtex(pub);
    navigator.clipboard.writeText(bib).then(() => {
      (window as any).toast?.('BibTeX copiado!', 'success');
    }).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = bib; document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); document.body.removeChild(ta);
      (window as any).toast?.('BibTeX copiado!', 'success');
    });
  }

  let allPubs: any[] = [];

  function renderPublications(pubs: any[]) {
    const grid = document.getElementById('pub-public-grid');
    const empty = document.getElementById('pub-public-empty');
    const cta = document.getElementById('pub-cta');
    const stats = document.getElementById('pub-stats');
    if (!grid) return;

    if (pubs.length === 0) {
      grid.classList.add('hidden');
      empty?.classList.remove('hidden');
      cta?.classList.add('hidden');
      return;
    }

    empty?.classList.add('hidden');
    cta?.classList.remove('hidden');

    // Stats
    if (stats) {
      const articles = pubs.filter(p => p.publication_type === 'article').length;
      const frameworks = pubs.filter(p => p.publication_type === 'framework').length;
      const webinars = pubs.filter(p => p.publication_type === 'webinar_recording').length;
      const totalViews = pubs.reduce((s: number, p: any) => s + (p.view_count || 0), 0);
      stats.innerHTML = [
        articles > 0 ? `<span class="text-[.78rem] text-[var(--text-secondary)] font-semibold">${articles} artigos</span>` : '',
        frameworks > 0 ? `<span class="text-[.78rem] text-[var(--text-secondary)] font-semibold">${frameworks} frameworks</span>` : '',
        webinars > 0 ? `<span class="text-[.78rem] text-[var(--text-secondary)] font-semibold">${webinars} webinars</span>` : '',
        `<span class="text-[.78rem] text-[var(--text-muted)]">\u{1F441} ${totalViews} views</span>`,
      ].filter(Boolean).join('<span class="text-[var(--text-muted)]">\u00B7</span>');
      stats.classList.remove('hidden');
    }

    const viewsLabel = document.getElementById('pub-i18n-views')?.textContent || 'views';
    const readLabel = document.getElementById('pub-i18n-read')?.textContent || 'Ler \u2192';
    const featuredLabel = document.getElementById('pub-i18n-featured')?.textContent || 'Destaque';

    grid.innerHTML = pubs.map((p: any) => {
      const icon = TYPE_ICONS[p.publication_type] || '\u{1F4C4}';
      const typeLabel = TYPE_LABELS[p.publication_type] || p.publication_type;
      const dateStr = p.publication_date ? new Date(p.publication_date).toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' }) : '';
      const authors = (p.authors || []).join(', ');
      const abstractShort = p.abstract ? (p.abstract.length > 120 ? p.abstract.substring(0, 120) + '...' : p.abstract) : '';
      const keywords = (p.keywords || []).slice(0, 4);

      return `
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-5 hover:-translate-y-px hover:shadow-md transition-all duration-200 flex flex-col" data-pub-id="${p.id}">
          ${p.is_featured ? `<span class="inline-block self-start px-2 py-0.5 bg-amber-100 text-amber-800 text-[.6rem] font-bold rounded-full mb-2">\u2B50 ${escHtml(featuredLabel)}</span>` : ''}
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[.65rem] font-bold px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700">${icon} ${escHtml(typeLabel)}</span>
            ${dateStr ? `<span class="text-[.65rem] text-[var(--text-muted)]">${escHtml(dateStr)}</span>` : ''}
          </div>
          <h3 class="text-sm font-bold text-navy leading-snug mb-1.5 line-clamp-2">${escHtml(p.title)}</h3>
          <p class="text-[.7rem] text-[var(--text-secondary)] mb-1.5">${escHtml(authors)}</p>
          ${abstractShort ? `<p class="text-[.68rem] text-[var(--text-muted)] italic mb-2 line-clamp-2">"${escHtml(abstractShort)}"</p>` : ''}
          ${keywords.length > 0 ? `<div class="flex flex-wrap gap-1 mb-2">${keywords.map((k: string) => `<span class="px-1.5 py-0.5 bg-[var(--surface-section-cool)] text-[var(--text-secondary)] rounded text-[.6rem] font-medium">${escHtml(k)}</span>`).join('')}</div>` : ''}
          <div class="mt-auto pt-2 flex items-center gap-2 border-t border-[var(--border-subtle)]">
            <span class="text-[.65rem] text-[var(--text-muted)]">\u{1F441} ${p.view_count || 0} ${escHtml(viewsLabel)}</span>
            <span class="flex-1"></span>
            ${p.external_url ? `<a href="${escHtml(p.external_url)}" target="_blank" rel="noopener" class="text-[.68rem] text-teal font-semibold no-underline hover:underline">${escHtml(readLabel)}</a>` : ''}
            <button onclick="window.__copyBibtex(${pubs.indexOf(p)})" class="text-[.65rem] px-1.5 py-0.5 rounded bg-[var(--surface-section-cool)] text-[var(--text-secondary)] font-medium cursor-pointer border-0 hover:bg-[var(--surface-hover)]">BibTeX</button>
            ${p.pdf_url ? `<a href="${escHtml(p.pdf_url)}" target="_blank" rel="noopener" class="text-[.65rem] px-1.5 py-0.5 rounded bg-[var(--surface-section-cool)] text-[var(--text-secondary)] font-medium no-underline hover:bg-[var(--surface-hover)]">PDF</a>` : ''}
          </div>
        </div>
      `;
    }).join('');

    grid.classList.remove('hidden');
    grid.classList.add('grid');

    // Inject Schema.org for each publication
    const existingLd = document.getElementById('pub-schema-ld');
    if (existingLd) existingLd.remove();
    const ldScript = document.createElement('script');
    ldScript.type = 'application/ld+json';
    ldScript.id = 'pub-schema-ld';
    ldScript.textContent = JSON.stringify(pubs.map((p: any) => ({
      '@context': 'https://schema.org',
      '@type': 'ScholarlyArticle',
      headline: p.title,
      author: (p.authors || []).map((a: string) => ({ '@type': 'Person', name: a })),
      datePublished: p.publication_date,
      publisher: { '@type': 'Organization', name: 'Núcleo IA & GP — PMI Brazilian Chapters' },
      keywords: p.keywords,
      abstract: p.abstract,
      url: p.external_url
    })));
    document.head.appendChild(ldScript);
  }

  async function loadPublicPublications() {
    const loading = document.getElementById('pub-public-loading');
    try {
      const sb = (window as any).navGetSb?.();
      if (!sb) { setTimeout(loadPublicPublications, 500); return; }

      const typeFilter = (document.getElementById('pub-filter-type') as HTMLSelectElement)?.value || null;
      const search = (document.getElementById('pub-search') as HTMLInputElement)?.value?.trim() || null;

      const { data, error } = await sb.rpc('get_public_publications', {
        p_type: typeFilter || null, p_search: search || null
      });
      loading?.classList.add('hidden');
      allPubs = data || [];
      (window as any).__pubsData = allPubs;
      renderPublications(allPubs);
    } catch (e) {
      console.warn('Publications load:', e);
      loading?.classList.add('hidden');
      document.getElementById('pub-public-empty')?.classList.remove('hidden');
    }
  }

  // ── Researcher self-service: My Submissions ──
  const STATUS_COLORS: Record<string, string> = {
    draft: 'bg-gray-100 text-gray-700',
    submitted: 'bg-blue-100 text-blue-700',
    under_review: 'bg-amber-100 text-amber-700',
    revision_requested: 'bg-orange-100 text-orange-700',
    accepted: 'bg-green-100 text-green-700',
    rejected: 'bg-red-100 text-red-700',
    published: 'bg-emerald-100 text-emerald-700',
    presented: 'bg-purple-100 text-purple-700',
  };
  const STATUS_LABELS: Record<string, string> = {
    draft: 'Rascunho', submitted: 'Submetido', under_review: 'Em Revisão',
    revision_requested: 'Revisão Solicitada', accepted: 'Aceito',
    rejected: 'Rejeitado', published: 'Publicado', presented: 'Apresentado',
  };
  const TARGET_LABELS: Record<string, string> = {
    pmi_global_conference: 'PMI Global', pmi_chapter_event: 'PMI Chapter',
    academic_journal: 'Periódico', academic_conference: 'Conferência',
    webinar: 'Webinar', blog_post: 'Blog Post', other: 'Outro',
  };

  async function loadMySubmissions() {
    const sb = (window as any).navGetSb?.();
    const member = (window as any).navGetMember?.();
    if (!sb || !member) return;

    const loading = document.getElementById('my-subs-loading');
    const empty = document.getElementById('my-subs-empty');
    const list = document.getElementById('my-subs-list');
    if (!list) return;

    try {
      const { data, error } = await sb.rpc('get_publication_submissions', {
        p_status: null, p_tribe_id: null
      });
      if (error) throw error;

      const myId = member.id;
      const mySubs = (data || []).filter((s: any) =>
        s.primary_author_id === myId ||
        (s.authors || []).some((a: any) => a.member_id === myId)
      );

      loading?.classList.add('hidden');

      if (mySubs.length === 0) {
        empty?.classList.remove('hidden');
        return;
      }

      list.innerHTML = mySubs.map((s: any) => {
        const sColor = STATUS_COLORS[s.status] || 'bg-gray-100 text-gray-700';
        const sLabel = STATUS_LABELS[s.status] || s.status;
        const tLabel = TARGET_LABELS[s.target_type] || s.target_type;
        return `
          <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 cursor-pointer hover:shadow-md transition-all" data-my-sub-id="${s.id}">
            <div class="flex items-center justify-between gap-2 mb-1">
              <h3 class="text-sm font-bold text-navy truncate flex-1">${escHtml(s.title)}</h3>
              <span class="text-[.65rem] font-bold px-2 py-0.5 rounded-full ${sColor} whitespace-nowrap">${escHtml(sLabel)}</span>
            </div>
            <div class="flex items-center gap-2 text-[.7rem] text-[var(--text-muted)]">
              <span>${escHtml(tLabel)}</span>
              ${s.target_name ? `<span>&bull; ${escHtml(s.target_name)}</span>` : ''}
              ${s.created_at ? `<span>&bull; ${new Date(s.created_at).toLocaleDateString('pt-BR')}</span>` : ''}
            </div>
          </div>
        `;
      }).join('');

      list.classList.remove('hidden');

      // Click handlers for detail
      list.querySelectorAll('[data-my-sub-id]').forEach(el => {
        el.addEventListener('click', () => showMySubDetail(el.getAttribute('data-my-sub-id')!, mySubs));
      });
    } catch (e) {
      console.warn('My submissions load:', e);
      loading?.classList.add('hidden');
    }
  }

  function showMySubDetail(id: string, subs: any[]) {
    const sub = subs.find((s: any) => s.id === id);
    if (!sub) return;
    const body = document.getElementById('my-detail-body');
    if (!body) return;

    const sColor = STATUS_COLORS[sub.status] || 'bg-gray-100 text-gray-700';
    const sLabel = STATUS_LABELS[sub.status] || sub.status;
    const tLabel = TARGET_LABELS[sub.target_type] || sub.target_type;

    body.innerHTML = `
      <div class="space-y-3">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-[.7rem] font-bold px-2 py-0.5 rounded-full ${sColor}">${escHtml(sLabel)}</span>
          <span class="text-[.7rem] text-[var(--text-muted)]">${escHtml(tLabel)}</span>
        </div>
        <h2 class="text-lg font-extrabold text-navy">${escHtml(sub.title)}</h2>
        ${sub.abstract ? `<p class="text-sm text-[var(--text-secondary)] italic">${escHtml(sub.abstract)}</p>` : ''}
        ${sub.target_name ? `<div class="text-[.75rem]"><strong>Destino:</strong> ${escHtml(sub.target_name)}</div>` : ''}
        ${sub.target_url ? `<div class="text-[.75rem]"><a href="${escHtml(sub.target_url)}" target="_blank" rel="noopener" class="text-teal hover:underline">Link externo</a></div>` : ''}
        ${sub.primary_author_name ? `<div class="text-[.75rem]"><strong>Autor principal:</strong> ${escHtml(sub.primary_author_name)}</div>` : ''}
        ${sub.estimated_cost ? `<div class="text-[.75rem]"><strong>Custo estimado:</strong> R$ ${Number(sub.estimated_cost).toFixed(2)}</div>` : ''}
        <div class="text-[.7rem] text-[var(--text-muted)] pt-2 border-t border-[var(--border-subtle)]">
          Criado em ${sub.created_at ? new Date(sub.created_at).toLocaleDateString('pt-BR') : '-'}
        </div>
      </div>
    `;
    document.getElementById('my-detail-modal')?.classList.remove('hidden');
  }

  // Close my-detail modal
  document.getElementById('my-detail-close')?.addEventListener('click', () => {
    document.getElementById('my-detail-modal')?.classList.add('hidden');
  });
  document.getElementById('my-detail-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) document.getElementById('my-detail-modal')?.classList.add('hidden');
  });

  // New submission modal for researcher
  document.getElementById('btn-my-new-sub')?.addEventListener('click', () => {
    document.getElementById('my-new-modal')?.classList.remove('hidden');
  });
  document.getElementById('my-new-close')?.addEventListener('click', () => {
    document.getElementById('my-new-modal')?.classList.add('hidden');
  });
  document.getElementById('my-new-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) document.getElementById('my-new-modal')?.classList.add('hidden');
  });

  document.getElementById('my-new-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const sb = (window as any).navGetSb?.();
    const member = (window as any).navGetMember?.();
    if (!sb || !member) return;

    const fd = new FormData(e.target as HTMLFormElement);
    const { error } = await sb.rpc('create_publication_submission', {
      p_title: fd.get('title'),
      p_abstract: fd.get('abstract') || null,
      p_target_type: fd.get('target_type'),
      p_target_name: fd.get('target_name') || null,
      p_primary_author_id: member.id,
      p_tribe_id: member.tribe_id || null,
      p_estimated_cost: fd.get('estimated_cost') ? Number(fd.get('estimated_cost')) : null,
    });

    if (error) {
      (window as any).toast?.('Erro ao criar submissão', 'error');
      return;
    }
    (window as any).toast?.('Submissão criada!', 'success');
    document.getElementById('my-new-modal')?.classList.add('hidden');
    (e.target as HTMLFormElement).reset();
    loadMySubmissions();
  });

  // Show internal board section if logged in
  function checkInternalAccess() {
    const m = (window as any).navGetMember?.();
    if (m) {
      document.getElementById('pub-internal')?.classList.remove('hidden');
    }
  }

  (window as any).__copyBibtex = (idx: number) => {
    const pub = (window as any).__pubsData?.[idx];
    if (pub) copyBibtex(pub);
  };

  // Debounced filter
  let filterTimer: ReturnType<typeof setTimeout>;
  document.getElementById('pub-filter-type')?.addEventListener('change', () => { loadPublicPublications(); });
  document.getElementById('pub-search')?.addEventListener('input', () => {
    clearTimeout(filterTimer);
    filterTimer = setTimeout(loadPublicPublications, 400);
  });

  // Check researcher self-service access
  function checkMySubmissionsAccess() {
    const m = (window as any).navGetMember?.();
    if (!m) return;
    // Researchers, tribe_leaders, managers, deputy_managers, superadmins can submit
    const canSubmit = hasPermission(m, 'content.submit_publication');
    if (canSubmit) {
      document.getElementById('pub-my-submissions')?.classList.remove('hidden');
      loadMySubmissions();
    }
  }

  // Boot
  function boot() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 300); return; }
    loadPublicPublications();
    checkInternalAccess();
    checkMySubmissionsAccess();
    window.addEventListener('nav:member', () => { checkInternalAccess(); checkMySubmissionsAccess(); });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
