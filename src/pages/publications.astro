---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import PublicationsBoardIsland from '../components/boards/PublicationsBoardIsland';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('publications.publicTitle', lang)} activePage="publications">
  <!-- ── Public Publications Section (no login required) ── -->
  <div class="max-w-[1200px] mx-auto px-4 pt-8 pb-6">
    <div class="mb-2 text-[.73rem] font-bold tracking-[.15em] uppercase text-indigo-600">
      {t('publications.publicLabel', lang)}
    </div>
    <h1 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-2 text-navy">
      {t('publications.publicTitle', lang)}
    </h1>
    <p class="text-base text-[var(--text-secondary)] max-w-[700px] mb-6">
      {t('publications.publicSubtitle', lang)}
    </p>

    <!-- Stats bar -->
    <div id="pub-stats" class="hidden flex flex-wrap gap-4 mb-6">
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 mb-6" id="pub-filters">
      <select id="pub-filter-type" class="px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-card)]">
        <option value="">{t('publications.filterAllTypes', lang)}</option>
        <option value="article">{t('publications.typeArticle', lang)}</option>
        <option value="framework">{t('publications.typeFramework', lang)}</option>
        <option value="toolkit">{t('publications.typeToolkit', lang)}</option>
        <option value="case_study">{t('publications.typeCaseStudy', lang)}</option>
        <option value="webinar_recording">{t('publications.typeWebinar', lang)}</option>
      </select>
      <input type="search" id="pub-search" placeholder={t('publications.searchPlaceholder', lang)}
        class="px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-card)] min-w-[200px]">
    </div>

    <!-- Loading -->
    <div id="pub-public-loading" class="text-center py-8 text-[var(--text-muted)] text-sm">
      {t('common.loading', lang)}
    </div>

    <!-- Empty -->
    <div id="pub-public-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-3">&#x1F4DA;</div>
      <p class="text-[var(--text-secondary)]">{t('publications.publicEmpty', lang)}</p>
    </div>

    <!-- Publications grid -->
    <div id="pub-public-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
    </div>

    <!-- CTA -->
    <div id="pub-cta" class="hidden text-center py-6 border-t border-[var(--border-subtle)]">
      <p class="text-sm text-[var(--text-secondary)] mb-3">{t('publications.ctaText', lang)}</p>
      <a href="/teams" class="inline-block px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('publications.ctaButton', lang)}
      </a>
    </div>
  </div>

  <!-- ── Internal Board (login required, hidden for anonymous) ── -->
  <div id="pub-internal" class="hidden max-w-[1200px] mx-auto px-4 pb-10 space-y-4">
    <section class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
      <div class="p-6 sm:p-8">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 border border-indigo-200 text-[.72rem] font-semibold text-indigo-700 mb-3">
              <span>Governança global</span>
              <span class="text-indigo-400">&bull;</span>
              <span>{t('publications.badgeFlow', lang)}</span>
            </div>
            <h2 class="text-xl font-extrabold text-navy mb-2">{t('publications.title', lang)}</h2>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              {t('publications.subtitle', lang)}
            </p>
          </div>
          <a href="/admin/curatorship" class="px-4 py-2.5 rounded-xl bg-navy text-white text-[.78rem] font-semibold no-underline text-center hover:opacity-90 transition-all">
            {t('publications.openCuratorship', lang)}
          </a>
        </div>
      </div>
    </section>
    <section id="pub-board-island">
      <PublicationsBoardIsland client:load />
    </section>
  </div>
</BaseLayout>

<!-- Hidden i18n strings for JS -->
<span id="pub-i18n-views" class="hidden">{t('publications.views', lang)}</span>
<span id="pub-i18n-bibtex" class="hidden">BibTeX</span>
<span id="pub-i18n-read" class="hidden">{t('publications.readMore', lang)}</span>
<span id="pub-i18n-featured" class="hidden">{t('publications.featured', lang)}</span>

<script>
  const TYPE_ICONS: Record<string, string> = {
    article: '\u{1F4C4}', framework: '\u{1F3D7}\uFE0F', toolkit: '\u{1F9F0}',
    case_study: '\u{1F4CB}', webinar_recording: '\u{1F3AC}', ebook: '\u{1F4D6}', podcast: '\u{1F3A7}'
  };
  const TYPE_LABELS: Record<string, string> = {
    article: 'Artigo', framework: 'Framework', toolkit: 'Toolkit',
    case_study: 'Case Study', webinar_recording: 'Webinar', ebook: 'E-book', podcast: 'Podcast'
  };

  function escHtml(s: string) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function generateBibtex(pub: any): string {
    const firstAuthor = (pub.authors?.[0] || 'Unknown').split(' ');
    const surname = firstAuthor[firstAuthor.length - 1].toLowerCase();
    const year = pub.publication_date ? new Date(pub.publication_date).getFullYear() : 'nd';
    const key = `${surname}${year}`;
    const authorsFormatted = (pub.authors || []).map((a: string) => {
      const parts = a.trim().split(' ');
      return parts.length > 1 ? `${parts[parts.length-1]}, ${parts.slice(0,-1).join(' ')}` : a;
    }).join(' and ');
    const safeTitle = (pub.title || '').replace(/&/g, '\\&');
    return `@article{${key},\n  title={${safeTitle}},\n  author={${authorsFormatted}},\n  year={${year}},\n  publisher={Núcleo IA \\& GP — PMI Brazilian Chapters}${pub.external_url ? `,\n  url={${pub.external_url}}` : ''}${pub.doi ? `,\n  doi={${pub.doi}}` : ''}\n}`;
  }

  function copyBibtex(pub: any) {
    const bib = generateBibtex(pub);
    navigator.clipboard.writeText(bib).then(() => {
      (window as any).toast?.('BibTeX copiado!', 'success');
    }).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = bib; document.body.appendChild(ta); ta.select();
      document.execCommand('copy'); document.body.removeChild(ta);
      (window as any).toast?.('BibTeX copiado!', 'success');
    });
  }

  let allPubs: any[] = [];

  function renderPublications(pubs: any[]) {
    const grid = document.getElementById('pub-public-grid');
    const empty = document.getElementById('pub-public-empty');
    const cta = document.getElementById('pub-cta');
    const stats = document.getElementById('pub-stats');
    if (!grid) return;

    if (pubs.length === 0) {
      grid.classList.add('hidden');
      empty?.classList.remove('hidden');
      cta?.classList.add('hidden');
      return;
    }

    empty?.classList.add('hidden');
    cta?.classList.remove('hidden');

    // Stats
    if (stats) {
      const articles = pubs.filter(p => p.publication_type === 'article').length;
      const frameworks = pubs.filter(p => p.publication_type === 'framework').length;
      const webinars = pubs.filter(p => p.publication_type === 'webinar_recording').length;
      const totalViews = pubs.reduce((s: number, p: any) => s + (p.view_count || 0), 0);
      stats.innerHTML = [
        articles > 0 ? `<span class="text-[.78rem] text-[var(--text-secondary)] font-semibold">${articles} artigos</span>` : '',
        frameworks > 0 ? `<span class="text-[.78rem] text-[var(--text-secondary)] font-semibold">${frameworks} frameworks</span>` : '',
        webinars > 0 ? `<span class="text-[.78rem] text-[var(--text-secondary)] font-semibold">${webinars} webinars</span>` : '',
        `<span class="text-[.78rem] text-[var(--text-muted)]">\u{1F441} ${totalViews} views</span>`,
      ].filter(Boolean).join('<span class="text-[var(--text-muted)]">\u00B7</span>');
      stats.classList.remove('hidden');
    }

    const viewsLabel = document.getElementById('pub-i18n-views')?.textContent || 'views';
    const readLabel = document.getElementById('pub-i18n-read')?.textContent || 'Ler \u2192';
    const featuredLabel = document.getElementById('pub-i18n-featured')?.textContent || 'Destaque';

    grid.innerHTML = pubs.map((p: any) => {
      const icon = TYPE_ICONS[p.publication_type] || '\u{1F4C4}';
      const typeLabel = TYPE_LABELS[p.publication_type] || p.publication_type;
      const dateStr = p.publication_date ? new Date(p.publication_date).toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' }) : '';
      const authors = (p.authors || []).join(', ');
      const abstractShort = p.abstract ? (p.abstract.length > 120 ? p.abstract.substring(0, 120) + '...' : p.abstract) : '';
      const keywords = (p.keywords || []).slice(0, 4);

      return `
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-5 hover:-translate-y-px hover:shadow-md transition-all duration-200 flex flex-col" data-pub-id="${p.id}">
          ${p.is_featured ? `<span class="inline-block self-start px-2 py-0.5 bg-amber-100 text-amber-800 text-[.6rem] font-bold rounded-full mb-2">\u2B50 ${escHtml(featuredLabel)}</span>` : ''}
          <div class="flex items-center gap-2 mb-2">
            <span class="text-[.65rem] font-bold px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700">${icon} ${escHtml(typeLabel)}</span>
            ${dateStr ? `<span class="text-[.65rem] text-[var(--text-muted)]">${escHtml(dateStr)}</span>` : ''}
          </div>
          <h3 class="text-sm font-bold text-navy leading-snug mb-1.5 line-clamp-2">${escHtml(p.title)}</h3>
          <p class="text-[.7rem] text-[var(--text-secondary)] mb-1.5">${escHtml(authors)}</p>
          ${abstractShort ? `<p class="text-[.68rem] text-[var(--text-muted)] italic mb-2 line-clamp-2">"${escHtml(abstractShort)}"</p>` : ''}
          ${keywords.length > 0 ? `<div class="flex flex-wrap gap-1 mb-2">${keywords.map((k: string) => `<span class="px-1.5 py-0.5 bg-[var(--surface-section-cool)] text-[var(--text-secondary)] rounded text-[.6rem] font-medium">${escHtml(k)}</span>`).join('')}</div>` : ''}
          <div class="mt-auto pt-2 flex items-center gap-2 border-t border-[var(--border-subtle)]">
            <span class="text-[.65rem] text-[var(--text-muted)]">\u{1F441} ${p.view_count || 0} ${escHtml(viewsLabel)}</span>
            <span class="flex-1"></span>
            ${p.external_url ? `<a href="${escHtml(p.external_url)}" target="_blank" rel="noopener" class="text-[.68rem] text-teal font-semibold no-underline hover:underline">${escHtml(readLabel)}</a>` : ''}
            <button onclick="window.__copyBibtex(${pubs.indexOf(p)})" class="text-[.65rem] px-1.5 py-0.5 rounded bg-[var(--surface-section-cool)] text-[var(--text-secondary)] font-medium cursor-pointer border-0 hover:bg-[var(--surface-hover)]">BibTeX</button>
            ${p.pdf_url ? `<a href="${escHtml(p.pdf_url)}" target="_blank" rel="noopener" class="text-[.65rem] px-1.5 py-0.5 rounded bg-[var(--surface-section-cool)] text-[var(--text-secondary)] font-medium no-underline hover:bg-[var(--surface-hover)]">PDF</a>` : ''}
          </div>
        </div>
      `;
    }).join('');

    grid.classList.remove('hidden');
    grid.classList.add('grid');

    // Inject Schema.org for each publication
    const existingLd = document.getElementById('pub-schema-ld');
    if (existingLd) existingLd.remove();
    const ldScript = document.createElement('script');
    ldScript.type = 'application/ld+json';
    ldScript.id = 'pub-schema-ld';
    ldScript.textContent = JSON.stringify(pubs.map((p: any) => ({
      '@context': 'https://schema.org',
      '@type': 'ScholarlyArticle',
      headline: p.title,
      author: (p.authors || []).map((a: string) => ({ '@type': 'Person', name: a })),
      datePublished: p.publication_date,
      publisher: { '@type': 'Organization', name: 'Núcleo IA & GP — PMI Brazilian Chapters' },
      keywords: p.keywords,
      abstract: p.abstract,
      url: p.external_url
    })));
    document.head.appendChild(ldScript);
  }

  async function loadPublicPublications() {
    const loading = document.getElementById('pub-public-loading');
    try {
      const sb = (window as any).navGetSb?.();
      if (!sb) { setTimeout(loadPublicPublications, 500); return; }

      const typeFilter = (document.getElementById('pub-filter-type') as HTMLSelectElement)?.value || null;
      const search = (document.getElementById('pub-search') as HTMLInputElement)?.value?.trim() || null;

      const { data, error } = await sb.rpc('get_public_publications', {
        p_type: typeFilter || null, p_search: search || null
      });
      loading?.classList.add('hidden');
      allPubs = data || [];
      (window as any).__pubsData = allPubs;
      renderPublications(allPubs);
    } catch (e) {
      console.warn('Publications load:', e);
      loading?.classList.add('hidden');
      document.getElementById('pub-public-empty')?.classList.remove('hidden');
    }
  }

  // Show internal board section if logged in
  function checkInternalAccess() {
    const m = (window as any).navGetMember?.();
    if (m) {
      document.getElementById('pub-internal')?.classList.remove('hidden');
    }
  }

  (window as any).__copyBibtex = (idx: number) => {
    const pub = (window as any).__pubsData?.[idx];
    if (pub) copyBibtex(pub);
  };

  // Debounced filter
  let filterTimer: ReturnType<typeof setTimeout>;
  document.getElementById('pub-filter-type')?.addEventListener('change', () => { loadPublicPublications(); });
  document.getElementById('pub-search')?.addEventListener('input', () => {
    clearTimeout(filterTimer);
    filterTimer = setTimeout(loadPublicPublications, 400);
  });

  // Boot
  function boot() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 300); return; }
    loadPublicPublications();
    checkInternalAccess();
    window.addEventListener('nav:member', () => checkInternalAccess());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
