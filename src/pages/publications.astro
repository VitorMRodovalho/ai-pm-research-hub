---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import PublicationsBoardIsland from '../components/boards/PublicationsBoardIsland';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('nav.publications', lang)} activePage="publications">
  <div id="pub-loading" class="max-w-[1200px] mx-auto px-4 py-12 text-center text-slate-400">
    Carregando painel global de publicações...
  </div>

  <div id="pub-content" class="hidden max-w-[1200px] mx-auto px-4 pb-10 space-y-4">
    <section class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <div class="p-6 sm:p-8">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 border border-indigo-200 text-[.72rem] font-semibold text-indigo-700 mb-3">
              <span>Governança global</span>
              <span class="text-indigo-400">•</span>
              <span>Curadoria → Submissão externa</span>
            </div>
            <h1 class="text-2xl font-extrabold text-navy dark:text-slate-100 mb-2">Publicações & Submissões</h1>
            <p class="text-sm text-slate-500 dark:text-slate-300 leading-relaxed">
              Quadro global para acompanhar artigos aprovados na Curadoria até o envio e publicação no ecossistema PMI.
              Este fluxo não pertence a uma tribo específica.
            </p>
          </div>
          <a href="/admin/curatorship" class="px-4 py-2.5 rounded-xl bg-navy text-white text-[.78rem] font-semibold no-underline text-center hover:opacity-90 transition-all">
            Abrir Curadoria
          </a>
        </div>
      </div>
    </section>

    <section id="pub-board-island">
      <PublicationsBoardIsland client:load />
    </section>
  </div>
</BaseLayout>
<script>
  document.getElementById('pub-loading')?.classList.add('hidden');
  document.getElementById('pub-content')?.classList.remove('hidden');
</script>
