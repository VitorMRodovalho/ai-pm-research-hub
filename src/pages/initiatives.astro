---
import BaseLayout from '../layouts/BaseLayout.astro';
import LoadingSkeleton from '../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
---
<BaseLayout title={t('nav.myInitiatives', lang)} activePage="my-initiatives" lang={lang}>
  <div class="max-w-[1000px] mx-auto px-4 py-8">
    <div id="init-catalog-loading" class="text-center py-10 text-[var(--text-muted)]">{t('initiative.loading', lang)}</div>
    <div id="init-catalog" class="hidden"></div>
  </div>
  <!-- Hidden i18n strings for script-context lookups (catalog page renders entirely in JS) -->
  <span id="ai18n-i-title" class="hidden">{t('initiative.catalog.title', lang)}</span>
  <span id="ai18n-i-active" class="hidden">{t('initiative.catalog.activeCount', lang)}</span>
  <span id="ai18n-i-mybadge" class="hidden">{t('initiative.catalog.youParticipateBadge', lang)}</span>
  <span id="ai18n-i-empty" class="hidden">{t('initiative.catalog.empty', lang)}</span>
  <span id="ai18n-i-error" class="hidden">{t('initiative.catalog.loadError', lang)}</span>
  <span id="ai18n-i-members" class="hidden">{t('initiative.catalog.members', lang)}</span>
  <span id="ai18n-i-mine" class="hidden">{t('initiative.catalog.youParticipateInline', lang)}</span>
  <span id="ai18n-i-k-committee" class="hidden">{t('initiative.kindBadge.committee', lang)}</span>
  <span id="ai18n-i-k-workgroup" class="hidden">{t('initiative.kindBadge.workgroup', lang)}</span>
  <span id="ai18n-i-k-study_group" class="hidden">{t('initiative.kindBadge.study_group', lang)}</span>
  <span id="ai18n-i-k-book_club" class="hidden">{t('initiative.kindBadge.book_club', lang)}</span>
  <span id="ai18n-i-k-congress" class="hidden">{t('initiative.kindBadge.congress', lang)}</span>
  <span id="ai18n-i-k-workshop" class="hidden">{t('initiative.kindBadge.workshop', lang)}</span>
  <span id="ai18n-i-k-research_tribe" class="hidden">{t('initiative.kindBadge.research_tribe', lang)}</span>
</BaseLayout>

<script>
  const KIND_ICONS: Record<string, string> = {
    committee: '👥', workgroup: '💼', study_group: '📖', book_club: '📚',
    congress: '🎤', workshop: '🔧', research_tribe: '🔬',
  };
  const KIND_COLORS: Record<string, string> = {
    committee: '#06B6D4', workgroup: '#0891B2', study_group: '#8B5CF6', book_club: '#10B981',
    congress: '#F59E0B', workshop: '#EF4444', research_tribe: '#4F17A8',
  };
  const KIND_ORDER: Record<string, number> = {
    research_tribe: 0, workgroup: 1, committee: 2, study_group: 3, congress: 4, book_club: 5, workshop: 6,
  };

  const _i18n = (id: string, fallback: string): string =>
    document.getElementById(id)?.textContent || fallback;
  const _i18nKind = (slug: string, fallback: string): string =>
    _i18n(`ai18n-i-k-${slug}`, fallback);

  function escapeHtml(s: string): string {
    return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function getSb() { return (window as any).navGetSb?.(); }

  async function boot() {
    const sb = getSb();
    const member = (window as any).navGetMember?.();
    if (!sb || !member) {
      window.addEventListener('nav:member', boot, { once: true });
      return;
    }

    const loading = document.getElementById('init-catalog-loading');
    const catalog = document.getElementById('init-catalog');
    if (!loading || !catalog) return;

    // Fetch all initiatives
    const { data, error } = await sb.rpc('list_initiatives', { p_kind: null, p_status: null });
    if (error || !data) {
      loading.textContent = _i18n('ai18n-i-error', 'Erro ao carregar iniciativas.');
      return;
    }

    // Fetch user's engagements to mark "mine"
    let myInitiativeIds = new Set<string>();
    if (member?.auth_id) {
      const { data: personData } = await sb.from('persons').select('id').eq('auth_id', member.auth_id).single();
      if (personData?.id) {
        const { data: engData } = await sb
          .from('engagements')
          .select('initiative_id')
          .eq('person_id', personData.id)
          .eq('status', 'active');
        if (engData) {
          myInitiativeIds = new Set(engData.map((e: any) => e.initiative_id));
        }
      }
    }

    const initiatives = Array.isArray(data) ? data : [];

    // Filter: only active/draft (not archived/concluded unless admin)
    const isAdmin = member?.is_superadmin || ['manager', 'deputy_manager'].includes(member?.operational_role || '');
    const visible = initiatives.filter((i: any) =>
      isAdmin || ['active', 'draft'].includes(i.status)
    );

    // Group by kind
    const groups: Record<string, any[]> = {};
    for (const i of visible) {
      const k = i.kind || 'other';
      (groups[k] = groups[k] || []).push(i);
    }

    // Sort groups by KIND_ORDER
    const sortedKinds = Object.keys(groups).sort((a, b) => (KIND_ORDER[a] ?? 99) - (KIND_ORDER[b] ?? 99));

    // Count how many are "mine"
    const myCount = visible.filter((i: any) => myInitiativeIds.has(i.id)).length;

    const titleStr = _i18n('ai18n-i-title', 'Iniciativas');
    const activeStr = _i18n('ai18n-i-active', '{count} iniciativa(s) ativa(s)').replace('{count}', String(visible.length));
    const myBadgeStr = myCount > 0
      ? _i18n('ai18n-i-mybadge', ' · {count} com sua participação').replace('{count}', String(myCount))
      : '';

    let html = `<div class="mb-6">
      <h1 class="text-xl font-extrabold text-navy">${titleStr}</h1>
      <p class="text-sm text-[var(--text-secondary)] mt-1">${activeStr}${myBadgeStr}</p>
    </div>`;

    const membersTpl = _i18n('ai18n-i-members', '{count} membro(s)');
    const mineInlineStr = _i18n('ai18n-i-mine', 'Você participa');

    for (const kind of sortedKinds) {
      const items = groups[kind];
      const icon = KIND_ICONS[kind] || '📋';
      const color = KIND_COLORS[kind] || '#666';
      // Prefer locale-aware kind label over DB display_name (DB is PT-only).
      const kindName = _i18nKind(kind, items[0]?.kind_display_name || kind.replace(/_/g, ' '));

      html += `<div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-lg">${icon}</span>
          <h2 class="text-sm font-bold uppercase tracking-wide" style="color:${color}">${escapeHtml(kindName)}</h2>
          <span class="text-xs text-[var(--text-muted)]">(${items.length})</span>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          ${items.map((i: any) => {
            const isMine = myInitiativeIds.has(i.id);
            const memberCount = i.member_count || 0;
            const membersStr = membersTpl.replace('{count}', String(memberCount));
            const statusBadge = i.status !== 'active'
              ? `<span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-200 text-gray-600 font-semibold ml-1">${i.status}</span>`
              : '';
            return `<a href="${(typeof window !== 'undefined' && (window as any).__LANG_PREFIX) || ''}/initiative/${i.id}" class="block no-underline bg-[var(--surface-card)] border ${isMine ? 'border-teal-300 ring-1 ring-teal-200' : 'border-[var(--border-default)]'} rounded-xl p-4 hover:shadow-md transition-all group">
              <div class="flex items-start gap-3">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-base flex-shrink-0" style="background:${color}">${icon}</div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-bold text-[var(--text-primary)] group-hover:text-navy truncate">
                    ${escapeHtml(i.title)}${statusBadge}
                  </div>
                  <div class="text-xs text-[var(--text-muted)] mt-0.5">
                    👥 ${membersStr}${isMine ? ` · <span class="text-teal-600 font-semibold">${mineInlineStr}</span>` : ''}
                  </div>
                  ${i.description ? `<p class="text-xs text-[var(--text-secondary)] mt-1 line-clamp-2">${escapeHtml(i.description)}</p>` : ''}
                </div>
              </div>
            </a>`;
          }).join('')}
        </div>
      </div>`;
    }

    if (visible.length === 0) {
      html += `<p class="text-sm text-[var(--text-muted)] text-center py-8">${_i18n('ai18n-i-empty', 'Nenhuma iniciativa encontrada.')}</p>`;
    }

    loading.classList.add('hidden');
    catalog.innerHTML = html;
    catalog.classList.remove('hidden');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
