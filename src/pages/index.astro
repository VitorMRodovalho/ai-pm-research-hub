---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import AuthModal from '../components/ui/AuthModal.astro';
---
<BaseLayout title="Núcleo IA & GP — Ciclo 03" activePage="home">
  <Toast />
  <AuthModal />
  <!-- Hero placeholder while full migration is built -->
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-navy via-slate-900 to-purple/20">
    <div class="text-center text-white px-4">
      <div class="text-orange text-sm font-bold tracking-widest uppercase mb-4">KICK-OFF OFICIAL — CICLO 03 (2026/1)</div>
      <h1 class="text-4xl md:text-6xl font-black leading-tight mb-4">
        Núcleo de Estudos e Pesquisa em<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal to-purple">Inteligência Artificial</span><br>
        e Gerenciamento de Projetos
      </h1>
      <p class="text-white/60 text-lg mb-8">The AI & PM Study and Research Hub — A Joint Initiative of the PMI Brazilian Chapters</p>
      <div class="flex gap-3 justify-center flex-wrap">
        {['PMI-GO','PMI-CE','PMI-DF','PMI-MG','PMI-RS'].map(c => (
          <span class="px-3 py-1.5 border border-white/20 rounded-full text-sm font-semibold text-white/80">{c}</span>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
