  achLifetimeXP: t('gamification.ach.lifetimeXP', lang),
  achCurrentCycle: t('gamification.ach.currentCycle', lang),
  mpTitle: t('gamification.mp.title', lang),
  mpEmpty: t('gamification.mp.empty', lang),
  mpTotal: t('gamification.mp.total', lang),
  mpToNext: t('gamification.mp.toNext', lang),
  mpMaxLevel: t('gamification.mp.maxLevel', lang),
  mpNoPoints: t('gamification.mp.noPoints', lang),
  mpErrorLoad: t('gamification.mp.errorLoad', lang),
  mpLifetimeLabel: t('gamification.mp.lifetimeLabel', lang),
  mpCurrentCycleLabel: t('gamification.mp.currentCycleLabel', lang),
  mpPtsLabel: t('gamification.mp.ptsLabel', lang),
  certTitle: t('gamification.cert.title', lang),
  certEmpty: t('gamification.cert.empty', lang),
  certIssue: t('gamification.cert.issue', lang),
  certSelect: t('gamification.cert.select', lang),
  certParticipant: t('gamification.cert.participant', lang),
  certType: t('gamification.cert.type', lang),
  certCycle: t('gamification.cert.cycle', lang),
  certCertTitle: t('gamification.cert.certTitle', lang),
  certDesc: t('gamification.cert.desc', lang),
  certIssued: t('gamification.cert.issued', lang),
  certFillFields: t('gamification.cert.fillFields', lang),
  certCode: t('gamification.cert.code', lang),
  certErrorLoad: t('gamification.cert.errorLoad', lang),
  certIssueBtn: t('gamification.cert.issueBtn', lang),
  certTitlePlaceholder: t('gamification.cert.titlePlaceholder', lang),
  certDescPlaceholder: t('gamification.cert.descPlaceholder', lang),
  typeParticipation: t('gamification.cert.type.participation', lang),
  typeCompletion: t('gamification.cert.type.completion', lang),
  typeContribution: t('gamification.cert.type.contribution', lang),
  typeExcellence: t('gamification.cert.type.excellence', lang),
  syncAttendanceError: t('gamification.sync.attendanceError', lang),
  syncAttendanceFail: t('gamification.sync.attendanceFail', lang),
  syncAttendanceSuccess: t('gamification.sync.attendanceSuccess', lang),
  syncCredlySuccess: t('gamification.sync.credlySuccess', lang),
  syncCredlyBatchError: t('gamification.sync.credlyBatchError', lang),
  syncCredlyNotRun: t('gamification.sync.credlyNotRun', lang),
  trailLoading: t('gamification.trail.loading', lang),
  trailTitle: t('gamification.trail.title', lang),
  trailCoursesOf: t('gamification.trail.coursesOf', lang),
  trailPctComplete: t('gamification.trail.pctComplete', lang),
  trailComplete: t('gamification.trail.complete', lang),
  trailMissing: t('gamification.trail.missing', lang),
  trailInProgress: t('gamification.trail.inProgress', lang),
  trailError: t('gamification.trail.error', lang),
  credlyTierTitle: t('gamification.credly.tierTitle', lang),
  credlyTotalLabel: t('gamification.credly.totalLabel', lang),
  credlyTiersDesc: t('gamification.credly.tiersDesc', lang),
  levelExplorer: t('gamification.levels.explorer', lang),
  levelPractitioner: t('gamification.levels.practitioner', lang),
  levelExpert: t('gamification.levels.expert', lang),
  levelMaster: t('gamification.levels.master', lang),
  levelLegend: t('gamification.levels.legend', lang),
  achDefFirstPointsName: t('gamification.ach.def.firstPoints.name', lang),
  achDefFirstPointsDesc: t('gamification.ach.def.firstPoints.desc', lang),
  achDefPractitionerName: t('gamification.ach.def.practitioner.name', lang),
  achDefPractitionerDesc: t('gamification.ach.def.practitioner.desc', lang),
  achDefExpertName: t('gamification.ach.def.expert.name', lang),
  achDefExpertDesc: t('gamification.ach.def.expert.desc', lang),
  achDefMasterName: t('gamification.ach.def.master.name', lang),
  achDefMasterDesc: t('gamification.ach.def.master.desc', lang),
  achDefLegendName: t('gamification.ach.def.legend.name', lang),
  achDefLegendDesc: t('gamification.ach.def.legend.desc', lang),
  achDefScholarName: t('gamification.ach.def.scholar.name', lang),
  achDefScholarDesc: t('gamification.ach.def.scholar.desc', lang),
  achDefPublisherName: t('gamification.ach.def.publisher.name', lang),
  achDefPublisherDesc: t('gamification.ach.def.publisher.desc', lang),
  achDefConsistentName: t('gamification.ach.def.consistent.name', lang),
  achDefConsistentDesc: t('gamification.ach.def.consistent.desc', lang),
  achDefEngagedName: t('gamification.ach.def.engaged.name', lang),
  achDefEngagedDesc: t('gamification.ach.def.engaged.desc', lang),
  achDefVeteranName: t('gamification.ach.def.veteran.name', lang),
  achDefVeteranDesc: t('gamification.ach.def.veteran.desc', lang),
  achDefProfileCompleteName: t('gamification.ach.def.profileComplete.name', lang),
  achDefProfileCompleteDesc: t('gamification.ach.def.profileComplete.desc', lang),
  tribeName1: t('gamification.tribeName.1', lang),
  tribeName2: t('gamification.tribeName.2', lang),
  tribeName3: t('gamification.tribeName.3', lang),
  tribeName4: t('gamification.tribeName.4', lang),
  tribeName5: t('gamification.tribeName.5', lang),
  tribeName6: t('gamification.tribeName.6', lang),
  tribeName7: t('gamification.tribeName.7', lang),
  tribeName8: t('gamification.tribeName.8', lang),
  locale: lang === 'es-LATAM' ? 'es' : lang,
};
---
<BaseLayout title={t('gamification.titleFull', lang)} activePage="gamification">
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
      <h1 class="text-2xl font-extrabold text-navy">{t('gamification.headingFull', lang)}</h1>
      <button id="btn-sync" class="hidden px-4 py-2 bg-teal text-white rounded-xl font-semibold text-sm cursor-pointer border-0 hover:opacity-90 transition-all"
              data-action="sync-points">
        {t('gamification.syncCredlyBtn', lang)}
      </button>
    </div>

    <!-- XP Level Legend -->
    <div class="bg-gradient-to-r from-navy/5 to-orange/5 rounded-xl border border-slate-200 p-5 mb-6">
      <h3 class="text-sm font-bold text-navy mb-3">{t('gamification.levels.title', lang)}</h3>
      <div class="flex flex-wrap gap-3">
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">🌱</span>
          <div><strong>{t('gamification.levels.explorer', lang)}</strong><span class="text-slate-400 ml-1">0–30 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">⚡</span>
          <div><strong>{t('gamification.levels.practitioner', lang)}</strong><span class="text-slate-400 ml-1">31–90 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">🔥</span>
          <div><strong>{t('gamification.levels.expert', lang)}</strong><span class="text-slate-400 ml-1">91–200 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">💎</span>
          <div><strong>{t('gamification.levels.master', lang)}</strong><span class="text-slate-400 ml-1">201–400 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">🏆</span>
          <div><strong>{t('gamification.levels.legend', lang)}</strong><span class="text-slate-400 ml-1">401+ pts</span></div>
        </div>
      </div>
    </div>

    <!-- Points legend -->
    <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
      <h3 class="text-sm font-bold text-navy mb-3">{t('gamification.pointsLegend.title', lang)}</h3>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 text-[13px]">
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-[11px]">+10</span>
          <span class="text-slate-600">{t('gamification.pointsLegend.attendance', lang)}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center font-bold text-[11px]">+15</span>
          <span class="text-slate-600">{t('gamification.pointsLegend.course', lang)}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-[11px]">+30</span>
          <span class="text-slate-600">{t('gamification.pointsLegend.artifact', lang)}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-pink-50 text-pink-600 flex items-center justify-center font-bold text-[11px]">+50</span>
          <span class="text-slate-600">{t('gamification.pointsLegend.profile', lang)}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center font-bold text-[11px]">+10-50</span>
          <span class="text-slate-600">{t('gamification.pointsLegend.credly', lang)}</span>
        </div>
      </div>
      <div class="mt-3 text-[11px] text-slate-500">
        {t('gamification.credly.tiersDesc', lang)}
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-6 flex-wrap">
      <button class="gam-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white"
              data-tab="leaderboard" data-action="switch-tab">{t('gamification.tab.individual', lang)}</button>
      <button class="gam-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              data-tab="tribes" data-action="switch-tab">{t('gamification.tab.tribes', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-achievements" data-tab="achievements" data-action="switch-tab">{t('gamification.tab.achievements', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-mypoints" data-tab="mypoints" data-action="switch-tab">{t('gamification.tab.myPoints', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-mycerts" data-tab="mycerts" data-action="switch-tab">{t('gamification.tab.certs', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-admin-certs" data-tab="admin-certs" data-action="switch-tab">{t('gamification.tab.issue', lang)}</button>
    </div>

    <!-- Trail Clarity (logged user) -->
    <div id="trail-clarity-card" class="hidden mb-6">
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <div id="trail-clarity-content">
          <p class="text-slate-400 text-sm text-center py-2">{t('gamification.trail.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Individual Leaderboard -->
    <div id="panel-leaderboard">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200 flex items-center justify-between">
          <h3 class="text-sm font-bold text-navy">{t('gamification.lb.title', lang)}</h3>
          <div class="inline-flex items-center gap-1.5 bg-slate-50 rounded-full p-1 border border-slate-200">
            <button id="lb-mode-cycle" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-navy text-white border-0 cursor-pointer"
                    data-action="set-leaderboard-mode" data-mode="cycle">{t('gamification.mode.cycle', lang)}</button>
            <button id="lb-mode-lifetime" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-transparent text-slate-500 border-0 cursor-pointer"
                    data-action="set-leaderboard-mode" data-mode="lifetime">{t('gamification.mode.lifetime', lang)}</button>
          </div>
        </div>
        <div class="p-5" id="leaderboard-list">
          <p class="text-slate-400 text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Tribe Ranking -->
    <div id="panel-tribes" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200 flex items-center justify-between gap-3 flex-wrap">
          <h3 class="text-sm font-bold text-navy">{t('gamification.tr.title', lang)}</h3>
          <div class="inline-flex items-center gap-1.5 bg-slate-50 rounded-full p-1 border border-slate-200">
            <button id="tr-mode-cycle" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-navy text-white border-0 cursor-pointer"
                    data-action="set-tribe-mode" data-mode="cycle">{t('gamification.mode.cycle', lang)}</button>
            <button id="tr-mode-lifetime" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-transparent text-slate-500 border-0 cursor-pointer"
                    data-action="set-tribe-mode" data-mode="lifetime">{t('gamification.mode.lifetime', lang)}</button>
          </div>
        </div>
        <p class="px-5 pt-2 text-[.7rem] text-slate-400">{t('gamification.tr.formula', lang)}</p>
        <div class="p-5" id="tribes-ranking-list">
          <p class="text-slate-400 text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Achievements -->
    <div id="panel-achievements" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">{t('gamification.ach.title', lang)}</h3>
        </div>
        <div class="p-5" id="achievements-list">
          <p class="text-slate-400 text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- My Points -->
    <div id="panel-mypoints" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">{t('gamification.mp.title', lang)}</h3>
        </div>
        <div class="p-5" id="mypoints-list">
          <p class="text-slate-400 text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- My Certificates -->
    <div id="panel-mycerts" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">{t('gamification.cert.title', lang)}</h3>
        </div>
        <div class="p-5" id="mycerts-list">
          <p class="text-slate-400 text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Admin: Issue Certificate -->
    <div id="panel-admin-certs" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">{t('gamification.cert.issue', lang)}</h3>
        </div>
        <div class="p-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-[12px] font-semibold text-slate-500">{t('gamification.cert.participant', lang)}</label>
              <select id="cert-member" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white focus:outline-none focus:border-navy">
                <option value="">{t('gamification.cert.select', lang)}</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[12px] font-semibold text-slate-500">{t('gamification.cert.type', lang)}</label>
              <select id="cert-type" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white">
                <option value="participation">{t('gamification.cert.type.participation', lang)}</option>
                <option value="completion">{t('gamification.cert.type.completion', lang)}</option>
                <option value="contribution">{t('gamification.cert.type.contribution', lang)}</option>
                <option value="excellence">{t('gamification.cert.type.excellence', lang)}</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[12px] font-semibold text-slate-500">{t('gamification.cert.cycle', lang)}</label>
              <input type="number" id="cert-cycle" value="3" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
            </div>
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-[12px] font-semibold text-slate-500">{t('gamification.cert.certTitle', lang)}</label>
              <input type="text" id="cert-title" placeholder={t('gamification.cert.titlePlaceholder', lang)}
                     class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
            </div>
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-[12px] font-semibold text-slate-500">{t('gamification.cert.desc', lang)}</label>
              <textarea id="cert-desc" rows="2" placeholder={t('gamification.cert.descPlaceholder', lang)}
                        class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy resize-y"></textarea>
            </div>
          </div>
          <div class="mt-4 flex justify-end">
            <button data-action="issue-certificate" class="px-5 py-2.5 bg-navy text-white rounded-xl font-semibold text-sm cursor-pointer border-0 hover:opacity-90 transition-all">
              {t('gamification.cert.issueBtn', lang)}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ GAM_I18N }}>
  window.__GAMIFICATION_I18N = typeof GAM_I18N !== 'undefined' ? GAM_I18N : {};
</script>
<script>
  import { getMemberRole } from '../lib/routing';
  import { aggregateCredlyByMember } from '../lib/gamification';
  import { buildTrailProgressByMember } from '../lib/trail-progress';

  const I = (typeof window !== 'undefined' && (window as any).__GAMIFICATION_I18N) || {};

  let sb: any = null;
  let MEMBER: any = null;
  let leaderboardData: any[] = [];
  let leaderboardMode: 'cycle' | 'lifetime' = 'cycle';
  let tribeMode: 'cycle' | 'lifetime' = 'cycle';
  let lifetimePointsByMember: Record<string, number> = {};
  let trailProgressByMember = new Map();
  const TRAIL_TOTAL = 8;
  const PANEL_QUERY_TIMEOUT_MS = 15000;

  const CATEGORY_META: Record<string, { icon: string; color: string; bg: string }> = {
    attendance: { icon: '📅', color: '#2563EB', bg: '#EFF6FF' },
    course:     { icon: '🎓', color: '#7C3AED', bg: '#F5F3FF' },
    artifact:   { icon: '📄', color: '#059669', bg: '#ECFDF5' },
    bonus:      { icon: '⭐', color: '#D97706', bg: '#FFFBEB' },
  };

  const TYPE_LABELS: Record<string, string> = {
    participation: I.typeParticipation, completion: I.typeCompletion,
    contribution: I.typeContribution, excellence: I.typeExcellence,
  };

  const TRIBE_NAMES: Record<number, string> = {
    1: I.tribeName1, 2: I.tribeName2, 3: I.tribeName3,
    4: I.tribeName4, 5: I.tribeName5, 6: I.tribeName6,
    7: I.tribeName7, 8: I.tribeName8,
  };
  const TRIBE_COLORS: Record<number, string> = {
