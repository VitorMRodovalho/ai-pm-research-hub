  msgFailUnexpected: t('gamification.msg.failUnexpected', lang),
  msgInvalidSession: t('gamification.msg.invalidSession', lang),
  msgSyncError: t('gamification.msg.syncError', lang),
  msgErrorPrefix: t('gamification.msg.errorPrefix', lang),
  msgLoginAchievements: t('gamification.msg.loginAchievements', lang),
  msgLoginPoints: t('gamification.msg.loginPoints', lang),
  msgLoginCerts: t('gamification.msg.loginCerts', lang),
  lbTitle: t('gamification.lb.title', lang),
  lbEmpty: t('gamification.lb.empty', lang),
  lbEmptySync: t('gamification.lb.emptySync', lang),
