      <td class="px-2 py-1.5 text-center whitespace-nowrap">
        <button class="text-navy hover:underline cursor-pointer bg-transparent border-0 text-[10px] mr-1" data-action="download-cert" data-cert='${JSON.stringify({member_name:c.member_name,type:c.type,title:c.title||'',period_start:c.period_start||'',period_end:c.period_end||'',function_role:c.function_role||'',language:c.language||'pt-BR',verification_code:c.verification_code||'',description:c.description||'',issued_by:c.issued_by||''}).replace(/'/g,"&#39;")}'>📄 PDF</button>
        <a href="/verify/${c.verification_code}" target="_blank" class="text-blue-500 hover:underline text-[10px] no-underline mr-1">🔗</a>
        ${c.status !== 'revoked' ? `<button class="text-navy hover:underline cursor-pointer bg-transparent border-0 text-[10px] mr-1" data-action="edit-cert" data-cert-id="${c.id}" data-cert-title="${(c.title||'').replace(/"/g,'&quot;')}" data-cert-desc="${(c.description||'').replace(/"/g,'&quot;').replace(/\n/g,'&#10;')}" data-cert-period-start="${c.period_start||''}" data-cert-period-end="${c.period_end||''}" data-cert-role="${c.function_role||''}" data-cert-type="${c.type||''}" data-cert-lang="${c.language||'pt-BR'}">✏️</button>` : ''}
        ${c.status === 'draft' ? `<button class="text-emerald-600 hover:underline cursor-pointer bg-transparent border-0 text-[10px] mr-1" data-action="publish-cert" data-cert-id="${c.id}">✅</button>` : ''}
        ${c.status !== 'revoked' ? `<button class="text-red-500 hover:underline cursor-pointer bg-transparent border-0 text-[10px]" data-action="revoke-cert" data-cert-id="${c.id}">🔴</button>` : ''}
      </td>
    </tr>`).join('')}</tbody></table></div>`;
  }
  document.getElementById('manage-certs-filter')?.addEventListener('change', () => loadManageCerts());
  document.getElementById('manage-certs-search')?.addEventListener('input', () => { clearTimeout((window as any).__mcSearch); (window as any).__mcSearch = setTimeout(loadManageCerts, 300); });

  // ── BULK CERTIFICATE ISSUANCE ──
  let bulkMembers: any[] = [];
  let bulkExistingCerts: Set<string> = new Set();

  async function loadBulkMembers() {
    const listEl = document.getElementById('bulk-member-list');
    if (!listEl) return;
    const tribeFilter = (document.getElementById('bulk-tribe-filter') as HTMLSelectElement)?.value || '';
    const bType = (document.getElementById('bulk-type') as HTMLSelectElement)?.value || 'participation';
    const bStart = (document.getElementById('bulk-period-start') as HTMLInputElement)?.value.trim() || '';
    const bEnd = (document.getElementById('bulk-period-end') as HTMLInputElement)?.value.trim() || '';

    // Load members + existing certs in parallel
    const [membersRes, certsRes] = await Promise.all([
      sb.from('public_members').select('id, name, operational_role, tribe_id, current_cycle_active').eq('is_active', true).eq('current_cycle_active', true).order('name'),
      (bStart && bEnd) ? sb.from('certificates').select('member_id').eq('type', bType).eq('period_start', bStart).eq('period_end', bEnd).neq('status', 'revoked') : Promise.resolve({ data: [] }),
    ]);

    bulkMembers = membersRes.data || [];
    bulkExistingCerts = new Set((certsRes.data || []).map((c: any) => c.member_id));

    // Populate tribe filter if empty
    const tribeSelect = document.getElementById('bulk-tribe-filter') as HTMLSelectElement;
    if (tribeSelect && tribeSelect.options.length <= 1) {
      const tribes = [...new Set(bulkMembers.filter((m: any) => m.tribe_id).map((m: any) => m.tribe_id))].sort();
      for (const tid of tribes) { const o = document.createElement('option'); o.value = String(tid); o.textContent = `Tribo ${tid}`; tribeSelect.appendChild(o); }
    }

    const filtered = tribeFilter ? bulkMembers.filter((m: any) => String(m.tribe_id) === tribeFilter) : bulkMembers;

    listEl.innerHTML = filtered.map((m: any) => {
      const hasExisting = bulkExistingCerts.has(m.id);
      return `<label class="flex items-center gap-2 px-3 py-1.5 hover:bg-[var(--surface-hover)] cursor-pointer text-[12px] border-b border-[var(--border-subtle)] last:border-0">
        <input type="checkbox" class="bulk-member-cb accent-navy w-3.5 h-3.5" value="${m.id}" ${hasExisting ? '' : ''}>
        <span class="flex-1 truncate ${hasExisting ? 'text-[var(--text-muted)]' : ''}">${m.name}</span>
        <span class="text-[10px] text-[var(--text-muted)]">${m.operational_role || ''}</span>
        ${hasExisting ? `<span class="text-[9px] px-1 py-0.5 rounded bg-amber-100 text-amber-700">⚠️ ${I.certAlreadyIssued}</span>` : ''}
      </label>`;
    }).join('') || '<div class="p-3 text-center text-xs text-[var(--text-muted)]">Nenhum membro encontrado</div>';
    updateBulkCounter();
  }

  function updateBulkCounter() {
    const checked = document.querySelectorAll('.bulk-member-cb:checked').length;
    const total = document.querySelectorAll('.bulk-member-cb').length;
    const counterEl = document.getElementById('bulk-counter');
    if (counterEl) counterEl.textContent = I.certSelected.replace('{n}', String(checked)).replace('{total}', String(total));
    const btn = document.querySelector('[data-action="bulk-issue"]') as HTMLButtonElement;
    if (btn) {
      btn.disabled = checked === 0;
      btn.textContent = I.certBulkConfirm.replace('{n}', String(checked));
    }
    // Preview
    const preview = document.getElementById('bulk-preview');
    if (preview) {
      if (checked > 0) {
        const bType = (document.getElementById('bulk-type') as HTMLSelectElement)?.value || 'participation';
        const bStart = (document.getElementById('bulk-period-start') as HTMLInputElement)?.value || '?';
        const bEnd = (document.getElementById('bulk-period-end') as HTMLInputElement)?.value || '?';
        preview.textContent = `📦 Emitir ${checked} certificados de ${bType} | Período: ${bStart} → ${bEnd}`;
        preview.classList.remove('hidden');
      } else preview.classList.add('hidden');
    }
  }

  async function bulkIssueCerts() {
    const checkedEls = document.querySelectorAll('.bulk-member-cb:checked') as NodeListOf<HTMLInputElement>;
    const memberIds = Array.from(checkedEls).map(el => el.value);
    if (!memberIds.length) return;

    const bType = (document.getElementById('bulk-type') as HTMLSelectElement)?.value || 'participation';
    const bTitle = (document.getElementById('bulk-title') as HTMLInputElement)?.value.trim();
    const bStart = (document.getElementById('bulk-period-start') as HTMLInputElement)?.value.trim();
    const bEnd = (document.getElementById('bulk-period-end') as HTMLInputElement)?.value.trim();
    const bCycle = parseInt((document.getElementById('bulk-cycle') as HTMLInputElement)?.value) || 3;
    const bLang = (document.querySelector('input[name="bulk-lang"]:checked') as HTMLInputElement)?.value || 'pt-BR';

    if (!bTitle || !bStart || !bEnd) { toast(I.certFillFields, 'error'); return; }

    const btn = document.querySelector('[data-action="bulk-issue"]') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = `⏳ 0/${memberIds.length}...`; }

    try {
      const { data, error } = await sb.rpc('bulk_issue_certificates', {
        p_type: bType, p_title: bTitle, p_period_start: bStart, p_period_end: bEnd,
        p_language: bLang, p_cycle: bCycle, p_member_ids: memberIds,
      });
      if (error) throw error;
      if (data?.error) { toast(data.error, 'error'); return; }
      toast(I.certBulkDone.replace('{n}', String(data.issued || 0)), 'success');
      // Switch to manage tab
      const manageTab = document.querySelector('[data-tab="manage-certs"]') as HTMLElement;
      if (manageTab) switchGamTab(manageTab, 'manage-certs');
      loadManageCerts();
    } catch (e: any) {
      toast(e?.message || 'Error', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = I.certBulkConfirm.replace('{n}', String(memberIds.length)); }
    }
  }

  // Bulk listeners
  document.getElementById('bulk-tribe-filter')?.addEventListener('change', () => loadBulkMembers());
  document.getElementById('bulk-type')?.addEventListener('change', () => loadBulkMembers());
  document.getElementById('bulk-period-start')?.addEventListener('change', () => loadBulkMembers());
  document.getElementById('bulk-period-end')?.addEventListener('change', () => loadBulkMembers());
  document.addEventListener('change', (e) => { if ((e.target as HTMLElement)?.classList?.contains('bulk-member-cb')) updateBulkCounter(); });

  // ── CERTIFICATE PDF (print-based, portrait A4) ──
  (window as any).downloadCertificatePDF = async function(certData: any) {
    // Fetch issuer signature if issued_by is available
    if (certData.issued_by && !certData.signature_url) {
      try {
        const sb = (window as any).navGetSb?.();
        if (sb) {
          const { data: issuer } = await sb.from('public_members').select('signature_url').eq('id', certData.issued_by).single();
          if (issuer?.signature_url) certData.signature_url = issuer.signature_url;
        }
      } catch {}
    }
    const TEMPLATES: Record<string, Record<string, string>> = {
      'pt-BR': { participation: 'Certificamos que', contribution: 'Certificamos que', completion: 'Certificamos que', excellence: 'Certificamos que', bodyParticipation: 'participou como pesquisador(a) voluntário(a) do Núcleo de Estudos e Pesquisa em Inteligência Artificial e Gerenciamento de Projetos, uma iniciativa colaborativa entre capítulos do PMI no Brasil.', bodyContribution: 'contribuiu como voluntário(a) do Núcleo de Estudos e Pesquisa em Inteligência Artificial e Gerenciamento de Projetos, desempenhando a função de {role}.', bodyCompletion: 'concluiu a Trilha PMI de Inteligência Artificial, demonstrando domínio nos fundamentos de IA aplicada ao Gerenciamento de Projetos.', bodyExcellence: 'recebeu reconhecimento de Excelência por contribuição excepcional ao Núcleo de Estudos e Pesquisa em Inteligência Artificial e Gerenciamento de Projetos.', title: 'CERTIFICADO', period: 'Período: {start} a {end}', footer: 'Iniciativa colaborativa entre PMI-GO, PMI-CE, PMI-DF, PMI-MG e PMI-RS', contributions: 'Principais contribuições:', disclaimer: 'PMI®, PMBOK®, PMP® e PMI-CPMAI™ são marcas registradas do PMI, Inc.' },
      'en-US': { participation: 'This certifies that', contribution: 'This certifies that', completion: 'This certifies that', excellence: 'This certifies that', bodyParticipation: 'served as a volunteer researcher at the AI & PM Study and Research Hub, a collaborative initiative among PMI chapters in Brazil.', bodyContribution: 'contributed as a volunteer to the AI & PM Study and Research Hub, serving as {role}.', bodyCompletion: 'completed the PMI AI Trail, demonstrating proficiency in AI fundamentals applied to Project Management.', bodyExcellence: 'received the Excellence Award for outstanding contribution to the AI & PM Study and Research Hub.', title: 'CERTIFICATE', period: 'Period: {start} to {end}', footer: 'A collaborative initiative among PMI-GO, PMI-CE, PMI-DF, PMI-MG and PMI-RS', contributions: 'Key contributions:', disclaimer: 'PMI®, PMBOK®, PMP® and PMI-CPMAI™ are registered marks of PMI, Inc.' },
      'es-LATAM': { participation: 'Se certifica que', contribution: 'Se certifica que', completion: 'Se certifica que', excellence: 'Se certifica que', bodyParticipation: 'participó como investigador(a) voluntario(a) del Hub de Estudios e Investigación en Inteligencia Artificial y Gestión de Proyectos, una iniciativa colaborativa entre capítulos del PMI en Brasil.', bodyContribution: 'contribuyó como voluntario(a) del Hub de Estudios e Investigación en IA y Gestión de Proyectos, desempeñando la función de {role}.', bodyCompletion: 'completó la Ruta PMI de Inteligencia Artificial, demostrando dominio en los fundamentos de IA aplicada a la Gestión de Proyectos.', bodyExcellence: 'recibió el reconocimiento de Excelencia por contribución excepcional al Hub de Estudios e Investigación en IA y Gestión de Proyectos.', title: 'CERTIFICADO', period: 'Período: {start} a {end}', footer: 'Iniciativa colaborativa entre PMI-GO, PMI-CE, PMI-DF, PMI-MG y PMI-RS', contributions: 'Contribuciones principales:', disclaimer: 'PMI®, PMBOK®, PMP® y PMI-CPMAI™ son marcas registradas de PMI, Inc.' },
    };
    const tpl = TEMPLATES[certData.language] || TEMPLATES['pt-BR'];
    const bodyKey = 'body' + (certData.type || 'participation').charAt(0).toUpperCase() + (certData.type || 'participation').slice(1);
    const bodyText = (tpl[bodyKey] || tpl.bodyParticipation).replace('{role}', certData.function_role || '');
    const period = certData.period_start && certData.period_end ? tpl.period.replace('{start}', certData.period_start).replace('{end}', certData.period_end) : '';
    const descSection = certData.description ? `<div style="margin:24px auto;max-width:420px;text-align:left"><div style="font-size:11px;font-weight:bold;color:#555;margin-bottom:6px">${tpl.contributions}</div><div style="font-size:12px;color:#666;line-height:1.6">${certData.description.replace(/\n/g, '<br>')}</div></div>` : '';
    const sigImg = certData.signature_url ? `<img src="${certData.signature_url}" style="max-width:180px;max-height:60px;margin-bottom:4px" crossorigin="anonymous">` : '';
    const w = window.open('', '_blank');
    if (!w) return;
    w.document.write(`<html><head><title>${tpl.title} — ${certData.member_name}</title><style>@page{size:A4 portrait;margin:0}body{margin:0;display:flex;justify-content:center;align-items:center;min-height:100vh;background:#fff;font-family:Georgia,serif}</style></head><body>
      <div style="width:595px;min-height:842px;padding:48px 40px;border:3px double #1a365d;position:relative;background:#fff;box-sizing:border-box">
        <div style="position:absolute;top:14px;left:14px;right:14px;bottom:14px;border:1px solid #cbd5e0;pointer-events:none"></div>
        <div style="text-align:center;margin-bottom:20px"><div style="font-size:13px;color:#666;letter-spacing:2px;text-transform:uppercase">Núcleo de Estudos e Pesquisa em IA & GP</div><div style="font-size:9px;color:#999;margin-top:3px">The AI & PM Study and Research Hub</div></div>
        <div style="text-align:center;font-size:11px;color:#bbb;margin-bottom:20px">─── ✦ ───</div>
        <div style="text-align:center;margin-bottom:28px"><div style="font-size:26px;font-weight:bold;color:#1a365d;letter-spacing:3px">${tpl.title}</div></div>
        <div style="text-align:center;font-size:15px;color:#555;margin-bottom:8px">${tpl[certData.type] || tpl.participation}</div>
        <div style="text-align:center;font-size:22px;font-weight:bold;color:#1a365d;margin-bottom:12px">${certData.member_name}</div>
        <div style="text-align:center;font-size:14px;line-height:1.7;color:#444;max-width:440px;margin:0 auto">${bodyText}</div>
        ${descSection}
        ${period ? `<div style="text-align:center;font-size:12px;color:#666;margin-top:20px">${period}</div>` : ''}
        <div style="text-align:center;margin-top:40px">${sigImg}<div style="border-top:1px solid #333;width:220px;margin:0 auto;padding-top:4px;font-size:11px;color:#333">Vitor Maia Rodovalho, PMP</div><div style="font-size:10px;color:#666">Gestor do Projeto</div></div>
        <div style="text-align:center;margin-top:24px;font-size:10px;color:#999"><div>Código: ${certData.verification_code}</div><div>${new Date().toLocaleDateString()}</div></div>
        <div style="text-align:center;margin-top:16px;font-size:10px;color:#aaa">${tpl.footer}</div>
        <div style="text-align:center;margin-top:8px;font-size:8px;color:#ccc">${tpl.disclaimer}</div>
      </div>
    </body></html>`);
    w.document.close();
    setTimeout(() => w.print(), 500);
  };

  boot();
</script>
