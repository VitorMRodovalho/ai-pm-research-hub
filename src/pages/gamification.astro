---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
---
<BaseLayout title="Gamificação & Certificados — Núcleo IA & GP" activePage="gamification">
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
      <h1 class="text-2xl font-extrabold text-navy">🏆 Gamificação & Certificados</h1>
      <button id="btn-sync" class="hidden px-4 py-2 bg-teal text-white rounded-xl font-semibold text-sm cursor-pointer border-0 hover:opacity-90 transition-all"
              onclick="syncPoints()">
        🔄 Sincronizar Pontos
      </button>
    </div>

    <!-- XP Level Legend -->
    <div class="bg-gradient-to-r from-navy/5 to-orange/5 rounded-xl border border-slate-200 p-5 mb-6">
      <h3 class="text-sm font-bold text-navy mb-3">Níveis de Experiência</h3>
      <div class="flex flex-wrap gap-3">
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">🌱</span>
          <div><strong>Explorador</strong><span class="text-slate-400 ml-1">0–30 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">⚡</span>
          <div><strong>Praticante</strong><span class="text-slate-400 ml-1">31–90 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">🔥</span>
          <div><strong>Especialista</strong><span class="text-slate-400 ml-1">91–200 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">💎</span>
          <div><strong>Mestre</strong><span class="text-slate-400 ml-1">201–400 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-white rounded-lg border border-slate-100">
          <span class="text-lg">🏆</span>
          <div><strong>Lenda</strong><span class="text-slate-400 ml-1">401+ pts</span></div>
        </div>
      </div>
    </div>

    <!-- Points legend -->
    <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
      <h3 class="text-sm font-bold text-navy mb-3">Como ganhar pontos</h3>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 text-[13px]">
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-[11px]">+10</span>
          <span class="text-slate-600">Presença</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center font-bold text-[11px]">+15</span>
          <span class="text-slate-600">Curso</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-[11px]">+30</span>
          <span class="text-slate-600">Artefato</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-pink-50 text-pink-600 flex items-center justify-center font-bold text-[11px]">+50</span>
          <span class="text-slate-600">Perfil 100%</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-amber-50 text-amber-600 flex items-center justify-center font-bold text-[11px]">+10-50</span>
          <span class="text-slate-600">Credly (T1-4)</span>
        </div>
      </div>
      <div class="mt-3 text-[11px] text-slate-500">
        Credly tiers: T1 Master +50, T2 Specialization +25, T3 Trail/Knowledge +15, T4 Other +10.
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-6 flex-wrap">
      <button class="gam-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white"
              data-tab="leaderboard" onclick="switchGamTab(this,'leaderboard')">🏅 Ranking Individual</button>
      <button class="gam-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              data-tab="tribes" onclick="switchGamTab(this,'tribes')">🏷️ Ranking de Tribos</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-achievements" data-tab="achievements" onclick="switchGamTab(this,'achievements')">🎯 Conquistas</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-mypoints" data-tab="mypoints" onclick="switchGamTab(this,'mypoints')">📊 Meus Pontos</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-mycerts" data-tab="mycerts" onclick="switchGamTab(this,'mycerts')">🎓 Certificados</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500"
              id="tab-admin-certs" data-tab="admin-certs" onclick="switchGamTab(this,'admin-certs')">📋 Emitir</button>
    </div>

    <!-- Individual Leaderboard -->
    <div id="panel-leaderboard">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200 flex items-center justify-between">
          <h3 class="text-sm font-bold text-navy">Ranking Individual — Ciclo 3</h3>
        </div>
        <div class="p-5" id="leaderboard-list">
          <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
        </div>
      </div>
    </div>

    <!-- Tribe Ranking -->
    <div id="panel-tribes" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">Ranking de Tribos — Ciclo 3</h3>
          <p class="text-[.7rem] text-slate-400 mt-0.5">Score = (média pontos × 1) + (membros ativos × 10)</p>
        </div>
        <div class="p-5" id="tribes-ranking-list">
          <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
        </div>
      </div>
    </div>

    <!-- Achievements -->
    <div id="panel-achievements" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">Minhas Conquistas</h3>
        </div>
        <div class="p-5" id="achievements-list">
          <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
        </div>
      </div>
    </div>

    <!-- My Points -->
    <div id="panel-mypoints" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">Meu Histórico de Pontos</h3>
        </div>
        <div class="p-5" id="mypoints-list">
          <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
        </div>
      </div>
    </div>

    <!-- My Certificates -->
    <div id="panel-mycerts" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">Meus Certificados</h3>
        </div>
        <div class="p-5" id="mycerts-list">
          <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
        </div>
      </div>
    </div>

    <!-- Admin: Issue Certificate -->
    <div id="panel-admin-certs" class="hidden">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3.5 border-b border-slate-200">
          <h3 class="text-sm font-bold text-navy">Emitir Certificado</h3>
        </div>
        <div class="p-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-[12px] font-semibold text-slate-500">Participante</label>
              <select id="cert-member" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white focus:outline-none focus:border-navy">
                <option value="">Selecione...</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[12px] font-semibold text-slate-500">Tipo</label>
              <select id="cert-type" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white">
                <option value="participation">Participação</option>
                <option value="completion">Conclusão de Trilha</option>
                <option value="contribution">Contribuição</option>
                <option value="excellence">Excelência</option>
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[12px] font-semibold text-slate-500">Ciclo</label>
              <input type="number" id="cert-cycle" value="3" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
            </div>
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-[12px] font-semibold text-slate-500">Título</label>
              <input type="text" id="cert-title" placeholder="Ex: Certificado de Participação — Ciclo 3"
                     class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
            </div>
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-[12px] font-semibold text-slate-500">Descrição</label>
              <textarea id="cert-desc" rows="2" placeholder="Descrição opcional..."
                        class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy resize-y"></textarea>
            </div>
          </div>
          <div class="mt-4 flex justify-end">
            <button onclick="issueCertificate()" class="px-5 py-2.5 bg-navy text-white rounded-xl font-semibold text-sm cursor-pointer border-0 hover:opacity-90 transition-all">
              🎓 Emitir Certificado
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { getMemberRole } from '../lib/routing';
  import { aggregateCredlyByMember } from '../lib/gamification';
  import { buildTrailProgressByMember } from '../lib/trail-progress';

  let sb: any = null;
  let MEMBER: any = null;
  let leaderboardData: any[] = [];
  let trailProgressByMember = new Map();
  const TRAIL_TOTAL = 8;

  const CATEGORY_META: Record<string, { icon: string; color: string; bg: string }> = {
    attendance: { icon: '📅', color: '#2563EB', bg: '#EFF6FF' },
    course:     { icon: '🎓', color: '#7C3AED', bg: '#F5F3FF' },
    artifact:   { icon: '📄', color: '#059669', bg: '#ECFDF5' },
    bonus:      { icon: '⭐', color: '#D97706', bg: '#FFFBEB' },
  };

  const TYPE_LABELS: Record<string, string> = {
    participation: 'Participação', completion: 'Conclusão de Trilha',
    contribution: 'Contribuição', excellence: 'Excelência',
  };

  const TRIBE_NAMES: Record<number, string> = {
    1: 'Radar Tecnológico', 2: 'Agentes Autônomos', 3: 'TMO & PMO do Futuro',
    4: 'Cultura & Change', 5: 'Talentos & Upskilling', 6: 'ROI & Portfólio',
    7: 'Governança & Trustworthy AI', 8: 'Inclusão & Colaboração'
  };
  const TRIBE_COLORS: Record<number, string> = {
    1: '#00799E', 2: '#00799E', 3: '#FF610F', 4: '#FF610F',
    5: '#4F17A8', 6: '#4F17A8', 7: '#10B981', 8: '#10B981'
  };

  function toast(msg: string, type = '') { (window as any).toast?.(msg, type); }

  function setPanelMessage(targetId: string, message: string, kind: 'loading' | 'error' | 'empty' = 'loading') {
    const el = document.getElementById(targetId);
    if (!el) return;
    const color = kind === 'error' ? 'text-crimson' : 'text-slate-400';
    el.innerHTML = `<p class="${color} text-sm text-center py-6">${message}</p>`;
  }

  // ── XP LEVEL SYSTEM ──
  function getLevel(pts: number): { name: string; emoji: string; next: string; ptsToNext: number; pctInLevel: number } {
    const levels = [
      { min: 0,   max: 30,  name: 'Explorador', emoji: '🌱', next: 'Praticante' },
      { min: 31,  max: 90,  name: 'Praticante', emoji: '⚡', next: 'Especialista' },
      { min: 91,  max: 200, name: 'Especialista', emoji: '🔥', next: 'Mestre' },
      { min: 201, max: 400, name: 'Mestre', emoji: '💎', next: 'Lenda' },
      { min: 401, max: 9999, name: 'Lenda', emoji: '🏆', next: '' },
    ];
    const lvl = levels.find(l => pts >= l.min && pts <= l.max) || levels[0];
    const range = lvl.max - lvl.min;
    const progress = pts - lvl.min;
    return {
      name: lvl.name, emoji: lvl.emoji, next: lvl.next,
      ptsToNext: lvl.next ? (lvl.max + 1 - pts) : 0,
      pctInLevel: range > 0 ? Math.min(Math.round((progress / range) * 100), 100) : 100,
    };
  }

  // ── ACHIEVEMENTS (computed from existing data) ──
  const ACHIEVEMENT_DEFS = [
    { id: 'first_points', icon: '🎯', name: 'Primeira Pontuação', desc: 'Ganhou seus primeiros pontos', check: (pts: number, data: any) => pts > 0 },
    { id: 'level_practitioner', icon: '⚡', name: 'Praticante IA', desc: 'Alcançou 31 pontos', check: (pts: number) => pts >= 31 },
    { id: 'level_expert', icon: '🔥', name: 'Especialista IA', desc: 'Alcançou 91 pontos', check: (pts: number) => pts >= 91 },
    { id: 'level_master', icon: '💎', name: 'Mestre IA', desc: 'Alcançou 201 pontos', check: (pts: number) => pts >= 201 },
    { id: 'level_legend', icon: '🏆', name: 'Lenda IA', desc: 'Alcançou 401 pontos', check: (pts: number) => pts >= 401 },
    { id: 'scholar', icon: '📚', name: 'Scholar', desc: 'Completou toda a trilha IA (8/8 cursos)', check: (_: number, d: any) => d.coursesCompleted >= 8 },
    { id: 'publisher', icon: '📝', name: 'Publisher', desc: 'Publicou seu primeiro artefato', check: (_: number, d: any) => d.artifactsPublished > 0 },
    { id: 'consistent', icon: '🔥', name: 'Consistente', desc: 'Participou de 5+ eventos', check: (_: number, d: any) => d.attendanceCount >= 5 },
    { id: 'engaged', icon: '💪', name: 'Engajado', desc: 'Participou de 10+ eventos', check: (_: number, d: any) => d.attendanceCount >= 10 },
    { id: 'veteran', icon: '🌟', name: 'Veterano', desc: 'Participou em 2+ ciclos do Núcleo', check: (_: number, d: any) => d.cycleCount >= 2 },
    { id: 'profile_complete', icon: '✨', name: 'Perfil Completo', desc: 'Preencheu 100% do perfil', check: (_: number, d: any) => d.profileComplete },
  ];

  // ── TABS ──
  (window as any).switchGamTab = (el: HTMLElement, tab: string) => {
    document.querySelectorAll('.gam-tab').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
    });
    el.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    ['leaderboard', 'tribes', 'achievements', 'mypoints', 'mycerts', 'admin-certs'].forEach(p => {
      document.getElementById(`panel-${p}`)?.classList.toggle('hidden', p !== tab);
    });
    if (tab === 'leaderboard') loadLeaderboard();
    if (tab === 'tribes') loadTribeRanking();
    if (tab === 'achievements') loadAchievements();
    if (tab === 'mypoints') loadMyPoints();
    if (tab === 'mycerts') loadMyCertificates();
  };

  // ── INDIVIDUAL LEADERBOARD (with XP levels) ──
  async function loadLeaderboard() {
    const el = document.getElementById('leaderboard-list')!;
    setPanelMessage('leaderboard-list', 'Carregando...', 'loading');
    try {
      const { data, error } = await sb.from('gamification_leaderboard').select('*');
      if (error) throw error;
      const { data: credlyRows, error: credlyError } = await sb.from('gamification_points')
        .select('member_id, points, reason')
        .like('reason', 'Credly:%');
      if (credlyError) throw credlyError;
      const { data: courseRows, error: courseRowsError } = await sb.from('course_progress')
        .select('member_id, course_id, status');
      if (courseRowsError) throw courseRowsError;

      leaderboardData = data || [];
      const credlyByMember = aggregateCredlyByMember(credlyRows || []);
      trailProgressByMember = buildTrailProgressByMember(courseRows || [], TRAIL_TOTAL);
      if (!data?.length) {
        setPanelMessage('leaderboard-list', 'Nenhum ponto registrado. Clique em "Sincronizar Pontos" para calcular.', 'empty');
        return;
      }

      const maxPts = Math.max(...data.map((m: any) => m.total_points), 1);

      el.innerHTML = data.map((m: any, i: number) => {
      const initials = m.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
      const photo = m.photo_url
        ? `<img src="${m.photo_url}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="">`
        : `<div class="w-10 h-10 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.7rem] flex-shrink-0">${initials}</div>`;

      const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
      const rank = i + 1;
      const pct = (m.total_points / maxPts * 100).toFixed(0);
      const level = getLevel(m.total_points);
      const isMe = MEMBER && m.member_id === MEMBER.id;
      const credly = credlyByMember[m.member_id] || { total: 0, badges: 0, t1: 0, t2: 0, t3: 0, t4: 0 };
      const trail = trailProgressByMember.get(m.member_id) || { completed: 0, inProgress: 0, pct: 0 };

      const breakdown = [
        m.attendance_points > 0 ? `📅 ${m.attendance_points}` : '',
        `📚 ${trail.completed}/${TRAIL_TOTAL}`,
        trail.inProgress > 0 ? `⏳ ${trail.inProgress} em andamento` : '',
        m.artifact_points > 0 ? `📄 ${m.artifact_points}` : '',
        m.bonus_points > 0 ? `⭐ ${m.bonus_points}` : '',
        credly.total > 0 ? `🏅 ${credly.total}` : '',
      ].filter(Boolean).join(' · ');

      const credlyTierTags = credly.total > 0
        ? [
          credly.t1 > 0 ? `T1×${credly.t1}` : '',
          credly.t2 > 0 ? `T2×${credly.t2}` : '',
          credly.t3 > 0 ? `T3×${credly.t3}` : '',
          credly.t4 > 0 ? `T4×${credly.t4}` : '',
        ].filter(Boolean).map((x: string) => `<span class="text-[.55rem] px-1 py-0.5 rounded bg-amber-50 text-amber-700">${x}</span>`).join(' ')
        : '';

      return `
      <div class="flex items-center gap-3 py-3 border-b border-slate-100 last:border-b-0 ${i < 3 ? 'bg-amber-50/30' : ''} ${isMe ? 'ring-2 ring-orange/30 rounded-lg' : ''}">
        <div class="w-8 text-center font-bold text-[13px] text-slate-400 flex-shrink-0">${medal || rank}</div>
        ${photo}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-1.5">
            <span class="text-[13px] font-semibold truncate">${m.name.split(' ').slice(0, 3).join(' ')}</span>
            <span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-slate-100">${level.emoji} ${level.name}</span>
            ${isMe ? '<span class="text-[.55rem] font-bold px-1 py-0.5 rounded bg-orange/10 text-orange">VOCÊ</span>' : ''}
          </div>
          <div class="text-[11px] text-slate-400">${m.chapter || ''} ${breakdown ? '· ' + breakdown : ''}</div>
          ${credlyTierTags ? `<div class="mt-1 flex gap-1 flex-wrap">${credlyTierTags}</div>` : ''}
          <div class="h-1.5 bg-slate-100 rounded-full mt-1 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%;background:${m.total_points > 0 ? '#FF610F' : '#E2E8F0'}"></div>
          </div>
        </div>
        <div class="text-right flex-shrink-0">
          <div class="text-lg font-extrabold text-navy">${m.total_points}</div>
          <div class="text-[10px] text-slate-400">pts</div>
        </div>
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadLeaderboard failed', e);
      setPanelMessage('leaderboard-list', `Erro ao carregar ranking: ${e?.message || 'falha inesperada'}`, 'error');
    }
  }

  // ── TRIBE RANKING ──
  async function loadTribeRanking() {
    setPanelMessage('tribes-ranking-list', 'Carregando...', 'loading');
    try {
      // Get tribe selections + leaderboard data
      const { data: selections, error: selectionsError } = await sb.from('tribe_selections').select('tribe_id, member_id');
      if (selectionsError) throw selectionsError;
      const { data: leaders, error: leadersError } = await sb.from('members')
        .select('id, tribe_id')
        .eq('operational_role', 'tribe_leader');
      if (leadersError) throw leadersError;

      if (!leaderboardData.length) {
        const { data, error } = await sb.from('gamification_leaderboard').select('*');
        if (error) throw error;
        leaderboardData = data || [];
      }

    // Build tribe map: member_id → tribe_id
    const memberTribe: Record<string, number> = {};
    (selections || []).forEach((s: any) => { memberTribe[s.member_id] = s.tribe_id; });
    (leaders || []).forEach((l: any) => { if (l.tribe_id) memberTribe[l.id] = l.tribe_id; });

    // Aggregate by tribe
    const tribeStats: Record<number, { points: number; members: number; names: string[] }> = {};
    for (let t = 1; t <= 8; t++) tribeStats[t] = { points: 0, members: 0, names: [] };

    leaderboardData.forEach((m: any) => {
      const tid = memberTribe[m.member_id];
      if (tid && tribeStats[tid]) {
        tribeStats[tid].points += m.total_points;
        tribeStats[tid].members++;
        tribeStats[tid].names.push(m.name.split(' ')[0]);
      }
    });

    // Score = avg points + (members × 10)
    const ranked = Object.entries(tribeStats)
      .map(([tid, s]) => {
        const t = Number(tid);
        const avg = s.members > 0 ? Math.round(s.points / s.members) : 0;
        const score = avg + (s.members * 10);
        return { tid: t, name: TRIBE_NAMES[t], color: TRIBE_COLORS[t], avg, total: s.points, members: s.members, score, names: s.names };
      })
      .filter(t => t.members > 0)
      .sort((a, b) => b.score - a.score);

      const el = document.getElementById('tribes-ranking-list')!;
      if (!ranked.length) {
        setPanelMessage('tribes-ranking-list', 'Nenhum dado de tribo disponível.', 'empty');
        return;
      }

    const maxScore = Math.max(...ranked.map(t => t.score), 1);

      el.innerHTML = ranked.map((t, i) => {
      const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
      const pct = Math.round((t.score / maxScore) * 100);
      return `
      <div class="py-4 border-b border-slate-100 last:border-b-0 ${i < 3 ? 'bg-amber-50/30 rounded-lg px-3 mb-2' : ''}">
        <div class="flex items-center gap-3">
          <div class="w-8 text-center font-bold text-[13px] text-slate-400 flex-shrink-0">${medal || (i + 1)}</div>
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style="background:${t.color}">
            T${String(t.tid).padStart(2, '0')}
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-[13px] font-bold">${t.name}</div>
            <div class="text-[11px] text-slate-400">${t.members} membros · Média: ${t.avg} pts · Total: ${t.total} pts</div>
            <div class="h-1.5 bg-slate-100 rounded-full mt-1.5 overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%;background:${t.color}"></div>
            </div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-xl font-extrabold text-navy">${t.score}</div>
            <div class="text-[10px] text-slate-400">score</div>
          </div>
        </div>
        <div class="ml-[76px] mt-2 flex flex-wrap gap-1">
          ${t.names.map((n: string) => `<span class="text-[.6rem] px-1.5 py-0.5 rounded bg-slate-100 text-slate-500">${n}</span>`).join('')}
        </div>
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadTribeRanking failed', e);
      setPanelMessage('tribes-ranking-list', `Erro ao carregar ranking de tribos: ${e?.message || 'falha inesperada'}`, 'error');
    }
  }

  // ── ACHIEVEMENTS ──
  async function loadAchievements() {
    const el = document.getElementById('achievements-list')!;
    if (!MEMBER) {
      setPanelMessage('achievements-list', 'Faça login para ver suas conquistas.', 'empty');
      return;
    }
    setPanelMessage('achievements-list', 'Carregando...', 'loading');

    try {
      // Gather data for achievement checks
      const { count: attendanceCount, error: attendanceError } = await sb.from('attendance')
        .select('*', { count: 'exact', head: true })
        .eq('member_id', MEMBER.id);
      if (attendanceError) throw attendanceError;

      const { data: courses, error: coursesError } = await sb.from('course_progress')
        .select('status')
        .eq('member_id', MEMBER.id);
      if (coursesError) throw coursesError;

      const { data: artifacts, error: artifactsError } = await sb.from('artifacts')
        .select('status')
        .eq('author_id', MEMBER.id);
      if (artifactsError) throw artifactsError;

      const { data: cycles, error: cyclesError } = await sb.from('member_cycle_history')
        .select('cycle_code')
        .eq('member_id', MEMBER.id);
      if (cyclesError) throw cyclesError;

    const myPoints = leaderboardData.find((m: any) => m.member_id === MEMBER.id)?.total_points || 0;
    const coursesCompleted = (courses || []).filter((c: any) => c.status === 'completed').length;
    const artifactsPublished = (artifacts || []).filter((a: any) => a.status === 'published').length;
    const cycleCount = (cycles || []).length;

    // Check profile completeness (simplified)
    const profileComplete = !!(MEMBER.photo_url && MEMBER.pmi_id && MEMBER.linkedin_url && MEMBER.phone && MEMBER.credly_url);

    const checkData = { attendanceCount: attendanceCount || 0, coursesCompleted, artifactsPublished, cycleCount, profileComplete };

    let earned = 0;
    const total = ACHIEVEMENT_DEFS.length;

      el.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        ${ACHIEVEMENT_DEFS.map(a => {
          const unlocked = a.check(myPoints, checkData);
          if (unlocked) earned++;
          return `
          <div class="flex items-center gap-3 p-3 rounded-xl border ${unlocked ? 'border-amber-200 bg-amber-50/50' : 'border-slate-100 bg-slate-50/50 opacity-50'}">
            <div class="text-2xl flex-shrink-0">${unlocked ? a.icon : '🔒'}</div>
            <div class="flex-1 min-w-0">
              <div class="text-[.78rem] font-bold ${unlocked ? 'text-navy' : 'text-slate-400'}">${a.name}</div>
              <div class="text-[.65rem] text-slate-400">${a.desc}</div>
            </div>
            ${unlocked ? '<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-700 flex-shrink-0">✓</span>' : ''}
          </div>`;
        }).join('')}
      </div>
      <div class="mt-4 text-center text-[.78rem] text-slate-500">
        ${earned} de ${total} conquistas desbloqueadas
      </div>`;
    } catch (e: any) {
      console.error('gamification.loadAchievements failed', e);
      setPanelMessage('achievements-list', `Erro ao carregar conquistas: ${e?.message || 'falha inesperada'}`, 'error');
    }
  }

  // ── MY POINTS ──
  async function loadMyPoints() {
    if (!MEMBER) {
      setPanelMessage('mypoints-list', 'Faça login para ver seus pontos.', 'empty');
      return;
    }
    setPanelMessage('mypoints-list', 'Carregando...', 'loading');
    const { data, error } = await sb.from('gamification_points')
      .select('*')
      .eq('member_id', MEMBER.id)
      .order('created_at', { ascending: false });
    if (error) {
      console.error('gamification.loadMyPoints failed', error);
      setPanelMessage('mypoints-list', `Erro ao carregar seus pontos: ${error.message}`, 'error');
      return;
    }

    const el = document.getElementById('mypoints-list')!;
    if (!data?.length) {
      setPanelMessage('mypoints-list', 'Nenhum ponto registrado ainda.', 'empty');
      return;
    }

    const total = data.reduce((s: number, p: any) => s + p.points, 0);
    const level = getLevel(total);
    const myCredly = aggregateCredlyByMember(
      (data || []).filter((p: any) => String(p.reason || '').startsWith('Credly:'))
    )[MEMBER.id] || { total: 0, badges: 0, t1: 0, t2: 0, t3: 0, t4: 0 };

    el.innerHTML = `
      <div class="text-center mb-6 py-5 bg-gradient-to-br from-navy/5 to-orange/5 rounded-xl">
        <div class="text-3xl mb-1">${level.emoji}</div>
        <div class="text-3xl font-extrabold text-navy">${total}</div>
        <div class="text-sm text-slate-500">pontos · <strong>${level.name}</strong></div>
        ${level.next ? `<div class="text-[.7rem] text-slate-400 mt-1">Faltam ${level.ptsToNext} pts para ${level.next}</div>` : '<div class="text-[.7rem] text-amber-600 mt-1 font-bold">Nível máximo alcançado!</div>'}
        <div class="w-40 h-2 bg-slate-200 rounded-full mx-auto mt-2 overflow-hidden">
          <div class="h-full bg-orange rounded-full" style="width:${level.pctInLevel}%"></div>
        </div>
      </div>
      ${myCredly.total > 0 ? `
      <div class="mb-5 p-3 rounded-xl border border-amber-200 bg-amber-50/50">
        <div class="text-[.78rem] font-bold text-navy mb-2">🏅 Credly por Tier</div>
        <div class="flex flex-wrap gap-2 text-[.7rem]">
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T1 Master: ${myCredly.t1}</span>
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T2 Specialization: ${myCredly.t2}</span>
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T3 Trail/Knowledge: ${myCredly.t3}</span>
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T4 Other: ${myCredly.t4}</span>
          <span class="px-2 py-1 rounded bg-navy text-white font-semibold">Total Credly: ${myCredly.total} pts</span>
        </div>
      </div>` : ''}
    ` + data.map((p: any) => {
      const cat = CATEGORY_META[p.category] || CATEGORY_META.bonus;
      const date = new Date(p.created_at).toLocaleDateString('pt-BR', { year: 'numeric', month: 'short', day: '2-digit' });
      return `
      <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background:${cat.bg}">${cat.icon}</div>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-medium truncate">${p.reason}</div>
          <div class="text-[11px] text-slate-400">${date}</div>
        </div>
        <div class="font-bold text-sm" style="color:${cat.color}">+${p.points}</div>
      </div>`;
    }).join('');
  }

  // ── MY CERTIFICATES ──
  async function loadMyCertificates() {
    if (!MEMBER) {
      setPanelMessage('mycerts-list', 'Faça login para ver seus certificados.', 'empty');
      return;
    }
    setPanelMessage('mycerts-list', 'Carregando...', 'loading');
    const { data, error } = await sb.from('certificates')
      .select('*')
      .eq('member_id', MEMBER.id)
      .order('issued_at', { ascending: false });
    if (error) {
      console.error('gamification.loadMyCertificates failed', error);
      setPanelMessage('mycerts-list', `Erro ao carregar certificados: ${error.message}`, 'error');
      return;
    }

    const el = document.getElementById('mycerts-list')!;
    if (!data?.length) {
      setPanelMessage('mycerts-list', 'Nenhum certificado emitido ainda. Continue participando!', 'empty');
      return;
    }

    el.innerHTML = data.map((c: any) => {
      const date = new Date(c.issued_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
      return `
      <div class="flex items-center gap-3 py-3 border-b border-slate-100 last:border-b-0">
        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center text-xl flex-shrink-0">🎓</div>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-semibold">${c.title}</div>
          <div class="text-[11px] text-slate-400">${TYPE_LABELS[c.type] || c.type} · ${date}</div>
          ${c.description ? `<div class="text-[12px] text-slate-500 mt-0.5">${c.description}</div>` : ''}
          <div class="text-[10px] text-slate-400 mt-0.5 font-mono">Código: ${c.verification_code}</div>
        </div>
        ${c.pdf_url ? `<a href="${c.pdf_url}" target="_blank" class="px-3 py-1.5 bg-navy text-white rounded-lg text-[12px] font-semibold no-underline hover:opacity-90">📥 PDF</a>` : ''}
      </div>`;
    }).join('');
  }

  // ── SYNC POINTS (admin) ──
  (window as any).syncPoints = async () => {
    const { data } = await sb.rpc('sync_attendance_points');
    if (data?.success) {
      toast(`${data.points_created} pontos sincronizados ✅`, 'success');
      loadLeaderboard();
    } else {
      toast(data?.error || 'Erro ao sincronizar', 'error');
    }
  };

  // ── ISSUE CERTIFICATE (admin) ──
  (window as any).issueCertificate = async () => {
    const memberId = (document.getElementById('cert-member') as HTMLSelectElement).value;
    const type = (document.getElementById('cert-type') as HTMLSelectElement).value;
    const title = (document.getElementById('cert-title') as HTMLInputElement).value.trim();
    const desc = (document.getElementById('cert-desc') as HTMLTextAreaElement).value.trim() || null;
    const cycle = parseInt((document.getElementById('cert-cycle') as HTMLInputElement).value);

    if (!memberId || !title) { toast('Selecione participante e preencha o título', 'error'); return; }

    const { error } = await sb.from('certificates').insert({
      member_id: memberId, type, title, description: desc, cycle, issued_by: MEMBER.id,
    });

    if (error) { toast('Erro: ' + error.message, 'error'); return; }
    toast('Certificado emitido ✅', 'success');
    (document.getElementById('cert-title') as HTMLInputElement).value = '';
    (document.getElementById('cert-desc') as HTMLTextAreaElement).value = '';
  };

  // ── LOAD MEMBERS FOR CERT DROPDOWN ──
  async function loadMembersDropdown() {
    const { data } = await sb.from('members')
      .select('id, name')
      .eq('current_cycle_active', true)
      .order('name');
    const sel = document.getElementById('cert-member') as HTMLSelectElement;
    if (sel && data) {
      sel.innerHTML = '<option value="">Selecione...</option>' +
        data.map((m: any) => `<option value="${m.id}">${m.name}</option>`).join('');
    }
  }

  // ── BOOT ──
  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest') {
        MEMBER = e.detail;
        setupUI();
      }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') {
      MEMBER = m;
      setupUI();
      return;
    }

    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && getMemberRole(data) !== 'guest') {
        MEMBER = data;
        setupUI();
        return;
      }
    }

    // Not logged in — show leaderboard only
    loadLeaderboard();
  }

  function setupUI() {
    const isAdmin = MEMBER.is_superadmin;
    document.getElementById('tab-achievements')?.classList.remove('hidden');
    document.getElementById('tab-mypoints')?.classList.remove('hidden');
    document.getElementById('tab-mycerts')?.classList.remove('hidden');
    if (isAdmin) {
      document.getElementById('btn-sync')?.classList.remove('hidden');
      document.getElementById('tab-admin-certs')?.classList.remove('hidden');
    }
    loadLeaderboard();
    loadMembersDropdown();
  }

  boot();
</script>
