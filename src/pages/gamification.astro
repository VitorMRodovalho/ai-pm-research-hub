---
<BaseLayout title={t('gamification.titleFull', lang)} activePage="gamification">
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
      <h1 class="text-2xl font-extrabold text-navy">{t('gamification.headingFull', lang)}</h1>
      <button id="btn-sync" class="hidden px-4 py-2 bg-teal text-white rounded-xl font-semibold text-sm cursor-pointer border-0 hover:opacity-90 transition-all"
              data-action="sync-points">
        {t('gamification.syncCredlyBtn', lang)}
      </button>
    </div>

    <!-- Guest banner (authenticated but not registered) -->
    <div id="guest-banner" class="hidden mb-6">
      <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-3 flex items-center gap-3">
        <span class="text-amber-600 text-lg flex-shrink-0">ℹ️</span>
        <p class="text-amber-800 text-[.78rem] font-medium flex-1">
          {t('guest.limitedAccess', lang)}
          <a href={`mailto:${t('guest.contactEmail', lang)}`} class="text-amber-800 font-semibold underline ml-1">{t('guest.contactEmail', lang)}</a>
        </p>
      </div>
    </div>

    <!-- XP Level Legend -->
    <div class="bg-gradient-to-r from-navy/5 to-orange/5 rounded-xl border border-[var(--border-default)] p-5 mb-6">
      <h3 class="text-sm font-bold text-navy mb-3">{t('gamification.levels.title', lang)}</h3>
      <div class="flex flex-wrap gap-3">
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-[var(--surface-card)] rounded-lg border border-[var(--border-subtle)]">
          <span class="text-lg">🌱</span>
          <div><strong>{t('gamification.levels.explorer', lang)}</strong><span class="text-[var(--text-muted)] ml-1">0–30 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-[var(--surface-card)] rounded-lg border border-[var(--border-subtle)]">
          <span class="text-lg">⚡</span>
          <div><strong>{t('gamification.levels.practitioner', lang)}</strong><span class="text-[var(--text-muted)] ml-1">31–90 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-[var(--surface-card)] rounded-lg border border-[var(--border-subtle)]">
          <span class="text-lg">🔥</span>
          <div><strong>{t('gamification.levels.expert', lang)}</strong><span class="text-[var(--text-muted)] ml-1">91–200 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-[var(--surface-card)] rounded-lg border border-[var(--border-subtle)]">
          <span class="text-lg">💎</span>
          <div><strong>{t('gamification.levels.master', lang)}</strong><span class="text-[var(--text-muted)] ml-1">201–400 pts</span></div>
        </div>
        <div class="flex items-center gap-1.5 text-[.72rem] px-3 py-1.5 bg-[var(--surface-card)] rounded-lg border border-[var(--border-subtle)]">
          <span class="text-lg">🏆</span>
          <div><strong>{t('gamification.levels.legend', lang)}</strong><span class="text-[var(--text-muted)] ml-1">401+ pts</span></div>
        </div>
      </div>
    </div>

    <!-- Points legend -->
    <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-6">
      <h3 class="text-sm font-bold text-navy mb-3 flex items-center gap-1.5">
        {t('gamification.pointsLegend.title', lang)}
        <ScoringInfoPopover client:load i18n={SCORING_I18N} />
      </h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-3 text-[13px]">
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center font-bold text-[11px]">+10</span>
          <span class="text-[var(--text-secondary)]">{t('gamification.pointsLegend.attendance', lang)}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center font-bold text-[11px]">+20</span>
          <span class="text-[var(--text-secondary)]">Trilha PMI</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-600 flex items-center justify-center font-bold text-[11px]">+20</span>
          <span class="text-[var(--text-secondary)]">AI & PM</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-amber-50 text-amber-700 flex items-center justify-center font-bold text-[11px]">30-50</span>
          <span class="text-[var(--text-secondary)]">Certificações</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-cyan-50 text-cyan-600 flex items-center justify-center font-bold text-[11px]">+25</span>
          <span class="text-[var(--text-secondary)]">Especialização</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-600 flex items-center justify-center font-bold text-[11px]">+30</span>
          <span class="text-[var(--text-secondary)]">{t('gamification.pointsLegend.artifact', lang)}</span>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-6 flex-wrap">
      <button class="gam-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white"
              data-tab="leaderboard" data-action="switch-tab">{t('gamification.tab.individual', lang)}</button>
      <button class="gam-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              data-tab="tribes" data-action="switch-tab">{t('gamification.tab.tribes', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-achievements" data-tab="achievements" data-action="switch-tab">{t('gamification.tab.achievements', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-mypoints" data-tab="mypoints" data-action="switch-tab">{t('gamification.tab.myPoints', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-mycerts" data-tab="mycerts" data-action="switch-tab">{t('gamification.tab.certs', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-admin-certs" data-tab="admin-certs" data-action="switch-tab">{t('gamification.tab.issue', lang)}</button>
      <button class="gam-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-manage-certs" data-tab="manage-certs" data-action="switch-tab">{t('gamification.cert.manage', lang)}</button>
    </div>

    <!-- Trail Clarity (logged user) -->
    <div id="trail-clarity-card" class="hidden mb-6">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5">
        <div id="trail-clarity-content">
          <p class="text-[var(--text-muted)] text-sm text-center py-2">{t('gamification.trail.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Individual Leaderboard -->
    <div id="panel-leaderboard">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)] flex items-center justify-between">
          <h3 class="text-sm font-bold text-navy">{t('gamification.lb.title', lang)}</h3>
          <div class="inline-flex items-center gap-1.5 bg-[var(--surface-base)] rounded-full p-1 border border-[var(--border-default)]">
            <button id="lb-mode-cycle" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-transparent text-[var(--text-secondary)] border-0 cursor-pointer"
                    data-action="set-leaderboard-mode" data-mode="cycle">{t('gamification.mode.cycle', lang)}</button>
            <button id="lb-mode-lifetime" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-navy text-white border-0 cursor-pointer"
                    data-action="set-leaderboard-mode" data-mode="lifetime">{t('gamification.mode.lifetime', lang)}</button>
          </div>
        </div>
        <div class="p-5" id="leaderboard-list">
          <p class="text-[var(--text-muted)] text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Tribe Ranking -->
    <div id="panel-tribes" class="hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)] flex items-center justify-between gap-3 flex-wrap">
          <h3 class="text-sm font-bold text-navy">{t('gamification.tr.title', lang)}</h3>
          <div class="inline-flex items-center gap-1.5 bg-[var(--surface-base)] rounded-full p-1 border border-[var(--border-default)]">
            <button id="tr-mode-cycle" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-navy text-white border-0 cursor-pointer"
                    data-action="set-tribe-mode" data-mode="cycle">{t('gamification.mode.cycle', lang)}</button>
            <button id="tr-mode-lifetime" class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-transparent text-[var(--text-secondary)] border-0 cursor-pointer"
                    data-action="set-tribe-mode" data-mode="lifetime">{t('gamification.mode.lifetime', lang)}</button>
          </div>
        </div>
        <p class="px-5 pt-2 text-[.7rem] text-[var(--text-muted)]">{t('gamification.tr.formula', lang)}</p>
        <div class="p-5" id="tribes-ranking-list">
          <p class="text-[var(--text-muted)] text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- Achievements -->
    <div id="panel-achievements" class="hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)]">
          <h3 class="text-sm font-bold text-navy">{t('gamification.ach.title', lang)}</h3>
        </div>
        <div class="p-5" id="achievements-list">
          <p class="text-[var(--text-muted)] text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- My Points -->
    <div id="panel-mypoints" class="hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)]">
          <h3 class="text-sm font-bold text-navy">{t('gamification.mp.title', lang)}</h3>
        </div>
        <div class="p-5" id="mypoints-list">
          <p class="text-[var(--text-muted)] text-sm text-center py-6">{t('gamification.loading', lang)}</p>
        </div>
      </div>
    </div>

    <!-- My Certificates -->
    <div id="panel-mycerts" class="hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
