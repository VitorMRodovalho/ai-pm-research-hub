    const STATUS_BADGE: Record<string, string> = { issued: 'bg-emerald-100 text-emerald-700', draft: 'bg-amber-100 text-amber-700', revoked: 'bg-red-100 text-red-700' };
    tableEl.innerHTML = `<div class="overflow-x-auto"><table class="w-full text-[11px]"><thead><tr class="bg-[var(--surface-section-cool)]">
      <th class="px-2 py-2 text-left">Participante</th><th class="px-2 py-2">Tipo</th><th class="px-2 py-2">Título</th><th class="px-2 py-2">Período</th><th class="px-2 py-2">Código</th><th class="px-2 py-2">Status</th><th class="px-2 py-2">Ações</th>
    </tr></thead><tbody>${certs.map((c: any) => `<tr class="border-t border-[var(--border-subtle)] hover:bg-[var(--surface-hover)] ${c.status === 'revoked' ? 'opacity-50 line-through' : ''}">
      <td class="px-2 py-1.5 font-medium">${c.member_name}</td>
      <td class="px-2 py-1.5 text-center">${c.type}</td>
      <td class="px-2 py-1.5">${c.title || ''}</td>
      <td class="px-2 py-1.5 text-center">${c.period_start || ''} → ${c.period_end || ''}</td>
      <td class="px-2 py-1.5 text-center font-mono text-[9px]">${c.verification_code || ''}</td>
