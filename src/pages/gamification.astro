  // ── BOOT ──
  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }
    await loadRuntimeTribes();

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest') {
        MEMBER = e.detail;
        setupUI();
      }
    }) as EventListener);

    window.addEventListener('nav:guest-with-session', (() => {
      document.getElementById('guest-banner')?.classList.remove('hidden');
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') {
      MEMBER = m;
      setupUI();
      return;
    }

    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && getMemberRole(data) !== 'guest') {
        MEMBER = data;
        setupUI();
        return;
      }
      document.getElementById('guest-banner')?.classList.remove('hidden');
    }

    // Not logged in or guest — show leaderboard only
    loadLeaderboard();
  }

  function setupUI() {
    const canSync = hasPermission(MEMBER, 'gamification.sync');
    document.getElementById('trail-clarity-card')?.classList.remove('hidden');
    document.getElementById('tab-achievements')?.classList.remove('hidden');
    document.getElementById('tab-mypoints')?.classList.remove('hidden');
    document.getElementById('tab-mycerts')?.classList.remove('hidden');
    if (canSync) {
      document.getElementById('btn-sync')?.classList.remove('hidden');
      document.getElementById('tab-admin-certs')?.classList.remove('hidden');
      document.getElementById('tab-manage-certs')?.classList.remove('hidden');
    }
    loadLeaderboard();
    loadMyTrailClarity();
    loadMembersDropdown();
    try { if ((window as any).posthog) (window as any).posthog.capture('gamification_viewed', {}); } catch {}
  }

  // ── CENTRALIZED EVENT DELEGATION ──
  document.addEventListener('click', async (e: Event) => {
    const el = e.target as HTMLElement;
    if (!el?.closest) return;
    const target = el.closest<HTMLElement>('[data-action]');
    if (!target) return;

    switch (target.dataset.action) {
      case 'sync-points':
        syncPoints();
        break;
      case 'switch-tab': {
        const tab = target.dataset.tab;
        if (tab) switchGamTab(target, tab);
        break;
      }
      case 'set-leaderboard-mode': {
        const mode = target.dataset.mode as 'cycle' | 'lifetime';
        if (mode) setLeaderboardMode(mode);
        break;
      }
      case 'set-tribe-mode': {
        const mode = target.dataset.mode as 'cycle' | 'lifetime';
        if (mode) setTribeMode(mode);
        break;
      }
      case 'issue-certificate':
        issueCertificate();
        break;
      case 'publish-cert': {
        const id = target.dataset.certId;
        await sb.rpc('update_certificate', { p_cert_id: id, p_updates: { status: 'issued' } });
        toast(I.certIssued || 'Publicado!', 'success');
        loadManageCerts();
        break;
      }
      case 'download-cert': {
        try { const d = JSON.parse(target.dataset.cert || '{}'); await (window as any).downloadCertificatePDF(d); } catch {}
        break;
      }
      case 'revoke-cert': {
        const id = target.dataset.certId;
        const reason = prompt(I.certRevokeReason || 'Motivo da revogação:');
        if (!reason) return;
        await sb.rpc('revoke_certificate', { p_cert_id: id, p_reason: reason });
        toast('Revogado', 'success');
        loadManageCerts();
        break;
      }
      case 'edit-cert': {
        enterEditMode(target.dataset.certId || '', {
          type: target.dataset.certType || '',
          title: target.dataset.certTitle || '',
          desc: (target.dataset.certDesc || '').replace(/&#10;/g, '\n'),
          periodStart: target.dataset.certPeriodStart || '',
          periodEnd: target.dataset.certPeriodEnd || '',
          role: target.dataset.certRole || '',
          lang: target.dataset.certLang || 'pt-BR',
        });
        break;
      }
      case 'toggle-bulk-panel': {
        const body = document.getElementById('bulk-cert-body');
        const arrow = document.getElementById('bulk-panel-arrow');
        if (body) {
          const hidden = body.classList.toggle('hidden');
          if (arrow) arrow.textContent = hidden ? '▼' : '▲';
          if (!hidden) loadBulkMembers();
        }
        break;
      }
      case 'bulk-select-all': {
        const cbs = document.querySelectorAll('.bulk-member-cb') as NodeListOf<HTMLInputElement>;
        const allChecked = Array.from(cbs).every(cb => cb.checked);
        cbs.forEach(cb => { cb.checked = !allChecked; });
        updateBulkCounter();
        break;
      }
      case 'bulk-issue':
        bulkIssueCerts();
        break;
    }
  });

  // ── MANAGE CERTIFICATES (GP tab) ──
  async function loadManageCerts() {
    const filter = (document.getElementById('manage-certs-filter') as HTMLSelectElement)?.value || null;
    const search = (document.getElementById('manage-certs-search') as HTMLInputElement)?.value?.trim() || null;
