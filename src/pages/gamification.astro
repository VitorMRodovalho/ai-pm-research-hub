        </div>
        <button class="px-3 py-1.5 bg-navy text-white rounded-lg text-[10px] font-semibold cursor-pointer border-0 hover:opacity-90" onclick="(async()=>{await sb.rpc('record_certificate_download',{p_cert_id:'${c.id}'});window.downloadCertificatePDF({member_name:'${MEMBER.name}',type:'${c.type}',title:'${c.title||''}',period_start:'${c.period_start||''}',period_end:'${c.period_end||''}',function_role:'${c.function_role||''}',language:'${c.language||'pt-BR'}',verification_code:'${c.verification_code||''}'})})()">📥 PDF</button>
        <a href="/verify/${c.verification_code}" target="_blank" class="text-[10px] text-blue-500 hover:underline no-underline ml-1">🔗 ${I.certVerify || 'Verificar'}</a>
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadMyCertificates failed', e);
      setPanelMessage('mycerts-list', `${I.certErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

  // ── MY TRAIL CLARITY ──
  async function loadMyTrailClarity() {
    if (!MEMBER) return;
    const host = document.getElementById('trail-clarity-content');
    if (!host) return;
    host.innerHTML = `<p class="text-[var(--text-muted)] text-sm text-center py-2">${I.trailLoading}</p>`;

    try {
      const { data: courses, error: coursesError } = await withTimeout(
        sb.from('courses').select('id, code, name, sort_order').eq('is_trail', true).order('sort_order', { ascending: true }),
      );
      if (coursesError) throw coursesError;

      const { data: rows, error: rowsError } = await withTimeout(
        sb.from('course_progress').select('course_id, status').eq('member_id', MEMBER.id),
      );
      if (rowsError) throw rowsError;

      const courseList = courses || [];
      const totalCourses = courseList.length || TRAIL_TOTAL;
      const statusByCourseId = new Map<number, string>();
      (rows || []).forEach((r: any) => {
        const id = Number(r.course_id);
        const current = String(r.status || '');
        const prev = statusByCourseId.get(id);
        if (prev === 'completed') return;
        if (current === 'completed' || !prev) statusByCourseId.set(id, current);
      });

      const completed = courseList.filter((c: any) => statusByCourseId.get(Number(c.id)) === 'completed');
      const inProgress = courseList.filter((c: any) => statusByCourseId.get(Number(c.id)) === 'in_progress');
      const missing = courseList.filter((c: any) => !statusByCourseId.has(Number(c.id)));
      const pct = totalCourses > 0 ? Math.round((completed.length / totalCourses) * 100) : 0;

      const courseRows = courseList.map(function(course: any) {
        const st = statusByCourseId.get(Number(course.id)) || 'pending';
        const statusIcon = st === 'completed'
          ? '<svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>'
          : st === 'in_progress'
          ? '<svg class="w-4 h-4 text-amber-500 animate-pulse shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>'
          : '<div class="w-4 h-4 rounded-full border-2 border-[var(--border-strong)] shrink-0"></div>';
        const statusLabel = st === 'completed' ? I.trailStatusCompleted : st === 'in_progress' ? I.trailStatusInProgress : I.trailStatusPending;
        const statusColor = st === 'completed' ? 'text-emerald-600' : st === 'in_progress' ? 'text-amber-600' : 'text-[var(--text-muted)]';
        const link = course.url ? '<a href="' + escapeHtml(course.url) + '" target="_blank" rel="noopener" class="text-[.6rem] text-teal font-semibold hover:underline no-underline shrink-0">' + (I.trailViewCourse || 'Acessar') + '</a>' : '';
        return '<div class="flex items-center gap-2.5 py-1.5 border-b border-[var(--border-subtle)] last:border-b-0">'
          + statusIcon
          + '<div class="flex-1 min-w-0"><div class="text-[.75rem] font-medium truncate">' + escapeHtml(course.name) + '</div></div>'
          + '<span class="text-[.6rem] font-semibold shrink-0 ' + statusColor + '">' + statusLabel + '</span>'
          + link
          + '</div>';
      }).join('');

      host.innerHTML = '<div class="flex items-center justify-between gap-3 flex-wrap mb-3">'
        + '<div><div class="text-sm font-bold text-navy">' + I.trailTitle + '</div>'
        + '<div class="text-[12px] text-[var(--text-secondary)]">' + I.trailCoursesOf.replace('{completed}', String(completed.length)).replace('{total}', String(totalCourses)) + '</div></div>'
        + '<span class="text-[11px] font-bold px-2 py-1 rounded-full ' + (pct >= 100 ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700') + '">'
        + I.trailPctComplete.replace('{pct}', String(pct)) + '</span></div>'
        + '<div class="h-2.5 bg-[var(--surface-base)] rounded-full overflow-hidden mb-4">'
        + '<div class="h-full rounded-full transition-all duration-700" style="width:' + pct + '%;background:' + (pct >= 100 ? '#10B981' : '#FF610F') + '"></div></div>'
        + '<div class="space-y-0">' + courseRows + '</div>';
    } catch (e: any) {
      host.innerHTML = `<p class="text-crimson text-sm text-center py-2">${I.trailError}${e?.message || I.msgFailUnexpected}</p>`;
    }
  }

  // ── SYNC POINTS (admin) ──
  async function syncPoints() {
    const btn = document.getElementById('btn-sync') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = I.syncBtnSyncing; }
    try {
      await sb.auth.refreshSession();
      const { data: { session } } = await sb.auth.getSession();
      if (!session?.access_token) {
        throw new Error(I.msgInvalidSession);
      }
      let attendanceSummary = '';

      let attendanceData: any = null;
      let attendanceError: any = null;
      try {
        const { data: aBody, error: aErr } = await sb.functions.invoke('sync-attendance-points', { body: {} });
        if (aErr) { attendanceError = { message: aErr.message || String(aErr) }; }
        else { attendanceData = aBody; }
      } catch (e: any) { attendanceError = { message: e.message }; }
      if (attendanceError || !attendanceData?.success) {
        const attendanceMsg = attendanceError
          ? await describeFnError(attendanceError)
          : (attendanceData?.error || I.syncAttendanceFail);
        attendanceSummary = `${I.syncAttendanceError}${attendanceMsg}.`;
      } else {
        attendanceSummary = I.syncAttendanceSuccess.replace('{n}', String(attendanceData.points_created));
      }

      let credlySummary = '';
      let credlyData: any = null;
      let credlyError: any = null;
      try {
        const { data: cBody, error: cErr } = await sb.functions.invoke('sync-credly-all', { body: {} });
        if (cErr) { credlyError = { message: cErr.message || String(cErr) }; }
        else { credlyData = cBody; }
      } catch (e: any) { credlyError = { message: e.message }; }
      if (!credlyError && credlyData?.success) {
        credlySummary = I.syncCredlySuccess.replace('{success}', String(credlyData.success_count)).replace('{total}', String(credlyData.total_candidates)).replace('{fail}', String(credlyData.fail_count));
      } else if (credlyError) {
        credlySummary = `${I.syncCredlyBatchError}${await describeFnError(credlyError)}.`;
      } else if (credlyData?.error) {
        credlySummary = `${I.syncCredlyBatchError}${credlyData.error}.`;
      } else {
        credlySummary = I.syncCredlyNotRun;
      }

      const isPartialError = attendanceSummary.includes(I.syncAttendanceError) || credlySummary.includes(I.syncCredlyBatchError);
      toast(`${attendanceSummary} ${credlySummary}`, isPartialError ? 'info' : 'success');
      loadLeaderboard();
      loadMyTrailClarity();
    } catch (e: any) {
      toast(`${I.msgSyncError}${e?.message || I.msgUnknownError}`, 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = I.syncBtn; }
    }
  }

  // ── ISSUE / EDIT CERTIFICATE (admin) ──
  let editingCertId: string | null = null;

  function enterEditMode(certId: string, data: Record<string, string>) {
    editingCertId = certId;
    // Switch to Emitir tab so the form is visible
    const emitTab = document.querySelector('[data-tab="admin-certs"]') as HTMLElement;
    if (emitTab) switchGamTab(emitTab, 'admin-certs');
    // Populate fields
    (document.getElementById('cert-type') as HTMLSelectElement).value = data.type || 'participation';
    (document.getElementById('cert-title') as HTMLInputElement).value = data.title || '';
    (document.getElementById('cert-desc') as HTMLTextAreaElement).value = data.desc || '';
    (document.getElementById('cert-period-start') as HTMLInputElement).value = data.periodStart || '';
    (document.getElementById('cert-period-end') as HTMLInputElement).value = data.periodEnd || '';
    (document.getElementById('cert-role') as HTMLInputElement).value = data.role || '';
    const langRadio = document.querySelector(`input[name="cert-lang"][value="${data.lang || 'pt-BR'}"]`) as HTMLInputElement;
    if (langRadio) langRadio.checked = true;
    const issueBtn = document.querySelector('[data-action="issue-certificate"]') as HTMLButtonElement;
    if (issueBtn) issueBtn.textContent = I.certSaveChanges;
    // Disable member select during edit
    const memberSel = document.getElementById('cert-member') as HTMLSelectElement;
    if (memberSel) memberSel.disabled = true;
    // Scroll form into view
    document.getElementById('cert-member')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function exitEditMode() {
    editingCertId = null;
    const issueBtn = document.querySelector('[data-action="issue-certificate"]') as HTMLButtonElement;
    if (issueBtn) issueBtn.textContent = I.certIssueBtn;
    const memberSel = document.getElementById('cert-member') as HTMLSelectElement;
    if (memberSel) memberSel.disabled = false;
    (document.getElementById('cert-title') as HTMLInputElement).value = '';
    (document.getElementById('cert-desc') as HTMLTextAreaElement).value = '';
    (document.getElementById('cert-period-start') as HTMLInputElement).value = '';
    (document.getElementById('cert-period-end') as HTMLInputElement).value = '';
    (document.getElementById('cert-role') as HTMLInputElement).value = '';
    // Switch back to Gerenciar tab
    const manageTab = document.querySelector('[data-tab="manage-certs"]') as HTMLElement;
    if (manageTab) switchGamTab(manageTab, 'manage-certs');
  }

  async function issueCertificate() {
    const type = (document.getElementById('cert-type') as HTMLSelectElement).value;
    const title = (document.getElementById('cert-title') as HTMLInputElement).value.trim();
    const desc = (document.getElementById('cert-desc') as HTMLTextAreaElement).value.trim() || null;
    const periodStart = (document.getElementById('cert-period-start') as HTMLInputElement)?.value.trim() || null;
    const periodEnd = (document.getElementById('cert-period-end') as HTMLInputElement)?.value.trim() || null;
    const functionRole = (document.getElementById('cert-role') as HTMLInputElement)?.value.trim() || null;
    const certLang = (document.querySelector('input[name="cert-lang"]:checked') as HTMLInputElement)?.value || 'pt-BR';

    if (editingCertId) {
      // UPDATE mode
      if (!title) { toast(I.certFillFields, 'error'); return; }
      const { error } = await sb.rpc('update_certificate', {
        p_cert_id: editingCertId,
        p_updates: { title, description: desc, type, period_start: periodStart, period_end: periodEnd, function_role: functionRole, language: certLang }
      });
      if (error) { toast(error.message || 'Error', 'error'); return; }
      toast(I.certUpdated, 'success');
      exitEditMode();
      loadManageCerts();
      return;
    }

    // ISSUE mode
    const memberId = (document.getElementById('cert-member') as HTMLSelectElement).value;
    const cycle = parseInt((document.getElementById('cert-cycle') as HTMLInputElement).value);
    if (!memberId || !title) { toast(I.certFillFields, 'error'); return; }

    const { data, error } = await sb.rpc('issue_certificate', {
      p_data: { member_id: memberId, type, title, description: desc, cycle, period_start: periodStart, period_end: periodEnd, function_role: functionRole, language: certLang }
    });

    if (error || data?.error) { toast(data?.error || error?.message || 'Error', 'error'); return; }
    toast(`${I.certIssued} — ${data.verification_code}`, 'success');
    const lastCert = { ...data, type, title, description: desc, period_start: periodStart, period_end: periodEnd, function_role: functionRole, language: certLang };
    (window as any).__lastCert = lastCert;
    (document.getElementById('cert-title') as HTMLInputElement).value = '';
    (document.getElementById('cert-desc') as HTMLTextAreaElement).value = '';
  }

  // ── LOAD MEMBERS FOR CERT DROPDOWN ──
  async function loadMembersDropdown() {
    const { data } = await sb.from('public_members')
      .select('id, name')
      .eq('current_cycle_active', true)
      .order('name');
    const sel = document.getElementById('cert-member') as HTMLSelectElement;
    if (sel && data) {
      sel.innerHTML = `<option value="">${I.certSelect}</option>` +
