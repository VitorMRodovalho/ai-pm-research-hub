  lbYou: t('gamification.lb.you', lang),
  lbBreakdownCycle: t('gamification.lb.breakdownCycle', lang),
  lbBreakdownLifetime: t('gamification.lb.breakdownLifetime', lang),
  lbBreakdownInProgress: t('gamification.lb.breakdownInProgress', lang),
  trTitle: t('gamification.tr.title', lang),
  trFormula: t('gamification.tr.formula', lang),
  trEmpty: t('gamification.tr.empty', lang),
  trErrorLoad: t('gamification.tr.errorLoad', lang),
  trMembers: t('gamification.tr.members', lang),
  trAvg: t('gamification.tr.avg', lang),
  trTotal: t('gamification.tr.total', lang),
  trScore: t('gamification.tr.score', lang),
  trModeAvg: t('gamification.tr.modeAvg', lang),
  achTitle: t('gamification.ach.title', lang),
  achUnlocked: t('gamification.ach.unlocked', lang),
  achOf: t('gamification.ach.of', lang),
