<script is:inline define:vars={{ GAM_I18N }}>
  window.__GAMIFICATION_I18N = typeof GAM_I18N !== 'undefined' ? GAM_I18N : {};
</script>
<script>
  import { getMemberRole } from '../lib/routing';
  import { aggregateCredlyByMember } from '../lib/gamification';
  import { buildTrailProgressByMember } from '../lib/trail-progress';
  import { buildTribeLabel, getTribeColor } from '../lib/tribes/catalog';
  import { hasPermission } from '../lib/permissions';

  const I = (typeof window !== 'undefined' && (window as any).__GAMIFICATION_I18N) || {};

  let sb: any = null;
  let MEMBER: any = null;
  let leaderboardData: any[] = [];
  let leaderboardMode: 'cycle' | 'lifetime' = 'lifetime';
  let tribeMode: 'cycle' | 'lifetime' = 'cycle';
  let lifetimePointsByMember: Record<string, number> = {};
  let trailProgressByMember = new Map();
  let credlyByMember: Record<string, any> = {};
  const TRAIL_TOTAL = 6;
  const PANEL_QUERY_TIMEOUT_MS = 15000;

  function escapeHtml(s: string): string {
    return String(s || '')
      .replace(/&/g, '&amp;').replace(/"/g, '&quot;')
      .replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  const CATEGORY_META: Record<string, { icon: string; color: string; bg: string; label: string }> = {
    attendance:          { icon: '📅', color: '#2563EB', bg: '#EFF6FF', label: 'Presença' },
    trail:               { icon: '🧭', color: '#7C3AED', bg: '#F5F3FF', label: 'Trilha PMI' },
    course:              { icon: '🎓', color: '#7C3AED', bg: '#F5F3FF', label: 'Curso' },
    knowledge_ai_pm:     { icon: '🧠', color: '#6366F1', bg: '#EEF2FF', label: 'AI & PM' },
    cert_pmi_senior:     { icon: '🏅', color: '#B45309', bg: '#FFFBEB', label: 'PMI Senior' },
    cert_cpmai:          { icon: '🤖', color: '#B45309', bg: '#FFFBEB', label: 'CPMAI™' },
    cert_pmi_mid:        { icon: '📋', color: '#B45309', bg: '#FFFBEB', label: 'PMI Mid' },
    cert_pmi_practitioner: { icon: '📜', color: '#B45309', bg: '#FFFBEB', label: 'PMI Practitioner' },
    cert_pmi_entry:      { icon: '📝', color: '#B45309', bg: '#FFFBEB', label: 'PMI Entry' },
    specialization:      { icon: '⚡', color: '#0891B2', bg: '#ECFEFF', label: 'Especialização' },
    badge:               { icon: '🏷️', color: '#D97706', bg: '#FFFBEB', label: 'Badge' },
    artifact:            { icon: '📄', color: '#059669', bg: '#ECFDF5', label: 'Artefato' },
    bonus:               { icon: '⭐', color: '#D97706', bg: '#FFFBEB', label: 'Bônus' },
  };

  const TYPE_LABELS: Record<string, string> = {
    participation: I.typeParticipation, completion: I.typeCompletion,
    contribution: I.typeContribution, excellence: I.typeExcellence,
  };

  let TRIBE_NAMES: Record<number, string> = {
    1: I.tribeName1, 2: I.tribeName2, 3: I.tribeName3,
    4: I.tribeName4, 5: I.tribeName5, 6: I.tribeName6,
    7: I.tribeName7, 8: I.tribeName8,
  };
  let TRIBE_COLORS: Record<number, string> = {
    1: '#00799E', 2: '#00799E', 3: '#FF610F', 4: '#FF610F',
    5: '#4F17A8', 6: '#4F17A8', 7: '#10B981', 8: '#10B981'
  };
  async function loadRuntimeTribes() {
    if (!sb) return;
    try {
      const { data, error } = await sb.from('tribes').select('id, name, name_i18n, quadrant').eq('is_active', true).order('id');
      if (error) throw error;
      const _sl = location.pathname.startsWith('/en') ? 'en' : location.pathname.startsWith('/es') ? 'es' : 'pt';
      (data || []).forEach((tribe: any) => {
        const localizedTribe = { ...tribe, name: tribe.name_i18n?.[_sl] || tribe.name };
        TRIBE_NAMES[tribe.id] = buildTribeLabel(localizedTribe, { prefix: 'Tribo', fallbackNames: TRIBE_NAMES });
        TRIBE_COLORS[tribe.id] = getTribeColor(tribe);
      });
    } catch (error) {
      console.warn('gamification tribes:', error);
    }
  }


  function toast(msg: string, type = '') { (window as any).toast?.(msg, type); }

  function setPanelMessage(targetId: string, message: string, kind: 'loading' | 'error' | 'empty' = 'loading', cta?: { text: string; action: string }) {
    const el = document.getElementById(targetId);
    if (!el) return;
    const color = kind === 'error' ? 'text-crimson' : 'text-[var(--text-muted)]';
    const ctaHtml = cta ? `<button type="button" class="mt-4 px-4 py-2 bg-teal text-white rounded-xl text-sm font-semibold cursor-pointer border-0 hover:opacity-90 transition-all" data-action="${cta.action}">${cta.text}</button>` : '';
    el.innerHTML = `<div class="text-center py-6"><p class="${color} text-sm">${message}</p>${ctaHtml}</div>`;
  }

  async function withTimeout<T>(promise: Promise<T>, ms = PANEL_QUERY_TIMEOUT_MS): Promise<T> {
    let timer: ReturnType<typeof setTimeout> | undefined;
    const timeout = new Promise<never>((_, reject) => {
      timer = setTimeout(() => reject(new Error(I.msgTimeout)), ms);
    });
    try {
      return await Promise.race([promise, timeout]);
    } finally {
      if (timer) clearTimeout(timer);
    }
  }

  async function describeFnError(err: any): Promise<string> {
    if (!err) return I.msgUnknownError;
    if (err.context && typeof err.context.json === 'function') {
      try {
        const payload = await err.context.json();
        const detail = payload?.error || payload?.message;
        if (detail) return detail;
      } catch {}
    }
    return err.message || I.msgUnknownError;
  }

  // ── XP LEVEL SYSTEM ──
  function getLevel(pts: number): { name: string; emoji: string; next: string; ptsToNext: number; pctInLevel: number } {
    const levels = [
      { min: 0,   max: 30,  name: I.levelExplorer, emoji: '🌱', next: I.levelPractitioner },
      { min: 31,  max: 90,  name: I.levelPractitioner, emoji: '⚡', next: I.levelExpert },
      { min: 91,  max: 200, name: I.levelExpert, emoji: '🔥', next: I.levelMaster },
      { min: 201, max: 400, name: I.levelMaster, emoji: '💎', next: I.levelLegend },
      { min: 401, max: 9999, name: I.levelLegend, emoji: '🏆', next: '' },
    ];
    const lvl = levels.find(l => pts >= l.min && pts <= l.max) || levels[0];
    const range = lvl.max - lvl.min;
    const progress = pts - lvl.min;
    return {
      name: lvl.name, emoji: lvl.emoji, next: lvl.next,
      ptsToNext: lvl.next ? (lvl.max + 1 - pts) : 0,
      pctInLevel: range > 0 ? Math.min(Math.round((progress / range) * 100), 100) : 100,
    };
  }

  // ── ACHIEVEMENTS (computed from existing data) ──
  const ACHIEVEMENT_DEFS = [
    { id: 'first_points', icon: '🎯', name: I.achDefFirstPointsName, desc: I.achDefFirstPointsDesc, check: (pts: number, data: any) => pts > 0 },
    { id: 'level_practitioner', icon: '⚡', name: I.achDefPractitionerName, desc: I.achDefPractitionerDesc, check: (pts: number) => pts >= 31 },
    { id: 'level_expert', icon: '🔥', name: I.achDefExpertName, desc: I.achDefExpertDesc, check: (pts: number) => pts >= 91 },
    { id: 'level_master', icon: '💎', name: I.achDefMasterName, desc: I.achDefMasterDesc, check: (pts: number) => pts >= 201 },
    { id: 'level_legend', icon: '🏆', name: I.achDefLegendName, desc: I.achDefLegendDesc, check: (pts: number) => pts >= 401 },
    { id: 'scholar', icon: '📚', name: I.achDefScholarName, desc: I.achDefScholarDesc, check: (_: number, d: any) => d.coursesCompleted >= 7 },
    { id: 'publisher', icon: '📝', name: I.achDefPublisherName, desc: I.achDefPublisherDesc, check: (_: number, d: any) => d.artifactsPublished > 0 },
    { id: 'consistent', icon: '🔥', name: I.achDefConsistentName, desc: I.achDefConsistentDesc, check: (_: number, d: any) => d.attendanceCount >= 5 },
    { id: 'engaged', icon: '💪', name: I.achDefEngagedName, desc: I.achDefEngagedDesc, check: (_: number, d: any) => d.attendanceCount >= 10 },
    { id: 'veteran', icon: '🌟', name: I.achDefVeteranName, desc: I.achDefVeteranDesc, check: (_: number, d: any) => d.cycleCount >= 2 },
    { id: 'profile_complete', icon: '✨', name: I.achDefProfileCompleteName, desc: I.achDefProfileCompleteDesc, check: (_: number, d: any) => d.profileComplete },
  ];

  // ── TABS ──
  async function setLeaderboardMode(mode: 'cycle' | 'lifetime') {
    leaderboardMode = mode;
    const cycleBtn = document.getElementById('lb-mode-cycle');
    const lifeBtn = document.getElementById('lb-mode-lifetime');
    if (cycleBtn && lifeBtn) {
      const cycleOn = mode === 'cycle';
      cycleBtn.classList.toggle('bg-navy', cycleOn);
      cycleBtn.classList.toggle('bg-transparent', !cycleOn);
      cycleBtn.classList.toggle('text-white', cycleOn);
      cycleBtn.classList.toggle('text-[var(--text-secondary)]', !cycleOn);
      lifeBtn.classList.toggle('bg-navy', !cycleOn);
      lifeBtn.classList.toggle('bg-transparent', cycleOn);
      lifeBtn.classList.toggle('text-white', !cycleOn);
      lifeBtn.classList.toggle('text-[var(--text-secondary)]', cycleOn);
    }
    await ensureLifetimePointsLoaded();
    renderLeaderboard();
    try { if ((window as any).posthog) (window as any).posthog.capture('leaderboard_filtered', { filter_type: cycleOn ? 'cycle' : 'lifetime' }); } catch {}
  }

  function switchGamTab(el: HTMLElement, tab: string) {
    document.querySelectorAll('.gam-tab').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-[var(--surface-card)]', 'text-[var(--text-secondary)]', 'border-[var(--border-default)]');
    });
    el.classList.remove('bg-[var(--surface-card)]', 'text-[var(--text-secondary)]', 'border-[var(--border-default)]');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    ['leaderboard', 'tribes', 'achievements', 'mypoints', 'mycerts', 'admin-certs', 'manage-certs'].forEach(p => {
      document.getElementById(`panel-${p}`)?.classList.toggle('hidden', p !== tab);
    });
    if (tab === 'leaderboard') loadLeaderboard();
    if (tab === 'tribes') loadTribeRanking();
    if (tab === 'achievements') loadAchievements();
    if (tab === 'mypoints') loadMyPoints();
    if (tab === 'mycerts') loadMyCertificates();
    if (tab === 'manage-certs') loadManageCerts();
  }

  function setTribeMode(mode: 'cycle' | 'lifetime') {
    tribeMode = mode;
    const cycleBtn = document.getElementById('tr-mode-cycle');
    const lifeBtn = document.getElementById('tr-mode-lifetime');
    if (cycleBtn && lifeBtn) {
      const cycleOn = mode === 'cycle';
      cycleBtn.classList.toggle('bg-navy', cycleOn);
      cycleBtn.classList.toggle('bg-transparent', !cycleOn);
      cycleBtn.classList.toggle('text-white', cycleOn);
      cycleBtn.classList.toggle('text-[var(--text-secondary)]', !cycleOn);
      lifeBtn.classList.toggle('bg-navy', !cycleOn);
      lifeBtn.classList.toggle('bg-transparent', cycleOn);
      lifeBtn.classList.toggle('text-white', !cycleOn);
      lifeBtn.classList.toggle('text-[var(--text-secondary)]', cycleOn);
    }
    loadTribeRanking();
  }

  function renderLeaderboard() {
    const el = document.getElementById('leaderboard-list')!;
    if (!leaderboardData?.length) {
      setPanelMessage('leaderboard-list', I.lbEmpty, 'empty');
      return;
    }

    const rankedRows = (leaderboardData || [])
      .map((m: any) => ({
        ...m,
        cycle_points: Number(m.cycle_points || 0),
        lifetime_points: Number(lifetimePointsByMember[m.member_id] ?? m.total_points ?? 0),
      }))
      .sort((a: any, b: any) => {
        const left = leaderboardMode === 'lifetime' ? a.lifetime_points : a.cycle_points;
        const right = leaderboardMode === 'lifetime' ? b.lifetime_points : b.cycle_points;
        return right - left;
      });

    const maxPts = Math.max(...rankedRows.map((m: any) => leaderboardMode === 'lifetime' ? m.lifetime_points : m.cycle_points), 1);
    const modeLabel = leaderboardMode === 'lifetime' ? I.modeLifetime : I.modeCycle;

    el.innerHTML = rankedRows.map((m: any, i: number) => {
      const safeMemberName = String(m.name || 'Membro sem nome');
      const initials = safeMemberName.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
      const photo = m.photo_url
        ? `<img src="${m.photo_url}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="">`
        : `<div class="w-10 h-10 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.7rem] flex-shrink-0">${initials}</div>`;

      const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
      const rank = i + 1;
      const displayPoints = leaderboardMode === 'lifetime' ? m.lifetime_points : m.cycle_points;
      const pct = (displayPoints / maxPts * 100).toFixed(0);
      const level = getLevel(displayPoints);
      const isMe = MEMBER && m.member_id === MEMBER.id;
      const credly = credlyByMember[m.member_id] || { total: 0, badges: 0, t1: 0, t2: 0, t3: 0, t4: 0 };
      const trail = trailProgressByMember.get(m.member_id) || { completed: 0, inProgress: 0, pct: 0 };

      const breakdown = [
        `🧭 ${modeLabel}: ${displayPoints}`,
        leaderboardMode === 'lifetime' ? `📅 ${I.lbBreakdownCycle}: ${m.cycle_points}` : `♾️ ${I.lbBreakdownLifetime}: ${m.lifetime_points}`,
        `📚 ${trail.completed}/${TRAIL_TOTAL}`,
        trail.inProgress > 0 ? `⏳ ${trail.inProgress} ${I.lbBreakdownInProgress}` : '',
      ].filter(Boolean).join(' · ');

      return `
      <div class="flex items-center gap-3 py-3 border-b border-[var(--border-subtle)] last:border-b-0 ${i < 3 ? 'bg-amber-50/30' : ''} ${isMe ? 'ring-2 ring-orange/30 rounded-lg' : ''}">
        <div class="w-8 text-center font-bold text-[13px] text-[var(--text-muted)] flex-shrink-0">${medal || rank}</div>
        ${photo}
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-1.5">
            <span class="text-[13px] font-semibold truncate">${safeMemberName.split(' ').slice(0, 3).join(' ')}</span>
            <span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-[var(--surface-base)]">${level.emoji} ${level.name}</span>
            ${isMe ? `<span class="text-[.55rem] font-bold px-1 py-0.5 rounded bg-orange/10 text-orange">${I.lbYou}</span>` : ''}
          </div>
          <div class="text-[11px] text-[var(--text-muted)]">${m.chapter || ''} · ${breakdown}</div>
          <div class="h-1.5 bg-[var(--surface-base)] rounded-full mt-1 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%;background:${displayPoints > 0 ? '#FF610F' : '#E2E8F0'}"></div>
          </div>
        </div>
        <div class="text-right flex-shrink-0">
          <div class="text-lg font-extrabold text-navy">${displayPoints}</div>
          <div class="text-[10px] text-[var(--text-muted)]">${I.mpPtsLabel}</div>
        </div>
      </div>`;
    }).join('');
  }

  async function ensureLifetimePointsLoaded() {
    if (Object.keys(lifetimePointsByMember).length > 0 || !leaderboardData.length) return;
    const ids = leaderboardData.map((m: any) => m.member_id).filter(Boolean);
    if (!ids.length) return;
    const { data: allPointsRows, error: allPointsError } = await withTimeout(
      sb.from('gamification_points').select('member_id, points').in('member_id', ids),
    );
    if (allPointsError) throw allPointsError;
    lifetimePointsByMember = {};
    (allPointsRows || []).forEach((r: any) => {
      const id = String(r.member_id || '');
      if (!id) return;
      lifetimePointsByMember[id] = (lifetimePointsByMember[id] || 0) + Number(r.points || 0);
    });
  }

  // ── INDIVIDUAL LEADERBOARD (with XP levels) ──
  async function loadLeaderboard() {
    setPanelMessage('leaderboard-list', I.loading, 'loading');
    try {
      // Anon/Ghost: use public leaderboard RPC (no PII, LGPD-safe)
      if (!MEMBER) {
        const { data: pubData, error: pubError } = await sb.rpc('get_public_leaderboard', { p_limit: 50 });
        if (pubError) throw pubError;
        const rows = Array.isArray(pubData) ? pubData : [];
        if (!rows.length) { setPanelMessage('leaderboard-list', I.lbEmpty, 'empty'); return; }
        leaderboardData = rows.map((r: any, i: number) => ({
          member_id: null,
          name: r.member_name,
          chapter: r.chapter,
          tribe_name: r.tribe_name,
          cycle_points: r.xp_total,
          lifetime_points: r.xp_total,
          level_name: r.level_name,
        }));
        credlyByMember = {};
        trailProgressByMember = {};
        lifetimePointsByMember = {};
        renderLeaderboard();
        return;
      }

      const { data, error } = await sb.from('gamification_leaderboard').select('*');
      if (error) throw error;
      const { data: courseRows, error: courseRowsError } = await sb.from('course_progress')
        .select('member_id, course_id, status');
      if (courseRowsError) throw courseRowsError;

      const { data: credlyRows, error: credlyError } = await sb.from('gamification_points')
        .select('member_id, points')
        .like('reason', 'Credly:%');
      if (credlyError) throw credlyError;
      credlyByMember = aggregateCredlyByMember(credlyRows || []);

      leaderboardData = data || [];
      trailProgressByMember = buildTrailProgressByMember(courseRows || [], TRAIL_TOTAL);
      if (!data?.length) {
        setPanelMessage('leaderboard-list', I.lbEmptySync, 'empty', MEMBER ? { text: I.syncBtn, action: 'sync-points' } : undefined);
        return;
      }

      lifetimePointsByMember = {};
      await ensureLifetimePointsLoaded();
      renderLeaderboard();
    } catch (e: any) {
      console.error('gamification.loadLeaderboard failed', e);
      setPanelMessage('leaderboard-list', `${I.lbErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

  // ── TRIBE RANKING ──
  async function loadTribeRanking() {
    setPanelMessage('tribes-ranking-list', I.loading, 'loading');
    try {
      // Get tribe selections + leaderboard data
      const { data: selections, error: selectionsError } = await withTimeout(
        sb.from('tribe_selections').select('tribe_id, member_id'),
      );
      if (selectionsError) throw selectionsError;
      const { data: leaders, error: leadersError } = await withTimeout(
        sb.from('public_members').select('id, tribe_id').eq('operational_role', 'tribe_leader'),
      );
      if (leadersError) throw leadersError;

      if (!leaderboardData.length) {
        const { data, error } = await withTimeout(sb.from('gamification_leaderboard').select('*'));
        if (error) throw error;
        leaderboardData = data || [];
      }
      await ensureLifetimePointsLoaded();

    // Build tribe map: member_id → tribe_id
    const memberTribe: Record<string, number> = {};
    (selections || []).forEach((s: any) => { memberTribe[s.member_id] = s.tribe_id; });
    (leaders || []).forEach((l: any) => { if (l.tribe_id) memberTribe[l.id] = l.tribe_id; });

    // Aggregate by tribe
    const tribeStats: Record<number, { points: number; members: number; names: string[] }> = {};
    for (const k of Object.keys(TRIBE_NAMES)) tribeStats[Number(k)] = { points: 0, members: 0, names: [] };

    leaderboardData.forEach((m: any) => {
      const tid = memberTribe[m.member_id];
      if (tid && tribeStats[tid]) {
        const points = tribeMode === 'lifetime'
          ? Number(lifetimePointsByMember[m.member_id] ?? m.total_points ?? 0)
          : Number(m.cycle_points || 0);
        tribeStats[tid].points += points;
        tribeStats[tid].members++;
        tribeStats[tid].names.push(String(m.name || 'Membro').split(' ')[0]);
      }
    });

    // Score = avg points + (members × 10)
    const ranked = Object.entries(tribeStats)
      .map(([tid, s]) => {
        const t = Number(tid);
        const avg = s.members > 0 ? Math.round(s.points / s.members) : 0;
        const score = avg + (s.members * 10);
        return { tid: t, name: TRIBE_NAMES[t] || buildTribeLabel(t, { prefix: 'Tribo', fallbackNames: TRIBE_NAMES }), color: TRIBE_COLORS[t] || getTribeColor(t), avg, total: s.points, members: s.members, score, names: s.names };
      })
      .filter(t => t.members > 0)
      .sort((a, b) => b.score - a.score);

      const el = document.getElementById('tribes-ranking-list')!;
      if (!ranked.length) {
        setPanelMessage('tribes-ranking-list', I.trEmpty, 'empty');
        return;
      }

    const maxScore = Math.max(...ranked.map(t => t.score), 1);

      const modeLabel = tribeMode === 'lifetime' ? I.modeLifetime : I.modeCycle;
      el.innerHTML = ranked.map((t, i) => {
      const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : '';
      const pct = Math.round((t.score / maxScore) * 100);
      return `
      <div class="py-4 border-b border-[var(--border-subtle)] last:border-b-0 ${i < 3 ? 'bg-amber-50/30 rounded-lg px-3 mb-2' : ''}">
        <div class="flex items-center gap-3">
          <div class="w-8 text-center font-bold text-[13px] text-[var(--text-muted)] flex-shrink-0">${medal || (i + 1)}</div>
          <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style="background:${t.color}">
            T${String(t.tid).padStart(2, '0')}
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-[13px] font-bold">${t.name}</div>
            <div class="text-[11px] text-[var(--text-muted)]">${t.members} ${I.trMembers} · ${modeLabel} ${I.trModeAvg}: ${t.avg} ${I.mpPtsLabel} · ${I.trTotal}: ${t.total} ${I.mpPtsLabel}</div>
            <div class="h-1.5 bg-[var(--surface-base)] rounded-full mt-1.5 overflow-hidden">
              <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%;background:${t.color}"></div>
            </div>
          </div>
          <div class="text-right flex-shrink-0">
            <div class="text-xl font-extrabold text-navy">${t.score}</div>
            <div class="text-[10px] text-[var(--text-muted)]">${I.trScore}</div>
          </div>
        </div>
        <div class="ml-[76px] mt-2 flex flex-wrap gap-1">
          ${t.names.map((n: string) => `<span class="text-[.6rem] px-1.5 py-0.5 rounded bg-[var(--surface-base)] text-[var(--text-secondary)]">${n}</span>`).join('')}
        </div>
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadTribeRanking failed', e);
      setPanelMessage('tribes-ranking-list', `${I.trErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

  // ── ACHIEVEMENTS ──
  async function loadAchievements() {
    const el = document.getElementById('achievements-list')!;
    if (!MEMBER) {
      setPanelMessage('achievements-list', I.msgLoginAchievements, 'empty');
      return;
    }
    setPanelMessage('achievements-list', I.loading, 'loading');

    try {
      if (!leaderboardData.length) {
        const { data: lbRows, error: lbError } = await withTimeout(sb.from('gamification_leaderboard').select('*'));
        if (lbError) throw lbError;
        leaderboardData = lbRows || [];
      }
      await ensureLifetimePointsLoaded();

      // Gather data for achievement checks
      const { count: attendanceCount, error: attendanceError } = await withTimeout(
        sb.from('attendance').select('*', { count: 'exact', head: true }).eq('member_id', MEMBER.id),
      );
      if (attendanceError) throw attendanceError;

      const { data: courses, error: coursesError } = await withTimeout(
        sb.from('course_progress').select('status').eq('member_id', MEMBER.id),
      );
      if (coursesError) throw coursesError;

      const { data: artifacts, error: artifactsError } = await withTimeout(
        sb.from('artifacts').select('status').eq('member_id', MEMBER.id),
      );
      if (artifactsError) throw artifactsError;

      const { data: cycles, error: cyclesError } = await withTimeout(
        sb.from('member_cycle_history').select('cycle_code').eq('member_id', MEMBER.id),
      );
      if (cyclesError) throw cyclesError;

    const cyclePoints = leaderboardData.find((m: any) => m.member_id === MEMBER.id)?.cycle_points || 0;
    const myPoints = Number(lifetimePointsByMember[MEMBER.id] || cyclePoints || 0);
    const coursesCompleted = (courses || []).filter((c: any) => c.status === 'completed').length;
    const artifactsPublished = (artifacts || []).filter((a: any) => a.status === 'published').length;
    const cycleCount = (cycles || []).length;

    // Check profile completeness (simplified)
    const profileComplete = !!(MEMBER.photo_url && MEMBER.pmi_id && MEMBER.linkedin_url && MEMBER.phone && MEMBER.credly_url);

    const checkData = { attendanceCount: attendanceCount || 0, coursesCompleted, artifactsPublished, cycleCount, profileComplete };

    let earned = 0;
    const total = ACHIEVEMENT_DEFS.length;

      el.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        ${ACHIEVEMENT_DEFS.map(a => {
          const unlocked = a.check(myPoints, checkData);
          if (unlocked) earned++;
          return `
          <div class="flex items-center gap-3 p-3 rounded-xl border ${unlocked ? 'border-amber-200 bg-amber-50/50' : 'border-[var(--border-subtle)] bg-[var(--surface-base)]/50 opacity-50'}">
            <div class="text-2xl flex-shrink-0">${unlocked ? a.icon : '🔒'}</div>
            <div class="flex-1 min-w-0">
              <div class="text-[.78rem] font-bold ${unlocked ? 'text-navy' : 'text-[var(--text-muted)]'}">${a.name}</div>
              <div class="text-[.65rem] text-[var(--text-muted)]">${a.desc}</div>
            </div>
            ${unlocked ? '<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-700 flex-shrink-0">✓</span>' : ''}
          </div>`;
        }).join('')}
      </div>
      <div class="mt-4 text-center text-[.78rem] text-[var(--text-secondary)]">
        ${I.achLifetimeXP}: <strong>${myPoints}</strong> · ${I.achCurrentCycle}: <strong>${cyclePoints}</strong><br>
        ${earned} ${I.achOf} ${total} ${I.achUnlocked}
      </div>`;
    } catch (e: any) {
      console.error('gamification.loadAchievements failed', e);
      setPanelMessage('achievements-list', `${I.achErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

  // ── MY POINTS ──
  async function loadMyPoints() {
    if (!MEMBER) {
      setPanelMessage('mypoints-list', I.msgLoginPoints, 'empty');
      return;
    }
    setPanelMessage('mypoints-list', I.loading, 'loading');
    try {
      const { data, error } = await withTimeout(
        sb.from('gamification_points')
          .select('*')
          .eq('member_id', MEMBER.id)
          .order('created_at', { ascending: false }),
      );
      if (error) throw error;

      const el = document.getElementById('mypoints-list')!;
      if (!data?.length) {
        setPanelMessage('mypoints-list', I.mpNoPoints, 'empty', MEMBER ? { text: I.syncBtn, action: 'sync-points' } : undefined);
        return;
      }

    const total = data.reduce((s: number, p: any) => s + p.points, 0);
    const cyclePoints = leaderboardData.find((m: any) => m.member_id === MEMBER.id)?.total_points || 0;
    const level = getLevel(total);
      const myCredly = aggregateCredlyByMember(
        (data || []).filter((p: any) => String(p.reason || '').startsWith('Credly:'))
      )[MEMBER.id] || { total: 0, badges: 0, t1: 0, t2: 0, t3: 0, t4: 0 };

      el.innerHTML = `
      <div class="text-center mb-6 py-5 bg-gradient-to-br from-navy/5 to-orange/5 rounded-xl">
        <div class="text-3xl mb-1">${level.emoji}</div>
        <div class="text-3xl font-extrabold text-navy">${total}</div>
        <div class="text-sm text-[var(--text-secondary)]">${I.mpLifetimeLabel} · <strong>${level.name}</strong></div>
        <div class="text-[.7rem] text-[var(--text-muted)] mt-1">${I.mpCurrentCycleLabel}: <strong>${cyclePoints}</strong> ${I.mpPtsLabel}</div>
        ${level.next ? `<div class="text-[.7rem] text-[var(--text-muted)] mt-1">${I.mpToNext.replace('{n}', String(level.ptsToNext)).replace('{level}', level.next)}</div>` : `<div class="text-[.7rem] text-amber-600 mt-1 font-bold">${I.mpMaxLevel}</div>`}
        <div class="w-40 h-2 bg-[var(--border-strong)] rounded-full mx-auto mt-2 overflow-hidden">
          <div class="h-full bg-orange rounded-full" style="width:${level.pctInLevel}%"></div>
        </div>
      </div>
      ${myCredly.total > 0 ? `
      <div class="mb-5 p-3 rounded-xl border border-amber-200 bg-amber-50/50">
        <div class="text-[.78rem] font-bold text-navy mb-2">${I.credlyTierTitle}</div>
        <div class="flex flex-wrap gap-2 text-[.7rem]">
          <span class="px-2 py-1 rounded bg-[var(--surface-card)] border border-amber-200 text-amber-700">T1 Master: ${myCredly.t1}</span>
          <span class="px-2 py-1 rounded bg-[var(--surface-card)] border border-amber-200 text-amber-700">T2 Specialization: ${myCredly.t2}</span>
          <span class="px-2 py-1 rounded bg-[var(--surface-card)] border border-amber-200 text-amber-700">T3 Trail/Knowledge: ${myCredly.t3}</span>
          <span class="px-2 py-1 rounded bg-[var(--surface-card)] border border-amber-200 text-amber-700">T4 Other: ${myCredly.t4}</span>
          <span class="px-2 py-1 rounded bg-navy text-white font-semibold">${I.credlyTotalLabel}: ${myCredly.total} ${I.mpPtsLabel}</span>
        </div>
      </div>` : ''}
    `;

    // Cycle breakdown: group by category
    const catTotals: Record<string, number> = {};
    data.forEach((p: any) => { catTotals[p.category] = (catTotals[p.category] || 0) + p.points; });
    const catKeys = Object.keys(catTotals).sort((a, b) => catTotals[b] - catTotals[a]);
    if (catKeys.length > 0) {
      el.innerHTML += '<div class="mb-4 p-3 bg-[var(--surface-base)] rounded-xl"><div class="text-[.72rem] font-bold text-[var(--text-secondary)] mb-2">' + (I.mpCycleBreakdown || 'Detalhamento') + '</div><div class="grid grid-cols-2 sm:grid-cols-4 gap-2">'
        + catKeys.map((cat: string) => {
          const meta = CATEGORY_META[cat] || CATEGORY_META.bonus;
          return '<div class="flex items-center gap-1.5 px-2 py-1.5 rounded-lg bg-[var(--surface-card)] border border-[var(--border-subtle)]"><span class="text-sm">' + meta.icon + '</span><div><div class="text-[.65rem] text-[var(--text-secondary)]">' + escapeHtml(meta.label || cat) + '</div><div class="text-sm font-bold" style="color:' + meta.color + '">' + catTotals[cat] + ' pts</div></div></div>';
        }).join('') + '</div></div>';
    }

    el.innerHTML += data.map((p: any) => {
      const cat = CATEGORY_META[p.category] || CATEGORY_META.bonus;
      const date = new Date(p.created_at).toLocaleDateString(I.locale || 'pt-BR', { year: 'numeric', month: 'short', day: '2-digit' });
      return `
      <div class="flex items-center gap-3 py-2.5 border-b border-[var(--border-subtle)] last:border-b-0">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background:${cat.bg}">${cat.icon}</div>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-medium truncate">${p.reason}</div>
          <div class="text-[11px] text-[var(--text-muted)]">${date}</div>
        </div>
        <div class="font-bold text-sm" style="color:${cat.color}">+${p.points}</div>
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadMyPoints failed', e);
      setPanelMessage('mypoints-list', `${I.mpErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

