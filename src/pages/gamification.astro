    if (error || data?.error) return;
    const s = data.summary || {};
    const summaryEl = document.getElementById('manage-certs-summary');
    if (summaryEl) {
      summaryEl.innerHTML = [
        { l: 'Total', v: s.total || 0, c: '' },
        { l: I.certStatusIssued || 'Emitido', v: s.issued || 0, c: 'text-emerald-600' },
        { l: I.certStatusDraft || 'Rascunho', v: s.draft || 0, c: 'text-amber-600' },
        { l: I.certStatusRevoked || 'Revogado', v: s.revoked || 0, c: 'text-red-600' },
        { l: I.certDownloaded || 'Baixado', v: s.downloaded || 0, c: 'text-blue-600' },
      ].map(x => `<div class="rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] p-2 text-center"><div class="text-lg font-black ${x.c}">${x.v}</div><div class="text-[9px] text-[var(--text-muted)] uppercase">${x.l}</div></div>`).join('');
