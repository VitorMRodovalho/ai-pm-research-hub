        <div class="flex flex-wrap gap-2 text-[.7rem]">
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T1 Master: ${myCredly.t1}</span>
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T2 Specialization: ${myCredly.t2}</span>
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T3 Trail/Knowledge: ${myCredly.t3}</span>
          <span class="px-2 py-1 rounded bg-white border border-amber-200 text-amber-700">T4 Other: ${myCredly.t4}</span>
          <span class="px-2 py-1 rounded bg-navy text-white font-semibold">${I.credlyTotalLabel}: ${myCredly.total} ${I.mpPtsLabel}</span>
        </div>
      </div>` : ''}
    ` + data.map((p: any) => {
      const cat = CATEGORY_META[p.category] || CATEGORY_META.bonus;
      const date = new Date(p.created_at).toLocaleDateString(I.locale || 'pt-BR', { year: 'numeric', month: 'short', day: '2-digit' });
      return `
      <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm" style="background:${cat.bg}">${cat.icon}</div>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-medium truncate">${p.reason}</div>
          <div class="text-[11px] text-slate-400">${date}</div>
        </div>
        <div class="font-bold text-sm" style="color:${cat.color}">+${p.points}</div>
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadMyPoints failed', e);
      setPanelMessage('mypoints-list', `${I.mpErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

  // ── MY CERTIFICATES ──
  async function loadMyCertificates() {
    if (!MEMBER) {
      setPanelMessage('mycerts-list', I.msgLoginCerts, 'empty');
      return;
    }
    setPanelMessage('mycerts-list', I.loading, 'loading');
    try {
      const { data, error } = await withTimeout(
        sb.from('certificates')
          .select('*')
          .eq('member_id', MEMBER.id)
          .order('issued_at', { ascending: false }),
      );
      if (error) throw error;

      const el = document.getElementById('mycerts-list')!;
      if (!data?.length) {
        setPanelMessage('mycerts-list', I.certEmpty, 'empty');
        return;
      }

      el.innerHTML = data.map((c: any) => {
        const date = new Date(c.issued_at).toLocaleDateString(I.locale || 'pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
        return `
      <div class="flex items-center gap-3 py-3 border-b border-slate-100 last:border-b-0">
        <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center text-xl flex-shrink-0">🎓</div>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-semibold">${c.title}</div>
          <div class="text-[11px] text-slate-400">${TYPE_LABELS[c.type] || c.type} · ${date}</div>
          ${c.description ? `<div class="text-[12px] text-slate-500 mt-0.5">${c.description}</div>` : ''}
          <div class="text-[10px] text-slate-400 mt-0.5 font-mono">${I.certCode}: ${c.verification_code}</div>
        </div>
        ${c.pdf_url ? `<a href="${c.pdf_url}" target="_blank" class="px-3 py-1.5 bg-navy text-white rounded-lg text-[12px] font-semibold no-underline hover:opacity-90">📥 PDF</a>` : ''}
      </div>`;
      }).join('');
    } catch (e: any) {
      console.error('gamification.loadMyCertificates failed', e);
      setPanelMessage('mycerts-list', `${I.certErrorLoad}${e?.message || I.msgFailUnexpected}`, 'error');
    }
  }

  // ── MY TRAIL CLARITY ──
  async function loadMyTrailClarity() {
    if (!MEMBER) return;
    const host = document.getElementById('trail-clarity-content');
    if (!host) return;
    host.innerHTML = `<p class="text-slate-400 text-sm text-center py-2">${I.trailLoading}</p>`;

    try {
      const { data: courses, error: coursesError } = await withTimeout(
        sb.from('courses').select('id, code, name, sort_order').order('sort_order', { ascending: true }),
      );
      if (coursesError) throw coursesError;

      const { data: rows, error: rowsError } = await withTimeout(
        sb.from('course_progress').select('course_id, status').eq('member_id', MEMBER.id),
      );
      if (rowsError) throw rowsError;

      const courseList = courses || [];
      const totalCourses = courseList.length || TRAIL_TOTAL;
      const statusByCourseId = new Map<number, string>();
      (rows || []).forEach((r: any) => {
        const id = Number(r.course_id);
        const current = String(r.status || '');
        const prev = statusByCourseId.get(id);
        if (prev === 'completed') return;
        if (current === 'completed' || !prev) statusByCourseId.set(id, current);
      });

      const completed = courseList.filter((c: any) => statusByCourseId.get(Number(c.id)) === 'completed');
      const inProgress = courseList.filter((c: any) => statusByCourseId.get(Number(c.id)) === 'in_progress');
      const missing = courseList.filter((c: any) => !statusByCourseId.has(Number(c.id)));
      const pct = totalCourses > 0 ? Math.round((completed.length / totalCourses) * 100) : 0;

      host.innerHTML = `
        <div class="flex items-center justify-between gap-3 flex-wrap mb-2">
          <div>
            <div class="text-sm font-bold text-navy">${I.trailTitle}</div>
            <div class="text-[12px] text-slate-500">${I.trailCoursesOf.replace('{completed}', String(completed.length)).replace('{total}', String(totalCourses))}</div>
          </div>
          <span class="text-[11px] font-bold px-2 py-1 rounded-full ${pct >= 100 ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700'}">
            ${I.trailPctComplete.replace('{pct}', String(pct))}
          </span>
        </div>
        <div class="h-2 bg-slate-100 rounded-full overflow-hidden mb-3">
          <div class="h-full rounded-full transition-all duration-500" style="width:${pct}%;background:${pct >= 100 ? '#10B981' : '#FF610F'}"></div>
        </div>
        <div class="text-[12px] text-slate-500">
          ${missing.length === 0
            ? I.trailComplete
            : `${I.trailMissing.replace('{n}', String(missing.length))} ${missing.map((c: any) => c.name).join(' · ')}`}
          ${inProgress.length > 0 ? `<br>${I.trailInProgress}${inProgress.map((c: any) => c.name).join(' · ')}` : ''}
        </div>
      `;
    } catch (e: any) {
      host.innerHTML = `<p class="text-crimson text-sm text-center py-2">${I.trailError}${e?.message || I.msgFailUnexpected}</p>`;
    }
  }

  // ── SYNC POINTS (admin) ──
  async function syncPoints() {
    const btn = document.getElementById('btn-sync') as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = I.syncBtnSyncing; }
    try {
      await sb.auth.refreshSession();
      const { data: { session } } = await sb.auth.getSession();
      if (!session?.access_token) {
        throw new Error(I.msgInvalidSession);
      }
      let attendanceSummary = '';
      const { data: attendanceData, error: attendanceError } = await sb.functions.invoke('sync-attendance-points', {
        headers: { Authorization: `Bearer ${session.access_token}` },
      });
      if (attendanceError || !attendanceData?.success) {
        const attendanceMsg = attendanceError
          ? await describeFnError(attendanceError)
          : (attendanceData?.error || I.syncAttendanceFail);
        attendanceSummary = `${I.syncAttendanceError}${attendanceMsg}.`;
      } else {
        attendanceSummary = I.syncAttendanceSuccess.replace('{n}', String(attendanceData.points_created));
      }

      let credlySummary = '';
      const { data: credlyData, error: credlyError } = await sb.functions.invoke('sync-credly-all', {
        headers: { Authorization: `Bearer ${session.access_token}` },
      });
      if (!credlyError && credlyData?.success) {
        credlySummary = I.syncCredlySuccess.replace('{success}', String(credlyData.success_count)).replace('{total}', String(credlyData.total_candidates)).replace('{fail}', String(credlyData.fail_count));
      } else if (credlyError) {
        credlySummary = `${I.syncCredlyBatchError}${await describeFnError(credlyError)}.`;
      } else if (credlyData?.error) {
        credlySummary = `${I.syncCredlyBatchError}${credlyData.error}.`;
      } else {
        credlySummary = I.syncCredlyNotRun;
      }

      const isPartialError = attendanceSummary.includes(I.syncAttendanceError) || credlySummary.includes(I.syncCredlyBatchError);
      toast(`${attendanceSummary} ${credlySummary}`, isPartialError ? 'info' : 'success');
      loadLeaderboard();
      loadMyTrailClarity();
    } catch (e: any) {
      toast(`${I.msgSyncError}${e?.message || I.msgUnknownError}`, 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = I.syncBtn; }
    }
  }

  // ── ISSUE CERTIFICATE (admin) ──
  async function issueCertificate() {
    const memberId = (document.getElementById('cert-member') as HTMLSelectElement).value;
    const type = (document.getElementById('cert-type') as HTMLSelectElement).value;
    const title = (document.getElementById('cert-title') as HTMLInputElement).value.trim();
    const desc = (document.getElementById('cert-desc') as HTMLTextAreaElement).value.trim() || null;
    const cycle = parseInt((document.getElementById('cert-cycle') as HTMLInputElement).value);

    if (!memberId || !title) { toast(I.certFillFields, 'error'); return; }

    const { error } = await sb.from('certificates').insert({
      member_id: memberId, type, title, description: desc, cycle, issued_by: MEMBER.id,
    });

    if (error) { toast(I.msgErrorPrefix + error.message, 'error'); return; }
    toast(I.certIssued, 'success');
    (document.getElementById('cert-title') as HTMLInputElement).value = '';
    (document.getElementById('cert-desc') as HTMLTextAreaElement).value = '';
  }

  // ── LOAD MEMBERS FOR CERT DROPDOWN ──
  async function loadMembersDropdown() {
    const { data } = await sb.from('members')
      .select('id, name')
      .eq('current_cycle_active', true)
      .order('name');
    const sel = document.getElementById('cert-member') as HTMLSelectElement;
    if (sel && data) {
      sel.innerHTML = `<option value="">${I.certSelect}</option>` +
        data.map((m: any) => `<option value="${m.id}">${m.name}</option>`).join('');
    }
  }

  // ── BOOT ──
  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest') {
        MEMBER = e.detail;
        setupUI();
      }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') {
      MEMBER = m;
      setupUI();
      return;
    }

    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && getMemberRole(data) !== 'guest') {
        MEMBER = data;
        setupUI();
        return;
      }
    }

    // Not logged in — show leaderboard only
    loadLeaderboard();
  }

  function setupUI() {
    const isAdmin = MEMBER.is_superadmin;
    document.getElementById('trail-clarity-card')?.classList.remove('hidden');
    document.getElementById('tab-achievements')?.classList.remove('hidden');
    document.getElementById('tab-mypoints')?.classList.remove('hidden');
    document.getElementById('tab-mycerts')?.classList.remove('hidden');
    if (isAdmin) {
      document.getElementById('btn-sync')?.classList.remove('hidden');
      document.getElementById('tab-admin-certs')?.classList.remove('hidden');
    }
    loadLeaderboard();
    loadMyTrailClarity();
    loadMembersDropdown();
  }

  // ── CENTRALIZED EVENT DELEGATION ──
  document.addEventListener('click', (e: Event) => {
    const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
    if (!target) return;

    switch (target.dataset.action) {
      case 'sync-points':
        syncPoints();
        break;
      case 'switch-tab': {
        const tab = target.dataset.tab;
        if (tab) switchGamTab(target, tab);
        break;
      }
      case 'set-leaderboard-mode': {
        const mode = target.dataset.mode as 'cycle' | 'lifetime';
        if (mode) setLeaderboardMode(mode);
        break;
      }
      case 'set-tribe-mode': {
        const mode = target.dataset.mode as 'cycle' | 'lifetime';
        if (mode) setTribeMode(mode);
        break;
      }
      case 'issue-certificate':
        issueCertificate();
        break;
    }
  });

  boot();
</script>
