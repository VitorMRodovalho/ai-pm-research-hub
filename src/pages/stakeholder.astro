---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import ChapterDashboard from '../components/chapter/ChapterDashboard';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---

<BaseLayout title={t('stakeholder.title', lang) || 'Chapter Dashboard'} activePage="stakeholder">
  <Toast />
  <div id="stakeholder-denied" class="hidden max-w-lg mx-auto px-4 py-20 text-center">
    <div class="text-4xl mb-4">🔒</div>
    <p class="text-sm text-[var(--text-secondary)]">{t('stakeholder.accessDenied', lang) || 'Access restricted to chapter sponsors and leadership.'}</p>
  </div>
  <div id="stakeholder-loading" class="max-w-lg mx-auto px-4 py-20 text-center">
    <p class="text-sm text-[var(--text-muted)]">{t('common.loading', lang) || 'Loading...'}</p>
  </div>
  <div id="stakeholder-app" class="hidden max-w-[1100px] mx-auto px-4 py-8">
    <ChapterDashboard client:load lang={lang} stakeholderMode={true} />
  </div>
</BaseLayout>

<script>
  function boot() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    const check = () => {
      const m = (window as any).navGetMember?.();
      if (!m) { setTimeout(check, 300); return; }

      const allowed = m.is_superadmin === true
        || ['manager', 'deputy_manager'].includes(m.operational_role || '')
        || (m.designations || []).some((d: string) => ['sponsor', 'chapter_liaison'].includes(d));

      const loading = document.getElementById('stakeholder-loading');
      if (loading) loading.classList.add('hidden');

      if (!allowed) {
        document.getElementById('stakeholder-denied')?.classList.remove('hidden');
        return;
      }
      document.getElementById('stakeholder-app')?.classList.remove('hidden');
    };

    window.addEventListener('nav:member', ((e: CustomEvent) => { if (e.detail) check(); }) as EventListener);
    check();
  }
  boot();
</script>
