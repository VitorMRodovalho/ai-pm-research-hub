---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import { getHomeSchedule } from '../../lib/schedule';
import AgendaSection from '../../components/sections/AgendaSection.astro';
import QuadrantsSection from '../../components/sections/QuadrantsSection.astro';
import TribesSection from '../../components/sections/TribesSection.astro';
import KpiSection from '../../components/sections/KpiSection.astro';
import NetworkingSection from '../../components/sections/NetworkingSection.astro';
import RulesSection from '../../components/sections/RulesSection.astro';
import TrailSection from '../../components/sections/TrailSection.astro';
import CpmaiSection from '../../components/sections/CpmaiSection.astro';
import TeamSection from '../../components/sections/TeamSection.astro';
import VisionSection from '../../components/sections/VisionSection.astro';
import ResourcesSection from '../../components/sections/ResourcesSection.astro';
import { t } from '../../i18n/utils';

const lang = 'en-US' as const;
const homeSchedule = await getHomeSchedule();
const deadlineIso = homeSchedule?.selectionDeadlineAt ?? null;
---
<BaseLayout title={t('meta.title', lang)} activePage="home" lang={lang}>
  <Toast />
  <HeroSection deadline={deadlineIso} schedule={homeSchedule} lang={lang} />
  <AgendaSection deadline={deadlineIso} lang={lang} />
  <QuadrantsSection lang={lang} />
  <TribesSection deadline={deadlineIso} lang={lang} />
  <KpiSection lang={lang} />
  <NetworkingSection lang={lang} />
  <RulesSection lang={lang} />
  <TrailSection lang={lang} />
  <CpmaiSection lang={lang} />
  <TeamSection lang={lang} />
  <VisionSection lang={lang} />
  <ResourcesSection deadline={deadlineIso} lang={lang} />
  <footer class="bg-[#200F3B] text-white/40 py-10 px-6 text-center text-[.78rem]">
    <p>{t('footer.line1', lang)}</p>
    <p class="mt-1">{t('footer.chapters', lang)}</p>
    <p class="mt-2 text-[.68rem]">{t('footer.trademarks', lang)}</p>
    <p class="mt-1">
      <a href="https://github.com/VitorMRodovalho/ai-pm-research-hub" class="text-[#05BFE0] no-underline hover:underline">GitHub</a>
      · {t('footer.gp', lang)}
    </p>
  </footer>
</BaseLayout>
