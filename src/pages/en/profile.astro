---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
const lang = 'en-US' as const;
---
<BaseLayout title={t('profile.title', lang)} activePage="profile" lang={lang}>
  <meta http-equiv="refresh" content="0;url=/profile?lang=en-US">
  <div class="flex items-center justify-center min-h-[60vh]">
    <p class="text-slate-400 text-sm">{t('common.loading', lang)}</p>
  </div>
</BaseLayout>
