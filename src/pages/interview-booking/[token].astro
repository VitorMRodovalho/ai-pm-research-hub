---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { createClient } from '@supabase/supabase-js';

export const prerender = false;

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);

const { token } = Astro.params;

let payload: any = null;
let errorMessage: string | null = null;

if (!token || token.length < 16) {
  errorMessage = 'invalid_token_format';
} else {
  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const sb = createClient(supabaseUrl, supabaseAnonKey);

  try {
    const { data, error } = await sb.rpc('validate_interview_booking_token', { p_token: token });
    if (error) {
      errorMessage = error.message?.includes('Invalid or expired') ? 'invalid_or_expired'
        : error.message?.includes('does not have interview_booking') ? 'wrong_scope'
        : `rpc_error: ${error.message}`;
    } else {
      payload = data;
    }
  } catch (e: any) {
    errorMessage = `network_error: ${e?.message ?? 'unknown'}`;
  }
}

const calendarBaseUrl = 'https://calendar.app.google/gh9WjefjcmisVLoh7';

const pageTitle = t('interview.booking.meta.title', lang);
const pageDesc = t('interview.booking.meta.description', lang);

const formattedExpiry = payload?.expires_at
  ? new Date(payload.expires_at).toLocaleDateString(lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es' : 'pt-BR', {
      day: '2-digit', month: 'long', year: 'numeric'
    })
  : null;
---

<BaseLayout title={pageTitle} description={pageDesc} lang={lang}>
  <main class="max-w-2xl mx-auto px-4 py-8 md:py-12">
    {errorMessage ? (
      <div class="bg-red-50 border border-red-200 rounded-lg p-6 text-red-800">
        <h1 class="text-2xl font-bold mb-3">{t('interview.booking.error.expiredTitle', lang)}</h1>
        <p class="mb-4">{t('interview.booking.error.expiredBody', lang)}</p>
        <p class="text-sm font-mono text-red-700">code: {errorMessage}</p>
        <p class="mt-4">
          <a href="mailto:nucleoia@pmigo.org.br" class="underline">nucleoia@pmigo.org.br</a>
        </p>
      </div>
    ) : (
      <div class="space-y-6">
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
          <h1 class="text-2xl font-bold mb-2 text-blue-900">
            {t('interview.booking.greeting', lang)}, {payload?.first_name ?? ''}
          </h1>
          <p class="text-lg text-blue-800">{t('interview.booking.ready', lang)}</p>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
          <p class="text-slate-700 mb-6">{t('interview.booking.instruction', lang)}</p>
          <a
            href={calendarBaseUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
          >
            {t('interview.booking.cta', lang)} →
          </a>

          {formattedExpiry && (
            <p class="text-sm text-slate-500 mt-6">
              {t('interview.booking.expiresAt', lang)} <strong>{formattedExpiry}</strong>
            </p>
          )}
        </div>

        <div class="text-sm text-slate-600">
          <p>
            {t('interview.booking.questions', lang)}:{' '}
            <a href="mailto:nucleoia@pmigo.org.br" class="text-blue-600 underline">nucleoia@pmigo.org.br</a>
          </p>
        </div>
      </div>
    )}
  </main>
</BaseLayout>
