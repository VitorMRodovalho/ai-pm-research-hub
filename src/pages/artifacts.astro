---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import LoadingSkeleton from '../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const tribeOptions = Array.from({length: 8}, (_, i) => ({
  value: String(i + 1),
  label: `${String(i + 1).padStart(2, '0')} — ${t(`data.tribe${i + 1}.name`, lang)}`,
}));
const ARTIFACTS_I18N = {
  typeLabels: {
    article: t('artifacts.typeLabel.article', lang),
    ebook: t('artifacts.typeLabel.ebook', lang),
    framework: t('artifacts.typeLabel.framework', lang),
    presentation: t('artifacts.typeLabel.presentation', lang),
    video: t('artifacts.typeLabel.video', lang),
    toolkit: t('artifacts.typeLabel.toolkit', lang),
    other: t('artifacts.typeLabel.other', lang),
  },
  statusLabels: {
    draft: t('artifacts.draft', lang),
    review: t('artifacts.review', lang),
    approved: t('artifacts.status.approved', lang),
    published: t('artifacts.published', lang),
  },
  tribeNames: Object.fromEntries(
    Array.from({length: 8}, (_, i) => [i + 1, t(`data.tribe${i + 1}.name`, lang)])
  ),
  emptyCatalogTitle: t('artifacts.empty.catalogTitle', lang),
  emptyCatalogMsgAuth: t('artifacts.empty.catalogMsgAuth', lang),
  emptyCatalogMsgAnon: t('artifacts.empty.catalogMsgAnon', lang),
  emptyCatalogCtaAuth: t('artifacts.empty.catalogCtaAuth', lang),
  emptyCatalogCtaAnon: t('artifacts.empty.catalogCtaAnon', lang),
  emptyMineTitle: t('artifacts.empty.mineTitle', lang),
  emptyMineMsg: t('artifacts.empty.mineMsg', lang),
  emptyMineCta: t('artifacts.empty.mineCta', lang),
  emptyReviewTitle: t('artifacts.empty.reviewTitle', lang),
  emptyReviewMsg: t('artifacts.empty.reviewMsg', lang),
  cardOpen: t('artifacts.card.open', lang),
  cardReview: t('artifacts.card.review', lang),
  modalSubmitTitle: t('artifacts.modal.submitTitle', lang),
  modalEditTitle: t('artifacts.modal.editTitle', lang),
  msgTitleRequired: t('artifacts.msg.titleRequired', lang),
  msgErrorPrefix: t('artifacts.msg.errorPrefix', lang),
  msgUpdated: t('artifacts.msg.updated', lang),
  msgSubmitted: t('artifacts.msg.submitted', lang),
  msgReviewSaved: t('artifacts.msg.reviewSaved', lang),
  dateLocale: t('artifacts.dateLocale', lang),
  search: t('artifacts.search', lang),
  filterAll: t('artifacts.filterAll', lang),
  tagAll: t('artifacts.tagAll', lang),
  results: t('artifacts.results', lang),
  uploadValidationTooLarge: t('upload.validation.tooLarge', lang),
  uploadValidationInvalidType: t('upload.validation.invalidType', lang),
};
---
<BaseLayout title={t('artifacts.title', lang)} activePage="artifacts">
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
      <h1 class="text-2xl font-extrabold text-navy">{t('artifacts.heading', lang)}</h1>
      <button id="btn-submit" class="hidden px-4 py-2 bg-teal text-white rounded-xl font-semibold text-sm cursor-pointer border-0 hover:opacity-90 transition-all"
              data-action="open-submit-modal">
        {t('artifacts.submitBtn', lang)}
      </button>
    </div>

    <!-- Guest banner (authenticated but not registered) -->
    <div id="guest-banner" class="hidden mb-6">
      <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-3 flex items-center gap-3">
        <span class="text-amber-600 text-lg flex-shrink-0">ℹ️</span>
        <p class="text-amber-800 text-[.78rem] font-medium flex-1">
          {t('guest.limitedAccess', lang)}
          <a href={`mailto:${t('guest.contactEmail', lang)}`} class="text-amber-800 font-semibold underline ml-1">{t('guest.contactEmail', lang)}</a>
        </p>
      </div>
    </div>

    <!-- Tabs -->
    <div class="flex gap-2 mb-6 flex-wrap">
      <button class="art-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white"
              data-tab="catalog" data-action="switch-tab">{t('artifacts.tab.catalog', lang)}</button>
      <button class="art-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-my" data-tab="mine" data-action="switch-tab">{t('artifacts.tab.mine', lang)}</button>
      <button class="art-tab hidden px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]"
              id="tab-review" data-tab="review" data-action="switch-tab">{t('artifacts.tab.review', lang)}</button>
    </div>

    <!-- Catalog category sub-tabs -->
    <div id="catalog-category" class="flex gap-2 mb-4">
      <button class="cat-sub px-3.5 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
              data-action="cat-sub" data-cat="produced">{t('artifacts.catProduced', lang)}</button>
      <button class="cat-sub px-3.5 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
              data-action="cat-sub" data-cat="reference">{t('artifacts.catReference', lang)}</button>
      <button class="cat-sub px-3.5 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
              data-action="cat-sub" data-cat="">{t('artifacts.catAll', lang)}</button>
    </div>

    <!-- Search + Filters (catalog only) -->
    <div id="catalog-filters" class="space-y-3 mb-4">
      <input id="art-search" type="text"
             class="w-full px-4 py-2.5 rounded-xl border-[1.5px] border-[var(--border-default)] text-sm bg-[var(--surface-card)] focus:outline-none focus:border-navy transition-colors"
             placeholder={t('artifacts.search', lang)} />
      <div class="flex flex-wrap items-center gap-2">
        <div class="flex gap-1.5 flex-wrap" id="art-type-filters"></div>
        <select id="art-tribe-filter"
                class="ml-auto px-3 py-1.5 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy cursor-pointer">
          <option value="">{t('workspace.tribeAll', lang)}</option>
        </select>
      </div>
      <div id="art-tag-bar" class="flex flex-wrap gap-1.5"></div>
      <div id="art-results" class="text-[.7rem] text-[var(--text-muted)]"></div>
    </div>

    <!-- Catalog tab -->
    <div id="panel-catalog">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5" id="catalog-list">
        <LoadingSkeleton variant="row" count={3} />
      </div>
    </div>

    <!-- My artifacts tab -->
    <div id="panel-mine" class="hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5" id="mine-list">
        <LoadingSkeleton variant="row" count={3} />
      </div>
    </div>

    <!-- Review queue tab -->
    <div id="panel-review" class="hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5" id="review-list">
        <LoadingSkeleton variant="row" count={3} />
      </div>
    </div>
  </div>

  <!-- Submit / Edit Modal -->
  <div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-artifact">
    <div class="bg-[var(--surface-elevated)] rounded-2xl w-full max-w-[560px] overflow-hidden flex flex-col" style="max-height:85vh">
      <div class="px-5 py-4 border-b border-[var(--border-default)] flex justify-between items-center flex-shrink-0">
        <h3 class="text-base font-bold text-navy" id="modal-artifact-title">{t('artifacts.modal.submitTitle', lang)}</h3>
        <button class="bg-transparent border-0 text-xl cursor-pointer text-[var(--text-muted)]" data-action="close-art-modal">✕</button>
      </div>
      <div class="p-5 overflow-y-auto flex-1">
        <input type="hidden" id="art-id">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.modal.labelTitle', lang)}</label>
            <input type="text" id="art-title" placeholder={t('artifacts.modal.placeholderTitle', lang)}
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.type', lang)}</label>
            <select id="art-type" class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
              <option value="article">{t('artifacts.type.article', lang)}</option>
              <option value="ebook">{t('artifacts.type.ebook', lang)}</option>
              <option value="framework">{t('artifacts.type.framework', lang)}</option>
              <option value="presentation">{t('artifacts.type.presentation', lang)}</option>
              <option value="video">{t('artifacts.type.video', lang)}</option>
              <option value="toolkit">{t('artifacts.type.toolkit', lang)}</option>
              <option value="other">{t('artifacts.type.other', lang)}</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.tribe', lang)}</label>
            <select id="art-tribe" class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
              <option value="">{t('artifacts.tribe.none', lang)}</option>
              {tribeOptions.map(opt => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </select>
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.modal.labelUrl', lang)}</label>
            <input type="url" id="art-url" placeholder="https://docs.google.com/..."
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.modal.labelDesc', lang)}</label>
            <textarea id="art-desc" rows="3" placeholder={t('artifacts.modal.placeholderDesc', lang)}
                      class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy resize-y"></textarea>
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('upload.label.orFile', lang)}</label>
            <input type="file" id="art-file" accept=".pdf,.pptx,.png,.jpg,.jpeg"
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
            <div id="art-file-error" class="hidden text-[11px] text-crimson font-semibold"></div>
          </div>
        </div>
        <!-- Best Practices Callout -->
        <div class="mt-4 bg-gradient-to-r from-emerald-50 to-teal-50 border border-emerald-200 rounded-lg p-3">
          <div class="flex gap-2.5">
            <div class="flex-shrink-0 w-6 h-6 bg-emerald-100 rounded-md flex items-center justify-center text-emerald-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <h4 class="text-[11px] font-bold text-emerald-800 mb-1">{t('artifacts.bestPractices.title', lang)}</h4>
              <div class="text-[10.5px] text-emerald-700 space-y-0.5">
                <p class="m-0"><span class="font-semibold text-emerald-600">&#x2713;</span> {t('artifacts.bestPractices.valid', lang)}</p>
                <p class="m-0"><span class="font-semibold text-crimson">&#x2717;</span> {t('artifacts.bestPractices.invalid', lang)}</p>
                <p class="m-0 mt-1 text-emerald-600 italic">{t('artifacts.bestPractices.tip', lang)}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="px-5 py-3.5 border-t border-[var(--border-default)] flex justify-end gap-2 flex-shrink-0">
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--overlay-card-hover)] cursor-pointer"
                data-action="close-art-modal">{t('artifacts.modal.cancel', lang)}</button>
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer"
                data-action="save-artifact">{t('artifacts.modal.save', lang)}</button>
      </div>
    </div>
  </div>

  <!-- Review Modal -->
  <div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-review">
    <div class="bg-[var(--surface-elevated)] rounded-2xl w-full max-w-[480px] overflow-hidden flex flex-col">
      <div class="px-5 py-4 border-b border-[var(--border-default)] flex justify-between items-center">
        <h3 class="text-base font-bold text-navy">{t('artifacts.modal.reviewTitle', lang)}</h3>
        <button class="bg-transparent border-0 text-xl cursor-pointer text-[var(--text-muted)]" data-action="close-review-modal">✕</button>
      </div>
      <div class="p-5">
        <input type="hidden" id="rev-id">
        <div class="text-sm font-bold mb-1" id="rev-title-display"></div>
        <div class="text-[12px] text-[var(--text-secondary)] mb-4" id="rev-author-display"></div>
        <div class="flex flex-col gap-1.5 mb-4">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.modal.labelStatus', lang)}</label>
          <select id="rev-status" class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
            <option value="review">{t('artifacts.review', lang)}</option>
            <option value="approved">{t('artifacts.status.approved', lang)}</option>
            <option value="published">{t('artifacts.published', lang)}</option>
            <option value="draft">{t('artifacts.status.returnDraft', lang)}</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('artifacts.modal.labelNotes', lang)}</label>
          <textarea id="rev-notes" rows="3" placeholder={t('artifacts.modal.placeholderNotes', lang)}
                    class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy resize-y"></textarea>
        </div>
      </div>
      <div class="px-5 py-3.5 border-t border-[var(--border-default)] flex justify-end gap-2">
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--overlay-card-hover)] cursor-pointer"
                data-action="close-review-modal">{t('artifacts.modal.cancel', lang)}</button>
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer"
                data-action="submit-review">{t('artifacts.modal.saveReview', lang)}</button>
      </div>
    </div>
  </div>
</BaseLayout>

<!-- define:vars forces is:inline and breaks imports; inject i18n separately -->
<script is:inline define:vars={{ ARTIFACTS_I18N }}>
  window.__ARTIFACTS_I18N = typeof ARTIFACTS_I18N !== 'undefined' ? ARTIFACTS_I18N : {};
</script>
<script>
  import { getMemberRole } from '../lib/routing';
  import { buildTribeLabel, isRuntimeTribeActive } from '../lib/tribes/catalog';

  const I18N = (typeof window !== 'undefined' && (window as any).__ARTIFACTS_I18N) || {};

  let sb: any = null;
  let MEMBER: any = null;
  let allTags: any[] = [];
  let catalogData: any[] = [];
  let activeType = '';
  let activeTribe = '';
  let activeTag = '';
  let searchQuery = '';
  let activeCategory = 'produced';
  let CAN_MANAGE = false;
  let runtimeTribesLoaded = false;

  const PRODUCED_TYPES = ['article', 'framework', 'ebook', 'toolkit'];
  const REFERENCE_TYPES = ['presentation', 'video', 'other'];

  const TYPE_LABELS: Record<string, string> = I18N.typeLabels || {
    article: '📄 Artigo', ebook: '📖 E-book', framework: '🏗️ Framework',
    presentation: '📊 Apresentação', video: '🎬 Vídeo', toolkit: '🧰 Toolkit', other: '📎 Outro'
  };
  const STATUS_LABELS: Record<string, { label: string; bg: string; color: string }> = {
    draft:     { label: I18N.statusLabels?.draft     || 'Rascunho',   bg: '#F1F5F9', color: '#475569' },
    review:    { label: I18N.statusLabels?.review    || 'Em Revisão', bg: '#FEF3C7', color: '#92400E' },
    approved:  { label: I18N.statusLabels?.approved  || 'Aprovado',   bg: '#D1FAE5', color: '#065F46' },
    published: { label: I18N.statusLabels?.published || 'Publicado',  bg: '#DBEAFE', color: '#1E40AF' },
  };
  let TRIBE_NAMES: Record<number, string> = I18N.tribeNames || {
    1: 'Radar Tecnológico', 2: 'Agentes Autônomos', 3: 'TMO & PMO do Futuro',
    4: 'Cultura & Change', 5: 'Talentos & Upskilling', 6: 'ROI & Portfólio',
    7: 'Governança & Trustworthy AI', 8: 'Inclusão & Colaboração'
  };

  function statusBadge(s: string): string {
    const st = STATUS_LABELS[s] || STATUS_LABELS.draft;
    return `<span class="inline-block px-2 py-0.5 rounded-md text-[11px] font-bold" style="background:${st.bg};color:${st.color}">${st.label}</span>`;
  }

  function toast(msg: string, type = '') { (window as any).toast?.(msg, type); }
  function loadingRows(count = 3): string {
    return Array.from({ length: count }).map(() => `
      <div class="flex items-center gap-3 px-1 py-3 border-b border-[var(--border-subtle)] last:border-b-0 animate-pulse">
        <div class="w-9 h-9 rounded-full bg-slate-200 flex-shrink-0"></div>
        <div class="flex-1 space-y-1.5">
          <div class="h-3 w-40 bg-slate-200 rounded"></div>
          <div class="h-2.5 w-56 bg-slate-200 rounded"></div>
        </div>
        <div class="h-6 w-16 rounded-full bg-slate-200"></div>
      </div>
    `).join('');
  }
  function emptyStateHtml(
    icon: string,
    title: string,
    message: string,
    ctaText?: string,
    ctaAction?: string
  ): string {
    const cta = ctaText && ctaAction
      ? `<button data-action="${ctaAction}" class="mt-4 px-4 py-2 bg-navy text-white rounded-xl text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">${ctaText}</button>`
      : '';
    return `
      <div class="text-center py-10">
        <div class="text-4xl mb-2">${icon}</div>
        <div class="font-semibold text-[var(--text-secondary)] text-sm">${title}</div>
        <p class="text-[var(--text-muted)] mt-1 max-w-[360px] mx-auto text-[.78rem]">${message}</p>
        ${cta}
      </div>
    `;
  }

  function fmtDate(d: string): string {
    if (!d) return '';
    return new Date(d).toLocaleDateString(I18N.dateLocale || 'pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  // ── TABS ──
  function switchArtTab(el: HTMLElement, tab: string) {
    document.querySelectorAll('.art-tab').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-[var(--surface-card)]', 'text-[var(--text-secondary)]', 'border-[var(--border-default)]');
    });
    el.classList.remove('bg-[var(--surface-card)]', 'text-[var(--text-secondary)]', 'border-[var(--border-default)]');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    ['catalog', 'mine', 'review'].forEach(p => {
      document.getElementById(`panel-${p}`)?.classList.toggle('hidden', p !== tab);
    });
    if (tab === 'catalog') loadCatalog();
    if (tab === 'mine') loadMyArtifacts();
    if (tab === 'review') loadReviewQueue();
  }

  // ── CATALOG (published) ──
  async function loadCatalog() {
    const el = document.getElementById('catalog-list')!;
    el.innerHTML = loadingRows(3);
    try {
      if (!runtimeTribesLoaded) {
        await loadRuntimeTribes();
        runtimeTribesLoaded = true;
      }
      const [artResp, tagsResp] = await Promise.all([
        sb.from('artifacts')
          .select('*, members!artifacts_member_id_fkey(name, photo_url)')
          .eq('status', 'published')
          .order('published_at', { ascending: false }),
        allTags.length ? Promise.resolve({ data: allTags }) : sb.rpc('list_taxonomy_tags'),
      ]);
      catalogData = artResp.data || [];
      if (!allTags.length && tagsResp.data) allTags = tagsResp.data;

      buildTypeFilters();
      buildTribeSelect();
      buildArtifactTagBar();
      renderCatalogFiltered();
    } catch (e: any) {
      console.warn('Artifacts: failed to load catalog:', e);
      el.innerHTML = '<div class="text-center py-8 text-red-500 text-sm">Failed to load catalog.</div>';
      toast('Failed to load artifact catalog.', 'error');
    }
  }

  // ── MY ARTIFACTS ──
  async function loadMyArtifacts() {
    if (!MEMBER) return;
    const el = document.getElementById('mine-list')!;
    el.innerHTML = loadingRows(3);
    try {
      const { data } = await sb.from('artifacts')
        .select('*')
        .eq('member_id', MEMBER.id)
        .order('created_at', { ascending: false });
      if (!data?.length) {
        el.innerHTML = emptyStateHtml('📝', I18N.emptyMineTitle, I18N.emptyMineMsg, I18N.emptyMineCta, 'open-submit-modal');
        return;
      }
      el.innerHTML = data.map((a: any) => artifactCard(a, true)).join('');
    } catch (e) {
      console.warn('Artifacts: failed to load my artifacts:', e);
      el.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">Failed to load your artifacts. Please try again later.</div>`;
      toast('Failed to load your artifacts.', 'error');
    }
  }

  // ── REVIEW QUEUE ──
  async function loadReviewQueue() {
    const el = document.getElementById('review-list')!;
    el.innerHTML = loadingRows(3);
    try {
      const { data } = await sb.from('artifacts')
        .select('*, members!artifacts_member_id_fkey(name, photo_url)')
        .in('status', ['draft', 'review'])
        .order('submitted_at', { ascending: true });
      if (!data?.length) {
        el.innerHTML = emptyStateHtml('✅', I18N.emptyReviewTitle, I18N.emptyReviewMsg);
        return;
      }
      el.innerHTML = data.map((a: any) => artifactCard(a, false, true)).join('');
    } catch (e) {
      console.warn('Artifacts: failed to load review queue:', e);
      el.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">Failed to load review queue. Please try again later.</div>`;
      toast('Failed to load review queue.', 'error');
    }
  }

  const esc = (s: string) => String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  const TAG_COLORS: Record<string, string> = {
    research:   'bg-purple-50 text-purple-700 border-purple-200',
    education:  'bg-blue-50 text-blue-700 border-blue-200',
    community:  'bg-green-50 text-green-700 border-green-200',
    innovation: 'bg-amber-50 text-amber-700 border-amber-200',
    impact:     'bg-rose-50 text-rose-700 border-rose-200',
    governance: 'bg-slate-100 text-slate-700 border-slate-200',
  };

  function tagColor(tagKey: string): string {
    var tag = allTags.find(function(t: any) { return t.tag_key === tagKey; });
    return tag ? (TAG_COLORS[tag.category] || TAG_COLORS.governance) : 'bg-slate-50 text-slate-600 border-slate-200';
  }

  function getFilteredCatalog(): any[] {
    var filtered = catalogData;
    if (activeCategory === 'produced') filtered = filtered.filter(function(a) { return PRODUCED_TYPES.includes(a.type); });
    if (activeCategory === 'reference') filtered = filtered.filter(function(a) { return REFERENCE_TYPES.includes(a.type); });
    if (activeType) filtered = filtered.filter(function(a) { return a.type === activeType; });
    if (activeTribe) filtered = filtered.filter(function(a) { return String(a.tribe_id) === activeTribe; });
    if (activeTag) filtered = filtered.filter(function(a) { return (a.tags || []).includes(activeTag); });
    if (searchQuery) {
      var q = searchQuery.toLowerCase();
      filtered = filtered.filter(function(a) {
        return (a.title || '').toLowerCase().includes(q)
          || (a.members?.name || '').toLowerCase().includes(q)
          || (a.tags || []).some(function(t: string) { return t.toLowerCase().includes(q); });
      });
    }
    return filtered;
  }

  function renderCatalogFiltered() {
    var el = document.getElementById('catalog-list')!;
    var filtered = getFilteredCatalog();
    var resultsEl = document.getElementById('art-results');
    if (resultsEl) resultsEl.textContent = (I18N.results || '{n} artefato(s)').replace('{n}', String(filtered.length));
    if (!filtered.length) {
      el.innerHTML = MEMBER
        ? emptyStateHtml('&#x1F4DA;', I18N.emptyCatalogTitle, I18N.emptyCatalogMsgAuth, I18N.emptyCatalogCtaAuth, 'open-submit-modal')
        : emptyStateHtml('&#x1F4DA;', I18N.emptyCatalogTitle, I18N.emptyCatalogMsgAnon, I18N.emptyCatalogCtaAnon, 'open-auth');
      return;
    }
    el.innerHTML = filtered.map(function(a: any) { return artifactCard(a, false); }).join('');
  }

  function buildArtifactTagBar() {
    var bar = document.getElementById('art-tag-bar');
    if (!bar || !allTags.length) return;
    var usedTags = new Set<string>();
    catalogData.forEach(function(a) { (a.tags || []).forEach(function(t: string) { usedTags.add(t); }); });
    if (!usedTags.size) { bar.innerHTML = ''; return; }
    bar.innerHTML = allTags
      .filter(function(t: any) { return usedTags.has(t.tag_key); })
      .map(function(t: any) {
        var color = TAG_COLORS[t.category] || TAG_COLORS.governance;
        var activeClass = activeTag === t.tag_key ? ' ring-2 ring-navy ring-offset-1' : '';
        return '<button class="art-tag-chip px-2 py-1 rounded-lg text-[.65rem] font-semibold border cursor-pointer transition-all '
          + color + activeClass + '" data-action="art-filter-tag" data-tag="' + esc(t.tag_key) + '">'
          + esc(t.label_pt || t.tag_key) + '</button>';
      }).join('');
  }

  function buildTypeFilters() {
    var el = document.getElementById('art-type-filters');
    if (!el) return;
    var types = ['article', 'ebook', 'framework', 'presentation', 'video', 'toolkit', 'other'];
    el.innerHTML = '<button class="art-type-btn px-3 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border-2 '
      + (!activeType ? 'border-navy bg-navy text-white' : 'border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]')
      + ' transition-all" data-action="art-filter-type" data-type="">' + (I18N.filterAll || 'Todos') + '</button>'
      + types.map(function(t) {
        var active = activeType === t;
        return '<button class="art-type-btn px-3 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border-2 '
          + (active ? 'border-navy bg-navy text-white' : 'border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]')
          + ' transition-all" data-action="art-filter-type" data-type="' + t + '">' + (TYPE_LABELS[t] || t) + '</button>';
      }).join('');
  }

  function buildTribeSelect() {
    var sel = document.getElementById('art-tribe-filter') as HTMLSelectElement;
    if (!sel) return;
    var tribeIds = [...new Set(catalogData.map(function(a) { return a.tribe_id; }).filter(Boolean))].sort(function(a: number, b: number) { return a - b; });
    while (sel.options.length > 1) sel.remove(1);
    tribeIds.forEach(function(id) {
      var opt = document.createElement('option');
      opt.value = String(id);
      opt.textContent = String(id).padStart(2, '0') + ' — ' + buildTribeLabel({ id, name: TRIBE_NAMES[id] }, { prefix: 'Tribo', fallbackNames: TRIBE_NAMES });
      sel.appendChild(opt);
    });
  }

  async function loadRuntimeTribes() {
    if (!sb) return;
    try {
      const { data, error } = await sb.from('tribes').select('id, name, is_active').order('id');
      if (error) throw error;
      (data || []).forEach(function(tribe: any) {
        if (isRuntimeTribeActive(tribe)) {
          TRIBE_NAMES[tribe.id] = buildTribeLabel(tribe, { prefix: 'Tribo', fallbackNames: TRIBE_NAMES });
        }
      });
    } catch (error) {
      console.warn('artifacts tribes:', error);
    }
  }

  function artifactCard(a: any, showEdit = false, showReview = false): string {
    (window as any).__artifactsById = (window as any).__artifactsById || {};
    (window as any).__artifactsById[a.id] = a;

    const author = a.members?.name || '—';
    const tribe = a.tribe_id ? TRIBE_NAMES[a.tribe_id] || '' : '';
    const typeLabel = TYPE_LABELS[a.type] || a.type;
    const urlLink = a.url ? `<a href="${a.url}" target="_blank" rel="noopener" class="text-teal text-[12px] font-semibold no-underline hover:underline">${I18N.cardOpen}</a>` : '';

    return `
    <div class="py-3.5 border-b border-[var(--border-subtle)] last:border-b-0">
      <div class="flex items-start gap-3">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-sm font-semibold">${a.title}</span>
            ${statusBadge(a.status)}
            <span class="text-[11px] text-[var(--text-muted)]">${typeLabel}</span>
          </div>
          <div class="text-[12px] text-[var(--text-secondary)] mt-1">
            ${author}${tribe ? ` · ${tribe}` : ''} · ${fmtDate(a.submitted_at)}
            ${urlLink ? ` · ${urlLink}` : ''}
          </div>
          ${a.description ? `<div class="text-[12px] text-[var(--text-secondary)] mt-1">${a.description}</div>` : ''}
          ${a.review_notes ? `<div class="text-[12px] text-amber-700 bg-amber-50 px-2 py-1 rounded mt-1">💬 ${a.review_notes}</div>` : ''}
          ${(a.tags || []).length ? '<div class="flex flex-wrap gap-1 mt-1.5">' + (a.tags || []).map(function(t: string) { return '<span class="px-1.5 py-0.5 rounded text-[.6rem] font-semibold border ' + tagColor(t) + '">' + esc(t) + '</span>'; }).join('') + '</div>' : ''}
        </div>
        <div class="flex gap-1.5 flex-shrink-0">
          ${showEdit && a.status === 'draft' ? `<button type="button" class="btn-edit-artifact px-2.5 py-1.5 text-[12px] bg-[var(--surface-base)] border border-[var(--border-default)] rounded-md cursor-pointer font-semibold" data-artifact-id="${esc(a.id)}">✏️</button>` : ''}
          ${showReview ? `<button type="button" class="btn-review-artifact px-2.5 py-1.5 text-[12px] bg-amber-50 border border-amber-200 rounded-md cursor-pointer font-semibold text-amber-800" data-artifact-id="${esc(a.id)}">${I18N.cardReview}</button>` : ''}
          ${CAN_MANAGE && !showEdit ? `<button type="button" class="btn-inline-tags px-2.5 py-1.5 text-[12px] bg-purple-50 border border-purple-200 rounded-md cursor-pointer font-semibold text-purple-700" data-artifact-id="${esc(a.id)}">🏷️</button>` : ''}
        </div>
      </div>
      <div class="art-inline-tag-editor hidden mt-3 p-3 bg-[var(--surface-base)] rounded-lg" data-artifact-id="${esc(a.id)}"></div>
    </div>`;
  }

  // ── SUBMIT / EDIT MODAL ──
  const ART_MAX_FILE_SIZE = 15 * 1024 * 1024;
  const ART_ALLOWED_EXTS = ['.pdf', '.pptx', '.png', '.jpg', '.jpeg'];
  const ART_MIME_MAP: Record<string, string> = {
    '.pdf': 'application/pdf',
    '.pptx': 'application/vnd.openxmlformats-officedocument.presentationml.presentation',
    '.png': 'image/png', '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg',
  };

  function validateArtFile(file: File): string | null {
    const ext = '.' + file.name.split('.').pop()!.toLowerCase();
    if (!ART_ALLOWED_EXTS.includes(ext)) return I18N.uploadValidationInvalidType || 'Invalid file type.';
    if (file.size > ART_MAX_FILE_SIZE) return I18N.uploadValidationTooLarge || 'File exceeds 15 MB.';
    return null;
  }

  const artFileInput = document.getElementById('art-file') as HTMLInputElement | null;
  const artFileError = document.getElementById('art-file-error') as HTMLElement | null;
  if (artFileInput) {
    artFileInput.addEventListener('change', () => {
      const file = artFileInput.files?.[0];
      if (!file) { artFileError?.classList.add('hidden'); return; }
      const err = validateArtFile(file);
      if (err) {
        if (artFileError) { artFileError.textContent = err; artFileError.classList.remove('hidden'); }
        artFileInput.value = '';
      } else {
        artFileError?.classList.add('hidden');
      }
    });
  }

  function openSubmitModal() {
    (document.getElementById('art-id') as HTMLInputElement).value = '';
    (document.getElementById('art-title') as HTMLInputElement).value = '';
    (document.getElementById('art-type') as HTMLSelectElement).value = 'article';
    (document.getElementById('art-tribe') as HTMLSelectElement).value = MEMBER?.tribe_id?.toString() || '';
    (document.getElementById('art-url') as HTMLInputElement).value = '';
    (document.getElementById('art-desc') as HTMLTextAreaElement).value = '';
    if (artFileInput) artFileInput.value = '';
    artFileError?.classList.add('hidden');
    document.getElementById('modal-artifact-title')!.textContent = I18N.modalSubmitTitle;
    const modal = document.getElementById('modal-artifact')!;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function editArtifact(a: any) {
    (document.getElementById('art-id') as HTMLInputElement).value = a.id;
    (document.getElementById('art-title') as HTMLInputElement).value = a.title || '';
    (document.getElementById('art-type') as HTMLSelectElement).value = a.type || 'article';
    (document.getElementById('art-tribe') as HTMLSelectElement).value = a.tribe_id?.toString() || '';
    (document.getElementById('art-url') as HTMLInputElement).value = a.url || '';
    (document.getElementById('art-desc') as HTMLTextAreaElement).value = a.description || '';
    document.getElementById('modal-artifact-title')!.textContent = I18N.modalEditTitle;
    const modal = document.getElementById('modal-artifact')!;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeArtModal() {
    const modal = document.getElementById('modal-artifact')!;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  if (!(window as any).__artifactsDelegationBound) {
    (window as any).__artifactsDelegationBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      const target = e.target as HTMLElement;
      const actionEl = target.closest('[data-action]') as HTMLElement | null;
      if (actionEl) {
        const action = actionEl.dataset.action;
        if (action === 'open-submit-modal') { openSubmitModal(); return; }
        if (action === 'switch-tab') {
          const tab = actionEl.dataset.tab;
          if (tab) switchArtTab(actionEl, tab);
          return;
        }
        if (action === 'close-art-modal') { closeArtModal(); return; }
        if (action === 'save-artifact') { saveArtifact(); return; }
        if (action === 'close-review-modal') { closeReviewModal(); return; }
        if (action === 'submit-review') { submitReview(); return; }
        if (action === 'open-auth') {
          document.dispatchEvent(new CustomEvent('open-auth'));
          return;
        }
      }
      const editBtn = target.closest('.btn-edit-artifact');
      if (editBtn) {
        const id = editBtn.getAttribute('data-artifact-id') || '';
        const a = (window as any).__artifactsById?.[id];
        if (a) editArtifact(a);
        return;
      }
      const reviewBtn = target.closest('.btn-review-artifact');
      if (reviewBtn) {
        const id = reviewBtn.getAttribute('data-artifact-id') || '';
        const a = (window as any).__artifactsById?.[id];
        if (a) openReview(a);
        return;
      }
      const inlineTagBtn = target.closest('.btn-inline-tags');
      if (inlineTagBtn) {
        const id = inlineTagBtn.getAttribute('data-artifact-id') || '';
        toggleInlineTagEditor(id);
        return;
      }
      if (target.closest('.art-save-tags-btn')) {
        const editor = target.closest('.art-inline-tag-editor') as HTMLElement;
        if (editor) saveInlineTags(editor);
        return;
      }
    });
  }

  async function saveArtifact() {
    const id = (document.getElementById('art-id') as HTMLInputElement).value;
    const title = (document.getElementById('art-title') as HTMLInputElement).value.trim();
    const type = (document.getElementById('art-type') as HTMLSelectElement).value;
    const tribeVal = (document.getElementById('art-tribe') as HTMLSelectElement).value;
    let url: string | null = (document.getElementById('art-url') as HTMLInputElement).value.trim() || null;
    const desc = (document.getElementById('art-desc') as HTMLTextAreaElement).value.trim() || null;
    const fileInput = document.getElementById('art-file') as HTMLInputElement | null;
    const file = fileInput?.files?.[0] || null;

    if (!title) { toast(I18N.msgTitleRequired, 'error'); return; }

    if (file) {
      const validationErr = validateArtFile(file);
      if (validationErr) { toast(validationErr, 'error'); return; }

      const ext = '.' + file.name.split('.').pop()!.toLowerCase();
      const contentType = ART_MIME_MAP[ext] || 'application/octet-stream';
      const fileName = Date.now() + '_' + file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
      const storagePath = 'knowledge-pdfs/' + fileName;

      const { error: uploadErr } = await sb.storage.from('documents').upload(storagePath, file, { contentType, upsert: false });
      if (uploadErr) { toast(I18N.msgErrorPrefix + uploadErr.message, 'error'); return; }

      const { data: urlData } = sb.storage.from('documents').getPublicUrl(storagePath);
      url = urlData?.publicUrl || url;
    }

    const payload = {
      title, type, url, description: desc,
      tribe_id: tribeVal ? parseInt(tribeVal) : null,
      member_id: MEMBER.id,
      status: 'draft',
    };

    let error;
    if (id) {
      const res = await sb.from('artifacts').update({
        title, type, url, description: desc,
        tribe_id: tribeVal ? parseInt(tribeVal) : null,
        updated_at: new Date().toISOString(),
      }).eq('id', id);
      error = res.error;
    } else {
      const res = await sb.from('artifacts').insert(payload);
      error = res.error;
    }

    if (error) { toast(I18N.msgErrorPrefix + error.message, 'error'); return; }
    closeArtModal();
    toast(id ? I18N.msgUpdated : I18N.msgSubmitted, 'success');
    loadMyArtifacts();
  }

  // ── REVIEW MODAL ──
  function openReview(a: any) {
    (document.getElementById('rev-id') as HTMLInputElement).value = a.id;
    document.getElementById('rev-title-display')!.textContent = a.title;
    document.getElementById('rev-author-display')!.textContent = a.members?.name || '—';
    (document.getElementById('rev-status') as HTMLSelectElement).value = a.status === 'draft' ? 'review' : 'approved';
    (document.getElementById('rev-notes') as HTMLTextAreaElement).value = '';
    const modal = document.getElementById('modal-review')!;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }

  function closeReviewModal() {
    const modal = document.getElementById('modal-review')!;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }

  async function submitReview() {
    const id = (document.getElementById('rev-id') as HTMLInputElement).value;
    const status = (document.getElementById('rev-status') as HTMLSelectElement).value;
    const notes = (document.getElementById('rev-notes') as HTMLTextAreaElement).value.trim() || null;

    const updatePayload: any = {
      status,
      review_notes: notes,
      reviewed_by: MEMBER.id,
      reviewed_at: new Date().toISOString(),
      updated_at: new Date().toISOString(),
    };
    if (status === 'published') {
      updatePayload.published_at = new Date().toISOString();
    }

    const { error } = await sb.from('artifacts').update(updatePayload).eq('id', id);
    if (error) { toast(I18N.msgErrorPrefix + error.message, 'error'); return; }
    closeReviewModal();
    toast(I18N.msgReviewSaved, 'success');
    loadReviewQueue();
  }

  // ── INLINE TAG EDITOR ──
  function toggleInlineTagEditor(artifactId: string) {
    const editors = document.querySelectorAll('.art-inline-tag-editor');
    editors.forEach(e => {
      const el = e as HTMLElement;
      if (el.dataset.artifactId !== artifactId) el.classList.add('hidden');
    });
    const editor = document.querySelector(`.art-inline-tag-editor[data-artifact-id="${artifactId}"]`) as HTMLElement;
    if (!editor) return;
    const wasHidden = editor.classList.contains('hidden');
    if (!wasHidden) { editor.classList.add('hidden'); return; }

    const artifact = (window as any).__artifactsById?.[artifactId];
    const currentTags = artifact?.tags || [];
    editor.innerHTML = '<div class="flex flex-wrap gap-1.5 mb-2">'
      + allTags.map((t: any) => {
        const checked = currentTags.includes(t.tag_key);
        return '<label class="flex items-center gap-1 px-2 py-1 rounded-lg text-[11px] cursor-pointer '
          + (checked ? tagColor(t.tag_key) : 'bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-secondary)]')
          + '"><input type="checkbox" value="' + esc(t.tag_key) + '"'
          + (checked ? ' checked' : '') + ' class="w-3 h-3 rounded" />' + esc(t.label_pt || t.tag_key) + '</label>';
      }).join('') + '</div>'
      + '<button class="art-save-tags-btn px-3 py-1.5 bg-purple-600 text-white rounded-lg text-[12px] font-semibold cursor-pointer border-0 hover:opacity-90">Salvar Tags</button>';
    editor.classList.remove('hidden');
  }

  async function saveInlineTags(editor: HTMLElement) {
    const artifactId = editor.dataset.artifactId || '';
    if (!artifactId) {
      toast('Item inválido para atualização de tags.', 'error');
      return;
    }
    const selected = Array.from(editor.querySelectorAll('input:checked')).map(i => (i as HTMLInputElement).value);
    try {
      const { error } = await sb.rpc('curate_item', {
        p_table: 'artifacts', p_id: artifactId, p_action: 'update_tags', p_tags: selected
      });
      if (error) throw new Error(error.message);
      const artifact = (window as any).__artifactsById?.[artifactId];
      if (artifact) artifact.tags = selected;
      editor.classList.add('hidden');
      toast('Tags atualizadas!', 'success');
      renderCatalogFiltered();
    } catch (e: any) {
      const msg = String(e?.message || '');
      if (msg.includes('invalid input syntax for type uuid') || msg.includes('22P02')) {
        toast('Não foi possível atualizar as tags: identificador do artefato inválido.', 'error');
        return;
      }
      toast(msg || 'Erro ao salvar tags', 'error');
    }
  }

  // ── BOOT ──
  // ── Filter event wiring ──
  if (!(window as any).__artifactFiltersBound) {
    (window as any).__artifactFiltersBound = true;
    document.addEventListener('click', function(e: MouseEvent) {
      var target = e.target as HTMLElement;
      var actionEl = target.closest('[data-action]') as HTMLElement | null;
      if (!actionEl) return;
      var action = actionEl.dataset.action;
      if (action === 'cat-sub') {
        activeCategory = (actionEl as HTMLElement).dataset.cat || '';
        document.querySelectorAll('.cat-sub').forEach(function(b) {
          var el = b as HTMLElement;
          var isActive = (el.dataset.cat || '') === activeCategory;
          el.className = 'cat-sub px-3.5 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border-2 transition-all '
            + (isActive ? 'border-navy bg-navy text-white' : 'border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)]');
        });
        activeType = '';
        buildTypeFilters();
        renderCatalogFiltered();
      }
      if (action === 'art-filter-type') {
        activeType = (actionEl as HTMLElement).dataset.type || '';
        buildTypeFilters();
        renderCatalogFiltered();
      }
      if (action === 'art-filter-tag') {
        var tag = (actionEl as HTMLElement).dataset.tag || '';
        activeTag = activeTag === tag ? '' : tag;
        buildArtifactTagBar();
        renderCatalogFiltered();
      }
    });
    document.addEventListener('change', function(e: Event) {
      var target = e.target as HTMLElement;
      if (target.id === 'art-tribe-filter') {
        activeTribe = (target as HTMLSelectElement).value;
        renderCatalogFiltered();
      }
    });
    var artSearchTimer: ReturnType<typeof setTimeout> | null = null;
    document.addEventListener('input', function(e: Event) {
      var target = e.target as HTMLElement;
      if (target.id === 'art-search') {
        if (artSearchTimer) clearTimeout(artSearchTimer);
        artSearchTimer = setTimeout(function() {
          searchQuery = (target as HTMLInputElement).value.trim();
          renderCatalogFiltered();
        }, 250);
      }
    });
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest') {
        MEMBER = e.detail;
        setupUI();
      }
    }) as EventListener);

    window.addEventListener('nav:guest-with-session', (() => {
      document.getElementById('guest-banner')?.classList.remove('hidden');
      loadCatalog();
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') {
      MEMBER = m;
      setupUI();
      return;
    }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        if (data && getMemberRole(data) !== 'guest') {
          MEMBER = data;
          setupUI();
          return;
        }
        document.getElementById('guest-banner')?.classList.remove('hidden');
      }
    } catch (e) {
      console.warn('Artifacts: session check failed, loading public catalog:', e);
    }
    loadCatalog();
  }

  function setupUI() {
    const role = getMemberRole(MEMBER);
    CAN_MANAGE = MEMBER.is_superadmin || role === 'tribe_leader' || (MEMBER.designations || []).includes('curator');
    // Show submit button for any logged-in member
    document.getElementById('btn-submit')?.classList.remove('hidden');
    document.getElementById('tab-my')?.classList.remove('hidden');
    if (CAN_MANAGE) {
      document.getElementById('tab-review')?.classList.remove('hidden');
    }
    loadCatalog();
  }

  boot();
</script>
