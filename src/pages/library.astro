---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import LoadingSkeleton from '../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const WORKSPACE_I18N = {
  heading: t('workspace.heading', lang),
  subtitle: t('workspace.subtitle', lang),
  filterAll: t('workspace.filterAll', lang),
  filterCourse: t('workspace.filterCourse', lang),
  filterReference: t('workspace.filterReference', lang),
  filterWebinar: t('workspace.filterWebinar', lang),
  filterOther: t('workspace.filterOther', lang),
  empty: t('workspace.empty', lang),
  loading: t('workspace.loading', lang),
  openLink: t('workspace.openLink', lang),
  tribeAll: t('workspace.tribeAll', lang),
  tribePrefix: t('workspace.tribePrefix', lang),
  error: t('workspace.error', lang),
  search: t('workspace.search', lang),
  searchPlaceholder: t('library.search.placeholder', lang),
  searching: t('library.search.searching', lang),
  searchResults: t('library.search.results', lang),
  tags: t('workspace.tags', lang),
  tagAll: t('workspace.tagAll', lang),
  prev: t('workspace.prev', lang),
  next: t('workspace.next', lang),
  pageOf: t('workspace.pageOf', lang),
  results: t('workspace.results', lang),
  tribeNames: Object.fromEntries(
    Array.from({length: 8}, (_, i) => [i + 1, t(`data.tribe${i + 1}.name`, lang)])
  ),
};
---
<BaseLayout title={t('workspace.meta', lang)} activePage="library" lang={lang}>
  <Toast />
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-navy">{t('workspace.heading', lang)}</h1>
      <p class="text-[var(--text-secondary)] text-sm mt-1">{t('workspace.subtitle', lang)}</p>
    </div>

    <div class="mb-4">
      <input id="ws-search" type="text"
             class="w-full px-4 py-2.5 rounded-xl border-[1.5px] border-[var(--border-default)] text-sm bg-[var(--surface-card)] focus:outline-none focus:border-navy transition-colors"
             placeholder={t('workspace.search', lang)} />
    </div>

    <div class="flex flex-wrap items-center gap-2 mb-2">
      <div class="flex gap-1.5 flex-wrap">
        <button class="ws-type-filter px-3.5 py-1.5 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
                data-filter-type="" data-action="filter-type">{t('workspace.filterAll', lang)}</button>
        <button class="ws-type-filter px-3.5 py-1.5 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                data-filter-type="course" data-action="filter-type">{t('workspace.filterCourse', lang)}</button>
        <button class="ws-type-filter px-3.5 py-1.5 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                data-filter-type="reference" data-action="filter-type">{t('workspace.filterReference', lang)}</button>
        <button class="ws-type-filter px-3.5 py-1.5 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                data-filter-type="webinar" data-action="filter-type">{t('workspace.filterWebinar', lang)}</button>
        <button class="ws-type-filter px-3.5 py-1.5 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                data-filter-type="other" data-action="filter-type">{t('workspace.filterOther', lang)}</button>
      </div>
      <select id="ws-tribe-filter"
              class="ml-auto px-3 py-1.5 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy cursor-pointer"
              data-action="filter-tribe">
        <option value="">{t('workspace.tribeAll', lang)}</option>
      </select>
    </div>

    <div id="ws-tag-bar" class="flex flex-wrap gap-1.5 mb-5"></div>
    <div id="ws-results" class="text-[.7rem] text-[var(--text-muted)] mb-3"></div>

    <div id="ws-grid">
      <LoadingSkeleton variant="card" count={6} />
    </div>

    <div id="ws-pagination" class="hidden flex items-center justify-center gap-3 mt-6">
      <button id="ws-prev" class="px-3.5 py-1.5 rounded-lg text-[13px] font-semibold border border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] cursor-pointer hover:bg-[var(--surface-hover)] disabled:opacity-40 disabled:cursor-default"
              data-action="ws-prev">{t('workspace.prev', lang)}</button>
      <span id="ws-page-info" class="text-[12px] text-[var(--text-secondary)]"></span>
      <button id="ws-next" class="px-3.5 py-1.5 rounded-lg text-[13px] font-semibold border border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] cursor-pointer hover:bg-[var(--surface-hover)] disabled:opacity-40 disabled:cursor-default"
              data-action="ws-next">{t('workspace.next', lang)}</button>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ WORKSPACE_I18N }}>
  window.__WORKSPACE_I18N = typeof WORKSPACE_I18N !== 'undefined' ? WORKSPACE_I18N : {};
</script>
<script>
  import { buildTribeLabel, isRuntimeTribeActive } from '../lib/tribes/catalog';
  const I18N = (typeof window !== 'undefined' && (window as any).__WORKSPACE_I18N) || {};

  const TYPE_ICONS: Record<string, string> = {
    course: '&#x1F393;',
    reference: '&#x1F4D8;',
    webinar: '&#x25B6;&#xFE0F;',
    other: '&#x1F4CE;',
  };
  const TYPE_LABELS: Record<string, string> = {
    course: I18N.filterCourse || 'Curso',
    reference: I18N.filterReference || 'Referencia',
    webinar: I18N.filterWebinar || 'Webinar',
    other: I18N.filterOther || 'Outro',
  };

  const TAG_COLORS: Record<string, string> = {
    research:   'bg-purple-50 text-purple-700 border-purple-200',
    education:  'bg-blue-50 text-blue-700 border-blue-200',
    community:  'bg-green-50 text-green-700 border-green-200',
    innovation: 'bg-amber-50 text-amber-700 border-amber-200',
    impact:     'bg-rose-50 text-rose-700 border-rose-200',
    governance: 'bg-[var(--surface-base)] text-[var(--text-primary)] border-[var(--border-default)]',
  };

  let TRIBE_NAMES: Record<number, string> = I18N.tribeNames || {};
  const PAGE_SIZE = 12;

  let sb: any = null;
  let allResources: any[] = [];
  let allTags: any[] = [];
  let activeType = '';
  let activeTribe = '';
  let activeTag = '';
  let searchQuery = '';
  let currentPage = 1;
  let searchRpcResults: any[] | null = null;
  let isSearching = false;

  const esc = (s: string) => String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  function tagCategoryColor(tagKey: string): string {
    const tag = allTags.find((t: any) => t.tag_key === tagKey);
    return tag ? (TAG_COLORS[tag.category] || TAG_COLORS.governance) : 'bg-[var(--surface-base)] text-[var(--text-secondary)] border-[var(--border-default)]';
  }

  function applyRouteState() {
    const params = new URLSearchParams(window.location.search);
    activeType = params.get('type') || '';
    activeTribe = params.get('tribe') || '';
    activeTag = params.get('tag') || '';
    searchQuery = (params.get('q') || '').trim();
    const searchInput = document.getElementById('ws-search') as HTMLInputElement | null;
    const tribeSelect = document.getElementById('ws-tribe-filter') as HTMLSelectElement | null;
    if (searchInput) searchInput.value = searchQuery;
    if (tribeSelect) tribeSelect.value = activeTribe;
    syncTypeButtons();
  }

  function getFiltered(): any[] {
    let filtered = searchRpcResults !== null ? searchRpcResults : allResources;
    if (activeType) filtered = filtered.filter(r => r.asset_type === activeType);
    if (activeTribe) filtered = filtered.filter(r => String(r.tribe_id) === activeTribe);
    if (activeTag) filtered = filtered.filter(r => (r.tags || []).includes(activeTag));
    // Client-side fallback when no RPC results
    if (searchRpcResults === null && searchQuery) {
      const q = searchQuery.toLowerCase();
      filtered = filtered.filter(r =>
        (r.title || '').toLowerCase().includes(q) ||
        (r.description || '').toLowerCase().includes(q) ||
        (r.tags || []).some((t: string) => t.toLowerCase().includes(q))
      );
    }
    return filtered;
  }

  function renderCards(items: any[]) {
    const grid = document.getElementById('ws-grid')!;
    if (!items.length) {
      grid.innerHTML = '<div class="text-center py-14"><div class="text-4xl mb-3">&#x1F4ED;</div><div class="font-semibold text-[var(--text-secondary)] text-sm">' + I18N.empty + '</div></div>';
      return;
    }
    grid.innerHTML = '<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">' + items.map(cardHtml).join('') + '</div>';
  }

  function cardHtml(r: any): string {
    const icon = TYPE_ICONS[r.asset_type] || TYPE_ICONS.other;
    const typeLabel = TYPE_LABELS[r.asset_type] || r.asset_type;
    const tribe = r.tribe_id ? TRIBE_NAMES[r.tribe_id] : null;
    const desc = r.description
      ? esc(r.description.length > 120 ? r.description.slice(0, 117) + '...' : r.description)
      : '';
    const link = r.url
      ? '<a href="' + esc(r.url) + '" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-teal text-[13px] font-semibold no-underline hover:underline mt-auto pt-3">' + I18N.openLink + '</a>'
      : '';

    const tagsHtml = (r.tags || []).length
      ? '<div class="flex flex-wrap gap-1 mt-2">' + (r.tags || []).map(function(t: string) {
          const color = tagCategoryColor(t);
          return '<span class="px-1.5 py-0.5 rounded text-[.6rem] font-semibold border ' + color + '">' + esc(t) + '</span>';
        }).join('') + '</div>'
      : '';

    const dateStr = r.created_at
      ? new Date(r.created_at).toLocaleDateString(I18N.locale || 'pt-BR', { month: 'short', day: '2-digit', year: 'numeric' })
      : '';

    return '<div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)]/80 p-5 flex flex-col shadow-sm hover:shadow-md hover:border-[var(--text-muted)] hover:-translate-y-px transition-all duration-200">'
      + '<div class="flex items-center gap-2 mb-3">'
      + '<span class="w-9 h-9 rounded-xl bg-[var(--surface-base)] flex items-center justify-center text-lg leading-none shrink-0">' + icon + '</span>'
      + '<div class="flex flex-col min-w-0"><span class="text-[11px] font-bold uppercase tracking-wide text-[var(--text-muted)]">' + esc(typeLabel) + '</span>'
      + (dateStr ? '<span class="text-[.6rem] text-[var(--text-muted)]">' + dateStr + '</span>' : '') + '</div>'
      + '</div>'
      + '<h3 class="text-[15px] font-bold text-navy leading-snug mb-1.5">' + esc(r.title) + '</h3>'
      + (desc ? '<p class="text-[12.5px] text-[var(--text-secondary)] leading-relaxed mb-0">' + desc + '</p>' : '')
      + tagsHtml
      + (tribe ? '<span class="inline-block mt-2 px-2 py-0.5 rounded-lg text-[11px] font-semibold bg-navy/5 text-navy/70 w-fit">' + esc(tribe) + '</span>' : '')
      + link
      + '</div>';
  }

  function applyFilters() {
    currentPage = 1;
    render();
  }

  function syncTypeButtons() {
    document.querySelectorAll('.ws-type-filter').forEach(function(btn) {
      const button = btn as HTMLElement;
      const isActive = (button.dataset.filterType || '') === activeType;
      button.classList.toggle('bg-navy', isActive);
      button.classList.toggle('text-white', isActive);
      button.classList.toggle('border-navy', isActive);
      button.classList.toggle('bg-[var(--surface-card)]', !isActive);
      button.classList.toggle('text-[var(--text-secondary)]', !isActive);
      button.classList.toggle('border-[var(--border-default)]', !isActive);
    });
  }

  function render() {
    const filtered = getFiltered();
    const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * PAGE_SIZE;
    const page = filtered.slice(start, start + PAGE_SIZE);

    const resultsEl = document.getElementById('ws-results');
    if (resultsEl) {
      resultsEl.textContent = (I18N.results || '{n} recurso(s)').replace('{n}', String(filtered.length));
    }

    renderCards(page);

    const paginationEl = document.getElementById('ws-pagination');
    const prevBtn = document.getElementById('ws-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('ws-next') as HTMLButtonElement;
    const pageInfo = document.getElementById('ws-page-info');

    if (totalPages > 1) {
      paginationEl?.classList.remove('hidden');
      if (prevBtn) prevBtn.disabled = currentPage <= 1;
      if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
      if (pageInfo) {
        pageInfo.textContent = (I18N.pageOf || 'Pagina {current} de {total}')
          .replace('{current}', String(currentPage))
          .replace('{total}', String(totalPages));
      }
    } else {
      paginationEl?.classList.add('hidden');
    }
  }

  function populateTribeSelect() {
    const select = document.getElementById('ws-tribe-filter') as HTMLSelectElement;
    if (!select) return;
    const tribeIds = [...new Set(allResources.map(r => r.tribe_id).filter(Boolean))].sort((a: number, b: number) => a - b);
    while (select.options.length > 1) select.remove(1);
    tribeIds.forEach(function(id) {
      const opt = document.createElement('option');
      opt.value = String(id);
      opt.textContent = String(id).padStart(2, '0') + ' — ' + buildTribeLabel({ id, name: TRIBE_NAMES[id] }, { prefix: I18N.tribePrefix || 'Tribo', fallbackNames: TRIBE_NAMES });
      select.appendChild(opt);
    });
  }

  async function loadRuntimeTribes() {
    if (!sb) return;
    try {
      const { data, error } = await sb.from('tribes').select('id, name, name_i18n, is_active').order('id');
      if (error) throw error;
      const _sl = location.pathname.startsWith('/en') ? 'en' : location.pathname.startsWith('/es') ? 'es' : 'pt';
      (data || []).forEach((tribe: any) => {
        if (isRuntimeTribeActive(tribe)) {
          const localizedTribe = { ...tribe, name: tribe.name_i18n?.[_sl] || tribe.name };
          TRIBE_NAMES[tribe.id] = buildTribeLabel(localizedTribe, { prefix: I18N.tribePrefix || 'Tribo', fallbackNames: TRIBE_NAMES });
        }
      });
    } catch (error) {
      console.warn('workspace tribes:', error);
    }
  }

  function buildTagBar() {
    const bar = document.getElementById('ws-tag-bar');
    if (!bar || !allTags.length) return;
    const usedTags = new Set<string>();
    allResources.forEach(function(r) { (r.tags || []).forEach(function(t: string) { usedTags.add(t); }); });
    if (!usedTags.size) { bar.innerHTML = ''; return; }

    bar.innerHTML = allTags
      .filter(function(t: any) { return usedTags.has(t.tag_key); })
      .map(function(t: any) {
        const color = TAG_COLORS[t.category] || TAG_COLORS.governance;
        const isActive = activeTag === t.tag_key;
        const activeClass = isActive ? ' ring-2 ring-navy ring-offset-1' : '';
        return '<button class="ws-tag-chip px-2 py-1 rounded-lg text-[.65rem] font-semibold border cursor-pointer transition-all '
          + color + activeClass
          + '" data-action="filter-tag" data-tag="' + esc(t.tag_key) + '">'
          + esc(t.label_pt || t.tag_key)
          + '</button>';
      }).join('');
  }

  let searchTimer: ReturnType<typeof setTimeout> | null = null;

  function updateSearchIndicator() {
    let indicator = document.getElementById('ws-search-indicator');
    if (!indicator) {
      const searchInput = document.getElementById('ws-search');
      if (searchInput && searchInput.parentElement) {
        indicator = document.createElement('span');
        indicator.id = 'ws-search-indicator';
        indicator.className = 'text-[.7rem] text-[var(--text-muted)] ml-2';
        searchInput.parentElement.appendChild(indicator);
      }
    }
    if (indicator) {
      if (isSearching) {
        indicator.textContent = I18N.searching || 'Buscando...';
      } else if (searchRpcResults !== null) {
        indicator.textContent = searchRpcResults.length + ' ' + (I18N.searchResults || 'resultados');
      } else {
        indicator.textContent = '';
      }
    }
  }

  if (!(window as any).__workspaceDelegationBound) {
    (window as any).__workspaceDelegationBound = true;
    document.addEventListener('click', function(e: MouseEvent) {
      if (!(e.target instanceof Element)) return;
      const target = e.target as HTMLElement;
      const actionEl = target.closest('[data-action]') as HTMLElement | null;
      if (!actionEl) return;
      const action = actionEl.dataset.action;

      if (action === 'filter-type') {
        activeType = (actionEl as HTMLElement).dataset.filterType || '';
        syncTypeButtons();
        applyFilters();
      }

      if (action === 'filter-tag') {
        const tag = (actionEl as HTMLElement).dataset.tag || '';
        activeTag = activeTag === tag ? '' : tag;
        buildTagBar();
        applyFilters();
      }

      if (action === 'ws-prev') {
        if (currentPage > 1) { currentPage--; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      }
      if (action === 'ws-next') {
        const filtered = getFiltered();
        const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        if (currentPage < totalPages) { currentPage++; render(); window.scrollTo({ top: 0, behavior: 'smooth' }); }
      }
    });

    document.addEventListener('change', function(e: Event) {
      const target = e.target as HTMLElement;
      if (target.id === 'ws-tribe-filter') {
        activeTribe = (target as HTMLSelectElement).value;
        applyFilters();
      }
    });

    document.addEventListener('input', function(e: Event) {
      const target = e.target as HTMLElement;
      if (target.id === 'ws-search') {
        if (searchTimer) clearTimeout(searchTimer);
        searchTimer = setTimeout(async function() {
          searchQuery = (target as HTMLInputElement).value.trim();
          if (searchQuery.length >= 2 && sb) {
            isSearching = true;
            updateSearchIndicator();
            try {
              const { data } = await sb.rpc('search_hub_resources', {
                p_query: searchQuery,
                p_asset_type: null,
                p_limit: 50,
              });
              if (Array.isArray(data)) {
                searchRpcResults = data;
                try { if ((window as any).posthog) (window as any).posthog.capture('library_search', { query: searchQuery, results: data.length }); } catch(e) {}
              } else {
                searchRpcResults = null;
              }
            } catch (_) {
              searchRpcResults = null;
            }
            isSearching = false;
            updateSearchIndicator();
          } else {
            searchRpcResults = null;
          }
          applyFilters();
        }, 300);
      }
    });
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    const grid = document.getElementById('ws-grid')!;
    try {
      const [resourcesResp, tagsResp] = await Promise.all([
        sb.from('hub_resources')
          .select('*')
          .eq('is_active', true)
          .order('created_at', { ascending: false }),
        sb.rpc('list_taxonomy_tags'),
      ]);

      if (resourcesResp.error) throw resourcesResp.error;

      allResources = resourcesResp.data || [];
      allTags = tagsResp.data || [];
      await loadRuntimeTribes();

      populateTribeSelect();
      applyRouteState();
      buildTagBar();
      applyFilters();
    } catch (e: any) {
      console.warn('Workspace: failed to load resources:', e);
      grid.innerHTML = '<div class="text-center py-10 text-red-500 text-sm">' + I18N.error + '</div>';
      (window as any).toast?.(I18N.error, 'error');
    }
  }

  boot();
</script>
