---
/**
 * /blog — Public blog listing (published posts only)
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname);
const langKey = lang === 'en-US' ? 'en' : lang === 'es-LATAM' ? 'es' : 'pt';
---

<BaseLayout activePage="blog" title={t('blog.title', lang)}>
  <div class="max-w-[900px] mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-[var(--fg)] mb-2">{t('blog.title', lang)}</h1>
    <p class="text-[var(--fg-muted)] mb-8">{t('blog.subtitle', lang)}</p>

    <div id="blog-loading" class="text-center py-16 text-gray-400">{t('campaigns.loading', lang)}</div>
    <div id="blog-posts" class="hidden space-y-6"></div>
    <div id="blog-empty" class="hidden text-center py-16 text-[var(--fg-muted)]">{t('blog.noPosts', lang)}</div>
  </div>
</BaseLayout>

<script define:vars={{ langKey }}>
  async function loadBlog() {
    const sb = window.navGetSb?.();
    if (!sb) { setTimeout(loadBlog, 200); return; }

    const { data, error } = await sb.from('blog_posts')
      .select('id, slug, title, excerpt, category, tags, published_at, is_featured, cover_image_url, view_count, like_count')
      .eq('status', 'published')
      .order('published_at', { ascending: false });

    document.getElementById('blog-loading')?.classList.add('hidden');

    if (!data || data.length === 0) {
      document.getElementById('blog-empty')?.classList.remove('hidden');
      return;
    }

    const container = document.getElementById('blog-posts');
    container?.classList.remove('hidden');

    container.innerHTML = data.map(p => {
      const title = p.title?.[langKey] || p.title?.pt || '';
      const excerpt = p.excerpt?.[langKey] || p.excerpt?.pt || '';
      const date = p.published_at ? new Date(p.published_at).toLocaleDateString(langKey === 'pt' ? 'pt-BR' : langKey === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
      const catBadge = { 'case-study': 'bg-blue-900/30 text-blue-300', tutorial: 'bg-green-900/30 text-green-300', announcement: 'bg-purple-900/30 text-purple-300', opinion: 'bg-amber-900/30 text-amber-300' }[p.category] || 'bg-gray-700 text-gray-300';

      return `<a href="/blog/${p.slug}" class="block bg-[var(--surface)] border border-[var(--border)] rounded-xl p-6 hover:border-teal-500/50 transition-colors no-underline">
        ${p.is_featured ? '<span class="inline-block px-2 py-0.5 rounded text-xs font-medium bg-teal-900/30 text-teal-300 mb-2">Featured</span>' : ''}
        <h2 class="text-xl font-bold text-[var(--fg)] mb-2">${title}</h2>
        <p class="text-[var(--fg-muted)] text-sm mb-3">${excerpt}</p>
        <div class="flex items-center gap-3 text-xs text-[var(--fg-muted)]">
          <span>${date}</span>
          <span class="px-2 py-0.5 rounded ${catBadge}">${p.category}</span>
          ${p.view_count ? '<span>' + p.view_count + ' views</span>' : ''}
          <span class="blog-like-badge" data-post-id="${p.id}" data-like-count="${p.like_count || 0}">🤍 ${p.like_count || 0}</span>
          ${(p.tags || []).map(t => '<span class="px-2 py-0.5 rounded bg-[var(--surface-hover)]">' + t + '</span>').join('')}
        </div>
      </a>`;
    }).join('');

    // Batch load like status for logged-in user
    const member = window.navGetMember?.();
    if (member) {
      const postIds = data.map(p => p.id);
      const { data: likesData } = await sb.rpc('get_blog_likes_batch', { p_post_ids: postIds });
      if (likesData && typeof likesData === 'object') {
        Object.entries(likesData).forEach(([postId, info]) => {
          const badge = container.querySelector(`[data-post-id="${postId}"]`);
          if (badge && info && info.liked) {
            badge.textContent = '❤️ ' + (info.like_count || 0);
          }
        });
      }
    }
  }
  loadBlog();
</script>
