---
/**
 * /blog/[slug] — Individual blog post page (SSR — content rendered server-side for SEO)
 * Like/view count enhanced client-side via progressive enhancement.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { createClient } from '@supabase/supabase-js';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langKey = lang;
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
const locale = lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es-ES' : 'pt-BR';
const { slug } = Astro.params;

// SSR: fetch blog post server-side (anon key — RLS allows public reads of published posts)
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: post } = await sb.from('blog_posts')
  .select('*, members:author_member_id(name)')
  .eq('slug', slug)
  .eq('status', 'published')
  .single();

const postTitle = post?.title?.[langKey] || post?.title?.['pt-BR'] || '';
const postBody = post?.body_html?.[langKey] || post?.body_html?.['pt-BR'] || '';
const postExcerpt = post?.excerpt?.[langKey] || post?.excerpt?.['pt-BR'] || '';
const postCategory = post?.category || '';
const postAuthor = post?.members?.name || '';
const postDate = post?.published_at
  ? new Date(post.published_at).toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const wasUpdated = post?.updated_at && post?.published_at
  && new Date(post.updated_at).getTime() - new Date(post.published_at).getTime() > 86400000;
const updatedDate = wasUpdated
  ? new Date(post.updated_at).toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const pageTitle = postTitle ? `${postTitle} | Núcleo IA & GP` : t('blog.title', lang);
---

<BaseLayout activePage="blog" title={pageTitle} lang={lang}>
  {/* OG meta tags for social sharing */}
  <meta slot="head" property="og:title" content={postTitle} />
  <meta slot="head" property="og:description" content={postExcerpt} />
  <meta slot="head" property="og:type" content="article" />
  <meta slot="head" property="og:url" content={`https://nucleoia.vitormr.dev${langPrefix}/blog/${slug}`} />
  <meta slot="head" property="og:image" content={post?.cover_image_url || 'https://nucleoia.vitormr.dev/favicon.svg'} />
  <meta slot="head" name="twitter:card" content="summary_large_image" />
  <meta slot="head" name="description" content={postExcerpt} />

  <div class="max-w-[800px] mx-auto px-4 py-12">
    {!post ? (
      <div class="text-center py-16">
        <p class="text-[var(--fg-muted)]">{t('blog.notFound', lang)}</p>
        <a href={`${langPrefix}/blog`} class="text-teal-400 hover:underline mt-2 inline-block">{t('blog.backToList', lang)}</a>
      </div>
    ) : (
      <article>
        <a href={`${langPrefix}/blog`} class="text-sm text-teal-400 hover:underline mb-6 inline-block">&larr; {t('blog.backToList', lang)}</a>
        <h1 class="text-3xl font-bold text-[var(--fg)] mb-4">{postTitle}</h1>
        <div class="flex items-center gap-4 text-sm text-[var(--fg-muted)] mb-8 flex-wrap">
          <span>{postDate}</span>
          <span class="px-2 py-0.5 rounded bg-[var(--surface-hover)]">{postCategory}</span>
          <span class="text-[var(--fg)]">{postAuthor}</span>
          <span id="post-views" class="text-[var(--fg-muted)]">{post.view_count ? `${post.view_count} views` : ''}</span>
          <button id="post-like-btn" class="hidden flex items-center gap-1 text-sm cursor-pointer bg-transparent border-0 hover:scale-110 transition-transform">
            <span id="post-like-icon">🤍</span>
            <span id="post-like-count" class="text-[var(--fg-muted)]">{post.like_count || 0}</span>
          </button>
        </div>
        {wasUpdated && (
          <div class="bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-800 rounded-xl px-4 py-2.5 text-sm text-blue-700 dark:text-blue-300 mb-6 flex items-center gap-2">
            <span>🔄</span>
            <span>{t('blog.updatedOn', lang)} {updatedDate}</span>
          </div>
        )}
        <div class="prose prose-invert max-w-none
          [&_h1]:text-2xl [&_h1]:font-bold [&_h1]:text-[var(--text-primary)] [&_h1]:mt-8 [&_h1]:mb-4
          [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-[var(--text-primary)] [&_h2]:mt-6 [&_h2]:mb-3
          [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-[var(--text-primary)] [&_h3]:mt-4 [&_h3]:mb-2
          [&_p]:text-[var(--text-secondary)] [&_p]:leading-relaxed [&_p]:mb-4
          [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:text-[var(--text-secondary)]
          [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:text-[var(--text-secondary)]
          [&_li]:mb-1 [&_li]:text-[var(--text-secondary)]
          [&_a]:text-teal-400 [&_a]:hover:underline
          [&_strong]:text-[var(--text-primary)] [&_strong]:font-semibold
          [&_em]:italic
          [&_hr]:border-[var(--border)] [&_hr]:my-8
          [&_table]:w-full [&_table]:border-collapse [&_table]:text-sm [&_table]:mb-4
          [&_th]:text-left [&_th]:px-3 [&_th]:py-2 [&_th]:border-b [&_th]:border-[var(--border)] [&_th]:text-[var(--text-primary)] [&_th]:font-semibold
          [&_td]:px-3 [&_td]:py-2 [&_td]:border-b [&_td]:border-[var(--border)] [&_td]:text-[var(--text-secondary)]
          [&_code]:bg-[var(--surface-hover)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-[.85em] [&_code]:text-[var(--text-primary)]
        " set:html={postBody} />
      </article>
    )}
  </div>
</BaseLayout>

<script define:vars={{ slug, postId: post?.id || null }}>
  // Progressive enhancement: view count, likes, PostHog tracking
  (async function() {
    const sb = window.navGetSb?.();
    if (!sb || !postId) return;

    // View count (session dedup)
    const viewKey = `blog_viewed_${slug}`;
    if (!sessionStorage.getItem(viewKey)) {
      sb.rpc('increment_blog_view', { p_slug: slug });
      sessionStorage.setItem(viewKey, '1');
    }

    // Like button
    const likeBtn = document.getElementById('post-like-btn');
    const likeIcon = document.getElementById('post-like-icon');
    const likeCount = document.getElementById('post-like-count');
    if (!likeBtn) return;
    likeBtn.classList.remove('hidden');

    let currentLiked = false;
    let currentCount = 0;

    const { data: likeData } = await sb.rpc('get_blog_post_likes', { p_post_id: postId });
    if (likeData) {
      currentLiked = likeData.liked || false;
      currentCount = likeData.like_count || 0;
    }
    if (likeIcon) likeIcon.textContent = currentLiked ? '❤️' : '🤍';
    if (likeCount) likeCount.textContent = String(currentCount);

    likeBtn.addEventListener('click', async () => {
      const member = window.navGetMember?.();
      if (!member) { document.dispatchEvent(new CustomEvent('open-auth')); return; }
      currentLiked = !currentLiked;
      currentCount += currentLiked ? 1 : -1;
      if (likeIcon) likeIcon.textContent = currentLiked ? '❤️' : '🤍';
      if (likeCount) likeCount.textContent = String(currentCount);
      const { data: toggleData } = await sb.rpc('toggle_blog_like', { p_post_id: postId });
      if (toggleData) {
        currentLiked = toggleData.liked;
        currentCount = toggleData.like_count;
        if (likeIcon) likeIcon.textContent = currentLiked ? '❤️' : '🤍';
        if (likeCount) likeCount.textContent = String(currentCount);
      }
    });
  })();

  // PostHog: blog_post_read — intersection observer at 50% + 30s
  (function() {
    const postSlug = String(slug || '');
    let scrolledPast = false, startTime = Date.now(), fired = false;
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'height:1px;width:1px;position:absolute;pointer-events:none;';
    const observer = new IntersectionObserver(([entry]) => { if (entry.isIntersecting) scrolledPast = true; }, { threshold: 0 });
    const check = setInterval(() => {
      if (fired) { clearInterval(check); return; }
      const article = document.querySelector('.prose') || document.querySelector('article');
      if (article && !sentinel.parentElement) {
        sentinel.style.top = (article.getBoundingClientRect().top + window.scrollY + article.clientHeight * 0.5) + 'px';
        document.body.appendChild(sentinel);
        observer.observe(sentinel);
      }
      if (scrolledPast && (Date.now() - startTime) / 1000 >= 30) {
        try { if (window.posthog) window.posthog.capture('blog_post_read', { post_slug: postSlug, reading_time_seconds: Math.round((Date.now() - startTime) / 1000) }); } catch {}
        fired = true; clearInterval(check); observer.disconnect();
      }
    }, 5000);
  })();
</script>
