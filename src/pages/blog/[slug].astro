---
/**
 * /blog/[slug] — Individual blog post page (published only)
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langKey = lang === 'en-US' ? 'en' : lang === 'es-LATAM' ? 'es' : 'pt';
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
const { slug } = Astro.params;
---

<BaseLayout activePage="blog" title={t('blog.title', lang)} lang={lang}>
  <div class="max-w-[800px] mx-auto px-4 py-12">
    <div id="post-loading" class="text-center py-16 text-gray-400">{t('campaigns.loading', lang)}</div>
    <div id="post-not-found" class="hidden text-center py-16">
      <p class="text-[var(--fg-muted)]">{t('blog.notFound', lang)}</p>
      <a href={`${langPrefix}/blog`} class="text-teal-400 hover:underline mt-2 inline-block">{t('blog.backToList', lang)}</a>
    </div>

    <article id="post-content" class="hidden">
      <a href={`${langPrefix}/blog`} class="text-sm text-teal-400 hover:underline mb-6 inline-block">&larr; {t('blog.backToList', lang)}</a>
      <h1 id="post-title" class="text-3xl font-bold text-[var(--fg)] mb-4"></h1>
      <div class="flex items-center gap-4 text-sm text-[var(--fg-muted)] mb-8">
        <span id="post-date"></span>
        <span id="post-category" class="px-2 py-0.5 rounded bg-[var(--surface-hover)]"></span>
        <span id="post-author" class="text-[var(--fg)]"></span>
        <span id="post-views" class="text-[var(--fg-muted)]"></span>
        <button id="post-like-btn" class="hidden flex items-center gap-1 text-sm cursor-pointer bg-transparent border-0 hover:scale-110 transition-transform">
          <span id="post-like-icon">🤍</span>
          <span id="post-like-count" class="text-[var(--fg-muted)]">0</span>
        </button>
      </div>
      <div id="post-body" class="prose prose-invert max-w-none
        [&_h1]:text-2xl [&_h1]:font-bold [&_h1]:text-[var(--fg)] [&_h1]:mt-8 [&_h1]:mb-4
        [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-[var(--fg)] [&_h2]:mt-6 [&_h2]:mb-3
        [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-[var(--fg)] [&_h3]:mt-4 [&_h3]:mb-2
        [&_p]:text-[var(--fg-muted)] [&_p]:leading-relaxed [&_p]:mb-4
        [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:text-[var(--fg-muted)]
        [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:text-[var(--fg-muted)]
        [&_li]:mb-1
        [&_a]:text-teal-400 [&_a]:hover:underline
        [&_strong]:text-[var(--fg)] [&_strong]:font-semibold
        [&_em]:italic
        [&_hr]:border-[var(--border)] [&_hr]:my-8
      "></div>
    </article>
  </div>
</BaseLayout>

<script define:vars={{ slug, langKey }}>
  async function loadPost() {
    const sb = window.navGetSb?.();
    if (!sb) { setTimeout(loadPost, 200); return; }

    const { data } = await sb.from('blog_posts')
      .select('*, members:author_member_id(name)')
      .eq('slug', slug)
      .eq('status', 'published')
      .single();

    document.getElementById('post-loading')?.classList.add('hidden');

    if (!data) {
      document.getElementById('post-not-found')?.classList.remove('hidden');
      return;
    }

    document.getElementById('post-content')?.classList.remove('hidden');
    document.getElementById('post-title').textContent = data.title?.[langKey] || data.title?.pt || '';
    document.getElementById('post-body').innerHTML = data.body_html?.[langKey] || data.body_html?.pt || '';
    document.getElementById('post-category').textContent = data.category;
    document.getElementById('post-author').textContent = data.members?.name || '';
    document.getElementById('post-date').textContent = data.published_at
      ? new Date(data.published_at).toLocaleDateString(langKey === 'pt' ? 'pt-BR' : langKey === 'es' ? 'es-ES' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })
      : '';

    // View count (session dedup)
    const viewKey = `blog_viewed_${slug}`;
    if (!sessionStorage.getItem(viewKey)) {
      sb.rpc('increment_blog_view', { p_slug: slug });
      sessionStorage.setItem(viewKey, '1');
    }

    // Show view count
    if (data.view_count != null) {
      const viewEl = document.getElementById('post-views');
      if (viewEl) viewEl.textContent = `${data.view_count + 1} visualizações`;
    }

    // Update page title
    document.title = (data.title?.[langKey] || data.title?.pt || 'Blog') + ' | Nucleo IA & GP';

    // Like button
    const likeBtn = document.getElementById('post-like-btn');
    const likeIcon = document.getElementById('post-like-icon');
    const likeCount = document.getElementById('post-like-count');
    if (likeBtn && data.id) {
      likeBtn.classList.remove('hidden');
      let currentLiked = false;
      let currentCount = data.like_count || 0;

      // Load like state
      const { data: likeData } = await sb.rpc('get_blog_post_likes', { p_post_id: data.id });
      if (likeData) {
        currentLiked = likeData.liked || false;
        currentCount = likeData.like_count || 0;
      }
      if (likeIcon) likeIcon.textContent = currentLiked ? '❤️' : '🤍';
      if (likeCount) likeCount.textContent = String(currentCount);

      likeBtn.addEventListener('click', async () => {
        const member = window.navGetMember?.();
        if (!member) { document.dispatchEvent(new CustomEvent('open-auth')); return; }
        // Optimistic update
        currentLiked = !currentLiked;
        currentCount += currentLiked ? 1 : -1;
        if (likeIcon) likeIcon.textContent = currentLiked ? '❤️' : '🤍';
        if (likeCount) likeCount.textContent = String(currentCount);
        // RPC
        const { data: toggleData } = await sb.rpc('toggle_blog_like', { p_post_id: data.id });
        if (toggleData) {
          currentLiked = toggleData.liked;
          currentCount = toggleData.like_count;
          if (likeIcon) likeIcon.textContent = currentLiked ? '❤️' : '🤍';
          if (likeCount) likeCount.textContent = String(currentCount);
        }
      });
    }
  }
  loadPost();
</script>
