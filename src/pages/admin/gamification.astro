---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import Toast from '../../components/ui/Toast.astro';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

// PT-BR canonical strings (audiência admin GP/co-GP). EN/ES via dict keys em follow-up.
const GAM_I18N = {
  title: 'Gamificação',
  subtitle: 'Regras de XP, Champions e auditoria — config-driven (ADR-0009)',
  accessRestricted: t('admin.accessRestricted', lang),
  backToAdmin: t('admin.backToAdmin', lang),
  loading: t('admin.loading', lang),
  rulesHeading: 'Regras de XP ativas',
  rulesEmpty: 'Nenhuma regra cadastrada.',
  championsHeading: 'Champions recentes',
  championsEmpty: 'Nenhum Champion ainda — Conferir o primeiro abaixo.',
  grantButton: '+ Conferir Champion',
  revokeButton: 'Revogar',
  revokeWindowExpired: 'Janela 7d expirada',
  modalTitle: 'Conferir Champion',
  recipientLabel: 'Recipient (member_id UUID)',
  surfaceLabel: 'Superfície',
  surfaceGeneral: 'Geral (reunião plenária)',
  surfaceTribe: 'Tribo (reunião da tribo)',
  surfaceDeliverable: 'Entregável (artefato/deliverable)',
  contextKindLabel: 'Tipo de contexto',
  contextIdLabel: 'ID do contexto (UUID)',
  contextIdHelp: 'event_id (general/tribe), tribe_deliverable_id ou meeting_artifact_id',
  criteriaLabel: 'Critérios atendidos (1-4)',
  justificationLabel: 'Justificativa (≥50 chars)',
  submitButton: 'Conferir Champion',
  cancelButton: 'Cancelar',
  successAwarded: 'Champion conferido',
  successRevoked: 'Champion revogado',
  errorPrefix: 'Erro',
  softCapWarning: 'Conferido — atenção: membro próximo do cap do ciclo',
  rulesColSlug: 'Categoria',
  rulesColPillar: 'Pilar',
  rulesColBase: 'Base',
  rulesColBonus: 'Bônus/crit',
  rulesColCap: 'Cap',
  rulesColTrigger: 'Trigger',
  // p171 TIER C — showcaseNudge migrou pra i18n dict (3 langs)
  showcaseNudgeTitle: t('admin.gamification.showcaseNudgeTitle', lang),
  showcaseNudgeSubtitle: t('admin.gamification.showcaseNudgeSubtitle', lang),
  // p172 TIER C — suggestionsNudge migrou pra i18n dict (3 langs)
  suggestionsNudgeTitle: t('admin.gamification.suggestionsNudgeTitle', lang),
  suggestionsNudgeSubtitle: t('admin.gamification.suggestionsNudgeSubtitle', lang),
  // p171 #13 — Category activity panel
  activityHeading: 'Atividade Recente por categoria',
  activitySubtitle: 'Canários: regras nunca acionadas (🚨) ou idle >30d (⚠️). Drift inverso (categoria sem regra) destacado como 👻 orphan.',
  activityEmpty: 'Sem categorias ativas.',
  activityWindowLabel: 'Janela (dias)',
  activityColCategory: 'Categoria',
  activityColPillar: 'Pilar',
  activityColBase: 'Base XP',
  activityColTotal: 'Total',
  activityColMembers: 'Members',
  activityColWindow: 'Janela',
  activityColLast7d: '7d',
  activityColLastAward: 'Último',
  activityColStatus: 'Status',
  activityStatusHealthy: 'healthy',
  activityStatusWarm: 'warm',
  activityStatusIdle: 'idle',
  activityStatusNever: 'never',
  activityStatusInactive: 'inactive',
  activityStatusOrphan: 'orphan',
  activityIncludeInactive: 'Incluir inativas',
};

// p171 #8 — criteria source-of-truth migrou pra DB (champion_criteria_catalog).
// Frontend fetch via RPC `get_champion_criteria_for_surface` on showPanel().
// Caso fetch falhe, fallback minimo abaixo (read-only safety net).
const CRITERIA_FALLBACK: Record<string, Array<{slug: string; pt: string}>> = {
  general: [
    { slug: 'conduziu_pauta', pt: 'Conduziu pauta com clareza' },
    { slug: 'apresentou_resultados', pt: 'Apresentou resultados de tribo/iniciativa' },
    { slug: 'destravou_bloqueio', pt: 'Destravou bloqueio cross-tribal' },
    { slug: 'mediou_decisao', pt: 'Facilitou decisão coletiva' },
  ],
  tribe: [
    { slug: 'conduziu_reuniao', pt: 'Conduziu reunião' },
    { slug: 'entregou_demo', pt: 'Demonstrou avanço técnico' },
    { slug: 'mentorou_novo', pt: 'Mentorou novo membro' },
    { slug: 'apoio_externo', pt: 'Suporte além da tribo' },
  ],
  deliverable: [
    { slug: 'qualidade_acima_baseline', pt: 'Qualidade acima do baseline' },
    { slug: 'prazo_antecipado', pt: 'Entregue antes do prazo' },
    { slug: 'impacto_pmi', pt: 'Impacto institucional PMI' },
    { slug: 'inovacao_tecnica', pt: 'Inovação técnica/conceitual' },
  ],
};
const LANG_FOR_CRITERIA = (lang === 'en-US' || lang === 'es-LATAM') ? lang : 'pt-BR';
---

<AdminLayout title={GAM_I18N.title} breadcrumbs={[{label: t('admin.breadcrumb.operations', lang)},{label: GAM_I18N.title}]}>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <div id="gam-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-8 text-center">
      <div class="text-3xl mb-3">🔒</div>
      <p class="font-semibold text-amber-800">{GAM_I18N.accessRestricted}</p>
      <a href={`${langPrefix}/admin`} class="inline-block mt-4 px-5 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{GAM_I18N.backToAdmin}</a>
    </div>

    <div id="gam-loading" class="text-center py-16 text-[var(--text-muted)]">{GAM_I18N.loading}</div>

    <div id="gam-panel" class="hidden">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-xl font-extrabold text-navy">🏆 {GAM_I18N.title}</h1>
          <p class="text-sm text-[var(--text-secondary)] mt-1">{GAM_I18N.subtitle}</p>
        </div>
        <button id="gam-grant-btn" class="px-4 py-2 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
          {GAM_I18N.grantButton}
        </button>
      </div>

      <!-- Section 1: Recent Champions -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-5 mb-6">
        <h2 class="text-sm font-bold text-navy mb-3">{GAM_I18N.championsHeading}</h2>
        <div id="gam-champions-list" class="space-y-2">
          <p class="text-[.7rem] text-[var(--text-muted)]">{GAM_I18N.loading}</p>
        </div>
      </section>

      <!-- Section 2: Rules table -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-5 mb-6">
        <h2 class="text-sm font-bold text-navy mb-3">{GAM_I18N.rulesHeading}</h2>
        <div id="gam-rules-table" class="overflow-x-auto">
          <p class="text-[.7rem] text-[var(--text-muted)]">{GAM_I18N.loading}</p>
        </div>
      </section>

      {/* p171 #13 — Category activity panel (canary: never-fired rules + idle drift) */}
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-5">
        <div class="flex items-start justify-between mb-2 gap-3 flex-wrap">
          <div class="flex-1 min-w-0">
            <h2 class="text-sm font-bold text-navy">{GAM_I18N.activityHeading}</h2>
            <p class="text-[.65rem] text-[var(--text-muted)] mt-0.5">{GAM_I18N.activitySubtitle}</p>
          </div>
          <div class="flex items-center gap-3">
            <label class="text-[.65rem] text-[var(--text-secondary)] flex items-center gap-1.5">
              <span>{GAM_I18N.activityWindowLabel}</span>
              <select id="gam-activity-window" class="border border-[var(--border-default)] rounded px-1.5 py-0.5 text-[.7rem]">
                <option value="7">7</option>
                <option value="30" selected>30</option>
                <option value="90">90</option>
              </select>
            </label>
            <label class="text-[.65rem] text-[var(--text-secondary)] flex items-center gap-1.5 cursor-pointer">
              <input id="gam-activity-include-inactive" type="checkbox" class="cursor-pointer">
              <span>{GAM_I18N.activityIncludeInactive}</span>
            </label>
          </div>
        </div>
        <div id="gam-activity-table" class="overflow-x-auto">
          <p class="text-[.7rem] text-[var(--text-muted)]">{GAM_I18N.loading}</p>
        </div>
      </section>
    </div>

    <!-- Grant Champion Modal -->
    <div id="gam-modal-overlay" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center overflow-auto">
      <div class="bg-[var(--surface-card)] rounded-2xl shadow-xl w-full max-w-xl mx-4 my-8 border border-[var(--border-default)]">
        <div class="px-5 py-4 border-b border-[var(--border-default)] flex items-center justify-between">
          <h3 class="text-sm font-bold text-navy">🏆 {GAM_I18N.modalTitle}</h3>
          <button id="gam-modal-close" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] text-lg cursor-pointer bg-transparent border-0">&times;</button>
        </div>
        <div class="p-5 space-y-3 max-h-[70vh] overflow-y-auto">
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{GAM_I18N.surfaceLabel}</label>
            <select id="gam-surface" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
              <option value="general">{GAM_I18N.surfaceGeneral}</option>
              <option value="tribe">{GAM_I18N.surfaceTribe}</option>
              <option value="deliverable">{GAM_I18N.surfaceDeliverable}</option>
            </select>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{GAM_I18N.contextKindLabel}</label>
            <select id="gam-context-kind" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
              <option value="event">event</option>
              <option value="deliverable">deliverable</option>
              <option value="artifact">artifact</option>
            </select>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{GAM_I18N.contextIdLabel}</label>
            <input type="text" id="gam-context-id" placeholder="uuid" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.72rem] font-mono">
            <p class="text-[.6rem] text-[var(--text-muted)] mt-0.5">{GAM_I18N.contextIdHelp}</p>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{GAM_I18N.recipientLabel}</label>
            <input type="text" id="gam-recipient-id" placeholder="member uuid" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.72rem] font-mono">
          </div>
          {/* p171 #9 (Track B) — Meeting close suggestions nudge: rendered when event_id has suggested_champion_ids */}
          <div id="gam-suggestions-nudge" class="hidden">
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-2.5">
              <div class="flex items-center gap-1.5 mb-1.5">
                <span class="text-[.65rem] font-bold text-amber-800">💡 {GAM_I18N.suggestionsNudgeTitle}</span>
                <span class="text-[.6rem] text-amber-700">{GAM_I18N.suggestionsNudgeSubtitle}</span>
              </div>
              <div id="gam-suggestions-nudge-list" class="space-y-1"></div>
            </div>
          </div>
          {/* p170 #15 (ADR-0084) — Showcase nudge: shown when recipient_id valid + showcases recent exist */}
          <div id="gam-showcase-nudge" class="hidden">
            <div class="bg-blue-50 border border-blue-200 rounded-lg p-2.5">
              <div class="flex items-center gap-1.5 mb-1.5">
                <span class="text-[.65rem] font-bold text-blue-700">📋 {GAM_I18N.showcaseNudgeTitle}</span>
                <span class="text-[.6rem] text-blue-600">{GAM_I18N.showcaseNudgeSubtitle}</span>
              </div>
              <div id="gam-showcase-nudge-list" class="space-y-1"></div>
            </div>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-2">{GAM_I18N.criteriaLabel}</label>
            <div id="gam-criteria-list" class="space-y-1.5"></div>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{GAM_I18N.justificationLabel}</label>
            <textarea id="gam-justification" rows="3" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] resize-y" placeholder="≥50 chars"></textarea>
            <p id="gam-justification-counter" class="text-[.6rem] text-[var(--text-muted)] mt-0.5">0 / 50</p>
          </div>
          <div class="flex gap-2 pt-2">
            <button id="gam-modal-cancel" class="flex-1 px-4 py-2 bg-gray-100 text-gray-700 rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:bg-gray-200 transition-all">
              {GAM_I18N.cancelButton}
            </button>
            <button id="gam-modal-submit" class="flex-1 px-4 py-2 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
              {GAM_I18N.submitButton}
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Toast />
</AdminLayout>

<script is:inline define:vars={{ GAM_I18N, CRITERIA_FALLBACK, LANG_FOR_CRITERIA }}>
  window.__GAM_I18N = GAM_I18N;
  window.__GAM_CRITERIA_FALLBACK = CRITERIA_FALLBACK;
  window.__GAM_LANG = LANG_FOR_CRITERIA;
</script>
<script>
  import { hasPermission } from '../../lib/permissions';

  const T = (typeof window !== 'undefined' && (window as any).__GAM_I18N) || {};
  const FALLBACK = (typeof window !== 'undefined' && (window as any).__GAM_CRITERIA_FALLBACK) || { general: [], tribe: [], deliverable: [] };
  const LANG = ((typeof window !== 'undefined' && (window as any).__GAM_LANG) || 'pt-BR') as string;
  // p171 #8 — runtime catalog cache per surface (loaded via RPC on showPanel)
  // Keyed by surface: 'general'|'tribe'|'deliverable'. Values: { slug, display }.
  const CRIT: Record<string, Array<{ slug: string; display: string }>> = {
    general: FALLBACK.general.map((c: any) => ({ slug: c.slug, display: c.pt })),
    tribe: FALLBACK.tribe.map((c: any) => ({ slug: c.slug, display: c.pt })),
    deliverable: FALLBACK.deliverable.map((c: any) => ({ slug: c.slug, display: c.pt })),
  };

  let sb: any = null;
  let MEMBER: any = null;

  function escapeHtml(s: string): string {
    return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showDenied() {
    document.getElementById('gam-loading')?.classList.add('hidden');
    document.getElementById('gam-panel')?.classList.add('hidden');
    document.getElementById('gam-denied')?.classList.remove('hidden');
  }

  function showPanel() {
    document.getElementById('gam-loading')?.classList.add('hidden');
    document.getElementById('gam-denied')?.classList.add('hidden');
    document.getElementById('gam-panel')?.classList.remove('hidden');
    loadRules();
    loadChampions();
    loadCategoryActivity();
    loadCriteriaCatalog().then(() => renderCriteria()); // p171 #8 — fetch DB criteria then render
    maybeAutoOpenFromUrl();
  }

  // p171 #8 — fetch criteria catalog from DB, replace fallback
  async function loadCriteriaCatalog() {
    if (!sb) return;
    const surfaces: Array<'general' | 'tribe' | 'deliverable'> = ['general', 'tribe', 'deliverable'];
    await Promise.all(surfaces.map(async (surface) => {
      try {
        const { data, error } = await sb.rpc('get_champion_criteria_for_surface', { p_surface: surface });
        if (error || !Array.isArray(data) || data.length === 0) return;
        CRIT[surface] = data.map((row: any) => ({
          slug: row.slug,
          display: (row.display_name_i18n && row.display_name_i18n[LANG]) || row.display_name_i18n?.['pt-BR'] || row.slug,
        }));
      } catch {
        // Fallback already populated from CRITERIA_FALLBACK
      }
    }));
  }

  // p171 #13 — Category activity panel
  async function loadCategoryActivity() {
    if (!sb) return;
    const container = document.getElementById('gam-activity-table');
    if (!container) return;
    const windowEl = document.getElementById('gam-activity-window') as HTMLSelectElement | null;
    const includeInactiveEl = document.getElementById('gam-activity-include-inactive') as HTMLInputElement | null;
    const windowDays = Number(windowEl?.value || 30);
    const includeInactive = Boolean(includeInactiveEl?.checked);
    try {
      const { data, error } = await sb.rpc('get_gamification_category_activity', { p_window_days: windowDays });
      if (error) throw error;
      const rows = (data || []).filter((r: any) => includeInactive || r.status !== 'inactive');
      if (rows.length === 0) {
        container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${T.activityEmpty}</p>`;
        return;
      }
      const statusBadge = (s: string) => {
        switch (s) {
          case 'healthy':  return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-emerald-100 text-emerald-800">✓ ${T.activityStatusHealthy}</span>`;
          case 'warm':     return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-emerald-50 text-emerald-700">${T.activityStatusWarm}</span>`;
          case 'idle':     return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-amber-100 text-amber-800">⚠ ${T.activityStatusIdle}</span>`;
          case 'never':    return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-red-100 text-red-800">🚨 ${T.activityStatusNever}</span>`;
          case 'inactive': return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-gray-100 text-gray-600">${T.activityStatusInactive}</span>`;
          case 'orphan':   return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-purple-100 text-purple-800">👻 ${T.activityStatusOrphan}</span>`;
          default:         return `<span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold bg-gray-100 text-gray-600">${escapeHtml(s)}</span>`;
        }
      };
      const fmtLast = (ts: string | null) => {
        if (!ts) return '<span class="text-[var(--text-muted)]">—</span>';
        const ageMs = Date.now() - new Date(ts).getTime();
        const ageDays = Math.floor(ageMs / (24 * 60 * 60 * 1000));
        const cls = ageDays > 60 ? 'text-red-700' : ageDays > 30 ? 'text-amber-700' : ageDays > 7 ? 'text-gray-600' : 'text-emerald-700';
        return `<span class="${cls}">${ageDays}d</span>`;
      };
      const html = rows.map((r: any) => `
        <tr class="border-b border-[var(--border-default)] ${r.status === 'never' || r.status === 'orphan' ? 'bg-red-50/30' : r.status === 'idle' ? 'bg-amber-50/30' : ''}">
          <td class="py-1.5 pr-3 font-mono text-[.68rem]">${escapeHtml(r.slug)}</td>
          <td class="py-1.5 pr-3 text-[.68rem] text-[var(--text-secondary)]">${escapeHtml(r.pillar || '—')}</td>
          <td class="py-1.5 pr-3 text-right text-[.7rem] font-semibold">${r.base_points ?? '—'}</td>
          <td class="py-1.5 pr-3 text-right text-[.7rem]">${r.total_events}</td>
          <td class="py-1.5 pr-3 text-right text-[.65rem] text-[var(--text-muted)]">${r.unique_members}</td>
          <td class="py-1.5 pr-3 text-right text-[.7rem]">${r.last_window_events}</td>
          <td class="py-1.5 pr-3 text-right text-[.7rem]">${r.last_7d_events}</td>
          <td class="py-1.5 pr-3 text-right text-[.65rem]">${fmtLast(r.last_award)}</td>
          <td class="py-1.5 pr-3 text-center">${statusBadge(r.status)}</td>
        </tr>`).join('');
      container.innerHTML = `
        <table class="w-full text-[.78rem]">
          <thead><tr class="border-b-2 border-[var(--border-default)] text-[.6rem] uppercase tracking-wider text-[var(--text-muted)]">
            <th class="py-1.5 pr-3 text-left">${T.activityColCategory}</th>
            <th class="py-1.5 pr-3 text-left">${T.activityColPillar}</th>
            <th class="py-1.5 pr-3 text-right">${T.activityColBase}</th>
            <th class="py-1.5 pr-3 text-right">${T.activityColTotal}</th>
            <th class="py-1.5 pr-3 text-right">${T.activityColMembers}</th>
            <th class="py-1.5 pr-3 text-right">${T.activityColWindow}</th>
            <th class="py-1.5 pr-3 text-right">${T.activityColLast7d}</th>
            <th class="py-1.5 pr-3 text-right">${T.activityColLastAward}</th>
            <th class="py-1.5 pr-3 text-center">${T.activityColStatus}</th>
          </tr></thead>
          <tbody>${html}</tbody>
        </table>`;
    } catch (e: any) {
      container.innerHTML = `<p class="text-[.7rem] text-red-600">${T.errorPrefix}: ${escapeHtml(e?.message || 'load failed')}</p>`;
    }
  }

  async function loadRules() {
    if (!sb) return;
    const container = document.getElementById('gam-rules-table');
    if (!container) return;
    try {
      const { data, error } = await sb.from('gamification_rules')
        .select('slug, pillar, display_name_i18n, base_points, bonus_per_criterion, cap_points, trigger_source, active')
        .order('pillar')
        .order('trigger_source')
        .order('slug');
      if (error) throw error;
      const rules = data || [];
      if (rules.length === 0) {
        container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${T.rulesEmpty}</p>`;
        return;
      }
      // p171 #14: pillar visible — admins SEE each rule's pillar (NOT NULL CHECK in DB).
      // Future CRUD forms MUST include pillar field — sediment p138 (supabase-js silent 400).
      const pillarColor = (p: string) => {
        switch (p) {
          case 'presenca':       return 'bg-blue-50 text-blue-700';
          case 'trilha':         return 'bg-indigo-50 text-indigo-700';
          case 'certificacoes':  return 'bg-violet-50 text-violet-700';
          case 'producao':       return 'bg-emerald-50 text-emerald-700';
          case 'curadoria':      return 'bg-orange-50 text-orange-700';
          case 'champions':      return 'bg-amber-50 text-amber-700';
          default:               return 'bg-gray-50 text-gray-600';
        }
      };
      const rows = rules.map((r: any) => {
        const displayName = (r.display_name_i18n && r.display_name_i18n['pt-BR']) || r.slug;
        const triggerColor = r.trigger_source === 'manual' ? 'bg-amber-50 text-amber-700'
                           : r.trigger_source === 'auto_trigger' ? 'bg-emerald-50 text-emerald-700'
                           : 'bg-blue-50 text-blue-700';
        return `
          <tr class="border-b border-[var(--border-default)] ${r.active === false ? 'opacity-60' : ''}">
            <td class="py-2 pr-3 font-mono text-[.7rem]">${escapeHtml(r.slug)}</td>
            <td class="py-2 pr-3"><span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold ${pillarColor(r.pillar)}">${escapeHtml(r.pillar || '—')}</span></td>
            <td class="py-2 pr-3 text-[.75rem]">${escapeHtml(displayName)}</td>
            <td class="py-2 pr-3 text-right font-semibold">${r.base_points}</td>
            <td class="py-2 pr-3 text-right text-[var(--text-muted)]">${r.bonus_per_criterion > 0 ? '+' + r.bonus_per_criterion : '—'}</td>
            <td class="py-2 pr-3 text-right text-[var(--text-muted)]">${r.cap_points ?? '—'}</td>
            <td class="py-2 pr-3"><span class="inline-block px-1.5 py-0.5 rounded text-[.6rem] font-semibold ${triggerColor}">${r.trigger_source}</span></td>
          </tr>`;
      }).join('');
      container.innerHTML = `
        <table class="w-full text-[.78rem]">
          <thead><tr class="border-b-2 border-[var(--border-default)] text-[.65rem] uppercase tracking-wider text-[var(--text-muted)]">
            <th class="py-2 pr-3 text-left">${T.rulesColSlug}</th>
            <th class="py-2 pr-3 text-left">${T.rulesColPillar}</th>
            <th class="py-2 pr-3 text-left">Display</th>
            <th class="py-2 pr-3 text-right">${T.rulesColBase}</th>
            <th class="py-2 pr-3 text-right">${T.rulesColBonus}</th>
            <th class="py-2 pr-3 text-right">${T.rulesColCap}</th>
            <th class="py-2 pr-3 text-left">${T.rulesColTrigger}</th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>`;
    } catch (e: any) {
      container.innerHTML = `<p class="text-[.7rem] text-red-600">${T.errorPrefix}: ${escapeHtml(e?.message || 'load failed')}</p>`;
    }
  }

  async function loadChampions() {
    if (!sb) return;
    const container = document.getElementById('gam-champions-list');
    if (!container) return;
    try {
      const { data, error } = await sb.from('champions_awarded')
        .select('id, surface, points_awarded, status, criteria_met, justification, created_at, awarded_by, recipient_id, initiative_id, revoked_reason')
        .order('created_at', { ascending: false })
        .limit(20);
      if (error) throw error;
      const champs = data || [];
      if (champs.length === 0) {
        container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${T.championsEmpty}</p>`;
        return;
      }

      // Fetch member names in bulk
      const memberIds = Array.from(new Set([...champs.map((c: any) => c.recipient_id), ...champs.map((c: any) => c.awarded_by)]));
      const { data: members } = await sb.from('members').select('id, name').in('id', memberIds);
      const memberMap = new Map((members || []).map((m: any) => [m.id, m.name]));

      const now = Date.now();
      const cards = champs.map((c: any) => {
        const recipientName = memberMap.get(c.recipient_id) || c.recipient_id.slice(0, 8);
        const awarderName = memberMap.get(c.awarded_by) || c.awarded_by.slice(0, 8);
        const ageMs = now - new Date(c.created_at).getTime();
        const withinWindow = ageMs < 7 * 24 * 60 * 60 * 1000;
        const ageDays = Math.floor(ageMs / (24 * 60 * 60 * 1000));
        const statusBadge = c.status === 'revoked'
          ? '<span class="inline-block px-1.5 py-0.5 bg-red-50 text-red-700 rounded text-[.6rem] font-semibold">REVOGADO</span>'
          : `<span class="inline-block px-1.5 py-0.5 bg-emerald-50 text-emerald-700 rounded text-[.6rem] font-semibold">${c.points_awarded} pts</span>`;
        const surfaceLabel = c.surface === 'general' ? '🏛️ Geral'
                           : c.surface === 'tribe' ? '🏕️ Tribo'
                           : '📦 Entregável';
        const revokeBtn = c.status === 'active' && withinWindow
          ? `<button data-champion-id="${c.id}" class="gam-revoke-btn text-[.65rem] px-2 py-1 bg-red-50 text-red-700 rounded hover:bg-red-100 border-0 cursor-pointer">${T.revokeButton}</button>`
          : c.status === 'active'
            ? `<span class="text-[.6rem] text-[var(--text-muted)]" title="${T.revokeWindowExpired}">⏱️</span>`
            : '';
        return `
          <div class="border border-[var(--border-default)] rounded-lg p-3 ${c.status === 'revoked' ? 'opacity-60' : ''}">
            <div class="flex items-start gap-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <span class="text-[.7rem] font-semibold text-navy">${escapeHtml(recipientName)}</span>
                  <span class="text-[.65rem] text-[var(--text-muted)]">${surfaceLabel}</span>
                  ${statusBadge}
                  <span class="text-[.6rem] text-[var(--text-muted)]">${ageDays}d</span>
                </div>
                <p class="text-[.7rem] text-[var(--text-secondary)] truncate">${escapeHtml(c.justification)}</p>
                <p class="text-[.6rem] text-[var(--text-muted)] mt-1">por ${escapeHtml(awarderName)} · critérios: ${escapeHtml((c.criteria_met || []).join(', '))}</p>
                ${c.status === 'revoked' && c.revoked_reason ? `<p class="text-[.6rem] text-red-600 mt-1">↩ ${escapeHtml(c.revoked_reason)}</p>` : ''}
              </div>
              <div class="shrink-0">${revokeBtn}</div>
            </div>
          </div>`;
      }).join('');
      container.innerHTML = cards;

      document.querySelectorAll('.gam-revoke-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const champId = btn.getAttribute('data-champion-id');
          if (!champId) return;
          const reason = prompt('Motivo da revogação (≥10 chars):');
          if (!reason || reason.trim().length < 10) {
            (window as any).toast?.('Motivo obrigatório (≥10 chars)', 'error');
            return;
          }
          try {
            const { data, error } = await sb.rpc('revoke_champion', { p_champion_id: champId, p_reason: reason });
            if (error) throw error;
            if (data?.error) throw new Error(data.error);
            (window as any).toast?.(T.successRevoked, 'success');
            loadChampions();
          } catch (e: any) {
            (window as any).toast?.(`${T.errorPrefix}: ${e?.message || 'revoke failed'}`, 'error');
          }
        });
      });
    } catch (e: any) {
      container.innerHTML = `<p class="text-[.7rem] text-red-600">${T.errorPrefix}: ${escapeHtml(e?.message || 'load failed')}</p>`;
    }
  }

  function renderCriteria() {
    const surface = (document.getElementById('gam-surface') as HTMLSelectElement)?.value || 'general';
    const container = document.getElementById('gam-criteria-list');
    if (!container) return;
    const items = CRIT[surface] || [];
    container.innerHTML = items.map((c) => `
      <label class="flex items-center gap-2 text-[.75rem] cursor-pointer">
        <input type="checkbox" class="gam-criterion-cb" value="${escapeHtml(c.slug)}">
        <span>${escapeHtml(c.display)}</span>
      </label>`).join('');
  }

  function openGrantModal(prefill?: { surface?: string; contextKind?: string; contextId?: string }) {
    document.getElementById('gam-modal-overlay')?.classList.remove('hidden');
    const surfaceSel = document.getElementById('gam-surface') as HTMLSelectElement;
    const kindSel = document.getElementById('gam-context-kind') as HTMLSelectElement;
    surfaceSel.value = prefill?.surface && ['general', 'tribe', 'deliverable'].includes(prefill.surface) ? prefill.surface : 'general';
    kindSel.value = prefill?.contextKind && ['event', 'deliverable', 'artifact'].includes(prefill.contextKind) ? prefill.contextKind : 'event';
    (document.getElementById('gam-context-id') as HTMLInputElement).value = prefill?.contextId || '';
    (document.getElementById('gam-recipient-id') as HTMLInputElement).value = '';
    (document.getElementById('gam-justification') as HTMLTextAreaElement).value = '';
    // p170 #15: reset showcase nudge
    document.getElementById('gam-showcase-nudge')?.classList.add('hidden');
    // p171 #9: reset suggestions nudge + fetch if event prefilled
    document.getElementById('gam-suggestions-nudge')?.classList.add('hidden');
    if (prefill?.contextId && prefill?.contextKind === 'event') {
      loadEventSuggestions(prefill.contextId);
    }
    updateJustificationCounter();
    renderCriteria();
  }

  // p171 #9 — fetch meeting_close suggestions for the event + render nudge
  async function loadEventSuggestions(eventId: string) {
    if (!sb || !eventId) return;
    const nudge = document.getElementById('gam-suggestions-nudge');
    const list = document.getElementById('gam-suggestions-nudge-list');
    if (!nudge || !list) return;
    try {
      const { data, error } = await sb.rpc('get_event_champion_suggestions', { p_event_id: eventId });
      if (error || !Array.isArray(data) || data.length === 0) {
        nudge.classList.add('hidden');
        return;
      }
      list.innerHTML = data.map((s: any) => `
        <button type="button" data-suggestion-id="${escapeHtml(s.member_id)}"
                class="gam-suggestion-btn w-full text-left text-[.65rem] bg-white border border-amber-200 rounded px-2 py-1.5 hover:bg-amber-50 cursor-pointer transition-colors">
          <div class="font-semibold text-amber-900">${escapeHtml(s.member_name)}</div>
          <div class="text-amber-700/70 text-[.6rem]">${escapeHtml(s.designation_summary || '')}</div>
        </button>
      `).join('');
      // Wire click → prefill recipient_id input + trigger showcase nudge refetch
      list.querySelectorAll('.gam-suggestion-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const memberId = btn.getAttribute('data-suggestion-id');
          if (!memberId) return;
          const recipientInput = document.getElementById('gam-recipient-id') as HTMLInputElement | null;
          if (recipientInput) {
            recipientInput.value = memberId;
            // Trigger showcaseNudge refetch (debounced input handler)
            recipientInput.dispatchEvent(new Event('input', { bubbles: true }));
          }
        });
      });
      nudge.classList.remove('hidden');
      // If exactly 1 suggestion AND recipient_id is empty, auto-prefill
      if (data.length === 1) {
        const recipientInput = document.getElementById('gam-recipient-id') as HTMLInputElement | null;
        if (recipientInput && !recipientInput.value) {
          recipientInput.value = data[0].member_id;
          recipientInput.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    } catch (e) {
      nudge.classList.add('hidden');
    }
  }

  // p170 #15 (ADR-0084) — Showcase nudge: fetch recent showcases for a member
  let showcaseNudgeDebounce: any = null;
  async function loadShowcaseNudge(memberId: string) {
    const nudge = document.getElementById('gam-showcase-nudge');
    const list = document.getElementById('gam-showcase-nudge-list');
    if (!nudge || !list) return;
    if (!memberId || memberId.length < 30) {
      nudge.classList.add('hidden');
      return;
    }
    try {
      const { data, error } = await sb.rpc('get_recent_showcases_by_member', {
        p_member_id: memberId,
        p_days: 30
      });
      if (error || !data || data.length === 0) {
        nudge.classList.add('hidden');
        return;
      }
      list.innerHTML = data.slice(0, 5).map((s: any) => `
        <div class="text-[.65rem] bg-white border border-blue-100 rounded px-2 py-1.5">
          <div class="font-semibold text-blue-800">
            ${escapeHtml(s.showcase_type)} · ${escapeHtml(s.showcase_title || '—')}
          </div>
          <div class="text-blue-600/70 text-[.6rem]">
            ${escapeHtml(s.event_title || 'sem event')} · ${s.event_date || '—'} · ${s.xp_awarded || 0} XP
          </div>
        </div>
      `).join('');
      nudge.classList.remove('hidden');
    } catch (e) {
      nudge.classList.add('hidden');
    }
  }

  // p162 Track B' G3b — leader digest CTA "Conferir Champion" deep-links here
  // with ?award_event_id=<uuid>&surface=tribe (default kind=event). Auto-opens
  // the grant modal pre-filled. Honors permission gate — if showDenied path
  // wins, the params are ignored. Backlog item: tribe_leader operational role
  // does not currently hold `admin.gamification` permission, so the auto-open
  // succeeds only for managers/deputy_managers/comms_leaders. PM follow-up
  // pending (whether to widen permission or build a leaner /champion/award page).
  function maybeAutoOpenFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const eventId = params.get('award_event_id');
    if (!eventId) return;
    const surface = params.get('surface') || 'tribe';
    setTimeout(() => openGrantModal({ surface, contextKind: 'event', contextId: eventId }), 50);
  }

  function closeGrantModal() {
    document.getElementById('gam-modal-overlay')?.classList.add('hidden');
  }

  function updateJustificationCounter() {
    const ta = document.getElementById('gam-justification') as HTMLTextAreaElement;
    const counter = document.getElementById('gam-justification-counter');
    if (!ta || !counter) return;
    const len = ta.value.trim().length;
    counter.textContent = `${len} / 50`;
    counter.className = len >= 50 ? 'text-[.6rem] text-emerald-600 mt-0.5' : 'text-[.6rem] text-[var(--text-muted)] mt-0.5';
  }

  async function submitGrant() {
    if (!sb) return;
    const surface = (document.getElementById('gam-surface') as HTMLSelectElement).value;
    const contextKind = (document.getElementById('gam-context-kind') as HTMLSelectElement).value;
    const contextId = (document.getElementById('gam-context-id') as HTMLInputElement).value.trim();
    const recipientId = (document.getElementById('gam-recipient-id') as HTMLInputElement).value.trim();
    const justification = (document.getElementById('gam-justification') as HTMLTextAreaElement).value.trim();
    const criteriaChecked = Array.from(document.querySelectorAll('.gam-criterion-cb:checked')).map((cb: any) => cb.value);

    if (!contextId || !recipientId) {
      (window as any).toast?.('Preencha context_id e recipient_id', 'error');
      return;
    }
    if (criteriaChecked.length < 1 || criteriaChecked.length > 4) {
      (window as any).toast?.('Selecione 1-4 critérios', 'error');
      return;
    }
    if (justification.length < 50) {
      (window as any).toast?.('Justificativa precisa ter ≥50 chars', 'error');
      return;
    }

    const btn = document.getElementById('gam-modal-submit') as HTMLButtonElement;
    if (btn) btn.disabled = true;
    try {
      const { data, error } = await sb.rpc('award_champion', {
        p_recipient_id: recipientId,
        p_surface: surface,
        p_context_kind: contextKind,
        p_context_id: contextId,
        p_criteria_met: criteriaChecked,
        p_justification: justification,
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error + (data.detail ? ': ' + data.detail : ''));
      const msg = data?.soft_cap_warning ? T.softCapWarning : T.successAwarded;
      (window as any).toast?.(msg, 'success');
      closeGrantModal();
      loadChampions();
    } catch (e: any) {
      (window as any).toast?.(`${T.errorPrefix}: ${e?.message || 'grant failed'}`, 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  function applyGate(m: any) {
    if (hasPermission(m, 'admin.gamification')) showPanel();
    else showDenied();
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) { MEMBER = m; applyGate(MEMBER); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        MEMBER = data;
        applyGate(MEMBER);
        return;
      }
    } catch (e) { console.warn('gam boot:', e); }
    showDenied();
  }

  document.getElementById('gam-grant-btn')?.addEventListener('click', openGrantModal);
  document.getElementById('gam-modal-close')?.addEventListener('click', closeGrantModal);
  document.getElementById('gam-modal-cancel')?.addEventListener('click', closeGrantModal);
  document.getElementById('gam-modal-submit')?.addEventListener('click', submitGrant);
  document.getElementById('gam-surface')?.addEventListener('change', renderCriteria);
  document.getElementById('gam-justification')?.addEventListener('input', updateJustificationCounter);
  document.getElementById('gam-modal-overlay')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeGrantModal();
  });
  // p170 #15: debounced recipient_id watch → fetch showcase nudge
  document.getElementById('gam-recipient-id')?.addEventListener('input', (e) => {
    const val = ((e.target as HTMLInputElement).value || '').trim();
    if (showcaseNudgeDebounce) clearTimeout(showcaseNudgeDebounce);
    showcaseNudgeDebounce = setTimeout(() => loadShowcaseNudge(val), 400);
  });

  // p171 #13: activity panel controls
  document.getElementById('gam-activity-window')?.addEventListener('change', () => loadCategoryActivity());
  document.getElementById('gam-activity-include-inactive')?.addEventListener('change', () => loadCategoryActivity());

  boot();
</script>
