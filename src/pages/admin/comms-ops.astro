---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import CommsDashboard from '../../components/admin/CommsDashboard';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('nav.adminCommsOps', lang)} activePage="admin">
  <div class="max-w-[1100px] mx-auto px-4 py-8 space-y-4">
    <div id="commsops-loading" class="text-slate-400 text-sm">Carregando operações de comunicação...</div>
    <div id="commsops-denied" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800 text-sm">
      Acesso restrito à gestão/comunicação.
    </div>
    <section id="commsops-panel" class="hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h1 class="text-xl font-extrabold text-navy mb-4">Comms Ops Dashboard (W85)</h1>
      <CommsDashboard client:load />
    </section>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    function hasCommsOpsAccess(member) {
      if (!member) return false;
      if (member.is_superadmin) return true;
      var role = String(member.operational_role || '');
      var designations = Array.isArray(member.designations) ? member.designations : [];
      return ['manager', 'deputy_manager'].includes(role) || ['comms_leader', 'comms_member'].some(function (d) { return designations.includes(d); });
    }
    function bootCommsOpsPage() {
      var loading = document.getElementById('commsops-loading');
      var denied = document.getElementById('commsops-denied');
      var panel = document.getElementById('commsops-panel');
      var member = window.navGetMember && window.navGetMember();
      var sb = window.navGetSb && window.navGetSb();
      if (!member || !sb) {
        window.addEventListener('nav:member', bootCommsOpsPage, { once: true });
        return;
      }
      if (loading) loading.classList.add('hidden');
      if (!hasCommsOpsAccess(member)) {
        if (denied) denied.classList.remove('hidden');
        return;
      }
      if (panel) panel.classList.remove('hidden');
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootCommsOpsPage);
    } else {
      bootCommsOpsPage();
    }
  })();
</script>
