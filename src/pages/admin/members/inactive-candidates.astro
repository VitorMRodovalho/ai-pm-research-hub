---
/**
 * /admin/members/inactive-candidates — ARM-9 G4 inactivity detection surface.
 * Calls detect_inactive_members(dry_run=true) and shows candidates linked from the
 * weekly cron's manager notification.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getLangFromURL, type Lang } from '../../../i18n/utils';
import { buildPageI18n } from '../../../i18n/pageI18n';
import InactiveCandidatesIsland from '../../../components/admin/members/InactiveCandidatesIsland';
import Toast from '../../../components/ui/Toast.astro';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['inactiveCandidates', 'common'], lang);
---

<AdminLayout
  title="Candidatos a Inativo"
  breadcrumbs={[
    { label: 'Pessoas', href: '/admin/members' },
    { label: 'Membros', href: '/admin/members' },
    { label: 'Candidatos a Inativo' }
  ]}
>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <InactiveCandidatesIsland client:load />
  <Toast />
</AdminLayout>
