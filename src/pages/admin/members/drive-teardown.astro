---
/**
 * /admin/members/drive-teardown — #1026 Fatia C.
 * Drive-offboarding teardown queue (previously UI-less, LL#588): per-member revocation status +
 * positive clean-attestation, drill-down, and manual approve. Reader is manage_member-gated
 * (get_drive_teardown_overview); the client shell is cosmetic (ADR-0106 boundary = RLS + SECDEF).
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../../i18n/utils';
import { buildPageI18n } from '../../../i18n/pageI18n';
import DriveTeardownIsland from '../../../components/admin/members/DriveTeardownIsland';
import Toast from '../../../components/ui/Toast.astro';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
const i18nBundle = buildPageI18n(['driveTeardown', 'common'], lang);
---

<AdminLayout
  title={t('driveTeardown.title', lang)}
  breadcrumbs={[
    { label: t('admin.breadcrumb.people', lang), href: `${langPrefix}/admin/members` },
    { label: t('admin.breadcrumb.members', lang), href: `${langPrefix}/admin/members` },
    { label: t('admin.breadcrumb.driveTeardown', lang) }
  ]}
>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <DriveTeardownIsland client:load />
  <Toast />
</AdminLayout>
