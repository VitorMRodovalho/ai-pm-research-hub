---
/**
 * /admin/members/[id] — Member detail page with 7 sections.
 * React island: MemberDetailIsland.
 * Trilingue p139 Ω-B+.2.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import MemberDetailIsland from '../../../components/admin/members/MemberDetailIsland';
import Toast from '../../../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../../../i18n/utils';
import { buildPageI18n } from '../../../i18n/pageI18n';

const { id } = Astro.params;
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
if (!id) return Astro.redirect(`${langPrefix}/admin/members`);

const i18nBundle = buildPageI18n(['admin.member', 'comp.memberDetail'], lang);
---

<AdminLayout
  title={t('admin.memberDetail.pageTitle', lang)}
  breadcrumbs={[
    { label: t('admin.breadcrumb.people', lang), href: `${langPrefix}/admin/members` },
    { label: t('admin.breadcrumb.members', lang), href: `${langPrefix}/admin/members` },
    { label: t('admin.breadcrumb.detail', lang) }
  ]}
>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <MemberDetailIsland client:load memberId={id} />
  <Toast />
</AdminLayout>
