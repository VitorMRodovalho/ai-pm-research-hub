---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);

// Pre-render strings for inline TS script via define:vars (Ω-B+.6.b p143)
const CR_I18N = {
  errorLoadingCycle: t('cycleReport.errorLoadingCycle', lang),
  colCycle: t('cycleReport.colCycle', lang),
  colMembers: t('cycleReport.colMembers', lang),
  colChapters: t('cycleReport.colChapters', lang),
  colTribes: t('cycleReport.colTribes', lang),
  colEvents: t('cycleReport.colEvents', lang),
  colGrowth: t('cycleReport.colGrowth', lang),
  milestonesTitle: t('cycleReport.milestonesTitle', lang),
  milestoneNewChapters: t('cycleReport.milestoneNewChapters', lang),
  milestonePlatform: t('cycleReport.milestonePlatform', lang),
  milestoneGovernance: t('cycleReport.milestoneGovernance', lang),
  milestoneMcpServer: t('cycleReport.milestoneMcpServer', lang),
  milestoneArticles: t('cycleReport.milestoneArticles', lang),
  milestoneEvents: t('cycleReport.milestoneEvents', lang),
  subtitleGeneratedOn: t('cycleReport.subtitleGeneratedOn', lang),
  metaPrefix: t('cycleReport.metaPrefix', lang),
  statTotal: t('cycleReport.statTotal', lang),
  statActive: t('cycleReport.statActive', lang),
  statRetention: t('cycleReport.statRetention', lang),
  statNewInCycle: t('cycleReport.statNewInCycle', lang),
  roleOther: t('cycleReport.roleOther', lang),
  tribeLeaderLabel: t('cycleReport.tribeLeaderLabel', lang),
  tribeMembersLabel: t('cycleReport.tribeMembersLabel', lang),
  tribeCardsLabel: t('cycleReport.tribeCardsLabel', lang),
  tribeCompletionLabel: t('cycleReport.tribeCompletionLabel', lang),
  tribeArticlesLabel: t('cycleReport.tribeArticlesLabel', lang),
  prodSubmitted: t('cycleReport.prodSubmitted', lang),
  prodInReview: t('cycleReport.prodInReview', lang),
  prodPublished: t('cycleReport.prodPublished', lang),
  prodWebinarsDone: t('cycleReport.prodWebinarsDone', lang),
  prodWebinarsPlanned: t('cycleReport.prodWebinarsPlanned', lang),
  engEvents: t('cycleReport.engEvents', lang),
  engHoursImpact: t('cycleReport.engHoursImpact', lang),
  engAvgAttendance: t('cycleReport.engAvgAttendance', lang),
  engCertification: t('cycleReport.engCertification', lang),
  curReviewed: t('cycleReport.curReviewed', lang),
  curApproved: t('cycleReport.curApproved', lang),
  curInReview: t('cycleReport.curInReview', lang),
  curAvgTime: t('cycleReport.curAvgTime', lang),
  curSlaOk: t('cycleReport.curSlaOk', lang),
  attColTribe: t('cycleReport.attColTribe', lang),
  attColMembers: t('cycleReport.attColMembers', lang),
  attColGeneralPct: t('cycleReport.attColGeneralPct', lang),
  attColTribePct: t('cycleReport.attColTribePct', lang),
  attColCombinedPct: t('cycleReport.attColCombinedPct', lang),
  attColAtRisk: t('cycleReport.attColAtRisk', lang),
  footerTemplate: t('cycleReport.footerTemplate', lang),
  roleLabels: {
    researcher: t('role.researcher', lang),
    tribe_leader: t('role.tribe_leader', lang),
    comms_leader: t('role.comms_leader', lang),
    sponsor: t('role.sponsor', lang),
    chapter_liaison: t('role.chapter_liaison', lang),
    manager: t('role.manager', lang),
    deputy_manager: t('role.deputy_manager', lang),
    observer: 'Observador',
    communicator: t('role.communicator', lang),
    none: t('cycleReport.roleNone', lang),
  },
};
---

<AdminLayout title={t('cycleReport.meta', lang)} breadcrumbs={[{label: t('admin.breadcrumb.reports', lang)},{label: t('cycleReport.meta', lang)}]}>

  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <div id="cr-loading" class="text-center py-10 text-[var(--text-muted)]">{t('cycleReport.loading', lang)}</div>
    <div id="cr-denied" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800 text-sm text-center">
      {t('cycleReport.denied', lang)}
    </div>

    <div id="cr-report" class="hidden space-y-8">
      <!-- Print-only institutional header -->
      <div id="cr-print-header" class="hidden print:block text-center mb-6 pb-4 border-b-2 border-navy">
        <div class="text-[10px] font-bold uppercase tracking-[.2em] text-gray-500 mb-1">{t('cycleReport.printOrgName', lang)}</div>
        <h1 class="text-xl font-extrabold text-navy">{t('cycleReport.printDocTitle', lang)}</h1>
        <div class="text-xs text-gray-600 mt-2 space-y-0.5">
          <div>{t('cycleReport.printIssuedBy', lang)}: <strong>Vitor Maia Rodovalho</strong> ({t('cycleReport.printIssuedRole', lang)})</div>
          <div>{t('cycleReport.printIssuedDate', lang)}: <strong id="cr-print-date"></strong></div>
          <div>{t('cycleReport.printCode', lang)}: <strong id="cr-print-code"></strong></div>
        </div>
      </div>

      <!-- Screen header -->
      <header class="flex items-center justify-between print:hidden flex-wrap gap-4">
        <div>
          <h1 class="text-2xl font-extrabold text-navy" id="cr-title">{t('cycleReport.title', lang)}</h1>
          <p class="text-sm text-[var(--text-secondary)]" id="cr-subtitle"></p>
        </div>
        <button id="cr-export-pdf" class="px-4 py-2 rounded-lg bg-navy text-white text-sm font-semibold cursor-pointer border-0 hover:opacity-90">
          {t('cycleReport.exportPdf', lang)}
        </button>
      </header>

      <!-- Evolution C2→C3 -->
      <section class="cr-section" id="cr-evolution-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.evolutionTitle', lang)}</h2>
        <div id="cr-evolution" class="space-y-4"></div>
      </section>

      <!-- KPIs Semaphore -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.kpisTitle', lang)}</h2>
        <div id="cr-kpis" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3"></div>
      </section>

      <!-- Members -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.membersTitle', lang)}</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4" id="cr-members-stats"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
            <h3 class="text-sm font-bold text-navy mb-2">{t('cycleReport.byChapter', lang)}</h3>
            <div style="position: relative; height: 300px; max-height: 300px; width: 100%; overflow: hidden;">
              <canvas id="cr-chart-chapters" style="max-height: 300px;"></canvas>
            </div>
          </div>
          <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
            <h3 class="text-sm font-bold text-navy mb-2">{t('cycleReport.byRole', lang)}</h3>
            <div style="position: relative; height: 300px; max-height: 300px; width: 100%; overflow: hidden;">
              <canvas id="cr-chart-roles" style="max-height: 300px;"></canvas>
            </div>
          </div>
        </div>
      </section>

      <!-- Tribes -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.tribesTitle', lang)}</h2>
        <div id="cr-tribes" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3"></div>
      </section>

      <!-- Production -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.productionTitle', lang)}</h2>
        <div id="cr-production" class="grid grid-cols-2 md:grid-cols-5 gap-3"></div>
      </section>

      <!-- Engagement -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.engagementTitle', lang)}</h2>
        <div id="cr-engagement" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
      </section>

      <!-- Curation -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.curationTitle', lang)}</h2>
        <div id="cr-curation" class="grid grid-cols-2 md:grid-cols-5 gap-3"></div>
      </section>

      <!-- Attendance by Tribe -->
      <section class="cr-section">
        <h2 class="text-lg font-extrabold text-navy mb-3">{t('cycleReport.attendanceByTribe', lang)}</h2>
        <div id="cr-attendance" class="overflow-x-auto"></div>
      </section>

      <!-- Footer (screen) -->
      <footer class="text-center text-xs text-[var(--text-muted)] pt-4 border-t border-[var(--border-default)] print:hidden">
        <span id="cr-footer"></span>
      </footer>
      <!-- Footer (print-only) -->
      <footer class="hidden print:block text-center text-[8px] text-gray-400 pt-4 mt-8 border-t border-gray-300">
        <div>{t('cycleReport.printFooterAuto', lang)}</div>
        <div>{t('cycleReport.printFooterUrl', lang)}</div>
        <div class="mt-1">{t('cycleReport.printFooterMarks', lang)}</div>
      </footer>
    </div>
  </div>
</AdminLayout>

<script is:inline define:vars={{ CR_I18N }}>
  window.__CR_I18N = CR_I18N;
</script>
<script>
  import Chart from 'chart.js/auto';
  import { hasPermission } from '../../lib/permissions';

  // PT-BR fallbacks (graceful degradation if define:vars injection fails)
  const T = (typeof window !== 'undefined' && (window as any).__CR_I18N) || {
    errorLoadingCycle: 'Falha ao gerar relatório do ciclo.',
    colCycle: 'Ciclo', colMembers: 'Membros', colChapters: 'Capítulos',
    colTribes: 'Tribos', colEvents: 'Eventos', colGrowth: 'Crescimento',
    milestonesTitle: 'Marcos do Ciclo 3',
    milestoneNewChapters: '🏛 {n} novos capítulos integrados ({names})',
    milestonePlatform: '🚀 Plataforma {version} em produção',
    milestoneGovernance: '📋 Governança digital: manual versionável, CRs com aprovação por quorum SHA-256',
    milestoneMcpServer: '🤖 Servidor MCP: 15 ferramentas para assistentes IA',
    milestoneArticles: '📄 {n} artigos submetidos a plataformas internacionais',
    milestoneEvents: '📅 {n} eventos realizados no C3',
    subtitleGeneratedOn: 'Gerado em', metaPrefix: 'meta',
    statTotal: 'Total', statActive: 'Ativos', statRetention: 'Retenção',
    statNewInCycle: 'Novos no Ciclo', roleOther: 'Outro',
    tribeLeaderLabel: 'Líder', tribeMembersLabel: 'Membros',
    tribeCardsLabel: 'Cards', tribeCompletionLabel: 'Conclusão',
    tribeArticlesLabel: 'Artigos',
    prodSubmitted: 'Submetidos', prodInReview: 'Em Revisão',
    prodPublished: 'Publicados', prodWebinarsDone: 'Webinars OK',
    prodWebinarsPlanned: 'Webinars Plan.',
    engEvents: 'Eventos', engHoursImpact: 'Horas Impacto',
    engAvgAttendance: 'Presença Média', engCertification: 'Certificação',
    curReviewed: 'Revisados', curApproved: 'Aprovados', curInReview: 'Em Revisão',
    curAvgTime: 'Tempo Médio', curSlaOk: 'SLA OK',
    attColTribe: 'Tribo', attColMembers: 'Membros',
    attColGeneralPct: 'Geral %', attColTribePct: 'Tribo %',
    attColCombinedPct: 'Combinado %', attColAtRisk: 'Em Risco',
    footerTemplate: 'Gerado em {date} · Núcleo IA & GP · nucleoia.vitormr.dev',
    roleLabels: {
      researcher: 'Pesquisador', tribe_leader: 'Líder de Tribo',
      comms_leader: 'Líder de Comunicação', sponsor: 'Patrocinador',
      chapter_liaison: 'Ponto Focal', manager: 'Gerente',
      deputy_manager: 'Deputy', observer: 'Observador',
      communicator: 'Comunicação', none: 'Sem papel',
    },
  };

  function _interp(s: string, vars: Record<string, string | number>): string {
    return Object.entries(vars).reduce((acc, [k, v]) => acc.replace(`{${k}}`, String(v)), s);
  }

  let crBootRetries = 0;
  let crChapterChart: Chart | null = null;
  let crRoleChart: Chart | null = null;

  const STATUS_STYLES: Record<string, { bg: string; border: string; text: string }> = {
    green:  { bg: '#D1FAE5', border: '#6EE7B7', text: '#047857' },
    yellow: { bg: '#FEF3C7', border: '#FCD34D', text: '#B45309' },
    red:    { bg: '#FEE2E2', border: '#FCA5A5', text: '#DC2626' },
  };

  const CHART_COLORS = [
    '#003B5C', '#4F17A8', '#05BFE0', '#FF610F', '#EC4899',
    '#10B981', '#D97706', '#7C3AED', '#BE2027', '#00799E',
  ];

  function statCard(label: string, value: string | number, accent = '') {
    return `<div class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-3">
      <div class="text-[10px] uppercase tracking-wide font-semibold text-[var(--text-secondary)]">${label}</div>
      <div class="text-2xl font-extrabold ${accent || 'text-navy'}">${value}</div>
    </div>`;
  }

  function hasAccess(member: any): boolean {
    if (!member) return false;
    return hasPermission(member, 'admin.analytics');
  }

  async function bootCycleReport() {
    const loading = document.getElementById('cr-loading');
    const denied = document.getElementById('cr-denied');
    const report = document.getElementById('cr-report');
    const member = (window as any).navGetMember?.();
    const sb = (window as any).navGetSb?.();

    if (!member || !sb) {
      crBootRetries++;
      if (crBootRetries >= 60) {
        loading?.classList.add('hidden');
        denied?.classList.remove('hidden');
        return;
      }
      setTimeout(bootCycleReport, 300);
      return;
    }

    loading?.classList.add('hidden');
    if (!hasAccess(member)) {
      denied?.classList.remove('hidden');
      return;
    }

    const { data, error } = await sb.rpc('exec_cycle_report');
    if (error || !data) {
      denied?.classList.remove('hidden');
      denied!.textContent = T.errorLoadingCycle;
      return;
    }

    // Also fetch evolution data
    const { data: evoData } = await sb.rpc('get_cycle_evolution');

    report?.classList.remove('hidden');
    renderReport(data);
    if (evoData) renderEvolution(evoData);
  }

  function renderEvolution(evo: any) {
    const el = document.getElementById('cr-evolution');
    if (!el) return;

    const cycles = evo.cycles || [];
    const highlights = evo.highlights || {};

    // Timeline table
    const timelineRows = cycles.map((c: any) => {
      const isC3 = c.cycle_code === 'cycle_3';
      const bold = isC3 ? 'font-bold text-navy' : '';
      return `<tr class="border-t border-[var(--border-subtle)] ${isC3 ? 'bg-blue-50/50 dark:bg-blue-900/10' : ''}">
        <td class="px-3 py-2 ${bold}">${c.cycle_label}</td>
        <td class="px-3 py-2 text-center ${bold}">${c.members}</td>
        <td class="px-3 py-2 text-center">${c.chapters || '—'}</td>
        <td class="px-3 py-2 text-center">${c.tribes || '—'}</td>
        <td class="px-3 py-2 text-center">${c.events || '—'}</td>
        <td class="px-3 py-2 text-center">${c.growth ? `<span class="text-emerald-600 font-bold">+${c.growth}%</span>` : '—'}</td>
      </tr>`;
    }).join('');

    // Key milestones
    const milestones = [
      highlights.new_chapters ? _interp(T.milestoneNewChapters, { n: highlights.new_chapters, names: highlights.chapter_names || '' }) : null,
      highlights.platform_version ? _interp(T.milestonePlatform, { version: highlights.platform_version }) : null,
      highlights.governance_digital ? T.milestoneGovernance : null,
      highlights.mcp_server ? T.milestoneMcpServer : null,
      highlights.total_articles ? _interp(T.milestoneArticles, { n: highlights.total_articles }) : null,
      highlights.total_events_c3 ? _interp(T.milestoneEvents, { n: highlights.total_events_c3 }) : null,
    ].filter(Boolean);

    el.innerHTML = `
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <table class="w-full text-xs">
          <thead>
            <tr class="bg-[var(--surface-base)]">
              <th class="text-left px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.colCycle}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.colMembers}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.colChapters}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.colTribes}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.colEvents}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.colGrowth}</th>
            </tr>
          </thead>
          <tbody>${timelineRows}</tbody>
        </table>
      </div>
      ${milestones.length ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-2">${T.milestonesTitle}</h3>
          <ul class="space-y-1.5 text-sm text-[var(--text-primary)]">
            ${milestones.map(m => `<li>${m}</li>`).join('')}
          </ul>
        </div>
      ` : ''}
    `;
  }

  function renderReport(r: any) {
    const lang = document.documentElement.lang?.startsWith('en') ? 'en' : document.documentElement.lang?.startsWith('es') ? 'es' : 'pt';

    // Header
    const subtitle = document.getElementById('cr-subtitle');
    if (subtitle) subtitle.textContent = `${r.cycle?.name || ''} — ${T.subtitleGeneratedOn} ${new Date().toLocaleDateString('pt-BR')}`;

    // KPIs
    const kpisEl = document.getElementById('cr-kpis');
    if (kpisEl && Array.isArray(r.kpis)) {
      kpisEl.innerHTML = r.kpis.map((k: any) => {
        const s = STATUS_STYLES[k.status] || STATUS_STYLES.red;
        const label = k.label?.[lang] || k.label?.pt || k.metric_key;
        const pct = Math.min(Number(k.progress_pct) || 0, 100);
        const unitSuffix = k.unit === 'percent' ? '%' : k.unit === 'hours' ? 'h' : '';
        return `<div class="rounded-xl p-3 text-center" style="background:${s.bg};border:1px solid ${s.border}">
          <div class="text-2xl font-extrabold" style="color:${s.text}">${k.current}${unitSuffix}</div>
          <div class="text-[10px] font-bold uppercase tracking-wide" style="color:${s.text}">${label}</div>
          <div class="w-full h-1.5 rounded-full mt-2" style="background:${s.border}40">
            <div class="h-full rounded-full" style="width:${pct}%;background:${s.text}"></div>
          </div>
          <div class="text-[9px] mt-1" style="color:${s.text}">${pct}% — ${T.metaPrefix}: ${k.target}${unitSuffix}</div>
        </div>`;
      }).join('');
    }

    // Members stats
    const ms = r.members || {};
    const membersStatsEl = document.getElementById('cr-members-stats');
    if (membersStatsEl) {
      membersStatsEl.innerHTML = [
        statCard(T.statTotal, ms.total || 0),
        statCard(T.statActive, ms.active || 0, 'text-emerald-600'),
        statCard(T.statRetention, `${ms.retention_rate || 0}%`, 'text-blue-600'),
        statCard(T.statNewInCycle, ms.new_this_cycle || 0, 'text-purple'),
      ].join('');
    }

    // Role label map (i18n) — single source via T.roleLabels
    const rl = T.roleLabels;

    // Founding chapters keep established branding colors; new chapters get
    // deterministic HSL via code hash so charts stay readable as registry expands.
    const FOUNDING_CHAPTER_PALETTE: Record<string, string> = { 'PMI-GO': '#0F6E56', 'PMI-CE': '#534AB7', 'PMI-DF': '#D85A30', 'PMI-MG': '#185FA5', 'PMI-RS': '#639922' };
    function chapterColor(code: string): string {
      if (FOUNDING_CHAPTER_PALETTE[code]) return FOUNDING_CHAPTER_PALETTE[code];
      let hash = 0;
      for (let i = 0; i < code.length; i++) hash = (hash * 31 + code.charCodeAt(i)) >>> 0;
      return `hsl(${hash % 360} 55% 42%)`;
    }
    const rolePalette: Record<string, string> = { researcher: '#378ADD', tribe_leader: '#1D9E75', comms_leader: '#0E7490', sponsor: '#BA7517', chapter_liaison: '#7F77DD', manager: '#D85A30', deputy_manager: '#D4537E', observer: '#888780', communicator: '#639922', none: '#B4B2A9' };

    // Dark mode support
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? '#c2c0b6' : '#3d3d3a';
    const gridColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';
    const borderColor = isDark ? '#1a2332' : '#ffffff';
    Chart.defaults.color = textColor;

    // Chart: by chapter (horizontal bar)
    if (crChapterChart) { crChapterChart.destroy(); crChapterChart = null; }
    if (crRoleChart) { crRoleChart.destroy(); crRoleChart = null; }

    const chaptersCanvas = document.getElementById('cr-chart-chapters') as HTMLCanvasElement;
    if (chaptersCanvas && Array.isArray(ms.by_chapter) && ms.by_chapter.length > 0) {
      crChapterChart = new Chart(chaptersCanvas, {
        type: 'bar',
        data: {
          labels: ms.by_chapter.map((c: any) => c.chapter),
          datasets: [{
            data: ms.by_chapter.map((c: any) => c.count),
            backgroundColor: ms.by_chapter.map((c: any) => chapterColor(c.chapter)),
            borderWidth: 0,
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: { beginAtZero: true, ticks: { precision: 0, color: textColor }, grid: { color: gridColor } },
            y: { ticks: { font: { size: 11 }, color: textColor }, grid: { display: false } },
          },
        },
      });
    }

    // Chart: by role (donut) — translated labels
    const rolesCanvas = document.getElementById('cr-chart-roles') as HTMLCanvasElement;
    if (rolesCanvas && Array.isArray(ms.by_role) && ms.by_role.length > 0) {
      crRoleChart = new Chart(rolesCanvas, {
        type: 'doughnut',
        data: {
          labels: ms.by_role.map((r: any) => rl[r.role] || r.role || T.roleOther),
          datasets: [{
            data: ms.by_role.map((r: any) => r.count),
            backgroundColor: ms.by_role.map((r: any) => rolePalette[r.role] || '#B4B2A9'),
            borderWidth: 2,
            borderColor: borderColor,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, color: textColor, padding: 12 } } },
        },
      });
    }

    // Tribes
    const tribesEl = document.getElementById('cr-tribes');
    if (tribesEl && Array.isArray(r.tribes)) {
      tribesEl.innerHTML = r.tribes.map((t: any) => `
        <div class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4">
          <div class="text-sm font-bold text-navy">${t.name}</div>
          <div class="text-[10px] text-[var(--text-muted)] mb-2">${T.tribeLeaderLabel}: ${t.leader}</div>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div>${T.tribeMembersLabel}: <strong>${t.member_count}</strong></div>
            <div>${T.tribeCardsLabel}: <strong>${t.board_items_completed}/${t.board_items_total}</strong></div>
            <div>${T.tribeCompletionLabel}: <strong>${t.completion_pct}%</strong></div>
            <div>${T.tribeArticlesLabel}: <strong>${t.articles_produced}</strong></div>
          </div>
          <div class="w-full h-1.5 rounded-full bg-[var(--border-default)] mt-2 overflow-hidden">
            <div class="h-full rounded-full bg-emerald-500" style="width:${Math.min(t.completion_pct, 100)}%"></div>
          </div>
        </div>
      `).join('');
    }

    // Production
    const prod = r.production || {};
    const prodEl = document.getElementById('cr-production');
    if (prodEl) {
      prodEl.innerHTML = [
        statCard(T.prodSubmitted, prod.articles_submitted || 0),
        statCard(T.prodInReview, prod.articles_in_review || 0, 'text-amber-600'),
        statCard(T.prodPublished, prod.articles_published || 0, 'text-emerald-600'),
        statCard(T.prodWebinarsDone, prod.webinars_completed || 0, 'text-blue-600'),
        statCard(T.prodWebinarsPlanned, prod.webinars_planned || 0),
      ].join('');
    }

    // Engagement
    const eng = r.engagement || {};
    const engEl = document.getElementById('cr-engagement');
    if (engEl) {
      engEl.innerHTML = [
        statCard(T.engEvents, eng.total_events || 0),
        statCard(T.engHoursImpact, `${Number(eng.total_attendance_hours || 0).toLocaleString('pt-BR')}h`, 'text-teal'),
        statCard(T.engAvgAttendance, eng.avg_attendance_per_event || 0),
        statCard(T.engCertification, `${eng.certification_completion_rate || 0}%`, 'text-purple'),
      ].join('');
    }

    // Curation
    const cur = r.curation || {};
    const curEl = document.getElementById('cr-curation');
    if (curEl) {
      curEl.innerHTML = [
        statCard(T.curReviewed, cur.items_submitted || 0),
        statCard(T.curApproved, cur.items_approved || 0, 'text-emerald-600'),
        statCard(T.curInReview, cur.items_in_review || 0, 'text-amber-600'),
        statCard(T.curAvgTime, `${cur.avg_review_days || 0}d`),
        statCard(T.curSlaOk, `${cur.sla_compliance_rate || 0}%`, 'text-blue-600'),
      ].join('');
    }

    // Attendance by tribe
    const attEl = document.getElementById('cr-attendance');
    if (attEl && Array.isArray(r.attendance) && r.attendance.length > 0) {
      attEl.innerHTML = `
        <table class="w-full text-xs">
          <thead>
            <tr class="bg-[var(--surface-base)]">
              <th class="text-left px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.attColTribe}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.attColMembers}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.attColGeneralPct}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.attColTribePct}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.attColCombinedPct}</th>
              <th class="text-center px-3 py-2 font-semibold text-[var(--text-secondary)]">${T.attColAtRisk}</th>
            </tr>
          </thead>
          <tbody>
            ${r.attendance.map((a: any) => {
              const combined = Number(a.avg_combined_pct) || 0;
              const risk = Number(a.at_risk_count) || 0;
              const color = combined >= 75 ? 'text-emerald-600' : combined >= 50 ? 'text-amber-600' : 'text-red-600';
              return `<tr class="border-t border-[var(--border-subtle)]">
                <td class="px-3 py-2 font-semibold text-[var(--text-primary)]">${a.tribe_name}</td>
                <td class="px-3 py-2 text-center">${a.members_count}</td>
                <td class="px-3 py-2 text-center">${a.avg_geral_pct}%</td>
                <td class="px-3 py-2 text-center">${a.avg_tribe_pct}%</td>
                <td class="px-3 py-2 text-center font-bold ${color}">${combined}%</td>
                <td class="px-3 py-2 text-center">${risk > 0 ? `<span class="text-red-600 font-bold">${risk}</span>` : '—'}</td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      `;
    }

    // Also render KPIs from new format if available
    const kpisEl2 = document.getElementById('cr-kpis');
    if (kpisEl2 && r.kpis?.kpis && Array.isArray(r.kpis.kpis)) {
      const cyclePct = r.kpis.cycle_pct || 0;
      kpisEl2.innerHTML = r.kpis.kpis.map((k: any) => {
        const pct = k.target > 0 ? Math.round((k.current / k.target) * 100) : 0;
        const status = pct >= cyclePct ? 'green' : pct >= cyclePct * 0.75 ? 'yellow' : 'red';
        const s = STATUS_STYLES[status];
        return `<div class="rounded-xl p-3 text-center" style="background:${s.bg};border:1px solid ${s.border}">
          <div class="text-2xl font-extrabold" style="color:${s.text}">${k.current}${k.unit ? k.unit : ''}</div>
          <div class="text-[10px] font-bold uppercase tracking-wide" style="color:${s.text}">${k.name}</div>
          <div class="w-full h-1.5 rounded-full mt-2" style="background:${s.border}40">
            <div class="h-full rounded-full" style="width:${Math.min(pct, 100)}%;background:${s.text}"></div>
          </div>
          <div class="text-[9px] mt-1" style="color:${s.text}">${pct}% — ${T.metaPrefix}: ${k.target}${k.unit ? k.unit : ''}</div>
        </div>`;
      }).join('');
    }

    // Footer
    const footer = document.getElementById('cr-footer');
    if (footer) {
      footer.textContent = _interp(T.footerTemplate, { date: new Date().toLocaleDateString('pt-BR') });
    }
  }

  // Export PDF
  document.getElementById('cr-export-pdf')?.addEventListener('click', () => {
    // Generate timestamp and verification code for print header
    const now = new Date();
    const dateStr = now.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    const code = 'RPT-' + now.getFullYear() + '-' + Math.random().toString(36).substring(2, 8).toUpperCase();
    const printDate = document.getElementById('cr-print-date');
    const printCode = document.getElementById('cr-print-code');
    if (printDate) printDate.textContent = dateStr;
    if (printCode) printCode.textContent = code;

    try { if ((window as any).posthog) (window as any).posthog.capture('report_exported', { report_type: 'cycle', code }); } catch {}
    window.print();
  });

  document.addEventListener('DOMContentLoaded', () => {
    requestAnimationFrame(() => bootCycleReport());
  });
</script>

<style>
  @media print {
    /* ═══ HIDE EVERYTHING THAT ISN'T REPORT CONTENT ═══ */

    /* Nav bar (BaseLayout) */
    body > div > nav,
    body > div > header,
    [class*="nav-"],
    #site-nav,
    .site-header { display: none !important; }

    /* Announcement banner */
    #announcements-area,
    .ann-banner,
    [data-ann-id] { display: none !important; }

    /* AdminSidebar */
    [class*="AdminSidebar"],
    .flex.min-h-\[calc\(100vh-64px\)\] > div:first-child,
    aside { display: none !important; }

    /* Breadcrumbs */
    nav:has(ol) { display: none !important; }

    /* Mobile hamburger */
    #admin-sidebar-toggle { display: none !important; }

    /* TierViewerBar */
    [class*="TierViewer"],
    [class*="tier-viewer"] { display: none !important; }

    /* Cookie consent */
    #consent-banner { display: none !important; }

    /* Help floating button */
    [class*="HelpFloating"],
    button[aria-label*="help" i],
    .fixed.bottom-4.right-4 { display: none !important; }

    /* Footer (BaseLayout) */
    body > div > footer,
    footer.bg-\[\#200F3B\] { display: none !important; }

    /* All buttons except inside report */
    #cr-export-pdf { display: none !important; }

    /* Generic print:hidden */
    .print\:hidden, [class*="print:hidden"] { display: none !important; }

    /* ═══ LAYOUT RESET ═══ */
    body { margin: 0 !important; padding: 0 !important; background: white !important; color: black !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    /* Remove sidebar flex layout — make content full width */
    .flex.min-h-\[calc\(100vh-64px\)\] { display: block !important; }
    main { width: 100% !important; max-width: 100% !important; padding: 0.5rem !important; overflow: visible !important; }
    .max-w-\[1200px\] { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
    .p-6 { padding: 0 !important; }

    /* ═══ SHOW PRINT ELEMENTS ═══ */
    #cr-print-header { display: block !important; }

    /* ═══ CONTENT FORMATTING ═══ */
    .cr-section { page-break-inside: avoid; margin-bottom: 1rem; }
    canvas { max-height: 250px !important; }

    /* Force colors to print (stat cards, progress bars) */
    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }

    /* Dark mode override */
    [data-theme="dark"] .cr-section,
    [data-theme="dark"] .cr-section * { color: black !important; background: white !important; border-color: #ddd !important; }

    /* ═══ PAGE SETUP ═══ */
    @page { margin: 1.5cm; size: A4 portrait; }
    @page :first { margin-top: 1cm; }
  }
</style>
