    /* Force colors to print (stat cards, progress bars) */
    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }

    /* Dark mode override */
    [data-theme="dark"] .cr-section,
    [data-theme="dark"] .cr-section * { color: black !important; background: white !important; border-color: #ddd !important; }

    /* ═══ PAGE SETUP ═══ */
    @page { margin: 1.5cm; size: A4 portrait; }
    @page :first { margin-top: 1cm; }
  }
</style>
