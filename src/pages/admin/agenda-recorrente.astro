---
/**
 * /admin/agenda-recorrente — #676 Slice 2 (read-only).
 * Canonical recurring-meeting rules for tribes/initiatives + drift indicators.
 * UX gate mirrors manage_platform (GP); the server RPC (get_recurring_meeting_admin_list,
 * gated manage_platform) is the real boundary.
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import RecurringAgendaIsland from '../../components/admin/RecurringAgendaIsland';
import Toast from '../../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.recurringAgenda', 'comp.common'], lang);
---

<AdminLayout
  title={t('admin.breadcrumb.recurringAgenda', lang)}
  breadcrumbs={[
    { label: t('admin.breadcrumb.operations', lang) },
    { label: t('admin.breadcrumb.recurringAgenda', lang) },
  ]}
>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <div class="max-w-[1200px] mx-auto px-4 pb-12">
    <RecurringAgendaIsland client:load />
  </div>
  <Toast />
</AdminLayout>

<script is:inline define:vars={{ deniedMsg: t('admin.deniedAdmin', lang) }}>
  document.addEventListener('DOMContentLoaded', () => {
    const check = () => {
      const member = window.navGetMember?.();
      if (!member) { setTimeout(check, 300); return; }
      // UX gate only — the server RPC (manage_platform) is the real boundary.
      // Mirror manage_platform = platform managers (GP/superadmin/deputy).
      const isAllowed =
        member.is_superadmin ||
        member.operational_role === 'manager' ||
        (member.designations || []).some(function (d) { return d === 'deputy_manager'; });
      if (!isAllowed) {
        document.querySelector('.max-w-\\[1200px\\]').innerHTML =
          '<div class="text-center py-20 text-[var(--text-muted)]">' + deniedMsg + '</div>';
      }
    };
    check();
  });
</script>
