---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import Toast from '../../components/ui/Toast.astro';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

// Pre-render strings for inline TS script via define:vars (Ω-B+.3.b p140)
const SETTINGS_I18N = {
  statusActive: t('admin.settings.statusActive', lang),
  rangeSeparator: t('admin.settings.rangeSeparator', lang),
  endOpen: t('admin.settings.endOpen', lang),
  activate: t('admin.settings.activate', lang),
  confirmActivate: t('admin.settings.confirmActivate', lang),
  activated: t('admin.settings.activated', lang),
  edit: t('common.edit', lang),
  delete: t('common.delete', lang),
  confirmDelete: t('admin.settings.confirmDelete', lang),
  deleted: t('admin.settings.deleted', lang),
  errorPrefix: t('common.errorPrefix', lang),
  editCycle: t('admin.settings.editCycle', lang),
  newCycle: t('admin.settings.cycleNewTitle', lang),
  fillRequired: t('admin.settings.fillRequiredCycle', lang),
  cycleUpdated: t('admin.settings.cycleUpdated', lang),
  cycleCreated: t('admin.settings.cycleCreated', lang),
  save: t('common.save', lang),
  saveError: t('admin.saveError', lang),
  loadError: t('admin.loadError', lang),
  noResults: t('admin.noResults', lang),
  platformResearchersLabel: t('admin.settings.platformResearchersLabel', lang),
  platformResearchersDesc: t('admin.settings.platformResearchersDesc', lang),
  platformMaxTribesLabel: t('admin.settings.platformMaxTribesLabel', lang),
  platformMaxTribesDesc: t('admin.settings.platformMaxTribesDesc', lang),
  platformGracePeriodLabel: t('admin.settings.platformGracePeriodLabel', lang),
  platformGracePeriodDesc: t('admin.settings.platformGracePeriodDesc', lang),
  lastChangeLabel: t('admin.settings.lastChangeLabel', lang),
  reasonPrompt: t('admin.settings.reasonPrompt', lang),
  reasonRequired: t('admin.settings.reasonRequired', lang),
  platformUpdated: t('admin.settings.platformUpdated', lang),
  slaUnitHours: t('admin.settings.slaUnitHours', lang),
  slaUnitDays: t('admin.settings.slaUnitDays', lang),
  slaCurrentLabel: t('admin.settings.slaCurrentLabel', lang),
  slaConfirm: t('admin.settings.slaConfirm', lang),
  slaSaved: t('admin.settings.slaSaved', lang),
  slaRangeError: t('admin.settings.slaRangeError', lang),
  slaInterviewOverdueLabel: t('admin.settings.slaInterviewOverdueLabel', lang),
  slaInterviewOverdueHelp: t('admin.settings.slaInterviewOverdueHelp', lang),
  slaStuckScheduledLabel: t('admin.settings.slaStuckScheduledLabel', lang),
  slaStuckScheduledHelp: t('admin.settings.slaStuckScheduledHelp', lang),
  slaRescheduleInitialLabel: t('admin.settings.slaRescheduleInitialLabel', lang),
  slaRescheduleInitialHelp: t('admin.settings.slaRescheduleInitialHelp', lang),
  slaRescheduleRepeatLabel: t('admin.settings.slaRescheduleRepeatLabel', lang),
  slaRescheduleRepeatHelp: t('admin.settings.slaRescheduleRepeatHelp', lang),
};
---

<AdminLayout title={t('nav.adminSettings', lang)} breadcrumbs={[{label: t('admin.breadcrumb.operations', lang)},{label: t('nav.adminSettings', lang)}]}>
  <div class="max-w-[700px] mx-auto px-4 pb-12">
    <div id="settings-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-8 text-center">
      <div class="text-3xl mb-3">&#x1F512;</div>
      <p class="font-semibold text-amber-800">{t('admin.settings.deniedSuperadmin', lang)}</p>
      <a href={`${langPrefix}/admin`} class="inline-block mt-4 px-5 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{t('admin.backToAdmin', lang)}</a>
    </div>

    <div id="settings-panel" class="hidden space-y-6">
      <div class="mb-6">
        <h1 class="text-2xl font-extrabold text-navy">{t('admin.settings.title', lang)}</h1>
        <p class="text-sm text-[var(--text-secondary)] mt-1">{t('admin.settings.description', lang)}</p>
      </div>

      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.settings.parameters', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)] mt-0.5">{t('admin.settings.parametersHint', lang)}</p>
        </div>
        <div class="p-5 space-y-4">
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.groupTermLabel', lang)}</label>
            <input type="text" id="cfg-group-term" placeholder={t('admin.settings.groupTermPlaceholder', lang)} class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
            <p class="text-[.6rem] text-[var(--text-muted)] mt-1">{t('admin.settings.groupTermHint', lang)}</p>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.cycleDefaultLabel', lang)}</label>
            <input type="text" id="cfg-cycle-default" placeholder="—" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
            <p class="text-[.6rem] text-[var(--text-muted)] mt-1">{t('admin.settings.cycleDefaultHint', lang)}</p>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">Webhook URL</label>
            <input type="url" id="cfg-webhook-url" placeholder="https://..." class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
            <p class="text-[.6rem] text-[var(--text-muted)] mt-1">{t('admin.settings.webhookHint', lang)}</p>
          </div>
          <button id="cfg-save" class="w-full px-4 py-2.5 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
            {t('admin.settings.saveBtn', lang)}
          </button>
        </div>
      </div>

      <!-- ── Platform Settings (Configurable Limits) ── -->
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.settings.platformLimits', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)] mt-0.5">{t('admin.settings.platformLimitsHint', lang)}</p>
        </div>
        <div id="platform-settings" class="p-5 space-y-3">
          <p class="text-[.7rem] text-[var(--text-muted)]">{t('common.loading', lang)}</p>
        </div>
      </div>

      <!-- ── J4 PR2 (#766): SLA Windows ── -->
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.settings.slaTitle', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)] mt-0.5">{t('admin.settings.slaHint', lang)}</p>
          <p class="text-[.62rem] text-amber-600 mt-1.5 flex items-start gap-1">
            <span aria-hidden="true">&#x26A0;</span>
            <span>{t('admin.settings.slaWarning', lang)}</span>
          </p>
        </div>
        <div class="p-5">
          <div id="sla-loading" class="text-[.7rem] text-[var(--text-muted)]">{t('common.loading', lang)}</div>
          <div id="sla-error" class="hidden text-[.7rem] text-red-600"></div>
          <div id="sla-content" class="hidden space-y-4">
            <div>
              <div class="text-[.6rem] font-semibold uppercase tracking-wide text-[var(--text-muted)] mb-2">{t('admin.settings.slaGroupInterviews', lang)}</div>
              <div id="sla-group-interviews" class="space-y-3"></div>
            </div>
            <hr class="border-[var(--border-subtle)]">
            <div>
              <div class="text-[.6rem] font-semibold uppercase tracking-wide text-[var(--text-muted)] mb-2">{t('admin.settings.slaGroupReschedule', lang)}</div>
              <div id="sla-group-reschedule" class="space-y-3"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── W111: Cycle Management ── -->
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)] flex items-center justify-between">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.settings.cycleManagement', lang)}</h2>
            <p class="text-[.68rem] text-[var(--text-muted)] mt-0.5">{t('admin.settings.cycleManagementHint', lang)}</p>
          </div>
          <button id="cycle-add-btn" class="px-3 py-1.5 bg-navy text-white rounded-lg text-[.7rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
            + {t('admin.settings.cycleAddBtn', lang)}
          </button>
        </div>
        <div id="cycle-list" class="p-5 space-y-3">
          <p class="text-[.7rem] text-[var(--text-muted)]">{t('admin.loadingCycles', lang)}</p>
        </div>
      </div>

      <!-- Cycle Modal -->
      <div id="cycle-modal-overlay" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center">
        <div class="bg-[var(--surface-card)] rounded-2xl shadow-xl w-full max-w-md mx-4 border border-[var(--border-default)]">
          <div class="px-5 py-4 border-b border-[var(--border-default)] flex items-center justify-between">
            <h3 id="cycle-modal-title" class="text-sm font-bold text-navy">{t('admin.settings.cycleNewTitle', lang)}</h3>
            <button id="cycle-modal-close" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] text-lg cursor-pointer bg-transparent border-0">&times;</button>
          </div>
          <div class="p-5 space-y-3">
            <div>
              <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.cycleCodeLabel', lang)}</label>
              <input type="text" id="cyc-code" placeholder="cycle_4" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
              <p class="text-[.6rem] text-[var(--text-muted)] mt-0.5">{t('admin.settings.cycleCodeHint', lang)}</p>
            </div>
            <div>
              <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.modalNameLabel', lang)}</label>
              <input type="text" id="cyc-label" placeholder={t('admin.settings.cycleNamePlaceholder', lang)} class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.cycleAbbrLabel', lang)}</label>
                <input type="text" id="cyc-abbr" placeholder="C4" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
              </div>
              <div>
                <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.modalColorLabel', lang)}</label>
                <input type="color" id="cyc-color" value="#94A3B8" class="w-full h-[38px] px-1 py-1 border border-[var(--border-default)] rounded-lg cursor-pointer">
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.cycleStartLabel', lang)}</label>
                <input type="date" id="cyc-start" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
              </div>
              <div>
                <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.cycleEndLabel', lang)}</label>
                <input type="date" id="cyc-end" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
                <p class="text-[.6rem] text-[var(--text-muted)] mt-0.5">{t('admin.settings.cycleEndHint', lang)}</p>
              </div>
            </div>
            <div>
              <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.settings.cycleSortLabel', lang)}</label>
              <input type="number" id="cyc-sort" value="0" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem]">
            </div>
            <button id="cycle-modal-save" class="w-full px-4 py-2.5 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all mt-2">
              {t('common.save', lang)}
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="settings-loading" class="text-center py-16 text-[var(--text-muted)]">{t('common.loading', lang)}</div>
  </div>
  <Toast />
  <span id="ai18n-nor" class="hidden">{t('admin.noResults', lang)}</span>
  <span id="ai18n-lod" class="hidden">{t('admin.loadError', lang)}</span>
  <span id="ai18n-sav" class="hidden">{t('admin.saveError', lang)}</span>
</AdminLayout>

<script is:inline define:vars={{ SETTINGS_I18N }}>
  window.__SETTINGS_I18N = SETTINGS_I18N;
</script>
<script>
  import { hasPermission } from '../../lib/permissions';

  // PT-BR fallbacks (graceful degradation if define:vars injection fails)
  const T = (typeof window !== 'undefined' && (window as any).__SETTINGS_I18N) || {
    statusActive: 'Ativo', rangeSeparator: 'a', endOpen: 'em andamento',
    activate: 'Ativar', confirmActivate: 'Definir "{code}" como ciclo ativo?',
    activated: 'Ciclo ativo atualizado', edit: 'Editar', delete: 'Excluir',
    confirmDelete: 'Excluir ciclo "{code}"? Esta ação não pode ser desfeita.',
    deleted: 'Ciclo excluído', errorPrefix: 'Erro',
    editCycle: 'Editar Ciclo', newCycle: 'Novo Ciclo',
    fillRequired: 'Preencha código, nome, abreviação e data início',
    cycleUpdated: 'Ciclo atualizado', cycleCreated: 'Ciclo criado', save: 'Salvar',
    saveError: 'Erro ao salvar.', loadError: 'Erro ao carregar.',
    noResults: 'Nenhum resultado encontrado.',
    platformResearchersLabel: 'Pesquisadores por tribo',
    platformResearchersDesc: 'Limite máximo de pesquisadores por tribo',
    platformMaxTribesLabel: 'Máximo de tribos ativas',
    platformMaxTribesDesc: 'Limite de tribos ativas no sistema',
    platformGracePeriodLabel: 'Grace period baseline (dias)',
    platformGracePeriodDesc: 'Dias antes do lock automático de baseline',
    lastChangeLabel: 'Último ajuste',
    reasonPrompt: 'Razão da alteração (obrigatório):',
    reasonRequired: 'Razão obrigatória.',
    platformUpdated: 'Configuração atualizada!',
    slaUnitHours: 'Horas', slaUnitDays: 'Dias',
    slaCurrentLabel: 'Configuração atual',
    slaConfirm: 'Confirmar — afeta cron de produção',
    slaSaved: 'Janela de SLA atualizada',
    slaRangeError: 'Valor fora do intervalo permitido.',
    slaInterviewOverdueLabel: 'Carência para alerta de entrevista atrasada',
    slaInterviewOverdueHelp: 'Tempo após o início da janela agendada antes de o sistema sinalizar que a entrevista está atrasada. O entrevistador é notificado após esse período.',
    slaStuckScheduledLabel: 'Carência para resgate de candidatura travada',
    slaStuckScheduledHelp: 'Tempo após a data da entrevista antes de uma candidatura em "entrevista agendada" ser automaticamente resgatada para revisão. Evita candidaturas esquecidas.',
    slaRescheduleInitialLabel: 'Aguardo antes do 1º lembrete de remarcação',
    slaRescheduleInitialHelp: 'Dias após um pedido de remarcação antes do primeiro email de lembrete ser enviado ao candidato.',
    slaRescheduleRepeatLabel: 'Intervalo entre lembretes de remarcação',
    slaRescheduleRepeatHelp: 'Dias mínimos entre emails de lembrete subsequentes ao candidato que ainda não remarcou.',
  };

  let sb: any = null;
  let MEMBER: any = null;

  function escapeHtml(s: string): string {
    return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showDenied() {
    document.getElementById('settings-loading')?.classList.add('hidden');
    document.getElementById('settings-panel')?.classList.add('hidden');
    document.getElementById('settings-denied')?.classList.remove('hidden');
  }

  // showPanel defined below with loadPlatformSettings

  async function loadConfig() {
    if (!sb) return;
    try {
      const { data, error } = await sb.rpc('get_site_config');
      if (error) throw error;
      const cfg = data || {};
      (document.getElementById('cfg-group-term') as HTMLInputElement).value = cfg.group_term ?? 'Núcleo';
      (document.getElementById('cfg-cycle-default') as HTMLInputElement).value = cfg.cycle_default ?? '';
      (document.getElementById('cfg-webhook-url') as HTMLInputElement).value = cfg.webhook_url ?? '';
    } catch (e: any) {
      console.error('Load config:', e);
    }
  }

  async function saveConfig() {
    if (!sb || !hasPermission(MEMBER, 'system.global_config')) return;
    const btn = document.getElementById('cfg-save') as HTMLButtonElement;
    if (btn) btn.disabled = true;
    try {
      const groupTerm = (document.getElementById('cfg-group-term') as HTMLInputElement).value.trim() || 'Núcleo';
      const cycleDefault = (document.getElementById('cfg-cycle-default') as HTMLInputElement).value.trim();
      const webhookUrl = (document.getElementById('cfg-webhook-url') as HTMLInputElement).value.trim();

      await sb.rpc('set_site_config', { p_key: 'group_term', p_value: groupTerm });
      await sb.rpc('set_site_config', { p_key: 'cycle_default', p_value: cycleDefault || null });
      await sb.rpc('set_site_config', { p_key: 'webhook_url', p_value: webhookUrl || null });
    } catch (e: any) {
      console.error('Save config:', e);
      (window as any).toast?.((document.getElementById('ai18n-sav')?.textContent || 'Error: ') + (e.message || 'unknown'), 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) { MEMBER = m; applyGate(MEMBER); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        MEMBER = data;
        applyGate(MEMBER);
        return;
      }
    } catch (e) { console.warn('Settings boot:', e); }

    showDenied();
  }

  function applyGate(m: any) {
    if (hasPermission(m, 'system.global_config')) showPanel();
    else showDenied();
  }

  document.getElementById('cfg-save')?.addEventListener('click', saveConfig);

  // ── W111: Cycle Management ──
  let editingCycleCode: string | null = null;

  async function loadCycles() {
    if (!sb) return;
    const container = document.getElementById('cycle-list');
    if (!container) return;
    try {
      const { data, error } = await sb.rpc('list_cycles');
      if (error) throw error;
      const cycles = data || [];
      if (cycles.length === 0) {
        container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${document.getElementById('ai18n-nor')?.textContent || 'No results.'}</p>`;
        return;
      }
      container.innerHTML = cycles.map((c: any) => `
        <div class="flex items-center gap-3 p-3 rounded-lg border border-[var(--border-subtle)] hover:border-[var(--border-default)] transition-all">
          <div class="w-4 h-4 rounded-full shrink-0" style="background:${escapeHtml(c.cycle_color)}"></div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-[.78rem] font-bold text-[var(--text-primary)]">${escapeHtml(c.cycle_label)}</span>
              <span class="text-[.65rem] px-1.5 py-0.5 rounded bg-[var(--surface-section-cool)] text-[var(--text-muted)] font-mono">${escapeHtml(c.cycle_code)}</span>
              ${c.is_current ? `<span class="text-[.6rem] px-1.5 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-bold">${T.statusActive}</span>` : ''}
            </div>
            <p class="text-[.65rem] text-[var(--text-muted)] mt-0.5">${escapeHtml(c.cycle_abbr)} &middot; ${c.cycle_start || '—'} ${T.rangeSeparator} ${c.cycle_end || T.endOpen}</p>
          </div>
          <div class="flex items-center gap-1.5 shrink-0">
            ${!c.is_current ? `<button data-cyc-current="${escapeHtml(c.cycle_code)}" class="px-2 py-1 text-[.65rem] font-semibold rounded-lg bg-emerald-50 text-emerald-700 border border-emerald-200 hover:bg-emerald-100 cursor-pointer transition-colors">${T.activate}</button>` : ''}
            <button data-cyc-edit="${escapeHtml(c.cycle_code)}" class="px-2 py-1 text-[.65rem] font-semibold rounded-lg bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100 cursor-pointer transition-colors">${T.edit}</button>
            ${!c.is_current ? `<button data-cyc-del="${escapeHtml(c.cycle_code)}" class="px-2 py-1 text-[.65rem] font-semibold rounded-lg bg-red-50 text-red-700 border border-red-200 hover:bg-red-100 cursor-pointer transition-colors">${T.delete}</button>` : ''}
          </div>
        </div>
      `).join('');

      // Bind edit buttons
      container.querySelectorAll('[data-cyc-edit]').forEach((btn: Element) => {
        btn.addEventListener('click', () => {
          const code = (btn as HTMLElement).dataset.cycEdit!;
          const cyc = cycles.find((c: any) => c.cycle_code === code);
          if (cyc) openCycleModal(cyc);
        });
      });
      // Bind set-current buttons
      container.querySelectorAll('[data-cyc-current]').forEach((btn: Element) => {
        btn.addEventListener('click', async () => {
          const code = (btn as HTMLElement).dataset.cycCurrent!;
          if (!confirm(T.confirmActivate.replace('{code}', code))) return;
          try {
            const { error } = await sb.rpc('admin_manage_cycle', { p_action: 'set_current', p_cycle_code: code });
            if (error) throw error;
            (window as any).toast?.(T.activated, 'success');
            loadCycles();
          } catch (e: any) { (window as any).toast?.(T.errorPrefix + ': ' + (e.message || 'unknown'), 'error'); }
        });
      });
      // Bind delete buttons
      container.querySelectorAll('[data-cyc-del]').forEach((btn: Element) => {
        btn.addEventListener('click', async () => {
          const code = (btn as HTMLElement).dataset.cycDel!;
          if (!confirm(T.confirmDelete.replace('{code}', code))) return;
          try {
            const { error } = await sb.rpc('admin_manage_cycle', { p_action: 'delete', p_cycle_code: code });
            if (error) throw error;
            (window as any).toast?.(T.deleted, 'success');
            loadCycles();
          } catch (e: any) { (window as any).toast?.(T.errorPrefix + ': ' + (e.message || 'unknown'), 'error'); }
        });
      });
    } catch (e: any) {
      console.error('Load cycles:', e);
      if (container) container.innerHTML = `<p class="text-[.7rem] text-red-600">${document.getElementById('ai18n-lod')?.textContent || 'Error loading.'}</p>`;
    }
  }

  function openCycleModal(cyc?: any) {
    editingCycleCode = cyc?.cycle_code || null;
    const title = document.getElementById('cycle-modal-title');
    if (title) title.textContent = cyc ? T.editCycle : T.newCycle;
    (document.getElementById('cyc-code') as HTMLInputElement).value = cyc?.cycle_code || '';
    (document.getElementById('cyc-code') as HTMLInputElement).disabled = !!cyc;
    (document.getElementById('cyc-label') as HTMLInputElement).value = cyc?.cycle_label || '';
    (document.getElementById('cyc-abbr') as HTMLInputElement).value = cyc?.cycle_abbr || '';
    (document.getElementById('cyc-color') as HTMLInputElement).value = cyc?.cycle_color || '#94A3B8';
    (document.getElementById('cyc-start') as HTMLInputElement).value = cyc?.cycle_start || '';
    (document.getElementById('cyc-end') as HTMLInputElement).value = cyc?.cycle_end || '';
    (document.getElementById('cyc-sort') as HTMLInputElement).value = String(cyc?.sort_order ?? 0);
    document.getElementById('cycle-modal-overlay')?.classList.remove('hidden');
  }

  function closeCycleModal() {
    document.getElementById('cycle-modal-overlay')?.classList.add('hidden');
    editingCycleCode = null;
  }

  async function saveCycle() {
    if (!sb) return;
    const code = (document.getElementById('cyc-code') as HTMLInputElement).value.trim();
    const label = (document.getElementById('cyc-label') as HTMLInputElement).value.trim();
    const abbr = (document.getElementById('cyc-abbr') as HTMLInputElement).value.trim();
    const color = (document.getElementById('cyc-color') as HTMLInputElement).value;
    const start = (document.getElementById('cyc-start') as HTMLInputElement).value;
    const end = (document.getElementById('cyc-end') as HTMLInputElement).value || null;
    const sort = parseInt((document.getElementById('cyc-sort') as HTMLInputElement).value) || 0;

    if (!code || !label || !abbr || !start) {
      (window as any).toast?.(T.fillRequired, 'error');
      return;
    }

    const btn = document.getElementById('cycle-modal-save') as HTMLButtonElement;
    if (btn) btn.disabled = true;
    try {
      const action = editingCycleCode ? 'update' : 'create';
      const { error } = await sb.rpc('admin_manage_cycle', {
        p_action: action,
        p_cycle_code: code,
        p_label: label,
        p_abbr: abbr,
        p_start: start,
        p_end: end,
        p_color: color,
        p_sort: sort,
      });
      if (error) throw error;
      (window as any).toast?.(editingCycleCode ? T.cycleUpdated : T.cycleCreated, 'success');
      closeCycleModal();
      loadCycles();
    } catch (e: any) {
      (window as any).toast?.(T.errorPrefix + ': ' + (e.message || 'unknown'), 'error');
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  document.getElementById('cycle-add-btn')?.addEventListener('click', () => openCycleModal());
  document.getElementById('cycle-modal-close')?.addEventListener('click', closeCycleModal);
  document.getElementById('cycle-modal-save')?.addEventListener('click', saveCycle);
  document.getElementById('cycle-modal-overlay')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeCycleModal();
  });

  // ── Platform Settings ──
  const SETTING_LABELS: Record<string, { label: string; desc: string; type: string }> = {
    max_researchers_per_tribe: { label: T.platformResearchersLabel, desc: T.platformResearchersDesc, type: 'number' },
    max_tribes: { label: T.platformMaxTribesLabel, desc: T.platformMaxTribesDesc, type: 'number' },
    baseline_grace_period_days: { label: T.platformGracePeriodLabel, desc: T.platformGracePeriodDesc, type: 'number' },
  };

  async function loadPlatformSettings() {
    if (!sb) return;
    const container = document.getElementById('platform-settings');
    if (!container) return;
    try {
      const { data, error } = await sb.from('platform_settings').select('*');
      if (error) throw error;
      const settings = (data || []).filter((s: any) => SETTING_LABELS[s.key]);
      if (settings.length === 0) { container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${document.getElementById('ai18n-nor')?.textContent || 'No results.'}</p>`; return; }
      container.innerHTML = settings.map((s: any) => {
        const meta = SETTING_LABELS[s.key];
        const lastChanged = s.changed_at ? new Date(s.changed_at).toLocaleDateString('pt-BR') : '';
        return `<div class="flex items-center gap-3 p-3 rounded-lg border border-[var(--border-subtle)]">
          <div class="flex-1">
            <div class="text-[.78rem] font-semibold text-[var(--text-primary)]">${meta.label}</div>
            <div class="text-[.6rem] text-[var(--text-muted)]">${meta.desc}</div>
            ${s.change_reason ? `<div class="text-[.6rem] text-[var(--text-muted)] mt-0.5">${T.lastChangeLabel}: ${lastChanged} — "${escapeHtml(s.change_reason)}"</div>` : ''}
          </div>
          <input type="${meta.type}" value="${JSON.parse(JSON.stringify(s.value))}" data-setting-key="${s.key}"
            class="w-20 px-2 py-1.5 border border-[var(--border-default)] rounded-lg text-[.78rem] text-center" />
          <button data-save-setting="${s.key}" class="px-3 py-1.5 text-[.65rem] font-semibold rounded-lg bg-navy text-white border-0 hover:opacity-90 cursor-pointer">${T.save}</button>
        </div>`;
      }).join('');

      container.querySelectorAll('[data-save-setting]').forEach((btn: Element) => {
        btn.addEventListener('click', async () => {
          const key = (btn as HTMLElement).dataset.saveSetting!;
          const input = container.querySelector(`[data-setting-key="${key}"]`) as HTMLInputElement;
          if (!input) return;
          const reason = prompt(T.reasonPrompt);
          if (!reason || !reason.trim()) { (window as any).toast?.(T.reasonRequired, 'error'); return; }
          const { data: result, error } = await sb.rpc('admin_update_setting', {
            p_key: key, p_new_value: JSON.parse(input.value), p_reason: reason.trim(),
          });
          if (error || result?.error) { (window as any).toast?.(result?.error || error?.message || T.errorPrefix, 'error'); return; }
          (window as any).toast?.(T.platformUpdated, 'success');
          loadPlatformSettings();
        });
      });
    } catch (e: any) {
      console.error('Load platform settings:', e);
      if (container) container.innerHTML = `<p class="text-[.7rem] text-red-600">${document.getElementById('ai18n-lod')?.textContent || 'Error loading.'}</p>`;
    }
  }

  // ── J4 PR2 (#766): SLA Windows ──
  const SLA_FIELDS: Array<{ key: string; group: string; labelKey: string; helpKey: string; minHours: number; maxHours: number }> = [
    { key: 'interview_overdue_grace', group: 'interviews', labelKey: 'slaInterviewOverdueLabel', helpKey: 'slaInterviewOverdueHelp', minHours: 1, maxHours: 168 },
    { key: 'stuck_scheduled_grace', group: 'interviews', labelKey: 'slaStuckScheduledLabel', helpKey: 'slaStuckScheduledHelp', minHours: 1, maxHours: 336 },
    { key: 'reschedule_nudge_initial', group: 'reschedule', labelKey: 'slaRescheduleInitialLabel', helpKey: 'slaRescheduleInitialHelp', minHours: 24, maxHours: 720 },
    { key: 'reschedule_nudge_repeat', group: 'reschedule', labelKey: 'slaRescheduleRepeatLabel', helpKey: 'slaRescheduleRepeatHelp', minHours: 24, maxHours: 720 },
  ];

  type SlaParsed = { value: number | null; unit: 'hours' | 'days'; ok: boolean; raw: string };

  // PostgREST renders `interval` as "24:00:00" (hours) or "3 days". Parse both; fall back to raw.
  function parseSlaInterval(raw: any): SlaParsed {
    if (raw == null) return { value: null, unit: 'hours', ok: false, raw: '' };
    const s = String(raw).trim();
    const dayMatch = s.match(/^(\d+)\s+days?(?:\s+(\d+):(\d+):(\d+))?$/i);
    if (dayMatch) {
      const days = parseInt(dayMatch[1], 10);
      const hh = dayMatch[2] ? parseInt(dayMatch[2], 10) : 0;
      const mm = dayMatch[3] ? parseInt(dayMatch[3], 10) : 0;
      if (hh === 0 && mm === 0) return { value: days, unit: 'days', ok: true, raw: s };
      return { value: Math.round((days * 24 + hh + mm / 60) * 100) / 100, unit: 'hours', ok: true, raw: s };
    }
    const timeMatch = s.match(/^(\d+):(\d+):(\d+)$/);
    if (timeMatch) {
      const hh = parseInt(timeMatch[1], 10);
      const mm = parseInt(timeMatch[2], 10);
      return { value: Math.round((hh + mm / 60) * 100) / 100, unit: 'hours', ok: true, raw: s };
    }
    return { value: null, unit: 'hours', ok: false, raw: s };
  }

  function fmtSlaCurrent(p: SlaParsed): string {
    if (!p.ok || p.value == null) return p.raw || '—';
    const unitLabel = (p.unit === 'days' ? T.slaUnitDays : T.slaUnitHours).toLowerCase();
    return `${p.value} ${unitLabel}`;
  }

  async function loadSlaWindows() {
    if (!sb) return;
    const loadingEl = document.getElementById('sla-loading');
    const errorEl = document.getElementById('sla-error');
    const contentEl = document.getElementById('sla-content');
    if (!contentEl) return;
    try {
      const { data, error } = await sb.from('sla_policies').select('policy_key, value_interval');
      if (error) throw error;
      const byKey: Record<string, any> = {};
      (data || []).forEach((r: any) => { byKey[r.policy_key] = r.value_interval; });

      const groupEls: Record<string, HTMLElement | null> = {
        interviews: document.getElementById('sla-group-interviews'),
        reschedule: document.getElementById('sla-group-reschedule'),
      };
      // Clear any live confirm-timers before re-rendering rows (avoids stale timers on detached nodes)
      Object.keys(slaConfirmTimers).forEach((k) => clearTimeout(slaConfirmTimers[k]));
      Object.keys(slaConfirmTimers).forEach((k) => delete slaConfirmTimers[k]);
      Object.keys(groupEls).forEach((g) => { const el = groupEls[g]; if (el) el.innerHTML = ''; });

      SLA_FIELDS.forEach((f) => {
        const container = groupEls[f.group];
        if (!container) return;
        const parsed = parseSlaInterval(byKey[f.key]);
        const label = (T as any)[f.labelKey] || f.key;
        const help = (T as any)[f.helpKey] || '';
        const valId = `sla-val-${escapeHtml(f.key)}`;
        const unitId = `sla-unit-${escapeHtml(f.key)}`;
        const hoursSel = parsed.unit === 'hours' ? ' selected' : '';
        const daysSel = parsed.unit === 'days' ? ' selected' : '';
        const valAttr = parsed.value != null ? String(parsed.value) : '';
        const row = document.createElement('div');
        row.className = 'p-3 rounded-lg border border-[var(--border-subtle)]';
        row.innerHTML = `
          <label for="${valId}" class="text-[.78rem] font-semibold text-[var(--text-primary)] block">${escapeHtml(label)}</label>
          <p class="text-[.6rem] text-[var(--text-muted)] mt-0.5">${escapeHtml(help)}</p>
          <div class="grid grid-cols-1 sm:grid-cols-[80px_110px_auto] gap-2 items-center mt-2">
            <input type="number" id="${valId}" value="${escapeHtml(valAttr)}" min="1" step="1" data-sla-val="${escapeHtml(f.key)}"
              class="w-full px-2 py-1.5 border border-[var(--border-default)] rounded-lg text-[.78rem] text-center" />
            <select id="${unitId}" data-sla-unit="${escapeHtml(f.key)}" aria-label="${escapeHtml(label)}"
              class="w-full px-2 py-1.5 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-card)]">
              <option value="hours"${hoursSel}>${escapeHtml(T.slaUnitHours)}</option>
              <option value="days"${daysSel}>${escapeHtml(T.slaUnitDays)}</option>
            </select>
            <button type="button" data-sla-save="${escapeHtml(f.key)}" data-min="${f.minHours}" data-max="${f.maxHours}"
              class="px-3 py-1.5 text-[.65rem] font-semibold rounded-lg bg-navy text-white border-0 hover:opacity-90 cursor-pointer transition-colors">${escapeHtml(T.save)}</button>
          </div>
          <p class="text-[.6rem] text-[var(--text-muted)] mt-1">${escapeHtml(T.slaCurrentLabel)}: ${escapeHtml(fmtSlaCurrent(parsed))}</p>
        `;
        container.appendChild(row);
      });

      contentEl.querySelectorAll('[data-sla-save]').forEach((btn: Element) => {
        btn.addEventListener('click', () => handleSlaSave(btn as HTMLButtonElement));
      });

      loadingEl?.classList.add('hidden');
      errorEl?.classList.add('hidden');
      contentEl.classList.remove('hidden');
    } catch (e: any) {
      console.error('Load SLA windows:', e);
      loadingEl?.classList.add('hidden');
      contentEl?.classList.add('hidden');
      if (errorEl) {
        errorEl.textContent = document.getElementById('ai18n-lod')?.textContent || 'Error loading.';
        errorEl.classList.remove('hidden');
      }
    }
  }

  const slaConfirmTimers: Record<string, any> = {};
  function resetSlaBtn(btn: HTMLButtonElement) {
    const key = btn.dataset.slaSave!;
    btn.dataset.confirming = '';
    btn.textContent = T.save;
    btn.setAttribute('aria-label', T.save);
    btn.classList.remove('bg-red-600');
    btn.classList.add('bg-navy');
    if (slaConfirmTimers[key]) { clearTimeout(slaConfirmTimers[key]); delete slaConfirmTimers[key]; }
  }

  async function handleSlaSave(btn: HTMLButtonElement) {
    if (!sb) return;
    const key = btn.dataset.slaSave!;
    const valInput = document.getElementById(`sla-val-${key}`) as HTMLInputElement | null;
    const unitSel = document.getElementById(`sla-unit-${key}`) as HTMLSelectElement | null;
    if (!valInput || !unitSel) return;
    const num = parseFloat(valInput.value);
    const unit = unitSel.value === 'days' ? 'days' : 'hours';
    if (!Number.isFinite(num) || num <= 0) { (window as any).toast?.(T.slaRangeError, 'error'); resetSlaBtn(btn); return; }
    // soft range guard (hours-equivalent) — RPC remains the source of truth
    const hoursEq = unit === 'days' ? num * 24 : num;
    const minH = parseFloat(btn.dataset.min || '0');
    const maxH = parseFloat(btn.dataset.max || '0');
    if ((minH && hoursEq < minH) || (maxH && hoursEq > maxH)) { (window as any).toast?.(T.slaRangeError, 'error'); resetSlaBtn(btn); return; }

    // two-click inline confirm — production cron impact (no prompt())
    if (btn.dataset.confirming !== '1') {
      btn.dataset.confirming = '1';
      btn.textContent = T.slaConfirm;
      btn.setAttribute('aria-label', T.slaConfirm);
      btn.classList.remove('bg-navy');
      btn.classList.add('bg-red-600');
      slaConfirmTimers[key] = setTimeout(() => resetSlaBtn(btn), 5000);
      return;
    }
    resetSlaBtn(btn);

    btn.disabled = true;
    try {
      const pValue = `${num} ${unit}`;
      const { data: result, error } = await sb.rpc('update_sla_policy', { p_key: key, p_value: pValue });
      if (error || result?.error) { (window as any).toast?.(result?.error || error?.message || T.errorPrefix, 'error'); return; }
      (window as any).toast?.(T.slaSaved, 'success');
      loadSlaWindows();
    } catch (e: any) {
      (window as any).toast?.(T.errorPrefix + ': ' + (e.message || 'unknown'), 'error');
    } finally {
      btn.disabled = false;
    }
  }

  function showPanel() {
    document.getElementById('settings-loading')?.classList.add('hidden');
    document.getElementById('settings-denied')?.classList.add('hidden');
    document.getElementById('settings-panel')?.classList.remove('hidden');
    loadConfig();
    loadCycles();
    loadPlatformSettings();
    loadSlaWindows();
  }

  boot();
</script>
