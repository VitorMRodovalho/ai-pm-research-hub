            <input type="time" id="slot-start" value="19:00" class="px-2 py-1.5 border border-slate-200 rounded-lg text-[.72rem]">
            <span class="text-slate-400 text-[.72rem]">–</span>
            <input type="time" id="slot-end" value="20:00" class="px-2 py-1.5 border border-slate-200 rounded-lg text-[.72rem]">
            <button type="button" class="btn-add-slot px-3 py-1.5 bg-teal text-white rounded-lg text-[.72rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all flex-shrink-0"
              data-tribe-id="${tribeId}">
              + Adicionar
            </button>
          </div>
        </div>
        <!-- Links & Config -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
