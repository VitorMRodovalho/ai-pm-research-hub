---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
---
<BaseLayout title="Admin — Núcleo IA & GP" activePage="admin">
  <Toast />
  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
      <div>
        <h1 class="text-2xl font-extrabold text-navy">⚙️ Administração</h1>
        <p class="text-sm text-slate-500">Gerenciamento de membros, tribos e operações do Ciclo 3</p>
      </div>
    </div>

    <div id="not-admin-msg" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">Acesso restrito. Faça login com uma conta autorizada.</p>
      <a href="/profile" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">👤 Ver meu perfil</a>
    </div>

    <div id="admin-loading" class="text-center py-10 text-slate-400">Verificando acesso...</div>

    <!-- Tier header (shown for non-superadmin tiers) -->
    <div id="tier-header" class="hidden mb-5 p-4 rounded-xl border" style="border-color:#4F17A830;background:#4F17A808">
      <div class="flex items-center gap-2">
        <span class="text-lg" id="tier-icon"></span>
        <div>
          <div class="text-sm font-bold text-navy" id="tier-title"></div>
          <div class="text-[.7rem] text-slate-400" id="tier-subtitle"></div>
        </div>
      </div>
    </div>

    <div id="admin-panel" class="hidden">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-5">
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-navy" id="stat-total">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">Total</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-emerald-600" id="stat-active">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">Ativos</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-amber-600" id="stat-pending">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">Sem Tribo</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-crimson" id="stat-inactive">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">Inativos</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-purple" id="stat-noauth">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">Sem Login</div></div>
      </div>

      <div class="flex gap-2 mb-5 flex-wrap">
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white" data-tab="tribes" onclick="switchAdmTab(this,'tribes')">🏷️ Gestão de Tribos</button>
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500" data-tab="members" onclick="switchAdmTab(this,'members')">👥 Membros</button>
      </div>

      <div id="panel-tribes">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6" id="tribe-cards"></div>
        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-200 bg-amber-50">
            <h3 class="text-sm font-bold text-amber-800">⚠️ Pool de Pendentes — Ainda não escolheram tribo</h3>
          </div>
          <div class="p-4" id="pending-list"><p class="text-slate-400 text-sm text-center py-4">Carregando...</p></div>
        </div>
      </div>

      <div id="panel-members" class="hidden">
        <!-- Filter bar -->
        <div class="bg-white border border-slate-200 rounded-2xl p-4 mb-4">
          <div class="flex items-center gap-3 mb-3 flex-wrap">
            <input type="text" id="f-search" placeholder="🔍 Buscar nome ou email..." oninput="applyFilters()"
              class="px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] focus:outline-none focus:border-teal flex-1 min-w-[200px]">
            <span class="text-[.72rem] font-bold text-slate-400" id="f-count">—</span>
          </div>
          <div class="flex gap-2 flex-wrap">
            <select id="f-chapter" onchange="applyFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">Capítulo: Todos</option>
              <option value="PMI-GO">PMI-GO</option>
              <option value="PMI-CE">PMI-CE</option>
              <option value="PMI-DF">PMI-DF</option>
              <option value="PMI-MG">PMI-MG</option>
              <option value="PMI-RS">PMI-RS</option>
            </select>
            <select id="f-oprole" onchange="applyFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">Papel: Todos</option>
              <option value="manager">Gerente</option>
              <option value="tribe_leader">Líder de Tribo</option>
              <option value="researcher">Pesquisador</option>
              <option value="facilitator">Facilitador</option>
              <option value="communicator">Multiplicador</option>
              <option value="none">Sem papel operacional</option>
              <option value="guest">Convidado</option>
            </select>
            <select id="f-desig" onchange="applyFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">Designação: Todas</option>
              <option value="sponsor">Patrocinador</option>
              <option value="ambassador">Embaixador</option>
              <option value="founder">Fundador</option>
              <option value="curator">Curador</option>
              <option value="has_any">✦ Com designação</option>
              <option value="has_none">○ Sem designação</option>
            </select>
            <select id="f-status" onchange="applyFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">Status: Todos</option>
              <option value="active">✅ Ativos</option>
              <option value="inactive">❌ Inativos</option>
            </select>
            <select id="f-auth" onchange="applyFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">Login: Todos</option>
              <option value="has">✅ Com login</option>
              <option value="no">⚠️ Sem login</option>
            </select>
            <select id="f-tribe" onchange="applyFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">Tribo: Todas</option>
              <option value="1">01 — Radar Tecnológico</option>
              <option value="2">02 — Agentes Autônomos</option>
              <option value="3">03 — TMO & PMO</option>
              <option value="4">04 — Cultura & Change</option>
              <option value="5">05 — Talentos</option>
              <option value="6">06 — ROI & Portfólio</option>
              <option value="7">07 — Governança</option>
              <option value="8">08 — Inclusão</option>
              <option value="none">⚠️ Sem tribo</option>
            </select>
            <button onclick="clearFilters()" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] text-slate-400 hover:text-crimson hover:border-crimson bg-white cursor-pointer transition-all">✕ Limpar</button>
          </div>
        </div>
        <div id="members-area"><div class="text-center py-10 text-slate-400">Carregando membros…</div></div>
      </div>

      <!-- Leader Tier: My Tribe panel -->
      <div id="panel-my-tribe" class="hidden">
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-5">
          <div class="px-5 py-3.5 border-b border-slate-200">
            <h3 class="text-sm font-bold text-navy">👥 Membros da Minha Tribo</h3>
          </div>
          <div class="p-5" id="my-tribe-members">
            <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
          </div>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-200">
            <h3 class="text-sm font-bold text-navy">📅 Presenças Recentes da Tribo</h3>
          </div>
          <div class="p-5" id="my-tribe-attendance">
            <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
          </div>
        </div>
      </div>

      <!-- Sponsor Tier: Executive Overview panel -->
      <div id="panel-executive" class="hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-5">
          <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
            <div class="px-5 py-3.5 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">🏛️ Membros por Capítulo</h3>
            </div>
            <div class="p-5" id="exec-chapters">
              <p class="text-slate-400 text-sm text-center py-4">Carregando...</p>
            </div>
          </div>
          <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
            <div class="px-5 py-3.5 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">📊 Progresso Geral</h3>
            </div>
            <div class="p-5" id="exec-progress">
              <p class="text-slate-400 text-sm text-center py-4">Carregando...</p>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-200">
            <h3 class="text-sm font-bold text-navy">🏷️ Status das Tribos</h3>
          </div>
          <div class="p-5" id="exec-tribes">
            <p class="text-slate-400 text-sm text-center py-4">Carregando...</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Modal: Allocate Tribe -->
  <div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-allocate">
    <div class="bg-white rounded-2xl w-full max-w-[400px] overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-200 flex justify-between items-center">
        <h3 class="text-base font-bold text-navy">Alocar em Tribo</h3>
        <button class="bg-transparent border-0 text-xl cursor-pointer text-slate-400" onclick="closeAllocate()">✕</button>
      </div>
      <div class="p-5">
        <input type="hidden" id="alloc-member-id">
        <div class="text-sm font-semibold mb-1" id="alloc-member-name"></div>
        <div class="text-[12px] text-slate-500 mb-4" id="alloc-member-info"></div>
        <label class="text-[12px] font-semibold text-slate-500 block mb-1.5">Selecione a Tribo</label>
        <select id="alloc-tribe" class="w-full px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white focus:outline-none focus:border-navy">
          <option value="">— Selecione —</option>
          <option value="1">01 — Radar Tecnológico</option>
          <option value="2">02 — Agentes Autônomos</option>
          <option value="3">03 — TMO & PMO do Futuro</option>
          <option value="4">04 — Cultura & Change</option>
          <option value="5">05 — Talentos & Upskilling</option>
          <option value="6">06 — ROI & Portfólio</option>
          <option value="7">07 — Governança & Trustworthy AI</option>
          <option value="8">08 — Inclusão & Colaboração</option>
        </select>
      </div>
      <div class="px-5 py-3.5 border-t border-slate-200 flex justify-end gap-2">
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-slate-50 cursor-pointer" onclick="closeAllocate()">Cancelar</button>
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer" onclick="confirmAllocate()">Alocar</button>
      </div>
    </div>
  </div>

  <!-- Modal: Edit Member (3-Axis Model) -->
  <div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-edit-member">
    <div class="bg-white rounded-2xl w-full max-w-[500px] overflow-hidden flex flex-col" style="max-height:90vh">
      <div class="px-5 py-4 border-b border-slate-200 flex justify-between items-center flex-shrink-0">
        <h3 class="text-base font-bold text-navy">Editar Membro</h3>
        <button class="bg-transparent border-0 text-xl cursor-pointer text-slate-400" onclick="closeEditMember()">✕</button>
      </div>
      <div class="p-5 overflow-y-auto flex-1">
        <input type="hidden" id="edit-m-id">
        <div class="flex items-center gap-3 mb-5" id="edit-m-header"></div>

        <!-- AXIS 1: Operational Role -->
        <div class="mb-4 p-3 rounded-xl bg-slate-50 border border-slate-200">
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-2">Eixo 1 — Papel Operacional</label>
          <p class="text-[.68rem] text-slate-400 mb-2">O que essa pessoa FAZ no ciclo ativo. Apenas um.</p>
          <select id="edit-m-oprole" class="w-full px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white focus:outline-none focus:border-navy">
            <option value="manager">⚙️ Gerente de Projeto (Nível 2)</option>
            <option value="tribe_leader">🏷️ Líder de Tribo (Nível 3)</option>
            <option value="researcher">🔬 Pesquisador (Nível 4)</option>
            <option value="facilitator">🤝 Facilitador (Nível 4)</option>
            <option value="communicator">📢 Multiplicador (Nível 4)</option>
            <option value="none">— Sem papel operacional (patrocinador/embaixador)</option>
            <option value="guest">👤 Convidado / Visitante</option>
          </select>
        </div>

        <!-- AXIS 2: Designations -->
        <div class="mb-4 p-3 rounded-xl bg-slate-50 border border-slate-200">
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-2">Eixo 2 — Designações Especiais</label>
          <p class="text-[.68rem] text-slate-400 mb-2">Reconhecimentos que transcendem ciclos. Múltiplos possíveis.</p>
          <div class="grid grid-cols-2 gap-2">
            <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 cursor-pointer transition-all text-[.78rem]">
              <input type="checkbox" value="sponsor" class="desig-cb accent-[#BE2027]"> <span style="color:#BE2027">●</span> Patrocinador
            </label>
            <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 cursor-pointer transition-all text-[.78rem]">
              <input type="checkbox" value="ambassador" class="desig-cb accent-[#10B981]"> <span style="color:#10B981">●</span> Embaixador
            </label>
            <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 cursor-pointer transition-all text-[.78rem]">
              <input type="checkbox" value="founder" class="desig-cb accent-[#7C3AED]"> <span style="color:#7C3AED">●</span> Fundador
            </label>
            <label class="flex items-center gap-2 px-3 py-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 cursor-pointer transition-all text-[.78rem]">
              <input type="checkbox" value="curator" class="desig-cb accent-[#D97706]"> <span style="color:#D97706">●</span> Curador
            </label>
          </div>
        </div>

        <!-- AXIS 3: Platform Access -->
        <div class="mb-4 p-3 rounded-xl bg-slate-50 border border-slate-200">
          <label class="text-[11px] font-bold text-slate-400 uppercase tracking-wider block mb-2">Eixo 3 — Acesso à Plataforma</label>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-[.78rem] font-semibold text-slate-700">🔧 Superadmin</p>
              <p class="text-[.68rem] text-slate-400">CRUD total, configurações, integrações, segurança</p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="edit-m-superadmin" class="sr-only peer">
              <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-orange"></div>
            </label>
          </div>
          <div class="mt-2 text-[.68rem] text-slate-400" id="edit-m-tier-hint">
            Nível de acesso derivado: <strong id="edit-m-tier-display">—</strong>
          </div>
        </div>

        <!-- Chapter + Status -->
        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-1.5">
            <label class="text-[12px] font-semibold text-slate-500">Capítulo</label>
            <select id="edit-m-chapter" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white">
              <option value="PMI-GO">PMI-GO</option>
              <option value="PMI-CE">PMI-CE</option>
              <option value="PMI-DF">PMI-DF</option>
              <option value="PMI-MG">PMI-MG</option>
              <option value="PMI-RS">PMI-RS</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[12px] font-semibold text-slate-500">Status</label>
            <select id="edit-m-active" class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white">
              <option value="true">✅ Ativo no Ciclo 3</option>
              <option value="false">❌ Inativo</option>
            </select>
          </div>
        </div>
      </div>
      <div class="px-5 py-3.5 border-t border-slate-200 flex justify-end gap-2 flex-shrink-0">
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-slate-50 cursor-pointer" onclick="closeEditMember()">Cancelar</button>
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer" onclick="saveEditMember()">Salvar</button>
      </div>
    </div>
  </div>
  <!-- Modal: Cycle History (Superadmin only) -->
  <div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-cycle-history">
    <div class="bg-white rounded-2xl w-full max-w-[600px] overflow-hidden flex flex-col" style="max-height:90vh">
      <div class="px-5 py-4 border-b border-slate-200 flex justify-between items-center flex-shrink-0">
        <h3 class="text-base font-bold text-navy">📅 Histórico de Ciclos</h3>
        <button class="bg-transparent border-0 text-xl cursor-pointer text-slate-400" onclick="closeCycleHistory()">✕</button>
      </div>
      <div class="px-5 pt-3 pb-1">
        <div class="text-sm font-semibold text-navy" id="ch-member-name"></div>
        <div class="text-[.68rem] text-slate-400 mb-3">🔧 Somente superadmins podem editar dados históricos</div>
      </div>
      <div class="px-5 pb-4 overflow-y-auto flex-1" id="ch-cycles-area">
        <p class="text-slate-400 text-sm text-center py-6">Carregando...</p>
      </div>
      <div class="px-5 py-3.5 border-t border-slate-200 flex justify-end gap-2 flex-shrink-0">
        <button class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-slate-50 cursor-pointer" onclick="closeCycleHistory()">Fechar</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { ROLE_COLORS, ROLE_LABELS } from '../../lib/supabase';

  let sb: any = null;
  let MEMBER: any = null;
  let allMembers: any[] = [];

  // ── Access tier labels ──
  const TIER_LABELS: Record<string, string> = {
    superadmin: '🔧 Superadmin (CRUD total)',
    admin: '⚙️ Admin (gestão completa)',
    leader: '🏷️ Líder (tribo read-only)',
    observer: '👁️ Observador (KPIs agregados)',
    member: '👤 Membro (perfil + participação)',
    visitor: '🚫 Visitante (apenas página pública)',
  };

  function getAccessTier(isSuperadmin: boolean, opRole: string, desigs: string[]): string {
    if (isSuperadmin) return 'superadmin';
    if (opRole === 'manager') return 'admin';
    if (opRole === 'tribe_leader') return 'leader';
    if (desigs.includes('sponsor') || desigs.includes('curator')) return 'observer';
    if (['researcher', 'facilitator', 'communicator'].includes(opRole)) return 'member';
    if (desigs.length > 0) return 'member';
    return 'visitor';
  }

  // ── Compute legacy role + roles for backward-compat ──
  const OP_ROLE_HIERARCHY = ['manager', 'tribe_leader', 'researcher', 'facilitator', 'communicator'];

  function computeLegacyFields(opRole: string, desigs: string[]): { role: string; roles: string[] } {
    const allRoles = [...(opRole !== 'none' && opRole !== 'guest' ? [opRole] : []), ...desigs];
    if (allRoles.length === 0) return { role: 'guest', roles: ['guest'] };
    // Primary role: operational role if exists, else first designation
    const role = opRole !== 'none' && opRole !== 'guest' ? opRole : desigs[0] || 'guest';
    return { role, roles: allRoles };
  }

  const TRIBE_NAMES: Record<number, string> = {
    1: 'Radar Tecnológico', 2: 'Agentes Autônomos', 3: 'TMO & PMO do Futuro',
    4: 'Cultura & Change', 5: 'Talentos & Upskilling', 6: 'ROI & Portfólio',
    7: 'Governança & Trustworthy AI', 8: 'Inclusão & Colaboração'
  };
  const TRIBE_LEADERS: Record<number, string> = {
    1: 'Hayala Curto', 2: 'Débora Moura', 3: 'Marcel Fleming',
    4: 'Fernando Maquiaveli', 5: 'Jefferson Pinto', 6: 'Fabricio Costa',
    7: 'Marcos Klemz', 8: 'Ana Carla Cavalcante'
  };
  const TRIBE_COLORS: Record<number, string> = {
    1: '#00799E', 2: '#00799E', 3: '#FF610F', 4: '#FF610F',
    5: '#4F17A8', 6: '#4F17A8', 7: '#10B981', 8: '#10B981'
  };
  const MAX_SLOTS = 6;
  const ELIGIBLE_ROLES = ['researcher', 'facilitator', 'communicator'];

  function toast(msg: string, type = '') { (window as any).toast?.(msg, type); }

  function initials(name: string): string {
    return name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
  }

  function avatar(m: any, size = 'w-8 h-8'): string {
    return m.photo_url
      ? `<img src="${m.photo_url}" class="${size} rounded-full object-cover flex-shrink-0" alt="">`
      : `<div class="${size} rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.6rem] flex-shrink-0">${initials(m.name)}</div>`;
  }

  function roleDots(m: any): string {
    const opRole = m.operational_role || m.role || 'guest';
    const desigs = m.designations?.length ? m.designations : [];
    const all = [...(opRole !== 'none' && opRole !== 'guest' ? [opRole] : []), ...desigs];
    return all.filter((r: string) => ROLE_COLORS[r]).map((r: string) =>
      `<span style="width:8px;height:8px;border-radius:50%;background:${ROLE_COLORS[r]};display:inline-block" title="${ROLE_LABELS[r] || r}"></span>`
    ).join('');
  }

  function roleLabelsText(m: any): string {
    const opRole = m.operational_role || m.role || 'guest';
    const desigs = m.designations?.length ? m.designations : [];
    const parts: string[] = [];
    if (opRole !== 'none' && opRole !== 'guest') parts.push(ROLE_LABELS[opRole] || opRole);
    desigs.forEach((d: string) => parts.push(ROLE_LABELS[d] || d));
    return parts.length > 0 ? parts.join(', ') : 'Convidado';
  }

  // ── TABS ──
  (window as any).switchAdmTab = (el: HTMLElement, tab: string) => {
    document.querySelectorAll('.adm-tab').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
    });
    el.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    document.getElementById('panel-tribes')?.classList.toggle('hidden', tab !== 'tribes');
    document.getElementById('panel-members')?.classList.toggle('hidden', tab !== 'members');
    if (tab === 'members') loadMembersList();
  };

  // ══════════════════════════════════════════
  // TRIBE MANAGEMENT
  // ══════════════════════════════════════════
  async function loadTribes() {
    const { data } = await sb.rpc('admin_get_tribe_allocations');
    if (!data || data.error) { toast(data?.error || 'Erro ao carregar', 'error'); return; }
    allMembers = data;

    const active = data.filter((m: any) => m.current_cycle_active);
    const eligible = active.filter((m: any) => ELIGIBLE_ROLES.includes(m.operational_role || m.role));
    const pending = eligible.filter((m: any) => !m.selected_tribe_id && !m.fixed_tribe_id);

    document.getElementById('stat-total')!.textContent = String(active.length);
    document.getElementById('stat-active')!.textContent = String(active.length);
    document.getElementById('stat-pending')!.textContent = String(pending.length);

    const cardsEl = document.getElementById('tribe-cards')!;
    let cardsHtml = '';

    for (let t = 1; t <= 8; t++) {
      const members = data.filter((m: any) =>
        m.selected_tribe_id === t || (m.fixed_tribe_id === t && (m.role === 'tribe_leader' || m.operational_role === 'tribe_leader'))
      );
      const count = members.filter((m: any) => m.role !== 'tribe_leader' && m.operational_role !== 'tribe_leader').length;
      const color = TRIBE_COLORS[t];
      const pct = Math.round((count / MAX_SLOTS) * 100);
      const full = count >= MAX_SLOTS;

      cardsHtml += `
      <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between" style="border-left:4px solid ${color}">
          <div>
            <div class="text-[.68rem] font-bold uppercase tracking-wider" style="color:${color}">Tribo ${String(t).padStart(2, '0')}</div>
            <div class="text-sm font-bold text-navy">${TRIBE_NAMES[t]}</div>
            <div class="text-[.68rem] text-slate-400">${TRIBE_LEADERS[t]}</div>
          </div>
          <div class="text-right">
            <div class="text-lg font-black ${full ? 'text-crimson' : 'text-navy'}">${count}/${MAX_SLOTS}</div>
            <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden mt-1">
              <div class="h-full rounded-full" style="width:${pct}%;background:${full ? '#BE2027' : color}"></div>
            </div>
            ${full ? '<div class="text-[.6rem] font-bold text-crimson mt-0.5">LOTADA</div>' : ''}
          </div>
        </div>
        <div class="p-3 flex flex-wrap gap-2 min-h-[52px]">
          ${members.map((m: any) => `
            <div class="flex items-center gap-1.5 bg-slate-50 rounded-lg px-2 py-1.5 text-[.72rem]" title="${m.name}">
              ${avatar(m, 'w-6 h-6')}
              <span class="font-medium max-w-[90px] truncate">${m.name.split(' ').slice(0, 2).join(' ')}</span>
              ${(m.role === 'tribe_leader' || m.operational_role === 'tribe_leader') ? '<span class="text-amber-500">&#x1F451;</span>' : ''}
            </div>
          `).join('')}
          ${members.length === 0 ? '<span class="text-[.72rem] text-slate-300 italic">Nenhum pesquisador</span>' : ''}
        </div>
      </div>`;
    }
    cardsEl.innerHTML = cardsHtml;
    renderPending(pending);
  }

  function renderPending(pending: any[]) {
    const el = document.getElementById('pending-list')!;
    if (!pending.length) {
      el.innerHTML = '<p class="text-emerald-600 text-sm text-center py-4 font-semibold">Todos os elegíveis já escolheram suas tribos!</p>';
      return;
    }
    el.innerHTML = `
    <div class="text-[.72rem] text-slate-400 mb-2">${pending.length} pesquisadores pendentes</div>
    ${pending.map((m: any) => {
      const phone = m.phone ? m.phone.replace(/\D/g, '') : '';
      const waLink = phone ? 'https://wa.me/' + phone + '?text=' + encodeURIComponent('Ola ' + m.name.split(' ')[0] + '! Lembrete: escolha sua tribo no Nucleo IA GP -> https://ai-pm-research-hub.pages.dev/#tribes') : '';
      const mailLink = 'mailto:' + m.email + '?subject=' + encodeURIComponent('Nucleo IA GP - Escolha sua Tribo') + '&body=' + encodeURIComponent('Ola ' + m.name.split(' ')[0] + ', lembrete: escolha sua tribo em https://ai-pm-research-hub.pages.dev/#tribes');
      return `
      <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
        ${avatar(m, 'w-9 h-9')}
        <div class="flex-1 min-w-0">
          <div class="text-[.82rem] font-semibold text-navy">${m.name}</div>
          <div class="text-[.68rem] text-slate-400">${m.email} - ${m.chapter || ''}</div>
        </div>
        <div class="flex gap-1.5 flex-shrink-0">
          ${waLink ? '<a href="' + waLink + '" target="_blank" class="px-2 py-1 text-[.68rem] font-bold bg-green-50 text-green-700 border border-green-200 rounded-lg no-underline hover:bg-green-100 transition-all" title="WhatsApp">&#x1F4F1;</a>' : ''}
          <a href="${mailLink}" class="px-2 py-1 text-[.68rem] font-bold bg-blue-50 text-blue-700 border border-blue-200 rounded-lg no-underline hover:bg-blue-100 transition-all" title="Email">&#x1F4E7;</a>
          <button onclick="openAllocate('${m.member_id}','${m.name.replace(/'/g, '')}','${m.email}','${m.chapter || ''}')"
            class="px-2.5 py-1 text-[.68rem] font-bold bg-navy text-white border-0 rounded-lg cursor-pointer hover:opacity-90 transition-all">
            Alocar
          </button>
        </div>
      </div>`;
    }).join('')}`;
  }

  // ── ALLOCATE MODAL ──
  (window as any).openAllocate = (id: string, name: string, email: string, chapter: string) => {
    (document.getElementById('alloc-member-id') as HTMLInputElement).value = id;
    document.getElementById('alloc-member-name')!.textContent = name;
    document.getElementById('alloc-member-info')!.textContent = email + ' - ' + chapter;
    (document.getElementById('alloc-tribe') as HTMLSelectElement).value = '';
    const modal = document.getElementById('modal-allocate')!;
    modal.classList.remove('hidden'); modal.classList.add('flex');
  };
  (window as any).closeAllocate = () => {
    const modal = document.getElementById('modal-allocate')!;
    modal.classList.add('hidden'); modal.classList.remove('flex');
  };
  (window as any).confirmAllocate = async () => {
    const memberId = (document.getElementById('alloc-member-id') as HTMLInputElement).value;
    const tribeId = parseInt((document.getElementById('alloc-tribe') as HTMLSelectElement).value);
    if (!tribeId) { toast('Selecione uma tribo', 'error'); return; }
    const { data } = await sb.rpc('admin_force_tribe_selection', { p_member_id: memberId, p_tribe_id: tribeId });
    if (data?.success) {
      (window as any).closeAllocate();
      toast('Alocado na Tribo ' + String(tribeId).padStart(2, '0') + '!', 'success');
      loadTribes();
    } else {
      toast(data?.error || 'Erro ao alocar', 'error');
    }
  };

  // ══════════════════════════════════════════
  // MEMBERS LIST (Enhanced with filters + tags)
  // ══════════════════════════════════════════

  const OPROLE_LABELS: Record<string, string> = {
    manager: 'Gerente', tribe_leader: 'Líder de Tribo', researcher: 'Pesquisador',
    facilitator: 'Facilitador', communicator: 'Multiplicador', none: 'Sem papel', guest: 'Convidado'
  };
  const OPROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', tribe_leader: '#4F17A8', researcher: '#EC4899',
    facilitator: '#06B6D4', communicator: '#8B5CF6', none: '#94A3B8', guest: '#94A3B8'
  };
  const DESIG_LABELS: Record<string, string> = {
    sponsor: 'Patrocinador', ambassador: 'Embaixador', founder: 'Fundador', curator: 'Curador'
  };
  const DESIG_COLORS: Record<string, string> = {
    sponsor: '#BE2027', ambassador: '#10B981', founder: '#7C3AED', curator: '#D97706'
  };

  function memberTags(m: any): string {
    const opRole = m.operational_role || 'guest';
    const desigs: string[] = m.designations?.length ? m.designations : [];
    let html = '';

    // Operational role tag
    if (opRole !== 'none' && opRole !== 'guest') {
      const c = OPROLE_COLORS[opRole] || '#94A3B8';
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded" style="background:${c}18;color:${c}">${OPROLE_LABELS[opRole] || opRole}</span>`;
    }

    // Designation tags
    desigs.forEach(d => {
      const c = DESIG_COLORS[d] || '#94A3B8';
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded" style="background:${c}18;color:${c}">${DESIG_LABELS[d] || d}</span>`;
    });

    // Superadmin badge
    if (m.is_superadmin) {
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded bg-orange/10 text-orange">🔧 SA</span>`;
    }

    // No role at all
    if (opRole === 'guest' && desigs.length === 0) {
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-400">Convidado</span>`;
    }

    return html;
  }

  function memberTribeTag(m: any): string {
    const tid = m.selected_tribe_id || m.fixed_tribe_id || m.tribe_id;
    if (!tid) return '<span class="text-[.6rem] text-slate-300">sem tribo</span>';
    const color = TRIBE_COLORS[tid] || '#94A3B8';
    return `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded" style="background:${color}18;color:${color}">T${String(tid).padStart(2,'0')}</span>`;
  }

  // Cycle history colors
  const CYCLE_META: Record<string, { label: string; abbr: string; color: string }> = {
    pilot:   { label: 'Piloto 2024', abbr: 'P',  color: '#D97706' },
    cycle_1: { label: 'Ciclo 1',     abbr: 'C1', color: '#4F17A8' },
    cycle_2: { label: 'Ciclo 2',     abbr: 'C2', color: '#00799E' },
    cycle_3: { label: 'Ciclo 3',     abbr: 'C3', color: '#FF610F' },
  };
  const CYCLE_ORDER = ['pilot', 'cycle_1', 'cycle_2', 'cycle_3'];

  let allCycleHistory: any[] = [];
  let memberListCache: any[] = [];

  function cycleDots(memberId: string): string {
    const memberCycles = allCycleHistory.filter((h: any) => h.member_id === memberId);
    return CYCLE_ORDER.map(code => {
      const record = memberCycles.find((h: any) => h.cycle_code === code);
      const meta = CYCLE_META[code];
      if (!record) return `<span class="w-[18px] h-[14px] rounded text-[.5rem] font-bold inline-flex items-center justify-center bg-slate-100 text-slate-300" title="${meta.label}: não participou">${meta.abbr}</span>`;
      const opLabel = OPROLE_LABELS[record.operational_role] || record.operational_role || '';
      const desigLabels = (record.designations || []).map((d: string) => DESIG_LABELS[d] || d).join(', ');
      const tooltip = `${meta.label}: ${opLabel}${desigLabels ? ' + ' + desigLabels : ''}${record.tribe_name ? ' · ' + record.tribe_name : ''}`;
      return `<span class="w-[18px] h-[14px] rounded text-[.5rem] font-bold inline-flex items-center justify-center text-white" style="background:${meta.color}" title="${tooltip}">${meta.abbr}</span>`;
    }).join('');
  }

  async function loadMembersList() {
    const [membersRes, historyRes] = await Promise.all([
      sb.rpc('admin_list_members', { p_limit: 200, p_offset: 0 }),
      sb.from('member_cycle_history').select('member_id, cycle_code, operational_role, designations, tribe_name, chapter, is_active')
    ]);
    const members = Array.isArray(membersRes.data) ? membersRes.data : [];
    allCycleHistory = historyRes.data || [];
    memberListCache = members;

    const inactive = members.filter((m: any) => !m.current_cycle_active);
    const noAuth = members.filter((m: any) => !m.auth_id);
    document.getElementById('stat-inactive')!.textContent = String(inactive.length);
    document.getElementById('stat-noauth')!.textContent = String(noAuth.length);

    const isSA = MEMBER?.is_superadmin === true;

    const area = document.getElementById('members-area')!;
    area.innerHTML = `
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
      <div id="members-rows">
      ${members.map((m: any) => {
        const opRole = m.operational_role || m.role || 'guest';
        const desigs: string[] = m.designations?.length ? m.designations : [];
        const tid = m.selected_tribe_id || m.fixed_tribe_id || m.tribe_id || '';
        const isActive = m.current_cycle_active;
        const hasAuth = !!m.auth_id;
        const status = isActive
          ? '<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-emerald-50 text-emerald-700">Ativo</span>'
          : '<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-red-50 text-crimson">Inativo</span>';

        const histBtn = isSA
          ? `<button onclick='openCycleHistory("${m.id}","${m.name.replace(/'/g, '')}")'
               class="px-1.5 py-0.5 text-[.6rem] font-semibold text-slate-400 border border-slate-100 rounded hover:border-amber-300 hover:text-amber-600 bg-transparent cursor-pointer transition-all" title="Editar histórico de ciclos (superadmin)">📅</button>`
          : '';

        return `
        <div class="member-row flex items-center gap-2 px-4 py-2.5 border-b border-slate-50 hover:bg-slate-50 transition-all ${isActive ? '' : 'opacity-50'}"
             data-name="${m.name.toLowerCase()}"
             data-email="${(m.email || '').toLowerCase()}"
             data-chapter="${m.chapter || ''}"
             data-oprole="${opRole}"
             data-desigs="${desigs.join(',')}"
             data-status="${isActive ? 'active' : 'inactive'}"
             data-auth="${hasAuth ? 'has' : 'no'}"
             data-tribe="${tid}"
             data-superadmin="${m.is_superadmin ? 'yes' : 'no'}">
          ${avatar(m, 'w-9 h-9')}
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-1.5 flex-wrap">
              <span class="font-semibold text-[.82rem] text-navy">${m.name}</span>
              ${!hasAuth ? '<span class="text-[.58rem] font-bold px-1 py-0.5 rounded bg-amber-50 text-amber-600">SEM LOGIN</span>' : ''}
            </div>
            <div class="text-[.65rem] text-slate-400 truncate">${m.email}</div>
          </div>
          <div class="flex gap-1 items-center flex-wrap justify-end max-w-[280px]">
            ${memberTags(m)}
          </div>
          <div class="flex gap-0.5 items-center flex-shrink-0 hidden md:flex" title="Ciclos participados">
            ${cycleDots(m.id)}
          </div>
          <span class="text-[.65rem] font-bold px-1.5 py-0.5 rounded bg-blue-50 text-navy whitespace-nowrap hidden lg:block">${m.chapter || '—'}</span>
          ${memberTribeTag(m)}
          ${status}
          <div class="flex gap-1 flex-shrink-0">
            <button onclick='openEditMember(${JSON.stringify(m).replace(/'/g, "&#39;")})'
              class="px-2 py-1 text-[.68rem] font-semibold text-slate-500 border border-slate-200 rounded-lg hover:border-teal hover:text-teal bg-transparent cursor-pointer transition-all whitespace-nowrap">
              Editar
            </button>
            ${histBtn}
          </div>
        </div>`;
      }).join('')}
      </div>
    </div>`;

    applyFilters();
  }

  (window as any).applyFilters = () => {
    const search = ((document.getElementById('f-search') as HTMLInputElement)?.value || '').toLowerCase().trim();
    const fChapter = (document.getElementById('f-chapter') as HTMLSelectElement)?.value || '';
    const fOpRole = (document.getElementById('f-oprole') as HTMLSelectElement)?.value || '';
    const fDesig = (document.getElementById('f-desig') as HTMLSelectElement)?.value || '';
    const fStatus = (document.getElementById('f-status') as HTMLSelectElement)?.value || '';
    const fAuth = (document.getElementById('f-auth') as HTMLSelectElement)?.value || '';
    const fTribe = (document.getElementById('f-tribe') as HTMLSelectElement)?.value || '';

    let visible = 0;
    let total = 0;

    document.querySelectorAll('.member-row').forEach((row) => {
      const el = row as HTMLElement;
      total++;
      let show = true;

      // Text search (name + email)
      if (search && !el.dataset.name?.includes(search) && !el.dataset.email?.includes(search)) show = false;

      // Chapter
      if (fChapter && el.dataset.chapter !== fChapter) show = false;

      // Operational role
      if (fOpRole && el.dataset.oprole !== fOpRole) show = false;

      // Designation
      if (fDesig) {
        const desigs = el.dataset.desigs || '';
        if (fDesig === 'has_any' && desigs === '') show = false;
        else if (fDesig === 'has_none' && desigs !== '') show = false;
        else if (fDesig !== 'has_any' && fDesig !== 'has_none' && !desigs.includes(fDesig)) show = false;
      }

      // Status
      if (fStatus && el.dataset.status !== fStatus) show = false;

      // Auth
      if (fAuth && el.dataset.auth !== fAuth) show = false;

      // Tribe
      if (fTribe) {
        if (fTribe === 'none' && el.dataset.tribe !== '') show = false;
        else if (fTribe !== 'none' && el.dataset.tribe !== fTribe) show = false;
      }

      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    const countEl = document.getElementById('f-count');
    if (countEl) {
      countEl.textContent = visible === total
        ? `${total} membros`
        : `${visible} de ${total} membros`;
    }
  };

  (window as any).clearFilters = () => {
    (document.getElementById('f-search') as HTMLInputElement).value = '';
    (document.getElementById('f-chapter') as HTMLSelectElement).value = '';
    (document.getElementById('f-oprole') as HTMLSelectElement).value = '';
    (document.getElementById('f-desig') as HTMLSelectElement).value = '';
    (document.getElementById('f-status') as HTMLSelectElement).value = '';
    (document.getElementById('f-auth') as HTMLSelectElement).value = '';
    (document.getElementById('f-tribe') as HTMLSelectElement).value = '';
    applyFilters();
  };

  // Keep old filterMembers as alias for backward-compat
  (window as any).filterMembers = (q: string) => {
    (document.getElementById('f-search') as HTMLInputElement).value = q;
    applyFilters();
  };

  // ══════════════════════════════════════════
  // EDIT MEMBER MODAL (3-Axis)
  // ══════════════════════════════════════════

  function updateTierHint() {
    const opRole = (document.getElementById('edit-m-oprole') as HTMLSelectElement).value;
    const desigs = Array.from(document.querySelectorAll('.desig-cb:checked')).map(cb => (cb as HTMLInputElement).value);
    const isSuperadmin = (document.getElementById('edit-m-superadmin') as HTMLInputElement).checked;
    const tier = getAccessTier(isSuperadmin, opRole, desigs);
    const display = document.getElementById('edit-m-tier-display');
    if (display) display.textContent = TIER_LABELS[tier] || tier;
  }

  // Bind change events for live tier preview
  document.getElementById('edit-m-oprole')?.addEventListener('change', updateTierHint);
  document.getElementById('edit-m-superadmin')?.addEventListener('change', updateTierHint);
  document.querySelectorAll('.desig-cb').forEach(cb => cb.addEventListener('change', updateTierHint));

  (window as any).openEditMember = (m: any) => {
    (document.getElementById('edit-m-id') as HTMLInputElement).value = m.id;

    // Header
    const isSA = m.is_superadmin === true;
    document.getElementById('edit-m-header')!.innerHTML = avatar(m, 'w-12 h-12') +
      `<div>
        <div class="font-bold text-navy">${m.name}</div>
        <div class="text-[.72rem] text-slate-400">${m.email} · ${m.chapter || ''}</div>
        ${isSA ? '<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded bg-orange/10 text-orange">🔧 SUPERADMIN</span>' : ''}
      </div>`;

    // Axis 1: Operational Role
    const opRole = m.operational_role || 'guest';
    (document.getElementById('edit-m-oprole') as HTMLSelectElement).value = opRole;

    // Axis 2: Designations
    const desigs: string[] = m.designations?.length ? m.designations : [];
    document.querySelectorAll('.desig-cb').forEach(cb => {
      (cb as HTMLInputElement).checked = desigs.includes((cb as HTMLInputElement).value);
    });

    // Axis 3: Superadmin
    (document.getElementById('edit-m-superadmin') as HTMLInputElement).checked = isSA;

    // Chapter + Status
    (document.getElementById('edit-m-chapter') as HTMLSelectElement).value = m.chapter || 'PMI-GO';
    (document.getElementById('edit-m-active') as HTMLSelectElement).value = String(m.current_cycle_active);

    updateTierHint();

    const modal = document.getElementById('modal-edit-member')!;
    modal.classList.remove('hidden'); modal.classList.add('flex');
  };

  (window as any).closeEditMember = () => {
    const modal = document.getElementById('modal-edit-member')!;
    modal.classList.add('hidden'); modal.classList.remove('flex');
  };

  (window as any).saveEditMember = async () => {
    const id = (document.getElementById('edit-m-id') as HTMLInputElement).value;
    const opRole = (document.getElementById('edit-m-oprole') as HTMLSelectElement).value;
    const desigs = Array.from(document.querySelectorAll('.desig-cb:checked')).map(cb => (cb as HTMLInputElement).value);
    const isSuperadmin = (document.getElementById('edit-m-superadmin') as HTMLInputElement).checked;
    const chapter = (document.getElementById('edit-m-chapter') as HTMLSelectElement).value;
    const active = (document.getElementById('edit-m-active') as HTMLSelectElement).value === 'true';

    // Compute backward-compatible role/roles
    const { role, roles } = computeLegacyFields(opRole, desigs);

    // Save via RPC (handles role + roles)
    const { data, error } = await sb.rpc('admin_update_member', {
      p_member_id: id,
      p_role: role,
      p_roles: roles,
      p_chapter: chapter,
      p_current_cycle_active: active
    });

    if (error) {
      toast('Erro ao salvar: ' + error.message, 'error');
      return;
    }

    if (!data?.success) {
      toast(data?.error || 'Erro ao salvar', 'error');
      return;
    }

    // Also update the new 3-axis fields directly
    // (RPC updates role/roles, we update operational_role/designations/is_superadmin)
    const { error: e2 } = await sb.from('members').update({
      operational_role: opRole,
      designations: desigs,
      is_superadmin: isSuperadmin
    }).eq('id', id);

    if (e2) {
      console.warn('3-axis direct update warning:', e2.message);
      // Non-fatal: RPC already saved role/roles
    }

    (window as any).closeEditMember();
    toast('Membro atualizado!', 'success');
    loadMembersList();
    loadTribes();
  };

  // ══════════════════════════════════════════
  // CYCLE HISTORY MODAL (Superadmin only)
  // ══════════════════════════════════════════
  let chMemberId = '';

  (window as any).openCycleHistory = async (memberId: string, memberName: string) => {
    if (!MEMBER?.is_superadmin) { toast('Apenas superadmins podem editar histórico', 'error'); return; }
    chMemberId = memberId;
    document.getElementById('ch-member-name')!.textContent = memberName;

    const { data: records } = await sb.from('member_cycle_history')
      .select('*')
      .eq('member_id', memberId)
      .order('cycle_start', { ascending: true });

    const area = document.getElementById('ch-cycles-area')!;
    const existingCodes = (records || []).map((r: any) => r.cycle_code);

    area.innerHTML = `
      ${(records || []).map((r: any) => {
        const meta = CYCLE_META[r.cycle_code] || { label: r.cycle_code, color: '#94A3B8' };
        const opLabel = OPROLE_LABELS[r.operational_role] || r.operational_role || 'none';
        const desigLabels = (r.designations || []).map((d: string) => DESIG_LABELS[d] || d);
        return `
        <div class="rounded-xl border border-slate-200 p-3 mb-3" style="border-left:4px solid ${meta.color}">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[.78rem] font-bold" style="color:${meta.color}">${r.cycle_label || meta.label}</span>
            <div class="flex gap-1">
              <button onclick="editCycleRecord('${r.id}')" class="text-[.6rem] px-2 py-0.5 rounded bg-slate-100 text-slate-500 hover:bg-amber-50 hover:text-amber-600 cursor-pointer border-0 transition-all">✏️ Editar</button>
              <button onclick="deleteCycleRecord('${r.id}','${r.cycle_label || meta.label}')" class="text-[.6rem] px-2 py-0.5 rounded bg-slate-100 text-red-400 hover:bg-red-50 hover:text-crimson cursor-pointer border-0 transition-all">🗑️</button>
            </div>
          </div>
          <div class="text-[.72rem] text-slate-600">
            <span class="font-semibold">Papel:</span> ${opLabel}
            ${desigLabels.length ? ` · <span class="font-semibold">Designações:</span> ${desigLabels.join(', ')}` : ''}
          </div>
          ${r.tribe_name ? `<div class="text-[.68rem] text-slate-400 mt-0.5">🏷️ ${r.tribe_name}</div>` : ''}
          ${r.chapter ? `<div class="text-[.68rem] text-slate-400">📍 ${r.chapter}</div>` : ''}
          ${r.notes ? `<div class="text-[.65rem] text-slate-400 italic mt-1">📝 ${r.notes}</div>` : ''}
          <div class="text-[.6rem] text-slate-300 mt-1">${r.is_active ? '✅ Ativo' : '❌ Inativo'} · ${r.cycle_start || ''} → ${r.cycle_end || 'atual'}</div>
        </div>`;
      }).join('')}

      ${CYCLE_ORDER.filter(c => !existingCodes.includes(c)).length > 0 ? `
      <div class="mt-3 p-3 border border-dashed border-slate-200 rounded-xl">
        <div class="text-[.72rem] font-semibold text-slate-500 mb-2">➕ Adicionar registro de ciclo</div>
        <div class="flex gap-2 flex-wrap">
          ${CYCLE_ORDER.filter(c => !existingCodes.includes(c)).map(c => {
            const meta = CYCLE_META[c];
            return `<button onclick="addCycleRecord('${c}')" class="px-3 py-1.5 text-[.68rem] font-bold rounded-lg border-0 cursor-pointer text-white hover:opacity-90 transition-all" style="background:${meta.color}">${meta.label}</button>`;
          }).join('')}
        </div>
      </div>` : '<div class="text-center text-[.72rem] text-emerald-600 font-semibold mt-2">✅ Todos os ciclos registrados</div>'}
    `;

    const modal = document.getElementById('modal-cycle-history')!;
    modal.classList.remove('hidden'); modal.classList.add('flex');
  };

  (window as any).closeCycleHistory = () => {
    const modal = document.getElementById('modal-cycle-history')!;
    modal.classList.add('hidden'); modal.classList.remove('flex');
  };

  (window as any).addCycleRecord = async (cycleCode: string) => {
    if (!MEMBER?.is_superadmin || !chMemberId) return;
    const meta = CYCLE_META[cycleCode];
    const dates: Record<string, { start: string; end: string|null }> = {
      pilot:   { start: '2024-03-01', end: '2024-12-31' },
      cycle_1: { start: '2025-01-01', end: '2025-06-30' },
      cycle_2: { start: '2025-07-01', end: '2025-12-31' },
      cycle_3: { start: '2026-01-01', end: null },
    };
    const d = dates[cycleCode] || { start: '2026-01-01', end: null };

    // Get member name for snapshot
    const member = memberListCache?.find((m: any) => m.id === chMemberId) || {};

    const { error } = await sb.from('member_cycle_history').insert({
      member_id: chMemberId,
      member_name_snapshot: member.name || 'Unknown',
      cycle_code: cycleCode,
      cycle_label: meta.label,
      cycle_start: d.start,
      cycle_end: d.end,
      operational_role: 'researcher',
      designations: [],
      chapter: member.chapter || '',
      is_active: true,
    });

    if (error) { toast('Erro: ' + error.message, 'error'); return; }
    toast(`${meta.label} adicionado ✅`, 'success');
    // Refresh
    (window as any).openCycleHistory(chMemberId, document.getElementById('ch-member-name')!.textContent || '');
  };

  (window as any).editCycleRecord = async (recordId: string) => {
    if (!MEMBER?.is_superadmin) return;
    const opRole = prompt('Papel operacional (manager/tribe_leader/researcher/facilitator/communicator/none):');
    if (opRole === null) return;
    const desigsRaw = prompt('Designações (separar por vírgula: sponsor,ambassador,founder,curator):');
    if (desigsRaw === null) return;
    const tribeName = prompt('Nome da tribo (ex: "T3: Priorização e Seleção" ou vazio):');
    if (tribeName === null) return;
    const notes = prompt('Notas (opcional):');

    const desigs = desigsRaw.split(',').map(d => d.trim()).filter(Boolean);

    const { error } = await sb.from('member_cycle_history').update({
      operational_role: opRole || 'researcher',
      designations: desigs,
      tribe_name: tribeName || null,
      notes: notes || null,
    }).eq('id', recordId);

    if (error) { toast('Erro: ' + error.message, 'error'); return; }
    toast('Registro atualizado ✅', 'success');
    (window as any).openCycleHistory(chMemberId, document.getElementById('ch-member-name')!.textContent || '');
  };

  (window as any).deleteCycleRecord = async (recordId: string, label: string) => {
    if (!MEMBER?.is_superadmin) return;
    if (!confirm(`Excluir registro "${label}"? Esta ação não pode ser desfeita.`)) return;
    const { error } = await sb.from('member_cycle_history').delete().eq('id', recordId);
    if (error) { toast('Erro: ' + error.message, 'error'); return; }
    toast(`${label} removido`, 'info');
    (window as any).openCycleHistory(chMemberId, document.getElementById('ch-member-name')!.textContent || '');
  };

  // ══════════════════════════════════════════
  // LEADER TIER: My Tribe view
  // ══════════════════════════════════════════
  async function loadMyTribe() {
    const tribeId = MEMBER.tribe_id;
    if (!tribeId) {
      document.getElementById('my-tribe-members')!.innerHTML =
        '<p class="text-slate-400 text-sm text-center py-6">Você não está alocado em uma tribo.</p>';
      return;
    }

    // Load tribe members
    const { data: selections } = await sb.from('tribe_selections')
      .select('member_id')
      .eq('tribe_id', tribeId);

    const memberIds = (selections || []).map((s: any) => s.member_id);
    // Include self (tribe leader)
    if (!memberIds.includes(MEMBER.id)) memberIds.push(MEMBER.id);

    const { data: members } = await sb.from('members')
      .select('id, name, email, chapter, photo_url, operational_role, designations, current_cycle_active')
      .in('id', memberIds)
      .order('name');

    const el = document.getElementById('my-tribe-members')!;
    if (!members?.length) {
      el.innerHTML = '<p class="text-slate-400 text-sm text-center py-6">Nenhum membro na tribo ainda.</p>';
      return;
    }

    el.innerHTML = `
      <div class="text-[.72rem] text-slate-400 mb-3">${members.length} membros na tribo</div>
      ${members.map((m: any) => {
        const isLeader = m.operational_role === 'tribe_leader';
        const initials = m.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
        const photo = m.photo_url
          ? `<img src="${m.photo_url}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="">`
          : `<div class="w-10 h-10 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.7rem] flex-shrink-0">${initials}</div>`;
        return `
        <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
          ${photo}
          <div class="flex-1 min-w-0">
            <div class="text-[.82rem] font-semibold text-navy">${m.name} ${isLeader ? '👑' : ''}</div>
            <div class="text-[.68rem] text-slate-400">${m.email} · ${m.chapter || ''}</div>
          </div>
          <span class="text-[.65rem] font-bold px-2 py-0.5 rounded-full ${m.current_cycle_active ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-crimson'}">
            ${m.current_cycle_active ? 'Ativo' : 'Inativo'}
          </span>
        </div>`;
      }).join('')}`;

    // Load recent attendance
    const { data: events } = await sb.from('events')
      .select('id, title, event_date, duration_hours')
      .order('event_date', { ascending: false })
      .limit(5);

    const attEl = document.getElementById('my-tribe-attendance')!;
    if (!events?.length) {
      attEl.innerHTML = '<p class="text-slate-400 text-sm text-center py-6">Nenhum evento recente.</p>';
      return;
    }

    // Get attendance for these events
    const eventIds = events.map((e: any) => e.id);
    const { data: attendance } = await sb.from('attendance')
      .select('event_id, member_id, status')
      .in('event_id', eventIds)
      .in('member_id', memberIds);

    const attMap: Record<string, Record<string, string>> = {};
    (attendance || []).forEach((a: any) => {
      if (!attMap[a.event_id]) attMap[a.event_id] = {};
      attMap[a.event_id][a.member_id] = a.status;
    });

    attEl.innerHTML = events.map((ev: any) => {
      const date = new Date(ev.event_date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
      const evAtt = attMap[ev.id] || {};
      const present = Object.values(evAtt).filter(s => s === 'present').length;
      const total = members.length;
      return `
      <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
        <div class="text-[.72rem] font-bold text-slate-400 w-14 flex-shrink-0">${date}</div>
        <div class="flex-1 min-w-0 text-[.82rem] truncate">${ev.title}</div>
        <div class="text-[.72rem] font-bold ${present === total ? 'text-emerald-600' : present > 0 ? 'text-amber-600' : 'text-slate-400'}">
          ${present}/${total}
        </div>
      </div>`;
    }).join('');
  }

  // ══════════════════════════════════════════
  // SPONSOR TIER: Executive Overview
  // ══════════════════════════════════════════
  async function loadExecutiveOverview() {
    // Members by chapter
    const { data: members } = await sb.from('members')
      .select('chapter, current_cycle_active, operational_role')
      .neq('operational_role', 'guest');

    const active = (members || []).filter((m: any) => m.current_cycle_active);
    const byChapter: Record<string, { total: number; active: number }> = {};
    (members || []).forEach((m: any) => {
      const ch = m.chapter || 'Outros';
      if (!byChapter[ch]) byChapter[ch] = { total: 0, active: 0 };
      byChapter[ch].total++;
      if (m.current_cycle_active) byChapter[ch].active++;
    });

    const CHAPTER_COLORS: Record<string, string> = {
      'PMI-GO': '#FF610F', 'PMI-CE': '#4F17A8', 'PMI-DF': '#00799E',
      'PMI-MG': '#10B981', 'PMI-RS': '#D97706'
    };

    document.getElementById('exec-chapters')!.innerHTML =
      Object.entries(byChapter).sort((a, b) => b[1].active - a[1].active).map(([ch, s]) => {
        const color = CHAPTER_COLORS[ch] || '#94A3B8';
        const maxActive = Math.max(...Object.values(byChapter).map(v => v.active), 1);
        const pct = Math.round((s.active / maxActive) * 100);
        return `
        <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
          <div class="text-[.82rem] font-bold w-16 flex-shrink-0" style="color:${color}">${ch}</div>
          <div class="flex-1">
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
            </div>
          </div>
          <div class="text-[.78rem] font-bold text-navy flex-shrink-0">${s.active}</div>
          <div class="text-[.65rem] text-slate-400 flex-shrink-0">ativos</div>
        </div>`;
      }).join('');

    // General progress stats
    const totalActive = active.length;
    const researchers = active.filter((m: any) => m.operational_role === 'researcher').length;
    const leaders = active.filter((m: any) => m.operational_role === 'tribe_leader').length;
    const managers = active.filter((m: any) => m.operational_role === 'manager').length;

    // Course progress aggregated
    const { data: courseProgress } = await sb.from('course_progress')
      .select('status');
    const completed = (courseProgress || []).filter((c: any) => c.status === 'completed').length;
    const totalCourseSlots = totalActive * 8;
    const trailPct = totalCourseSlots > 0 ? Math.round((completed / totalCourseSlots) * 100) : 0;

    // Artifacts
    const { data: artifacts } = await sb.from('artifacts').select('status');
    const published = (artifacts || []).filter((a: any) => a.status === 'published').length;
    const inReview = (artifacts || []).filter((a: any) => a.status === 'review').length;

    document.getElementById('exec-progress')!.innerHTML = `
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-navy">${totalActive}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Ativos</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-purple">${leaders + managers}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Liderança</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-teal">${trailPct}%</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Trilha IA</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-emerald-600">${published}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Publicados</div>
        </div>
      </div>
      <div class="mt-3 text-[.7rem] text-slate-400">
        ${researchers} pesquisadores · ${inReview} artefatos em revisão · ${completed} cursos concluídos
      </div>`;

    // Tribe summary
    const { data: tribeData } = await sb.from('tribe_selections').select('tribe_id');
    const tribeCounts: Record<number, number> = {};
    (tribeData || []).forEach((t: any) => { tribeCounts[t.tribe_id] = (tribeCounts[t.tribe_id] || 0) + 1; });

    document.getElementById('exec-tribes')!.innerHTML = `
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        ${[1,2,3,4,5,6,7,8].map(tid => {
          const count = tribeCounts[tid] || 0;
          const color = TRIBE_COLORS[tid] || '#94A3B8';
          return `
          <div class="rounded-xl p-3 text-center border border-slate-100">
            <div class="text-[.65rem] font-bold uppercase tracking-wider mb-1" style="color:${color}">T${String(tid).padStart(2,'0')}</div>
            <div class="text-lg font-black text-navy">${count}/6</div>
            <div class="text-[.6rem] text-slate-400">${TRIBE_NAMES[tid]?.split(' ').slice(0,2).join(' ')}</div>
          </div>`;
        }).join('')}
      </div>`;
  }

  // ══════════════════════════════════════════
  // BOOT (Tier-aware)
  // ══════════════════════════════════════════
  let TIER = 'visitor';

  function getTier(m: any): string {
    if (m.is_superadmin) return 'superadmin';
    const opRole = m.operational_role || m.role || 'guest';
    if (opRole === 'manager') return 'admin';
    if (opRole === 'tribe_leader') return 'leader';
    const desigs: string[] = m.designations || [];
    if (desigs.includes('sponsor') || desigs.includes('curator')) return 'observer';
    return 'visitor';
  }

  function setup() {
    document.getElementById('admin-loading')?.classList.add('hidden');
    TIER = getTier(MEMBER);

    if (TIER === 'visitor') {
      document.getElementById('not-admin-msg')?.classList.remove('hidden');
      return;
    }

    document.getElementById('admin-panel')?.classList.remove('hidden');

    // Configure UI based on tier
    if (TIER === 'superadmin' || TIER === 'admin') {
      // Full access: tribes tab + members tab + filters
      loadTribes();

    } else if (TIER === 'leader') {
      // Show tier header
      const header = document.getElementById('tier-header')!;
      header.classList.remove('hidden');
      document.getElementById('tier-icon')!.textContent = '🏷️';
      document.getElementById('tier-title')!.textContent = 'Painel da Tribo — ' + (TRIBE_NAMES[MEMBER.tribe_id] || 'Sua Tribo');
      document.getElementById('tier-subtitle')!.textContent = 'Visualização read-only · Pode registrar presença dos membros';

      // Hide superadmin tabs, show my-tribe
      document.querySelectorAll('.adm-tab').forEach(t => (t as HTMLElement).style.display = 'none');
      document.getElementById('panel-tribes')?.classList.add('hidden');
      document.getElementById('panel-members')?.classList.add('hidden');

      // Hide KPI bar (superadmin-only stats)
      document.querySelectorAll('#admin-panel > .grid.grid-cols-2')[0]?.classList.add('hidden');

      document.getElementById('panel-my-tribe')?.classList.remove('hidden');
      loadMyTribe();

    } else if (TIER === 'observer') {
      // Show tier header
      const header = document.getElementById('tier-header')!;
      header.classList.remove('hidden');
      header.style.borderColor = '#BE202730';
      header.style.background = '#BE202708';
      document.getElementById('tier-icon')!.textContent = '📊';
      document.getElementById('tier-title')!.textContent = 'Visão Executiva — Ciclo 3';
      document.getElementById('tier-subtitle')!.textContent = 'Dados agregados · Sem acesso a informações individuais detalhadas';

      // Hide superadmin tabs, show executive
      document.querySelectorAll('.adm-tab').forEach(t => (t as HTMLElement).style.display = 'none');
      document.getElementById('panel-tribes')?.classList.add('hidden');
      document.getElementById('panel-members')?.classList.add('hidden');

      document.getElementById('panel-executive')?.classList.remove('hidden');
      loadExecutiveOverview();
    }
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && e.detail.role !== 'guest' && !MEMBER) {
        MEMBER = e.detail;
        setup();
      }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && m.role !== 'guest') { MEMBER = m; setup(); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        if (data && data.role !== 'guest') { MEMBER = data; setup(); return; }
      }
    } catch (e) {}

    setTimeout(() => {
      if (MEMBER) return;
      document.getElementById('admin-loading')?.classList.add('hidden');
      document.getElementById('not-admin-msg')?.classList.remove('hidden');
    }, 2000);
  }

  boot();
</script>
