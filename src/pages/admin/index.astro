      const toggleBtn = (e.target as HTMLElement).closest('.btn-toggle-knw');
      if (toggleBtn) {
        (window as any).toggleKnowledgeAsset(toggleBtn.getAttribute('data-knw-id') || '', toggleBtn.getAttribute('data-knw-active') === 'true');
      }
    });
  }

  // ── P3: PDF Upload Handler (with file validation) ──
  const MAX_FILE_SIZE = 15 * 1024 * 1024; // 15 MB
  const ALLOWED_EXTS = ['.pdf', '.pptx', '.png', '.jpg', '.jpeg'];
  const MIME_MAP: Record<string, string> = {
    '.pdf': 'application/pdf',
    '.pptx': 'application/vnd.openxmlformats-officedocument.presentationml.presentation',
    '.png': 'image/png',
    '.jpg': 'image/jpeg',
    '.jpeg': 'image/jpeg',
  };

  function validateFileInput(file: File): string | null {
    const ext = '.' + file.name.split('.').pop()!.toLowerCase();
    if (!ALLOWED_EXTS.includes(ext)) return ADMIN_I18N.uploadValidationInvalidType || 'Invalid file type.';
    if (file.size > MAX_FILE_SIZE) return ADMIN_I18N.uploadValidationTooLarge || 'File exceeds 15 MB.';
    return null;
  }

  // Live validation on file input change
  const pdfFileInput = document.getElementById('pdf-file') as HTMLInputElement | null;
  const pdfFileError = document.getElementById('pdf-file-error') as HTMLElement | null;
  const pdfUploadBtn = document.getElementById('pdf-upload-btn') as HTMLButtonElement | null;
  if (pdfFileInput) {
    pdfFileInput.addEventListener('change', () => {
      const file = pdfFileInput.files?.[0];
      if (!file) { pdfFileError?.classList.add('hidden'); if (pdfUploadBtn) pdfUploadBtn.disabled = false; return; }
      const err = validateFileInput(file);
      if (err) {
        if (pdfFileError) { pdfFileError.textContent = err; pdfFileError.classList.remove('hidden'); }
        if (pdfUploadBtn) { pdfUploadBtn.disabled = true; pdfUploadBtn.classList.add('opacity-50', 'cursor-not-allowed'); }
        pdfFileInput.value = '';
      } else {
        if (pdfFileError) pdfFileError.classList.add('hidden');
        if (pdfUploadBtn) { pdfUploadBtn.disabled = false; pdfUploadBtn.classList.remove('opacity-50', 'cursor-not-allowed'); }
      }
    });
  }

  if (!(window as any).__pdfUploadBound) {
    (window as any).__pdfUploadBound = true;
    if (pdfUploadBtn) {
      pdfUploadBtn.addEventListener('click', async () => {
        if (!ensureAdminAction()) return;
        const titleEl = document.getElementById('pdf-title') as HTMLInputElement;
        const typeEl = document.getElementById('pdf-type') as HTMLSelectElement;
        const fileEl = document.getElementById('pdf-file') as HTMLInputElement;
        const statusEl = document.getElementById('pdf-upload-status')!;

        const title = titleEl?.value.trim();
        const file = fileEl?.files?.[0];
        if (!title || !file) { toast('Preencha o titulo e selecione um arquivo.', 'error'); return; }

        const validationErr = validateFileInput(file);
        if (validationErr) { toast(validationErr, 'error'); return; }

        const ext = '.' + file.name.split('.').pop()!.toLowerCase();
        const contentType = MIME_MAP[ext] || 'application/octet-stream';

        statusEl.classList.remove('hidden');
        statusEl.textContent = 'Enviando...';
        statusEl.className = 'mt-3 text-[.72rem] text-blue-600';

        try {
          const fileName = Date.now() + '_' + file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
          const storagePath = 'knowledge-pdfs/' + fileName;
          const { error: uploadErr } = await sb.storage.from('documents').upload(storagePath, file, { contentType, upsert: false });
          if (uploadErr) { statusEl.textContent = 'Erro no upload: ' + uploadErr.message; statusEl.className = 'mt-3 text-[.72rem] text-crimson'; return; }

          const { data: urlData } = sb.storage.from('documents').getPublicUrl(storagePath);
          const publicUrl = urlData?.publicUrl || '';

          const { error: insertErr } = await sb.from('hub_resources').insert({
            title: title,
            asset_type: typeEl?.value || 'reference',
            url: publicUrl,
            source: 'pdf_upload',
            is_active: true,
            author_id: MEMBER?.id || null,
          });
          if (insertErr) { statusEl.textContent = 'Erro ao registrar: ' + insertErr.message; statusEl.className = 'mt-3 text-[.72rem] text-crimson'; return; }

          statusEl.textContent = 'Arquivo enviado e vinculado com sucesso!';
          statusEl.className = 'mt-3 text-[.72rem] text-emerald-600';
          titleEl.value = ''; fileEl.value = '';
          loadKnowledgeAssets();
        } catch (e: any) {
          statusEl.textContent = 'Erro: ' + (e.message || 'Desconhecido');
          statusEl.className = 'mt-3 text-[.72rem] text-crimson';
        }
      });
    }
  }

  // ── P3: Trello Import Handler ──
  if (!(window as any).__trelloImportBound) {
    (window as any).__trelloImportBound = true;

    async function runTrelloImport(dryRun: boolean) {
      if (!ensureAdminAction()) return;
      const sourceEl = document.getElementById('trello-source') as HTMLSelectElement;
      const targetEl = document.getElementById('trello-target') as HTMLSelectElement;
      const fileEl = document.getElementById('trello-file') as HTMLInputElement;
      const statusEl = document.getElementById('trello-import-status')!;

      const file = fileEl?.files?.[0];
      if (!file) { toast('Selecione o arquivo JSON exportado do Trello.', 'error'); return; }

      statusEl.classList.remove('hidden');
      statusEl.textContent = dryRun ? 'Executando Dry Run...' : 'Importando...';
      statusEl.className = 'mt-3 text-[.72rem] text-blue-600';

      try {
        const text = await file.text();
        const board = JSON.parse(text);
        const { data: { session } } = await sb.auth.getSession();
        if (!session) { statusEl.textContent = 'Sessao expirada. Faca login novamente.'; statusEl.className = 'mt-3 text-[.72rem] text-crimson'; return; }

        const res = await fetch(sb.supabaseUrl + '/functions/v1/import-trello-legacy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + session.access_token },
          body: JSON.stringify({
            board: board,
            board_source: sourceEl?.value || 'articles_c1',
            target_table: targetEl?.value || 'artifacts',
            dry_run: dryRun,
          }),
        });

        const data = await res.json();
        if (!data.success) { statusEl.textContent = 'Erro: ' + (data.error || 'Falha desconhecida'); statusEl.className = 'mt-3 text-[.72rem] text-crimson'; return; }

        const label = dryRun ? 'DRY RUN' : 'IMPORTACAO';
        statusEl.innerHTML = '<strong>' + label + ':</strong> ' + data.mapped + ' cards mapeados, ' + data.skipped + ' ignorados (total: ' + data.total + ')';
        statusEl.className = 'mt-3 text-[.72rem] text-emerald-600';
        if (!dryRun) { fileEl.value = ''; loadKnowledgeAssets(); }
      } catch (e: any) {
        statusEl.textContent = 'Erro: ' + (e.message || 'JSON invalido');
        statusEl.className = 'mt-3 text-[.72rem] text-crimson';
      }
    }

    document.getElementById('trello-import-btn')?.addEventListener('click', () => runTrelloImport(false));
    document.getElementById('trello-dryrun-btn')?.addEventListener('click', () => runTrelloImport(true));
  }

  // ── P3: Calendar Import Handler ──
  if (!(window as any).__calendarImportBound) {
    (window as any).__calendarImportBound = true;

    async function runCalendarImport(dryRun: boolean) {
      if (!ensureAdminAction()) return;
      const jsonEl = document.getElementById('calendar-json') as HTMLTextAreaElement;
      const statusEl = document.getElementById('calendar-import-status')!;

      const raw = jsonEl?.value.trim();
      if (!raw) { toast('Cole o JSON de eventos do Google Calendar.', 'error'); return; }

      statusEl.classList.remove('hidden');
      statusEl.textContent = dryRun ? 'Executando Dry Run...' : 'Importando eventos...';
      statusEl.className = 'mt-3 text-[.72rem] text-blue-600';

      try {
        let parsed = JSON.parse(raw);
        const events = parsed.events || parsed.items || (Array.isArray(parsed) ? parsed : []);

        const { data: { session } } = await sb.auth.getSession();
        if (!session) { statusEl.textContent = 'Sessao expirada.'; statusEl.className = 'mt-3 text-[.72rem] text-crimson'; return; }

        const res = await fetch(sb.supabaseUrl + '/functions/v1/import-calendar-legacy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + session.access_token },
          body: JSON.stringify({ events: events, dry_run: dryRun }),
        });

        const data = await res.json();
        if (!data.success) { statusEl.textContent = 'Erro: ' + (data.error || 'Falha'); statusEl.className = 'mt-3 text-[.72rem] text-crimson'; return; }

        const label = dryRun ? 'DRY RUN' : 'IMPORTACAO';
        statusEl.innerHTML = '<strong>' + label + ':</strong> ' + data.imported + ' eventos importados, ' + data.skipped + ' ignorados (total: ' + data.total + ')';
        statusEl.className = 'mt-3 text-[.72rem] text-emerald-600';
        if (!dryRun) jsonEl.value = '';
      } catch (e: any) {
        statusEl.textContent = 'Erro: ' + (e.message || 'JSON invalido');
        statusEl.className = 'mt-3 text-[.72rem] text-crimson';
      }
    }

    document.getElementById('calendar-import-btn')?.addEventListener('click', () => runCalendarImport(false));
    document.getElementById('calendar-dryrun-btn')?.addEventListener('click', () => runCalendarImport(true));
  }

  // Event Delegation: members, cycle history, tribe slots (.cursorrules compliant)
