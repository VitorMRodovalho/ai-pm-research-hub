      </div>`;

    // Axis 1: Operational Role
    const opRole = m.operational_role || 'guest';
    (document.getElementById('edit-m-oprole') as HTMLSelectElement).value = opRole;

    // Axis 2: Designations
    const desigs: string[] = m.designations?.length ? m.designations : [];
    document.querySelectorAll('.desig-cb').forEach(cb => {
