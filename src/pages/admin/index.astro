  async function loadMyTribe() {
    if (!ensureLeaderAction(false)) return;
    const tribeId = MEMBER.tribe_id;
    if (!tribeId) {
      document.getElementById('my-tribe-settings')!.innerHTML =
        `<p class="text-slate-400 text-sm text-center py-4">${ADMIN_I18N.myTribeNoAllocation}</p>`;
      document.getElementById('my-tribe-members')!.innerHTML =
        `<p class="text-slate-400 text-sm text-center py-6">${ADMIN_I18N.myTribeNoAllocation}</p>`;
      return;
    }

    // ── Load tribe settings ──
    const { data: tribe } = await sb.from('tribes')
      .select('*')
      .eq('id', tribeId)
      .single();

    const settingsEl = document.getElementById('my-tribe-settings')!;
    if (tribe) {
      // Load existing slots
      const { data: slots } = await sb.from('tribe_meeting_slots')
        .select('id, day_of_week, time_start, time_end, is_active')
        .eq('tribe_id', tribeId)
        .order('day_of_week');

      const DAY_OPTS = [
        { v: 0, l: ADMIN_I18N.dayNames[0] }, { v: 1, l: ADMIN_I18N.dayNames[1] }, { v: 2, l: ADMIN_I18N.dayNames[2] },
        { v: 3, l: ADMIN_I18N.dayNames[3] }, { v: 4, l: ADMIN_I18N.dayNames[4] }, { v: 5, l: ADMIN_I18N.dayNames[5] }, { v: 6, l: ADMIN_I18N.dayNames[6] }
      ];
      const DAY_SHORT = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

      const slotsHtml = (slots || []).map((s: any) => `
        <div class="flex items-center gap-2 py-1.5 border-b border-slate-100" data-slot-id="${s.id}">
          <span class="text-[.78rem] font-semibold w-12">${DAY_SHORT[s.day_of_week]}</span>
          <span class="text-[.78rem] text-slate-600">${s.time_start.substring(0,5)} – ${s.time_end.substring(0,5)}</span>
          <span class="flex-1"></span>
          <button type="button" class="btn-delete-slot text-[.6rem] px-2 py-0.5 rounded bg-red-50 text-crimson hover:bg-red-100 border-0 cursor-pointer transition-all"
            data-slot-id="${escapeAttr(s.id)}" data-tribe-id="${tribeId}">🗑️</button>
        </div>`).join('');

      const dayOptions = DAY_OPTS.map(d => `<option value="${d.v}">${d.l}</option>`).join('');

      settingsEl.innerHTML = `
