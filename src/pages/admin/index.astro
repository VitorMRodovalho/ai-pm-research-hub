  (window as any).addCycleRecord = async (cycleCode: string) => {
    if (!canAccessAdminRoute(MEMBER, 'admin_member_edit') || !chMemberId) return;
    const meta = getCycleDisplayMeta(cycleCode);
    const d = cycleDatesMap[cycleCode] || { start: getFallbackCycleStart(), end: null };

    // Get member name for snapshot
    const member = memberListCache?.find((m: any) => m.id === chMemberId) || {};

    const { error } = await sb.from('member_cycle_history').insert({
      member_id: chMemberId,
      member_name_snapshot: safeName(member),
      cycle_code: cycleCode,
      cycle_label: meta.label,
      cycle_start: d.start,
      cycle_end: d.end,
      operational_role: 'researcher',
      designations: [],
      chapter: member.chapter || '',
      is_active: true,
    });

    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    toast(ADMIN_I18N.cycleRecordAdded.replace('{label}', meta.label), 'success');
    // Refresh
    (window as any).openCycleHistory(chMemberId, document.getElementById('ch-member-name')!.textContent || '');
  };

  (window as any).editCycleRecord = async (recordId: string) => {
    if (!canAccessAdminRoute(MEMBER, 'admin_member_edit')) return;
    const opRole = prompt(ADMIN_I18N.cyclePromptOpRole);
    if (opRole === null) return;
    const desigsRaw = prompt(ADMIN_I18N.cyclePromptDesigs);
    if (desigsRaw === null) return;
    const tribeName = prompt(ADMIN_I18N.cyclePromptTribeName);
    if (tribeName === null) return;
    const notes = prompt(ADMIN_I18N.cyclePromptNotes);

    const desigs = desigsRaw.split(',').map(d => d.trim()).filter(Boolean);

    const { error } = await sb.from('member_cycle_history').update({
      operational_role: opRole || 'researcher',
      designations: desigs,
      tribe_name: tribeName || null,
      notes: notes || null,
    }).eq('id', recordId);

    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    toast(ADMIN_I18N.recordUpdated, 'success');
    (window as any).openCycleHistory(chMemberId, document.getElementById('ch-member-name')!.textContent || '');
  };

  (window as any).deleteCycleRecord = async (recordId: string, label: string) => {
    if (!canAccessAdminRoute(MEMBER, 'admin_member_edit')) return;
    if (!confirm(`${ADMIN_I18N.deleteRecordConfirmPrefix} "${label}"? ${ADMIN_I18N.deleteRecordConfirmSuffix}`)) return;
    const { error } = await sb.from('member_cycle_history').delete().eq('id', recordId);
    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    toast(ADMIN_I18N.recordRemoved.replace('{label}', label), 'info');
    (window as any).openCycleHistory(chMemberId, document.getElementById('ch-member-name')!.textContent || '');
  };

