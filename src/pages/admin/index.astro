---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
import AdminDashboardIsland from '../../components/admin/dashboard/AdminDashboardIsland';
import PlatformHealthWidget from '../../components/admin/PlatformHealthWidget';
import SyncHealthWidget from '../../components/admin/SyncHealthWidget';
import VolunteerComplianceWidget from '../../components/admin/VolunteerComplianceWidget';
import CrossTribeWidget from '../../components/admin/CrossTribeWidget';
import ResearchPipelineWidget from '../../components/admin/ResearchPipelineWidget';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.adminDash', 'comp.common'], lang);
---

<AdminLayout title="Dashboard" breadcrumbs={[{label:'Dashboard'}]}>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
    <AdminDashboardIsland client:load />
    <div class="mt-6">
      <CrossTribeWidget client:load lang={lang} />
    </div>
    <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-4">
      <ResearchPipelineWidget client:load lang={lang} />
      <div class="space-y-4">
        <PlatformHealthWidget client:load lang={lang} />
        <VolunteerComplianceWidget client:load lang={lang} />
      </div>
    </div>
    <div class="mt-4">
      <SyncHealthWidget client:load lang={lang} />
    </div>
  </div>
</AdminLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const check = () => {
      const member = window.navGetMember?.();
      if (!member) { setTimeout(check, 300); return; }
      const isAdmin = member.is_superadmin || ['manager', 'deputy_manager', 'tribe_leader', 'sponsor', 'chapter_liaison'].includes(member.operational_role) || (member.designations || []).some(function(d) { return d === 'deputy_manager' || d === 'curator' || d === 'chapter_board'; });
      if (!isAdmin) {
        document.querySelector('.max-w-\\[1100px\\]').innerHTML = '<div class="text-center py-20 text-[var(--text-muted)]">Acesso restrito a administradores.</div>';
      }
    };
    check();
  });
</script>
