  (window as any).saveEditMember = async () => {
    if (!ensureAdminAction()) return;
    const id = (document.getElementById('edit-m-id') as HTMLInputElement).value;
    const opRole = (document.getElementById('edit-m-oprole') as HTMLSelectElement).value;
    const desigs = Array.from(document.querySelectorAll('.desig-cb:checked')).map(cb => (cb as HTMLInputElement).value);
    const isSuperadmin = (document.getElementById('edit-m-superadmin') as HTMLInputElement).checked;
    const chapter = (document.getElementById('edit-m-chapter') as HTMLSelectElement).value;
    const active = (document.getElementById('edit-m-active') as HTMLSelectElement).value === 'true';

    const { data, error, mode } = await adminUpdateMemberCompat({
      memberId: id,
      opRole,
      desigs,
      chapter,
      active
    });

    if (error) {
      toast(ADMIN_I18N.saveErrorPrefix + error.message, 'error');
      return;
    }

    if (!data?.success) {
      toast(data?.error || ADMIN_I18N.saveError, 'error');
      return;
    }

    // Keep source-of-truth fields synchronized even when backend falls back to legacy contract.
    const { error: e2 } = await sb.from('members').update({
      operational_role: opRole,
      designations: desigs,
      is_superadmin: isSuperadmin
    }).eq('id', id);

    if (e2) {
      console.warn('3-axis direct update warning:', e2.message);
      // Non-fatal: role contract update succeeded.
    }

    if (mode === 'legacy') {
      console.warn('admin_update_member used legacy payload fallback');
    }

    (window as any).closeEditMember();
    toast(ADMIN_I18N.memberUpdated, 'success');
    loadMembersList();
    loadTribes();
  };

