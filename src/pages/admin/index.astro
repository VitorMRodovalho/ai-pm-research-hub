  async function loadAnnouncements() {
    if (!ensureAdminAction(false)) return;
    const { data } = await sb.from('announcements')
      .select('id, title, message, type, link_url, link_text, starts_at, ends_at, is_active, created_at')
      .order('created_at', { ascending: false })
      .limit(20);

    const el = document.getElementById('ann-list');
    if (!el) return;
    if (!data?.length) {
      el.innerHTML = `<p class="text-slate-400 text-[.72rem] text-center py-3">${escapeHtml(ADMIN_I18N.annEmpty)}</p>`;
      return;
    }

    const TYPE_ICONS: Record<string, string> = { info: 'ℹ️', warning: '⚠️', success: '✅', urgent: '🚨' };

    el.innerHTML = data.map((a: any) => {
      const now = new Date();
      const isExpired = a.ends_at && new Date(a.ends_at) < now;
      const isScheduled = a.starts_at && new Date(a.starts_at) > now;
      const statusBadge = !a.is_active
        ? `<span class="text-[.58rem] font-bold px-1.5 py-0.5 rounded-full bg-slate-100 text-slate-400">${escapeHtml(ADMIN_I18N.annStatusInactive)}</span>`
        : isExpired
          ? `<span class="text-[.58rem] font-bold px-1.5 py-0.5 rounded-full bg-red-50 text-crimson">${escapeHtml(ADMIN_I18N.annStatusExpired)}</span>`
          : isScheduled
            ? `<span class="text-[.58rem] font-bold px-1.5 py-0.5 rounded-full bg-amber-50 text-amber-700">${escapeHtml(ADMIN_I18N.annStatusScheduled)}</span>`
            : `<span class="text-[.58rem] font-bold px-1.5 py-0.5 rounded-full bg-emerald-50 text-emerald-700">${escapeHtml(ADMIN_I18N.annStatusActive)}</span>`;
      const date = new Date(a.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
      const toggleLabel = a.is_active ? ADMIN_I18N.annBtnDeactivate : ADMIN_I18N.annBtnActivate;
      return `
      <div class="flex items-center gap-2 py-2 border-b border-slate-100 last:border-b-0">
        <span class="flex-shrink-0">${TYPE_ICONS[a.type] || 'ℹ️'}</span>
        <div class="flex-1 min-w-0">
          <div class="text-[.78rem] font-semibold truncate">${escapeHtml(a.title || '')}</div>
          ${a.message ? `<div class="text-[.65rem] text-slate-400 truncate">${escapeHtml(a.message)}</div>` : ''}
        </div>
        ${statusBadge}
        <span class="text-[.6rem] text-slate-300 flex-shrink-0">${date}</span>
        <button type="button" class="btn-toggle-ann text-[.6rem] px-2 py-0.5 rounded border-0 cursor-pointer transition-all ${a.is_active ? 'bg-red-50 text-crimson hover:bg-red-100' : 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100'}"
          data-ann-id="${escapeAttr(String(a.id))}" data-ann-active="${!a.is_active}">${escapeHtml(toggleLabel)}</button>
        <button type="button" class="btn-delete-ann text-[.6rem] px-2 py-0.5 rounded bg-slate-50 text-slate-400 hover:bg-red-50 hover:text-crimson border-0 cursor-pointer transition-all"
          data-ann-id="${escapeAttr(String(a.id))}">🗑️</button>
      </div>`;
    }).join('');
  }

  (window as any).createAnnouncement = async () => {
    if (!ensureAdminAction()) return;
    const title = (document.getElementById('ann-title') as HTMLInputElement).value.trim();
    if (!title) { toast(ADMIN_I18N.fillTitle, 'error'); return; }
    const startsVal = (document.getElementById('ann-starts') as HTMLInputElement).value;
    const endsVal = (document.getElementById('ann-ends') as HTMLInputElement).value;
    if (startsVal && endsVal && new Date(startsVal) >= new Date(endsVal)) {
      toast(ADMIN_I18N.startBeforeEnd, 'error');
      return;
    }

    const { error } = await sb.from('announcements').insert({
      title,
      message: (document.getElementById('ann-message') as HTMLInputElement).value.trim() || null,
      type: (document.getElementById('ann-type') as HTMLSelectElement).value,
      link_url: (document.getElementById('ann-link-url') as HTMLInputElement).value.trim() || null,
      link_text: (document.getElementById('ann-link-text') as HTMLInputElement).value.trim() || null,
      starts_at: startsVal || null,
      ends_at: endsVal || null,
      created_by: MEMBER.id,
    });

    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    toast(ADMIN_I18N.annPublished, 'success');
    (document.getElementById('ann-title') as HTMLInputElement).value = '';
    (document.getElementById('ann-message') as HTMLTextAreaElement).value = '';
    (document.getElementById('ann-link-url') as HTMLInputElement).value = '';
    (document.getElementById('ann-link-text') as HTMLInputElement).value = '';
    (document.getElementById('ann-starts') as HTMLInputElement).value = '';
    (document.getElementById('ann-ends') as HTMLInputElement).value = '';
    const prev = document.getElementById('ann-message-preview');
    const btn = document.getElementById('ann-preview-toggle');
    if (prev && !prev.classList.contains('hidden')) {
      prev.classList.add('hidden');
      (document.getElementById('ann-message') as HTMLTextAreaElement).classList.remove('hidden');
      if (btn) btn.textContent = ADMIN_I18N.annPreviewToggle;
    }
    loadAnnouncements();
  };

  function simpleMarkdownPreview(text: string): string {
    if (!text) return '';
    return String(text)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\*([^*]+)\*/g, '<em>$1</em>')
      .replace(/`([^`]+)`/g, '<code class="bg-slate-200 px-0.5 rounded text-[.7em]">$1</code>')
      .replace(/\n/g, '<br>');
  }

  document.getElementById('ann-preview-toggle')?.addEventListener('click', () => {
    const ta = document.getElementById('ann-message') as HTMLTextAreaElement;
    const preview = document.getElementById('ann-message-preview');
    const btn = document.getElementById('ann-preview-toggle');
    if (!ta || !preview || !btn) return;
    if (preview.classList.contains('hidden')) {
      preview.innerHTML = simpleMarkdownPreview(ta.value);
      preview.classList.remove('hidden');
      ta.classList.add('hidden');
      btn.textContent = ADMIN_I18N.annEditToggle;
    } else {
      preview.classList.add('hidden');
      ta.classList.remove('hidden');
      btn.textContent = ADMIN_I18N.annPreviewToggle;
    }
  });

  if (!(window as any).__adminAnnBound) {
    (window as any).__adminAnnBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      const t = (e.target as HTMLElement).closest('.btn-toggle-ann');
      if (t) {
        (window as any).toggleAnnouncement(t.getAttribute('data-ann-id') || '', t.getAttribute('data-ann-active') === 'true');
        return;
      }
      const d = (e.target as HTMLElement).closest('.btn-delete-ann');
      if (d) {
        (window as any).deleteAnnouncement(d.getAttribute('data-ann-id') || '');
      }
    });
  }

