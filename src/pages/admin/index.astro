  document.getElementById('btn-cancel-notify')?.addEventListener('click', () => {
    const modal = document.getElementById('modal-notify-alloc')!;
    modal.classList.add('hidden'); modal.classList.remove('flex');
  });
  document.getElementById('btn-confirm-notify')?.addEventListener('click', () => notifySend());

  // ── ALLOCATE MODAL (Event Delegation: .btn-alloc, .cursorrules compliant) ──
  if (!(window as any).__adminAllocBound) {
    (window as any).__adminAllocBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as HTMLElement).closest('.btn-alloc');
      if (btn) {
        const id = btn.getAttribute('data-member-id') || '';
        const name = btn.getAttribute('data-member-name') || '';
        const email = btn.getAttribute('data-member-email') || '';
        const chapter = btn.getAttribute('data-member-chapter') || '';
        (window as any).openAllocate(id, name, email, chapter);
      }
    });
  }
  (window as any).openAllocate = (id: string, name: string, email: string, chapter: string) => {
    if (!ensureAdminAction()) return;
    (document.getElementById('alloc-member-id') as HTMLInputElement).value = id;
    document.getElementById('alloc-member-name')!.textContent = name;
    document.getElementById('alloc-member-info')!.textContent = email + ' - ' + chapter;
    (document.getElementById('alloc-tribe') as HTMLSelectElement).value = '';
    const modal = document.getElementById('modal-allocate')!;
    modal.classList.remove('hidden'); modal.classList.add('flex');
  };
  (window as any).closeAllocate = () => {
    const modal = document.getElementById('modal-allocate')!;
    modal.classList.add('hidden'); modal.classList.remove('flex');
  };
  (window as any).confirmAllocate = async () => {
    if (!ensureAdminAction()) return;
    const memberId = (document.getElementById('alloc-member-id') as HTMLInputElement).value?.trim();
    const tribeId = parseInt((document.getElementById('alloc-tribe') as HTMLSelectElement).value, 10);
    if (!memberId) { toast(ADMIN_I18N.allocateError, 'error'); return; }
    if (!tribeId || isNaN(tribeId)) { toast(ADMIN_I18N.selectTribe, 'error'); return; }
    const { data, error: rpcError } = await sb.rpc('admin_force_tribe_selection', { p_member_id: memberId, p_tribe_id: tribeId });
    if (rpcError) {
      toast(rpcError.message || ADMIN_I18N.allocateError, 'error');
      return;
    }
    if (data?.success) {
      (window as any).closeAllocate();
      toast(`${ADMIN_I18N.allocatedPrefix} ${String(tribeId).padStart(2, '0')}!`, 'success');
      loadTribes();
      loadExecutiveKpis();
    } else {
      toast(data?.error || ADMIN_I18N.allocateError, 'error');
    }
  };

  // ══════════════════════════════════════════
  // MEMBERS LIST (Enhanced with filters + tags)
