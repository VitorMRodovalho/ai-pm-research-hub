  function memberTags(m: any): string {
    const opRole = m.operational_role || 'guest';
    const desigs: string[] = m.designations?.length ? m.designations : [];
    let html = '';

    // Operational role tag
    if (opRole !== 'none' && opRole !== 'guest') {
      const c = OPROLE_COLORS[opRole] || '#94A3B8';
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded" style="background:${c}18;color:${c}">${OPROLE_LABELS[opRole] || opRole}</span>`;
    }

    // Designation tags
    desigs.forEach(d => {
      const c = DESIG_COLORS[d] || '#94A3B8';
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded" style="background:${c}18;color:${c}">${DESIG_LABELS[d] || d}</span>`;
    });

    // Superadmin badge
    if (m.is_superadmin) {
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded bg-orange/10 text-orange">🔧 SA</span>`;
    }

    // No role at all
    if (opRole === 'guest' && desigs.length === 0) {
      html += `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded bg-slate-100 text-slate-400">Convidado</span>`;
    }

    return html;
  }

  function memberTribeTag(m: any): string {
    const tid = m.selected_tribe_id || m.fixed_tribe_id || m.tribe_id;
    if (!tid) return '<span class="text-[.6rem] text-slate-300">sem tribo</span>';
    const color = TRIBE_COLORS[tid] || '#94A3B8';
    return `<span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded" style="background:${color}18;color:${color}">T${String(tid).padStart(2,'0')}</span>`;
  }

  let allCycleHistory: any[] = [];
  let memberListCache: any[] = [];

  function cycleDots(memberId: string): string {
    const memberCycles = allCycleHistory.filter((h: any) => h.member_id === memberId);
    return cycleOrder.map((code: string) => {
      const record = memberCycles.find((h: any) => h.cycle_code === code);
      const meta = getCycleDisplayMeta(code);
      if (!record) return `<span class="w-[18px] h-[14px] rounded text-[.5rem] font-bold inline-flex items-center justify-center bg-slate-100 text-slate-300" title="${meta.label}: não participou">${meta.abbr}</span>`;
      const opLabel = OPROLE_LABELS[record.operational_role] || record.operational_role || '';
      const desigLabels = (record.designations || []).map((d: string) => DESIG_LABELS[d] || d).join(', ');
      const tooltip = `${meta.label}: ${opLabel}${desigLabels ? ' + ' + desigLabels : ''}${record.tribe_name ? ' · ' + record.tribe_name : ''}`;
      return `<span class="w-[18px] h-[14px] rounded text-[.5rem] font-bold inline-flex items-center justify-center text-white" style="background:${meta.color}" title="${tooltip}">${meta.abbr}</span>`;
    }).join('');
  }

  async function loadMembersList() {
    if (!ensureAdminAction(false)) return;
    const [membersRes, historyRes] = await Promise.all([
      sb.rpc('admin_list_members', { p_limit: 200, p_offset: 0 }),
      sb.from('member_cycle_history').select('member_id, cycle_code, operational_role, designations, tribe_name, chapter, is_active')
    ]);
    const members = Array.isArray(membersRes.data) ? membersRes.data : [];
    allCycleHistory = historyRes.data || [];
    memberListCache = members;

    const inactive = members.filter((m: any) => !m.current_cycle_active);
    const noAuth = members.filter((m: any) => !m.auth_id);
    document.getElementById('stat-inactive')!.textContent = String(inactive.length);
    document.getElementById('stat-noauth')!.textContent = String(noAuth.length);

    const isSA = MEMBER?.is_superadmin === true;

    const area = document.getElementById('members-area')!;
    area.innerHTML = `
    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
      <div id="members-rows">
      ${members.map((m: any) => {
        const opRole = getMemberRole(m);
        const desigs: string[] = m.designations?.length ? m.designations : [];
        const tid = m.selected_tribe_id || m.fixed_tribe_id || m.tribe_id || '';
        const isActive = m.current_cycle_active;
        const hasAuth = !!m.auth_id;
        const status = isActive
