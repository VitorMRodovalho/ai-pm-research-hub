    // ── Load tribe members ──
    const { data: selections } = await sb.from('tribe_selections')
      .select('member_id')
      .eq('tribe_id', tribeId);

    const memberIds = (selections || []).map((s: any) => s.member_id);
    if (!memberIds.includes(MEMBER.id)) memberIds.push(MEMBER.id);

    const { data: members } = await sb.from('members')
      .select('id, name, email, chapter, photo_url, operational_role, designations, current_cycle_active')
      .in('id', memberIds)
      .order('name');

    const el = document.getElementById('my-tribe-members')!;
    if (!members?.length) {
      el.innerHTML = '<p class="text-slate-400 text-sm text-center py-6">Nenhum membro na tribo ainda.</p>';
      return;
    }

    el.innerHTML = `
      <div class="text-[.72rem] text-slate-400 mb-3">${members.length} membros na tribo</div>
      ${members.map((m: any) => {
        const isLeader = m.operational_role === 'tribe_leader';
        const nm = safeName(m);
        const ini = initials(m?.name);
        const photo = m.photo_url
          ? `<img src="${m.photo_url}" class="w-10 h-10 rounded-full object-cover flex-shrink-0" alt="">`
          : `<div class="w-10 h-10 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.7rem] flex-shrink-0">${ini}</div>`;
        return `
        <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
          ${photo}
          <div class="flex-1 min-w-0">
            <div class="text-[.82rem] font-semibold text-navy">${escapeHtml(nm)} ${isLeader ? '👑' : ''}</div>
            <div class="text-[.68rem] text-slate-400">${m.email} · ${m.chapter || ''}</div>
          </div>
          <span class="text-[.65rem] font-bold px-2 py-0.5 rounded-full ${m.current_cycle_active ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-crimson'}">
            ${m.current_cycle_active ? 'Ativo' : 'Inativo'}
          </span>
        </div>`;
      }).join('')}`;

    // ── Load recent attendance ──
    const { data: events } = await sb.from('events')
      .select('id, title, date, duration_minutes')
      .order('date', { ascending: false })
      .limit(5);

    const attEl = document.getElementById('my-tribe-attendance')!;
    if (!events?.length) {
      attEl.innerHTML = '<p class="text-slate-400 text-sm text-center py-6">Nenhum evento recente.</p>';
      return;
    }

    const eventIds = events.map((e: any) => e.id);
    const { data: attendance } = await sb.from('attendance')
      .select('event_id, member_id, status')
      .in('event_id', eventIds)
      .in('member_id', memberIds);

    const attMap: Record<string, Record<string, string>> = {};
    (attendance || []).forEach((a: any) => {
      if (!attMap[a.event_id]) attMap[a.event_id] = {};
      attMap[a.event_id][a.member_id] = a.status;
    });

    attEl.innerHTML = events.map((ev: any) => {
      const date = new Date(ev.date).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
      const evAtt = attMap[ev.id] || {};
      const present = Object.values(evAtt).filter(s => s === 'present').length;
      const total = members.length;
      return `
      <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
        <div class="text-[.72rem] font-bold text-slate-400 w-14 flex-shrink-0">${date}</div>
        <div class="flex-1 min-w-0 text-[.82rem] truncate">${ev.title}</div>
        <div class="text-[.72rem] font-bold ${present === total ? 'text-emerald-600' : present > 0 ? 'text-amber-600' : 'text-slate-400'}">
          ${present}/${total}
        </div>
      </div>`;
    }).join('');
  }

  (window as any).addSlot = async (tribeId: number) => {
    if (!ensureLeaderAction()) return;
    const day = parseInt((document.getElementById('slot-day') as HTMLSelectElement).value);
    const start = (document.getElementById('slot-start') as HTMLInputElement).value;
    const end = (document.getElementById('slot-end') as HTMLInputElement).value;
    if (!start || !end) { toast(ADMIN_I18N.fillStartEnd, 'error'); return; }
    if (start >= end) { toast(ADMIN_I18N.startBeforeEnd, 'error'); return; }

    const { error } = await sb.from('tribe_meeting_slots').insert({
      tribe_id: tribeId, day_of_week: day, time_start: start, time_end: end
    });
    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    toast(ADMIN_I18N.slotAdded, 'success');
    loadMyTribe(); // Refresh the whole panel
  };

  (window as any).deleteSlot = async (slotId: string, tribeId: number) => {
    if (!ensureLeaderAction()) return;
    const { error } = await sb.from('tribe_meeting_slots').delete().eq('id', slotId);
    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    toast(ADMIN_I18N.slotRemoved, 'info');
    loadMyTribe();
  };

  (window as any).saveTribeSettings = async (tribeId: number) => {
    if (!ensureLeaderAction()) return;
    const waVal = (document.getElementById('tribe-wa') as HTMLInputElement).value.trim();
    if (waVal && !waVal.startsWith('https://chat.whatsapp.com/')) {
      toast(ADMIN_I18N.invalidWhatsAppUrl, 'error');
      return;
    }
    const { error } = await sb.from('tribes').update({
      meeting_link: (document.getElementById('tribe-meeting-link') as HTMLInputElement).value.trim() || null,
      whatsapp_url: waVal || null,
      drive_url: (document.getElementById('tribe-drive') as HTMLInputElement).value.trim() || null,
      miro_url: (document.getElementById('tribe-miro') as HTMLInputElement).value.trim() || null,
      notes: (document.getElementById('tribe-notes') as HTMLInputElement).value.trim() || null,
      updated_at: new Date().toISOString(),
      updated_by: MEMBER.id,
    }).eq('id', tribeId);

    if (error) { toast(ADMIN_I18N.errorPrefix + error.message, 'error'); return; }
    const ok = document.getElementById('tribe-save-ok');
    if (ok) { ok.classList.remove('hidden'); setTimeout(() => ok.classList.add('hidden'), 2000); }
    toast(ADMIN_I18N.settingsSaved, 'success');
  };

  // ══════════════════════════════════════════
  // SPONSOR TIER: Executive Overview (S-PA2-UI-BIND)
  // Uses exec_funnel_summary, exec_cert_timeline, exec_skills_radar RPCs
  // ══════════════════════════════════════════
  const EXEC_LOADING = () => `<p class="text-slate-400 text-sm text-center py-4">${escapeHtml(ADMIN_I18N.loading)}</p>`;
  const EXEC_ERROR = (msg: string) => `<p class="text-crimson text-sm text-center py-4">${escapeHtml(msg)}</p>`;

  async function loadExecutiveOverview() {
    // ── 1. Funnel (exec_funnel_summary RPC) ──
    const funnelEl = document.getElementById('exec-funnel')!;
    funnelEl.innerHTML = EXEC_LOADING();
    try {
      const { data: funnelData, error: funnelErr } = await sb.rpc('exec_funnel_summary');
      if (funnelErr) throw funnelErr;
      const f = Array.isArray(funnelData) && funnelData[0] ? funnelData[0] : null;
      if (!f) {
        funnelEl.innerHTML = EXEC_ERROR(ADMIN_I18N.execFunnelNoData);
      } else {
        const total = f.total_members || 0;
        const maxStage = Math.max(f.active_members || 0, 1);
        const stagePct = (n: number) => Math.round((n / maxStage) * 100);
        funnelEl.innerHTML = `
          <div class="space-y-2 text-[.78rem]">
            <div class="flex justify-between items-center py-1.5 border-b border-slate-100">
              <span class="font-semibold text-slate-600">Total membros</span>
              <span class="font-bold text-navy">${f.total_members ?? 0}</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-b border-slate-100">
              <span class="font-semibold text-slate-600">Ativos</span>
              <span class="font-bold text-teal">${f.active_members ?? 0}</span>
            </div>
            <div class="flex items-center gap-2 py-1.5">
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-teal rounded-full" style="width:${stagePct(f.members_with_credly_url || 0)}%"></div>
              </div>
              <span class="text-[.7rem] font-semibold">Credly: ${f.members_with_credly_url ?? 0}</span>
            </div>
            <div class="flex items-center gap-2 py-1.5">
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-purple rounded-full" style="width:${stagePct(f.members_with_full_core_trail || 0)}%"></div>
              </div>
              <span class="text-[.7rem] font-semibold">Trilha completa: ${f.members_with_full_core_trail ?? 0}</span>
            </div>
            <div class="flex items-center gap-2 py-1.5">
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-amber-500 rounded-full" style="width:${stagePct(f.members_with_tier1 || 0)}%"></div>
              </div>
              <span class="text-[.7rem] font-semibold">Tier 1: ${f.members_with_tier1 ?? 0}</span>
            </div>
            <div class="flex items-center gap-2 py-1.5">
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-emerald-600 rounded-full" style="width:${stagePct(f.members_with_tier2_plus || 0)}%"></div>
              </div>
              <span class="text-[.7rem] font-semibold">Tier 2+: ${f.members_with_tier2_plus ?? 0}</span>
            </div>
            <div class="flex justify-between items-center py-1.5 border-t border-slate-200 mt-2">
              <span class="font-semibold text-slate-600">Artefatos publicados</span>
              <span class="font-bold text-emerald-600">${f.total_published_artifacts ?? 0}</span>
            </div>
          </div>`;
      }
    } catch (e: any) {
      funnelEl.innerHTML = EXEC_ERROR(e?.message || ADMIN_I18N.execFunnelError);
    }

    // ── 2. Cert Timeline (exec_cert_timeline RPC) ──
    const certEl = document.getElementById('exec-cert-timeline')!;
    certEl.innerHTML = EXEC_LOADING();
    try {
      const { data: timelineData, error: timelineErr } = await sb.rpc('exec_cert_timeline', { p_months: 12 });
      if (timelineErr) throw timelineErr;
      const rows = Array.isArray(timelineData) ? timelineData : [];
      if (!rows.length) {
        certEl.innerHTML = `<p class="text-slate-400 text-[.78rem] text-center py-4">${escapeHtml(ADMIN_I18N.execNoCohortData)}</p>`;
      } else {
        const maxT1 = Math.max(...rows.map((r: any) => r.members_with_tier1 || 0), 1);
        certEl.innerHTML = rows.slice(0, 8).map((r: any) => {
          const pct = Math.round(((r.members_with_tier1 || 0) / maxT1) * 100);
          return `
          <div class="flex items-center gap-2 py-1.5 border-b border-slate-100 last:border-b-0">
            <span class="text-[.72rem] font-bold text-slate-500 w-20">${r.cohort_month || '—'}</span>
            <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-amber-500 rounded-full" style="width:${pct}%"></div>
            </div>
            <span class="text-[.68rem] font-semibold w-12 text-right">${r.members_with_tier1 ?? 0}/${r.members_in_cohort ?? 0}</span>
          </div>`;
        }).join('');
      }
    } catch (e: any) {
      certEl.innerHTML = EXEC_ERROR(e?.message || ADMIN_I18N.execCertError);
    }

    // ── 3. Skills Radar (exec_skills_radar RPC) ──
    const radarEl = document.getElementById('exec-skills-radar')!;
    radarEl.innerHTML = EXEC_LOADING();
    try {
      const { data: radarData, error: radarErr } = await sb.rpc('exec_skills_radar');
      if (radarErr) throw radarErr;
      const radarRows = Array.isArray(radarData) ? radarData : [];
      if (!radarRows.length) {
        radarEl.innerHTML = `<p class="text-slate-400 text-[.78rem] text-center py-4">${escapeHtml(ADMIN_I18N.execNoRadarData)}</p>`;
      } else {
        const maxPts = Math.max(...radarRows.map((r: any) => r.total_points || 0), 1);
        radarEl.innerHTML = radarRows.map((r: any) => {
          const pct = Math.round(((r.total_points || 0) / maxPts) * 100);
          const axis = (r.radar_axis || '—').replace(/_/g, ' ');
          return `
          <div class="flex items-center gap-2 py-1.5 border-b border-slate-100 last:border-b-0">
            <span class="text-[.72rem] font-semibold text-slate-600 flex-1 truncate">${escapeHtml(axis)}</span>
            <div class="flex-1 max-w-[100px] h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-navy rounded-full" style="width:${pct}%"></div>
            </div>
            <span class="text-[.68rem] font-bold text-navy w-14 text-right">${r.total_points ?? 0} pts</span>
          </div>`;
        }).join('');
      }
    } catch (e: any) {
      radarEl.innerHTML = EXEC_ERROR(e?.message || ADMIN_I18N.execRadarError);
    }

    // ── 4. Chapters (manual — lightweight) ──
    const { data: members } = await sb.from('members')
      .select('chapter, current_cycle_active, operational_role')
      .neq('operational_role', 'guest');

    const active = (members || []).filter((m: any) => m.current_cycle_active);
    const byChapter: Record<string, { total: number; active: number }> = {};
    (members || []).forEach((m: any) => {
      const ch = m.chapter || 'Outros';
      if (!byChapter[ch]) byChapter[ch] = { total: 0, active: 0 };
      byChapter[ch].total++;
      if (m.current_cycle_active) byChapter[ch].active++;
    });

    const CHAPTER_COLORS: Record<string, string> = {
      'PMI-GO': '#FF610F', 'PMI-CE': '#4F17A8', 'PMI-DF': '#00799E',
      'PMI-MG': '#10B981', 'PMI-RS': '#D97706'
    };

    document.getElementById('exec-chapters')!.innerHTML =
      Object.entries(byChapter).sort((a, b) => b[1].active - a[1].active).map(([ch, s]) => {
        const color = CHAPTER_COLORS[ch] || '#94A3B8';
        const maxActive = Math.max(...Object.values(byChapter).map(v => v.active), 1);
        const pct = Math.round((s.active / maxActive) * 100);
        return `
        <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-b-0">
          <div class="text-[.82rem] font-bold w-16 flex-shrink-0" style="color:${color}">${escapeHtml(ch)}</div>
          <div class="flex-1">
            <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full rounded-full" style="width:${pct}%;background:${color}"></div>
            </div>
          </div>
          <div class="text-[.78rem] font-bold text-navy flex-shrink-0">${s.active}</div>
          <div class="text-[.65rem] text-slate-400 flex-shrink-0">${ADMIN_I18N.execLabelActive}</div>
        </div>`;
      }).join('');

    // ── 5. Progress (manual — complements funnel) ──
    const totalActive = active.length;
    const researchers = active.filter((m: any) => m.operational_role === 'researcher').length;
    const leaders = active.filter((m: any) => m.operational_role === 'tribe_leader').length;
    const managers = active.filter((m: any) => m.operational_role === 'manager').length;

    const { data: courseProgress } = await sb.from('course_progress').select('status');
    const completed = (courseProgress || []).filter((c: any) => c.status === 'completed').length;
    const totalCourseSlots = totalActive * 8;
    const trailPct = totalCourseSlots > 0 ? Math.round((completed / totalCourseSlots) * 100) : 0;

    const { data: artifacts } = await sb.from('artifacts').select('status');
    const published = (artifacts || []).filter((a: any) => a.status === 'published').length;
    const inReview = (artifacts || []).filter((a: any) => a.status === 'review').length;

    document.getElementById('exec-progress')!.innerHTML = `
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-navy">${totalActive}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Ativos</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-purple">${leaders + managers}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">${ADMIN_I18N.execLabelLeadership}</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-teal">${trailPct}%</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Trilha IA</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-emerald-600">${published}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">Publicados</div>
        </div>
      </div>
      <div class="mt-3 text-[.7rem] text-slate-400">
        ${researchers} ${ADMIN_I18N.execLabelResearchers} · ${inReview} ${ADMIN_I18N.execLabelArtifactsInReview} · ${completed} ${ADMIN_I18N.execLabelCoursesCompleted}
      </div>`;

    // ── 6. Tribes ──
    const { data: tribeData } = await sb.from('tribe_selections').select('tribe_id');
    const tribeCounts: Record<number, number> = {};
    (tribeData || []).forEach((t: any) => { tribeCounts[t.tribe_id] = (tribeCounts[t.tribe_id] || 0) + 1; });

    document.getElementById('exec-tribes')!.innerHTML = `
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        ${[1,2,3,4,5,6,7,8].map(tid => {
          const count = tribeCounts[tid] || 0;
          const color = TRIBE_COLORS[tid] || '#94A3B8';
          return `
          <div class="rounded-xl p-3 text-center border border-slate-100">
            <div class="text-[.65rem] font-bold uppercase tracking-wider mb-1" style="color:${color}">T${String(tid).padStart(2,'0')}</div>
            <div class="text-lg font-black text-navy">${count}/6</div>
            <div class="text-[.6rem] text-slate-400">${(TRIBE_NAMES[tid] || '').split(' ').slice(0,2).join(' ')}</div>
          </div>`;
        }).join('')}
      </div>`;
  }

  // ══════════════════════════════════════════
  // BOOT (Tier-aware)
  // ══════════════════════════════════════════
  let TIER = 'visitor';

  function setup() {
    document.getElementById('admin-loading')?.classList.add('hidden');
    TIER = resolveTierFromMember(MEMBER);

    if (!canAccessAdminRoute(MEMBER, 'admin_panel')) {
      document.getElementById('not-admin-msg')?.classList.remove('hidden');
      return;
    }

    document.getElementById('admin-panel')?.classList.remove('hidden');

    // Configure UI based on tier
    if (TIER === 'superadmin' || TIER === 'admin') {
      // Full access: tribes tab + members tab + filters
      loadTribes();

    } else if (TIER === 'leader') {
      // Show tier header
      const header = document.getElementById('tier-header')!;
      header.classList.remove('hidden');
      document.getElementById('tier-icon')!.textContent = '🏷️';
      document.getElementById('tier-title')!.textContent = ADMIN_I18N.tierLeaderTitlePrefix + (TRIBE_NAMES[MEMBER.tribe_id] || ADMIN_I18N.tierMyTribe);
      document.getElementById('tier-subtitle')!.textContent = ADMIN_I18N.tierLeaderSubtitle;

      // Hide superadmin tabs, show my-tribe
      document.querySelectorAll('.adm-tab').forEach(t => (t as HTMLElement).style.display = 'none');
      document.getElementById('panel-tribes')?.classList.add('hidden');
      document.getElementById('panel-members')?.classList.add('hidden');
      document.getElementById('panel-reports')?.classList.add('hidden');
      document.getElementById('panel-knowledge')?.classList.add('hidden');

      // Hide KPI bar (superadmin-only stats)
      document.querySelectorAll('#admin-panel > .grid.grid-cols-2')[0]?.classList.add('hidden');

      document.getElementById('panel-my-tribe')?.classList.remove('hidden');
      loadMyTribe();

    } else if (TIER === 'observer') {
      // Show tier header
      const header = document.getElementById('tier-header')!;
      header.classList.remove('hidden');
      header.style.borderColor = '#BE202730';
      header.style.background = '#BE202708';
      document.getElementById('tier-icon')!.textContent = '📊';
      document.getElementById('tier-title')!.textContent = ADMIN_I18N.tierExecTitle;
      document.getElementById('tier-subtitle')!.textContent = ADMIN_I18N.tierExecSubtitle;

      // Hide superadmin tabs, show executive
      document.querySelectorAll('.adm-tab').forEach(t => (t as HTMLElement).style.display = 'none');
      document.getElementById('panel-tribes')?.classList.add('hidden');
      document.getElementById('panel-members')?.classList.add('hidden');
      document.getElementById('panel-reports')?.classList.add('hidden');
      document.getElementById('panel-knowledge')?.classList.add('hidden');

      document.getElementById('panel-executive')?.classList.remove('hidden');
      if (canAccessAdminRoute(MEMBER, 'admin_analytics')) {
        document.getElementById('exec-analytics-link-card')?.classList.remove('hidden');
      }
      loadExecutiveOverview();
      loadAdminLinks();
      initLifecycleControls();
    }
  }


  async function loadAdminLinks() {
    const section = document.getElementById('admin-links-section');
    const list = document.getElementById('admin-links-list');
    if (!section || !list || !sb) return;

    const m = (window as any).navGetMember?.() || MEMBER;
    if (!m) return;
    const isAdmin = canManageTribeLifecycle(m);
    if (!isAdmin) return;

    section.classList.remove('hidden');

    try {
      const { data, error } = await sb.rpc('list_admin_links');
      if (error || !data?.length) return;

      const ICONS: Record<string, string> = {
        'folder-lock': '\u{1F512}',
        'folder': '\u{1F4C1}',
        'file-text': '\u{1F4C4}',
        'shield': '\u{1F6E1}',
      };
      const CATS: Record<string, string> = {
        governance: 'Governan\u00e7a', finance: 'Financeiro', legal: 'Jur\u00eddico',
        operations: 'Operacional', templates: 'Templates', other: 'Outros',
      };

      list.innerHTML = data.map(function(link: any) {
        var icon = ICONS[link.icon] || '\u{1F517}';
        var cat = CATS[link.category] || link.category;
        return '<a href="' + link.url + '" target="_blank" rel="noopener noreferrer" '
          + 'class="flex items-center gap-3 px-4 py-3 rounded-lg bg-slate-50 hover:bg-slate-100 no-underline transition-colors">'
          + '<span class="text-xl">' + icon + '</span>'
          + '<div class="flex-1 min-w-0">'
          + '<div class="text-sm font-semibold text-navy truncate">' + (link.title || '') + '</div>'
          + '<div class="text-[.68rem] text-slate-500 truncate">' + (link.description || '') + '</div>'
          + '</div>'
          + '<span class="px-2 py-0.5 rounded-full text-[.65rem] font-semibold bg-purple-100 text-purple-800 whitespace-nowrap">' + cat + '</span>'
          + '</a>';
      }).join('');
    } catch (e) {
      console.warn('Admin links load error:', e);
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // Lifecycle Management (Project management + superadmin)
  // ═══════════════════════════════════════════════════════════════

  async function initLifecycleControls() {
    const section = document.getElementById('lifecycle-section');
    if (!section || !sb) return;

    const m = (window as any).navGetMember?.() || MEMBER;
    if (!m || !canManageTribeLifecycle(m)) return;

    section.classList.remove('hidden');

    const { data: members } = await sb.from('public_members')
      .select('id, name, tribe_id, operational_role, current_cycle_active, is_active')
      .eq('current_cycle_active', true)
      .eq('is_active', true)
      .order('name');

    const activeMembers = members || [];
    const allTribes = await loadTribeCatalog(true);

    function populateSelect(id: string, items: {value: string; label: string}[], placeholder: string) {
      const el = document.getElementById(id) as HTMLSelectElement;
      if (!el) return;
      el.innerHTML = '<option value="">' + placeholder + '</option>'
        + items.map(i => '<option value="' + i.value + '">' + i.label + '</option>').join('');
    }

    const memberOpts = activeMembers.map((m: any) => ({
      value: m.id,
      label: m.name + (m.operational_role ? ' (' + m.operational_role + ')' : '')
    }));
    const tribeOpts = allTribes
      .filter((tribe: any) => m.is_superadmin === true || tribe.is_active !== false)
      .map((tribe: any) => ({
        value: String(tribe.id),
        label: buildTribeLabel(tribe) + (tribe.is_active === false ? ' (inativa)' : ''),
      }));

    populateSelect('lc-move-member', memberOpts, 'Selecione o membro...');
    populateSelect('lc-move-tribe', tribeOpts, 'Selecione a tribo destino...');
    populateSelect('lc-leader-tribe', tribeOpts, 'Selecione a tribo...');
    populateSelect('lc-deact-member', memberOpts, 'Selecione o membro...');
    populateSelect('lc-deact-tribe', tribeOpts, 'Selecione a tribo...');

    const leaderTribeSel = document.getElementById('lc-leader-tribe') as HTMLSelectElement;
    if (leaderTribeSel && !leaderTribeSel.dataset.bound) {
      leaderTribeSel.dataset.bound = '1';
      leaderTribeSel.addEventListener('change', function() {
        const tid = Number(this.value);
        const tribeMembers = activeMembers
          .filter((m: any) => m.tribe_id === tid)
          .map((m: any) => ({
            value: m.id,
            label: m.name + (m.operational_role === 'tribe_leader' ? ' (lider atual)' : '')
          }));
        populateSelect('lc-leader-member', tribeMembers, 'Selecione o novo lider...');
      });
    }

    async function callRpc(fnName: string, params: Record<string, any>, btn: HTMLButtonElement) {
      const origText = btn.textContent || '';
      btn.disabled = true;
      btn.textContent = 'Processando...';
      try {
        const { data, error } = await sb.rpc(fnName, params);
        if (error) throw new Error(error.message);
        alert('Sucesso! ' + JSON.stringify(data, null, 2));
        if (data?.draft_email_subject) {
          showDraftEmail(data.draft_email_subject, data.draft_email_body);
        }
        initLifecycleControls();
      } catch (e: any) {
        alert('Erro: ' + (e.message || e));
      } finally {
        btn.disabled = false;
        btn.textContent = origText;
      }
    }

    function showDraftEmail(subject: string, body: string) {
      const resultEl = document.getElementById('onboarding-result');
      if (!resultEl) return;
      resultEl.classList.remove('hidden');
      resultEl.innerHTML = '<div class="mb-2"><strong>Rascunho de e-mail gerado:</strong></div>'
        + '<div class="bg-white p-3 rounded border border-slate-200 mb-2">'
        + '<div class="text-xs text-slate-500 mb-1">Assunto:</div>'
        + '<div class="text-sm font-semibold">' + subject + '</div></div>'
        + '<div class="bg-white p-3 rounded border border-slate-200">'
        + '<div class="text-xs text-slate-500 mb-1">Corpo:</div>'
        + '<pre class="text-sm whitespace-pre-wrap">' + body + '</pre></div>';
    }

    const bindLifecycleButton = (id: string, handler: (btn: HTMLButtonElement) => void) => {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (!btn || btn.dataset.bound) return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => handler(btn));
    };

    bindLifecycleButton('btn-move-member', (btn) => {
      const mid = (document.getElementById('lc-move-member') as HTMLSelectElement).value;
      const tid = Number((document.getElementById('lc-move-tribe') as HTMLSelectElement).value);
      const reason = (document.getElementById('lc-move-reason') as HTMLInputElement).value.trim();
      if (!mid || !tid) { alert('Selecione membro e tribo.'); return; }
      if (!confirm('Transferir este membro para a tribo selecionada?')) return;
      callRpc('admin_move_member_tribe', { p_member_id: mid, p_new_tribe_id: tid, p_reason: reason || 'Administrative transfer' }, btn);
    });

    bindLifecycleButton('btn-change-leader', (btn) => {
      const tid = Number((document.getElementById('lc-leader-tribe') as HTMLSelectElement).value);
      const mid = (document.getElementById('lc-leader-member') as HTMLSelectElement).value;
      const reason = (document.getElementById('lc-leader-reason') as HTMLInputElement).value.trim();
      if (!tid || !mid) { alert('Selecione tribo e novo lider.'); return; }
      if (!confirm('Substituir o lider desta tribo? O lider atual sera rebaixado.')) return;
      callRpc('admin_change_tribe_leader', { p_tribe_id: tid, p_new_leader_id: mid, p_reason: reason || 'Leadership transition' }, btn);
    });

    bindLifecycleButton('btn-deact-member', (btn) => {
      const mid = (document.getElementById('lc-deact-member') as HTMLSelectElement).value;
      const reason = (document.getElementById('lc-deact-reason') as HTMLInputElement).value.trim();
      if (!mid) { alert('Selecione o membro.'); return; }
      if (!confirm('ATENCAO: Esta acao ira desligar o pesquisador do ciclo ativo. Confirma?')) return;
      callRpc('admin_deactivate_member', { p_member_id: mid, p_reason: reason || 'Administrative deactivation' }, btn);
    });

    bindLifecycleButton('btn-deact-tribe', (btn) => {
      const tid = Number((document.getElementById('lc-deact-tribe') as HTMLSelectElement).value);
      const reason = (document.getElementById('lc-deact-tribe-reason') as HTMLInputElement).value.trim();
      if (!tid) { alert('Selecione a tribo.'); return; }
      if (!confirm('ATENCAO: Todos os membros desta tribo serao inativados. Esta acao e irreversivel. Confirma?')) return;
      callRpc('admin_deactivate_tribe', { p_tribe_id: tid, p_reason: reason || 'Tribe deactivated' }, btn);
    });

    // Onboarding broadcast buttons
    async function sendOnboarding(dryRun: boolean) {
      const btn = document.getElementById(dryRun ? 'btn-onboarding-dry' : 'btn-onboarding-send') as HTMLButtonElement;
      const resultEl = document.getElementById('onboarding-result');
      if (!btn) return;

      const origText = btn.textContent || '';
      btn.disabled = true;
      btn.textContent = dryRun ? 'Simulando...' : 'Enviando...';

      try {
        const session = (await sb.auth.getSession()).data.session;
        if (!session) throw new Error('Not authenticated');

        const resp = await fetch(
          sb.supabaseUrl + '/functions/v1/send-global-onboarding',
          {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer ' + session.access_token,
              'apikey': sb.supabaseKey,
            },
            body: JSON.stringify({ dry_run: dryRun }),
          }
        );

        const data = await resp.json();

        if (resultEl) {
          resultEl.classList.remove('hidden');
          if (data.success) {
            resultEl.innerHTML = '<div class="text-teal font-semibold mb-2">'
              + (dryRun ? 'Simulacao concluida' : 'Envio realizado!') + '</div>'
              + '<div class="text-xs">Tribos processadas: ' + data.tribes_processed + '</div>'
              + '<div class="text-xs mb-2">Total de destinatarios: ' + data.total_recipients + '</div>'
              + '<div class="space-y-1">' + (data.details || []).map(function(d: any) {
                return '<div class="flex items-center gap-2 text-xs">'
                  + '<span class="w-2 h-2 rounded-full ' + (d.status === 'sent' ? 'bg-teal' : d.status === 'failed' ? 'bg-red-500' : 'bg-blue-400') + '"></span>'
                  + '<span class="font-medium">' + d.tribe + '</span>'
                  + '<span class="text-slate-400">' + d.recipients + ' destinatarios</span>'
                  + (d.emails_sample ? '<span class="text-slate-400 truncate">' + d.emails_sample.join(', ') + '</span>' : '')
                  + '</div>';
              }).join('') + '</div>';
          } else {
            resultEl.innerHTML = '<div class="text-red-600 font-semibold">Erro: ' + (data.error || 'Unknown') + '</div>'
              + (data.detail ? '<div class="text-xs text-slate-500">' + data.detail + '</div>' : '');
          }
        }
      } catch (e: any) {
        alert('Erro: ' + (e.message || e));
      } finally {
        btn.disabled = false;
        btn.textContent = origText;
      }
    }

    document.getElementById('btn-onboarding-dry')?.addEventListener('click', function() { sendOnboarding(true); });
    document.getElementById('btn-onboarding-send')?.addEventListener('click', function() {
      if (!confirm('Enviar e-mail de boas-vindas para TODOS os membros ativos? Esta acao disparara e-mails reais.')) return;
      sendOnboarding(false);
    });
  }

  
  // ══════════════════════════════════════════
  // EXECUTIVE KPI OVERVIEW (get_executive_kpis RPC)
  // ══════════════════════════════════════════
  async function loadExecutiveKpis() {
    const panel = document.getElementById('exec-kpi-overview');
    if (!panel) return;
    try {
      const { data, error } = await sb.rpc('get_executive_kpis');
      if (error) throw error;
      const kpi = typeof data === 'string' ? JSON.parse(data) : data;
      if (!kpi) return;

      panel.classList.remove('hidden');
      document.getElementById('ekpi-active').textContent = String(kpi.total_active || 0);
      document.getElementById('ekpi-chapters').textContent = String(kpi.chapters || 0);
      document.getElementById('ekpi-retention').textContent = (kpi.retention_pct || 0) + '%';
      document.getElementById('ekpi-multi').textContent = String(kpi.multi_cycle || 0);
      document.getElementById('ekpi-verified').textContent = String(kpi.pmi_verified || 0);
      const verPct = kpi.total_active > 0 ? Math.round((kpi.pmi_verified / kpi.total_active) * 100) : 0;
      document.getElementById('ekpi-verified-pct').textContent = String(verPct);
      document.getElementById('ekpi-artifacts').textContent = String(kpi.published_artifacts || 0);
      document.getElementById('ekpi-tribes').textContent = String(kpi.active_tribes || 0);
      document.getElementById('ekpi-avg').textContent = String(kpi.avg_per_tribe || 0);
    } catch (e) {
      console.warn('Executive KPIs load error:', e);
    }
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    try {
      const cyclesData = await loadCycles(sb);
      cycleDatesMap = getCycleDates(cyclesData);
      cycleMeta = getCycleMeta(cyclesData);
      cycleOrder = getCycleOrder(cyclesData);
      currentCycleStart = getCurrentCycle(cyclesData)?.cycle_start || getFallbackCycleStart();
    } catch (_) { console.warn('Admin boot cycle check:', _); }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest' && !MEMBER) {
        MEMBER = e.detail;
        setup();
      }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') { MEMBER = m; setup(); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        if (data && getMemberRole(data) !== 'guest') { MEMBER = data; setup(); return; }
      }
    } catch (e) { console.warn('Admin boot session check:', e); }

    setTimeout(() => {
      if (MEMBER) return;
      document.getElementById('admin-loading')?.classList.add('hidden');
      document.getElementById('not-admin-msg')?.classList.remove('hidden');
    }, 2000);
  }

  boot();
</script>
