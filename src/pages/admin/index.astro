    const payload = {
      asset_type: (document.getElementById('knw-type') as HTMLSelectElement).value,
      title,
      description: (document.getElementById('knw-description') as HTMLInputElement).value.trim() || null,
      url: (document.getElementById('knw-url') as HTMLInputElement).value.trim() || null,
      tribe_id: (() => { const v = (document.getElementById('knw-tribe') as HTMLSelectElement).value; return v ? parseInt(v, 10) : null; })(),
      author_id: MEMBER?.id || null,
