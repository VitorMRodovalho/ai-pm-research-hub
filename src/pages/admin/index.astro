  let _notifyPreviewData: any = null;

  async function notifyPreview() {
    if (!ensureAdminAction()) return;
    const body = document.getElementById('notify-modal-body');
    if (body) body.innerHTML = '<p class="text-slate-400 text-sm text-center py-6">Carregando preview...</p>';
    const modal = document.getElementById('modal-notify-alloc')!;
    modal.classList.remove('hidden'); modal.classList.add('flex');

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (!session) { toast('Sessao expirada', 'error'); return; }
      const res = await fetch(sb.supabaseUrl + '/functions/v1/send-allocation-notify', {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + session.access_token,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ dry_run: true }),
      });
      const data = await res.json();
      _notifyPreviewData = data;

      if (!data.success && !data.dry_run) {
        if (body) body.innerHTML = '<p class="text-crimson text-sm text-center py-6">' + (data.error || 'Erro ao carregar preview') + '</p>';
        return;
      }

      const byTribe: Record<string, any[]> = {};
      (data.members || []).forEach((m: any) => {
        const key = m.tribe_name || 'Tribo ' + m.tribe_id;
        if (!byTribe[key]) byTribe[key] = [];
        byTribe[key].push(m);
      });

      let html = '<div class="bg-amber-50 border border-amber-200 rounded-xl p-3 mb-4">'
        + '<p class="text-[.78rem] font-semibold text-amber-800">Tem certeza que deseja notificar ' + data.count + ' membros?</p>'
        + '<p class="text-[.68rem] text-amber-600 mt-1">Cada membro recebera um e-mail com o nome da sua tribo e o link do grupo de WhatsApp.</p>'
        + '</div>';

      for (const [tribe, members] of Object.entries(byTribe)) {
        html += '<div class="mb-3"><div class="text-[.78rem] font-bold text-navy mb-1">' + tribe + ' (' + members.length + ')</div>';
        html += '<div class="flex flex-wrap gap-1">';
        members.forEach((m: any) => {
          html += '<span class="text-[.68rem] bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full">' + (m.name || m.email).split(' ').slice(0,2).join(' ') + '</span>';
        });
        html += '</div></div>';
      }

      if (body) body.innerHTML = html;
    } catch (err) {
      if (body) body.innerHTML = '<p class="text-crimson text-sm text-center py-6">Erro: ' + (err instanceof Error ? err.message : String(err)) + '</p>';
    }
  }

  async function notifySend() {
    if (!ensureAdminAction()) return;
    const btn = document.getElementById('btn-confirm-notify') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (!session) { toast('Sessao expirada', 'error'); return; }
      const res = await fetch(sb.supabaseUrl + '/functions/v1/send-allocation-notify', {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + session.access_token,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ dry_run: false }),
      });
      const data = await res.json();

      if (data.success) {
        toast('Notificacoes enviadas para ' + data.total_notified + ' membros em ' + data.tribes_processed + ' tribos!' + (data.sandbox ? ' (Sandbox)' : ''), 'success');
      } else {
        toast('Erro: ' + (data.error || JSON.stringify(data.errors || 'Falha desconhecida')), 'error');
      }
    } catch (err) {
      toast('Erro: ' + (err instanceof Error ? err.message : String(err)), 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Confirmar e Enviar'; }
      const modal = document.getElementById('modal-notify-alloc')!;
      modal.classList.add('hidden'); modal.classList.remove('flex');
    }
  }

  // Event delegation for notify buttons
  document.getElementById('btn-notify-preview')?.addEventListener('click', () => notifyPreview());
  document.getElementById('btn-notify-send')?.addEventListener('click', () => notifyPreview());
  document.getElementById('btn-close-notify-modal')?.addEventListener('click', () => {
    const modal = document.getElementById('modal-notify-alloc')!;
    modal.classList.add('hidden'); modal.classList.remove('flex');
