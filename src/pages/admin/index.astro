          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">Miro (opcional)</label>
            <input type="text" inputmode="url" id="tribe-miro" value="${tribe.miro_url || ''}" placeholder="https://miro.com/..."
