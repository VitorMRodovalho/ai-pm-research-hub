  (window as any).previewVRMS = async () => {
    if (!ensureAdminAction()) return;
    const fromDate = (document.getElementById('vrms-from') as HTMLInputElement).value;
    const toDate = (document.getElementById('vrms-to') as HTMLInputElement).value;
    if (!fromDate || !toDate) { toast(ADMIN_I18N.selectDates, 'error'); return; }

    // Get events in range
    const { data: events } = await sb.from('events')
      .select('id, title, event_date, duration_hours')
      .gte('event_date', fromDate)
      .lte('event_date', toDate)
      .order('event_date');

    if (!events?.length) {
      document.getElementById('vrms-preview')!.textContent = ADMIN_I18N.noEventsInPeriod;
      document.getElementById('vrms-table-area')?.classList.add('hidden');
      return;
    }

    const eventIds = events.map((e: any) => e.id);

    // Get attendance for those events (only present)
    const { data: attendance } = await sb.from('attendance')
      .select('event_id, member_id, status')
      .in('event_id', eventIds)
      .eq('status', 'present');

    // Get active members
    const { data: members } = await sb.from('members')
      .select('id, name, email, pmi_id, chapter, operational_role, designations')
      .eq('current_cycle_active', true)
      .order('name');

    // Build hours map: member_id → { events: count, hours: sum }
    const hoursMap: Record<string, { events: number; hours: number }> = {};
    const eventHoursMap: Record<string, number> = {};
    events.forEach((e: any) => { eventHoursMap[e.id] = e.duration_hours || 2; });

    (attendance || []).forEach((a: any) => {
      if (!hoursMap[a.member_id]) hoursMap[a.member_id] = { events: 0, hours: 0 };
      hoursMap[a.member_id].events++;
      hoursMap[a.member_id].hours += eventHoursMap[a.event_id] || 2;
    });

    // Build VRMS rows (PMI audit-compliant)
    const CHAPTER_FULL: Record<string, string> = {
      'PMI-GO': 'PMI Chapter Goiás', 'PMI-CE': 'PMI Chapter Ceará',
      'PMI-DF': 'PMI Chapter Distrito Federal', 'PMI-MG': 'PMI Chapter Minas Gerais',
      'PMI-RS': 'PMI Chapter Rio Grande do Sul',
    };

    vrmsData = (members || []).map((m: any) => {
      const h = hoursMap[m.id] || { events: 0, hours: 0 };
      const opLabel = OPROLE_LABELS[m.operational_role] || m.operational_role || 'Colaborador';
      const desigLabels = (m.designations || []).map((d: string) => DESIG_LABELS[d] || d).join('; ');
      const initiative = 'Núcleo IA & GP — ' + opLabel + (desigLabels ? ' + ' + desigLabels : '');
      return {
        name: safeName(m),
        pmi_id: m.pmi_id || '',
        email: m.email,
        org: CHAPTER_FULL[m.chapter] || m.chapter || '',
        initiative,
        date_from: fromDate,
        date_to: toDate,
        events: h.events,
        hours: h.hours,
        validator: 'Vitor Maia Rodovalho (vitor.rodovalho@outlook.com)',
        evidence: 'https://ai-pm-research-hub.pages.dev/attendance',
      };
    }).filter((r: any) => r.hours > 0).sort((a: any, b: any) => b.hours - a.hours);

    // Preview stats
    const totalHours = vrmsData.reduce((s: number, r: any) => s + r.hours, 0);
    const totalMembers = vrmsData.length;
    document.getElementById('vrms-preview')!.innerHTML =
      `<span class="text-emerald-600 font-bold">${totalMembers}</span> voluntários · <span class="text-navy font-bold">${totalHours}</span> horas de impacto · <span class="text-slate-400">${events.length} eventos no período</span>`;

    // Render preview table
    const tbody = document.getElementById('vrms-table-body')!;
    tbody.innerHTML = vrmsData.map((r: any) => `
      <tr class="border-b border-slate-50 hover:bg-slate-50">
        <td class="px-3 py-2 font-medium">${escapeHtml(r.name || 'Membro sem nome')}</td>
        <td class="px-3 py-2 font-mono text-slate-500">${r.pmi_id || '—'}</td>
        <td class="px-3 py-2 text-slate-500">${r.email}</td>
        <td class="px-3 py-2 text-[.65rem]">${r.org}</td>
        <td class="px-3 py-2 text-[.65rem] text-slate-500">${r.initiative}</td>
        <td class="px-3 py-2 text-center text-[.65rem]">${r.date_from} → ${r.date_to}</td>
        <td class="px-3 py-2 text-right font-bold text-navy">${r.hours}h</td>
      </tr>`).join('');

    document.getElementById('vrms-table-count')!.textContent = ADMIN_I18N.vrmsCountFormat.replace('{n}', String(totalMembers)).replace('{h}', String(totalHours));
    document.getElementById('vrms-table-area')?.classList.remove('hidden');
  };

  (window as any).downloadVRMS = async () => {
    if (!ensureAdminAction()) return;
    if (!vrmsData.length) {
      await (window as any).previewVRMS();
      if (!vrmsData.length) { toast(ADMIN_I18N.noExportData, 'error'); return; }
    }

    const fromDate = (document.getElementById('vrms-from') as HTMLInputElement).value;
    const toDate = (document.getElementById('vrms-to') as HTMLInputElement).value;

    const header = ADMIN_I18N.csvVrmsHeader;
    const rows = vrmsData.map((r: any) =>
      `"${(r.name || 'Membro sem nome').replace(/"/g, '""')}","${r.pmi_id || ''}","${r.email || ''}","${(r.org || '').replace(/"/g, '""')}","${(r.initiative || '').replace(/"/g, '""')}","${r.date_from}","${r.date_to}",${r.hours},"${r.validator}","${r.evidence}"`
    );
    const csv = '\uFEFF' + [header, ...rows].join('\n'); // BOM for Excel UTF-8

    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `VRMS_Nucleo_IA_GP_${fromDate}_${toDate}.csv`;
    a.click();
    URL.revokeObjectURL(url);
    toast(ADMIN_I18N.csvDownloaded, 'success');
  };

  (window as any).downloadMembersCSV = async () => {
    if (!ensureAdminAction()) return;
    const { data: members } = await sb.rpc('admin_list_members', { p_limit: 500, p_offset: 0 });
    if (!members?.length) { toast(ADMIN_I18N.noMembers, 'error'); return; }

    // Get cycle history
    const { data: history } = await sb.from('member_cycle_history')
      .select('member_id, cycle_code, cycle_start, cycle_label, is_active');

    const cycleRecordsByMember: Record<string, any[]> = {};
    (history || []).forEach((h: any) => {
      if (!cycleRecordsByMember[h.member_id]) cycleRecordsByMember[h.member_id] = [];
      cycleRecordsByMember[h.member_id].push(h);
    });

    const header = ADMIN_I18N.csvMemberHeader;
    const rows = members.map((m: any) => {
      const opRole = OPROLE_LABELS[m.operational_role] || m.operational_role || '';
      const desigs = (m.designations || []).map((d: string) => DESIG_LABELS[d] || d).join('; ');
      const cycles = uniqueSortedCycleCodes(cycleRecordsByMember[m.id] || []).join('; ');
      const tid = m.tribe_id || '';
      return `"${(m?.name || 'Membro sem nome').replace(/"/g, '""')}","${m.email || ''}","${m.pmi_id || ''}","${m.phone || ''}","${m.chapter || ''}","${opRole}","${desigs}","${tid}","${m.current_cycle_active ? ADMIN_I18N.csvYes : ADMIN_I18N.csvNo}","${m.is_superadmin ? ADMIN_I18N.csvYes : ADMIN_I18N.csvNo}","${cycles}","${m.linkedin_url || ''}","${m.credly_url || ''}"`;
    });

    const csv = '\uFEFF' + [header, ...rows].join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `Membros_Nucleo_IA_GP_${new Date().toISOString().split('T')[0]}.csv`;
    a.click();
    URL.revokeObjectURL(url);
    toast(ADMIN_I18N.memberCsvDownloaded, 'success');
  };

