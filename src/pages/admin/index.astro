---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
import AdminNav from '../../components/nav/AdminNav.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const ADMIN_I18N = {
  loadError: t('admin.msg.loadError', lang),
  selectTribe: t('admin.msg.selectTribe', lang),
  allocatedPrefix: t('admin.msg.allocatedPrefix', lang),
  allocateError: t('admin.msg.allocateError', lang),
  saveErrorPrefix: t('admin.msg.saveErrorPrefix', lang),
  memberUpdated: t('admin.msg.memberUpdated', lang),
  fillTitle: t('admin.msg.fillTitle', lang),
  errorPrefix: t('admin.msg.errorPrefix', lang),
  annPublished: t('admin.msg.annPublished', lang),
  annEnabled: t('admin.msg.annEnabled', lang),
  annDisabled: t('admin.msg.annDisabled', lang),
  annDeleteConfirm: t('admin.msg.annDeleteConfirm', lang),
  annDeleted: t('admin.msg.annDeleted', lang),
  annBtnDeactivate: t('admin.announcements.btnDeactivate', lang),
  annBtnActivate: t('admin.announcements.btnActivate', lang),
  annEmpty: t('admin.announcements.empty', lang),
  annStatusInactive: t('admin.announcements.statusInactive', lang),
  annStatusExpired: t('admin.announcements.statusExpired', lang),
  annStatusActive: t('admin.announcements.statusActive', lang),
  annStatusScheduled: t('admin.announcements.statusScheduled', lang),
  annPreviewToggle: t('admin.announcements.previewToggle', lang),
  annEditToggle: t('admin.announcements.editToggle', lang),
  knwTitle: t('admin.knowledge.title', lang),
  knwSubtitle: t('admin.knowledge.subtitle', lang),
  knwEmpty: t('admin.knowledge.empty', lang),
  knwLoading: t('admin.knowledge.loading', lang),
  knwLabelTitle: t('admin.knowledge.labelTitle', lang),
  knwPlaceholderTitle: t('admin.knowledge.placeholderTitle', lang),
  knwLabelType: t('admin.knowledge.labelType', lang),
  knwTypeCourse: t('admin.knowledge.typeCourse', lang),
  knwTypeReference: t('admin.knowledge.typeReference', lang),
  knwTypeWebinar: t('admin.knowledge.typeWebinar', lang),
  knwTypeOther: t('admin.knowledge.typeOther', lang),
  knwLabelDesc: t('admin.knowledge.labelDescription', lang),
  knwPlaceholderDesc: t('admin.knowledge.placeholderDescription', lang),
  knwLabelUrl: t('admin.knowledge.labelUrl', lang),
  knwPlaceholderUrl: t('admin.knowledge.placeholderUrl', lang),
  knwLabelTribe: t('admin.knowledge.labelTribe', lang),
  knwBtnAdd: t('admin.knowledge.btnAdd', lang),
  knwBtnSave: t('admin.knowledge.btnSave', lang),
  knwCancel: t('common.cancel', lang),
  invalidWhatsAppUrl: t('admin.invalidWhatsAppUrl', lang),
  selectDates: t('admin.msg.selectDates', lang),
  noExportData: t('admin.msg.noExportData', lang),
  csvDownloaded: t('admin.msg.csvDownloaded', lang),
  noMembers: t('admin.msg.noMembers', lang),
  memberCsvDownloaded: t('admin.msg.memberCsvDownloaded', lang),
  superadminOnlyHistory: t('admin.msg.superadminOnlyHistory', lang),
  noEventsInPeriod: t('admin.msg.noEventsInPeriod', lang),
  deleteRecordConfirmPrefix: t('admin.msg.deleteRecordConfirmPrefix', lang),
  deleteRecordConfirmSuffix: t('admin.msg.deleteRecordConfirmSuffix', lang),
  saveError: t('admin.msg.saveError', lang),
  snapshotLoadError: t('admin.snapshot.loadError', lang),
  snapshotNoData: t('admin.snapshot.noData', lang),
  snapshotBase: t('admin.snapshot.base', lang),
  snapshotDone: t('admin.snapshot.done', lang),
  snapshotInProgress: t('admin.snapshot.inProgress', lang),
  snapshotBlocked: t('admin.snapshot.blocked', lang),
  snapshotByChapter: t('admin.snapshot.byChapter', lang),
  snapshotByTribe: t('admin.snapshot.byTribe', lang),
  snapshotRecentCerts: t('admin.snapshot.recentCerts', lang),
  snapshotNoRecentCerts: t('admin.snapshot.noRecentCerts', lang),
  loading: t('admin.loading', lang),
  noPermission: t('admin.restricted', lang),
  fillStartEnd: t('admin.msg.fillStartEnd', lang),
  startBeforeEnd: t('admin.msg.startBeforeEnd', lang),
  slotAdded: t('admin.msg.slotAdded', lang),
  slotRemoved: t('admin.msg.slotRemoved', lang),
  settingsSaved: t('admin.msg.settingsSaved', lang),
  cycleRecordAdded: t('admin.msg.cycleRecordAdded', lang),
  recordUpdated: t('admin.msg.recordUpdated', lang),
  recordRemoved: t('admin.msg.recordRemoved', lang),
  addCycleRecordSection: t('admin.msg.addCycleRecordSection', lang),
  allCyclesRegistered: t('admin.msg.allCyclesRegistered', lang),
  cycleHistoryActive: t('admin.msg.cycleHistoryActive', lang),
  cycleHistoryInactive: t('admin.msg.cycleHistoryInactive', lang),
  cycleHistoryCurrent: t('admin.msg.cycleHistoryCurrent', lang),
  myTribeNoAllocation: t('admin.myTribe.noAllocation', lang),
  myTribeSettingsTitle: t('admin.myTribe.settingsTitle', lang),
  myTribeMembersTitle: t('admin.myTribe.membersTitle', lang),
  myTribeAttendanceTitle: t('admin.myTribe.attendanceTitle', lang),
  myTribeMeetingSlots: t('admin.myTribe.meetingSlots', lang),
  myTribeSaved: t('admin.myTribe.saved', lang),
  researchersPending: t('admin.myTribe.researchersPending', lang),
  execLabelActive: t('admin.exec.labelActive', lang),
  execLabelLeadership: t('admin.exec.labelLeadership', lang),
  execLabelResearchers: t('admin.exec.labelResearchers', lang),
  execLabelArtifactsInReview: t('admin.exec.labelArtifactsInReview', lang),
  execLabelCoursesCompleted: t('admin.exec.labelCoursesCompleted', lang),
  execNoCohortData: t('admin.exec.noCohortData', lang),
  execFunnelNoData: t('admin.exec.funnelNoData', lang),
  execFunnelError: t('admin.exec.funnelError', lang),
  execCertError: t('admin.exec.certError', lang),
  execRadarError: t('admin.exec.radarError', lang),
  execNoRadarData: t('admin.exec.noRadarData', lang),
  cyclePromptOpRole: t('admin.cycleHistory.promptOpRole', lang),
  cyclePromptDesigs: t('admin.cycleHistory.promptDesigs', lang),
  cyclePromptTribeName: t('admin.cycleHistory.promptTribeName', lang),
  cyclePromptNotes: t('admin.cycleHistory.promptNotes', lang),
  cycleLabelRole: t('admin.cycleHistory.labelRole', lang),
  cycleLabelDesignations: t('admin.cycleHistory.labelDesignations', lang),
  dayNames: [t('common.days.sun', lang), t('common.days.mon', lang), t('common.days.tue', lang), t('common.days.wed', lang), t('common.days.thu', lang), t('common.days.fri', lang), t('common.days.sat', lang)],
  csvVrmsHeader: t('admin.csv.vrmsHeader', lang),
  csvMemberHeader: t('admin.csv.memberHeader', lang),
  vrmsCountFormat: t('admin.reports.vrmsCountFormat', lang),
  csvYes: t('admin.csv.yes', lang),
  csvNo: t('admin.csv.no', lang),
  tierLeaderTitlePrefix: t('admin.tier.leaderTitlePrefix', lang),
  tierLeaderSubtitle: t('admin.tier.leaderSubtitle', lang),
  tierMyTribe: t('admin.tier.myTribe', lang),
  tierExecTitle: t('admin.tier.execTitle', lang),
  tierExecSubtitle: t('admin.tier.execSubtitle', lang),
  uploadValidationTooLarge: t('upload.validation.tooLarge', lang),
  uploadValidationInvalidType: t('upload.validation.invalidType', lang),
};
---
<BaseLayout title={t('admin.meta', lang)} activePage="admin">
  <Toast />
  <div class="max-w-[1400px] mx-auto px-4 pt-6">
    <AdminNav activeSub="panel" lang={lang} />
  </div>
  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
      <div>
        <h1 class="text-2xl font-extrabold text-navy">{t('admin.title', lang)}</h1>
        <p class="text-sm text-slate-500">{t('admin.subtitle', lang)}</p>
      </div>
    </div>

    <div id="not-admin-msg" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">{t('admin.restricted', lang)}</p>
      <a href="/profile" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{t('admin.viewProfile', lang)}</a>
    </div>

    <div id="admin-loading" class="text-center py-10 text-slate-400">{t('admin.checkingAccess', lang)}</div>

    <!-- Tier header (shown for non-superadmin tiers) -->
    <div id="tier-header" class="hidden mb-5 p-4 rounded-xl border" style="border-color:#4F17A830;background:#4F17A808">
      <div class="flex items-center gap-2">
        <span class="text-lg" id="tier-icon"></span>
        <div>
          <div class="text-sm font-bold text-navy" id="tier-title"></div>
          <div class="text-[.7rem] text-slate-400" id="tier-subtitle"></div>
        </div>
      </div>
    </div>

    <div id="admin-panel" class="hidden">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-5">
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-navy" id="stat-total">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">{t('admin.stat.total', lang)}</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-emerald-600" id="stat-active">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">{t('admin.stat.active', lang)}</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-amber-600" id="stat-pending">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">{t('admin.stat.noTribe', lang)}</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-crimson" id="stat-inactive">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">{t('admin.stat.inactive', lang)}</div></div>
        <div class="bg-white border border-slate-200 rounded-xl p-4"><div class="text-2xl font-black text-purple" id="stat-noauth">—</div><div class="text-[.68rem] text-slate-400 font-semibold mt-0.5">{t('admin.stat.noLogin', lang)}</div></div>
      </div>

      <!-- Executive Overview KPI Cards (loaded via get_executive_kpis RPC) -->
      <div id="exec-kpi-overview" class="hidden mb-5">
        <div class="flex items-center gap-2 mb-3">
          <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          <h2 class="text-sm font-bold text-navy">Executive Overview</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div class="bg-gradient-to-br from-emerald-50 to-teal-50 border border-emerald-200/60 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span class="text-[.65rem] font-semibold text-emerald-700 uppercase tracking-wide">Membros Ativos</span>
            </div>
            <div class="text-2xl font-black text-emerald-700" id="ekpi-active">—</div>
            <div class="text-[.6rem] text-emerald-600/70 mt-0.5"><span id="ekpi-chapters">—</span> capitulos</div>
          </div>
          <div class="bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200/60 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              <span class="text-[.65rem] font-semibold text-blue-700 uppercase tracking-wide">Retencao</span>
            </div>
            <div class="text-2xl font-black text-blue-700" id="ekpi-retention">—</div>
            <div class="text-[.6rem] text-blue-600/70 mt-0.5"><span id="ekpi-multi">—</span> em mais de 1 ciclo</div>
          </div>
          <div class="bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200/60 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
              <span class="text-[.65rem] font-semibold text-amber-700 uppercase tracking-wide">PMI Verificados</span>
            </div>
            <div class="text-2xl font-black text-amber-700" id="ekpi-verified">—</div>
            <div class="text-[.6rem] text-amber-600/70 mt-0.5"><span id="ekpi-verified-pct">—</span>% do total ativo</div>
          </div>
          <div class="bg-gradient-to-br from-purple-50 to-fuchsia-50 border border-purple-200/60 rounded-xl p-4">
            <div class="flex items-center gap-2 mb-1">
              <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
              <span class="text-[.65rem] font-semibold text-purple-700 uppercase tracking-wide">Artefatos</span>
            </div>
            <div class="text-2xl font-black text-purple-700" id="ekpi-artifacts">—</div>
            <div class="text-[.6rem] text-purple-600/70 mt-0.5"><span id="ekpi-tribes">—</span> tribos ativas · <span id="ekpi-avg">—</span> membros/tribo</div>
          </div>
        </div>
      </div>

      <div class="flex gap-2 mb-5 flex-wrap">
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white" data-action="switch-adm-tab" data-tab="tribes">{t('admin.tab.tribes', lang)}</button>
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500" data-action="switch-adm-tab" data-tab="members">{t('admin.tab.members', lang)}</button>
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500" data-action="switch-adm-tab" data-tab="reports">{t('admin.tab.reports', lang)}</button>
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500" data-action="switch-adm-tab" data-tab="knowledge">{t('admin.tab.knowledge', lang)}</button>
        <button class="adm-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500" data-action="switch-adm-tab" data-tab="analytics">{t('admin.tab.analytics', lang)}</button>
      </div>

      <div id="panel-tribes">
        <div class="grid grid-cols-1 xl:grid-cols-[1.5fr_.9fr] gap-4 mb-6">
          <div class="bg-white border border-slate-200 rounded-2xl p-5">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div>
                <h3 class="text-sm font-bold text-navy">Catálogo de Tribos</h3>
                <p class="text-[.72rem] text-slate-400 mt-1">O catálogo agora pode crescer além do conjunto fixo `01..08`. Gestão do projeto abre novas tribos ativas e o Superadmin também acompanha inativas.</p>
              </div>
              <div id="tribe-catalog-summary" class="text-[.72rem] text-slate-400">Carregando catálogo...</div>
            </div>
          </div>
          <div class="bg-white border border-slate-200 rounded-2xl p-5">
            <h3 class="text-sm font-bold text-navy">Abrir Nova Tribo</h3>
            <p class="text-[.72rem] text-slate-400 mt-1 mb-3">Cria uma nova entrada no catálogo para permitir navegação, alocação e gestão operacional.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <input id="new-tribe-name" type="text" placeholder="Nome da nova tribo" class="px-3 py-2 border border-slate-200 rounded-lg text-sm sm:col-span-2" />
              <select id="new-tribe-quadrant" class="px-3 py-2 border border-slate-200 rounded-lg text-sm">
                <option value="1">Q1</option>
                <option value="2">Q2</option>
                <option value="3">Q3</option>
                <option value="4">Q4</option>
              </select>
              <input id="new-tribe-quadrant-name" type="text" placeholder="Label do quadrante" class="px-3 py-2 border border-slate-200 rounded-lg text-sm" />
              <input id="new-tribe-notes" type="text" placeholder="Descrição curta / contexto" class="px-3 py-2 border border-slate-200 rounded-lg text-sm sm:col-span-2" />
            </div>
            <div class="mt-3 flex justify-end">
              <button id="btn-create-tribe" data-action="create-tribe" class="px-4 py-2 bg-navy text-white rounded-lg text-sm font-semibold hover:opacity-90">Criar Tribo</button>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6" id="tribe-cards"></div>

        <!-- Notify Allocations Action Card -->
        <div class="bg-gradient-to-r from-navy/5 to-teal/5 border border-navy/20 rounded-2xl p-5 mb-6 flex items-center justify-between flex-wrap gap-4" id="notify-alloc-card" style="display:none">
          <div>
            <h3 class="text-sm font-bold text-navy flex items-center gap-2">
              <svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              Notificar Alocacoes
            </h3>
            <p class="text-[.72rem] text-slate-500 mt-1">Enviar e-mail de confirmacao de tribo para todos os membros alocados, incluindo link do WhatsApp.</p>
            <div class="text-[.68rem] text-slate-400 mt-1" id="notify-alloc-summary"></div>
          </div>
          <div class="flex gap-2">
            <button type="button" class="px-4 py-2 rounded-lg text-[.78rem] font-semibold border border-navy/30 text-navy bg-white hover:bg-navy/5 cursor-pointer transition-all" id="btn-notify-preview">
              Pre-visualizar
            </button>
            <button type="button" class="px-4 py-2 rounded-lg text-[.78rem] font-semibold bg-teal text-white border-0 hover:bg-teal/90 cursor-pointer transition-all" id="btn-notify-send">
              Notificar Membros
            </button>
          </div>
        </div>

        <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-200 bg-amber-50">
            <h3 class="text-sm font-bold text-amber-800">{t('admin.pendingPoolTitle', lang)}</h3>
          </div>
          <div class="p-4" id="pending-list"><p class="text-slate-400 text-sm text-center py-4">{t('admin.loading', lang)}</p></div>
        </div>
      </div>

      <div id="panel-members" class="hidden">
        <!-- Filter bar -->
        <div class="bg-white border border-slate-200 rounded-2xl p-4 mb-4">
          <div class="flex items-center gap-3 mb-3 flex-wrap">
            <input type="text" id="f-search" placeholder={t('admin.filter.search', lang)} data-action="apply-filters"
              class="px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] focus:outline-none focus:border-teal flex-1 min-w-[200px]">
            <span class="text-[.72rem] font-bold text-slate-400" id="f-count">—</span>
          </div>
          <div class="flex gap-2 flex-wrap">
            <select id="f-chapter" data-action="apply-filters" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">{t('admin.filter.chapterAll', lang)}</option>
              <option value="PMI-GO">PMI-GO</option>
              <option value="PMI-CE">PMI-CE</option>
              <option value="PMI-DF">PMI-DF</option>
              <option value="PMI-MG">PMI-MG</option>
              <option value="PMI-RS">PMI-RS</option>
            </select>
            <select id="f-oprole" data-action="apply-filters" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">{t('admin.filter.roleAll', lang)}</option>
              <option value="manager">{t('role.manager', lang)}</option>
              <option value="deputy_manager">Deputy PM</option>
              <option value="tribe_leader">{t('role.tribe_leader', lang)}</option>
              <option value="researcher">{t('role.researcher', lang)}</option>
              <option value="facilitator">{t('role.facilitator', lang)}</option>
              <option value="communicator">{t('role.communicator', lang)}</option>
              <option value="none">{t('admin.filter.noOperationalRole', lang)}</option>
              <option value="guest">{t('role.guest', lang)}</option>
            </select>
            <select id="f-desig" data-action="apply-filters" class="px-2.5 py-1.5 border border-slate-200 rounded-lg text-[.72rem] bg-white">
              <option value="">{t('admin.filter.designationAll', lang)}</option>
              <option value="sponsor">{t('admin.desig.sponsor', lang)}</option>
              <option value="chapter_liaison">{t('admin.desig.chapterLiaison', lang)}</option>
              <option value="ambassador">{t('admin.desig.ambassador', lang)}</option>
              <option value="founder">{t('admin.desig.founder', lang)}</option>
