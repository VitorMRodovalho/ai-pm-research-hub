  // ══════════════════════════════════════════
  // REPORTS (VRMS CSV + Members Export)
  // ══════════════════════════════════════════
  let vrmsData: any[] = [];
  let leadershipRows: any[] = [];
  const TRAIL_CODES = ['GENAI_OVERVIEW','DATA_LANDSCAPE','PROMPT_ENG','PRACTICAL_GENAI','CDBA_INTRO','CPMAI_INTRO','AI_INFRA','AI_AGILE'];

  function initReports() {
    if (!ensureAdminAction(false)) return;
    // Set default date range: current cycle start → today
    const fromEl = document.getElementById('vrms-from') as HTMLInputElement;
    const toEl = document.getElementById('vrms-to') as HTMLInputElement;
    const cycleStart = getFallbackCycleStart();
    if (fromEl && !fromEl.value) fromEl.value = cycleStart;
    if (toEl && !toEl.value) toEl.value = new Date().toISOString().split('T')[0];
    const lsFrom = document.getElementById('ls-from') as HTMLInputElement;
    const lsTo = document.getElementById('ls-to') as HTMLInputElement;
    if (lsFrom && !lsFrom.value) lsFrom.value = cycleStart;
    if (lsTo && !lsTo.value) lsTo.value = new Date().toISOString().split('T')[0];
    loadAnnouncements();
    loadLeadershipSnapshot();
  }

  function leadershipFilters() {
    const chapter = (document.getElementById('ls-chapter') as HTMLSelectElement)?.value || '';
    const tribe = (document.getElementById('ls-tribe') as HTMLSelectElement)?.value || '';
    const fromDate = (document.getElementById('ls-from') as HTMLInputElement)?.value || '';
    const toDate = (document.getElementById('ls-to') as HTMLInputElement)?.value || '';
    return { chapter, tribe, fromDate, toDate };
  }

  (window as any).applyLeadershipFilters = async () => {
    if (!ensureAdminAction()) return;
    await loadLeadershipSnapshot();
  };

  async function loadLeadershipSnapshot() {
    if (!ensureAdminAction(false)) return;
    const host = document.getElementById('leadership-snapshot');
    if (!host) return;
    host.innerHTML = `<p class="text-slate-400 text-sm text-center py-4">${ADMIN_I18N.loading}</p>`;
    leadershipRows = [];
    const filters = leadershipFilters();

    let membersQuery = sb.from('members')
        .select('id, name, chapter, tribe_id, current_cycle_active, operational_role')
        .eq('current_cycle_active', true);
    if (filters.chapter) membersQuery = membersQuery.eq('chapter', filters.chapter);
    if (filters.tribe) membersQuery = membersQuery.eq('tribe_id', Number(filters.tribe));

    const { data: membersRaw, error: membersError } = await membersQuery;
    if (membersError) {
      host.innerHTML = `<p class="text-crimson text-sm text-center py-4">${ADMIN_I18N.snapshotLoadError}</p>`;
      return;
    }

    const members = (membersRaw || []).filter((m: any) => ['manager', 'deputy_manager', 'tribe_leader', 'researcher', 'facilitator', 'communicator'].includes(m.operational_role));
    if (!members.length) {
      host.innerHTML = `<p class="text-slate-400 text-sm text-center py-4">${ADMIN_I18N.snapshotNoData}</p>`;
      return;
    }

    const memberIds = members.map((m: any) => m.id);
    let pointsQuery = sb.from('gamification_points')
      .select('member_id, reason, created_at, points')
      .in('member_id', memberIds)
      .like('reason', 'Credly:%')
      .order('created_at', { ascending: false })
      .limit(400);
    if (filters.fromDate) pointsQuery = pointsQuery.gte('created_at', `${filters.fromDate}T00:00:00`);
    if (filters.toDate) pointsQuery = pointsQuery.lte('created_at', `${filters.toDate}T23:59:59`);

    const [progressRes, pointsRes] = await Promise.all([
      sb.from('course_progress')
        .select('member_id, code, status, completed_at')
        .in('member_id', memberIds)
        .in('code', TRAIL_CODES),
      pointsQuery,
    ]);

    if (progressRes.error || pointsRes.error) {
      host.innerHTML = `<p class="text-crimson text-sm text-center py-4">${ADMIN_I18N.snapshotLoadError}</p>`;
      return;
    }

    const progress = progressRes.data || [];
    const points = pointsRes.data || [];

    const perMember: Record<string, { completed: Set<string>; inProgress: Set<string> }> = {};
    progress.forEach((p: any) => {
      if (!perMember[p.member_id]) perMember[p.member_id] = { completed: new Set(), inProgress: new Set() };
      if (p.status === 'completed') {
        const completedDate = p.completed_at ? String(p.completed_at).slice(0, 10) : '';
        const inRange = (!filters.fromDate || completedDate >= filters.fromDate) && (!filters.toDate || completedDate <= filters.toDate);
        if (inRange) perMember[p.member_id].completed.add(p.code);
      }
      if (p.status === 'in_progress') perMember[p.member_id].inProgress.add(p.code);
    });

    let trailDone = 0;
    let trailInProgress = 0;
    let blocked = 0;
    const chapterAgg: Record<string, { total: number; done: number }> = {};
    const tribeAgg: Record<number, { total: number; done: number }> = {};

    members.forEach((m: any) => {
      const p = perMember[m.id] || { completed: new Set(), inProgress: new Set() };
      const doneCount = p.completed.size;
      const progCount = p.inProgress.size;
      const isDone = doneCount >= TRAIL_CODES.length;
      const isBlocked = doneCount === 0 && progCount === 0;
      if (isDone) trailDone++;
      else if (doneCount > 0 || progCount > 0) trailInProgress++;
      if (isBlocked) blocked++;

      const ch = m.chapter || 'Outros';
      if (!chapterAgg[ch]) chapterAgg[ch] = { total: 0, done: 0 };
      chapterAgg[ch].total++;
      if (isDone) chapterAgg[ch].done++;

      const tid = Number(m.tribe_id || 0);
      if (tid > 0) {
        if (!tribeAgg[tid]) tribeAgg[tid] = { total: 0, done: 0 };
        tribeAgg[tid].total++;
        if (isDone) tribeAgg[tid].done++;
      }

      const status = isDone ? 'done' : (isBlocked ? 'blocked' : 'progress');
      leadershipRows.push({
        member_id: m.id,
        name: safeName(m),
        chapter: m.chapter || '',
        tribe: m.tribe_id ? `T${String(m.tribe_id).padStart(2, '0')}` : '',
        completed_courses: doneCount,
        in_progress_courses: progCount,
        status,
      });
    });

    const memberById: Record<string, any> = {};
    members.forEach((m: any) => { memberById[m.id] = m; });

    const recentCerts = points
      .filter((p: any) => memberById[p.member_id])
      .slice(0, 12)
      .map((p: any) => {
        const m = memberById[p.member_id];
        return {
          name: safeName(m),
          chapter: m.chapter || '—',
          tribe: m.tribe_id ? `T${String(m.tribe_id).padStart(2, '0')}` : '—',
          badge: String(p.reason || '').replace(/^Credly:\s*/, ''),
          createdAt: p.created_at,
          points: p.points || 0,
        };
      });

    const chapterRows = Object.entries(chapterAgg)
      .sort((a, b) => b[1].done - a[1].done)
      .map(([chapter, stats]) => {
        const pct = stats.total > 0 ? Math.round((stats.done / stats.total) * 100) : 0;
        return `
          <div class="flex items-center gap-2 py-1.5 border-b border-slate-100 last:border-b-0">
            <div class="w-16 text-[.72rem] font-bold text-slate-600">${chapter}</div>
            <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-teal rounded-full" style="width:${pct}%"></div>
            </div>
            <div class="text-[.7rem] font-bold text-navy">${stats.done}/${stats.total}</div>
          </div>
        `;
      }).join('');

    const tribeRows = Object.entries(tribeAgg)
      .sort((a, b) => Number(a[0]) - Number(b[0]))
      .map(([tid, stats]) => {
        const pct = stats.total > 0 ? Math.round((stats.done / stats.total) * 100) : 0;
        return `
          <div class="flex items-center gap-2 py-1.5 border-b border-slate-100 last:border-b-0">
            <div class="w-10 text-[.72rem] font-bold text-slate-600">T${String(tid).padStart(2, '0')}</div>
            <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
              <div class="h-full bg-purple rounded-full" style="width:${pct}%"></div>
            </div>
            <div class="text-[.7rem] font-bold text-navy">${stats.done}/${stats.total}</div>
          </div>
        `;
      }).join('');

    host.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-4 gap-3 mb-4">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-navy">${members.length}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">${ADMIN_I18N.snapshotBase}</div>
        </div>
        <div class="bg-emerald-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-emerald-700">${trailDone}</div>
          <div class="text-[.65rem] text-emerald-700 font-semibold">${ADMIN_I18N.snapshotDone}</div>
        </div>
        <div class="bg-amber-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-amber-700">${trailInProgress}</div>
          <div class="text-[.65rem] text-amber-700 font-semibold">${ADMIN_I18N.snapshotInProgress}</div>
        </div>
        <div class="bg-red-50 rounded-xl p-3 text-center">
          <div class="text-xl font-black text-crimson">${blocked}</div>
          <div class="text-[.65rem] text-crimson font-semibold">${ADMIN_I18N.snapshotBlocked}</div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div class="bg-white border border-slate-200 rounded-xl p-3">
          <div class="text-[.72rem] font-bold text-slate-500 mb-1">${ADMIN_I18N.snapshotByChapter}</div>
          ${chapterRows || `<p class="text-[.72rem] text-slate-400 py-2">${ADMIN_I18N.snapshotNoData}</p>`}
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-3">
          <div class="text-[.72rem] font-bold text-slate-500 mb-1">${ADMIN_I18N.snapshotByTribe}</div>
          ${tribeRows || `<p class="text-[.72rem] text-slate-400 py-2">${ADMIN_I18N.snapshotNoData}</p>`}
        </div>
        <div class="bg-white border border-slate-200 rounded-xl p-3">
          <div class="text-[.72rem] font-bold text-slate-500 mb-1">${ADMIN_I18N.snapshotRecentCerts}</div>
          <div class="space-y-1.5">
            ${recentCerts.length ? recentCerts.map((r: any) => `
              <div class="text-[.68rem] border-b border-slate-100 last:border-b-0 pb-1.5">
                <div class="font-semibold text-slate-700 truncate">${escapeHtml(r.name || 'Membro sem nome')} · ${r.chapter} · ${r.tribe}</div>
                <div class="text-slate-500 truncate">${r.badge}</div>
                <div class="text-slate-400">${new Date(r.createdAt).toLocaleDateString('pt-BR')} · ${r.points} XP</div>
              </div>
            `).join('') : `<p class="text-[.72rem] text-slate-400 py-2">${ADMIN_I18N.snapshotNoRecentCerts}</p>`}
          </div>
        </div>
      </div>
    `;
  }

  (window as any).downloadLeadershipSnapshot = () => {
    if (!ensureAdminAction()) return;
    if (!leadershipRows.length) { toast(ADMIN_I18N.noExportData, 'error'); return; }
    const filters = leadershipFilters();
    const header = 'Member ID,Name,Chapter,Tribe,Completed Courses,In Progress Courses,Status';
    const rows = leadershipRows.map((r: any) =>
      `"${r.member_id}","${(r.name || 'Membro sem nome').replace(/"/g, '""')}","${r.chapter}","${r.tribe}",${r.completed_courses},${r.in_progress_courses},"${r.status}"`
    );
    const csv = '\uFEFF' + [header, ...rows].join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    const from = filters.fromDate || 'all';
    const to = filters.toDate || 'all';
    a.href = url;
    a.download = `Leadership_Snapshot_${from}_${to}.csv`;
    a.click();
