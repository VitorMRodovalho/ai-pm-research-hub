<!-- define:vars forces is:inline and breaks imports; inject i18n separately -->
<script is:inline define:vars={{ ADMIN_I18N }}>
  window.__ADMIN_I18N = typeof ADMIN_I18N !== 'undefined' ? ADMIN_I18N : {};
</script>
<script>
  import { getCurrentCycle, getCycleDates, getCycleMeta, getCycleOrder, loadCycles } from '../../lib/cycles';
  import { ROLE_COLORS, ROLE_LABELS } from '../../lib/supabase';
  import { getMemberRole } from '../../lib/routing';
  import { normalizeMemberCycleHistory, uniqueSortedCycleCodes } from '../../lib/cycle-history';
  import {
    DESIG_COLORS,
    DESIG_LABELS,
    ELIGIBLE_ROLES,
    MAX_SLOTS,
    OPROLE_COLORS,
    OPROLE_LABELS,
    TIER_LABELS,
    TRIBE_COLORS,
    TRIBE_LEADERS,
    TRIBE_NAMES,
    getAccessTier,
    canAccessAdminRoute,
    hasMinimumTier,
    resolveTierFromMember,
  } from '../../lib/admin/constants';
  import { canManageTribeLifecycle } from '../../lib/tribes/access';
  import { buildTribeLabel, getQuadrantColor, getTribeColor, isRuntimeTribeActive } from '../../lib/tribes/catalog';

  const ADMIN_I18N = (typeof window !== 'undefined' && (window as any).__ADMIN_I18N) || {};
  let sb: any = null;
  let MEMBER: any = null;
  let allMembers: any[] = [];
  let cycleMeta: Record<string, { label: string; abbr: string; color: string }> = {};
  let cycleOrder: string[] = [];
  let cycleDatesMap: Record<string, { start: string; end: string | null }> = {};
  let currentCycleStart = '';
  let tribeCatalogCache: any[] = [];

  function getCycleDisplayMeta(code: string): { label: string; abbr: string; color: string } {
    return cycleMeta[code] || { label: code, abbr: code, color: '#94A3B8' };
  }

  function getFallbackCycleStart(): string {
    return currentCycleStart || new Date().toISOString().split('T')[0];
  }

  async function adminUpdateMemberCompat(payload: {
    memberId: string;
    opRole: string;
    desigs: string[];
    chapter: string;
    active: boolean;
  }) {
    const res = await sb.rpc('admin_update_member', {
      p_member_id: payload.memberId,
      p_operational_role: payload.opRole,
      p_designations: payload.desigs,
      p_chapter: payload.chapter,
      p_current_cycle_active: payload.active
    });
    return { mode: 'v2', data: res.data, error: res.error };
  }

  function toast(msg: string, type = '') { (window as any).toast?.(msg, type); }

  function ensureAdminAction(showToast = true): boolean {
    if (canAccessAdminRoute(MEMBER, 'admin_manage_actions')) return true;
    if (showToast) toast(ADMIN_I18N.noPermission, 'error');
    return false;
  }

  function ensureLeaderAction(showToast = true): boolean {
    const tier = resolveTierFromMember(MEMBER);
    if (hasMinimumTier(tier, 'leader')) return true;
    if (showToast) toast(ADMIN_I18N.noPermission, 'error');
    return false;
  }

  function initials(name: string | null | undefined): string {
    if (!name || typeof name !== 'string') return '?';
    return name.split(' ').map(w => w[0]).filter(Boolean).join('').substring(0, 2).toUpperCase() || '?';
  }

  function escapeAttr(s: string): string {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function escapeHtml(s: string): string {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function avatar(m: any, size = 'w-8 h-8'): string {
    return m.photo_url
      ? `<img src="${m.photo_url}" class="${size} rounded-full object-cover flex-shrink-0" alt="">`
      : `<div class="${size} rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.6rem] flex-shrink-0">${initials(m?.name)}</div>`;
  }

  function safeName(m: any): string {
    return m?.name || 'Membro sem nome';
  }

  function roleDots(m: any): string {
    const opRole = getMemberRole(m);
    const desigs = m.designations?.length ? m.designations : [];
    const all = [...(opRole !== 'none' && opRole !== 'guest' ? [opRole] : []), ...desigs];
    return all.filter((r: string) => ROLE_COLORS[r]).map((r: string) =>
      `<span style="width:8px;height:8px;border-radius:50%;background:${ROLE_COLORS[r]};display:inline-block" title="${ROLE_LABELS[r] || r}"></span>`
    ).join('');
  }

  function roleLabelsText(m: any): string {
    const opRole = getMemberRole(m);
    const desigs = m.designations?.length ? m.designations : [];
    const parts: string[] = [];
    if (opRole !== 'none' && opRole !== 'guest') parts.push(ROLE_LABELS[opRole] || opRole);
    desigs.forEach((d: string) => parts.push(ROLE_LABELS[d] || d));
    return parts.length > 0 ? parts.join(', ') : 'Convidado';
  }

  // ── TABS ──
  function switchAdmTab(el: HTMLElement, tab: string) {
    if (['tribes', 'members', 'reports', 'knowledge'].includes(tab) && !ensureAdminAction()) return;
    if (tab === 'analytics' && !canAccessAdminRoute(MEMBER, 'admin_analytics')) {
      toast(ADMIN_I18N.noPermission, 'error');
      return;
    }
    document.querySelectorAll('.adm-tab').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
    });
    el.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    document.getElementById('panel-tribes')?.classList.toggle('hidden', tab !== 'tribes');
    document.getElementById('panel-members')?.classList.toggle('hidden', tab !== 'members');
    document.getElementById('panel-reports')?.classList.toggle('hidden', tab !== 'reports');
    document.getElementById('panel-knowledge')?.classList.toggle('hidden', tab !== 'knowledge');
    document.getElementById('panel-analytics')?.classList.toggle('hidden', tab !== 'analytics');
    if (tab === 'members') loadMembersList();
    if (tab === 'reports') initReports();
    if (tab === 'knowledge') loadKnowledgeAssets();
    if (tab === 'analytics') { initAnalyticsConsent(); loadAnalyticsCharts(); }
  }

  (window as any).switchAdmTab = switchAdmTab;

  function setupAdminDelegatedActions() {
    const win = window as any;
    if (win.__adminDelegatedActionsBound) return;
    win.__adminDelegatedActionsBound = true;

    document.addEventListener('click', (event) => {
      const target = (event.target as HTMLElement | null)?.closest('[data-action]') as HTMLElement | null;
      if (!target) return;

      switch (target.dataset.action) {
        case 'switch-adm-tab': {
          const tab = target.dataset.tab;
          if (tab) switchAdmTab(target, tab);
          break;
        }
        case 'create-tribe': createTribe(); break;
        case 'toggle-tribe-active': toggleTribeActive(target); break;
        case 'clear-filters': clearFilters(); break;
        case 'preview-vrms': previewVRMS(); break;
        case 'download-vrms': downloadVRMS(); break;
        case 'download-members-csv': downloadMembersCSV(); break;
        case 'apply-leadership-filters': applyLeadershipFilters(); break;
        case 'download-leadership-snapshot': downloadLeadershipSnapshot(); break;
        case 'create-announcement': createAnnouncement(); break;
        case 'save-knowledge-asset': saveKnowledgeAsset(); break;
        case 'cancel-knowledge-edit': cancelKnowledgeEdit(); break;
        case 'close-allocate': closeAllocate(); break;
        case 'confirm-allocate': confirmAllocate(); break;
        case 'close-edit-member': closeEditMember(); break;
        case 'save-edit-member': saveEditMember(); break;
        case 'close-cycle-history': closeCycleHistory(); break;
      }
    });

    const handleFilterChange = (event: Event) => {
      const target = event.target as HTMLElement | null;
      if (target?.matches('[data-action="apply-filters"]')) applyFilters();
    };

    document.addEventListener('input', handleFilterChange);
    document.addEventListener('change', handleFilterChange);
  }

  setupAdminDelegatedActions();

  let chartsLoaded = false;
  async function loadAnalyticsCharts() {
    if (chartsLoaded || !sb) return;
    chartsLoaded = true;
    const { Chart, BarController, RadarController, DoughnutController, CategoryScale, LinearScale, RadialLinearScale, BarElement, PointElement, LineElement, ArcElement, Filler, Legend, Tooltip } = await import('chart.js');
    Chart.register(BarController, RadarController, DoughnutController, CategoryScale, LinearScale, RadialLinearScale, BarElement, PointElement, LineElement, ArcElement, Filler, Legend, Tooltip);
    const PALETTE = ['#0d9488', '#7c3aed', '#2563eb', '#e11d48', '#ea580c', '#65a30d', '#0891b2', '#6366f1'];

    try {
      const { data: funnel } = await sb.rpc('exec_funnel_summary');
      if (funnel && funnel.total_members) {
        const funnelCanvas = document.getElementById('chart-funnel') as HTMLCanvasElement;
        if (funnelCanvas) new Chart(funnelCanvas, {
          type: 'bar',
          data: {
            labels: ['Com Tribo', 'Credly', 'Com Foto', 'Com LinkedIn'],
            datasets: [{
              data: [funnel.with_tribe, funnel.with_credly, funnel.with_photo, funnel.with_linkedin],
              backgroundColor: PALETTE.slice(0, 4),
              borderRadius: 6, barPercentage: 0.7,
            }]
          },
          options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c: any) => c.raw + ' / ' + funnel.total_members } } }, scales: { x: { max: funnel.total_members, grid: { color: '#f1f5f9' } }, y: { grid: { display: false } } } }
        });
      }
    } catch (e) { console.warn('Funnel chart:', e); }

    try {
      const { data: radar } = await sb.rpc('exec_skills_radar');
      if (Array.isArray(radar) && radar.length) {
        const radarCanvas = document.getElementById('chart-radar') as HTMLCanvasElement;
        if (radarCanvas) new Chart(radarCanvas, {
          type: 'radar',
          data: {
            labels: radar.map((t: any) => t.tribe_name?.substring(0, 12)),
            datasets: [
              { label: 'Credly', data: radar.map((t: any) => t.credly_count || 0), borderColor: PALETTE[1], backgroundColor: PALETTE[1] + '30', fill: true },
              { label: 'Foto', data: radar.map((t: any) => t.photo_count || 0), borderColor: PALETTE[2], backgroundColor: PALETTE[2] + '30', fill: true },
              { label: 'LinkedIn', data: radar.map((t: any) => t.linkedin_count || 0), borderColor: PALETTE[0], backgroundColor: PALETTE[0] + '30', fill: true },
            ]
          },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } }, scales: { r: { ticks: { font: { size: 9 } }, pointLabels: { font: { size: 9 } } } } }
        });
      }
    } catch (e) { console.warn('Radar chart:', e); }

    try {
      const { data: impact } = await sb.from('impact_hours_summary').select('*');
      const { data: total } = await sb.from('impact_hours_total').select('*').single();
      if (Array.isArray(impact) && impact.length) {
        const impactCanvas = document.getElementById('chart-impact') as HTMLCanvasElement;
        if (impactCanvas) new Chart(impactCanvas, {
          type: 'doughnut',
          data: {
            labels: impact.map((t: any) => 'Tribo ' + t.tribe_id),
            datasets: [{ data: impact.map((t: any) => Number(t.impact_hours || 0)), backgroundColor: PALETTE, borderWidth: 2, borderColor: '#fff' }]
          },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } }, tooltip: { callbacks: { label: (c: any) => c.label + ': ' + c.raw.toFixed(1) + 'h' } } } }
        });
      }
      if (total) {
        const kpiEl = document.getElementById('kpi-cards');
        if (kpiEl) {
          const pct = total.percent_of_target ? Number(total.percent_of_target).toFixed(1) : '0';
          kpiEl.innerHTML = '<div class="grid grid-cols-2 gap-3">'
            + '<div class="bg-slate-50 rounded-xl p-3 text-center"><div class="text-xl font-extrabold text-navy">' + Number(total.total_impact_hours || 0).toFixed(0) + 'h</div><div class="text-[.65rem] text-slate-500">Horas de Impacto</div></div>'
            + '<div class="bg-slate-50 rounded-xl p-3 text-center"><div class="text-xl font-extrabold text-teal">' + pct + '%</div><div class="text-[.65rem] text-slate-500">da Meta Anual</div></div>'
            + '<div class="bg-slate-50 rounded-xl p-3 text-center"><div class="text-xl font-extrabold text-navy">' + (total.total_events || 0) + '</div><div class="text-[.65rem] text-slate-500">Eventos</div></div>'
            + '<div class="bg-slate-50 rounded-xl p-3 text-center"><div class="text-xl font-extrabold text-navy">' + (total.total_attendances || 0) + '</div><div class="text-[.65rem] text-slate-500">Presenças</div></div>'
            + '</div>';
        }
      }
    } catch (e) { console.warn('Impact chart:', e); }
  }

  function initAnalyticsConsent() {
    const CK = 'analytics_consent';
    const statusEl = document.getElementById('consent-status-inline');
    function renderC() {
      const v = localStorage.getItem(CK);
      if (!statusEl) return;
      if (v === 'granted') { statusEl.textContent = 'Consentimento ativo'; statusEl.className = 'text-[.68rem] text-emerald-600 mt-1'; }
      else if (v === 'denied') { statusEl.textContent = 'Consentimento revogado'; statusEl.className = 'text-[.68rem] text-crimson mt-1'; }
      else { statusEl.textContent = 'Nao consentido'; statusEl.className = 'text-[.68rem] text-slate-400 mt-1'; }
    }
    const gBtn = document.getElementById('btn-consent-grant-inline');
    const rBtn = document.getElementById('btn-consent-revoke-inline');
    if (gBtn && !gBtn.dataset.bound) { gBtn.dataset.bound = '1'; gBtn.addEventListener('click', () => { localStorage.setItem(CK, 'granted'); renderC(); }); }
    if (rBtn && !rBtn.dataset.bound) { rBtn.dataset.bound = '1'; rBtn.addEventListener('click', () => { localStorage.setItem(CK, 'denied'); renderC(); }); }
    renderC();
  }

  // ══════════════════════════════════════════
  // TRIBE MANAGEMENT
  // ══════════════════════════════════════════
  async function loadTribeCatalog(force = false) {
    if (!sb) return [];
    if (!force && tribeCatalogCache.length) return tribeCatalogCache;
    const includeInactive = MEMBER?.is_superadmin === true;
    const { data, error } = await sb.rpc('admin_list_tribes', { p_include_inactive: includeInactive });
    if (error) {
      console.warn('admin_list_tribes failed, falling back to direct read', error);
      let fallbackQuery = sb.from('tribes')
        .select('id, name, quadrant, quadrant_name, leader_member_id, is_active')
        .order('id');
      if (!includeInactive) fallbackQuery = fallbackQuery.eq('is_active', true);
      const fallback = await fallbackQuery;
      tribeCatalogCache = fallback.data || [];
      return tribeCatalogCache;
    }
    tribeCatalogCache = Array.isArray(data) ? data : [];
    return tribeCatalogCache;
  }

  function renderTribeCatalogSummary(tribes: any[]) {
    const summaryEl = document.getElementById('tribe-catalog-summary');
    if (!summaryEl) return;
    const active = tribes.filter((tribe: any) => isRuntimeTribeActive(tribe)).length;
    const inactive = tribes.length - active;
    summaryEl.textContent = MEMBER?.is_superadmin
      ? `${active} ativas · ${inactive} inativas`
      : `${active} ativas no catálogo`;
  }

  function populateAdminTribeFilter(tribes: any[]) {
    const select = document.getElementById('f-tribe') as HTMLSelectElement | null;
    if (!select) return;
    const currentValue = select.value;
    const allLabel = select.querySelector('option[value=""]')?.textContent || 'Todas as tribos';
    const noneLabel = select.querySelector('option[value="none"]')?.textContent || 'Sem tribo';
    const dynamicOptions = tribes.map((tribe: any) =>
      `<option value="${tribe.id}">${String(tribe.id).padStart(2, '0')} — ${escapeHtml(buildTribeLabel(tribe))}</option>`
    ).join('');
    select.innerHTML = `<option value="">${escapeHtml(allLabel)}</option>${dynamicOptions}<option value="none">${escapeHtml(noneLabel)}</option>`;
    select.value = currentValue;
  }

  async function loadTribes() {
    if (!ensureAdminAction(false)) return;
    const [catalog, allocationsRes] = await Promise.all([
      loadTribeCatalog(),
      sb.rpc('admin_get_tribe_allocations'),
    ]);
    const data = allocationsRes.data;
    if (!data || data.error) { toast(data?.error || ADMIN_I18N.loadError, 'error'); return; }
    allMembers = data;
    populateAdminTribeFilter(catalog);
    renderTribeCatalogSummary(catalog);

    const active = data.filter((m: any) => m.current_cycle_active);
    const eligible = active.filter((m: any) => ELIGIBLE_ROLES.includes(getMemberRole(m)));
    const pending = eligible.filter((m: any) => !m.selected_tribe_id && !m.fixed_tribe_id);

    document.getElementById('stat-total')!.textContent = String(active.length);
    document.getElementById('stat-active')!.textContent = String(active.length);
    document.getElementById('stat-pending')!.textContent = String(pending.length);

    const cardsEl = document.getElementById('tribe-cards')!;
    let cardsHtml = '';

    for (const tribe of catalog) {
      const t = Number(tribe.id);
      const members = data.filter((m: any) =>
        m.selected_tribe_id === t || (m.fixed_tribe_id === t && getMemberRole(m) === 'tribe_leader')
      );
      const count = members.filter((m: any) => getMemberRole(m) !== 'tribe_leader').length;
      const color = getTribeColor(tribe);
      const pct = Math.round((count / MAX_SLOTS) * 100);
      const full = count >= MAX_SLOTS;
      const isInactive = tribe.is_active === false;
      const statusBadge = isInactive
        ? '<span class="inline-block mt-1 text-[.58rem] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full bg-slate-200 text-slate-600">Inativa</span>'
        : '<span class="inline-block mt-1 text-[.58rem] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">Ativa</span>';
      const leaderName = tribe.leader_name || TRIBE_LEADERS[t] || 'Sem líder';
      const toggleLabel = isInactive ? 'Reativar catálogo' : 'Marcar inativa';
      const toggleClass = isInactive
        ? 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100'
        : 'bg-slate-100 text-slate-600 hover:bg-slate-200';

      cardsHtml += `
      <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between" style="border-left:4px solid ${color}">
          <div>
            <div class="text-[.68rem] font-bold uppercase tracking-wider" style="color:${color}">Tribo ${String(t).padStart(2, '0')}</div>
            <div class="text-sm font-bold text-navy">${escapeHtml(buildTribeLabel(tribe))}</div>
            <div class="text-[.68rem] text-slate-400">${escapeHtml(leaderName)}</div>
            ${statusBadge}
          </div>
          <div class="text-right">
            <div class="text-lg font-black ${full ? 'text-crimson' : 'text-navy'}">${count}/${MAX_SLOTS}</div>
            <div class="w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden mt-1">
              <div class="h-full rounded-full" style="width:${pct}%;background:${full ? '#BE2027' : color}"></div>
            </div>
            ${full ? '<div class="text-[.6rem] font-bold text-crimson mt-0.5">LOTADA</div>' : ''}
          </div>
        </div>
        <div class="p-3 flex flex-wrap gap-2 min-h-[52px]">
          ${members.map((m: any) => `
            <div class="flex items-center gap-1.5 bg-slate-50 rounded-lg px-2 py-1.5 text-[.72rem]" title="${escapeAttr(safeName(m))}">
              ${avatar(m, 'w-6 h-6')}
              <span class="font-medium max-w-[90px] truncate">${(m?.name || '').split(' ').slice(0, 2).join(' ')}</span>
              ${getMemberRole(m) === 'tribe_leader' ? '<span class="text-amber-500">&#x1F451;</span>' : ''}
            </div>
          `).join('')}
          ${members.length === 0 ? '<span class="text-[.72rem] text-slate-300 italic">Nenhum pesquisador</span>' : ''}
        </div>
        <div class="px-3 pb-3 flex items-center gap-2 flex-wrap">
          <button type="button" data-action="toggle-tribe-active" class="btn-tribe-toggle px-3 py-1.5 rounded-lg text-[.7rem] font-semibold border-0 cursor-pointer transition-all ${toggleClass}"
            data-tribe-id="${t}" data-next-active="${isInactive ? 'true' : 'false'}">
            ${toggleLabel}
          </button>
        </div>
      </div>`;
    }
    cardsEl.innerHTML = cardsHtml;
    renderPending(pending);

    // Show notify card for superadmins with allocated members
    const allocatedCount = eligible.filter((m: any) => m.selected_tribe_id || m.fixed_tribe_id).length;
    const notifyCard = document.getElementById('notify-alloc-card');
    if (notifyCard && allocatedCount > 0) {
      notifyCard.style.display = 'flex';
      const summaryEl = document.getElementById('notify-alloc-summary');
      if (summaryEl) summaryEl.textContent = allocatedCount + ' membros alocados em ' + catalog.length + ' tribos';
    }
  }

  async function createTribe() {
    if (!canManageTribeLifecycle(MEMBER)) return;
    const name = (document.getElementById('new-tribe-name') as HTMLInputElement | null)?.value.trim() || '';
    const quadrant = Number((document.getElementById('new-tribe-quadrant') as HTMLSelectElement | null)?.value || '0');
    const quadrantName = (document.getElementById('new-tribe-quadrant-name') as HTMLInputElement | null)?.value.trim() || '';
    const notes = (document.getElementById('new-tribe-notes') as HTMLInputElement | null)?.value.trim() || '';
    const btn = document.getElementById('btn-create-tribe') as HTMLButtonElement | null;
    if (!name || !quadrant || !quadrantName) {
      toast('Preencha nome, quadrante e label do quadrante.', 'error');
      return;
    }
    const original = btn?.textContent || 'Criar Tribo';
    if (btn) { btn.disabled = true; btn.textContent = 'Criando...'; }
    try {
      const { data, error } = await sb.rpc('admin_upsert_tribe', {
        p_name: name,
        p_quadrant: quadrant,
        p_quadrant_name: quadrantName,
        p_notes: notes || null,
        p_is_active: true,
      });
      if (error) throw error;
      toast(`Tribo ${data?.tribe_id || ''} criada com sucesso.`, 'success');
      (document.getElementById('new-tribe-name') as HTMLInputElement).value = '';
      (document.getElementById('new-tribe-quadrant-name') as HTMLInputElement).value = '';
      (document.getElementById('new-tribe-notes') as HTMLInputElement).value = '';
      tribeCatalogCache = [];
      await loadTribes();
    } catch (error: any) {
      toast(ADMIN_I18N.errorPrefix + (error?.message || error), 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = original; }
    }
  }

  async function toggleTribeActive(target: HTMLElement) {
    if (!canManageTribeLifecycle(MEMBER)) return;
    const tribeId = Number(target.dataset.tribeId || '0');
    const nextActive = target.dataset.nextActive === 'true';
    if (!tribeId) return;
    const confirmMsg = nextActive
      ? 'Reativar esta tribo no catálogo atual?'
      : 'Marcar esta tribo como inativa no catálogo atual?';
    if (!confirm(confirmMsg)) return;
    const btn = target as HTMLButtonElement;
    const original = btn.textContent || '';
    btn.disabled = true;
    btn.textContent = nextActive ? 'Reativando...' : 'Inativando...';
    try {
      const { error } = await sb.rpc('admin_set_tribe_active', {
        p_tribe_id: tribeId,
        p_is_active: nextActive,
        p_reason: nextActive ? 'Catálogo reativado' : 'Catálogo marcado como inativo',
      });
      if (error) throw error;
      toast(nextActive ? 'Tribo reativada no catálogo.' : 'Tribo marcada como inativa.', 'success');
      tribeCatalogCache = [];
      await loadTribes();
    } catch (error: any) {
      toast(ADMIN_I18N.errorPrefix + (error?.message || error), 'error');
      btn.disabled = false;
      btn.textContent = original;
    }
  }

