---
import AdminLayout from '../../layouts/AdminLayout.astro';
import VepReconciliationIsland from '../../components/admin/VepReconciliationIsland';
import Toast from '../../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---

<AdminLayout
  title={t('admin.breadcrumb.vepReconciliation', lang)}
  breadcrumbs={[
    { label: t('admin.breadcrumb.system', lang) },
    { label: t('admin.breadcrumb.vepReconciliation', lang) },
  ]}
>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <VepReconciliationIsland client:load lang={lang} />
  </div>
  <Toast />
</AdminLayout>

<script is:inline define:vars={{ deniedMsg: t('admin.deniedAdmin', lang) }}>
  document.addEventListener('DOMContentLoaded', () => {
    const check = () => {
      const member = window.navGetMember?.();
      if (!member) { setTimeout(check, 300); return; }
      const isAdmin = member.is_superadmin
        || ['manager', 'deputy_manager', 'tribe_leader', 'comms_leader', 'sponsor', 'chapter_liaison'].includes(member.operational_role)
        || (member.designations || []).some(function(d) { return d === 'deputy_manager' || d === 'curator'; });
      if (!isAdmin) {
        document.querySelector('.max-w-\\[1100px\\]').innerHTML = '<div class="text-center py-20 text-[var(--text-muted)]">' + deniedMsg + '</div>';
      }
    };
    check();
  });
</script>
