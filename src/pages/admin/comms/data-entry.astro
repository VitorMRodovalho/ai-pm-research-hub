---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('admin.comms.entry.meta', lang)} activePage="admin">
  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <div class="mb-6 flex items-start justify-between gap-3 flex-wrap">
      <div>
        <h1 class="text-2xl font-extrabold text-navy">{t('admin.comms.entry.title', lang)}</h1>
        <p class="text-sm text-slate-500">{t('admin.comms.entry.subtitle', lang)}</p>
      </div>
      <a href="/admin/comms" class="inline-flex items-center px-3 py-2 bg-white border border-slate-200 rounded-lg text-[.78rem] font-semibold text-slate-600 no-underline hover:bg-slate-50 transition-all">
        {t('admin.comms.entry.backComms', lang)}
      </a>
    </div>

    <div id="entry-loading" class="text-center py-10 text-slate-400">{t('admin.comms.loading', lang)}</div>

    <div id="entry-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">{t('admin.comms.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('admin.comms.backAdmin', lang)}
      </a>
    </div>

    <section id="entry-panel" class="hidden space-y-4">
      <div class="bg-white border border-slate-200 rounded-xl p-5">
        <div class="flex items-start justify-between gap-3 flex-wrap mb-4">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.comms.entry.formTitle', lang)}</h2>
            <p class="text-[.72rem] text-slate-500">{t('admin.comms.entry.formSubtitle', lang)}</p>
          </div>
          <div class="flex gap-2">
            <button id="btn-today" class="px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-[.72rem] font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all">{t('admin.comms.entry.today', lang)}</button>
            <button id="btn-yesterday" class="px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-[.72rem] font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all">{t('admin.comms.entry.yesterday', lang)}</button>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.date', lang)}</label>
            <input type="date" id="entry-date" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem]" />
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.channel', lang)}</label>
            <select id="entry-channel" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] bg-white">
              <option value="linkedin">LinkedIn</option>
              <option value="instagram">Instagram</option>
              <option value="youtube">YouTube</option>
              <option value="newsletter">Newsletter</option>
              <option value="website">Website</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.source', lang)}</label>
            <input type="text" id="entry-source" value="manual_admin" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] bg-slate-50 text-slate-600" readonly />
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.kpiAudience', lang)}</label>
            <input type="number" id="entry-audience" min="0" step="1" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem]" placeholder="0" />
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.kpiReach', lang)}</label>
            <input type="number" id="entry-reach" min="0" step="1" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem]" placeholder="0" />
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.kpiEngagement', lang)}</label>
            <input type="number" id="entry-engagement" min="0" max="1" step="0.0001" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem]" placeholder="0.0000" />
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.kpiLeads', lang)}</label>
            <input type="number" id="entry-leads" min="0" step="1" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem]" placeholder="0" />
          </div>
        </div>

        <div class="flex flex-wrap gap-2">
          <button id="btn-load" class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-[.78rem] font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all">{t('admin.comms.entry.load', lang)}</button>
          <button id="btn-save" class="px-4 py-2 bg-teal text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">{t('admin.comms.entry.save', lang)}</button>
          <button id="btn-delete" class="px-4 py-2 bg-white border border-amber-300 text-amber-700 rounded-lg text-[.78rem] font-semibold cursor-pointer hover:bg-amber-50 transition-all">{t('admin.comms.entry.delete', lang)}</button>
          <span id="entry-status" class="text-[.72rem] text-slate-500 self-center"></span>
        </div>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-5">
        <div class="flex items-start justify-between gap-3 flex-wrap mb-3">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.comms.entry.csvTitle', lang)}</h2>
            <p class="text-[.72rem] text-slate-500">{t('admin.comms.entry.csvSubtitle', lang)}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
          <div class="md:col-span-2">
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.csvFile', lang)}</label>
            <input type="file" id="csv-file" accept=".csv,text/csv" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] bg-white" />
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.source', lang)}</label>
            <input type="text" id="csv-source" value="manual_csv" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] bg-slate-50 text-slate-600" readonly />
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mb-3">
          <button id="btn-csv-preview" class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-[.78rem] font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all">{t('admin.comms.entry.csvPreview', lang)}</button>
          <button id="btn-csv-publish" class="px-4 py-2 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">{t('admin.comms.entry.csvPublish', lang)}</button>
          <span id="csv-status" class="text-[.72rem] text-slate-500 self-center"></span>
        </div>
        <div id="csv-summary" class="text-[.72rem] text-slate-500 mb-3"></div>
        <div class="overflow-x-auto border border-slate-200 rounded-lg">
          <table class="w-full text-[.72rem]">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.date', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.channel', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiAudience', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiReach', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiEngagement', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiLeads', lang)}</th>
              </tr>
            </thead>
            <tbody id="csv-preview-body">
              <tr><td colspan="6" class="px-3 py-5 text-center text-slate-400">{t('admin.comms.entry.csvEmpty', lang)}</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl p-5">
        <div class="flex items-start justify-between gap-3 flex-wrap mb-3">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.comms.entry.publishTitle', lang)}</h2>
            <p class="text-[.72rem] text-slate-500">{t('admin.comms.entry.publishSubtitle', lang)}</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.source', lang)}</label>
            <select id="publish-source" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] bg-white">
              <option value="manual_csv">manual_csv</option>
              <option value="manual_admin">manual_admin</option>
            </select>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-slate-500 block mb-1">{t('admin.comms.entry.publishDate', lang)}</label>
            <select id="publish-date" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[.78rem] bg-white"></select>
          </div>
          <div class="flex items-end gap-2">
            <button id="btn-publish-refresh" class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-[.78rem] font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all">
              {t('admin.comms.entry.publishRefresh', lang)}
            </button>
            <button id="btn-publish-run" class="px-4 py-2 bg-emerald-600 text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
              {t('admin.comms.entry.publishRun', lang)}
            </button>
          </div>
        </div>
        <div id="publish-status" class="text-[.72rem] text-slate-500 mb-3"></div>
        <div class="overflow-x-auto border border-slate-200 rounded-lg">
          <table class="w-full text-[.72rem]">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.publishDate', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.source', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.entry.publishPendingRows', lang)}</th>
              </tr>
            </thead>
            <tbody id="publish-pending-body">
              <tr><td colspan="3" class="px-3 py-5 text-center text-slate-400">{t('common.loading', lang)}</td></tr>
            </tbody>
          </table>
        </div>
        <div class="mt-3 overflow-x-auto border border-slate-200 rounded-lg">
          <table class="w-full text-[.72rem]">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.publishBatch', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.source', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.publishDate', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.entry.publishRows', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.kpiUpdatedAt', lang)}</th>
              </tr>
            </thead>
            <tbody id="publish-log-body">
              <tr><td colspan="5" class="px-3 py-5 text-center text-slate-400">{t('common.loading', lang)}</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-200 flex items-center justify-between gap-2 flex-wrap">
          <div>
            <h3 class="text-sm font-bold text-navy">{t('admin.comms.entry.recentTitle', lang)}</h3>
            <p class="text-[.68rem] text-slate-400">{t('admin.comms.entry.recentSubtitle', lang)}</p>
          </div>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-[.72rem]">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.date', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.channel', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiAudience', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiReach', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiEngagement', lang)}</th>
                <th class="px-3 py-2 text-right font-semibold text-slate-500">{t('admin.comms.kpiLeads', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.entry.source', lang)}</th>
                <th class="px-3 py-2 text-left font-semibold text-slate-500">{t('admin.comms.kpiUpdatedAt', lang)}</th>
              </tr>
            </thead>
            <tbody id="entry-recent-body">
              <tr><td colspan="8" class="px-3 py-5 text-center text-slate-400">{t('common.loading', lang)}</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  import { canAccessAdminRoute } from '../../../lib/admin/constants';

  const SOURCE = 'manual_admin';
  const MSG = {
    loaded: "{t('admin.comms.entry.loaded', lang)}",
    noRows: "{t('admin.comms.entry.noRows', lang)}",
    saved: "{t('admin.comms.entry.saved', lang)}",
    deleted: "{t('admin.comms.entry.deleted', lang)}",
    loadError: "{t('admin.comms.entry.loadError', lang)}",
    saveError: "{t('admin.comms.entry.saveError', lang)}",
    deleteError: "{t('admin.comms.entry.deleteError', lang)}",
    confirmDelete: "{t('admin.comms.entry.confirmDelete', lang)}",
    csvNoFile: "{t('admin.comms.entry.csvNoFile', lang)}",
    csvParseError: "{t('admin.comms.entry.csvParseError', lang)}",
    csvPreviewReady: "{t('admin.comms.entry.csvPreviewReady', lang)}",
    csvPublishSuccess: "{t('admin.comms.entry.csvPublishSuccess', lang)}",
    csvPublishError: "{t('admin.comms.entry.csvPublishError', lang)}",
    csvNothingToPublish: "{t('admin.comms.entry.csvNothingToPublish', lang)}",
    publishNoDate: "{t('admin.comms.entry.publishNoDate', lang)}",
    publishSuccess: "{t('admin.comms.entry.publishSuccess', lang)}",
    publishError: "{t('admin.comms.entry.publishError', lang)}",
    publishNothing: "{t('admin.comms.entry.publishNothing', lang)}",
  };

  let sb: any = null;
  let MEMBER: any = null;
  let csvValidRows: any[] = [];
  let csvInvalidRows: string[] = [];
  let pendingPublishRows: any[] = [];

  function allowComms(m: any): boolean {
    return canAccessAdminRoute(m, 'admin_analytics');
  }

  function toDateInput(d: Date): string {
    return d.toISOString().slice(0, 10);
  }

  function readValue(id: string): string {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
    return el?.value?.trim?.() || '';
  }

  function setValue(id: string, value: any) {
    const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
    if (!el) return;
    el.value = value === null || value === undefined ? '' : String(value);
  }

  function setStatus(text: string, error = false) {
    const el = document.getElementById('entry-status');
    if (!el) return;
    el.textContent = text;
    el.className = error ? 'text-[.72rem] text-crimson self-center' : 'text-[.72rem] text-slate-500 self-center';
  }

  function setCsvStatus(text: string, error = false) {
    const el = document.getElementById('csv-status');
    if (!el) return;
    el.textContent = text;
    el.className = error ? 'text-[.72rem] text-crimson self-center' : 'text-[.72rem] text-slate-500 self-center';
  }

  function setPublishStatus(text: string, error = false) {
    const el = document.getElementById('publish-status');
    if (!el) return;
    el.textContent = text;
    el.className = error ? 'text-[.72rem] text-crimson mb-3' : 'text-[.72rem] text-slate-500 mb-3';
  }

  function asNumber(v: string, decimals = false): number {
    if (!v) return 0;
    const n = Number(v.replace(',', '.'));
    if (!Number.isFinite(n)) return 0;
    return decimals ? n : Math.trunc(n);
  }

  function parseCsvLine(line: string): string[] {
    const out: string[] = [];
    let current = '';
    let quoted = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"') {
        if (quoted && line[i + 1] === '"') {
          current += '"';
          i += 1;
        } else {
          quoted = !quoted;
        }
        continue;
      }
      if (ch === ',' && !quoted) {
        out.push(current.trim());
        current = '';
        continue;
      }
      current += ch;
    }
    out.push(current.trim());
    return out;
  }

  function parseCsvContent(content: string) {
    const lines = content.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
    if (lines.length < 2) return { valid: [], invalid: ['empty_file'] };

    const headers = parseCsvLine(lines[0]).map((h) => h.trim().toLowerCase());
    const idx = {
      metric_date: headers.findIndex((h) => ['metric_date', 'date'].includes(h)),
      channel: headers.findIndex((h) => ['channel', 'platform', 'network'].includes(h)),
      audience: headers.findIndex((h) => ['audience', 'followers', 'subscribers'].includes(h)),
      reach: headers.findIndex((h) => ['reach', 'impressions'].includes(h)),
      engagement: headers.findIndex((h) => ['engagement_rate', 'engagement', 'engagementrate'].includes(h)),
      leads: headers.findIndex((h) => ['leads', 'conversions'].includes(h)),
    };

    if (idx.metric_date < 0 || idx.channel < 0) return { valid: [], invalid: ['missing_required_headers'] };

    const valid: any[] = [];
    const invalid: string[] = [];

    for (let i = 1; i < lines.length; i++) {
      const cols = parseCsvLine(lines[i]);
      const metricDate = String(cols[idx.metric_date] || '').trim();
      const channel = String(cols[idx.channel] || '').trim().toLowerCase();
      if (!metricDate || !/^\d{4}-\d{2}-\d{2}$/.test(metricDate) || !channel) {
        invalid.push(`line_${i + 1}`);
        continue;
      }
      valid.push({
        metric_date: metricDate,
        channel,
        audience: asNumber(String(cols[idx.audience] || '0')),
        reach: asNumber(String(cols[idx.reach] || '0')),
        engagement_rate: Number(asNumber(String(cols[idx.engagement] || '0'), true).toFixed(4)),
        leads: asNumber(String(cols[idx.leads] || '0')),
      });
    }

    return { valid, invalid };
  }

  function renderCsvPreview() {
    const body = document.getElementById('csv-preview-body');
    const summary = document.getElementById('csv-summary');
    if (!body || !summary) return;

    if (!csvValidRows.length) {
      body.innerHTML = `<tr><td colspan="6" class="px-3 py-5 text-center text-slate-400">{t('admin.comms.entry.csvEmpty', lang)}</td></tr>`;
    } else {
      body.innerHTML = csvValidRows.slice(0, 20).map((r) => `
        <tr class="border-t border-slate-100">
          <td class="px-3 py-2 text-slate-700">${r.metric_date}</td>
          <td class="px-3 py-2 text-slate-700">${r.channel}</td>
          <td class="px-3 py-2 text-right text-slate-700">${Number(r.audience || 0).toLocaleString('pt-BR')}</td>
          <td class="px-3 py-2 text-right text-slate-700">${Number(r.reach || 0).toLocaleString('pt-BR')}</td>
          <td class="px-3 py-2 text-right text-slate-700">${Number(r.engagement_rate || 0).toFixed(4)}</td>
          <td class="px-3 py-2 text-right text-slate-700">${Number(r.leads || 0).toLocaleString('pt-BR')}</td>
        </tr>
      `).join('');
    }

    summary.textContent = `${csvValidRows.length} valid · ${csvInvalidRows.length} invalid`;
  }

  function showDenied() {
    document.getElementById('entry-loading')?.classList.add('hidden');
    document.getElementById('entry-denied')?.classList.remove('hidden');
    document.getElementById('entry-panel')?.classList.add('hidden');
  }

  function showPanel() {
    document.getElementById('entry-loading')?.classList.add('hidden');
    document.getElementById('entry-denied')?.classList.add('hidden');
    document.getElementById('entry-panel')?.classList.remove('hidden');
  }

  function renderRecent(rows: any[]) {
    const body = document.getElementById('entry-recent-body');
    if (!body) return;
    if (!rows.length) {
      body.innerHTML = `<tr><td colspan="8" class="px-3 py-5 text-center text-slate-400">${MSG.noRows}</td></tr>`;
      return;
    }

    body.innerHTML = rows.map((r) => {
      const updated = r.updated_at ? new Date(r.updated_at).toLocaleString('pt-BR') : '—';
      const engagement = typeof r.engagement_rate === 'number' ? r.engagement_rate.toFixed(4) : (r.engagement_rate ?? '—');
      return `<tr class="border-t border-slate-100">
        <td class="px-3 py-2 text-slate-700">${r.metric_date || '—'}</td>
        <td class="px-3 py-2 text-slate-700">${r.channel || '—'}</td>
        <td class="px-3 py-2 text-right text-slate-700">${Number(r.audience || 0).toLocaleString('pt-BR')}</td>
        <td class="px-3 py-2 text-right text-slate-700">${Number(r.reach || 0).toLocaleString('pt-BR')}</td>
        <td class="px-3 py-2 text-right text-slate-700">${engagement}</td>
        <td class="px-3 py-2 text-right text-slate-700">${Number(r.leads || 0).toLocaleString('pt-BR')}</td>
        <td class="px-3 py-2 text-slate-500">${r.source || '—'}</td>
        <td class="px-3 py-2 text-slate-500">${updated}</td>
      </tr>`;
    }).join('');
  }

  function renderPendingPublishTable(rows: any[]) {
    const body = document.getElementById('publish-pending-body');
    const dateSelect = document.getElementById('publish-date') as HTMLSelectElement | null;
    if (!body || !dateSelect) return;

    if (!rows.length) {
      body.innerHTML = `<tr><td colspan="3" class="px-3 py-5 text-center text-slate-400">${MSG.publishNothing}</td></tr>`;
      dateSelect.innerHTML = '';
      return;
    }

    body.innerHTML = rows.map((r) => `
      <tr class="border-t border-slate-100">
        <td class="px-3 py-2 text-slate-700">${r.metric_date}</td>
        <td class="px-3 py-2 text-slate-700">${r.source}</td>
        <td class="px-3 py-2 text-right text-slate-700">${Number(r.rows_count || 0).toLocaleString('pt-BR')}</td>
      </tr>
    `).join('');

    const currentSource = (document.getElementById('publish-source') as HTMLSelectElement | null)?.value || 'manual_csv';
    const filtered = rows.filter((r) => r.source === currentSource);
    dateSelect.innerHTML = filtered
      .map((r) => `<option value="${r.metric_date}">${r.metric_date}</option>`)
      .join('');
  }

  function renderPublishLog(rows: any[]) {
    const body = document.getElementById('publish-log-body');
    if (!body) return;
    if (!rows.length) {
      body.innerHTML = `<tr><td colspan="5" class="px-3 py-5 text-center text-slate-400">${MSG.noRows}</td></tr>`;
      return;
    }
    body.innerHTML = rows.map((r) => {
      const createdAt = r.created_at ? new Date(r.created_at).toLocaleString('pt-BR') : '—';
      return `<tr class="border-t border-slate-100">
        <td class="px-3 py-2 text-slate-700 font-mono">${r.batch_id || '—'}</td>
        <td class="px-3 py-2 text-slate-700">${r.source || '—'}</td>
        <td class="px-3 py-2 text-slate-700">${r.target_date || '—'}</td>
        <td class="px-3 py-2 text-right text-slate-700">${Number(r.published_rows || 0).toLocaleString('pt-BR')}</td>
        <td class="px-3 py-2 text-slate-500">${createdAt}</td>
      </tr>`;
    }).join('');
  }

  async function loadCurrentSelection() {
    if (!sb) return;
    const date = readValue('entry-date');
    const channel = readValue('entry-channel');
    if (!date || !channel) return;

    try {
      const { data, error } = await sb
        .from('comms_metrics_daily')
        .select('metric_date, channel, audience, reach, engagement_rate, leads, source, updated_at')
        .eq('metric_date', date)
        .eq('channel', channel)
        .eq('source', SOURCE)
        .maybeSingle();

      if (error) throw error;

      setValue('entry-audience', data?.audience ?? '');
      setValue('entry-reach', data?.reach ?? '');
      setValue('entry-engagement', data?.engagement_rate ?? '');
      setValue('entry-leads', data?.leads ?? '');
      setStatus(data ? MSG.loaded : MSG.noRows, false);
    } catch (e: any) {
      setStatus(`${MSG.loadError} ${e?.message || ''}`.trim(), true);
    }

    await refreshRecentRows();
  }

  async function refreshRecentRows() {
    if (!sb) return;
    try {
      const { data, error } = await sb
        .from('comms_metrics_daily')
        .select('metric_date, channel, audience, reach, engagement_rate, leads, source, updated_at')
        .in('source', [SOURCE, 'manual_csv'])
        .order('metric_date', { ascending: false })
        .order('updated_at', { ascending: false })
        .limit(30);
      if (error) throw error;
      renderRecent(data || []);
    } catch {
      renderRecent([]);
    }
  }

  async function refreshPublishData() {
    if (!sb) return;
    try {
      const { data: pendingRows, error: pendingError } = await sb
        .from('comms_metrics_daily')
        .select('metric_date, source')
        .is('published_at', null)
        .in('source', ['manual_csv', 'manual_admin'])
        .order('metric_date', { ascending: false })
        .limit(300);
      if (pendingError) throw pendingError;

      const grouped = new Map<string, { metric_date: string; source: string; rows_count: number }>();
      (pendingRows || []).forEach((row: any) => {
        const key = `${row.metric_date}::${row.source}`;
        const prev = grouped.get(key);
        if (prev) {
          prev.rows_count += 1;
        } else {
          grouped.set(key, { metric_date: String(row.metric_date || ''), source: String(row.source || ''), rows_count: 1 });
        }
      });
      pendingPublishRows = Array.from(grouped.values()).sort((a, b) => (a.metric_date < b.metric_date ? 1 : -1));
      renderPendingPublishTable(pendingPublishRows);
    } catch {
      pendingPublishRows = [];
      renderPendingPublishTable([]);
    }

    try {
      const { data: logRows, error: logError } = await sb
        .from('comms_metrics_publish_log')
        .select('batch_id, source, target_date, published_rows, created_at')
        .order('created_at', { ascending: false })
        .limit(20);
      if (logError) throw logError;
      renderPublishLog(logRows || []);
    } catch {
      renderPublishLog([]);
    }
  }

  async function saveEntry() {
    if (!sb || !MEMBER) return;

    const metricDate = readValue('entry-date');
    const channel = readValue('entry-channel');
    if (!metricDate || !channel) {
      setStatus(MSG.loadError, true);
      return;
    }

    const row = {
      metric_date: metricDate,
      channel,
      audience: asNumber(readValue('entry-audience')),
      reach: asNumber(readValue('entry-reach')),
      engagement_rate: asNumber(readValue('entry-engagement'), true),
      leads: asNumber(readValue('entry-leads')),
      source: SOURCE,
      created_by: MEMBER.id,
      payload: {
        origin: 'admin_data_entry',
        actor_member_id: MEMBER.id,
        updated_at: new Date().toISOString(),
      },
    };

    try {
      const { error } = await sb.from('comms_metrics_daily').upsert(row, { onConflict: 'metric_date,channel,source' });
      if (error) throw error;
      (window as any).toast?.(MSG.saved, 'success');
      setStatus(MSG.saved, false);
      await refreshRecentRows();
    } catch (e: any) {
      setStatus(`${MSG.saveError} ${e?.message || ''}`.trim(), true);
    }
  }

  async function deleteEntry() {
    if (!sb) return;
    const metricDate = readValue('entry-date');
    const channel = readValue('entry-channel');
    if (!metricDate || !channel) return;
    if (!confirm(MSG.confirmDelete)) return;

    try {
      const { error } = await sb
        .from('comms_metrics_daily')
        .delete()
        .eq('metric_date', metricDate)
        .eq('channel', channel)
        .eq('source', SOURCE);
      if (error) throw error;
      setValue('entry-audience', '');
      setValue('entry-reach', '');
      setValue('entry-engagement', '');
      setValue('entry-leads', '');
      setStatus(MSG.deleted, false);
      (window as any).toast?.(MSG.deleted, 'success');
      await refreshRecentRows();
    } catch (e: any) {
      setStatus(`${MSG.deleteError} ${e?.message || ''}`.trim(), true);
    }
  }

  async function previewCsv() {
    const fileEl = document.getElementById('csv-file') as HTMLInputElement | null;
    const file = fileEl?.files?.[0];
    if (!file) {
      setCsvStatus(MSG.csvNoFile, true);
      return;
    }

    try {
      const text = await file.text();
      const parsed = parseCsvContent(text);
      csvValidRows = parsed.valid;
      csvInvalidRows = parsed.invalid;
      renderCsvPreview();
      setCsvStatus(MSG.csvPreviewReady, false);
    } catch (e: any) {
      csvValidRows = [];
      csvInvalidRows = [];
      renderCsvPreview();
      setCsvStatus(`${MSG.csvParseError} ${e?.message || ''}`.trim(), true);
    }
  }

  async function publishCsv() {
    if (!sb || !MEMBER) return;
    if (!csvValidRows.length) {
      setCsvStatus(MSG.csvNothingToPublish, true);
      return;
    }

    const source = readValue('csv-source') || 'manual_csv';
    const rows = csvValidRows.map((r) => ({
      ...r,
      source,
      created_by: MEMBER.id,
      payload: {
        origin: 'admin_csv_import',
        actor_member_id: MEMBER.id,
        updated_at: new Date().toISOString(),
      },
    }));

    try {
      const { error } = await sb.from('comms_metrics_daily').upsert(rows, { onConflict: 'metric_date,channel,source' });
      if (error) throw error;
      setCsvStatus(MSG.csvPublishSuccess, false);
      (window as any).toast?.(MSG.csvPublishSuccess, 'success');
      await refreshRecentRows();
    } catch (e: any) {
      setCsvStatus(`${MSG.csvPublishError} ${e?.message || ''}`.trim(), true);
    }
  }

  async function publishSelectedBatch() {
    if (!sb) return;
    const sourceEl = document.getElementById('publish-source') as HTMLSelectElement | null;
    const dateEl = document.getElementById('publish-date') as HTMLSelectElement | null;
    const source = sourceEl?.value || 'manual_csv';
    const metricDate = dateEl?.value || '';
    if (!metricDate) {
      setPublishStatus(MSG.publishNoDate, true);
      return;
    }

    try {
      const { data, error } = await sb.rpc('publish_comms_metrics_batch', {
        p_source: source,
        p_metric_date: metricDate,
      });
      if (error) throw error;
      const row = Array.isArray(data) ? data[0] : data;
      const rows = Number(row?.published_rows || 0);
      setPublishStatus(`${MSG.publishSuccess} (${rows})`, false);
      (window as any).toast?.(`${MSG.publishSuccess} (${rows})`, 'success');
      await refreshRecentRows();
      await refreshPublishData();
    } catch (e: any) {
      setPublishStatus(`${MSG.publishError} ${e?.message || ''}`.trim(), true);
    }
  }

  function bindButtons() {
    const todayBtn = document.getElementById('btn-today');
    const yBtn = document.getElementById('btn-yesterday');
    const loadBtn = document.getElementById('btn-load');
    const saveBtn = document.getElementById('btn-save');
    const deleteBtn = document.getElementById('btn-delete');
    const csvPreviewBtn = document.getElementById('btn-csv-preview');
    const csvPublishBtn = document.getElementById('btn-csv-publish');
    const publishRefreshBtn = document.getElementById('btn-publish-refresh');
    const publishRunBtn = document.getElementById('btn-publish-run');
    const publishSourceEl = document.getElementById('publish-source') as HTMLSelectElement | null;

    if (todayBtn && !todayBtn.dataset.bound) {
      todayBtn.dataset.bound = '1';
      todayBtn.addEventListener('click', () => setValue('entry-date', toDateInput(new Date())));
    }
    if (yBtn && !yBtn.dataset.bound) {
      yBtn.dataset.bound = '1';
      yBtn.addEventListener('click', () => {
        const d = new Date();
        d.setDate(d.getDate() - 1);
        setValue('entry-date', toDateInput(d));
      });
    }
    if (loadBtn && !loadBtn.dataset.bound) {
      loadBtn.dataset.bound = '1';
      loadBtn.addEventListener('click', () => { void loadCurrentSelection(); });
    }
    if (saveBtn && !saveBtn.dataset.bound) {
      saveBtn.dataset.bound = '1';
      saveBtn.addEventListener('click', () => { void saveEntry(); });
    }
    if (deleteBtn && !deleteBtn.dataset.bound) {
      deleteBtn.dataset.bound = '1';
      deleteBtn.addEventListener('click', () => { void deleteEntry(); });
    }
    if (csvPreviewBtn && !csvPreviewBtn.dataset.bound) {
      csvPreviewBtn.dataset.bound = '1';
      csvPreviewBtn.addEventListener('click', () => { void previewCsv(); });
    }
    if (csvPublishBtn && !csvPublishBtn.dataset.bound) {
      csvPublishBtn.dataset.bound = '1';
      csvPublishBtn.addEventListener('click', () => { void publishCsv(); });
    }
    if (publishRefreshBtn && !publishRefreshBtn.dataset.bound) {
      publishRefreshBtn.dataset.bound = '1';
      publishRefreshBtn.addEventListener('click', () => { void refreshPublishData(); });
    }
    if (publishRunBtn && !publishRunBtn.dataset.bound) {
      publishRunBtn.dataset.bound = '1';
      publishRunBtn.addEventListener('click', () => { void publishSelectedBatch(); });
    }
    if (publishSourceEl && !publishSourceEl.dataset.bound) {
      publishSourceEl.dataset.bound = '1';
      publishSourceEl.addEventListener('change', () => {
        renderPendingPublishTable(pendingPublishRows);
      });
    }
  }

  async function applyGate(m: any) {
    if (m && allowComms(m)) {
      MEMBER = m;
      showPanel();
      bindButtons();
      setValue('entry-date', toDateInput(new Date()));
      await refreshRecentRows();
      await refreshPublishData();
      return;
    }
    showDenied();
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) void applyGate(e.detail);
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) { await applyGate(m); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        await applyGate(data);
        return;
      }
    } catch {}

    showDenied();
  }

  boot();
</script>
