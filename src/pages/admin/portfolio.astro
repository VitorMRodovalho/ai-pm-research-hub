---
import AdminLayout from '../../layouts/AdminLayout.astro';
import PortfolioDashboard from '../../components/portfolio/PortfolioDashboard';
import PlannedVsActualSection from '../../components/portfolio/PlannedVsActualSection';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<AdminLayout title={t('nav.adminPortfolio', lang)} breadcrumbs={[{label:'Relatórios'},{label:'Portfólio Executivo'}]}>
  <div class="max-w-[1100px] mx-auto px-4 py-8 space-y-4">
    <!-- W142: GP Portfolio Dashboard (React island) -->
    <section class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
      <h2 class="text-lg font-extrabold text-navy mb-1">{t('portfolio.title', lang)}</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-4">{t('portfolio.subtitle', lang)}</p>
      <PortfolioDashboard client:load />
    </section>

    <!-- Planned vs Actual -->
    <section class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
      <h2 class="text-lg font-extrabold text-navy mb-1">Planejado × Realizado</h2>
      <p class="text-xs text-[var(--text-secondary)] mb-4">Performance por tribo — entregáveis planejados vs concluídos, SPI e desvio médio.</p>
      <PlannedVsActualSection client:load />
    </section>

    <div id="portfolio-loading" class="text-[var(--text-muted)] text-sm">{t('portfolio.loading', lang)}</div>
    <div id="portfolio-denied" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800 text-sm">
      {t('portfolio.denied', lang)}
    </div>
    <section id="portfolio-panel" class="hidden rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
      <h1 class="text-xl font-extrabold text-navy mb-3">{t('portfolio.title', lang)}</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-4">{t('portfolio.subtitle', lang)}</p>
      <div id="portfolio-macros" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 mb-4"></div>
      <div class="flex flex-wrap gap-2 mb-4">
        <button id="portfolio-run-taxonomy-alerts" class="px-3 py-2 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-xs font-semibold hover:bg-[var(--surface-hover)]">{t('portfolio.runTaxonomy', lang)}</button>
        <button id="portfolio-run-sanity" class="px-3 py-2 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-xs font-semibold hover:bg-[var(--surface-hover)]">{t('portfolio.runSanity', lang)}</button>
      </div>
      <div id="portfolio-summary" class="space-y-5"></div>
    </section>

    <!-- KPI Health Section (W104) -->
    <section id="kpi-health-panel" class="hidden rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-extrabold text-navy">{t('portfolio.kpiHealth.title', lang)}</h2>
          <p class="text-xs text-[var(--text-secondary)]">{t('portfolio.kpiHealth.subtitle', lang)}</p>
        </div>
      </div>
      <div id="kpi-health-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"></div>
    </section>

    <!-- Active Boards List (W139) -->
    <section id="boards-list-panel" class="hidden rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
      <h2 class="text-lg font-extrabold text-navy mb-3">{t('portfolio.activeBoards', lang)}</h2>
      <div id="boards-list-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"></div>
    </section>
  </div>
</AdminLayout>

<script>
  import { hasPermission } from '../../lib/permissions';

  let portfolioBootRetries = 0;

  function hasPortfolioAccess(member: any): boolean {
    if (!member) return false;
    return hasPermission(member, 'admin.portfolio');
  }

  function cardHtml(entry: any): string {
    const hasNoActiveCards = Number(entry.total_cards || 0) === 0;
    const overdueClass = Number(entry.overdue_cards || 0) > 0 ? 'text-red-600 font-bold' : 'text-[var(--text-secondary)]';
    return `
      <article class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-base)] p-3">
        <div class="text-xs font-bold uppercase tracking-wide text-[var(--text-secondary)]">${entry.board_scope} · ${entry.domain_key} ${hasNoActiveCards ? '<span class="ml-1 text-amber-600">⚠️</span>' : ''}</div>
        <div class="mt-1 text-sm text-[var(--text-primary)]">Cards: <strong>${entry.total_cards || 0}</strong></div>
        <div class="text-xs text-[var(--text-secondary)] mt-1">Atrasados: <span class="${overdueClass}">${entry.overdue_cards || 0}</span> · Órfãos: ${entry.orphan_cards || 0}</div>
      </article>
    `;
  }

  function macroHtml(title: string, value: string | number, accentClass = 'text-[var(--text-primary)]'): string {
    return `
      <article class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-base)] p-3">
        <div class="text-[11px] uppercase tracking-wide font-semibold text-[var(--text-secondary)]">${title}</div>
        <div class="text-2xl font-extrabold ${accentClass}">${value}</div>
      </article>
    `;
  }

  function toMacroCounts(rows: any[]) {
    const totalOverdue = rows.reduce((sum, row) => sum + Number(row?.overdue_cards || 0), 0);
    const totalBoardsOperating = rows.length;
    return { totalOverdue, totalBoardsOperating };
  }

  function classifyBlock(row: any): 'research' | 'operations' | 'global' {
    const scope = String(row?.board_scope || '');
    const domain = String(row?.domain_key || '');
    if (scope === 'global' || domain.includes('publications') || domain.includes('governance')) return 'global';
    if (scope === 'operational' || domain.includes('communication') || domain.includes('webinar')) return 'operations';
    return 'research';
  }

  function sectionHtml(title: string, rows: any[]): string {
    return `
      <section>
        <h2 class="text-sm font-bold uppercase tracking-wide text-[var(--text-secondary)] mb-2">${title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">${rows.map((row: any) => cardHtml(row)).join('')}</div>
      </section>
    `;
  }

  async function bootPortfolioPage() {
    const loading = document.getElementById('portfolio-loading');
    const denied = document.getElementById('portfolio-denied');
    const panel = document.getElementById('portfolio-panel');
    const summary = document.getElementById('portfolio-summary');
    const macros = document.getElementById('portfolio-macros');
    const member = (window as any).navGetMember?.();
    const sb = (window as any).navGetSb?.();

    if (!member || !sb) {
      portfolioBootRetries += 1;
      if (portfolioBootRetries >= 20) {
        loading?.classList.add('hidden');
        denied?.classList.remove('hidden');
        denied!.textContent = 'Acesso restrito a administração e audiência executiva.';
        return;
      }
      setTimeout(() => bootPortfolioPage(), 150);
      return;
    }
    loading?.classList.add('hidden');
    if (!hasPortfolioAccess(member)) {
      denied?.classList.remove('hidden');
      return;
    }

    const [{ data, error }, membersQuery, tribesQuery] = await Promise.all([
      sb.rpc('exec_portfolio_board_summary', { p_include_inactive: false }),
      sb.from('public_members').select('member_id', { count: 'exact', head: true }).eq('current_cycle_active', true),
      sb.from('tribes').select('id', { count: 'exact', head: true }).eq('is_active', true),
    ]);
    if (error) {
      denied?.classList.remove('hidden');
      denied!.textContent = 'Falha ao carregar visão executiva de portfólio.';
      return;
    }
    const rows = Array.isArray(data?.by_lane) ? data.by_lane : [];
    const grouped = rows.reduce((acc: any, row: any) => {
      const key = classifyBlock(row);
      acc[key].push(row);
      return acc;
    }, { research: [], operations: [], global: [] });
    const { totalOverdue, totalBoardsOperating } = toMacroCounts(rows);
    const totalMembers = Number(membersQuery?.count || 0);
    const totalTribes = Number(tribesQuery?.count || 0);
    panel?.classList.remove('hidden');
    if (macros) {
      macros.innerHTML = [
        macroHtml('Total de Membros Ativos', totalMembers),
        macroHtml('Total de Tribos Ativas', totalTribes),
        macroHtml('Total de Boards Operando', totalBoardsOperating),
        macroHtml('Total de Cards Atrasados', totalOverdue, totalOverdue > 0 ? 'text-red-600' : 'text-[var(--text-primary)]'),
      ].join('');
    }
    if (summary) {
      summary.innerHTML = [
        sectionHtml('🟢 Tribos de Pesquisa', grouped.research),
        sectionHtml('⚙️ Operações', grouped.operations),
        sectionHtml('🌍 Global', grouped.global),
      ].join('');
    }

    // Load KPI health cards
    loadKpiHealth(sb);
    // Load boards list (W139)
    loadBoardsList(sb);
  }

  document.getElementById('portfolio-run-taxonomy-alerts')?.addEventListener('click', async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb) return;
    const { data, error } = await sb.rpc('admin_detect_board_taxonomy_drift');
    if (error) {
      (window as any).toast?.('Falha ao detectar drift taxonomy.', 'error');
      return;
    }
    (window as any).toast?.(`Detecção concluída. Alertas abertos: ${data?.open_alerts ?? 'n/a'}`, 'success');
  });

  document.getElementById('portfolio-run-sanity')?.addEventListener('click', async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb) return;
    const { data, error } = await sb.rpc('admin_run_portfolio_data_sanity');
    if (error) {
      (window as any).toast?.('Falha na execução do data sanity.', 'error');
      return;
    }
    const summary = data?.summary || {};
    (window as any).toast?.(`Sanity OK. Orfãos: ${summary.orphan_items ?? 0} · Inativos: ${summary.items_in_inactive_board ?? 0}`, 'success');
  });

  // ─── KPI Health (W104) — now uses get_annual_kpis ───
  async function loadKpiHealth(sb: any) {
    const healthPanel = document.getElementById('kpi-health-panel');
    const healthGrid = document.getElementById('kpi-health-grid');
    if (!healthPanel || !healthGrid) return;

    const { data, error } = await sb.rpc('get_annual_kpis', { p_cycle: 3, p_year: 2026 });
    if (error || !data?.kpis) return;

    const kpis = data.kpis;
    if (kpis.length === 0) return;

    const lang = document.documentElement.lang || 'pt-BR';
    const langKey = lang === 'en-US' || lang.startsWith('en') ? 'en' : lang.startsWith('es') ? 'es' : 'pt';

    const HEALTH_STYLES: Record<string, { bg: string; border: string; accent: string; bar: string }> = {
      achieved: { bg: 'bg-emerald-50', border: 'border-emerald-200', accent: 'text-emerald-700', bar: '#10B981' },
      on_track: { bg: 'bg-blue-50',    border: 'border-blue-200',    accent: 'text-blue-700',    bar: '#3B82F6' },
      at_risk:  { bg: 'bg-amber-50',   border: 'border-amber-200',   accent: 'text-amber-700',   bar: '#D97706' },
      behind:   { bg: 'bg-red-50',     border: 'border-red-200',     accent: 'text-red-700',      bar: '#BE2027' },
    };

    // Summary bar
    const s = data.summary;
    const summaryHtml = `<div class="col-span-full flex items-center gap-3 text-[.7rem] font-semibold mb-1">
      <span class="text-emerald-600">🟢 ${s.achieved}</span>
      <span class="text-blue-600">🔵 ${s.on_track}</span>
      <span class="text-amber-600">🟡 ${s.at_risk}</span>
      <span class="text-red-600">🔴 ${s.behind}</span>
      <span class="text-[var(--text-muted)] ml-auto">${s.total} KPIs</span>
    </div>`;

    const CATEGORY_LABELS: Record<string, Record<string, string>> = {
      delivery:   { pt: 'Entregas',     en: 'Delivery',    es: 'Entregas' },
      engagement: { pt: 'Engajamento',  en: 'Engagement',  es: 'Compromiso' },
      learning:   { pt: 'Aprendizado',  en: 'Learning',    es: 'Aprendizaje' },
      financial:  { pt: 'Financeiro',   en: 'Financial',   es: 'Financiero' },
      growth:     { pt: 'Crescimento',  en: 'Growth',      es: 'Crecimiento' },
    };
    const CATEGORY_ICONS: Record<string, string> = {
      delivery: '📦', engagement: '🤝', learning: '🎓', financial: '💰', growth: '📈',
    };
    const CATEGORY_ORDER = ['delivery', 'engagement', 'learning', 'financial', 'growth'];

    function renderKpiCard(k: any): string {
      const h = HEALTH_STYLES[k.health] || HEALTH_STYLES.behind;
      const label = langKey === 'en' && k.label_en ? k.label_en : k.label_pt;
      const pct = Math.min(Number(k.progress_pct) || 0, 999);
      const displayPct = Math.min(pct, 100);
      const unitLabel = k.unit === '%' ? '%' : k.unit === 'R$' ? ' R$' : '';
      const currentDisplay = k.current !== null && k.current !== undefined ? k.current : '—';

      return `<article class="rounded-xl ${h.border} ${h.bg} p-4">
        <div class="flex items-center gap-2 mb-2">
          <span>${k.icon}</span>
          <span class="text-[.68rem] font-bold uppercase tracking-wide ${h.accent}">${label}</span>
        </div>
        <div class="flex items-end gap-1 mb-2">
          <span class="text-2xl font-extrabold ${h.accent}">${currentDisplay}${unitLabel}</span>
          <span class="text-xs text-[var(--text-muted)] mb-1">/ ${k.target}${unitLabel}</span>
        </div>
        <div class="w-full h-2 rounded-full bg-white/60 overflow-hidden">
          <div class="h-full rounded-full transition-all duration-500" style="width:${displayPct}%;background:${h.bar}"></div>
        </div>
        <div class="text-[10px] ${h.accent} font-semibold mt-1">${pct}%</div>
      </article>`;
    }

    // Group KPIs by category
    const grouped = new Map<string, any[]>();
    for (const k of kpis) {
      const cat = k.category || 'other';
      if (!grouped.has(cat)) grouped.set(cat, []);
      grouped.get(cat)!.push(k);
    }

    let groupedHtml = '';
    for (const cat of CATEGORY_ORDER) {
      const items = grouped.get(cat);
      if (!items || items.length === 0) continue;
      const catLabel = CATEGORY_LABELS[cat]?.[langKey] || cat;
      const catIcon = CATEGORY_ICONS[cat] || '';
      groupedHtml += `<div class="col-span-full mt-3 first:mt-0">
        <h3 class="text-xs font-bold uppercase tracking-widest text-[var(--text-muted)] mb-2">${catIcon} ${catLabel}</h3>
      </div>`;
      groupedHtml += items.map(renderKpiCard).join('');
    }

    healthGrid.innerHTML = summaryHtml + groupedHtml;
    healthPanel.classList.remove('hidden');
  }

  // ─── Boards List (W139) ───
  async function loadBoardsList(sb: any) {
    const panel = document.getElementById('boards-list-panel');
    const grid = document.getElementById('boards-list-grid');
    if (!panel || !grid) return;

    const { data, error } = await sb.rpc('list_project_boards');
    if (error || !data) return;

    const boards = (Array.isArray(data) ? data : []).filter((b: any) => b.is_active);
    if (boards.length === 0) return;

    panel.classList.remove('hidden');
    grid.innerHTML = boards.map((b: any) => {
      const scope = b.board_scope === 'tribe' ? 'Tribo' : b.board_scope === 'global' ? 'Global' : b.board_scope || '';
      return `
        <a href="/admin/board/${b.id}" class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-base)] p-3 no-underline hover:border-teal transition-all block">
          <div class="text-sm font-semibold text-navy">${escH(b.board_name || 'Board')}</div>
          <div class="text-[.68rem] text-[var(--text-muted)] mt-1">${escH(scope)} · ${escH(b.domain_key || '')}</div>
        </a>
      `;
    }).join('');
  }

  function escH(s: string) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  bootPortfolioPage();
</script>
