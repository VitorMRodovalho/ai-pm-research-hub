---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('nav.adminPortfolio', lang)} activePage="admin">
  <div class="max-w-[1100px] mx-auto px-4 py-8 space-y-4">
    <div id="portfolio-loading" class="text-[var(--text-muted)] text-sm">{t('portfolio.loading', lang)}</div>
    <div id="portfolio-denied" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800 text-sm">
      {t('portfolio.denied', lang)}
    </div>
    <section id="portfolio-panel" class="hidden rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
      <h1 class="text-xl font-extrabold text-navy mb-3">{t('portfolio.title', lang)}</h1>
      <p class="text-sm text-[var(--text-secondary)] mb-4">{t('portfolio.subtitle', lang)}</p>
      <div id="portfolio-macros" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-3 mb-4"></div>
      <div class="flex flex-wrap gap-2 mb-4">
        <button id="portfolio-run-taxonomy-alerts" class="px-3 py-2 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-xs font-semibold hover:bg-[var(--surface-hover)]">{t('portfolio.runTaxonomy', lang)}</button>
        <button id="portfolio-run-sanity" class="px-3 py-2 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-xs font-semibold hover:bg-[var(--surface-hover)]">{t('portfolio.runSanity', lang)}</button>
      </div>
      <div id="portfolio-summary" class="space-y-5"></div>
    </section>
  </div>
</BaseLayout>

<script>
  let portfolioBootRetries = 0;

  function hasPortfolioAccess(member: any): boolean {
    if (!member) return false;
    if (member.is_superadmin) return true;
    const role = String(member.operational_role || '');
    const designations: string[] = Array.isArray(member.designations) ? member.designations : [];
    return ['manager', 'deputy_manager'].includes(role)
      || ['sponsor', 'chapter_liaison', 'curator', 'co_gp'].some((d) => designations.includes(d));
  }

  function cardHtml(entry: any): string {
    const hasNoActiveCards = Number(entry.total_cards || 0) === 0;
    const overdueClass = Number(entry.overdue_cards || 0) > 0 ? 'text-red-600 font-bold' : 'text-[var(--text-secondary)]';
    return `
      <article class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-base)] p-3">
        <div class="text-xs font-bold uppercase tracking-wide text-[var(--text-secondary)]">${entry.board_scope} · ${entry.domain_key} ${hasNoActiveCards ? '<span class="ml-1 text-amber-600">⚠️</span>' : ''}</div>
        <div class="mt-1 text-sm text-[var(--text-primary)]">Cards: <strong>${entry.total_cards || 0}</strong></div>
        <div class="text-xs text-[var(--text-secondary)] mt-1">Atrasados: <span class="${overdueClass}">${entry.overdue_cards || 0}</span> · Órfãos: ${entry.orphan_cards || 0}</div>
      </article>
    `;
  }

  function macroHtml(title: string, value: string | number, accentClass = 'text-[var(--text-primary)]'): string {
    return `
      <article class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-base)] p-3">
        <div class="text-[11px] uppercase tracking-wide font-semibold text-[var(--text-secondary)]">${title}</div>
        <div class="text-2xl font-extrabold ${accentClass}">${value}</div>
      </article>
    `;
  }

  function toMacroCounts(rows: any[]) {
    const totalOverdue = rows.reduce((sum, row) => sum + Number(row?.overdue_cards || 0), 0);
    const totalBoardsOperating = rows.length;
    return { totalOverdue, totalBoardsOperating };
  }

  function classifyBlock(row: any): 'research' | 'operations' | 'global' {
    const scope = String(row?.board_scope || '');
    const domain = String(row?.domain_key || '');
    if (scope === 'global' || domain.includes('publications') || domain.includes('governance')) return 'global';
    if (scope === 'operational' || domain.includes('communication') || domain.includes('webinar')) return 'operations';
    return 'research';
  }

  function sectionHtml(title: string, rows: any[]): string {
    return `
      <section>
        <h2 class="text-sm font-bold uppercase tracking-wide text-[var(--text-secondary)] mb-2">${title}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">${rows.map((row: any) => cardHtml(row)).join('')}</div>
      </section>
    `;
  }

  async function bootPortfolioPage() {
    const loading = document.getElementById('portfolio-loading');
    const denied = document.getElementById('portfolio-denied');
    const panel = document.getElementById('portfolio-panel');
    const summary = document.getElementById('portfolio-summary');
    const macros = document.getElementById('portfolio-macros');
    const member = (window as any).navGetMember?.();
    const sb = (window as any).navGetSb?.();

    if (!member || !sb) {
      portfolioBootRetries += 1;
      if (portfolioBootRetries >= 20) {
        loading?.classList.add('hidden');
        denied?.classList.remove('hidden');
        denied!.textContent = 'Acesso restrito a administração e audiência executiva.';
        return;
      }
      setTimeout(() => bootPortfolioPage(), 150);
      return;
    }
    loading?.classList.add('hidden');
    if (!hasPortfolioAccess(member)) {
      denied?.classList.remove('hidden');
      return;
    }

    const [{ data, error }, membersQuery, tribesQuery] = await Promise.all([
      sb.rpc('exec_portfolio_board_summary', { p_include_inactive: false }),
      sb.from('public_members').select('member_id', { count: 'exact', head: true }).eq('current_cycle_active', true),
      sb.from('tribes').select('id', { count: 'exact', head: true }).eq('is_active', true),
    ]);
    if (error) {
      denied?.classList.remove('hidden');
      denied!.textContent = 'Falha ao carregar visão executiva de portfólio.';
      return;
    }
    const rows = Array.isArray(data?.by_lane) ? data.by_lane : [];
    const grouped = rows.reduce((acc: any, row: any) => {
      const key = classifyBlock(row);
      acc[key].push(row);
      return acc;
    }, { research: [], operations: [], global: [] });
    const { totalOverdue, totalBoardsOperating } = toMacroCounts(rows);
    const totalMembers = Number(membersQuery?.count || 0);
    const totalTribes = Number(tribesQuery?.count || 0);
    panel?.classList.remove('hidden');
    if (macros) {
      macros.innerHTML = [
        macroHtml('Total de Membros Ativos', totalMembers),
        macroHtml('Total de Tribos Ativas', totalTribes),
        macroHtml('Total de Boards Operando', totalBoardsOperating),
        macroHtml('Total de Cards Atrasados', totalOverdue, totalOverdue > 0 ? 'text-red-600' : 'text-[var(--text-primary)]'),
      ].join('');
    }
    if (summary) {
      summary.innerHTML = [
        sectionHtml('🟢 Tribos de Pesquisa', grouped.research),
        sectionHtml('⚙️ Operações', grouped.operations),
        sectionHtml('🌍 Global', grouped.global),
      ].join('');
    }
  }

  document.getElementById('portfolio-run-taxonomy-alerts')?.addEventListener('click', async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb) return;
    const { data, error } = await sb.rpc('admin_detect_board_taxonomy_drift');
    if (error) {
      (window as any).toast?.('Falha ao detectar drift taxonomy.', 'error');
      return;
    }
    (window as any).toast?.(`Detecção concluída. Alertas abertos: ${data?.open_alerts ?? 'n/a'}`, 'success');
  });

  document.getElementById('portfolio-run-sanity')?.addEventListener('click', async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb) return;
    const { data, error } = await sb.rpc('admin_run_portfolio_data_sanity');
    if (error) {
      (window as any).toast?.('Falha na execução do data sanity.', 'error');
      return;
    }
    const summary = data?.summary || {};
    (window as any).toast?.(`Sanity OK. Orfãos: ${summary.orphan_items ?? 0} · Inativos: ${summary.items_in_inactive_board ?? 0}`, 'success');
  });

  bootPortfolioPage();
</script>
