---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import AdminNav from '../../components/nav/AdminNav.astro';

const lang: Lang = getLangFromURL(Astro.url.pathname);
const ANALYTICS_I18N = {
  consentGranted: t('admin.analytics.consentGranted', lang),
  consentDenied: t('admin.analytics.consentDenied', lang),
  consentUnknown: t('admin.analytics.consentUnknown', lang),
  funnelTitle: t('admin.analytics.funnelTitle', lang),
  funnelDesc: t('admin.analytics.funnelDesc', lang),
  radarTitle: t('admin.analytics.radarTitle', lang),
  radarDesc: t('admin.analytics.radarDesc', lang),
  totalMembers: t('admin.analytics.totalMembers', lang),
  withTribe: t('admin.analytics.withTribe', lang),
  withCredly: t('admin.analytics.withCredly', lang),
  withPhoto: t('admin.analytics.withPhoto', lang),
  withLinkedin: t('admin.analytics.withLinkedin', lang),
  tribeLeaders: t('admin.analytics.tribeLeaders', lang),
  totalArtifacts: t('admin.analytics.totalArtifacts', lang),
  totalEvents: t('admin.analytics.totalEvents', lang),
  totalBroadcasts: t('admin.analytics.totalBroadcasts', lang),
  members: t('admin.analytics.members', lang),
  credly: t('admin.analytics.credly', lang),
  photos: t('admin.analytics.photos', lang),
  linkedin: t('admin.analytics.linkedin', lang),
  artifacts: t('admin.analytics.artifacts', lang),
  noData: t('admin.analytics.noData', lang),
};
---

<BaseLayout title={t('admin.analytics.meta', lang)} activePage="admin">
  <div class="max-w-[1200px] mx-auto px-4 pt-6">
    <AdminNav activeSub="analytics" lang={lang} />
  </div>
  <div class="max-w-[1200px] mx-auto px-4 pb-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-navy">{t('admin.analytics.title', lang)}</h1>
      <p class="text-sm text-slate-500">{t('admin.analytics.subtitle', lang)}</p>
    </div>

    <div id="analytics-loading" class="text-center py-10 text-slate-400">{t('admin.analytics.loading', lang)}</div>

    <div id="analytics-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1F512;</div>
      <p class="font-semibold text-amber-800">{t('admin.analytics.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('admin.analytics.backAdmin', lang)}
      </a>
    </div>

    <div id="analytics-panel" class="hidden space-y-6">
      <!-- Consent card -->
      <div class="bg-white border border-slate-200 rounded-xl p-4">
        <div class="flex items-center justify-between gap-3 flex-wrap">
          <div>
            <div class="text-[.75rem] font-semibold text-slate-500 mb-1">{t('admin.analytics.consentTitle', lang)}</div>
            <p class="text-[.72rem] text-slate-500">{t('admin.analytics.consentBody', lang)}</p>
            <p class="text-[.68rem] text-slate-400 mt-1" id="consent-status">{t('admin.analytics.consentUnknown', lang)}</p>
          </div>
          <div class="flex gap-2">
            <button id="btn-consent-grant" class="px-3 py-2 bg-emerald-600 text-white rounded-lg text-[.72rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
              {t('admin.analytics.consentGrant', lang)}
            </button>
            <button id="btn-consent-revoke" class="px-3 py-2 bg-slate-100 text-slate-700 rounded-lg text-[.72rem] font-semibold cursor-pointer border border-slate-200 hover:bg-slate-200 transition-all">
              {t('admin.analytics.consentRevoke', lang)}
            </button>
          </div>
        </div>
      </div>

      <!-- Cross-Source Platform Overview -->
      <div class="border-b-2 border-slate-200 pb-6 mb-6">
        <h2 class="text-lg font-extrabold text-navy mb-1">Visão Geral da Plataforma</h2>
        <p class="text-[.72rem] text-slate-400 mb-4">Dados consolidados de todas as fontes integradas</p>

        <div id="platform-kpis" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-4"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">Saúde da Plataforma</h3>
              <p class="text-[.68rem] text-slate-400">Completude dos dados de membros</p>
            </div>
            <div class="p-4" style="height:260px">
              <canvas id="platform-health-chart"></canvas>
            </div>
          </section>

          <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">Atividade Mensal</h3>
              <p class="text-[.68rem] text-slate-400">Eventos, artefatos e comunicados por mês</p>
            </div>
            <div class="p-4" style="height:260px">
              <canvas id="activity-timeline-chart"></canvas>
            </div>
          </section>
        </div>
      </div>

      <!-- KPI Stats -->
      <div id="stats-grid" class="grid grid-cols-2 sm:grid-cols-4 gap-3"></div>

      <!-- Charts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
          <div class="px-4 py-3 border-b border-slate-200">
            <h2 class="text-sm font-bold text-navy" id="funnel-title"></h2>
            <p class="text-[.68rem] text-slate-400" id="funnel-desc"></p>
          </div>
          <div class="p-4" style="height:300px">
            <canvas id="funnel-chart"></canvas>
          </div>
        </section>

        <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
          <div class="px-4 py-3 border-b border-slate-200">
            <h2 class="text-sm font-bold text-navy" id="radar-title"></h2>
            <p class="text-[.68rem] text-slate-400" id="radar-desc"></p>
          </div>
          <div class="p-4" style="height:300px">
            <canvas id="radar-chart"></canvas>
          </div>
        </section>
      </div>

      <!-- Cert Timeline -->
      <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-200">
          <h2 class="text-sm font-bold text-navy">Linha do Tempo de Certificações</h2>
          <p class="text-[.68rem] text-slate-400">Progressão de certificações por cohort mensal</p>
        </div>
        <div class="p-4" style="height:280px">
          <canvas id="cert-chart"></canvas>
        </div>
      </section>

      <!-- Selection Process Analytics -->
      <div class="mt-8 pt-6 border-t-2 border-slate-200">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-lg font-extrabold text-navy">Processo Seletivo</h2>
          <span class="text-[10px] font-bold bg-amber-100 text-amber-700 px-2 py-0.5 rounded-full uppercase">LGPD</span>
        </div>
        <p class="text-[.72rem] text-slate-400 mb-5">Dados agregados de voluntários — Ciclos 1, 2 e 3</p>

        <!-- Funnel per cycle -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
          <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">Funil por Ciclo</h3>
              <p class="text-[.68rem] text-slate-400">Candidaturas vs. membros existentes vs. ativos</p>
            </div>
            <div class="p-4" style="height:300px">
              <canvas id="sel-funnel-chart"></canvas>
            </div>
          </section>

          <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">Certificações</h3>
              <p class="text-[.68rem] text-slate-400">Distribuição de certificações entre voluntários</p>
            </div>
            <div class="p-4" style="height:300px">
              <canvas id="sel-certs-chart"></canvas>
            </div>
          </section>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">Distribuição Geográfica</h3>
              <p class="text-[.68rem] text-slate-400">Top 15 estados/países dos voluntários</p>
            </div>
            <div class="p-4" style="height:300px">
              <canvas id="sel-geo-chart"></canvas>
            </div>
          </section>

          <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
            <div class="px-4 py-3 border-b border-slate-200">
              <h3 class="text-sm font-bold text-navy">Evolução por Snapshot (Ciclo 3)</h3>
              <p class="text-[.68rem] text-slate-400">Comparação Jan 16 vs. Mar 9</p>
            </div>
            <div class="p-4" style="height:300px">
              <canvas id="sel-snapshot-chart"></canvas>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ ANALYTICS_I18N }}>
  window.__ANALYTICS_I18N = typeof ANALYTICS_I18N !== 'undefined' ? ANALYTICS_I18N : {};
</script>
<script>
  import { canAccessAdminRoute } from '../../lib/admin/constants';

  const CONSENT_KEY = 'analytics_consent';
  let sb: any = null;
  let MEMBER: any = null;
  const L = (typeof window !== 'undefined' && (window as any).__ANALYTICS_I18N) || {};
  const PALETTE = ['#0d9488', '#7c3aed', '#2563eb', '#0a66c2', '#e11d48', '#ea580c', '#65a30d', '#0891b2'];

  function allowAnalytics(m: any): boolean {
    return canAccessAdminRoute(m, 'admin_analytics');
  }

  function showDenied() {
    document.getElementById('analytics-loading')?.classList.add('hidden');
    document.getElementById('analytics-denied')?.classList.remove('hidden');
    document.getElementById('analytics-panel')?.classList.add('hidden');
  }

  function showPanel() {
    document.getElementById('analytics-loading')?.classList.add('hidden');
    document.getElementById('analytics-denied')?.classList.add('hidden');
    document.getElementById('analytics-panel')?.classList.remove('hidden');
    setupConsentUi();
    loadCharts();
  }

  function consentValue(): 'granted' | 'denied' | 'unknown' {
    const v = localStorage.getItem(CONSENT_KEY);
    if (v === 'granted' || v === 'denied') return v;
    return 'unknown';
  }

  function renderConsentStatus() {
    const statusEl = document.getElementById('consent-status');
    if (!statusEl) return;
    const v = consentValue();
    if (v === 'granted') {
      statusEl.textContent = L.consentGranted || 'Consentimento ativo';
      statusEl.className = 'text-[.68rem] text-emerald-600 mt-1';
    } else if (v === 'denied') {
      statusEl.textContent = L.consentDenied || 'Consentimento revogado';
      statusEl.className = 'text-[.68rem] text-crimson mt-1';
    } else {
      statusEl.textContent = L.consentUnknown || 'Nao consentido';
      statusEl.className = 'text-[.68rem] text-slate-400 mt-1';
    }
  }

  function setupConsentUi() {
    const grantBtn = document.getElementById('btn-consent-grant');
    const revokeBtn = document.getElementById('btn-consent-revoke');
    if (grantBtn && !grantBtn.dataset.bound) {
      grantBtn.dataset.bound = '1';
      grantBtn.addEventListener('click', () => { localStorage.setItem(CONSENT_KEY, 'granted'); renderConsentStatus(); });
    }
    if (revokeBtn && !revokeBtn.dataset.bound) {
      revokeBtn.dataset.bound = '1';
      revokeBtn.addEventListener('click', () => { localStorage.setItem(CONSENT_KEY, 'denied'); renderConsentStatus(); });
    }
    renderConsentStatus();
  }

  function escapeHtml(s: string): string {
    return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  async function loadCharts() {
    const { Chart, BarController, RadarController, LineController, DoughnutController, CategoryScale, LinearScale, RadialLinearScale, BarElement, PointElement, LineElement, ArcElement, Filler, Legend, Tooltip } = await import('chart.js');
    Chart.register(BarController, RadarController, LineController, DoughnutController, CategoryScale, LinearScale, RadialLinearScale, BarElement, PointElement, LineElement, ArcElement, Filler, Legend, Tooltip);

    // ── Cross-source platform overview ──
    try {
      const { data: pData, error: pErr } = await sb.rpc('platform_activity_summary');
      if (!pErr && pData) {
        const m = pData.members || {};
        const a = pData.artifacts || {};
        const e = pData.events || {};
        const b = pData.boards || {};
        const cm = pData.comms || {};
        const va = pData.volunteer_apps || {};

        const kpiEl = document.getElementById('platform-kpis');
        if (kpiEl) {
          const kpis = [
            { icon: '&#x1F465;', val: m.active || 0, label: 'Membros Ativos' },
            { icon: '&#x1F4C4;', val: a.total || 0, label: 'Artefatos' },
            { icon: '&#x1F4C5;', val: e.total || 0, label: 'Eventos' },
            { icon: '&#x1F4CB;', val: b.total_items || 0, label: 'Itens Kanban' },
            { icon: '&#x1F4E2;', val: cm.total_reach || 0, label: 'Alcance Comms' },
            { icon: '&#x1F4E8;', val: va.total || 0, label: 'Candidaturas' },
          ];
          kpiEl.innerHTML = kpis.map(k =>
            `<div class="bg-white border border-slate-200 rounded-xl p-3 text-center">
              <div class="text-base">${k.icon}</div>
              <div class="text-lg font-extrabold text-navy">${k.val}</div>
              <div class="text-[.6rem] text-slate-500 font-semibold">${escapeHtml(k.label)}</div>
            </div>`
          ).join('');
        }

        // Platform health doughnut
        const healthCanvas = document.getElementById('platform-health-chart') as HTMLCanvasElement;
        if (healthCanvas && m.total) {
          new Chart(healthCanvas, {
            type: 'doughnut',
            data: {
              labels: ['Com Tribo', 'Com Credly', 'Com Foto', 'Com LinkedIn'],
              datasets: [{
                data: [m.with_tribe || 0, m.with_credly || 0, m.with_photo || 0, m.with_linkedin || 0],
                backgroundColor: [PALETTE[0], PALETTE[1], PALETTE[2], PALETTE[3]],
                borderWidth: 0,
              }]
            },
            options: {
              responsive: true, maintainAspectRatio: false, cutout: '55%',
              plugins: {
                legend: { position: 'bottom', labels: { font: { size: 10 }, usePointStyle: true, padding: 12 } },
                tooltip: { callbacks: { label: (c: any) => c.label + ': ' + c.raw + '/' + m.total + ' (' + Math.round(c.raw / m.total * 100) + '%)' } }
              }
            }
          });
        }

        // Activity timeline line chart
        const monthly = pData.monthly_activity || [];
        if (monthly.length) {
          const timelineCanvas = document.getElementById('activity-timeline-chart') as HTMLCanvasElement;
          if (timelineCanvas) {
            const labels = monthly.map((d: any) => {
              const dt = new Date(d.month_label);
              return dt.toLocaleDateString('pt-BR', { month: 'short', year: '2-digit' });
            });
            new Chart(timelineCanvas, {
              type: 'line',
              data: {
                labels,
                datasets: [
                  { label: 'Eventos', data: monthly.map((d: any) => d.events), borderColor: PALETTE[0], backgroundColor: PALETTE[0] + '20', fill: true, tension: 0.3, pointRadius: 4 },
                  { label: 'Artefatos', data: monthly.map((d: any) => d.artifacts), borderColor: PALETTE[1], backgroundColor: PALETTE[1] + '20', fill: true, tension: 0.3, pointRadius: 4 },
                  { label: 'Comunicados', data: monthly.map((d: any) => d.broadcasts), borderColor: PALETTE[5], backgroundColor: PALETTE[5] + '20', fill: true, tension: 0.3, pointRadius: 4 },
                ]
              },
              options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, usePointStyle: true } } },
                scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
              }
            });
          }
        }
      }
    } catch (e) { console.warn('Platform overview:', e); }

    const funnelTitle = document.getElementById('funnel-title');
    const funnelDesc = document.getElementById('funnel-desc');
    const radarTitle = document.getElementById('radar-title');
    const radarDesc = document.getElementById('radar-desc');
    if (funnelTitle) funnelTitle.textContent = L.funnelTitle || 'Funil de Engajamento';
    if (funnelDesc) funnelDesc.textContent = L.funnelDesc || '';
    if (radarTitle) radarTitle.textContent = L.radarTitle || 'Radar por Tribo';
    if (radarDesc) radarDesc.textContent = L.radarDesc || '';

    try {
      const { data, error } = await sb.rpc('exec_funnel_summary');
      if (!error && data?.total_members) {
        const total = data.total_members;
        const statsGrid = document.getElementById('stats-grid');
        if (statsGrid) {
          const stats = [
            { label: L.totalMembers || 'Membros Ativos', value: total, icon: '&#x1F465;' },
            { label: L.tribeLeaders || 'Líderes', value: data.tribe_leaders, icon: '&#x1F451;' },
            { label: L.totalArtifacts || 'Artefatos', value: data.total_artifacts, icon: '&#x1F4C4;' },
            { label: L.totalBroadcasts || 'Broadcasts', value: data.total_broadcasts, icon: '&#x1F4E7;' },
          ];
          statsGrid.innerHTML = stats.map(s =>
            '<div class="bg-white border border-slate-200 rounded-xl p-3 text-center">'
            + '<div class="text-lg">' + s.icon + '</div>'
            + '<div class="text-xl font-extrabold text-navy">' + s.value + '</div>'
            + '<div class="text-[.65rem] text-slate-500 font-semibold">' + escapeHtml(s.label) + '</div>'
            + '</div>'
          ).join('');
        }

        const funnelCanvas = document.getElementById('funnel-chart') as HTMLCanvasElement;
        if (funnelCanvas) new Chart(funnelCanvas, {
          type: 'bar',
          data: {
            labels: [L.withTribe || 'Com Tribo', L.withCredly || 'Credly', L.withPhoto || 'Com Foto', L.withLinkedin || 'LinkedIn'],
            datasets: [{
              data: [data.with_tribe, data.with_credly, data.with_photo, data.with_linkedin],
              backgroundColor: PALETTE.slice(0, 4),
              borderRadius: 6, barPercentage: 0.65,
            }]
          },
          options: {
            indexAxis: 'y', responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c: any) => c.raw + ' / ' + total + ' (' + Math.round(c.raw / total * 100) + '%)' } } },
            scales: { x: { max: total, grid: { color: '#f1f5f9' } }, y: { grid: { display: false } } }
          }
        });
      }
    } catch (e) { console.warn('Funnel chart:', e); }

    try {
      const { data } = await sb.rpc('exec_skills_radar');
      if (Array.isArray(data) && data.length) {
        const radarCanvas = document.getElementById('radar-chart') as HTMLCanvasElement;
        if (radarCanvas) new Chart(radarCanvas, {
          type: 'radar',
          data: {
            labels: data.map((t: any) => (t.tribe_name || '').substring(0, 14)),
            datasets: [
              { label: L.credly || 'Credly', data: data.map((t: any) => t.credly_count || 0), borderColor: PALETTE[1], backgroundColor: PALETTE[1] + '25', fill: true, pointRadius: 3 },
              { label: L.photos || 'Fotos', data: data.map((t: any) => t.photo_count || 0), borderColor: PALETTE[2], backgroundColor: PALETTE[2] + '25', fill: true, pointRadius: 3 },
              { label: L.linkedin || 'LinkedIn', data: data.map((t: any) => t.linkedin_count || 0), borderColor: PALETTE[0], backgroundColor: PALETTE[0] + '25', fill: true, pointRadius: 3 },
            ]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, usePointStyle: true } } },
            scales: { r: { ticks: { font: { size: 9 } }, pointLabels: { font: { size: 9 } } } }
          }
        });
      }
    } catch (e) { console.warn('Radar chart:', e); }

    try {
      const { data } = await sb.rpc('exec_cert_timeline', { p_months: 12 });
      if (Array.isArray(data) && data.length) {
        const certCanvas = document.getElementById('cert-chart') as HTMLCanvasElement;
        if (certCanvas) new Chart(certCanvas, {
          type: 'line',
          data: {
            labels: data.map((d: any) => d.cohort_month),
            datasets: [
              { label: 'Tier 1 (%)', data: data.map((d: any) => d.pct_with_tier1 || 0), borderColor: PALETTE[0], backgroundColor: PALETTE[0] + '20', fill: true, tension: 0.3, pointRadius: 4 },
              { label: 'Tier 2+ (%)', data: data.map((d: any) => d.pct_with_tier2 || 0), borderColor: PALETTE[1], backgroundColor: PALETTE[1] + '20', fill: true, tension: 0.3, pointRadius: 4 },
            ]
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, usePointStyle: true } } },
            scales: { y: { beginAtZero: true, max: 100, ticks: { callback: (v: any) => v + '%' }, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
          }
        });
      }
    } catch (e) { console.warn('Cert timeline chart:', e); }

    // ── Selection Process charts ──
    try {
      const { data: selData, error: selErr } = await sb.rpc('volunteer_funnel_summary');
      if (!selErr && selData) {
        const byCycle = selData.by_cycle || [];
        const certs = selData.certifications || [];
        const geo = selData.geography || [];

        // Funnel per cycle
        if (byCycle.length) {
          const funnelCanvas = document.getElementById('sel-funnel-chart') as HTMLCanvasElement;
          if (funnelCanvas) new Chart(funnelCanvas, {
            type: 'bar',
            data: {
              labels: byCycle.map((c: any) => 'Ciclo ' + c.cycle),
              datasets: [
                { label: 'Candidaturas', data: byCycle.map((c: any) => c.total_applications), backgroundColor: PALETTE[2], borderRadius: 4 },
                { label: 'Membros Existentes', data: byCycle.map((c: any) => c.matched_members), backgroundColor: PALETTE[0], borderRadius: 4 },
                { label: 'Ativos', data: byCycle.map((c: any) => c.active_applications), backgroundColor: PALETTE[1], borderRadius: 4 },
              ]
            },
            options: {
              responsive: true, maintainAspectRatio: false,
              plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, usePointStyle: true } } },
              scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
            }
          });
        }

        // Certifications horizontal bar
        if (certs.length) {
          const certCanvas = document.getElementById('sel-certs-chart') as HTMLCanvasElement;
          if (certCanvas) new Chart(certCanvas, {
            type: 'bar',
            data: {
              labels: certs.slice(0, 12).map((c: any) => (c.cert || 'N/A').substring(0, 20)),
              datasets: [{
                data: certs.slice(0, 12).map((c: any) => c.cnt),
                backgroundColor: PALETTE.concat(PALETTE).slice(0, 12),
                borderRadius: 4, barPercentage: 0.7,
              }]
            },
            options: {
              indexAxis: 'y', responsive: true, maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: { x: { beginAtZero: true, grid: { color: '#f1f5f9' } }, y: { grid: { display: false }, ticks: { font: { size: 9 } } } }
            }
          });
        }

        // Geographic treemap-like horizontal bar
        if (geo.length) {
          const geoCanvas = document.getElementById('sel-geo-chart') as HTMLCanvasElement;
          if (geoCanvas) new Chart(geoCanvas, {
            type: 'bar',
            data: {
              labels: geo.slice(0, 15).map((g: any) => [g.state, g.country].filter(Boolean).join(', ')),
              datasets: [{
                data: geo.slice(0, 15).map((g: any) => g.cnt),
                backgroundColor: PALETTE.concat(PALETTE).slice(0, 15),
                borderRadius: 4, barPercentage: 0.7,
              }]
            },
            options: {
              indexAxis: 'y', responsive: true, maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: { x: { beginAtZero: true, grid: { color: '#f1f5f9' } }, y: { grid: { display: false }, ticks: { font: { size: 9 } } } }
            }
          });
        }

        // Snapshot comparison for Ciclo 3
        const c3Snapshots = byCycle.filter((c: any) => c.cycle === 3);
        if (c3Snapshots.length >= 1) {
          const snap = c3Snapshots[0];
          const snapshotCanvas = document.getElementById('sel-snapshot-chart') as HTMLCanvasElement;
          if (snapshotCanvas) {
            const labels = ['Candidaturas', 'Únicos', 'Membros', 'Ativos'];
            const vals = [snap.total_applications, snap.unique_applicants, snap.matched_members, snap.active_applications];
            new Chart(snapshotCanvas, {
              type: 'bar',
              data: {
                labels,
                datasets: [{
                  label: `Ciclo 3 (${snap.earliest_snapshot || ''} → ${snap.latest_snapshot || ''})`,
                  data: vals,
                  backgroundColor: [PALETTE[2], PALETTE[3], PALETTE[0], PALETTE[1]],
                  borderRadius: 6, barPercentage: 0.6,
                }]
              },
              options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { font: { size: 10 }, usePointStyle: true } } },
                scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } }
              }
            });
          }
        }
      }
    } catch (e) { console.warn('Selection process charts:', e); }
  }

  function applyGate(m: any) {
    if (m && allowAnalytics(m)) showPanel();
    else showDenied();
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) { MEMBER = m; applyGate(MEMBER); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        MEMBER = data;
        applyGate(MEMBER);
        return;
      }
    } catch (e) { console.warn('Analytics boot:', e); }

    showDenied();
  }

  boot();
</script>
