---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import AdminNav from '../../components/nav/AdminNav.astro';
import ChartCard from '../../components/analytics/ChartCard.astro';
import { CHAPTER_FULL } from '../../lib/admin/constants';

const lang: Lang = getLangFromURL(Astro.url.pathname);
const chapterOptions = Object.entries(CHAPTER_FULL).map(([code, label]) => ({ code, label }));
const ANALYTICS_I18N = {
  consentGranted: t('admin.analytics.consentGranted', lang),
  consentDenied: t('admin.analytics.consentDenied', lang),
  consentUnknown: t('admin.analytics.consentUnknown', lang),
  emptyState: t('admin.analytics.emptyState', lang),
  chartNoData: t('admin.analytics.chartNoData', lang),
  chartError: t('admin.analytics.chartError', lang),
  stageEntered: t('admin.analytics.stageEntered', lang),
  stageOnboarding: t('admin.analytics.stageOnboarding', lang),
  stageAllocated: t('admin.analytics.stageAllocated', lang),
  stagePublished: t('admin.analytics.stagePublished', lang),
  backgroundLabel: t('admin.analytics.backgroundLabel', lang),
  impactLabel: t('admin.analytics.impactLabel', lang),
  currentAffiliates: t('admin.analytics.currentAffiliates', lang),
  attributedAffiliates: t('admin.analytics.attributedAffiliates', lang),
  promotedMembers: t('admin.analytics.promotedMembers', lang),
  transitions: t('admin.analytics.transitions', lang),
  targetMeta: t('admin.analytics.targetMeta', lang),
  scopePrefix: t('admin.analytics.scopePrefix', lang),
  allTribesLabel: t('admin.analytics.filterAllTribes', lang),
  allChaptersLabel: t('admin.analytics.filterAllChapters', lang),
  allCyclesLabel: t('admin.analytics.filterAllCycles', lang),
  transitionFrom: t('admin.analytics.transitionFrom', lang),
  transitionTo: t('admin.analytics.transitionTo', lang),
  transitionCount: t('admin.analytics.transitionCount', lang),
  impactHoursShort: t('admin.analytics.impactHoursShort', lang),
  qualityTitle: t('admin.analytics.qualityTitle', lang),
  qualityOk: t('admin.analytics.qualityOk', lang),
  qualityWarn: t('admin.analytics.qualityWarn', lang),
  qualityIssue: t('admin.analytics.qualityIssue', lang),
  qualityWindowLabel: t('admin.analytics.qualityWindowLabel', lang),
  interpretationTitle: t('admin.analytics.interpretationTitle', lang),
  interpretationBody: t('admin.analytics.interpretationBody', lang),
  interpretationFunnel: t('admin.analytics.interpretationFunnel', lang),
  interpretationImpact: t('admin.analytics.interpretationImpact', lang),
  interpretationRoi: t('admin.analytics.interpretationRoi', lang),
  interpretationLeadership: t('admin.analytics.interpretationLeadership', lang),
  copySummary: t('admin.analytics.copySummary', lang),
  summaryCopied: t('admin.analytics.summaryCopied', lang),
  summaryCopyError: t('admin.analytics.summaryCopyError', lang),
};
---

<BaseLayout title={t('admin.analytics.meta', lang)} activePage="admin">
  <div class="max-w-[1200px] mx-auto px-4 pt-6">
    <AdminNav activeSub="analytics" lang={lang} />
  </div>
  <div class="max-w-[1200px] mx-auto px-4 pb-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-navy">{t('admin.analytics.title', lang)}</h1>
      <p class="text-sm text-[var(--text-secondary)]">{t('admin.analytics.subtitle', lang)}</p>
    </div>

    <div id="analytics-loading" class="text-center py-10 text-[var(--text-muted)]">{t('admin.analytics.loading', lang)}</div>

    <div id="analytics-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1F512;</div>
      <p class="font-semibold text-amber-800">{t('admin.analytics.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('admin.analytics.backAdmin', lang)}
      </a>
    </div>

    <div id="analytics-panel" class="hidden space-y-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <section id="analytics-access-note" class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="text-[.75rem] font-semibold text-[var(--text-secondary)] mb-1">{t('admin.analytics.accessTitle', lang)}</div>
          <p class="text-[.72rem] text-[var(--text-secondary)]">{t('admin.analytics.accessBody', lang)}</p>
        </section>

        <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="flex items-center justify-between gap-3 flex-wrap">
            <div>
              <div class="text-[.75rem] font-semibold text-[var(--text-secondary)] mb-1">{t('admin.analytics.consentTitle', lang)}</div>
              <p class="text-[.72rem] text-[var(--text-secondary)]">{t('admin.analytics.consentBody', lang)}</p>
              <p class="text-[.68rem] text-[var(--text-muted)] mt-1" id="consent-status">{t('admin.analytics.consentUnknown', lang)}</p>
            </div>
            <div class="flex gap-2">
              <button id="btn-consent-grant" class="px-3 py-2 bg-emerald-600 text-white rounded-lg text-[.72rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
                {t('admin.analytics.consentGrant', lang)}
              </button>
              <button id="btn-consent-revoke" class="px-3 py-2 bg-[var(--surface-section-cool)] text-[var(--text-primary)] rounded-lg text-[.72rem] font-semibold cursor-pointer border border-[var(--border-default)] hover:bg-[var(--surface-hover)] transition-all">
                {t('admin.analytics.consentRevoke', lang)}
              </button>
            </div>
          </div>
        </section>
      </div>

      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden" id="analytics-filter-shell">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.analytics.filtersTitle', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">{t('admin.analytics.filtersBody', lang)}</p>
        </div>
        <div class="p-4">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <label class="text-[.72rem] text-[var(--text-secondary)] font-semibold">
              {t('admin.analytics.filterCycle', lang)}
              <select id="analytics-filter-cycle" class="mt-1 w-full px-3 py-2 rounded-lg border border-[var(--border-default)] text-sm bg-[var(--surface-card)]">
                <option value="">{t('admin.analytics.filterAllCycles', lang)}</option>
              </select>
            </label>
            <label class="text-[.72rem] text-[var(--text-secondary)] font-semibold">
              {t('admin.analytics.filterTribe', lang)}
              <select id="analytics-filter-tribe" class="mt-1 w-full px-3 py-2 rounded-lg border border-[var(--border-default)] text-sm bg-[var(--surface-card)]">
                <option value="">{t('admin.analytics.filterAllTribes', lang)}</option>
              </select>
            </label>
            <label class="text-[.72rem] text-[var(--text-secondary)] font-semibold">
              {t('admin.analytics.filterChapter', lang)}
              <select id="analytics-filter-chapter" class="mt-1 w-full px-3 py-2 rounded-lg border border-[var(--border-default)] text-sm bg-[var(--surface-card)]">
                <option value="">{t('admin.analytics.filterAllChapters', lang)}</option>
              </select>
            </label>
          </div>
          <div class="mt-3 flex items-center justify-between gap-3 flex-wrap">
            <div id="analytics-scope-summary" class="text-[.72rem] text-[var(--text-secondary)]">{t('admin.analytics.loading', lang)}</div>
            <div class="flex gap-2">
              <button id="analytics-apply" class="px-4 py-2 bg-navy text-white rounded-lg text-sm font-semibold hover:opacity-90">
                {t('admin.analytics.applyFilters', lang)}
              </button>
              <button id="analytics-reset" class="px-4 py-2 bg-[var(--surface-section-cool)] text-[var(--text-primary)] rounded-lg text-sm font-semibold border border-[var(--border-default)] hover:bg-[var(--surface-hover)]">
                {t('admin.analytics.resetFilters', lang)}
              </button>
            </div>
          </div>
        </div>
      </section>

      <section id="analytics-quality-banner" class="hidden rounded-xl border px-4 py-3">
        <div class="flex items-center justify-between gap-2 flex-wrap">
          <div class="text-[.75rem] font-semibold" id="analytics-quality-title">{t('admin.analytics.qualityTitle', lang)}</div>
          <div class="text-[.68rem] font-semibold" id="analytics-quality-status"></div>
        </div>
        <div class="mt-2 text-[.7rem] text-[var(--text-secondary)]" id="analytics-quality-window"></div>
        <div class="mt-2 text-[.72rem] text-[var(--text-primary)]" id="analytics-quality-body"></div>
      </section>

      <section id="analytics-interpretation-card" class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div>
            <div class="text-[.75rem] font-semibold text-[var(--text-secondary)] mb-1">{t('admin.analytics.interpretationTitle', lang)}</div>
            <p class="text-[.72rem] text-[var(--text-secondary)]">{t('admin.analytics.interpretationBody', lang)}</p>
          </div>
          <button id="analytics-copy-summary" class="px-4 py-2 bg-[var(--surface-section-cool)] text-[var(--text-primary)] rounded-lg text-[.72rem] font-semibold border border-[var(--border-default)] hover:bg-[var(--surface-hover)]">
            {t('admin.analytics.copySummary', lang)}
          </button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mt-3 text-[.72rem] text-[var(--text-secondary)]">
          <div class="rounded-lg bg-[var(--surface-base)] border border-[var(--border-default)] px-3 py-2">{t('admin.analytics.interpretationFunnel', lang)}</div>
          <div class="rounded-lg bg-[var(--surface-base)] border border-[var(--border-default)] px-3 py-2">{t('admin.analytics.interpretationImpact', lang)}</div>
          <div class="rounded-lg bg-[var(--surface-base)] border border-[var(--border-default)] px-3 py-2">{t('admin.analytics.interpretationRoi', lang)}</div>
          <div class="rounded-lg bg-[var(--surface-base)] border border-[var(--border-default)] px-3 py-2">{t('admin.analytics.interpretationLeadership', lang)}</div>
        </div>
      </section>

      <div id="analytics-v2-kpis" class="grid grid-cols-2 xl:grid-cols-5 gap-3">
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="text-[.68rem] text-[var(--text-muted)] font-semibold">{t('admin.analytics.kpiCohort', lang)}</div>
          <div id="kpi-cohort-members" class="text-2xl font-black text-navy mt-1">-</div>
          <div id="kpi-cohort-meta" class="text-[.65rem] text-[var(--text-muted)] mt-1">-</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="text-[.68rem] text-[var(--text-muted)] font-semibold">{t('admin.analytics.kpiOnboarding', lang)}</div>
          <div id="kpi-onboarding-rate" class="text-2xl font-black text-teal mt-1">-</div>
          <div id="kpi-onboarding-meta" class="text-[.65rem] text-[var(--text-muted)] mt-1">-</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="text-[.68rem] text-[var(--text-muted)] font-semibold">{t('admin.analytics.kpiImpact', lang)}</div>
          <div id="kpi-impact-hours" class="text-2xl font-black text-purple mt-1">-</div>
          <div id="kpi-impact-meta" class="text-[.65rem] text-[var(--text-muted)] mt-1">-</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="text-[.68rem] text-[var(--text-muted)] font-semibold">{t('admin.analytics.kpiAffiliations', lang)}</div>
          <div id="kpi-affiliations" class="text-2xl font-black text-amber-600 mt-1">-</div>
          <div id="kpi-affiliations-meta" class="text-[.65rem] text-[var(--text-muted)] mt-1">-</div>
        </div>
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
          <div class="text-[.68rem] text-[var(--text-muted)] font-semibold">{t('admin.analytics.kpiLeadership', lang)}</div>
          <div id="kpi-leadership" class="text-2xl font-black text-emerald-600 mt-1">-</div>
          <div id="kpi-leadership-meta" class="text-[.65rem] text-[var(--text-muted)] mt-1">-</div>
        </div>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <ChartCard
          cardId="analytics-funnel-card"
          canvasId="analytics-funnel-chart"
          title={t('admin.analytics.funnelTitle', lang)}
          subtitle={t('admin.analytics.funnelDesc', lang)}
          heightClass="h-[320px]"
        >
          <p id="analytics-funnel-note" class="text-[.68rem] text-[var(--text-muted)] mt-3"></p>
        </ChartCard>

        <ChartCard
          cardId="analytics-impact-tribe-card"
          canvasId="analytics-impact-tribe-chart"
          title={t('admin.analytics.impactTribeTitle', lang)}
          subtitle={t('admin.analytics.impactTribeDesc', lang)}
          heightClass="h-[320px]"
        >
          <p id="analytics-impact-tribe-note" class="text-[.68rem] text-[var(--text-muted)] mt-3"></p>
        </ChartCard>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <ChartCard
          cardId="analytics-impact-chapter-card"
          canvasId="analytics-impact-chapter-chart"
          title={t('admin.analytics.impactChapterTitle', lang)}
          subtitle={t('admin.analytics.impactChapterDesc', lang)}
          heightClass="h-[320px]"
        >
          <p id="analytics-impact-chapter-note" class="text-[.68rem] text-[var(--text-muted)] mt-3"></p>
        </ChartCard>

        <ChartCard
          cardId="analytics-cert-card"
          canvasId="analytics-cert-chart"
          title={t('admin.analytics.certTitle', lang)}
          subtitle={t('admin.analytics.certDesc', lang)}
          heightClass="h-[320px]"
        >
          <p id="analytics-cert-note" class="text-[.68rem] text-[var(--text-muted)] mt-3"></p>
        </ChartCard>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <ChartCard
          cardId="analytics-roi-card"
          canvasId="analytics-roi-chart"
          title={t('admin.analytics.roiTitle', lang)}
          subtitle={t('admin.analytics.roiDesc', lang)}
          heightClass="h-[320px]"
        >
          <p id="analytics-roi-note" class="text-[.68rem] text-[var(--text-muted)] mt-3"></p>
        </ChartCard>

        <ChartCard
          cardId="analytics-leadership-card"
          canvasId="analytics-leadership-chart"
          title={t('admin.analytics.leadershipTitle', lang)}
          subtitle={t('admin.analytics.leadershipDesc', lang)}
          heightClass="h-[320px]"
        >
          <div id="analytics-leadership-highlight" class="text-[.68rem] text-[var(--text-secondary)] mt-3"></div>
        </ChartCard>
      </div>

      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden" id="analytics-transition-matrix-card">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.analytics.transitionMatrixTitle', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">{t('admin.analytics.transitionMatrixDesc', lang)}</p>
        </div>
        <div class="p-4">
          <div id="analytics-transition-matrix" class="overflow-x-auto text-sm text-[var(--text-secondary)]">
            <p class="text-[.72rem] text-[var(--text-muted)]">{t('admin.analytics.loading', lang)}</p>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ ANALYTICS_I18N, chapterOptions }}>
  window.__ANALYTICS_I18N = typeof ANALYTICS_I18N !== 'undefined' ? ANALYTICS_I18N : {};
  window.__ANALYTICS_CHAPTER_OPTIONS = Array.isArray(chapterOptions) ? chapterOptions : [];
</script>
<script>
  import { canReadInternalAnalytics } from '../../lib/admin/constants';
  import { buildTribeLabel } from '../../lib/tribes/catalog';

  const CONSENT_KEY = 'analytics_consent';
  const L = (typeof window !== 'undefined' && (window as any).__ANALYTICS_I18N) || {};
  const CHAPTER_OPTIONS = (typeof window !== 'undefined' && (window as any).__ANALYTICS_CHAPTER_OPTIONS) || [];
  const PALETTE = ['#0d9488', '#7c3aed', '#2563eb', '#e11d48', '#ea580c', '#65a30d', '#0891b2', '#6366f1'];

  let sb: any = null;
  let MEMBER: any = null;
  let filters = { cycleCode: '', tribeId: '', chapter: '' };
  let chartInstances = new Map<string, any>();
  let chartPromise: Promise<any> | null = null;
  let tribeMap = new Map<number, string>();
  let lastSnapshot: any = null;

  function toast(msg: string, type = '') {
    (window as any).toast?.(msg, type);
  }

  function formatNumber(value: number | string | null | undefined, digits = 0): string {
    const numeric = Number(value || 0);
    return new Intl.NumberFormat(document.documentElement.lang || 'pt-BR', {
      minimumFractionDigits: digits,
      maximumFractionDigits: digits,
    }).format(Number.isFinite(numeric) ? numeric : 0);
  }

  function formatPercent(part: number, total: number): string {
    if (!total) return '0%';
    return `${Math.round((part / total) * 100)}%`;
  }

  function setText(id: string, value: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  }

  function setNote(id: string, value: string) {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  }

  function showDenied() {
    document.getElementById('analytics-loading')?.classList.add('hidden');
    document.getElementById('analytics-denied')?.classList.remove('hidden');
    document.getElementById('analytics-panel')?.classList.add('hidden');
  }

  function showPanel() {
    document.getElementById('analytics-loading')?.classList.add('hidden');
    document.getElementById('analytics-denied')?.classList.add('hidden');
    document.getElementById('analytics-panel')?.classList.remove('hidden');
  }

  function consentValue(): 'granted' | 'denied' | 'unknown' {
    const raw = localStorage.getItem(CONSENT_KEY);
    if (raw === 'granted' || raw === 'denied') return raw;
    return 'unknown';
  }

  function renderConsentStatus() {
    const statusEl = document.getElementById('consent-status');
    if (!statusEl) return;
    const current = consentValue();
    if (current === 'granted') {
      statusEl.textContent = L.consentGranted || 'Consent granted';
      statusEl.className = 'text-[.68rem] text-emerald-600 mt-1';
      return;
    }
    if (current === 'denied') {
      statusEl.textContent = L.consentDenied || 'Consent revoked';
      statusEl.className = 'text-[.68rem] text-crimson mt-1';
      return;
    }
    statusEl.textContent = L.consentUnknown || 'Consent unknown';
    statusEl.className = 'text-[.68rem] text-[var(--text-muted)] mt-1';
  }

  function setupConsentUi() {
    const grantBtn = document.getElementById('btn-consent-grant');
    const revokeBtn = document.getElementById('btn-consent-revoke');
    if (grantBtn && !grantBtn.dataset.bound) {
      grantBtn.dataset.bound = '1';
      grantBtn.addEventListener('click', () => {
        localStorage.setItem(CONSENT_KEY, 'granted');
        renderConsentStatus();
      });
    }
    if (revokeBtn && !revokeBtn.dataset.bound) {
      revokeBtn.dataset.bound = '1';
      revokeBtn.addEventListener('click', () => {
        localStorage.setItem(CONSENT_KEY, 'denied');
        renderConsentStatus();
      });
    }
    renderConsentStatus();
  }

  async function getChartLib() {
    if (!chartPromise) {
      chartPromise = import('chart.js').then((mod) => {
        const {
          Chart,
          BarController,
          BarElement,
          LineController,
          LineElement,
          CategoryScale,
          LinearScale,
          PointElement,
          ArcElement,
          DoughnutController,
          Tooltip,
          Legend,
        } = mod;
        Chart.register(
          BarController,
          BarElement,
          LineController,
          LineElement,
          CategoryScale,
          LinearScale,
          PointElement,
          ArcElement,
          DoughnutController,
          Tooltip,
          Legend,
        );
        return Chart;
      });
    }
    return chartPromise;
  }

  async function upsertChart(canvasId: string, config: any) {
    const canvas = document.getElementById(canvasId) as HTMLCanvasElement | null;
    if (!canvas) return;
    const Chart = await getChartLib();
    chartInstances.get(canvasId)?.destroy?.();
    chartInstances.set(canvasId, new Chart(canvas, config));
  }

  function renderEmptyChart(canvasId: string, noteId: string) {
    chartInstances.get(canvasId)?.destroy?.();
    chartInstances.delete(canvasId);
    setNote(noteId, L.chartNoData || L.emptyState || 'No data');
  }

  function getFilterPayload() {
    return {
      p_cycle_code: filters.cycleCode || null,
      p_tribe_id: filters.tribeId ? Number(filters.tribeId) : null,
      p_chapter: filters.chapter || null,
    };
  }

  async function safeRpc(name: string) {
    try {
      const { data, error } = await sb.rpc(name, getFilterPayload());
      if (error) throw error;
      return data || {};
    } catch (error) {
      console.warn(name, error);
      toast(`${L.chartError || 'Analytics error'}: ${name}`, 'error');
      return null;
    }
  }

  function populateSelect(selectId: string, options: Array<{ value: string; label: string }>, defaultLabel: string, selected = '') {
    const select = document.getElementById(selectId) as HTMLSelectElement | null;
    if (!select) return;
    const html = [`<option value="">${defaultLabel}</option>`]
      .concat(options.map((option) => `<option value="${option.value}">${option.label}</option>`))
      .join('');
    select.innerHTML = html;
    select.value = selected;
  }

  async function loadFilterOptions() {
    const [cyclesRes, tribesRes] = await Promise.all([
      sb.from('cycles').select('cycle_code, cycle_label, is_current, sort_order').order('sort_order', { ascending: false }),
      sb.from('tribes').select('id, name, is_active').eq('is_active', true).order('id'),
    ]);

    const cycles = Array.isArray(cyclesRes.data) ? cyclesRes.data : [];
    const activeTribes = Array.isArray(tribesRes.data) ? tribesRes.data : [];

    tribeMap = new Map(activeTribes.map((tribe: any) => [Number(tribe.id), buildTribeLabel(tribe)]));

    if (!filters.cycleCode) {
      const currentCycle = cycles.find((cycle: any) => cycle.is_current) || cycles[0];
      filters.cycleCode = currentCycle?.cycle_code || '';
    }

    populateSelect(
      'analytics-filter-cycle',
      cycles.map((cycle: any) => ({ value: cycle.cycle_code, label: cycle.cycle_label || cycle.cycle_code })),
      L.allCyclesLabel || 'All cycles',
      filters.cycleCode
    );
    populateSelect(
      'analytics-filter-tribe',
      activeTribes.map((tribe: any) => ({
        value: String(tribe.id),
        label: `${String(tribe.id).padStart(2, '0')} - ${buildTribeLabel(tribe)}`,
      })),
      L.allTribesLabel || 'All tribes',
      filters.tribeId
    );
    populateSelect(
      'analytics-filter-chapter',
      CHAPTER_OPTIONS.map((chapter: any) => ({ value: chapter.code, label: chapter.code })),
      L.allChaptersLabel || 'All chapters',
      filters.chapter
    );
  }

  function bindFilterUi() {
    const applyBtn = document.getElementById('analytics-apply');
    const resetBtn = document.getElementById('analytics-reset');

    if (applyBtn && !applyBtn.dataset.bound) {
      applyBtn.dataset.bound = '1';
      applyBtn.addEventListener('click', () => {
        const cycle = document.getElementById('analytics-filter-cycle') as HTMLSelectElement | null;
        const tribe = document.getElementById('analytics-filter-tribe') as HTMLSelectElement | null;
        const chapter = document.getElementById('analytics-filter-chapter') as HTMLSelectElement | null;
        filters = {
          cycleCode: cycle?.value || '',
          tribeId: tribe?.value || '',
          chapter: chapter?.value || '',
        };
        loadAnalyticsV2();
      });
    }

    if (resetBtn && !resetBtn.dataset.bound) {
      resetBtn.dataset.bound = '1';
      resetBtn.addEventListener('click', async () => {
        filters = { cycleCode: '', tribeId: '', chapter: '' };
        await loadFilterOptions();
        loadAnalyticsV2();
      });
    }
  }

  function buildScopeSummary(funnel: any) {
    const cycleSelect = document.getElementById('analytics-filter-cycle') as HTMLSelectElement | null;
    const tribeSelect = document.getElementById('analytics-filter-tribe') as HTMLSelectElement | null;
    const chapterSelect = document.getElementById('analytics-filter-chapter') as HTMLSelectElement | null;
    const cycleLabel = funnel?.cycle_label || cycleSelect?.selectedOptions?.[0]?.textContent || L.allCyclesLabel || '';
    const tribeLabel = tribeSelect?.value ? tribeSelect.selectedOptions?.[0]?.textContent : (L.allTribesLabel || '');
    const chapterLabel = chapterSelect?.value ? chapterSelect.selectedOptions?.[0]?.textContent : (L.allChaptersLabel || '');
    return `${L.scopePrefix || 'Scope'}: ${cycleLabel} | ${tribeLabel} | ${chapterLabel}`;
  }

  function renderKpis(funnel: any, impact: any, roi: any, leadership: any) {
    const stages = funnel?.stages || {};
    const totalMembers = Number(stages.total_members || 0);
    const fullCore = Number(stages.members_with_full_core_trail || 0);
    const totalImpactHours = Number(impact?.total_impact_hours || 0);
    const impactPct = Number(impact?.percent_of_target || 0);
    const attributedAffiliations = Array.isArray(roi?.chapters)
      ? roi.chapters.reduce((sum: number, chapter: any) => sum + Number(chapter.attributed_conversions || 0), 0)
      : 0;
    const promotedMembers = Number(leadership?.summary?.promoted_members || 0);
    const trackedTransitions = Number(leadership?.summary?.tracked_transitions || 0);

    setText('kpi-cohort-members', formatNumber(totalMembers));
    setText('kpi-cohort-meta', buildScopeSummary(funnel));

    setText('kpi-onboarding-rate', formatPercent(fullCore, totalMembers));
    setText('kpi-onboarding-meta', `${formatNumber(fullCore)} / ${formatNumber(totalMembers)}`);

    setText('kpi-impact-hours', `${formatNumber(totalImpactHours, 1)}h`);
    setText('kpi-impact-meta', `${formatNumber(impactPct, 1)}% ${L.targetMeta || 'of target'}`);

    setText('kpi-affiliations', formatNumber(attributedAffiliations));
    setText('kpi-affiliations-meta', L.attributedAffiliates || 'Attributed affiliations');

    setText('kpi-leadership', formatNumber(promotedMembers));
    setText('kpi-leadership-meta', `${formatNumber(trackedTransitions)} ${L.transitions || 'transitions'}`);
  }

  async function renderFunnelChart(funnel: any) {
    const stages = funnel?.stages || {};
    const values = [
      Number(stages.total_members || 0),
      Number(stages.members_with_full_core_trail || 0),
      Number(stages.members_allocated_to_tribe || 0),
      Number(stages.members_with_published_artifact || 0),
    ];
    if (!values.some(Boolean)) {
      renderEmptyChart('analytics-funnel-chart', 'analytics-funnel-note');
      return;
    }
    setNote('analytics-funnel-note', '');
    await upsertChart('analytics-funnel-chart', {
      type: 'bar',
      data: {
        labels: [
          L.stageEntered || 'Entered',
          L.stageOnboarding || 'Onboarding',
          L.stageAllocated || 'Allocated',
          L.stagePublished || 'Published',
        ],
        datasets: [{
          label: L.stageEntered || 'Members',
          data: values,
          backgroundColor: PALETTE.slice(0, 4),
          borderRadius: 10,
        }],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { beginAtZero: true, ticks: { precision: 0 } },
          y: { grid: { display: false } },
        },
      },
    });
  }

  async function renderImpactCharts(impact: any) {
    const tribes = Array.isArray(impact?.breakdown_by_tribe) ? impact.breakdown_by_tribe : [];
    const chapters = Array.isArray(impact?.breakdown_by_chapter) ? impact.breakdown_by_chapter : [];

    if (!tribes.length) {
      renderEmptyChart('analytics-impact-tribe-chart', 'analytics-impact-tribe-note');
    } else {
      setNote('analytics-impact-tribe-note', '');
      await upsertChart('analytics-impact-tribe-chart', {
        type: 'bar',
        data: {
          labels: tribes.map((item: any) => tribeMap.get(Number(item.tribe_id)) || `Tribo ${item.tribe_id}`),
          datasets: [{
            label: L.impactHoursShort || 'Hours',
            data: tribes.map((item: any) => Number(item.impact_hours || 0)),
            backgroundColor: PALETTE,
            borderRadius: 10,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true } },
        },
      });
    }

    if (!chapters.length) {
      renderEmptyChart('analytics-impact-chapter-chart', 'analytics-impact-chapter-note');
      return;
    }

    setNote('analytics-impact-chapter-note', '');
    await upsertChart('analytics-impact-chapter-chart', {
      type: 'doughnut',
      data: {
        labels: chapters.map((item: any) => item.chapter),
        datasets: [{
          data: chapters.map((item: any) => Number(item.impact_hours || 0)),
          backgroundColor: PALETTE,
          borderWidth: 2,
          borderColor: '#fff',
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
      },
    });
  }

  async function renderCertChart(cert: any) {
    const series = Array.isArray(cert?.series) ? cert.series : [];
    if (!series.length) {
      renderEmptyChart('analytics-cert-chart', 'analytics-cert-note');
      return;
    }

    setNote(
      'analytics-cert-note',
      `${formatNumber(cert?.summary?.prior_background || 0)} ${L.backgroundLabel || 'background'} | ${formatNumber(cert?.summary?.hub_impact || 0)} ${L.impactLabel || 'impact'}`
    );

    await upsertChart('analytics-cert-chart', {
      type: 'bar',
      data: {
        labels: series.map((item: any) => item.certification_type),
        datasets: [
          {
            label: L.backgroundLabel || 'Background',
            data: series.map((item: any) => Number(item.prior_background || 0)),
            backgroundColor: PALETTE[5],
            borderRadius: 8,
          },
          {
            label: L.impactLabel || 'Hub impact',
            data: series.map((item: any) => Number(item.hub_impact || 0)),
            backgroundColor: PALETTE[0],
            borderRadius: 8,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
        scales: {
          x: { stacked: true },
          y: { stacked: true, beginAtZero: true, ticks: { precision: 0 } },
        },
      },
    });
  }

  async function renderRoiChart(roi: any) {
    const chapters = Array.isArray(roi?.chapters) ? roi.chapters : [];
    if (!chapters.length) {
      renderEmptyChart('analytics-roi-chart', 'analytics-roi-note');
      return;
    }

    setNote('analytics-roi-note', '');
    await upsertChart('analytics-roi-chart', {
      type: 'bar',
      data: {
        labels: chapters.map((item: any) => item.chapter_code),
        datasets: [
          {
            label: L.currentAffiliates || 'Current affiliates',
            data: chapters.map((item: any) => Number(item.current_active_affiliates || 0)),
            backgroundColor: PALETTE[2],
            borderRadius: 8,
          },
          {
            label: L.attributedAffiliates || 'Attributed',
            data: chapters.map((item: any) => Number(item.attributed_conversions || 0)),
            backgroundColor: PALETTE[4],
            borderRadius: 8,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom' } },
        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
      },
    });
  }

  async function renderLeadershipChart(leadership: any) {
    const conversions = Array.isArray(leadership?.conversions_by_cycle) ? leadership.conversions_by_cycle : [];
    if (!conversions.length) {
      renderEmptyChart('analytics-leadership-chart', 'analytics-leadership-highlight');
      return;
    }

    const topCycle = [...conversions].sort((a: any, b: any) => Number(b.promoted_members || 0) - Number(a.promoted_members || 0))[0];
    setText(
      'analytics-leadership-highlight',
      topCycle
        ? `${topCycle.cycle_label || topCycle.cycle_code}: ${formatNumber(topCycle.promoted_members || 0)} ${L.promotedMembers || 'promoted members'}`
        : ''
    );

    await upsertChart('analytics-leadership-chart', {
      type: 'bar',
      data: {
        labels: conversions.map((item: any) => item.cycle_label || item.cycle_code),
        datasets: [{
          label: L.promotedMembers || 'Promoted members',
          data: conversions.map((item: any) => Number(item.promoted_members || 0)),
          backgroundColor: PALETTE[6],
          borderRadius: 8,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
      },
    });
  }

  function renderTransitionMatrix(leadership: any) {
    const matrix = Array.isArray(leadership?.transition_matrix) ? leadership.transition_matrix : [];
    const container = document.getElementById('analytics-transition-matrix');
    if (!container) return;
    if (!matrix.length) {
      container.innerHTML = `<p class="text-[.72rem] text-[var(--text-muted)]">${L.chartNoData || L.emptyState || 'No data'}</p>`;
      return;
    }
    container.innerHTML = `
      <table class="w-full text-left text-[.78rem]">
        <thead>
          <tr class="border-b border-[var(--border-default)] text-[var(--text-secondary)] uppercase tracking-wide text-[.65rem]">
            <th class="py-2 pr-3">${L.transitionFrom || 'From'}</th>
            <th class="py-2 pr-3">${L.transitionTo || 'To'}</th>
            <th class="py-2">${L.transitionCount || 'Transitions'}</th>
          </tr>
        </thead>
        <tbody>
          ${matrix.slice(0, 10).map((row: any) => `
            <tr class="border-b border-[var(--border-subtle)]">
              <td class="py-2 pr-3">${row.from_role_bucket || '-'}</td>
              <td class="py-2 pr-3">${row.to_role_bucket || '-'}</td>
              <td class="py-2 font-semibold text-navy">${formatNumber(row.transitions || 0)}</td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  function buildExecutiveSummary(): string {
    if (!lastSnapshot) return '';
    const { funnel, impact, roi, leadership, quality } = lastSnapshot;
    const stages = funnel?.stages || {};
    const chapterCount = Array.isArray(roi?.chapters) ? roi.chapters.length : 0;
    const promoted = Number(leadership?.summary?.promoted_members || 0);
    const transitions = Number(leadership?.summary?.tracked_transitions || 0);
    const qualityIssues = Array.isArray(quality?.issues) ? quality.issues.length : 0;
    const qualityWarnings = Array.isArray(quality?.warnings) ? quality.warnings.length : 0;
    return [
      `Scope: ${buildScopeSummary(funnel)}`,
      `Funnel => total: ${stages.total_members || 0}, onboarding: ${stages.members_with_full_core_trail || 0}, allocated: ${stages.members_allocated_to_tribe || 0}, published: ${stages.members_with_published_artifact || 0}`,
      `Impact => hours: ${impact?.total_impact_hours || 0}, target%: ${impact?.percent_of_target || 0}`,
      `ROI => chapters: ${chapterCount}, attributed conversions: ${(roi?.chapters || []).reduce((s: number, c: any) => s + Number(c.attributed_conversions || 0), 0)}`,
      `Leadership => promoted: ${promoted}, tracked transitions: ${transitions}`,
      `Quality => issues: ${qualityIssues}, warnings: ${qualityWarnings}`,
    ].join('\n');
  }

  function bindPartnerUxActions() {
    const copyBtn = document.getElementById('analytics-copy-summary');
    if (!copyBtn || copyBtn.dataset.bound) return;
    copyBtn.dataset.bound = '1';
    copyBtn.addEventListener('click', async () => {
      const summary = buildExecutiveSummary();
      if (!summary) {
        toast(L.summaryCopyError || 'Unable to copy summary', 'error');
        return;
      }
      try {
        await navigator.clipboard?.writeText(summary);
        toast(L.summaryCopied || 'Summary copied', 'success');
      } catch {
        toast(L.summaryCopyError || 'Unable to copy summary', 'error');
      }
    });
  }

  function renderQuality(quality: any) {
    const banner = document.getElementById('analytics-quality-banner');
    const title = document.getElementById('analytics-quality-title');
    const status = document.getElementById('analytics-quality-status');
    const body = document.getElementById('analytics-quality-body');
    const windowEl = document.getElementById('analytics-quality-window');
    if (!banner || !title || !status || !body || !windowEl) return;
    if (!quality) {
      banner.classList.add('hidden');
      return;
    }
    const issues: string[] = Array.isArray(quality.issues) ? quality.issues : [];
    const warnings: string[] = Array.isArray(quality.warnings) ? quality.warnings : [];
    const beforeDays = Number(quality?.attribution_window?.before_days || 30);
    const afterDays = Number(quality?.attribution_window?.after_days || 90);

    title.textContent = L.qualityTitle || 'Data quality';
    windowEl.textContent = `${L.qualityWindowLabel || 'ROI attribution window'}: -${beforeDays} / +${afterDays} days`;

    if (!issues.length && !warnings.length) {
      banner.className = 'rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3';
      status.textContent = L.qualityOk || 'No issues detected';
      status.className = 'text-[.68rem] font-semibold text-emerald-700';
      body.textContent = '';
      banner.classList.remove('hidden');
      return;
    }

    const chunks = [];
    if (issues.length) chunks.push(`${L.qualityIssue || 'Issues'}: ${issues.join(', ')}`);
    if (warnings.length) chunks.push(`${L.qualityWarn || 'Warnings'}: ${warnings.join(', ')}`);
    body.textContent = chunks.join(' | ');

    if (issues.length) {
      banner.className = 'rounded-xl border border-amber-300 bg-amber-50 px-4 py-3';
      status.textContent = `${issues.length} ${L.qualityIssue || 'issues'}`;
      status.className = 'text-[.68rem] font-semibold text-amber-800';
    } else {
      banner.className = 'rounded-xl border border-sky-300 bg-sky-50 px-4 py-3';
      status.textContent = `${warnings.length} ${L.qualityWarn || 'warnings'}`;
      status.className = 'text-[.68rem] font-semibold text-sky-700';
    }
    banner.classList.remove('hidden');
  }

  async function loadAnalyticsV2() {
    setText('analytics-scope-summary', L.scopePrefix || 'Loading...');
    const [funnel, impact, cert, roi, leadership, quality] = await Promise.all([
      safeRpc('exec_funnel_summary'),
      safeRpc('exec_impact_hours_v2'),
      safeRpc('exec_certification_delta'),
      safeRpc('exec_chapter_roi'),
      safeRpc('exec_role_transitions'),
      safeRpc('exec_analytics_v2_quality'),
    ]);

    if (!funnel || !impact || !cert || !roi || !leadership) {
      setText('analytics-scope-summary', L.chartError || 'Analytics error');
      renderQuality(quality);
      return;
    }

    setText('analytics-scope-summary', buildScopeSummary(funnel));
    lastSnapshot = { funnel, impact, cert, roi, leadership, quality };
    renderQuality(quality);
    renderKpis(funnel, impact, roi, leadership);
    await Promise.all([
      renderFunnelChart(funnel),
      renderImpactCharts(impact),
      renderCertChart(cert),
      renderRoiChart(roi),
      renderLeadershipChart(leadership),
    ]);
    renderTransitionMatrix(leadership);
  }

  let _initDone = false;

  async function init() {
    if (_initDone) return;
    sb = (window as any).navGetSb?.();
    MEMBER = (window as any).navGetMember?.();

    if (!sb || !MEMBER) return; // Not ready yet — don't show denied, just wait
    if (!canReadInternalAnalytics(MEMBER)) {
      _initDone = true;
      showDenied();
      return;
    }

    _initDone = true;
    showPanel();
    setupConsentUi();
    bindPartnerUxActions();
    bindFilterUi();
    await loadFilterOptions();
    await loadAnalyticsV2();
  }

  function boot() {
    if ((window as any).navGetMember?.()) {
      init();
      return;
    }
    window.addEventListener('nav:member', () => init(), { once: true });
    // Retry pattern: check multiple times instead of single timeout
    const retryIntervals = [500, 1000, 2000, 4000];
    retryIntervals.forEach(ms => setTimeout(() => { if (!_initDone) init(); }, ms));
    // Final fallback: if nothing resolved after 5s, show denied
    setTimeout(() => { if (!_initDone) { _initDone = true; showDenied(); } }, 5000);
  }

  boot();
</script>
