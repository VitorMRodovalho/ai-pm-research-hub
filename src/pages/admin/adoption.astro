  function renderAuthCard(auth: any) {
    const el = document.getElementById('adp-auth');
    if (!el) return;
    let providers = auth?.providers || [];
    const ghosts = auth?.ghost_count || 0;
    const secondary = auth?.members_with_secondary_auth || 0;
    const totalLogins = auth?.total_logins || 0;

    // Ensure all configured providers appear (even with 0 logins)
    const CONFIGURED_PROVIDERS = ['google', 'azure', 'linkedin_oidc', 'email'];
    const existingProviders = new Set(providers.map((p: any) => p.provider));
    for (const cp of CONFIGURED_PROVIDERS) {
      if (!existingProviders.has(cp)) {
        providers.push({ provider: cp, total: 0, pct: 0 });
      }
    }

    const maxProv = Math.max(1, ...providers.map((p: any) => p.total));
    const provBars = providers.map((p: any) => {
      const pct = p.pct ?? (totalLogins > 0 ? Math.round((p.total / totalLogins) * 100) : 0);
      const barW = Math.round((p.total / maxProv) * 100);
      const provName = (p.provider || 'unknown').replace('google', 'Google').replace('linkedin_oidc', 'LinkedIn').replace('azure', 'Microsoft').replace('email', 'Magic Link');
      return `<div class="flex items-center gap-2 text-[.72rem]">
        <span class="w-20 font-semibold text-[var(--text-primary)]">${esc(provName)}</span>
        <span class="text-[var(--text-muted)] w-8 text-right">${p.total}</span>
        <div class="flex-1 h-2 rounded-full bg-[var(--border-subtle)] overflow-hidden">
          <div class="h-full rounded-full bg-navy" style="width:${barW}%"></div>
        </div>
        <span class="text-[var(--text-muted)] w-10 text-right">${pct}%</span>
      </div>`;
    }).join('');

    el.innerHTML = `
      <h3 class="text-sm font-bold text-navy mb-3">Provedores de Auth</h3>
      <p class="text-[.68rem] text-[var(--text-muted)] mb-2">${totalLogins} sessões de login</p>
      <div class="space-y-1.5 mb-3">${provBars}</div>
      <div class="flex gap-4 text-[.68rem] text-[var(--text-muted)]">
        ${ghosts > 0 ? `<span>👻 ${ghosts} visitante${ghosts > 1 ? 's' : ''} externo${ghosts > 1 ? 's' : ''}</span>` : ''}
        ${secondary > 0 ? `<span>🔗 ${secondary} com login secundario</span>` : ''}
      </div>`;
  }

  function renderMemberTable() {
    const body = document.getElementById('adp-member-body');
    if (!body) return;
    const filterVal = (document.getElementById('adp-filter-status') as HTMLSelectElement)?.value || '';
    const search = ((document.getElementById('adp-search') as HTMLInputElement)?.value || '').toLowerCase();

    let filtered = allMembers;

    // Apply filter
    if (filterVal.startsWith('role:')) {
      const role = filterVal.slice(5);
      filtered = filtered.filter((m: any) => m.tier === role);
    } else if (filterVal === 'desig:none') {
      filtered = filtered.filter((m: any) => !m.designations || m.designations.length === 0);
    } else if (filterVal.startsWith('desig:')) {
      const desig = filterVal.slice(6);
      filtered = filtered.filter((m: any) => (m.designations || []).includes(desig));
    } else if (filterVal) {
      filtered = filtered.filter((m: any) => m.status === filterVal);
    }

    if (search) filtered = filtered.filter((m: any) => (m.name || '').toLowerCase().includes(search));

    // Sort
    filtered.sort((a: any, b: any) => {
      let va: any, vb: any;
      if (sortField === 'name') { va = a.name || ''; vb = b.name || ''; }
      else if (sortField === 'sessions') { va = a.total_sessions || 0; vb = b.total_sessions || 0; }
      else { va = a.last_seen || ''; vb = b.last_seen || ''; }
      if (va < vb) return sortAsc ? -1 : 1;
      if (va > vb) return sortAsc ? 1 : -1;
      return 0;
    });

    const mcpCol = ''; // MCP column is rendered per-member below

    body.innerHTML = filtered.map((m: any) => {
      const desigBadges = (m.designations || []).map((d: string) =>
        `<span class="inline-block px-1 py-0.5 rounded text-[9px] font-bold bg-[var(--surface-section-cool)] text-[var(--text-muted)]">${esc(d)}</span>`
      ).join(' ');
      return `
      <tr class="border-t border-[var(--border-subtle)] hover:bg-[var(--surface-hover)]">
        <td class="px-4 py-2">
          <div class="font-semibold text-navy">${esc(m.name || '—')}</div>
          ${desigBadges ? `<div class="mt-0.5 flex gap-1 flex-wrap">${desigBadges}</div>` : ''}
        </td>
        <td class="px-3 py-2 text-center text-[.68rem]">${esc(ROLE_LABELS[m.tier] || m.tier || '—')}</td>
        <td class="px-3 py-2 text-center text-[.68rem]">${m.tribe_name ? esc(m.tribe_name) : '—'}</td>
        <td class="px-3 py-2 text-center">${relativeTime(m.last_seen)}</td>
        <td class="px-3 py-2 text-center font-bold">${m.total_sessions || 0}</td>
        ${hasMcpData ? `<td class="px-3 py-2 text-center">${mcpUserIds.has(m.id) ? '🤖' : '—'}</td>` : ''}
        <td class="px-3 py-2 text-center">${STATUS_ICONS[m.status] || ''}</td>
      </tr>`;
    }).join('');
  }

  async function loadDashboard() {
    if (!sb) return;
    try {
      const { data, error } = await sb.rpc('get_adoption_dashboard');
      if (error) throw error;
      if (!data) return;

      renderKpis(data.summary || {});
      renderMcpCard(data.mcp_usage || {});
      renderAuthCard(data.auth_providers || {});
      renderLifecycle(data.lifecycle || {});
      renderChart(data.daily_activity || []);
      renderTribeTable(data.by_tribe || []);
      renderTierTable(data.by_tier || []);
      allMembers = data.members || [];
      renderMemberTable();
    } catch (e: any) {
      console.error('Adoption dashboard:', e);
      (window as any).toast?.('Erro: ' + (e.message || ''), 'error');
    }
  }

  // ── Analytics Tab — Phase 2 Native Charts ──
  const PROXY_BASE = 'https://ldrfrvwhxsmgaabwmaik.supabase.co/functions/v1/posthog-proxy';
  let analyticsLoaded = false;
  let visitorsLoaded = false;
  let analyticsPeriod = 30;
  let chartInstances: any[] = [];

  async function phQuery(q: string, days?: number) {
    try {
      const session = await sb.auth.getSession();
      const token = session.data.session?.access_token;
      if (!token) return null;
      const d = days || analyticsPeriod;
      const resp = await fetch(`${PROXY_BASE}?action=query&q=${q}&days=${d}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!resp.ok) return null;
      return await resp.json();
    } catch { return null; }
  }

  async function phGet(endpoint: string, id?: string) {
    try {
      const session = await sb.auth.getSession();
      const token = session.data.session?.access_token;
      if (!token) return null;
      const params = new URLSearchParams({ endpoint });
      if (id) params.set('id', id);
      const resp = await fetch(`${PROXY_BASE}?${params}`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (!resp.ok) return null;
      return await resp.json();
    } catch { return null; }
  }

  function destroyCharts() {
    chartInstances.forEach(c => { try { c.destroy(); } catch {} });
    chartInstances = [];
  }

  async function loadAnalytics() {
    destroyCharts();

    // Fetch all 5 queries + Phase 1 details in parallel
    const [dauWau, topPages, traffic, rage, retention, dashData] = await Promise.all([
      phQuery('dau_wau'),
      phQuery('top_pages'),
      phQuery('traffic_sources'),
      phQuery('rage_clicks'),
      phQuery('retention_weekly', Math.max(analyticsPeriod, 60)),
      phGet('dashboards', '1407425'),
    ]);

    const { Chart, LineController, BarController, DoughnutController, CategoryScale, LinearScale,
      PointElement, LineElement, BarElement, ArcElement, Legend, Tooltip, Filler } = await import('chart.js');
    Chart.register(LineController, BarController, DoughnutController, CategoryScale, LinearScale,
      PointElement, LineElement, BarElement, ArcElement, Legend, Tooltip, Filler);

    // 1. DAU/WAU Line Chart
    const dauEl = document.getElementById('canvas-dau-wau') as HTMLCanvasElement;
    const dauEmpty = document.getElementById('chart-dau-wau-empty')!;
    if (dauWau?.series?.length && dauWau.series[0]?.data?.length) {
      dauEmpty.classList.add('hidden');
      dauEl.parentElement!.classList.remove('hidden');
      const labels = (dauWau.series[0].labels || []).map((l: string) => l.length > 6 ? l.slice(-5) : l);
      const ch = new Chart(dauEl, {
        type: 'line',
        data: {
          labels,
          datasets: [
            { label: 'DAU', data: dauWau.series[0]?.data || [], borderColor: '#003B5C', backgroundColor: 'rgba(0,59,92,0.1)', fill: true, tension: 0.3, pointRadius: 1 },
            ...(dauWau.series[1] ? [{ label: 'WAU', data: dauWau.series[1].data, borderColor: '#93C5FD', borderDash: [5, 5], fill: false, tension: 0.3, pointRadius: 0 }] : []),
          ],
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } }, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false }, ticks: { maxTicksLimit: 10, font: { size: 9 } } } } },
      });
      chartInstances.push(ch);
    } else {
      dauEl.parentElement!.classList.add('hidden');
      dauEmpty.classList.remove('hidden');
    }

    // 2. Rage Clicks
    const rageEl = document.getElementById('chart-rage')!;
    const rageTotal = rage?.series?.[0]?.count || 0;
    if (rageTotal === 0) {
      rageEl.innerHTML = `<div class="text-center"><div class="text-4xl font-extrabold text-emerald-600">0</div><div class="text-sm text-emerald-600 mt-1">${document.getElementById('ai18n-nor')?.textContent || 'No rage clicks'}</div></div>`;
    } else {
      const color = rageTotal > 50 ? 'text-red-600' : rageTotal > 10 ? 'text-amber-600' : 'text-[var(--text-primary)]';
      rageEl.innerHTML = `<div class="text-center"><div class="text-4xl font-extrabold ${color}">${rageTotal}</div><div class="text-sm ${color} mt-1">cliques de frustracao</div><div class="text-[.68rem] text-[var(--text-muted)] mt-2">nos ultimos ${analyticsPeriod} dias</div></div>`;
    }

    // 3. Top Pages Bar Chart
    const pagesCanvas = document.getElementById('canvas-pages') as HTMLCanvasElement;
    const pagesEmpty = document.getElementById('chart-pages-empty')!;
    if (topPages?.series?.length) {
      const items = topPages.series.filter((s: any) => s.breakdown_value).sort((a: any, b: any) => (b.data?.[0] || 0) - (a.data?.[0] || 0)).slice(0, 10);
      if (items.length) {
        pagesEmpty.classList.add('hidden');
        pagesCanvas.parentElement!.classList.remove('hidden');
        const ch = new Chart(pagesCanvas, {
          type: 'bar',
          data: {
            labels: items.map((s: any) => String(s.breakdown_value || '').replace(/^\/(pt-BR|en|es)/, '')),
            datasets: [{ label: 'Views', data: items.map((s: any) => s.data?.[0] || 0), backgroundColor: '#003B5C', borderRadius: 4 }],
          },
          options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true, grid: { color: '#f1f5f9' } }, y: { grid: { display: false }, ticks: { font: { size: 9 } } } } },
        });
        chartInstances.push(ch);
      } else { pagesCanvas.parentElement!.classList.add('hidden'); pagesEmpty.classList.remove('hidden'); }
    } else { pagesCanvas.parentElement!.classList.add('hidden'); pagesEmpty.classList.remove('hidden'); }

    // 4. Traffic Sources Doughnut
    const trafficCanvas = document.getElementById('canvas-traffic') as HTMLCanvasElement;
    const trafficEmpty = document.getElementById('chart-traffic-empty')!;
    if (traffic?.series?.length) {
      const items = traffic.series.filter((s: any) => s.breakdown_value);
      if (items.length) {
        trafficEmpty.classList.add('hidden');
        trafficCanvas.parentElement!.classList.remove('hidden');
        const COLORS = ['#003B5C', '#10B981', '#F59E0B', '#7C3AED', '#94A3B8', '#EC4899', '#06B6D4', '#EF4444'];
        const ch = new Chart(trafficCanvas, {
          type: 'doughnut',
          data: {
            labels: items.map((s: any) => s.breakdown_value || 'Directo'),
            datasets: [{ data: items.map((s: any) => s.count || s.data?.[0] || 0), backgroundColor: COLORS.slice(0, items.length) }],
          },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', labels: { font: { size: 10 } } } } },
        });
        chartInstances.push(ch);
      } else { trafficCanvas.parentElement!.classList.add('hidden'); trafficEmpty.classList.remove('hidden'); }
    } else { trafficCanvas.parentElement!.classList.add('hidden'); trafficEmpty.classList.remove('hidden'); }

    // 5. Retention Grid (HTML table)
    const retEl = document.getElementById('chart-retention')!;
    if (retention?.retention?.length) {
      const cohorts = retention.retention;
      const maxWeeks = Math.max(...cohorts.map((c: any) => c.values?.length || 0));
      let html = '<table class="w-full text-[.68rem] border-collapse"><thead><tr><th class="text-left px-2 py-1 text-[var(--text-muted)]">Cohort</th><th class="text-center px-2 py-1 text-[var(--text-muted)]">Tamanho</th>';
      for (let w = 0; w < maxWeeks; w++) html += `<th class="text-center px-2 py-1 text-[var(--text-muted)]">S${w}</th>`;
      html += '</tr></thead><tbody>';
      cohorts.forEach((c: any) => {
        const size = c.cohort_size || 0;
        html += `<tr><td class="px-2 py-1 font-semibold text-navy">${c.date ? new Date(c.date + 'T12:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' }) : c.label}</td><td class="text-center px-2 py-1 font-bold">${size}</td>`;
        (c.values || []).forEach((v: any, i: number) => {
          const pct = size > 0 ? Math.round((v.count / size) * 100) : 0;
          const intensity = Math.round(pct * 2.55);
          const bg = i === 0 ? 'bg-navy text-white' : `bg-emerald-${pct > 50 ? '200' : pct > 20 ? '100' : '50'}`;
          html += `<td class="text-center px-2 py-1 ${i === 0 ? 'bg-navy/10 font-bold' : ''}" style="${i > 0 ? `background:rgba(16,185,129,${pct / 100 * 0.4});` : ''}">${pct}%<div class="text-[9px] text-[var(--text-muted)]">${v.count}</div></td>`;
        });
        html += '</tr>';
      });
      html += '</tbody></table>';
      retEl.innerHTML = html;
    } else {
      retEl.innerHTML = '<div class="text-sm text-[var(--text-muted)] text-center py-6">Dados insuficientes para retencao (min. 2 semanas)</div>';
    }

    // Phase 1 details (collapsed)
    const detailEl = document.getElementById('analytics-insights-detail');
    if (detailEl && dashData?.tiles) {
      const tiles = dashData.tiles.filter((t: any) => t.insight || t.name).slice(0, 20);
      detailEl.innerHTML = tiles.length ? `<div class="grid grid-cols-1 md:grid-cols-2 gap-3">${tiles.map((tile: any) => {
        const insight = tile.insight || tile;
        const name = insight.name || tile.name || 'Insight';
        const shortId = insight.short_id || '';
        const href = shortId ? `https://us.posthog.com/project/334261/insights/${shortId}` : '#';
        return `<article class="rounded-xl border border-[var(--border-default)] p-3"><div class="flex items-center justify-between gap-2"><span class="text-[.78rem] font-semibold text-navy truncate">${esc(name)}</span><a href="${esc(href)}" target="_blank" rel="noopener" class="text-[.68rem] text-teal no-underline hover:underline shrink-0">Abrir</a></div></article>`;
      }).join('')}</div>` : `<div class="text-sm text-[var(--text-muted)] text-center py-4">${document.getElementById('ai18n-nor')?.textContent || 'No insights found.'}</div>`;
    }

    analyticsLoaded = true;
  }

  // ── VISITORS TAB ──
  async function loadVisitors() {
    try {
      const { data, error } = await sb.rpc('get_ghost_visitors');
      if (error) throw error;
      const ghosts = data || [];

      // KPIs
      const now = new Date();
      const d30 = new Date(now.getTime() - 30 * 86400000);
      const recentCount = ghosts.filter((g: any) => g.last_sign_in_at && new Date(g.last_sign_in_at) > d30).length;
      const matchCount = ghosts.filter((g: any) => g.possible_member_name).length;
      const providers: Record<string, number> = {};
      ghosts.forEach((g: any) => { providers[g.provider || 'unknown'] = (providers[g.provider || 'unknown'] || 0) + 1; });
      const topProvider = Object.entries(providers).sort((a, b) => b[1] - a[1])[0];

      const kpiEl = document.getElementById('visitors-kpis');
      if (kpiEl) {
        kpiEl.innerHTML = [
          kpiCard('👻 Total Ghosts', String(ghosts.length), '', ''),
          kpiCard('🕐 Últimos 30d', String(recentCount), '', ''),
          kpiCard('🔗 Match c/ Membro', String(matchCount), 'login duplicado?', 'text-amber-600'),
          kpiCard('🔑 Top Provider', topProvider ? `${topProvider[0]} (${topProvider[1]})` : '—', '', ''),
        ].join('');
      }

      // Table
      const body = document.getElementById('visitors-body');
      if (!body) return;

      if (!ghosts.length) {
        body.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-[var(--text-muted)]">Nenhum visitante externo encontrado</td></tr>';
        visitorsLoaded = true;
        return;
      }

      const providerIcons: Record<string, string> = { google: '🔵', linkedin_oidc: '🔷', azure: '🟦', email: '📧' };
      body.innerHTML = ghosts.map((g: any) => {
        const createdAt = g.created_at ? new Date(g.created_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: '2-digit' }) : '—';
        const lastLogin = g.last_sign_in_at ? new Date(g.last_sign_in_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: '2-digit' }) : '—';
        const provIcon = providerIcons[g.provider] || '🔑';
        const match = g.possible_member_name
          ? `<span class="text-amber-600 font-semibold" title="Membro existente com mesmo email">⚠️ ${esc(g.possible_member_name)}</span>`
          : '<span class="text-[var(--text-muted)]">—</span>';
        const action = g.possible_member_name
          ? `<span class="text-[.65rem] text-amber-600">Vincular auth</span>`
          : `<span class="text-[.65rem] text-teal">Candidato</span>`;

        return `<tr class="border-b border-[var(--border-subtle)] hover:bg-[var(--surface-hover)]">
          <td class="px-4 py-2.5 font-medium">${esc(g.email)}</td>
          <td class="px-3 py-2.5 text-center">${provIcon} ${esc(g.provider || '?')}</td>
          <td class="px-3 py-2.5 text-center">${createdAt}</td>
          <td class="px-3 py-2.5 text-center">${lastLogin}</td>
          <td class="px-3 py-2.5 text-center">${match}</td>
          <td class="px-3 py-2.5 text-center">${action}</td>
        </tr>`;
      }).join('');
    } catch (e: any) {
      console.error('loadVisitors failed', e);
      const body = document.getElementById('visitors-body');
      if (body) body.innerHTML = `<tr><td colspan="6" class="px-4 py-8 text-center text-red-500">Erro: ${esc(e?.message || 'unknown')}</td></tr>`;
    }
    visitorsLoaded = true;
  }

  function switchTab(tab: string) {
    const tabs = ['members', 'visitors', 'analytics'];
    for (const t of tabs) {
      document.getElementById(`panel-${t}`)?.classList.toggle('hidden', tab !== t);
      const btn = document.getElementById(`tab-${t}`);
      if (btn) {
        btn.classList.toggle('border-navy', tab === t);
        btn.classList.toggle('text-navy', tab === t);
        btn.classList.toggle('border-transparent', tab !== t);
        btn.classList.toggle('text-[var(--text-muted)]', tab !== t);
      }
    }
    if (tab === 'analytics' && !analyticsLoaded) loadAnalytics();
    if (tab === 'visitors' && !visitorsLoaded) loadVisitors();
  }

  function bindFilters() {
    document.getElementById('adp-filter-status')?.addEventListener('change', renderMemberTable);
    document.getElementById('adp-search')?.addEventListener('input', renderMemberTable);
    document.querySelectorAll('[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const field = (th as HTMLElement).dataset.sort!;
        if (sortField === field) sortAsc = !sortAsc;
        else { sortField = field; sortAsc = field === 'name'; }
        renderMemberTable();
      });
    });
    // Tab switching
    document.querySelectorAll('[data-tab-switch]').forEach(btn => {
      btn.addEventListener('click', () => switchTab((btn as HTMLElement).dataset.tabSwitch!));
    });
    // Period selector
    document.querySelectorAll('#period-selector button').forEach(btn => {
      btn.addEventListener('click', () => {
        const days = parseInt((btn as HTMLElement).dataset.period || '30');
        analyticsPeriod = days;
        document.querySelectorAll('#period-selector button').forEach(b => {
          b.classList.toggle('bg-navy', (b as HTMLElement).dataset.period === String(days));
          b.classList.toggle('text-white', (b as HTMLElement).dataset.period === String(days));
          b.classList.toggle('bg-[var(--surface-card)]', (b as HTMLElement).dataset.period !== String(days));
        });
        analyticsLoaded = false;
        loadAnalytics();
      });
    });
  }

  let _initDone = false;
  async function init() {
    if (_initDone) return;
    sb = (window as any).navGetSb?.();
    const m = (window as any).navGetMember?.();
    if (!sb || !m) return;

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (!session) return;
    } catch { return; }

    if (!hasPermission(m, 'admin.analytics')) {
      _initDone = true;
      showDenied();
      return;
    }

    _initDone = true;
    showPanel();
    bindFilters();
    await loadDashboard();
  }

  function boot() {
    if ((window as any).navGetMember?.()) { init(); return; }
    window.addEventListener('nav:member', () => init(), { once: true });
    [500, 1000, 2000, 4000].forEach(ms => setTimeout(() => { if (!_initDone) init(); }, ms));
    setTimeout(() => { if (!_initDone) { _initDone = true; showDenied(); } }, 5000);
  }

  boot();
</script>

<style>
  @media print {
    /* Hide UI chrome */
    nav, aside, select, input, button, #adp-denied, [data-admin-nav],
    .admin-sidebar, #admin-sidebar-toggle, #announcements-area, .ann-banner,
    footer.bg-\[\#200F3B\], #consent-banner, .print\:hidden,
    [class*="TierViewer"], [class*="print:hidden"] { display: none !important; }

    /* Show content */
    #adp-panel { display: block !important; }

    /* LGPD: hide member table (contains names, last_seen = PII) */
    .print\:hidden { display: none !important; }

    /* Layout reset */
    body { background: white !important; color: black !important; }
    .flex.min-h-\[calc\(100vh-64px\)\] { display: block !important; }
    main { width: 100% !important; max-width: 100% !important; }
    .p-6, .max-w-\[1100px\] { padding: 0.5rem !important; max-width: 100% !important; }

    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    @page { margin: 1.5cm; size: A4 portrait; }
  }
</style>
