  function renderChart(daily: any[]) {
    const chart = document.getElementById('adp-chart');
    const labels = document.getElementById('adp-chart-labels');
    if (!chart || !labels) return;
    const maxVal = Math.max(1, ...daily.map((d: any) => d.unique_members || 0));
    chart.innerHTML = daily.map((d: any) => {
      const h = Math.max(2, Math.round(((d.unique_members || 0) / maxVal) * 180));
      const pv = d.total_pageviews || 0;
      return `<div class="flex-1 bg-navy/20 rounded-t-sm relative group" style="height:${h}px" title="${d.date}: ${d.unique_members} membros, ${pv} pageviews">
        <div class="absolute bottom-0 left-0 right-0 bg-navy rounded-t-sm" style="height:${h}px"></div>
      </div>`;
    }).join('');
    // Show first, middle, last date labels
    if (daily.length > 0) {
      const fmt = (s: string) => s.slice(5); // MM-DD
      labels.innerHTML = `<span>${fmt(daily[0].date)}</span><span>${fmt(daily[Math.floor(daily.length / 2)].date)}</span><span>${fmt(daily[daily.length - 1].date)}</span>`;
    }
  }

