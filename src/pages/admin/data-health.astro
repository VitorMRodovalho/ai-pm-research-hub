---
import AdminLayout from '../../layouts/AdminLayout.astro';
import DataHealthIsland from '../../components/admin/DataHealthIsland';
import Toast from '../../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.dataHealth', 'comp.common'], lang);
---

<AdminLayout title={t('admin.breadcrumb.dataHealth', lang)} breadcrumbs={[{label: t('admin.breadcrumb.system', lang)},{label: t('admin.breadcrumb.dataHealth', lang)}]}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <DataHealthIsland client:load />
  </div>
  <Toast />
</AdminLayout>

<script is:inline define:vars={{ deniedMsg: t('admin.deniedAdmin', lang) }}>
  document.addEventListener('DOMContentLoaded', () => {
    const check = () => {
      const member = window.navGetMember?.();
      if (!member) { setTimeout(check, 300); return; }
      // ADR-0083 Tier B: admin entry via canForAdminEntry (engagement-derived
      // org-scoped) + manager/deputy_manager hard-tier fallback + designations.
      const hasAdminCapability = window.__nucleoCanForAdminEntry?.() === true;
      const v3HardTier = ['manager', 'deputy_manager'].includes(member.operational_role);
      const hasAdminDesignation = (member.designations || []).some(function(d) { return d === 'deputy_manager' || d === 'curator'; });
      const isAdmin = member.is_superadmin || hasAdminCapability || v3HardTier || hasAdminDesignation;
      if (!isAdmin) {
        document.querySelector('.max-w-\\[1100px\\]').innerHTML = '<div class="text-center py-20 text-[var(--text-muted)]">' + deniedMsg + '</div>';
      }
    };
    check();
  });
</script>
