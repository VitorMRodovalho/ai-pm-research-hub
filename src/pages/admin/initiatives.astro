---
// p155 Op 3: Admin CRUD for initiatives (portfolio do Núcleo).
// List + filter (kind/status/search) + create + edit. Membership management remete para /initiative/[id]
// (já tem botão "Adicionar Membro" via manage_initiative_engagement). p155 (2026-05-13).
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import Toast from '../../components/ui/Toast.astro';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

const INIT_I18N = {
  pageTitle: t('admin.initiatives.title', lang),
  pageDesc: t('admin.initiatives.desc', lang),
  newBtn: t('admin.initiatives.newBtn', lang),
  filterKind: t('admin.initiatives.filterKind', lang),
  filterStatus: t('admin.initiatives.filterStatus', lang),
  filterSearch: t('admin.initiatives.filterSearch', lang),
  allKinds: t('admin.initiatives.allKinds', lang),
  allStatuses: t('admin.initiatives.allStatuses', lang),
  empty: t('admin.initiatives.empty', lang),
  loading: t('admin.loading', lang),
  loadError: t('admin.loadError', lang),
  denied: t('admin.accessRestricted', lang),
  backToAdmin: t('admin.backToAdmin', lang),
  editTitle: t('admin.initiatives.editTitle', lang),
  newTitle: t('admin.initiatives.newTitle', lang),
  formKind: t('admin.initiatives.formKind', lang),
  formTitle: t('admin.initiatives.formTitle', lang),
  formDescription: t('admin.initiatives.formDescription', lang),
  formStatus: t('admin.initiatives.formStatus', lang),
  formMetadata: t('admin.initiatives.formMetadata', lang),
  metadataHint: t('admin.initiatives.metadataHint', lang),
  metadataReadOnly: t('admin.initiatives.metadataReadOnly', lang),
  fillRequired: t('admin.initiatives.fillRequired', lang),
  invalidJson: t('admin.initiatives.invalidJson', lang),
  created: t('admin.initiatives.created', lang),
  updated: t('admin.initiatives.updated', lang),
  errorPrefix: t('common.errorPrefix', lang),
  membersLink: t('admin.initiatives.membersLink', lang),
  membersHint: t('admin.initiatives.membersHint', lang),
  save: t('admin.save', lang),
  cancel: t('common.cancel', lang),
  members: t('admin.initiatives.members', lang),
  statusDraft: t('admin.initiatives.statusDraft', lang),
  statusActive: t('admin.initiatives.statusActive', lang),
  statusArchived: t('admin.initiatives.statusArchived', lang),
  statusCompleted: t('admin.initiatives.statusCompleted', lang),
  edit: t('common.edit', lang),
};
---

<AdminLayout title={INIT_I18N.pageTitle} breadcrumbs={[{label: t('admin.breadcrumb.operations', lang)}, {label: INIT_I18N.pageTitle}]}>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <div id="init-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-8 text-center">
      <div class="text-3xl mb-3">&#x1F512;</div>
      <p class="font-semibold text-amber-800">{INIT_I18N.denied}</p>
      <a href={`${langPrefix}/admin`} class="inline-block mt-4 px-5 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{INIT_I18N.backToAdmin}</a>
    </div>

    <div id="init-panel" class="hidden">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h1 class="text-xl font-extrabold text-navy">{INIT_I18N.pageTitle}</h1>
          <p class="text-sm text-[var(--text-secondary)] mt-1">{INIT_I18N.pageDesc}</p>
        </div>
        <button id="init-add-btn" class="px-4 py-2 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">
          + {INIT_I18N.newBtn}
        </button>
      </div>

      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3 mb-4 flex flex-wrap items-center gap-2">
        <select id="init-filter-kind" class="px-3 py-1.5 text-[.72rem] border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
          <option value="">{INIT_I18N.allKinds}</option>
        </select>
        <select id="init-filter-status" class="px-3 py-1.5 text-[.72rem] border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
          <option value="">{INIT_I18N.allStatuses}</option>
          <option value="draft">{INIT_I18N.statusDraft}</option>
          <option value="active">{INIT_I18N.statusActive}</option>
          <option value="archived">{INIT_I18N.statusArchived}</option>
          <option value="completed">{INIT_I18N.statusCompleted}</option>
        </select>
        <input id="init-filter-search" type="text" placeholder={INIT_I18N.filterSearch} class="flex-1 min-w-[160px] px-3 py-1.5 text-[.72rem] border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
      </div>

      <div id="init-list" class="space-y-3">
        <p class="text-[.7rem] text-[var(--text-muted)]">{INIT_I18N.loading}</p>
      </div>
    </div>

    <div id="init-loading" class="text-center py-16 text-[var(--text-muted)]">{INIT_I18N.loading}</div>

    <!-- Modal -->
    <div id="init-modal-overlay" class="hidden fixed inset-0 z-50 bg-black/40 flex items-center justify-center overflow-auto">
      <div class="bg-[var(--surface-card)] rounded-2xl shadow-xl w-full max-w-2xl mx-4 my-8 border border-[var(--border-default)]">
        <div class="px-5 py-4 border-b border-[var(--border-default)] flex items-center justify-between">
          <h3 id="init-modal-title" class="text-sm font-bold text-navy">{INIT_I18N.newTitle}</h3>
          <button id="init-modal-close" class="text-[var(--text-muted)] hover:text-[var(--text-primary)] text-lg cursor-pointer bg-transparent border-0">&times;</button>
        </div>
        <div class="p-5 space-y-3 max-h-[70vh] overflow-y-auto">
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{INIT_I18N.formKind} *</label>
            <select id="init-kind" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-input)]"></select>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{INIT_I18N.formTitle} *</label>
            <input type="text" id="init-title" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-input)]" />
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{INIT_I18N.formDescription}</label>
            <textarea id="init-description" rows="3" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] resize-y bg-[var(--surface-input)]"></textarea>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">{INIT_I18N.formStatus}</label>
            <select id="init-status" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.78rem] bg-[var(--surface-input)]">
              <option value="draft">{INIT_I18N.statusDraft}</option>
              <option value="active" selected>{INIT_I18N.statusActive}</option>
              <option value="archived">{INIT_I18N.statusArchived}</option>
              <option value="completed">{INIT_I18N.statusCompleted}</option>
            </select>
          </div>
          <div>
            <label class="text-[.68rem] font-semibold text-[var(--text-secondary)] block mb-1">
              {INIT_I18N.formMetadata}
              <span id="init-metadata-readonly-badge" class="hidden ml-2 text-[.6rem] text-[var(--text-muted)] font-normal">({INIT_I18N.metadataReadOnly})</span>
            </label>
            <textarea id="init-metadata" rows="6" class="w-full px-3 py-2 border border-[var(--border-default)] rounded-lg text-[.7rem] font-mono resize-y bg-[var(--surface-input)]"></textarea>
            <p class="text-[.6rem] text-[var(--text-muted)] mt-0.5">{INIT_I18N.metadataHint}</p>
          </div>

          <div id="init-members-link" class="hidden border-t border-[var(--border-default)] pt-3 mt-3">
            <p class="text-[.68rem] font-semibold text-[var(--text-secondary)] mb-1">{INIT_I18N.members}</p>
            <p class="text-[.65rem] text-[var(--text-muted)] mb-2">{INIT_I18N.membersHint}</p>
            <a id="init-members-anchor" href="#" class="inline-block px-3 py-1.5 text-[.72rem] font-semibold rounded-lg bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100 no-underline transition-colors">{INIT_I18N.membersLink} &rarr;</a>
          </div>

          <div class="flex gap-2 pt-2">
            <button id="init-modal-save" class="flex-1 px-4 py-2.5 bg-navy text-white rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all">{INIT_I18N.save}</button>
            <button id="init-modal-cancel" class="px-4 py-2.5 bg-transparent text-[var(--text-secondary)] rounded-lg text-[.78rem] font-semibold cursor-pointer border border-[var(--border-default)] hover:bg-[var(--surface-base)] transition-all">{INIT_I18N.cancel}</button>
          </div>
        </div>
      </div>
    </div>
  </div>
  <Toast />
</AdminLayout>

<script is:inline define:vars={{ INIT_I18N, langPrefix }}>
  window.__INIT_ADMIN_I18N = INIT_I18N;
  window.__INIT_ADMIN_LANG_PREFIX = langPrefix;
</script>
<script>
  import { hasPermission } from '../../lib/permissions';

  // i18n bundle is injected via define:vars; bail out if missing (no PT-BR fallback —
  // keeps the page strictly trilingual via dictionaries).
  const T = (typeof window !== 'undefined' && (window as any).__INIT_ADMIN_I18N) || {};
  const LANG_PREFIX = (typeof window !== 'undefined' && (window as any).__INIT_ADMIN_LANG_PREFIX) || '';
  const DEFAULT_KIND_EMOJI = '📌';

  const STATUS_STYLES: Record<string, { bg: string; color: string; label: string }> = {
    draft:     { bg: 'bg-amber-50',    color: 'text-amber-700',    label: T.statusDraft },
    active:    { bg: 'bg-emerald-50',  color: 'text-emerald-700',  label: T.statusActive },
    archived:  { bg: 'bg-gray-100',    color: 'text-gray-600',     label: T.statusArchived },
    completed: { bg: 'bg-blue-50',     color: 'text-blue-700',     label: T.statusCompleted },
  };

  let sb: any = null;
  let MEMBER: any = null;
  let editingId: string | null = null;
  let allInitiatives: any[] = [];
  let allKinds: any[] = [];

  function escapeHtml(s: string): string {
    return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function showDenied() {
    document.getElementById('init-loading')?.classList.add('hidden');
    document.getElementById('init-panel')?.classList.add('hidden');
    document.getElementById('init-denied')?.classList.remove('hidden');
  }

  async function showPanel() {
    document.getElementById('init-loading')?.classList.add('hidden');
    document.getElementById('init-denied')?.classList.add('hidden');
    document.getElementById('init-panel')?.classList.remove('hidden');
    await loadKinds();
    await loadInitiatives();
  }

  async function loadKinds() {
    if (!sb) return;
    try {
      const { data, error } = await sb.from('initiative_kinds').select('slug, display_name').order('slug');
      if (error) throw error;
      allKinds = data || [];

      const filterSel = document.getElementById('init-filter-kind') as HTMLSelectElement;
      const modalSel = document.getElementById('init-kind') as HTMLSelectElement;

      const filterOpts = allKinds.map(k => `<option value="${escapeHtml(k.slug)}">${escapeHtml(k.display_name)}</option>`).join('');
      filterSel.innerHTML = `<option value="">${T.allKinds}</option>` + filterOpts;
      modalSel.innerHTML = allKinds.map(k => `<option value="${escapeHtml(k.slug)}">${escapeHtml(k.display_name)}</option>`).join('');
    } catch (e: any) {
      console.error('loadKinds', e);
    }
  }

  async function loadInitiatives() {
    if (!sb) return;
    const container = document.getElementById('init-list');
    if (!container) return;
    container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${T.loading}</p>`;
    try {
      const { data, error } = await sb.rpc('list_initiatives');
      if (error) throw error;
      allInitiatives = (data || []).map((row: any) => typeof row === 'string' ? JSON.parse(row) : row);
      renderList();
    } catch (e: any) {
      console.error('loadInitiatives', e);
      container.innerHTML = `<p class="text-[.7rem] text-red-600">${T.loadError}</p>`;
    }
  }

  function renderList() {
    const container = document.getElementById('init-list');
    if (!container) return;
    const fKind = (document.getElementById('init-filter-kind') as HTMLSelectElement).value;
    const fStatus = (document.getElementById('init-filter-status') as HTMLSelectElement).value;
    const fSearch = (document.getElementById('init-filter-search') as HTMLInputElement).value.trim().toLowerCase();

    const filtered = allInitiatives.filter((i: any) => {
      if (fKind && i.kind !== fKind) return false;
      if (fStatus && i.status !== fStatus) return false;
      if (fSearch && !(i.title || '').toLowerCase().includes(fSearch)) return false;
      return true;
    });

    if (filtered.length === 0) {
      container.innerHTML = `<p class="text-[.7rem] text-[var(--text-muted)]">${T.empty}</p>`;
      return;
    }

    container.innerHTML = filtered.map((i: any) => {
      const icon = (i.kind_config?.icon_emoji) || DEFAULT_KIND_EMOJI;
      const kindLabel = (i.kind_display_name || i.kind);
      const status = STATUS_STYLES[i.status] || STATUS_STYLES.draft;
      const memberCount = i.member_count ?? 0;
      return `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 hover:border-[var(--border-focus)] transition-all">
          <div class="flex items-start gap-3">
            <div class="text-2xl shrink-0" aria-hidden="true">${icon}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-[.85rem] font-bold text-[var(--text-primary)]">${escapeHtml(i.title)}</span>
                <span class="text-[.6rem] px-1.5 py-0.5 rounded bg-[var(--surface-section-cool)] text-[var(--text-muted)] font-mono">${escapeHtml(kindLabel)}</span>
                <span class="text-[.6rem] px-1.5 py-0.5 rounded ${status.bg} ${status.color} font-semibold">${escapeHtml(status.label)}</span>
                <span class="text-[.6rem] text-[var(--text-muted)]">${memberCount} ${T.members.toLowerCase()}</span>
              </div>
              <p class="text-[.7rem] text-[var(--text-secondary)] mt-1 line-clamp-2">${escapeHtml(i.description || '')}</p>
            </div>
            <button data-edit-id="${escapeHtml(i.id)}" class="shrink-0 px-3 py-1.5 text-[.7rem] font-semibold rounded-lg bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100 cursor-pointer transition-colors">${T.edit}</button>
          </div>
        </div>
      `;
    }).join('');

    container.querySelectorAll('[data-edit-id]').forEach((btn: Element) => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.editId!;
        const found = allInitiatives.find((i: any) => i.id === id);
        if (found) openModal(found);
      });
    });
  }

  function openModal(initiative?: any) {
    editingId = initiative?.id || null;
    const titleEl = document.getElementById('init-modal-title');
    if (titleEl) titleEl.textContent = initiative ? T.editTitle : T.newTitle;

    const kindSel = document.getElementById('init-kind') as HTMLSelectElement;
    kindSel.value = initiative?.kind || (allKinds[0]?.slug ?? '');
    kindSel.disabled = !!initiative;

    (document.getElementById('init-title') as HTMLInputElement).value = initiative?.title || '';
    (document.getElementById('init-description') as HTMLTextAreaElement).value = initiative?.description || '';
    (document.getElementById('init-status') as HTMLSelectElement).value = initiative?.status || 'active';

    const metaEl = document.getElementById('init-metadata') as HTMLTextAreaElement;
    metaEl.value = initiative?.metadata ? JSON.stringify(initiative.metadata, null, 2) : '{}';
    metaEl.readOnly = !!initiative;
    document.getElementById('init-metadata-readonly-badge')?.classList.toggle('hidden', !initiative);

    const membersLinkDiv = document.getElementById('init-members-link');
    const anchor = document.getElementById('init-members-anchor') as HTMLAnchorElement;
    if (initiative) {
      membersLinkDiv?.classList.remove('hidden');
      anchor.href = `${LANG_PREFIX}/initiative/${initiative.id}`;
    } else {
      membersLinkDiv?.classList.add('hidden');
    }

    document.getElementById('init-modal-overlay')?.classList.remove('hidden');
  }

  function closeModal() {
    editingId = null;
    document.getElementById('init-modal-overlay')?.classList.add('hidden');
  }

  async function saveInitiative() {
    if (!sb) return;
    const kind = (document.getElementById('init-kind') as HTMLSelectElement).value.trim();
    const title = (document.getElementById('init-title') as HTMLInputElement).value.trim();
    const description = (document.getElementById('init-description') as HTMLTextAreaElement).value.trim() || null;
    const status = (document.getElementById('init-status') as HTMLSelectElement).value;
    const metaRaw = (document.getElementById('init-metadata') as HTMLTextAreaElement).value.trim();

    if (!kind || !title) { (window as any).toast?.(T.fillRequired, 'error'); return; }

    let metadata: any = {};
    if (metaRaw) {
      try { metadata = JSON.parse(metaRaw); }
      catch { (window as any).toast?.(T.invalidJson, 'error'); return; }
    }

    const saveBtn = document.getElementById('init-modal-save') as HTMLButtonElement;
    if (saveBtn) saveBtn.disabled = true;
    try {
      if (editingId) {
        // update — only title/description/status (metadata read-only at edit per v1 scope)
        const { data, error } = await sb.rpc('update_initiative', {
          p_initiative_id: editingId,
          p_title: title,
          p_description: description,
          p_status: status,
          p_metadata: null,
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        (window as any).toast?.(T.updated, 'success');
      } else {
        // create
        const { data: newId, error } = await sb.rpc('create_initiative', {
          p_kind: kind, p_title: title, p_description: description, p_metadata: metadata,
        });
        if (error) throw error;
        // set status if not active default
        if (status !== 'active' && status !== 'draft' && newId) {
          await sb.rpc('update_initiative', {
            p_initiative_id: newId, p_title: null, p_description: null,
            p_status: status, p_metadata: null,
          });
        } else if (status === 'active' && newId) {
          // create_initiative starts in 'draft' by default — explicitly activate if requested
          await sb.rpc('update_initiative', {
            p_initiative_id: newId, p_title: null, p_description: null,
            p_status: 'active', p_metadata: null,
          });
        }
        (window as any).toast?.(T.created, 'success');
      }
      closeModal();
      await loadInitiatives();
    } catch (e: any) {
      console.error('saveInitiative', e);
      (window as any).toast?.(T.errorPrefix + ': ' + (e.message || 'unknown'), 'error');
    } finally {
      if (saveBtn) saveBtn.disabled = false;
    }
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) { MEMBER = m; applyGate(MEMBER); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        MEMBER = data;
        applyGate(MEMBER);
        return;
      }
    } catch (e) { console.warn('init admin boot:', e); }
    showDenied();
  }

  function applyGate(m: any) {
    if (hasPermission(m, 'admin.full')) showPanel();
    else showDenied();
  }

  document.getElementById('init-add-btn')?.addEventListener('click', () => openModal());
  document.getElementById('init-modal-close')?.addEventListener('click', closeModal);
  document.getElementById('init-modal-cancel')?.addEventListener('click', closeModal);
  document.getElementById('init-modal-save')?.addEventListener('click', saveInitiative);
  document.getElementById('init-modal-overlay')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeModal();
  });
  document.getElementById('init-filter-kind')?.addEventListener('change', renderList);
  document.getElementById('init-filter-status')?.addEventListener('change', renderList);
  document.getElementById('init-filter-search')?.addEventListener('input', renderList);

  boot();
</script>
