---
import AdminLayout from '../../layouts/AdminLayout.astro';
import AiCalibrationIsland from '../../components/admin/AiCalibrationIsland';
import Toast from '../../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.aiCalibration', 'comp.common'], lang);
---

<AdminLayout
  title={t('admin.breadcrumb.aiCalibration', lang)}
  breadcrumbs={[
    { label: t('admin.breadcrumb.operations', lang) },
    { label: t('admin.breadcrumb.aiCalibration', lang) }
  ]}
>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <AiCalibrationIsland client:load />
  </div>
  <Toast />
</AdminLayout>
