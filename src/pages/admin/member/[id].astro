---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Toast from '../../../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../../../i18n/utils';
import { buildPageI18n } from '../../../i18n/pageI18n';

const { id } = Astro.params;
const isNew = id === 'new';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
const i18nBundle = buildPageI18n(['comp.memberDetail', 'comp.memberList', 'common'], lang);

// Pre-render strings for inline script via define:vars (Ω-B+.2 p139)
const MEMBER_EDIT_I18N = {
  titleNew: t('admin.memberEdit.titleNew', lang),
  titleEdit: t('admin.memberEdit.titleEdit', lang),
  back: t('common.back', lang),
  label: {
    fullName: t('admin.memberEdit.label.fullName', lang),
    email: t('admin.memberEdit.label.email', lang),
    chapter: t('admin.memberEdit.label.chapter', lang),
    primaryRole: t('admin.memberEdit.label.primaryRole', lang),
    tribe: t('admin.memberEdit.label.tribe', lang),
    pmiId: t('admin.memberEdit.label.pmiId', lang),
    uniqueBadge: t('admin.memberEdit.label.uniqueBadge', lang),
    phone: t('admin.memberEdit.label.phone', lang),
    linkedin: t('admin.memberEdit.label.linkedin', lang),
    allRoles: t('admin.memberEdit.label.allRoles', lang),
    activeInCycle: t('admin.memberEdit.label.activeInCycle', lang),
  },
  placeholder: {
    fullName: t('admin.memberEdit.placeholder.fullName', lang),
  },
  option: {
    selectChapter: t('admin.memberEdit.option.selectChapter', lang),
    noTribe: t('admin.memberEdit.option.noTribe', lang),
  },
  tribePrefix: t('admin.memberEdit.tribePrefix', lang),
  action: {
    inactivate: t('admin.memberEdit.action.inactivate', lang),
    reactivate: t('admin.memberEdit.action.reactivate', lang),
    save: t('admin.memberEdit.action.save', lang),
  },
  error: {
    requiredNameEmail: t('admin.memberEdit.error.requiredNameEmail', lang),
  },
  toast: {
    saved: t('admin.memberEdit.toast.saved', lang),
    inactivated: t('admin.memberEdit.toast.inactivated', lang),
    reactivated: t('admin.memberEdit.toast.reactivated', lang),
  },
  prompt: {
    inactivateReason: t('admin.memberEdit.prompt.inactivateReason', lang),
  },
};
---
<AdminLayout title={isNew ? t('admin.memberEdit.titleNew', lang) : t('comp.memberDetail.editTitle', lang)} breadcrumbs={[{label:t('common.back', lang)},{label:t('admin.members.title', lang)}]}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <Toast />
  <div class="max-w-2xl mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-6">
      <a href={`${langPrefix}/admin`} class="text-[var(--text-muted)] hover:text-navy transition-all text-sm no-underline">← {t('common.back', lang)}</a>
      <h1 class="text-xl font-extrabold text-navy" id="page-title">
        {isNew ? t('admin.memberEdit.titleNew', lang) : t('admin.memberEdit.titleEdit', lang)}
      </h1>
    </div>
    <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-2xl p-6" id="member-form">
      <div class="text-center py-8 text-[var(--text-muted)]">{t('admin.loadingMembers', lang)}</div>
    </div>
  </div>
</AdminLayout>

<script is:inline define:vars={{ memberId: id, isNew, MEMBER_EDIT_I18N, langPrefix }}>
  window.__MEMBER_EDIT = { memberId, isNew, i18n: MEMBER_EDIT_I18N };
  window.__LANG_PREFIX = langPrefix;
</script>
<script>
  const { memberId, isNew, i18n: I18N } = (typeof window !== 'undefined' && (window as any).__MEMBER_EDIT) || { memberId: '', isNew: false, i18n: null };
  // PT-BR fallbacks (graceful degradation if define:vars injection fails)
  const T = I18N || {
    label: { fullName: 'Nome completo *', email: 'Email principal *', chapter: 'Capítulo', primaryRole: 'Papel principal', tribe: 'Tribo', pmiId: 'PMI ID', uniqueBadge: 'único', phone: 'Telefone', linkedin: 'LinkedIn URL', allRoles: 'Todos os papéis', activeInCycle: 'Membro ativo no ciclo atual' },
    placeholder: { fullName: 'Nome completo' },
    option: { selectChapter: '— Selecionar —', noTribe: '— Nenhuma —' },
    tribePrefix: 'Tribo',
    action: { inactivate: '🔴 Inativar membro', reactivate: '🟢 Reativar membro', save: '💾 Salvar' },
    error: { requiredNameEmail: 'Nome e email obrigatórios' },
    toast: { saved: 'Salvo ✅', inactivated: 'Membro inativado 🔴', reactivated: 'Membro reativado 🟢' },
    prompt: { inactivateReason: 'Motivo da inativação de {name} (opcional):' },
  };
  import { ROLE_LABELS, ROLE_COLORS } from '../../../lib/supabase';
  import { canAccessAdminRoute } from '../../../lib/admin/constants';
  import { loadChapters, type Chapter } from '../../../lib/chapters';
  let _member = null;
  let _aclReady = false;
  let _chapters: Chapter[] = [];

  async function onAuthorized() {
    if (_aclReady) return;
    _aclReady = true;
    _chapters = await loadChapters();
    if (!isNew) await loadMember();
    else renderForm(null);
  }

  function denyAccess() {
    location.href = ((typeof window !== 'undefined' && (window as any).__LANG_PREFIX) || '') + '/admin';
  }

  async function bootAcl() {
    const navMember = navGetMember?.();
    if (navMember) {
      if (!canAccessAdminRoute(navMember, 'admin_member_edit')) { denyAccess(); return; }
      await onAuthorized();
      return;
    }

    const sb = navGetSb?.();
    if (!sb) { setTimeout(bootAcl, 200); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data: me } = await sb.rpc('get_member_by_auth');
        if (!canAccessAdminRoute(me, 'admin_member_edit')) { denyAccess(); return; }
        await onAuthorized();
        return;
      }
    } catch {}

    denyAccess();
  }

  window.addEventListener('nav:member', async (e) => {
    const me = e.detail;
    if (!me) return;
    if (!canAccessAdminRoute(me, 'admin_member_edit')) { denyAccess(); return; }
    await onAuthorized();
  });

  bootAcl();

  async function loadMember() {
    const sb = navGetSb?.();
    const { data } = await sb.from('members').select('*').eq('id', memberId).single();
    _member = data;
    renderForm(data);
  }

  function escapeAttr(s) {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  function renderForm(m) {
    const el = document.getElementById('member-form');
    if (!el) return;
    const CHAPTERS = _chapters.map(c => c.display_code);
    const ROLES_ALL = Object.keys(ROLE_COLORS);
    const selectedRoles = [
      ...(m?.operational_role && m.operational_role !== 'none' && m.operational_role !== 'guest' ? [m.operational_role] : []),
      ...((m?.designations || []) as string[]),
    ];

    el.innerHTML = `
      <div class="grid grid-cols-2 gap-4">
        <div class="col-span-2">
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.fullName}</label>
          <input id="f-name" type="text" value="${m?.name||''}" placeholder="${T.placeholder.fullName}"
            class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
        </div>
        <div>
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.email}</label>
          <input id="f-email" type="email" value="${m?.email||''}"
            class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
          <div id="err-email" class="text-xs text-crimson mt-1 hidden"></div>
        </div>
        <div>
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.chapter}</label>
          <select id="f-chapter" class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
            <option value="">${T.option.selectChapter}</option>
            ${CHAPTERS.map(c=>`<option ${m?.chapter===c?'selected':''}>${c}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.primaryRole}</label>
          <select id="f-role" class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
            ${Object.entries(ROLE_LABELS).filter(([k])=>k!=='guest').map(([k,v])=>
              `<option value="${k}" ${m?.operational_role===k?'selected':''}>${v}</option>`
            ).join('')}
          </select>
        </div>
        <div>
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.tribe}</label>
          <select id="f-tribe" class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
            <option value="">${T.option.noTribe}</option>
            ${[1,2,3,4,5,6,7,8].map(n=>`<option value="${n}" ${m?.tribe_id===n?'selected':''}>${T.tribePrefix} ${n}</option>`).join('')}
          </select>
        </div>
        <div>
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.pmiId} <span class="text-amber-500">${T.label.uniqueBadge}</span></label>
          <input id="f-pmi" type="password" value="${m?.pmi_id||''}"
            class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
          <div id="err-pmi" class="text-xs text-crimson mt-1 hidden"></div>
        </div>
        <div>
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.phone} <span class="text-amber-500">${T.label.uniqueBadge}</span></label>
          <input id="f-phone" type="password" value="${m?.phone||''}"
            class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
          <div id="err-phone" class="text-xs text-crimson mt-1 hidden"></div>
        </div>
        <div class="col-span-2">
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-1">${T.label.linkedin}</label>
          <input id="f-li" type="url" value="${m?.linkedin_url||''}" placeholder="https://linkedin.com/in/…"
            class="w-full px-3 py-2.5 border-2 border-[var(--border-default)] rounded-xl text-sm bg-[var(--surface-input)] text-[var(--text-primary)] focus:outline-none focus:border-teal">
        </div>
        <div class="col-span-2">
          <label class="block text-[.7rem] font-bold text-[var(--text-muted)] uppercase tracking-wide mb-2">${T.label.allRoles}</label>
          <div class="flex flex-wrap gap-2" id="roles-grid">
            ${ROLES_ALL.map(r => {
              const on = selectedRoles.includes(r);
              const col = ROLE_COLORS[r];
              return `<button type="button" class="btn-toggle-role px-3 py-1.5 rounded-lg text-xs font-semibold border-2 transition-all cursor-pointer" id="rc-${escapeAttr(r)}"
                style="${on ? `background:${col};border-color:${col};color:#fff` : `background:transparent;border-color:#e2e8f0;color:#64748b`}"
                data-role="${escapeAttr(r)}" data-on="${on}">
                ${ROLE_LABELS[r]||r}
              </button>`;
            }).join('')}
          </div>
        </div>
        ${!isNew ? `<div class="col-span-2">
          <label class="flex items-center gap-2 cursor-pointer text-sm font-semibold">
            <input type="checkbox" id="f-active" ${m?.current_cycle_active?'checked':''} class="w-4 h-4">
            ${T.label.activeInCycle}
          </label>
        </div>` : ''}
      </div>
      <div class="flex justify-between items-center mt-6 pt-4 border-t border-[var(--border-subtle)]">
        <div>
          ${!isNew && m?.current_cycle_active ? `<button type="button" class="btn-inactivate-member text-xs text-crimson font-semibold hover:underline cursor-pointer border-0 bg-transparent" data-member-id="${escapeAttr(m.id)}" data-member-name="${escapeAttr(m.name||'')}">${T.action.inactivate}</button>` : ''}
          ${!isNew && !m?.current_cycle_active ? `<button type="button" class="btn-reactivate-member text-xs text-emerald-600 font-semibold hover:underline cursor-pointer border-0 bg-transparent" data-member-id="${escapeAttr(m.id)}">${T.action.reactivate}</button>` : ''}
        </div>
        <button type="button" data-action="save-member" class="px-5 py-2.5 bg-navy text-white rounded-xl font-semibold text-sm hover:opacity-90 transition-all cursor-pointer border-0">${T.action.save}</button>
      </div>`;
  }

  toggleRole = (r) => {
    const el = document.getElementById('rc-'+r) ;
    if (!el) return;
    const on = el.dataset.on !== 'true';
    el.dataset.on = String(on);
    const col = ROLE_COLORS[r];
    el.style.cssText = on
      ? `background:${col};border-color:${col};color:#fff`
      : `background:transparent;border-color:#e2e8f0;color:#64748b`;
  };

  function splitRoleSelection(opRole, selectedRoles) {
    const operational = new Set(['manager', 'deputy_manager', 'tribe_leader', 'researcher', 'facilitator', 'communicator', 'guest', 'none']);
    const designations = selectedRoles.filter((r) => !operational.has(r));
    return {
      operationalRole: opRole || 'guest',
      designations
    };
  }

  async function adminUpdateMemberCompat(sb, params, opRole, selectedRoles) {
    const split = splitRoleSelection(opRole, selectedRoles);
    const res = await sb.rpc('admin_update_member', {
      p_member_id: params.p_member_id,
      p_name: params.p_name,
      p_email: params.p_email,
      p_operational_role: split.operationalRole,
      p_designations: split.designations,
      p_chapter: params.p_chapter,
      p_tribe_id: params.p_tribe_id,
      p_pmi_id: params.p_pmi_id,
      p_phone: params.p_phone,
      p_linkedin_url: params.p_linkedin_url,
      p_current_cycle_active: params.p_current_cycle_active,
    });
    return { mode: 'v2', data: res.data, error: res.error };
  }

  saveMember = async () => {
    const sb = navGetSb?.();
    const name  = (document.getElementById('f-name') )?.value.trim();
    const email = (document.getElementById('f-email') )?.value.trim();
    if (!name || !email) { toast?.(T.error.requiredNameEmail,'error'); return; }
    const roles = Object.keys(ROLE_COLORS).filter(r => document.getElementById('rc-'+r)?.dataset.on === 'true');
    const opRole = (document.getElementById('f-role') )?.value;
    const params = {
      p_member_id: isNew ? undefined : memberId,
      p_name: name, p_email: email,
      p_chapter: (document.getElementById('f-chapter') )?.value || null,
      p_tribe_id: parseInt((document.getElementById('f-tribe') )?.value) || null,
      p_pmi_id:  (document.getElementById('f-pmi') )?.value.trim() || null,
      p_phone:   (document.getElementById('f-phone') )?.value.trim() || null,
      p_linkedin_url: (document.getElementById('f-li') )?.value.trim() || null,
      p_current_cycle_active: isNew ? true : (document.getElementById('f-active') )?.checked,
    };
    let result;
    if (isNew) {
      const split = splitRoleSelection(opRole, roles);
      const { error } = await sb.from('members').insert({
        name: params.p_name,
        email: params.p_email,
        operational_role: split.operationalRole,
        designations: split.designations,
        chapter:params.p_chapter, tribe_id:params.p_tribe_id, pmi_id:params.p_pmi_id,
        phone:params.p_phone, linkedin_url:params.p_linkedin_url, current_cycle_active:true,
      });
      result = error ? { error: error.message } : { success: true };
    } else {
      const compat = await adminUpdateMemberCompat(sb, params, opRole, roles);
      result = compat.data;
    }
    if (result?.error) { toast?.(result.error, 'error'); return; }
    toast?.(T.toast.saved,'success');
    setTimeout(() => location.href = ((typeof window !== 'undefined' && (window as any).__LANG_PREFIX) || '') + '/admin', 1200);
  };

  inactivateMember = async (id, name) => {
    const reason = prompt(T.prompt.inactivateReason.replace('{name}', name));
    if (reason === null) return;
    const sb = navGetSb?.();
    await sb.rpc('admin_inactivate_member', { p_member_id: id, p_reason: reason || null });
    toast?.(T.toast.inactivated,'info');
    setTimeout(() => location.href = ((typeof window !== 'undefined' && (window as any).__LANG_PREFIX) || '') + '/admin', 1200);
  };

  reactivateMember = async (id) => {
    const sb = navGetSb?.();
    await sb.rpc('admin_reactivate_member', { p_member_id: id });
    toast?.(T.toast.reactivated,'success');
    setTimeout(() => location.href = ((typeof window !== 'undefined' && (window as any).__LANG_PREFIX) || '') + '/admin', 1200);
  };

  if (!(window as any).__adminMemberDelegationBound) {
    (window as any).__adminMemberDelegationBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;
      const target = e.target as HTMLElement;
      const actionEl = target.closest('[data-action]') as HTMLElement | null;
      if (actionEl) {
        const action = actionEl.dataset.action;
        if (action === 'save-member') { saveMember(); return; }
      }
      const toggleBtn = target.closest('.btn-toggle-role');
      if (toggleBtn) {
        const r = toggleBtn.getAttribute('data-role') || '';
        toggleRole(r);
        return;
      }
      const inactBtn = target.closest('.btn-inactivate-member');
      if (inactBtn) {
        inactivateMember(inactBtn.getAttribute('data-member-id') || '', inactBtn.getAttribute('data-member-name') || '');
        return;
      }
      const reactBtn = target.closest('.btn-reactivate-member');
      if (reactBtn) {
        reactivateMember(reactBtn.getAttribute('data-member-id') || '');
      }
    });
  }
</script>
