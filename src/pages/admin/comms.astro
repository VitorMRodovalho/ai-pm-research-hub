---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname);
const COMMS_DASHBOARD_URL = import.meta.env.PUBLIC_LOOKER_COMMS_DASHBOARD_URL || '';
const COMMS_KPI_API_URL = import.meta.env.PUBLIC_COMMS_KPI_API_URL || '';
---

<BaseLayout title={t('admin.comms.meta', lang)} activePage="admin">
  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-navy">{t('admin.comms.title', lang)}</h1>
      <p class="text-sm text-slate-500">{t('admin.comms.subtitle', lang)}</p>
    </div>

    <div id="comms-loading" class="text-center py-10 text-slate-400">{t('admin.comms.loading', lang)}</div>

    <div id="comms-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">{t('admin.comms.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('admin.comms.backAdmin', lang)}
      </a>
    </div>

    <section id="comms-panel" class="hidden space-y-4">
      <div class="bg-white border border-slate-200 rounded-xl p-4">
        <div class="flex items-center justify-between gap-3 flex-wrap mb-3">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.comms.kpiTitle', lang)}</h2>
            <p class="text-[.68rem] text-slate-400">{t('admin.comms.kpiSubtitle', lang)}</p>
          </div>
          <button id="comms-kpi-refresh" class="px-3 py-1.5 rounded-lg border border-slate-200 bg-white text-[.72rem] font-semibold text-slate-600 cursor-pointer hover:bg-slate-50 transition-all">
            {t('admin.comms.kpiRefresh', lang)}
          </button>
        </div>

        <p id="comms-kpi-status" class="text-[.72rem] text-slate-500 mb-3">
          {COMMS_KPI_API_URL
            ? t('admin.comms.kpiLoading', lang)
            : t('admin.comms.kpiDbFallback', lang)}
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
            <div class="text-[.65rem] font-semibold text-slate-500">{t('admin.comms.kpiAudience', lang)}</div>
            <div id="kpi-audience" class="text-xl font-black text-navy">—</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
            <div class="text-[.65rem] font-semibold text-slate-500">{t('admin.comms.kpiReach', lang)}</div>
            <div id="kpi-reach" class="text-xl font-black text-teal">—</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
            <div class="text-[.65rem] font-semibold text-slate-500">{t('admin.comms.kpiEngagement', lang)}</div>
            <div id="kpi-engagement" class="text-xl font-black text-violet-700">—</div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
            <div class="text-[.65rem] font-semibold text-slate-500">{t('admin.comms.kpiLeads', lang)}</div>
            <div id="kpi-leads" class="text-xl font-black text-orange">—</div>
          </div>
        </div>
      </div>

      <section class="bg-white border border-slate-200 rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.comms.dashboardTitle', lang)}</h2>
            <p class="text-[.68rem] text-slate-400">{t('admin.comms.dashboardSubtitle', lang)}</p>
          </div>
          {COMMS_DASHBOARD_URL && (
            <a href={COMMS_DASHBOARD_URL} target="_blank" rel="noopener noreferrer" class="text-[.72rem] font-semibold text-teal no-underline hover:underline">
              {t('admin.comms.openExternal', lang)}
            </a>
          )}
        </div>
        {!COMMS_DASHBOARD_URL ? (
          <div class="p-4 text-[.72rem] text-slate-500">
            {t('admin.comms.missingConfig', lang)} <code class="bg-slate-100 px-1 py-0.5 rounded">PUBLIC_LOOKER_COMMS_DASHBOARD_URL</code>
          </div>
        ) : (
          <iframe
            src={COMMS_DASHBOARD_URL}
            title="Comms Central Dashboard"
            class="w-full min-h-[760px] border-0"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            sandbox="allow-same-origin allow-scripts allow-forms allow-popups allow-popups-to-escape-sandbox"
          ></iframe>
        )}
      </section>
    </section>
  </div>
</BaseLayout>

<script>
  import { canAccessAdminRoute } from '../../lib/admin/constants';

  const KPI_URL = "{COMMS_KPI_API_URL}";
  const KPI_MSG_LOADING = "{t('admin.comms.kpiLoading', lang)}";
  const KPI_MSG_ERROR = "{t('admin.comms.kpiError', lang)}";
  const KPI_MSG_UPDATED = "{t('admin.comms.kpiUpdatedAt', lang)}";
  const KPI_MSG_DB_FALLBACK = "{t('admin.comms.kpiDbFallback', lang)}";
  let kpiLoaded = false;
  let sb: any = null;

  function allowComms(m: any): boolean {
    return canAccessAdminRoute(m, 'admin_analytics');
  }

  function showDenied() {
    document.getElementById('comms-loading')?.classList.add('hidden');
    document.getElementById('comms-denied')?.classList.remove('hidden');
    document.getElementById('comms-panel')?.classList.add('hidden');
  }

  function showPanel() {
    document.getElementById('comms-loading')?.classList.add('hidden');
    document.getElementById('comms-denied')?.classList.add('hidden');
    document.getElementById('comms-panel')?.classList.remove('hidden');
    if (!kpiLoaded) void loadCommsKpis();
  }

  function fmtKpi(v: any): string {
    if (v === null || v === undefined || v === '') return '—';
    if (typeof v === 'number') return Number.isInteger(v) ? v.toLocaleString('pt-BR') : v.toFixed(2);
    return String(v);
  }

  function setKpi(id: string, value: any) {
    const el = document.getElementById(id);
    if (el) el.textContent = fmtKpi(value);
  }

  function setKpiStatus(text: string, tone: 'default' | 'error' = 'default') {
    const el = document.getElementById('comms-kpi-status');
    if (!el) return;
    el.textContent = text;
    el.className = tone === 'error' ? 'text-[.72rem] text-crimson mb-3' : 'text-[.72rem] text-slate-500 mb-3';
  }

  function parseKpis(payload: any) {
    const p = payload?.metrics || payload?.kpis || payload || {};
    return {
      audience: p.audience ?? p.followers ?? p.total_followers ?? null,
      reach: p.reach ?? p.impressions ?? p.views ?? null,
      engagement: p.engagement ?? p.engagement_rate ?? p.er ?? null,
      leads: p.leads ?? p.conversions ?? p.qualified_leads ?? null,
      updatedAt: payload?.updated_at || p.updated_at || null,
    };
  }

  async function loadCommsKpis() {
    setKpiStatus(KPI_MSG_LOADING);
    try {
      let data: any = null;
      if (KPI_URL) {
        const resp = await fetch(KPI_URL, { headers: { Accept: 'application/json' } });
        if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
        data = await resp.json();
      } else {
        if (!sb) throw new Error('Supabase client unavailable');
        const { data: rows, error } = await sb.rpc('comms_metrics_latest');
        if (error) throw error;
        const row = Array.isArray(rows) ? rows[0] : rows;
        data = {
          metrics: {
            audience: row?.audience ?? null,
            reach: row?.reach ?? null,
            engagement: row?.engagement ?? null,
            leads: row?.leads ?? null,
          },
          updated_at: row?.updated_at ?? null,
        };
      }
      const k = parseKpis(data);
      setKpi('kpi-audience', k.audience);
      setKpi('kpi-reach', k.reach);
      setKpi('kpi-engagement', k.engagement);
      setKpi('kpi-leads', k.leads);
      const statusBase = k.updatedAt ? `${KPI_MSG_UPDATED} ${new Date(k.updatedAt).toLocaleString('pt-BR')}` : KPI_MSG_UPDATED;
      const status = KPI_URL ? statusBase : `${KPI_MSG_DB_FALLBACK} · ${statusBase}`;
      setKpiStatus(status);
      kpiLoaded = true;
    } catch (e: any) {
      setKpiStatus(`${KPI_MSG_ERROR} ${e?.message || ''}`.trim(), 'error');
    }
  }

  function applyGate(m: any) {
    if (m && allowComms(m)) showPanel();
    else showDenied();
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    const refreshBtn = document.getElementById('comms-kpi-refresh') as HTMLButtonElement | null;
    if (refreshBtn && !refreshBtn.dataset.bound) {
      refreshBtn.dataset.bound = '1';
      refreshBtn.addEventListener('click', () => { void loadCommsKpis(); });
    }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) applyGate(e.detail);
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) { applyGate(m); return; }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        applyGate(data);
        return;
      }
    } catch {}

    showDenied();
  }

  boot();
</script>
