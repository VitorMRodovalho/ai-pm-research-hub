  document.getElementById('btn-toggle-manual-form')?.addEventListener('click', () => {
    const container = document.getElementById('manual-form-container');
    if (!container) return;
    container.classList.toggle('hidden');
    // Set default date to today
    const dateInput = document.getElementById('manual-date') as HTMLInputElement;
    if (dateInput && !dateInput.value) dateInput.value = new Date().toISOString().slice(0, 10);
  });

  document.getElementById('btn-save-manual-metric')?.addEventListener('click', async () => {
    if (!sb) return;
    const date = (document.getElementById('manual-date') as HTMLInputElement)?.value;
    const channel = (document.getElementById('manual-channel') as HTMLSelectElement)?.value;
    const audience = parseInt((document.getElementById('manual-audience') as HTMLInputElement)?.value || '0', 10) || null;
    const reach = parseInt((document.getElementById('manual-reach') as HTMLInputElement)?.value || '0', 10) || null;
    const engagementRaw = parseFloat((document.getElementById('manual-engagement') as HTMLInputElement)?.value || '0');
    const engagement = engagementRaw > 0 ? (engagementRaw > 1 ? engagementRaw / 100 : engagementRaw) : null;
    const leads = parseInt((document.getElementById('manual-leads') as HTMLInputElement)?.value || '0', 10) || null;

    if (!date || !channel) {
      (window as any).toast?.('Preencha data e canal.', 'error');
      return;
    }

    const { error } = await sb.from('comms_metrics_daily').upsert({
      metric_date: date,
      channel,
      audience,
      reach,
      engagement_rate: engagement,
      leads,
      source: 'manual',
      payload: { entered_by: 'admin_ui' },
    }, { onConflict: 'metric_date,channel,source' });

    if (error) {
      (window as any).toast?.('Erro ao salvar: ' + (error.message || ''), 'error');
      return;
    }

    (window as any).toast?.('Métrica registrada!', 'success');
    // Refresh table
    loadNativeTable();
    loadCommsChart();
  });

  // Wire up channel config modal buttons
  document.getElementById('btn-cancel-channel')?.addEventListener('click', closeChannelModal);
  document.getElementById('btn-save-channel')?.addEventListener('click', saveChannelConfig);
  document.getElementById('channel-config-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) closeChannelModal();
  });

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && canAccessAdminRoute(e.detail, 'admin_comms')) showPanel();
      else showDenied();
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) {
      if (canAccessAdminRoute(m, 'admin_comms')) showPanel();
      else showDenied();
      return;
    }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        if (data && canAccessAdminRoute(data, 'admin_comms')) { showPanel(); return; }
      }
    } catch (e) { console.warn('Comms boot:', e); }

    showDenied();
  }

  boot();
</script>
