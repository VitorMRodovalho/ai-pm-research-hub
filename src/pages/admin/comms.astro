---
/**
 * admin/comms.astro — S-COM6 Dashboard Central de Mídia
 * Sections: native channel metrics, tribe impact ranking, and broadcast history.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import AdminNav from '../../components/nav/AdminNav.astro';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('admin.comms.meta', lang)} activePage="admin">
  <div class="max-w-[1200px] mx-auto px-4 pt-6">
    <AdminNav activeSub="comms" lang={lang} />
  </div>
  <div class="max-w-[1200px] mx-auto px-4 pb-8 space-y-6">
    <div class="mb-2">
      <h1 class="text-2xl font-extrabold text-navy">{t('admin.comms.title', lang)}</h1>
      <p class="text-sm text-[var(--text-secondary)]">{t('admin.comms.subtitle', lang)}</p>
    </div>

    <div id="comms-loading" class="text-center py-10 text-[var(--text-muted)]">{t('admin.comms.loading', lang)}</div>

    <div id="comms-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1f512;</div>
      <p class="font-semibold text-amber-800">{t('admin.comms.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('admin.comms.backAdmin', lang)}
      </a>
    </div>

    <div id="comms-panel" class="hidden space-y-6">
      <section id="comms-context" class="hidden bg-blue-50 border border-blue-200 rounded-2xl p-5">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="max-w-3xl">
            <h2 class="text-sm font-bold text-navy">Handoff contextual</h2>
            <p id="comms-context-copy" class="text-[.76rem] text-[var(--text-secondary)] mt-1"></p>
          </div>
          <div class="flex gap-2 flex-wrap">
            <a id="comms-context-attendance" href="/attendance" class="hidden px-4 py-2 rounded-xl bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.78rem] font-semibold no-underline hover:bg-[var(--surface-hover)] transition-all">
              Abrir Attendance
            </a>
            <a href="/admin/webinars" class="px-4 py-2 rounded-xl bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.78rem] font-semibold no-underline hover:bg-[var(--surface-hover)] transition-all">
              Voltar para Webinars
            </a>
          </div>
        </div>
      </section>

      <section id="comms-playbook" class="hidden bg-[var(--surface-card)] border border-[var(--border-default)] rounded-2xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">Playbook rapido do webinar</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">Assunto e copy-base para acelerar a comunicação sem criar um editor paralelo aqui.</p>
        </div>
        <div id="comms-playbook-body" class="p-4 grid grid-cols-1 lg:grid-cols-2 gap-4"></div>
      </section>

      <!-- Section 1: Tribe Impact Ranking -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.comms.rankingTitle', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">{t('admin.comms.rankingSubtitle', lang)}</p>
        </div>
        <div id="ranking-container" class="p-4 overflow-x-auto">
          <div id="ranking-loading" class="text-center py-6 text-[var(--text-muted)] text-sm">{t('admin.comms.tableLoading', lang)}</div>
          <div id="ranking-empty" class="hidden text-center py-6 text-[var(--text-secondary)] text-sm">{t('admin.comms.rankingEmpty', lang)}</div>
          <table id="ranking-table" class="hidden w-full text-[.72rem] border-collapse">
            <thead>
              <tr class="border-b border-[var(--border-default)] text-left">
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">#</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colTribe', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">{t('admin.comms.colEvents', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">{t('admin.comms.colHours', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">{t('admin.comms.colAvgAttendance', lang)}</th>
              </tr>
            </thead>
            <tbody id="ranking-body"></tbody>
          </table>
        </div>
      </section>

      <!-- Section 2: Channel Metrics Chart -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">Métricas por Canal (Visual)</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">Alcance e engajamento dos últimos 14 dias</p>
        </div>
        <div class="p-4" style="height:220px">
          <canvas id="comms-bar-chart"></canvas>
        </div>
      </section>

      <!-- Section 3: Channel Metrics Table -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.comms.nativeTitle', lang)}</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">{t('admin.comms.nativeSubtitle', lang)}</p>
        </div>
        <div id="comms-table-container" class="p-4 overflow-x-auto">
          <div id="comms-table-loading" class="text-center py-8 text-[var(--text-muted)] text-sm">{t('admin.comms.tableLoading', lang)}</div>
          <div id="comms-table-empty" class="hidden text-center py-8 text-[var(--text-secondary)] text-sm">{t('admin.comms.tableEmpty', lang)}</div>
          <table id="comms-table" class="hidden w-full text-[.72rem] border-collapse">
            <thead>
              <tr class="border-b border-[var(--border-default)] text-left">
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colDate', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colChannel', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colAudience', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colReach', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colEngagement', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colLeads', lang)}</th>
              </tr>
            </thead>
            <tbody id="comms-table-body"></tbody>
          </table>
        </div>
        <p class="px-4 pb-4 text-[.65rem] text-[var(--text-muted)]">{t('admin.comms.configNote', lang)}</p>
      </section>

      <!-- Section 3: Broadcast History -->
      <section id="broadcast-section" class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)] flex items-center justify-between gap-3 flex-wrap">
          <div>
            <h2 class="text-sm font-bold text-navy">{t('admin.comms.broadcastTitle', lang)}</h2>
            <p class="text-[.68rem] text-[var(--text-muted)]">{t('admin.comms.broadcastSubtitle', lang)}</p>
          </div>
          <input id="comms-broadcast-search" type="text"
                 class="w-full sm:w-[280px] px-3 py-2 rounded-xl border-[1.5px] border-[var(--border-default)] text-sm bg-[var(--surface-card)] focus:outline-none focus:border-navy transition-colors"
                 placeholder="Buscar assunto, tribo ou remetente" />
        </div>
        <div id="broadcast-container" class="p-4 overflow-x-auto">
          <div id="broadcast-loading" class="text-center py-6 text-[var(--text-muted)] text-sm">{t('admin.comms.tableLoading', lang)}</div>
          <div id="broadcast-empty" class="hidden text-center py-6 text-[var(--text-secondary)] text-sm">{t('admin.comms.broadcastEmpty', lang)}</div>
          <table id="broadcast-table" class="hidden w-full text-[.72rem] border-collapse">
            <thead>
              <tr class="border-b border-[var(--border-default)] text-left">
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colSubject', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colTribe', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">{t('admin.comms.colRecipients', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colSentAt', lang)}</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">{t('admin.comms.colSentBy', lang)}</th>
              </tr>
            </thead>
            <tbody id="broadcast-body"></tbody>
          </table>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<script>
  import { canAccessAdminRoute } from '../../lib/admin/constants';
  import { buildAttendanceFromCommsRoute, buildCommsPlaybookTemplates } from '../../lib/webinars/context-aids';

  let sb: any = null;
  let allBroadcasts: any[] = [];
  const COMMS_ROUTE = {
    focus: '',
    context: '',
    stage: '',
    q: '',
    title: '',
    date: '',
    eventId: '',
    broadcastScrolled: false,
  };

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function parseCommsRoute() {
    const params = new URLSearchParams(window.location.search);
    COMMS_ROUTE.focus = params.get('focus') || '';
    COMMS_ROUTE.context = params.get('context') || '';
    COMMS_ROUTE.stage = params.get('stage') || '';
    COMMS_ROUTE.q = (params.get('q') || '').trim();
    COMMS_ROUTE.title = (params.get('title') || COMMS_ROUTE.q).trim();
    COMMS_ROUTE.date = params.get('date') || '';
    COMMS_ROUTE.eventId = params.get('eventId') || '';
    const searchInput = document.getElementById('comms-broadcast-search') as HTMLInputElement | null;
    if (searchInput) searchInput.value = COMMS_ROUTE.q;
  }

  function formatRouteDate(dateIso: string): string {
    if (!dateIso) return '';
    const date = new Date(`${dateIso}T12:00:00`);
    if (Number.isNaN(date.getTime())) return dateIso;
    return date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function renderCommsContext() {
    const box = document.getElementById('comms-context');
    const copy = document.getElementById('comms-context-copy');
    const attendanceLink = document.getElementById('comms-context-attendance') as HTMLAnchorElement | null;
    if (!box || !copy) return;
    const hasContext = !!(COMMS_ROUTE.context || COMMS_ROUTE.q || COMMS_ROUTE.stage);
    if (!hasContext) {
      box.classList.add('hidden');
      copy.innerHTML = '';
      if (attendanceLink) attendanceLink.classList.add('hidden');
      return;
    }
    const stageLabel: Record<string, string> = {
      invite: 'preparar convite e lembrete',
      reminder: 'revisar lembrete operacional',
      followup: 'organizar follow-up e divulgação posterior',
    };
    const pieces = [
      COMMS_ROUTE.context === 'webinar'
        ? `Contexto atual: ${stageLabel[COMMS_ROUTE.stage] || 'revisar a comunicação'} do webinar <strong>${escapeHtml(COMMS_ROUTE.title || 'selecionado')}</strong>.`
        : 'Contexto atual: revisar a comunicação relacionada ao item selecionado.',
    ];
    if (COMMS_ROUTE.date) pieces.push(`Data de referência: ${escapeHtml(formatRouteDate(COMMS_ROUTE.date))}.`);
    if (COMMS_ROUTE.q) pieces.push('O histórico de disparos abaixo foi filtrado automaticamente para reduzir busca manual.');
    copy.innerHTML = pieces.join(' ');
    if (attendanceLink && COMMS_ROUTE.context === 'webinar') {
      attendanceLink.href = buildAttendanceFromCommsHref();
      attendanceLink.classList.remove('hidden');
    }
    box.classList.remove('hidden');
    if (COMMS_ROUTE.focus === 'broadcasts' && !COMMS_ROUTE.broadcastScrolled) {
      COMMS_ROUTE.broadcastScrolled = true;
      requestAnimationFrame(() => {
        document.getElementById('broadcast-section')?.scrollIntoView({ block: 'start', behavior: 'smooth' });
      });
    }
  }

  function showDenied() {
    document.getElementById('comms-loading')?.classList.add('hidden');
    document.getElementById('comms-denied')?.classList.remove('hidden');
    document.getElementById('comms-panel')?.classList.add('hidden');
  }

  function showPanel() {
    parseCommsRoute();
    renderCommsContext();
    renderCommsPlaybook();
    document.getElementById('comms-loading')?.classList.add('hidden');
    document.getElementById('comms-denied')?.classList.add('hidden');
    document.getElementById('comms-panel')?.classList.remove('hidden');
    loadRanking();
    loadBroadcasts();
    loadNativeTable();
    loadCommsChart();
  }

  async function loadCommsChart() {
    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 14 });
      if (error || !data?.length) return;
      const { Chart, BarController, CategoryScale, LinearScale, BarElement, Legend, Tooltip } = await import('chart.js');
      Chart.register(BarController, CategoryScale, LinearScale, BarElement, Legend, Tooltip);
      const canvas = document.getElementById('comms-bar-chart') as HTMLCanvasElement;
      if (!canvas) return;
      const channels = [...new Set(data.map((r: any) => r.channel))];
      const PALETTE = ['#0d9488', '#7c3aed', '#2563eb', '#e11d48', '#ea580c'];
      new Chart(canvas, {
        type: 'bar',
        data: {
          labels: channels,
          datasets: [
            { label: 'Alcance', data: channels.map(ch => data.filter((r: any) => r.channel === ch).reduce((s: number, r: any) => s + (r.reach || 0), 0)), backgroundColor: PALETTE[0], borderRadius: 4 },
            { label: 'Audiência', data: channels.map(ch => data.filter((r: any) => r.channel === ch).reduce((s: number, r: any) => s + (r.audience || 0), 0)), backgroundColor: PALETTE[1], borderRadius: 4 },
          ]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { font: { size: 10 } } } }, scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } } }
      });
    } catch (e) { console.warn('Comms chart:', e); }
  }

  async function loadRanking() {
    const loading = document.getElementById('ranking-loading');
    const empty = document.getElementById('ranking-empty');
    const table = document.getElementById('ranking-table');
    const tbody = document.getElementById('ranking-body');
    if (!loading || !empty || !table || !tbody) return;

    try {
      const { data, error } = await sb.rpc('tribe_impact_ranking');
      loading.classList.add('hidden');
      if (error || !data?.length) {
        empty.classList.remove('hidden');
        return;
      }
      const medals = ['\u{1F947} ', '\u{1F948} ', '\u{1F949} '];
      tbody.innerHTML = data.map((r: any, i: number) => {
        const medal = medals[i] || '';
        return '<tr class="border-b border-[var(--border-subtle)] hover:bg-[var(--surface-hover)]">'
          + '<td class="px-3 py-2 text-center font-bold text-[var(--text-muted)]">' + (i + 1) + '</td>'
          + '<td class="px-3 py-2 font-medium">' + medal + escapeHtml(r.tribe_name || '\u2014') + '</td>'
          + '<td class="px-3 py-2 text-right">' + (r.total_events ?? 0) + '</td>'
          + '<td class="px-3 py-2 text-right font-semibold text-navy">' + Number(r.total_hours || 0).toFixed(1) + 'h</td>'
          + '<td class="px-3 py-2 text-right">' + Number(r.avg_attendance || 0).toFixed(1) + '</td>'
          + '</tr>';
      }).join('');
      table.classList.remove('hidden');
    } catch (e: any) {
      loading.classList.add('hidden');
      if (empty) { empty.textContent = e?.message || 'Error'; empty.classList.remove('hidden'); }
    }
  }

  async function loadNativeTable() {
    const loading = document.getElementById('comms-table-loading');
    const empty = document.getElementById('comms-table-empty');
    const table = document.getElementById('comms-table');
    const tbody = document.getElementById('comms-table-body');
    if (!loading || !empty || !table || !tbody) return;

    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 14 });
      loading.classList.add('hidden');
      if (error) {
        empty.textContent = (error.message || 'Unknown error');
        empty.classList.remove('hidden');
        return;
      }
      if (!data?.length) { empty.classList.remove('hidden'); return; }
      tbody.innerHTML = data.map((r: any) =>
        '<tr class="border-b border-[var(--border-subtle)] hover:bg-[var(--surface-hover)]">'
        + '<td class="px-3 py-2">' + (r.metric_date || '\u2014') + '</td>'
        + '<td class="px-3 py-2 font-medium">' + escapeHtml(r.channel || '\u2014') + '</td>'
        + '<td class="px-3 py-2 text-right">' + (r.audience ?? '\u2014') + '</td>'
        + '<td class="px-3 py-2 text-right">' + (r.reach ?? '\u2014') + '</td>'
        + '<td class="px-3 py-2 text-right">' + (r.engagement != null ? (Number(r.engagement) * 100).toFixed(2) + '%' : '\u2014') + '</td>'
        + '<td class="px-3 py-2 text-right">' + (r.leads ?? '\u2014') + '</td>'
        + '</tr>'
      ).join('');
      table.classList.remove('hidden');
    } catch (e: any) {
      loading.classList.add('hidden');
      if (empty) { empty.textContent = (e?.message || 'Error loading data'); empty.classList.remove('hidden'); }
    }
  }

  async function loadBroadcasts() {
    const loading = document.getElementById('broadcast-loading');
    const empty = document.getElementById('broadcast-empty');
    const table = document.getElementById('broadcast-table');
    const tbody = document.getElementById('broadcast-body');
    if (!loading || !empty || !table || !tbody) return;

    try {
      const { data, error } = await sb.rpc('broadcast_history', { p_limit: 20 });
      loading.classList.add('hidden');
      if (error) { empty.classList.remove('hidden'); return; }
      allBroadcasts = data || [];
      renderBroadcasts();
    } catch (e: any) {
      loading.classList.add('hidden');
      if (empty) { empty.textContent = e?.message || 'Error'; empty.classList.remove('hidden'); }
    }
  }

  function buildAttendanceFromCommsHref(): string {
    return buildAttendanceFromCommsRoute(COMMS_ROUTE);
  }

  function buildCommsPlaybook(): Array<{ title: string; tone: string; subject: string; body: string }> {
    return buildCommsPlaybookTemplates(COMMS_ROUTE, formatRouteDate);
  }

  function renderCommsPlaybook() {
    const section = document.getElementById('comms-playbook');
    const body = document.getElementById('comms-playbook-body');
    if (!section || !body) return;
    if (COMMS_ROUTE.context !== 'webinar') {
      section.classList.add('hidden');
      body.innerHTML = '';
      return;
    }
    const templates = buildCommsPlaybook();
    body.innerHTML = templates.map((template, index) => `
      <article class="rounded-2xl border ${template.tone} p-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <h3 class="text-sm font-bold text-navy">${escapeHtml(template.title)}</h3>
            <p class="text-[.72rem] text-[var(--text-secondary)] mt-1">Use como base rápida e ajuste no canal/ferramenta final.</p>
          </div>
          <div class="flex gap-2 flex-wrap justify-end">
            <button type="button" class="px-3 py-1.5 rounded-lg bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.72rem] font-semibold cursor-pointer hover:bg-[var(--surface-hover)]" data-action="copy-template" data-copy-label="assunto" data-copy-value="${escapeHtml(template.subject)}">Copiar assunto</button>
            <button type="button" class="px-3 py-1.5 rounded-lg bg-navy text-white text-[.72rem] font-semibold border-0 cursor-pointer hover:opacity-90" data-action="copy-template" data-copy-label="mensagem" data-copy-value="${escapeHtml(template.body)}">Copiar mensagem</button>
          </div>
        </div>
        <div class="mt-3 space-y-3">
          <div>
            <div class="text-[.68rem] font-semibold uppercase tracking-wide text-[var(--text-secondary)]">Assunto sugerido</div>
            <div class="mt-1 text-[.8rem] text-[var(--text-primary)]">${escapeHtml(template.subject)}</div>
          </div>
          <div>
            <div class="text-[.68rem] font-semibold uppercase tracking-wide text-[var(--text-secondary)]">Mensagem base</div>
            <pre class="mt-1 whitespace-pre-wrap text-[.76rem] text-[var(--text-primary)] font-sans">${escapeHtml(template.body)}</pre>
          </div>
        </div>
      </article>
    `).join('');
    section.classList.remove('hidden');
  }

  async function copyTemplate(value: string, label: string) {
    try {
      if (navigator.clipboard?.writeText) await navigator.clipboard.writeText(value);
      else {
        const area = document.createElement('textarea');
        area.value = value;
        area.setAttribute('readonly', 'true');
        area.style.position = 'absolute';
        area.style.left = '-9999px';
        document.body.appendChild(area);
        area.select();
        document.execCommand('copy');
        document.body.removeChild(area);
      }
      (window as any).toast?.(`${label} copiado.`, 'success');
    } catch (error) {
      console.warn('Copy template:', error);
      (window as any).toast?.(`Nao foi possivel copiar ${label}.`, 'error');
    }
  }

  function renderBroadcasts() {
    const empty = document.getElementById('broadcast-empty');
    const table = document.getElementById('broadcast-table');
    const tbody = document.getElementById('broadcast-body');
    if (!empty || !table || !tbody) return;
    if (!allBroadcasts.length) {
      empty.classList.remove('hidden');
      table.classList.add('hidden');
      return;
    }
    const query = COMMS_ROUTE.q.toLowerCase();
    const filtered = allBroadcasts.filter((r: any) => {
      if (!query) return true;
      return (r.subject || '').toLowerCase().includes(query)
        || (r.tribe_name || '').toLowerCase().includes(query)
        || (r.sent_by_name || '').toLowerCase().includes(query);
    });
    if (!filtered.length) {
      empty.textContent = 'Nenhum disparo encontrado para o contexto atual.';
      empty.classList.remove('hidden');
      table.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    tbody.innerHTML = filtered.map((r: any) => {
      const dt = r.sent_at ? new Date(r.sent_at).toLocaleString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '\u2014';
      return '<tr class="border-b border-[var(--border-subtle)] hover:bg-[var(--surface-hover)]">'
        + '<td class="px-3 py-2 font-medium">' + escapeHtml(r.subject || '\u2014') + '</td>'
        + '<td class="px-3 py-2">' + escapeHtml(r.tribe_name || '\u2014') + '</td>'
        + '<td class="px-3 py-2 text-right">' + (r.recipient_count ?? '\u2014') + '</td>'
        + '<td class="px-3 py-2">' + dt + '</td>'
        + '<td class="px-3 py-2">' + escapeHtml(r.sent_by_name || '\u2014') + '</td>'
        + '</tr>';
    }).join('');
    table.classList.remove('hidden');
  }

  if (!(window as any).__commsDelegationBound) {
    (window as any).__commsDelegationBound = true;
    document.addEventListener('click', (e: Event) => {
      const target = (e.target as HTMLElement).closest('[data-action="copy-template"]') as HTMLElement | null;
      if (!target) return;
      copyTemplate(target.dataset.copyValue || '', target.dataset.copyLabel || 'texto');
    });
    document.addEventListener('input', (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.id === 'comms-broadcast-search') {
        COMMS_ROUTE.q = target.value.trim();
        renderCommsContext();
        renderBroadcasts();
      }
    });
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && canAccessAdminRoute(e.detail, 'admin_comms')) showPanel();
      else showDenied();
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) {
      if (canAccessAdminRoute(m, 'admin_comms')) showPanel();
      else showDenied();
      return;
    }

    try {
      const { data: { session } } = await sb.auth.getSession();
      if (session) {
        const { data } = await sb.rpc('get_member_by_auth');
        if (data && canAccessAdminRoute(data, 'admin_comms')) { showPanel(); return; }
      }
    } catch (e) { console.warn('Comms boot:', e); }

    showDenied();
  }

  boot();
</script>
