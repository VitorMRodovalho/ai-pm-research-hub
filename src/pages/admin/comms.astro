  };

  function timeAgo(iso: string | null): string {
    if (!iso) return 'Nunca';
    const diff = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 60) return `${mins}min atrás`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h atrás`;
    const days = Math.floor(hrs / 24);
    return `${days}d atrás`;
  }

  async function loadChannelConfig() {
    const grid = document.getElementById('comms-channels-grid');
    if (!grid) return;

    try {
      const { data, error } = await sb.rpc('comms_channel_status');
      if (error || !data?.length) {
        grid.innerHTML = '<p class="text-xs text-[var(--text-muted)] col-span-full">Nenhum canal configurado.</p>';
        return;
      }

      grid.innerHTML = (data as any[]).map((ch: any) => {
        const s = STATUS_MAP[ch.sync_status] || STATUS_MAP.error;
        const icon = CHANNEL_ICONS[ch.channel] || '';
        const isYoutube = ch.channel === 'youtube';
        const hasToken = isYoutube ? ch.has_api_key : ch.has_oauth_token;
        const expiryInfo = ch.days_until_expiry != null
          ? (ch.days_until_expiry < 0 ? 'Expirado' : `${ch.days_until_expiry}d restantes`)
          : (isYoutube ? 'Sem expiração' : 'Não configurado');
        const warningExpiry = ch.days_until_expiry != null && ch.days_until_expiry <= 7 && ch.days_until_expiry >= 0;

        return `<article class="rounded-xl border ${s.cls} p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="${ch.channel === 'youtube' ? 'text-red-600' : ch.channel === 'linkedin' ? 'text-blue-700' : 'text-pink-600'}">${icon}</span>
            <span class="text-sm font-bold capitalize">${ch.channel}</span>
            <span class="ml-auto text-[10px] px-2 py-0.5 rounded-full font-semibold ${s.cls}">${s.dot} ${s.label}</span>
          </div>
          <div class="space-y-1 text-[11px] text-[var(--text-secondary)]">
            <div>Token: ${hasToken ? '<span class="text-emerald-600 font-semibold">Configurado</span>' : '<span class="text-[var(--text-muted)]">Pendente</span>'}</div>
            <div>Expiração: ${warningExpiry ? '<span class="text-amber-600 font-semibold">' + expiryInfo + '</span>' : expiryInfo}</div>
            <div>Último sync: ${timeAgo(ch.last_sync_at)}</div>
          </div>
          <button class="mt-3 w-full px-3 py-1.5 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-[10px] font-semibold hover:bg-[var(--surface-hover)] transition-colors" data-action="config-channel" data-channel="${ch.channel}" data-config='${JSON.stringify(ch.config || {})}' data-has-apikey="${ch.has_api_key}" data-has-oauth="${ch.has_oauth_token}">
            ${hasToken ? 'Editar Config' : 'Configurar'}
          </button>
        </article>`;
      }).join('');

      // Wire up config buttons
      grid.querySelectorAll('[data-action="config-channel"]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const channel = (btn as HTMLElement).dataset.channel || '';
          const cfgStr = (btn as HTMLElement).dataset.config || '{}';
          openChannelModal(channel, JSON.parse(cfgStr));
        });
      });
    } catch (e) {
      console.warn('Channel config load:', e);
    }
  }

  function openChannelModal(channel: string, config: Record<string, unknown>) {
    const modal = document.getElementById('channel-config-modal');
    const title = document.getElementById('channel-modal-title');
    if (!modal) return;

    (document.getElementById('channel-modal-name') as HTMLInputElement).value = channel;
    if (title) title.textContent = `Configurar ${channel.charAt(0).toUpperCase() + channel.slice(1)}`;

    const isYoutube = channel === 'youtube';
    document.getElementById('channel-apikey-row')!.classList.toggle('hidden', !isYoutube);
    document.getElementById('channel-oauth-row')!.classList.toggle('hidden', isYoutube);
    document.getElementById('channel-refresh-row')!.classList.toggle('hidden', isYoutube);
    document.getElementById('channel-expires-row')!.classList.toggle('hidden', isYoutube);

    (document.getElementById('channel-apikey') as HTMLInputElement).value = '';
    (document.getElementById('channel-oauth') as HTMLInputElement).value = '';
    (document.getElementById('channel-refresh') as HTMLInputElement).value = '';
    (document.getElementById('channel-expires') as HTMLInputElement).value = '';
    (document.getElementById('channel-config-json') as HTMLTextAreaElement).value = JSON.stringify(config, null, 2);

    modal.classList.remove('hidden');
  }

  function closeChannelModal() {
    document.getElementById('channel-config-modal')?.classList.add('hidden');
  }

  async function saveChannelConfig() {
    const channel = (document.getElementById('channel-modal-name') as HTMLInputElement)?.value;
    if (!channel) return;

    const isYoutube = channel === 'youtube';
    const apiKey = isYoutube ? (document.getElementById('channel-apikey') as HTMLInputElement)?.value?.trim() || null : null;
    const oauthToken = !isYoutube ? (document.getElementById('channel-oauth') as HTMLInputElement)?.value?.trim() || null : null;
    const refreshToken = !isYoutube ? (document.getElementById('channel-refresh') as HTMLInputElement)?.value?.trim() || null : null;
    const expiresVal = !isYoutube ? (document.getElementById('channel-expires') as HTMLInputElement)?.value : null;
    const expiresAt = expiresVal ? new Date(expiresVal).toISOString() : null;

    let config = {};
    try {
      config = JSON.parse((document.getElementById('channel-config-json') as HTMLTextAreaElement)?.value || '{}');
    } catch { /* keep empty */ }

    const { data, error } = await sb.rpc('admin_manage_comms_channel', {
      p_action: 'upsert',
      p_channel: channel,
      p_api_key: apiKey,
      p_oauth_token: oauthToken,
      p_oauth_refresh_token: refreshToken,
      p_token_expires_at: expiresAt,
      p_config: config,
    });

    if (error || !data?.success) {
      (window as any).toast?.(data?.error || 'Erro ao salvar.', 'error');
      return;
    }

    closeChannelModal();
    (window as any).toast?.('Canal atualizado!', 'success');
    loadChannelConfig();
  }

  async function loadTokenAlerts() {
    const container = document.getElementById('comms-token-alerts');
    if (!container) return;

    try {
      const { data, error } = await sb.rpc('comms_check_token_expiry');
      if (error || !data?.active_alerts?.length) {
        container.classList.add('hidden');
        return;
      }

      container.innerHTML = (data.active_alerts as any[]).map((alert: any) => {
        const isUrgent = alert.alert_type === 'urgent';
        const cls = isUrgent
          ? 'bg-red-50 border-red-200 text-red-800'
          : 'bg-amber-50 border-amber-200 text-amber-800';
        const icon = isUrgent ? '\u{1F6A8}' : '\u26A0\uFE0F';
        return `<div class="rounded-xl border ${cls} px-4 py-3 flex items-center justify-between gap-3">
          <span class="text-sm">${icon} ${escapeHtml(alert.message)}</span>
          <button class="text-[10px] font-semibold underline opacity-70 hover:opacity-100" data-action="ack-alert" data-alert-id="${alert.id}">Dispensar</button>
        </div>`;
      }).join('');
      container.classList.remove('hidden');

      container.querySelectorAll('[data-action="ack-alert"]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const alertId = (btn as HTMLElement).dataset.alertId;
          if (!alertId) return;
          await sb.rpc('comms_acknowledge_alert', { p_alert_id: alertId });
          loadTokenAlerts();
        });
      });
    } catch (e) {
      console.warn('Token alerts:', e);
    }
  }

  // ─── Staleness / Graceful Degradation Banner ───

  async function loadStalenessBanner() {
    const banner = document.getElementById('comms-staleness-banner');
    if (!banner) return;

    try {
      const { data, error } = await sb.rpc('comms_channel_status');
      if (error || !data?.length) return;

      const SEVEN_DAYS = 7 * 24 * 60 * 60 * 1000;
      const alerts: string[] = [];

      for (const ch of data as any[]) {
        const lastSync = ch.last_sync_at ? new Date(ch.last_sync_at).getTime() : 0;
        const syncAge = Date.now() - lastSync;
        const channelName = ch.channel.charAt(0).toUpperCase() + ch.channel.slice(1);

        if (ch.sync_status === 'token_expired') {
          const lastDate = ch.last_sync_at
            ? new Date(ch.last_sync_at).toLocaleDateString('pt-BR')
            : 'desconhecida';
          alerts.push(
            `<div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-800 text-sm">
              \u{1F6A8} <strong>${channelName}</strong>: Token expirado. Última atualização: ${lastDate}.
            </div>`
          );
        } else if (lastSync > 0 && syncAge > SEVEN_DAYS) {
          const daysAgo = Math.floor(syncAge / (24 * 60 * 60 * 1000));
          alerts.push(
            `<div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800 text-sm">
              \u26A0\uFE0F <strong>${channelName}</strong>: Dados podem estar desatualizados (último sync: ${daysAgo} dias atrás).
            </div>`
          );
        }
      }

      if (alerts.length > 0) {
        banner.innerHTML = alerts.join('');
        banner.classList.remove('hidden');
      } else {
        banner.classList.add('hidden');
      }
    } catch (e) {
      console.warn('Staleness banner:', e);
    }
  }

