---
/**
 * admin/comms.astro — Social Media Analytics Dashboard
 * Sections: executive KPIs, trend chart, per-channel metrics, channel config (admin-only).
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---

<AdminLayout title={t('admin.comms.meta', lang)} breadcrumbs={[{label:'Conteudo'},{label:'Midia Social'}]}>
  <div class="max-w-[1200px] mx-auto px-4 pb-8 space-y-6">
    <div id="comms-loading" class="text-center py-10 text-[var(--text-muted)]">{t('admin.comms.loading', lang)}</div>

    <div id="comms-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1f512;</div>
      <p class="font-semibold text-amber-800">{t('admin.comms.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">
        {t('admin.comms.backAdmin', lang)}
      </a>
    </div>

    <div id="comms-panel" class="hidden space-y-6">
      <!-- Header with nav to Comunicacao -->
      <div class="flex items-center justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-2xl font-extrabold text-navy">Midia Social</h1>
          <p class="text-sm text-[var(--text-secondary)]">Metricas de YouTube, Instagram e LinkedIn</p>
        </div>
        <a href="/admin/comms-ops" class="px-4 py-2 rounded-xl bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.78rem] font-semibold no-underline hover:bg-[var(--surface-hover)] transition-all">
          &larr; Comunicacao (Ops)
        </a>
      </div>

      <!-- S1: Executive KPI Cards -->
      <section id="kpi-section" class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <div class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4">
          <div class="text-[.68rem] font-semibold uppercase text-[var(--text-muted)]">Audiencia Total</div>
          <div id="kpi-audience" class="text-xl font-extrabold text-navy mt-1">--</div>
          <div id="kpi-audience-sub" class="text-[.65rem] text-[var(--text-secondary)] mt-0.5"></div>
        </div>
        <div class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4">
          <div class="text-[.68rem] font-semibold uppercase text-[var(--text-muted)]">Alcance (7d)</div>
          <div id="kpi-reach" class="text-xl font-extrabold text-navy mt-1">--</div>
          <div id="kpi-reach-sub" class="text-[.65rem] text-[var(--text-secondary)] mt-0.5"></div>
        </div>
        <div class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4">
          <div class="text-[.68rem] font-semibold uppercase text-[var(--text-muted)]">Engagement Medio</div>
          <div id="kpi-engagement" class="text-xl font-extrabold text-navy mt-1">--</div>
          <div id="kpi-engagement-sub" class="text-[.65rem] text-[var(--text-secondary)] mt-0.5"></div>
        </div>
        <div class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4">
          <div class="text-[.68rem] font-semibold uppercase text-[var(--text-muted)]">Posts Totais</div>
          <div id="kpi-posts" class="text-xl font-extrabold text-navy mt-1">--</div>
          <div id="kpi-posts-sub" class="text-[.65rem] text-[var(--text-secondary)] mt-0.5"></div>
        </div>
      </section>

      <!-- S2: Trend Chart -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)] flex items-center justify-between gap-3">
          <div>
            <h2 class="text-sm font-bold text-navy">Tendencia por Canal</h2>
            <p class="text-[.68rem] text-[var(--text-muted)]">Audiencia e alcance ao longo do tempo</p>
          </div>
          <select id="trend-metric" class="text-xs rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-2 py-1">
            <option value="audience">Audiencia</option>
            <option value="reach">Alcance</option>
          </select>
        </div>
        <div class="p-4" style="height:260px">
          <canvas id="trend-chart"></canvas>
        </div>
      </section>

      <!-- S3: Per-Channel Performance -->
      <section id="channel-perf" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div id="perf-instagram" class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4 space-y-3">
          <div class="flex items-center gap-2">
            <span class="text-pink-600"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558a5.9 5.9 0 002.126-1.384 5.9 5.9 0 001.384-2.126c.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913a5.89 5.89 0 00-1.384-2.126A5.89 5.89 0 0019.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm7.846-10.405a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/></svg></span>
            <span class="text-sm font-bold">Instagram</span>
          </div>
          <div id="perf-ig-body" class="text-sm text-[var(--text-muted)]">Carregando...</div>
        </div>
        <div id="perf-youtube" class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4 space-y-3">
          <div class="flex items-center gap-2">
            <span class="text-red-600"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></span>
            <span class="text-sm font-bold">YouTube</span>
          </div>
          <div id="perf-yt-body" class="text-sm text-[var(--text-muted)]">Carregando...</div>
        </div>
        <div id="perf-linkedin" class="rounded-xl border border-[var(--border-default)] bg-[var(--surface-card)] p-4 space-y-3">
          <div class="flex items-center gap-2">
            <span class="text-blue-700"><svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.064 2.064 0 110-4.128 2.064 2.064 0 010 4.128zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></span>
            <span class="text-sm font-bold">LinkedIn</span>
          </div>
          <div id="perf-li-body" class="text-sm text-[var(--text-muted)]">Aguardando aprovacao da API</div>
        </div>
      </section>

      <!-- S4: Top Content (populated in Phase 3) -->
      <section id="top-content-section" class="hidden bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">Top Content</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">Posts com melhor performance nos ultimos 30 dias</p>
        </div>
        <div id="top-content-body" class="p-4"></div>
      </section>

      <!-- S5: Best Time to Post (Instagram) -->
      <section id="best-time-section" class="hidden bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">Melhor Horario para Postar</h2>
          <p class="text-[.68rem] text-[var(--text-muted)]">Quando seus seguidores do Instagram estao online (por hora do dia)</p>
        </div>
        <div id="best-time-body" class="p-4">
          <div id="best-time-chart" class="flex items-end gap-[3px] h-[140px]"></div>
          <div id="best-time-legend" class="mt-2 text-[.65rem] text-[var(--text-muted)] text-center"></div>
        </div>
      </section>

      <!-- S6: Metrics Table -->
      <section class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-default)] flex items-center justify-between gap-3 flex-wrap">
          <div>
            <h2 class="text-sm font-bold text-navy">Historico de Metricas</h2>
            <p class="text-[.68rem] text-[var(--text-muted)]">Dados diarios por canal (ultimos 14 dias)</p>
          </div>
          <div class="flex gap-2">
            <button id="btn-export-csv" class="px-3 py-1.5 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-[.7rem] font-semibold hover:bg-[var(--surface-hover)]">Exportar CSV</button>
            <button id="btn-export-pdf" class="px-3 py-1.5 rounded-lg bg-navy text-white text-[.7rem] font-semibold hover:opacity-90">Exportar PDF</button>
          </div>
        </div>
        <div id="metrics-table-container" class="p-4 overflow-x-auto">
          <div id="metrics-table-loading" class="text-center py-6 text-[var(--text-muted)] text-sm">Carregando...</div>
          <div id="metrics-table-empty" class="hidden text-center py-6 text-[var(--text-secondary)] text-sm">Nenhuma metrica encontrada.</div>
          <table id="metrics-table" class="hidden w-full text-[.72rem] border-collapse">
            <thead>
              <tr class="border-b border-[var(--border-default)] text-left">
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">Data</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">Canal</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">Audiencia</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">Alcance</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)] text-right">Engagement</th>
                <th class="px-3 py-2 font-semibold text-[var(--text-secondary)]">Fonte</th>
              </tr>
            </thead>
            <tbody id="metrics-table-body"></tbody>
          </table>
        </div>
      </section>

      <!-- S6: Channel Admin (comms_leader+ only) -->
      <div id="admin-sections" class="space-y-6">
        <!-- Token Alerts -->
        <div id="comms-token-alerts" class="hidden space-y-2"></div>
        <div id="comms-staleness-banner" class="hidden"></div>

        <!-- Channel Config -->
        <section id="comms-channels" class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
          <div class="px-4 py-3 border-b border-[var(--border-default)]">
            <h2 class="text-sm font-bold text-navy">Integracao de Canais</h2>
            <p class="text-[.68rem] text-[var(--text-muted)]">Status de tokens e configuracao de API</p>
          </div>
          <div id="comms-channels-grid" class="p-4 grid grid-cols-1 md:grid-cols-3 gap-3">
            <div class="text-sm text-[var(--text-muted)]">Carregando...</div>
          </div>
        </section>
      </div>

      <!-- Channel Config Modal -->
      <div id="channel-config-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-xl w-full max-w-md p-5 mx-4">
          <h2 id="channel-modal-title" class="text-lg font-extrabold text-navy mb-4">Configurar Canal</h2>
          <input type="hidden" id="channel-modal-name" />
          <div class="space-y-3">
            <div id="channel-apikey-row">
              <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">API Key</label>
              <input id="channel-apikey" type="password" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" placeholder="YouTube Data API v3 key" />
            </div>
            <div id="channel-oauth-row">
              <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">OAuth Token</label>
              <input id="channel-oauth" type="password" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" />
            </div>
            <div id="channel-refresh-row">
              <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">Refresh Token</label>
              <input id="channel-refresh" type="password" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" />
            </div>
            <div id="channel-expires-row">
              <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">Expiracao do Token</label>
              <input id="channel-expires" type="datetime-local" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" />
            </div>
            <div>
              <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">Config JSON</label>
              <textarea id="channel-config-json" rows="3" class="w-full text-xs font-mono rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" placeholder='{"channel_id": "..."}'></textarea>
            </div>
          </div>
          <div class="flex gap-2 justify-end mt-5">
            <button id="btn-cancel-channel" class="px-3 py-2 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-xs font-semibold hover:bg-[var(--surface-hover)]">Cancelar</button>
            <button id="btn-save-channel" class="px-3 py-2 rounded-lg bg-teal text-white text-xs font-semibold hover:opacity-90">Salvar</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  import { canAccessAdminRoute } from '../../lib/admin/constants';

  let sb: any = null;
  let currentMember: any = null;
  let trendData: any[] = [];

  function escapeHtml(s: string): string {
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  function fmt(n: number | null | undefined): string {
    if (n == null) return '--';
    if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
    if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
    return String(n);
  }

  function canManageChannels(member: any): boolean {
    if (!member) return false;
    if (member.is_superadmin) return true;
    const role = String(member.operational_role || '');
    if (['manager', 'deputy_manager'].includes(role)) return true;
    const desigs: string[] = Array.isArray(member.designations) ? member.designations : [];
    return desigs.includes('comms_leader');
  }

  // ── S1: Executive KPIs with period comparison ──

  function renderDelta(el: HTMLElement, current: number, previous: number, suffix = '') {
    if (!previous || !current) { el.textContent = ''; return; }
    const pct = ((current - previous) / previous * 100);
    const arrow = pct >= 0 ? '\u2191' : '\u2193';
    const color = pct >= 0 ? 'text-emerald-600' : 'text-red-500';
    el.innerHTML = `<span class="${color} font-semibold">${arrow} ${Math.abs(pct).toFixed(1)}%</span> vs periodo anterior${suffix}`;
  }

  async function loadKPIs() {
    try {
      // Current period (7 days)
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 7 });
      if (error || !data?.length) return;

      // Previous period (8-14 days ago)
      const { data: prevData } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 14 });

      const latest: Record<string, any> = {};
      for (const r of data) {
        if (!latest[r.channel] || r.metric_date > latest[r.channel].metric_date) latest[r.channel] = r;
      }

      // Previous period: entries older than 7 days
      const prevLatest: Record<string, any> = {};
      if (prevData) {
        const cutoff = new Date(); cutoff.setDate(cutoff.getDate() - 7);
        const cutoffStr = cutoff.toISOString().slice(0, 10);
        for (const r of prevData) {
          if (r.metric_date >= cutoffStr) continue;
          if (!prevLatest[r.channel] || r.metric_date > prevLatest[r.channel].metric_date) prevLatest[r.channel] = r;
        }
      }

      const totalAudience = Object.values(latest).reduce((s: number, r: any) => s + (r.audience || 0), 0);
      const prevAudience = Object.values(prevLatest).reduce((s: number, r: any) => s + (r.audience || 0), 0);
      const totalReach = data.reduce((s: number, r: any) => s + (r.reach || 0), 0);
      const prevReach = prevData ? prevData.filter((r: any) => r.metric_date < new Date(Date.now() - 7 * 86400000).toISOString().slice(0, 10)).reduce((s: number, r: any) => s + (r.reach || 0), 0) : 0;
      const engagements = Object.values(latest).filter((r: any) => r.engagement != null);
      const avgEngagement = engagements.length > 0
        ? engagements.reduce((s: number, r: any) => s + Number(r.engagement || 0), 0) / engagements.length
        : null;
      const prevEngagements = Object.values(prevLatest).filter((r: any) => r.engagement != null);
      const prevAvgEngagement = prevEngagements.length > 0
        ? prevEngagements.reduce((s: number, r: any) => s + Number(r.engagement || 0), 0) / prevEngagements.length
        : null;

      document.getElementById('kpi-audience')!.textContent = fmt(totalAudience);
      const audSub = document.getElementById('kpi-audience-sub')!;
      if (prevAudience > 0) renderDelta(audSub, totalAudience, prevAudience);
      else audSub.textContent = Object.entries(latest).map(([ch, r]: [string, any]) => `${ch}: ${fmt(r.audience)}`).join(' · ');

      document.getElementById('kpi-reach')!.textContent = fmt(totalReach);
      const reachSub = document.getElementById('kpi-reach-sub')!;
      if (prevReach > 0) renderDelta(reachSub, totalReach, prevReach, ' (7d)');
      else reachSub.textContent = 'Soma dos ultimos 7 dias';

      if (avgEngagement != null) {
        document.getElementById('kpi-engagement')!.textContent = (avgEngagement * 100).toFixed(1) + '%';
        const engSub = document.getElementById('kpi-engagement-sub')!;
        if (prevAvgEngagement != null && prevAvgEngagement > 0) renderDelta(engSub, avgEngagement, prevAvgEngagement);
        else engSub.textContent = 'Media ponderada por canal';
      }

      const igPosts = latest['instagram']?.payload?.media_count || 0;
      const ytVideos = latest['youtube']?.payload?.videoCount || latest['youtube']?.payload?.video_count || 0;
      document.getElementById('kpi-posts')!.textContent = fmt(Number(igPosts) + Number(ytVideos));
      document.getElementById('kpi-posts-sub')!.textContent = `IG: ${igPosts} · YT: ${ytVideos}`;
    } catch (e) { console.warn('KPIs:', e); }
  }

  // ── CSV Export ──

  let metricsDataForExport: any[] = [];

  function exportCSV() {
    if (!metricsDataForExport.length) { (window as any).toast?.('Sem dados para exportar.', 'error'); return; }
    const headers = ['Data', 'Canal', 'Audiencia', 'Alcance', 'Engagement', 'Fonte'];
    const rows = metricsDataForExport.map((r: any) => [
      r.metric_date || '',
      r.channel || '',
      r.audience ?? '',
      r.reach ?? '',
      r.engagement != null ? (Number(r.engagement) * 100).toFixed(2) + '%' : '',
      r.source || '',
    ]);
    const csv = [headers, ...rows].map(row => row.map(c => `"${String(c).replace(/"/g, '""')}"`).join(',')).join('\n');
    const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `social-media-metrics-${new Date().toISOString().slice(0, 10)}.csv`;
    a.click();
    URL.revokeObjectURL(url);
    (window as any).toast?.('CSV exportado!', 'success');
  }

  document.getElementById('btn-export-csv')?.addEventListener('click', exportCSV);

  // ── PDF Export ──

  async function exportPDF() {
    const btn = document.getElementById('btn-export-pdf') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Gerando...'; }
    try {
      const { default: html2canvas } = await import('html2canvas');
      const { jsPDF } = await import('jspdf');
      const panel = document.getElementById('comms-panel');
      if (!panel) return;

      // Temporarily hide admin-only sections and export buttons for clean PDF
      const adminSections = document.getElementById('admin-sections');
      const exportBtns = document.getElementById('btn-export-csv')?.parentElement;
      adminSections?.classList.add('hidden');
      exportBtns?.classList.add('hidden');

      const canvas = await html2canvas(panel, { scale: 1.5, useCORS: true, logging: false });

      adminSections?.classList.remove('hidden');
      exportBtns?.classList.remove('hidden');

      const imgData = canvas.toDataURL('image/png');
      const pdf = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
      const pageW = pdf.internal.pageSize.getWidth();
      const pageH = pdf.internal.pageSize.getHeight();
      const imgW = pageW - 20;
      const imgH = (canvas.height * imgW) / canvas.width;

      let y = 10;
      if (imgH <= pageH - 20) {
        pdf.addImage(imgData, 'PNG', 10, y, imgW, imgH);
      } else {
        // Multi-page
        const pageImgH = pageH - 20;
        let srcY = 0;
        while (srcY < canvas.height) {
          const sliceH = Math.min(pageImgH / imgW * canvas.width, canvas.height - srcY);
          const sliceCanvas = document.createElement('canvas');
          sliceCanvas.width = canvas.width;
          sliceCanvas.height = sliceH;
          sliceCanvas.getContext('2d')!.drawImage(canvas, 0, srcY, canvas.width, sliceH, 0, 0, canvas.width, sliceH);
          pdf.addImage(sliceCanvas.toDataURL('image/png'), 'PNG', 10, 10, imgW, sliceH * imgW / canvas.width);
          srcY += sliceH;
          if (srcY < canvas.height) pdf.addPage();
        }
      }

      pdf.save(`social-media-report-${new Date().toISOString().slice(0, 10)}.pdf`);
      (window as any).toast?.('PDF exportado!', 'success');
    } catch (e) {
      console.warn('PDF export:', e);
      (window as any).toast?.('Erro ao gerar PDF. Instale as dependencias: npm i html2canvas jspdf', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Exportar PDF'; }
    }
  }

  document.getElementById('btn-export-pdf')?.addEventListener('click', exportPDF);

  // ── Best Time to Post (Instagram online_followers) ──

  async function loadBestTimeToPost() {
    const section = document.getElementById('best-time-section');
    const chart = document.getElementById('best-time-chart');
    const legend = document.getElementById('best-time-legend');
    if (!section || !chart || !legend) return;

    try {
      // Check if we have online_followers data in the latest IG payload
      const { data } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 3 });
      if (!data) return;
      const igRow = data.find((r: any) => r.channel === 'instagram');
      const onlineData = igRow?.payload?.online_followers;
      if (!onlineData || typeof onlineData !== 'object') return;

      // onlineData is {0: count, 1: count, ..., 23: count}
      const hours = Array.from({ length: 24 }, (_, i) => i);
      const values = hours.map(h => Number(onlineData[h] || onlineData[String(h)] || 0));
      const maxVal = Math.max(...values, 1);
      const bestHour = hours[values.indexOf(Math.max(...values))];

      chart.innerHTML = hours.map(h => {
        const pct = Math.max((values[h] / maxVal) * 100, 4);
        const isBest = h === bestHour;
        const color = isBest ? 'bg-pink-500' : values[h] >= maxVal * 0.7 ? 'bg-pink-300' : 'bg-gray-200';
        return `<div class="flex-1 flex flex-col items-center gap-1">
          <div class="${color} rounded-t-sm w-full transition-all" style="height:${pct}%" title="${values[h]} online as ${h}h"></div>
          <span class="text-[.55rem] text-[var(--text-muted)] ${isBest ? 'font-bold text-pink-600' : ''}">${h}h</span>
        </div>`;
      }).join('');

      legend.textContent = `Melhor horario: ${bestHour}h (${values[bestHour]} seguidores online)`;
      section.classList.remove('hidden');
    } catch (e) { console.warn('Best time:', e); }
  }

  // ── S2: Trend Chart ──

  async function loadTrendChart(metric = 'audience') {
    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 30 });
      if (error || !data?.length) return;
      trendData = data;
      renderTrendChart(metric);
    } catch (e) { console.warn('Trend:', e); }
  }

  async function renderTrendChart(metric: string) {
    const canvas = document.getElementById('trend-chart') as HTMLCanvasElement;
    if (!canvas || !trendData.length) return;

    const { Chart, LineController, CategoryScale, LinearScale, PointElement, LineElement, Legend, Tooltip, Filler } = await import('chart.js');
    Chart.register(LineController, CategoryScale, LinearScale, PointElement, LineElement, Legend, Tooltip, Filler);

    if ((window as any).__trendChart) (window as any).__trendChart.destroy();

    const channels = [...new Set(trendData.map((r: any) => r.channel))];
    const dates = [...new Set(trendData.map((r: any) => r.metric_date))].sort();
    const COLORS: Record<string, string> = { instagram: '#E1306C', youtube: '#FF0000', linkedin: '#0077B5', newsletter: '#6B7280' };

    (window as any).__trendChart = new Chart(canvas, {
      type: 'line',
      data: {
        labels: dates.map(d => new Date(d + 'T12:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })),
        datasets: channels.map(ch => ({
          label: ch.charAt(0).toUpperCase() + ch.slice(1),
          data: dates.map(d => {
            const row = trendData.find((r: any) => r.channel === ch && r.metric_date === d);
            return row ? (metric === 'reach' ? row.reach : row.audience) : null;
          }),
          borderColor: COLORS[ch] || '#6B7280',
          backgroundColor: (COLORS[ch] || '#6B7280') + '15',
          fill: false,
          tension: 0.3,
          pointRadius: 3,
          borderWidth: 2,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { font: { size: 11 } } } },
        scales: { y: { beginAtZero: true, grid: { color: '#f1f5f9' } }, x: { grid: { display: false } } },
        interaction: { intersect: false, mode: 'index' },
      },
    });
  }

  document.getElementById('trend-metric')?.addEventListener('change', (e) => {
    renderTrendChart((e.target as HTMLSelectElement).value);
  });

  // ── S3: Per-Channel Performance ──

  async function loadChannelPerformance() {
    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 7 });
      if (error || !data?.length) return;

      const latest: Record<string, any> = {};
      for (const r of data) {
        if (!latest[r.channel] || r.metric_date > latest[r.channel].metric_date) latest[r.channel] = r;
      }

      // Instagram
      const ig = latest['instagram'];
      if (ig) {
        const engaged = ig.payload?.accounts_engaged;
        const interactions = ig.payload?.total_interactions;
        document.getElementById('perf-ig-body')!.innerHTML = `
          <div class="space-y-2">
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Seguidores</span><span class="font-bold text-navy">${fmt(ig.audience)}</span></div>
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Alcance (dia)</span><span class="font-bold">${fmt(ig.reach)}</span></div>
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Engagement</span><span class="font-bold">${ig.engagement ? (Number(ig.engagement) * 100).toFixed(1) + '%' : '--'}</span></div>
            ${engaged != null ? `<div class="flex justify-between"><span class="text-[var(--text-secondary)]">Contas engajadas</span><span class="font-bold">${engaged}</span></div>` : ''}
            ${interactions != null ? `<div class="flex justify-between"><span class="text-[var(--text-secondary)]">Interacoes totais</span><span class="font-bold">${interactions}</span></div>` : ''}
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Posts</span><span class="font-bold">${ig.payload?.media_count || '--'}</span></div>
          </div>`;
      } else {
        document.getElementById('perf-ig-body')!.innerHTML = '<p class="text-[var(--text-muted)]">Sem dados recentes</p>';
      }

      // YouTube
      const yt = latest['youtube'];
      if (yt) {
        document.getElementById('perf-yt-body')!.innerHTML = `
          <div class="space-y-2">
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Inscritos</span><span class="font-bold text-navy">${fmt(yt.audience)}</span></div>
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Views totais</span><span class="font-bold">${fmt(yt.reach)}</span></div>
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Videos</span><span class="font-bold">${yt.payload?.videoCount || yt.payload?.video_count || '--'}</span></div>
          </div>`;
      }

      // LinkedIn
      const li = latest['linkedin'];
      if (li && li.audience) {
        document.getElementById('perf-li-body')!.innerHTML = `
          <div class="space-y-2">
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Seguidores</span><span class="font-bold text-navy">${fmt(li.audience)}</span></div>
            <div class="flex justify-between"><span class="text-[var(--text-secondary)]">Alcance</span><span class="font-bold">${fmt(li.reach)}</span></div>
          </div>`;
      }
    } catch (e) { console.warn('Channel perf:', e); }
  }

  // ── S5: Metrics Table ──

  async function loadMetricsTable() {
    const loading = document.getElementById('metrics-table-loading');
    const empty = document.getElementById('metrics-table-empty');
    const table = document.getElementById('metrics-table');
    const tbody = document.getElementById('metrics-table-body');
    if (!loading || !empty || !table || !tbody) return;

    try {
      const { data, error } = await sb.rpc('comms_metrics_latest_by_channel', { p_days: 14 });
      loading.classList.add('hidden');
      if (error || !data?.length) { empty.classList.remove('hidden'); return; }
      metricsDataForExport = data;
      tbody.innerHTML = data.map((r: any) =>
        `<tr class="border-b border-[var(--border-subtle)] hover:bg-[var(--surface-hover)]">
          <td class="px-3 py-2">${r.metric_date || ''}</td>
          <td class="px-3 py-2 font-medium capitalize">${escapeHtml(r.channel || '')}</td>
          <td class="px-3 py-2 text-right">${r.audience != null ? fmt(r.audience) : ''}</td>
          <td class="px-3 py-2 text-right">${r.reach != null ? fmt(r.reach) : ''}</td>
          <td class="px-3 py-2 text-right">${r.engagement != null ? (Number(r.engagement) * 100).toFixed(1) + '%' : ''}</td>
          <td class="px-3 py-2"><span class="text-[10px] px-1.5 py-0.5 rounded-full font-semibold ${r.source === 'api' ? 'bg-teal/10 text-teal' : 'bg-gray-100 text-gray-500'}">${r.source === 'api' ? 'API' : r.source || 'manual'}</span></td>
        </tr>`
      ).join('');
      table.classList.remove('hidden');
    } catch (e: any) { loading?.classList.add('hidden'); empty?.classList.remove('hidden'); }
  }

  // ── S4: Top Content ──

  async function loadTopContent() {
    const section = document.getElementById('top-content-section');
    const body = document.getElementById('top-content-body');
    if (!section || !body) return;
    try {
      const { data, error } = await sb.rpc('comms_top_media', { p_days: 30, p_limit: 6 });
      if (error) return;
      const items = Array.isArray(data) ? data : (typeof data === 'string' ? JSON.parse(data) : []);
      if (!items.length) return;

      body.innerHTML = `<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">${items.map((m: any) => {
        const channelColor: Record<string, string> = { instagram: 'text-pink-600', youtube: 'text-red-600', linkedin: 'text-blue-700' };
        const date = m.published_at ? new Date(m.published_at).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' }) : '';
        return `<article class="rounded-xl border border-[var(--border-default)] overflow-hidden">
          ${m.thumbnail_url ? `<img src="${escapeHtml(m.thumbnail_url)}" alt="" class="w-full h-32 object-cover" loading="lazy" />` : '<div class="w-full h-32 bg-gray-100 flex items-center justify-center text-[var(--text-muted)] text-2xl">' + (m.channel === 'youtube' ? '\u25B6' : '\uD83D\uDCF7') + '</div>'}
          <div class="p-3">
            <div class="flex items-center gap-1.5 mb-1">
              <span class="${channelColor[m.channel] || ''} text-[.65rem] font-bold uppercase">${escapeHtml(m.channel)}</span>
              <span class="text-[.6rem] text-[var(--text-muted)]">${date}</span>
            </div>
            <p class="text-[.72rem] text-[var(--text-primary)] line-clamp-2">${escapeHtml(m.caption || 'Sem legenda')}</p>
            <div class="flex gap-3 mt-2 text-[.65rem] text-[var(--text-secondary)]">
              ${m.likes ? `<span>\u2764 ${m.likes}</span>` : ''}
              ${m.comments ? `<span>\uD83D\uDCAC ${m.comments}</span>` : ''}
              ${m.saves ? `<span>\uD83D\uDD16 ${m.saves}</span>` : ''}
              ${m.views ? `<span>\u25B6 ${fmt(m.views)}</span>` : ''}
              ${m.reach ? `<span>\uD83D\uDC41 ${fmt(m.reach)}</span>` : ''}
            </div>
            ${m.permalink ? `<a href="${escapeHtml(m.permalink)}" target="_blank" rel="noopener" class="mt-2 inline-block text-[.65rem] text-teal font-semibold no-underline hover:underline">Ver post &rarr;</a>` : ''}
          </div>
        </article>`;
      }).join('')}</div>`;
      section.classList.remove('hidden');
    } catch (e) { console.warn('Top content:', e); }
  }

  // ── Channel Admin (leader+ only) ──

  const STATUS_MAP: Record<string, { dot: string; label: string; cls: string }> = {
    active:        { dot: '\u{1F7E2}', label: 'Ativo',     cls: 'text-emerald-700 bg-emerald-50 border-emerald-200' },
    token_expired: { dot: '\u{1F534}', label: 'Expirado',  cls: 'text-red-700 bg-red-50 border-red-200' },
    error:         { dot: '\u{1F7E0}', label: 'Erro',      cls: 'text-amber-700 bg-amber-50 border-amber-200' },
  };

  function timeAgo(iso: string | null): string {
    if (!iso) return 'Nunca';
    const diff = Date.now() - new Date(iso).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 60) return `${mins}min atras`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs}h atras`;
    return `${Math.floor(hrs / 24)}d atras`;
  }

  async function loadChannelConfig() {
    const grid = document.getElementById('comms-channels-grid');
    if (!grid) return;
    try {
      const { data, error } = await sb.rpc('comms_channel_status');
      if (error || !data?.length) { grid.innerHTML = '<p class="text-xs text-[var(--text-muted)] col-span-full">Nenhum canal.</p>'; return; }

      grid.innerHTML = (data as any[]).map((ch: any) => {
        const s = STATUS_MAP[ch.sync_status] || STATUS_MAP.error;
        const isYT = ch.channel === 'youtube';
        const hasToken = isYT ? ch.has_api_key : ch.has_oauth_token;
        const expiry = ch.days_until_expiry != null
          ? (ch.days_until_expiry < 0 ? 'Expirado' : `${ch.days_until_expiry}d restantes`)
          : (isYT || (ch.has_oauth_token && !ch.token_expires_at) ? 'Permanente' : 'Nao configurado');

        return `<article class="rounded-xl border ${s.cls} p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-sm font-bold capitalize">${ch.channel}</span>
            <span class="ml-auto text-[10px] px-2 py-0.5 rounded-full font-semibold ${s.cls}">${s.dot} ${s.label}</span>
          </div>
          <div class="space-y-1 text-[11px] text-[var(--text-secondary)]">
            <div>Token: ${hasToken ? '<span class="text-emerald-600 font-semibold">Configurado</span>' : '<span class="text-[var(--text-muted)]">Pendente</span>'}</div>
            <div>Expiracao: ${expiry}</div>
            <div>Ultimo sync: ${timeAgo(ch.last_sync_at)}</div>
          </div>
          <button class="mt-3 w-full px-3 py-1.5 rounded-lg border border-[var(--border-default)] text-[var(--text-primary)] text-[10px] font-semibold hover:bg-[var(--surface-hover)]" data-action="config-channel" data-channel="${ch.channel}" data-config='${JSON.stringify(ch.config || {})}'>
            ${hasToken ? 'Editar Config' : 'Configurar'}
          </button>
        </article>`;
      }).join('');

      grid.querySelectorAll('[data-action="config-channel"]').forEach(btn => {
        btn.addEventListener('click', () => {
          openChannelModal((btn as HTMLElement).dataset.channel || '', JSON.parse((btn as HTMLElement).dataset.config || '{}'));
        });
      });
    } catch (e) { console.warn('Channel config:', e); }
  }

  function openChannelModal(channel: string, config: Record<string, unknown>) {
    const modal = document.getElementById('channel-config-modal');
    if (!modal) return;
    (document.getElementById('channel-modal-name') as HTMLInputElement).value = channel;
    document.getElementById('channel-modal-title')!.textContent = `Configurar ${channel.charAt(0).toUpperCase() + channel.slice(1)}`;
    const isYT = channel === 'youtube';
    document.getElementById('channel-apikey-row')!.classList.toggle('hidden', !isYT);
    document.getElementById('channel-oauth-row')!.classList.toggle('hidden', isYT);
    document.getElementById('channel-refresh-row')!.classList.toggle('hidden', isYT);
    document.getElementById('channel-expires-row')!.classList.toggle('hidden', isYT);
    (document.getElementById('channel-apikey') as HTMLInputElement).value = '';
    (document.getElementById('channel-oauth') as HTMLInputElement).value = '';
    (document.getElementById('channel-refresh') as HTMLInputElement).value = '';
    (document.getElementById('channel-expires') as HTMLInputElement).value = '';
    (document.getElementById('channel-config-json') as HTMLTextAreaElement).value = JSON.stringify(config, null, 2);
    modal.classList.remove('hidden');
  }

  function closeChannelModal() { document.getElementById('channel-config-modal')?.classList.add('hidden'); }

  async function saveChannelConfig() {
    const channel = (document.getElementById('channel-modal-name') as HTMLInputElement)?.value;
    if (!channel) return;
    const isYT = channel === 'youtube';
    const apiKey = isYT ? (document.getElementById('channel-apikey') as HTMLInputElement)?.value?.trim() || null : null;
    const oauthToken = !isYT ? (document.getElementById('channel-oauth') as HTMLInputElement)?.value?.trim() || null : null;
    const refreshToken = !isYT ? (document.getElementById('channel-refresh') as HTMLInputElement)?.value?.trim() || null : null;
    const expiresVal = !isYT ? (document.getElementById('channel-expires') as HTMLInputElement)?.value : null;
    const expiresAt = expiresVal ? new Date(expiresVal).toISOString() : null;
    let config = {};
    try { config = JSON.parse((document.getElementById('channel-config-json') as HTMLTextAreaElement)?.value || '{}'); } catch {}

    const { data, error } = await sb.rpc('admin_manage_comms_channel', {
      p_action: 'upsert', p_channel: channel, p_api_key: apiKey,
      p_oauth_token: oauthToken, p_oauth_refresh_token: refreshToken,
      p_token_expires_at: expiresAt, p_config: config,
    });
    if (error || !data?.success) { (window as any).toast?.(data?.error || 'Erro ao salvar.', 'error'); return; }
    closeChannelModal();
    (window as any).toast?.('Canal atualizado!', 'success');
    loadChannelConfig();
  }

  async function loadTokenAlerts() {
    const container = document.getElementById('comms-token-alerts');
    if (!container) return;
    try {
      const { data, error } = await sb.rpc('comms_check_token_expiry');
      if (error || !data?.active_alerts?.length) { container.classList.add('hidden'); return; }
      container.innerHTML = (data.active_alerts as any[]).map((a: any) => {
        const cls = a.alert_type === 'urgent' ? 'bg-red-50 border-red-200 text-red-800' : 'bg-amber-50 border-amber-200 text-amber-800';
        return `<div class="rounded-xl border ${cls} px-4 py-3 flex items-center justify-between gap-3">
          <span class="text-sm">${a.alert_type === 'urgent' ? '\u{1F6A8}' : '\u26A0\uFE0F'} ${escapeHtml(a.message)}</span>
          <button class="text-[10px] font-semibold underline opacity-70 hover:opacity-100" data-ack="${a.id}">Dispensar</button>
        </div>`;
      }).join('');
      container.classList.remove('hidden');
      container.querySelectorAll('[data-ack]').forEach(btn => {
        btn.addEventListener('click', async () => {
          await sb.rpc('comms_acknowledge_alert', { p_alert_id: (btn as HTMLElement).dataset.ack });
          loadTokenAlerts();
        });
      });
    } catch (e) { console.warn('Token alerts:', e); }
  }

  async function loadStalenessBanner() {
    const banner = document.getElementById('comms-staleness-banner');
    if (!banner) return;
    try {
      const { data, error } = await sb.rpc('comms_channel_status');
      if (error || !data?.length) return;
      const alerts: string[] = [];
      for (const ch of data as any[]) {
        const lastSync = ch.last_sync_at ? new Date(ch.last_sync_at).getTime() : 0;
        const name = ch.channel.charAt(0).toUpperCase() + ch.channel.slice(1);
        if (ch.sync_status === 'token_expired') {
          alerts.push(`<div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-red-800 text-sm">\u{1F6A8} <strong>${name}</strong>: Token expirado.</div>`);
        } else if (lastSync > 0 && Date.now() - lastSync > 7 * 86400000) {
          alerts.push(`<div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800 text-sm">\u26A0\uFE0F <strong>${name}</strong>: Dados desatualizados (${Math.floor((Date.now() - lastSync) / 86400000)}d).</div>`);
        }
      }
      if (alerts.length) { banner.innerHTML = alerts.join(''); banner.classList.remove('hidden'); }
      else banner.classList.add('hidden');
    } catch (e) { console.warn('Staleness:', e); }
  }

  // Wire modal
  document.getElementById('btn-cancel-channel')?.addEventListener('click', closeChannelModal);
  document.getElementById('btn-save-channel')?.addEventListener('click', saveChannelConfig);
  document.getElementById('channel-config-modal')?.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeChannelModal(); });

  // ── Boot ──

  function showPanel() {
    document.getElementById('comms-loading')?.classList.add('hidden');
    document.getElementById('comms-panel')?.classList.remove('hidden');

    // Analytics (everyone)
    loadKPIs();
    loadTrendChart();
    loadChannelPerformance();
    loadMetricsTable();
    loadBestTimeToPost();
    loadTopContent();

    // Admin sections (leader+ only)
    if (canManageChannels(currentMember)) {
      loadChannelConfig();
      loadTokenAlerts();
      loadStalenessBanner();
    } else {
      document.getElementById('admin-sections')?.classList.add('hidden');
    }
  }

  function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && canAccessAdminRoute(e.detail, 'admin_comms')) { currentMember = e.detail; showPanel(); }
      else { document.getElementById('comms-loading')?.classList.add('hidden'); document.getElementById('comms-denied')?.classList.remove('hidden'); }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m) {
      if (canAccessAdminRoute(m, 'admin_comms')) { currentMember = m; showPanel(); }
      else { document.getElementById('comms-loading')?.classList.add('hidden'); document.getElementById('comms-denied')?.classList.remove('hidden'); }
    }
  }

  boot();
</script>
