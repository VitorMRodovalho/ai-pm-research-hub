            ${row.areas_of_interest ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">Áreas de Interesse</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3">${esc(row.areas_of_interest)}</p></div>` : ''}
            ${row.non_pmi_experience ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">Experiência Extra-PMI</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[120px] overflow-y-auto">${esc(row.non_pmi_experience)}</p></div>` : ''}
            <div class="grid grid-cols-2 gap-3 text-[13px]">
              <div><span class="text-[var(--text-muted)] text-[11px]">Obj. Score</span><br><strong class="text-lg">${row.objective_score != null ? Number(row.objective_score).toFixed(1) : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Final Score</span><br><strong class="text-lg text-navy">${row.final_score != null ? Number(row.final_score).toFixed(1) : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Rank (Cap.)</span><br><strong>${row.rank_chapter != null ? '#' + row.rank_chapter : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Rank (Geral)</span><br><strong>${row.rank_overall != null ? '#' + row.rank_overall : '—'}</strong></div>
            </div>
            ${row.tags?.length ? `<div class="flex gap-1 flex-wrap">${row.tags.map((t: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 font-semibold">${esc(t)}</span>`).join('')}</div>` : ''}
            ${row.is_returning_member ? `<div id="returning-context-panel" data-app-id="${esc(row.id)}" class="border border-blue-100 bg-blue-50/40 rounded-xl p-3"><p class="text-[12px] text-blue-700">Carregando histórico de saída anterior...</p></div>` : ''}
          </div>
          <div class="space-y-4">
            <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">Alterar Status</h4>
            <select id="modal-status-select" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
              ${Object.entries(STATUS_LABELS).map(([k, v]) => `<option value="${k}" ${k === row.status ? 'selected' : ''}>${v}</option>`).join('')}
            </select>
            <textarea id="modal-feedback" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="Feedback / observações...">${esc(row.feedback || '')}</textarea>
            <button id="modal-save-btn" data-id="${esc(row.id)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Salvar alterações</button>
          </div>
        </div>
      </div>

      <!-- TAB: Evaluate (blind review) -->
      <div id="modal-tab-evaluate" class="hidden">
        <div id="eval-form-container" class="space-y-4">
          <p class="text-sm text-[var(--text-muted)]">Carregando formulário de avaliação...</p>
        </div>
      </div>

      <!-- TAB: Interview -->
      <div id="modal-tab-interview" class="hidden">
        <!-- S2+S8: Interview questions guide -->
        ${(currentCycle?.interview_questions || []).length ? `
        <details class="mb-4 border border-[var(--border-default)] rounded-xl">
          <summary class="px-4 py-2.5 text-[13px] font-bold text-navy cursor-pointer select-none">Roteiro de Perguntas (${(currentCycle?.interview_questions || []).length} pilares)</summary>
          <div class="px-4 pb-4 space-y-3">
            ${(currentCycle?.interview_questions || []).map((p: any) => `
              <div class="bg-[var(--surface-base)] rounded-lg p-3">
                <div class="flex items-center gap-2 mb-1.5">
                  <h5 class="text-[12px] font-bold text-[var(--text-primary)]">${esc(p.label)}</h5>
                  ${p.scored ? `<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-navy/10 text-navy">Pontuado</span>` : `<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-gray-100 text-gray-500">Contextual</span>`}
                </div>
                <ol class="list-decimal list-inside space-y-1">
                  ${(p.questions || []).map((q: string) => `<li class="text-[12px] text-[var(--text-secondary)] leading-relaxed">${esc(q)}</li>`).join('')}
                </ol>
              </div>
            `).join('')}
          </div>
        </details>` : ''}
        ${currentCycle?.interview_booking_url ? `<a href="${esc(currentCycle.interview_booking_url)}" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-navy hover:underline mb-3">Agendar via link externo &rarr;</a>` : ''}
        <div class="space-y-4">
          <h4 class="text-sm font-bold text-navy">Agendar Entrevista</h4>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] font-semibold text-[var(--text-secondary)] mb-1">Data/Hora</label>
              <input type="datetime-local" id="interview-datetime" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
            </div>
            <div>
              <label class="block text-[11px] font-semibold text-[var(--text-secondary)] mb-1">Duração (min)</label>
              <input type="number" id="interview-duration" value="30" min="15" max="120" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
            </div>
          </div>
          <button id="schedule-interview-btn" data-app-id="${esc(row.id)}" class="px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Agendar</button>
        </div>
        ${(row.status === 'interview_pending' || row.status === 'interview_scheduled') ? `
        <div class="space-y-3 mt-6 pt-4 border-t border-[var(--border-default)]">
          <div class="flex items-center gap-2">
            <h4 class="text-sm font-bold text-amber-700">Pedir Reagendamento</h4>
            ${row.interview_status === 'needs_reschedule' ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">Já solicitado</span>' : ''}
          </div>
          <p class="text-[12px] text-[var(--text-muted)]">Marca a aplicação como needs_reschedule e envia email ao candidato com novo link de booking.</p>
          ${row.interview_reschedule_reason ? `<div class="text-[12px] text-[var(--text-secondary)] bg-[var(--surface-base)] rounded-lg p-2"><strong>Motivo anterior:</strong> ${esc(row.interview_reschedule_reason)}</div>` : ''}
          <textarea id="reschedule-reason" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="Motivo (visível ao candidato)..."></textarea>
          <button id="reschedule-btn" data-app-id="${esc(row.id)}" class="px-5 py-2.5 bg-amber-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Pedir Reagendamento</button>
        </div>
        ` : ''}
      </div>

      <!-- TAB: Comunicação (p86 #5) -->
      <div id="modal-tab-comms" class="hidden">
        <div id="comms-container" class="space-y-3">
          <p class="text-sm text-[var(--text-muted)]">Carregando comunicações...</p>
        </div>
      </div>
    `;

    // #91 G4: lazy-load returning candidate offboarding context
    if (row.is_returning_member) {
      loadReturningContext(row.id);
    }

    // Modal tab switching
    body.querySelectorAll('.modal-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.modalTab;
        body.querySelectorAll('.modal-tab-btn').forEach(b => {
          const isActive = (b as HTMLElement).dataset.modalTab === tab;
          b.classList.toggle('border-navy', isActive);
          b.classList.toggle('text-navy', isActive);
          b.classList.toggle('border-transparent', !isActive);
          b.classList.toggle('text-[var(--text-secondary)]', !isActive);
        });
        ['info', 'evaluate', 'interview', 'comms'].forEach(t => {
          body.querySelector(`#modal-tab-${t}`)?.classList.toggle('hidden', t !== tab);
        });
        if (tab === 'evaluate') loadEvaluationForm(row.id);
        if (tab === 'interview') loadInterviewForm(row);
        if (tab === 'comms') loadCommunications(row.id);
      });
    });

    // Interview scheduling
    body.querySelector('#schedule-interview-btn')?.addEventListener('click', async () => {
      const dt = (body.querySelector('#interview-datetime') as HTMLInputElement)?.value;
      const dur = parseInt((body.querySelector('#interview-duration') as HTMLInputElement)?.value || '30', 10);
      if (!dt) { toast('Selecione data e hora', 'error'); return; }
      try {
        const { data, error } = await sb.rpc('schedule_interview', {
          p_application_id: row.id,
          p_interviewer_ids: [MEMBER.id],
          p_scheduled_at: new Date(dt).toISOString(),
          p_duration_minutes: dur,
        });
        if (error) throw error;
        toast('Entrevista agendada');
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) { toast(e.message || 'Erro ao agendar', 'error'); }
    });

    // p86 Wave 5d: request reschedule
    body.querySelector('#reschedule-btn')?.addEventListener('click', async () => {
      const reason = (body.querySelector('#reschedule-reason') as HTMLTextAreaElement)?.value?.trim();
      if (!reason) { toast('Informe o motivo do reagendamento', 'error'); return; }
      const btn = body.querySelector('#reschedule-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
      try {
        const { data, error } = await sb.rpc('request_interview_reschedule', {
          p_application_id: row.id,
          p_reason: reason,
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        toast('Reagendamento solicitado — email a caminho');
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao solicitar reagendamento', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Pedir Reagendamento'; }
      }
    });

    // Save handler — uses admin_update_application RPC (validates auth, seeds onboarding on approve)
    body.querySelector('#modal-save-btn')?.addEventListener('click', async () => {
      const newStatus = (body.querySelector('#modal-status-select') as HTMLSelectElement)?.value;
      const feedback = (body.querySelector('#modal-feedback') as HTMLTextAreaElement)?.value;
      const btn = body.querySelector('#modal-save-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }
      try {
        const { data, error } = await sb.rpc('admin_update_application', {
          p_application_id: row.id,
          p_data: { status: newStatus, feedback },
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        const msg = newStatus === 'approved' ? 'Candidato aprovado — onboarding iniciado' : 'Candidato atualizado';
        toast(msg);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao salvar', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Salvar alterações'; }
      }
    });

    // Save contact handler (phone/linkedin inline edit)
    body.querySelector('#save-contact-btn')?.addEventListener('click', async () => {
      const phone = (body.querySelector('#edit-phone') as HTMLInputElement)?.value?.trim();
      const linkedin = (body.querySelector('#edit-linkedin') as HTMLInputElement)?.value?.trim();
      if (!phone && !linkedin) { toast('Preencha ao menos um campo', 'error'); return; }
      try {
        const { error } = await sb.rpc('update_application_contact', {
          p_application_id: row.id,
          p_phone: phone || null,
          p_linkedin_url: linkedin || null,
        });
        if (error) throw error;
        toast('Contato atualizado');
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) { toast(e.message || 'Erro', 'error'); }
    });

    modal.classList.remove('hidden');
  }

  /* ── p86 #5: Comunicação tab — campaign sends to applicant.email ─── */
  async function loadCommunications(applicationId: string) {
    const container = document.getElementById('comms-container');
    if (!container || !sb) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando comunicações...</p>';
    try {
      const { data, error } = await sb.rpc('get_application_communications', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      const comms = data?.communications || [];
      if (comms.length === 0) {
        container.innerHTML = '<p class="text-sm text-[var(--text-muted)] py-4">Nenhuma comunicação enviada a este candidato ainda.</p>';
        return;
      }
      const catLabels: Record<string,string> = {
        onboarding: 'Onboarding', operational: 'Operacional',
        announcement: 'Comunicado', newsletter: 'Newsletter',
      };
      const catColors: Record<string,string> = {
        onboarding: 'bg-purple-50 text-purple-700',
        operational: 'bg-amber-50 text-amber-700',
        announcement: 'bg-blue-50 text-blue-700',
        newsletter: 'bg-emerald-50 text-emerald-700',
      };
      container.innerHTML = `
        <p class="text-[11px] text-[var(--text-muted)]">${comms.length} comunicação(ões) enviada(s) para <strong>${esc(data.applicant_email)}</strong></p>
        ${comms.map((c: any) => {
          const dt = c.send_sent_at ? new Date(c.send_sent_at).toLocaleString('pt-BR') : new Date(c.send_created_at).toLocaleString('pt-BR');
          const cat = c.template_category;
          const catBadge = cat ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${catColors[cat] || 'bg-gray-100 text-gray-700'}">${catLabels[cat] || cat}</span>` : '';
          const srcBadge = c.audience_source && c.audience_source !== 'manual' ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-slate-100 text-slate-700">${esc(c.audience_source)}</span>` : '';
          const statusColors: Record<string,string> = { sent: 'text-emerald-700', sending: 'text-amber-600', pending_delivery: 'text-amber-600', throttled: 'text-amber-600', failed: 'text-red-600', draft: 'text-gray-500' };
          const deliveryStatus = c.recipient_delivered ? 'Entregue' : (c.recipient_bounced_at ? 'Bounced' : c.recipient_error_message ? 'Erro' : c.send_status === 'pending_delivery' ? 'Pendente' : '—');
          const deliveryColor = c.recipient_delivered ? 'text-emerald-700' : (c.recipient_bounced_at || c.recipient_error_message) ? 'text-red-700' : 'text-amber-600';
          const openInfo = c.recipient_opened_at && !c.recipient_bot_suspected ? `<span class="text-[11px] text-[var(--text-muted)]">👁️ Aberto ${c.recipient_open_count || 1}x · primeiro em ${new Date(c.recipient_opened_at).toLocaleString('pt-BR')}</span>` : '';
          const clickInfo = c.recipient_clicked_at ? `<span class="text-[11px] text-[var(--text-muted)]">🖱️ Clicou ${c.recipient_click_count || 1}x</span>` : '';
          const bounceInfo = c.recipient_bounced_at ? `<span class="text-[11px] text-red-700">🔴 Bounce ${esc(c.recipient_bounce_type || '')} em ${new Date(c.recipient_bounced_at).toLocaleString('pt-BR')}</span>` : '';
          const errorInfo = c.recipient_error_message ? `<div class="text-[11px] text-red-700 mt-1">⚠️ ${esc(c.recipient_error_message)}</div>` : '';
          return `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <strong class="text-[13px] text-navy">${esc(c.template_name)}</strong>
              ${catBadge}
              ${srcBadge}
            </div>
            <div class="flex flex-wrap gap-x-3 gap-y-1 text-[11px] text-[var(--text-muted)]">
              <span>${dt}</span>
              <span class="${statusColors[c.send_status] || 'text-gray-500'} font-semibold">${esc(c.send_status)}</span>
              <span class="${deliveryColor} font-semibold">📬 ${deliveryStatus}</span>
              ${openInfo}
              ${clickInfo}
              ${bounceInfo}
            </div>
            ${errorInfo}
          </div>`;
        }).join('')}
      `;
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-700">Erro ao carregar comunicações: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── #91 G4: returning candidate offboarding context ─────────────── */
  async function loadReturningContext(applicationId: string) {
    const panel = document.getElementById('returning-context-panel');
    if (!panel) return;
    try {
      const { data, error } = await sb.rpc('get_application_returning_context', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      if (!data || !data.found) {
        panel.innerHTML = '<p class="text-[11px] text-[var(--text-muted)]">Sem histórico recuperável.</p>';
        return;
      }

      const ctx = data.offboarding_context;
      const member = data.matched_member;

      if (!member) {
        panel.innerHTML = `<div class="space-y-1">
          <h4 class="text-[12px] font-bold text-blue-700">Candidato Retornante</h4>
          <p class="text-[11px] text-[var(--text-secondary)]">Membro anterior não localizado por email; flag baseada em ${data.application_count || 1} aplicação(ões) prévia(s).</p>
        </div>`;
        return;
      }

      if (!ctx) {
        panel.innerHTML = `<div class="space-y-1">
          <h4 class="text-[12px] font-bold text-blue-700">Candidato Retornante</h4>
          <p class="text-[11px] text-[var(--text-secondary)]">Membro encontrado (${esc(member.name || '')}, ${esc(member.member_status || '')}), mas sem registro estruturado de saída.</p>
        </div>`;
        return;
      }

      const offboardDate = ctx.offboarded_at ? new Date(ctx.offboarded_at).toLocaleDateString('pt-BR') : '—';
      const returnInterestBadge = ctx.return_interest === true
        ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">Quer voltar</span>'
        : ctx.return_interest === false
          ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-rose-50 text-rose-700">Não declarou retorno</span>'
          : '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">Interesse não registrado</span>';
      const eligibilityBadge = ctx.preserves_return_eligibility === false
        ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-100 text-red-800" title="Categoria de saída sinaliza ineligibilidade (ex.: violação de política)">Atenção: ineligível</span>'
        : '';
      const faultBadge = ctx.is_volunteer_fault === true
        ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-800">Falta atribuída ao voluntário</span>'
        : '';

      panel.innerHTML = `
        <div class="space-y-2">
          <div class="flex items-center gap-2 flex-wrap">
            <h4 class="text-[12px] font-bold text-blue-700">Histórico de Saída Anterior</h4>
            ${returnInterestBadge}
            ${eligibilityBadge}
            ${faultBadge}
          </div>
          <div class="grid grid-cols-2 gap-2 text-[11px]">
            <div><span class="text-[var(--text-muted)]">Saída em</span><br><strong>${esc(offboardDate)}</strong></div>
            <div><span class="text-[var(--text-muted)]">Categoria</span><br><strong>${esc(ctx.reason_category_label_pt || ctx.reason_category_code || '—')}</strong></div>
            ${ctx.tribe_id_at_offboard ? `<div><span class="text-[var(--text-muted)]">Tribo na época</span><br><strong>Tribo ${ctx.tribe_id_at_offboard}</strong></div>` : ''}
            ${ctx.cycle_code_at_offboard ? `<div><span class="text-[var(--text-muted)]">Ciclo</span><br><strong>${esc(ctx.cycle_code_at_offboard)}</strong></div>` : ''}
          </div>
          ${ctx.return_window_suggestion ? `<div><span class="text-[var(--text-muted)] text-[10px]">Janela de retorno sugerida</span><br><span class="text-[12px] text-[var(--text-primary)]">${esc(ctx.return_window_suggestion)}</span></div>` : ''}
          ${ctx.lessons_learned ? `<details class="text-[11px]"><summary class="cursor-pointer font-semibold text-blue-700 hover:underline">Lições aprendidas</summary><p class="mt-1 text-[var(--text-secondary)] whitespace-pre-wrap bg-white/60 rounded p-2">${esc(ctx.lessons_learned)}</p></details>` : ''}
          ${ctx.recommendation_for_future ? `<details class="text-[11px]"><summary class="cursor-pointer font-semibold text-blue-700 hover:underline">Recomendação retrospectiva</summary><p class="mt-1 text-[var(--text-secondary)] whitespace-pre-wrap bg-white/60 rounded p-2">${esc(ctx.recommendation_for_future)}</p></details>` : ''}
          ${ctx.has_full_interview ? `<p class="text-[10px] text-[var(--text-muted)] italic">Há transcrição completa de exit interview registrada (use get_member_offboarding_record para detalhe completo).</p>` : ''}
        </div>
      `;
    } catch (e: any) {
      panel.innerHTML = `<p class="text-[11px] text-rose-700">Erro ao carregar histórico: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── evaluation form ──────────────────────────────── */
  async function loadEvaluationForm(applicationId: string) {
    const container = document.getElementById('eval-form-container');
    if (!container) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando...</p>';
    try {
      const { data, error } = await sb.rpc('get_evaluation_form', {
        p_application_id: applicationId, p_evaluation_type: 'objective',
      });
      if (error) throw error;
      if (!data) throw new Error('Sem dados');

      const criteria = data.criteria || [];
      const draft = data.draft;
      const isLocked = data.is_locked;
      const app = data.application || {};

      // Candidate context panel — quick access while evaluating
      const appRow = allRows.find(r => r.id === applicationId);
      const contactLinks = [
        appRow?.phone ? `<a href="https://wa.me/${appRow.phone.replace(/\\D/g, '')}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-semibold no-underline hover:bg-emerald-100">WhatsApp</a>` : '',
        appRow?.linkedin_url ? `<a href="${esc(appRow.linkedin_url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-blue-50 text-blue-700 text-[10px] font-semibold no-underline hover:bg-blue-100">LinkedIn</a>` : '',
        app.resume_url ? `<a href="${esc(app.resume_url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-purple-50 text-purple-700 text-[10px] font-semibold no-underline hover:bg-purple-100">CV</a>` : '',
        appRow?.member_credly_url ? `<a href="${esc(appRow.member_credly_url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-amber-50 text-amber-700 text-[10px] font-semibold no-underline hover:bg-amber-100">Credly</a>` : '',
      ].filter(Boolean).join(' ');

      const contextPanel = `
        <div class="bg-[var(--surface-base)] rounded-xl p-3 mb-4 border border-[var(--border-default)]">
          <div class="flex items-center gap-3 mb-2">
            ${appRow?.member_photo_url ? `<img src="${esc(appRow.member_photo_url)}" class="w-10 h-10 rounded-full object-cover" alt="" />` : ''}
            <div class="flex-1 min-w-0">
              <div class="text-[12px] font-bold text-navy">${esc(app.applicant_name || appRow?.applicant_name || '—')}</div>
              <div class="text-[10px] text-[var(--text-muted)]">${esc(app.chapter || '')} · ${esc(app.membership_status || 'Membership: —')}</div>
            </div>
          </div>
          ${app.certifications ? `<div class="text-[10px] mb-1.5"><span class="font-bold text-[var(--text-secondary)]">Certificações:</span> ${esc(app.certifications)}</div>` : ''}
          ${contactLinks ? `<div class="flex gap-1.5 flex-wrap">${contactLinks}</div>` : ''}
        </div>`;

      // Essay display
      const essayFields = [
        { key: 'motivation_letter', label: 'Motivação' },
        { key: 'chapter_affiliation', label: 'Capítulo / Filiação PMI' },
        { key: 'areas_of_interest', label: 'Perfil / Áreas de Interesse' },
        { key: 'academic_background', label: 'Formação / PMBOK' },
        { key: 'availability_declared', label: 'Disponibilidade' },
        { key: 'proposed_theme', label: 'Tema Proposto' },
        { key: 'leadership_experience', label: 'Experiência em Liderança' },
        { key: 'non_pmi_experience', label: 'Experiência Extra-PMI' },
      ];
      const essayItems = essayFields
        .filter(f => app[f.key])
        .map(f => `<div class="mb-2"><h5 class="text-[11px] font-bold text-[var(--text-secondary)] mb-0.5">${esc(f.label)}</h5><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-2.5 whitespace-pre-wrap max-h-[150px] overflow-y-auto">${esc(app[f.key])}</p></div>`)
        .join('');
      const essaySection = essayItems ? `
        <details open class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl mb-4">
          <summary class="px-4 py-3 text-sm font-bold text-navy cursor-pointer">Respostas do Candidato</summary>
          <div class="px-4 pb-3">${essayItems}</div>
        </details>` : '';

      // Gap 6: Check if leader role
      const isLeader = app.role_applied === 'leader';
      const committeeRole = data.committee_role || 'evaluator';
      const isObserver = committeeRole === 'observer';
      const canScore = !isLocked && !isObserver;

      container.innerHTML = `
        <div class="space-y-4">
          ${contextPanel}
          ${essaySection}
          ${isObserver ? '<div class="bg-blue-50 border border-blue-200 rounded-xl px-4 py-3 text-sm text-blue-800 font-semibold">Modo observador — você pode ver as informações mas não pode pontuar.</div>' : ''}
          ${isLocked ? '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold">Avaliação já submetida e bloqueada.</div>' : ''}
          ${!isObserver ? `<h4 class="text-sm font-bold text-navy">Avaliação Objetiva</h4>` : ''}
          ${!isObserver ? criteria.map((c: any) => {
            const cMax = c.max || 10;
            const defaultVal = draft?.scores?.[c.key] ?? Math.round(cMax / 2);
            return `
            <div class="bg-[var(--surface-base)] rounded-xl p-3">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight}, 0-${cMax})</span></label>
                <span class="eval-score-display text-sm font-bold text-navy" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
              </div>
              <input type="range" min="0" max="${cMax}" step="1" value="${defaultVal}"
                data-eval-key="${esc(c.key)}" ${!canScore ? 'disabled' : ''}
                class="w-full accent-navy" />
              ${c.guide ? `<div class="mt-1.5 text-[10px] leading-relaxed text-[var(--text-muted)] bg-[var(--surface-card)] rounded-lg px-2.5 py-1.5 border border-[var(--border-subtle)]">${c.guide.split('|').map((s: string) => '<span class="block">' + esc(s.trim()) + '</span>').join('')}</div>` : ''}
            </div>`;
          }).join('') : ''}
          ${!isObserver ? `<textarea id="eval-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas privadas (só você vê)..." ${!canScore ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>` : ''}
          ${canScore ? `<button id="submit-evaluation-btn" data-app-id="${esc(applicationId)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliação (bloqueia edição)</button>` : ''}
          ${isLocked || isObserver ? `<button id="view-results-btn" data-app-id="${esc(applicationId)}" class="w-full px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90 mt-2">Ver Resultados Consolidados</button>` : ''}
          <div id="leader-extra-container"></div>
        </div>
      `;

      // Range slider live display
      container.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.evalKey;
        slider.addEventListener('input', () => {
          const display = container.querySelector(`.eval-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Submit evaluation
      container.querySelector('#submit-evaluation-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        container.querySelectorAll<HTMLInputElement>('input[type="range"][data-eval-key]').forEach(slider => {
          if (slider.dataset.evalKey) scores[slider.dataset.evalKey] = parseInt(slider.value, 10);
        });
        const notes = (container.querySelector('#eval-notes') as HTMLTextAreaElement)?.value || '';
        const btn = container.querySelector('#submit-evaluation-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Submetendo...'; }
        try {
          const { data: result, error } = await sb.rpc('submit_evaluation', {
            p_application_id: applicationId, p_evaluation_type: 'objective',
            p_scores: scores, p_notes: notes,
          });
          if (error) throw error;
          toast(result?.all_submitted ? `Avaliacao submetida — PERT: ${result.pert_score}` : 'Avaliacao submetida');
          loadEvaluationForm(applicationId);
          loadDashboard();
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn) { btn.disabled = false; btn.textContent = 'Submeter Avaliacao'; }
        }
      });

      // Gap 1: View results button
      container.querySelector('#view-results-btn')?.addEventListener('click', () => {
        loadEvaluationResults(applicationId);
      });

      // Gap 6: Leader extra criteria
      if (isLeader) {
        loadLeaderExtraCriteria(applicationId);
      }
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar formulario')}</p>`;
    }
  }

  /* ── leader extra criteria (Gap 6) ───────────────── */
