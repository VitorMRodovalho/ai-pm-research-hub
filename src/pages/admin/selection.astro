    const body = document.getElementById('modal-body');
    if (!modal || !body || !nameEl) return;

    nameEl.textContent = row.applicant_name || '—';
    const sb2 = STATUS_BADGE[row.status] || STATUS_BADGE.submitted;
    const statusLabel = STATUS_LABELS[row.status] || row.status;

    body.innerHTML = `
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Left: Candidate info -->
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3 text-[13px]">
            <div><span class="text-[var(--text-muted)] text-[11px]">Email</span><br><strong>${esc(row.email)}</strong></div>
            <div><span class="text-[var(--text-muted)] text-[11px]">Capítulo</span><br><strong>${esc(row.chapter || '—')}</strong></div>
            <div><span class="text-[var(--text-muted)] text-[11px]">Papel</span><br><strong>${esc(ROLE_LABELS[row.role_applied] || row.role_applied)}</strong></div>
            <div><span class="text-[var(--text-muted)] text-[11px]">Status</span><br><span class="text-[11px] font-bold px-2 py-0.5 rounded-full ${sb2.bg} ${sb2.color}">${esc(statusLabel)}</span></div>
          </div>

          ${row.motivation ? `
          <div>
            <h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">Motivação</h4>
            <p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap">${esc(row.motivation)}</p>
          </div>` : ''}

          <div class="grid grid-cols-2 gap-3 text-[13px]">
            <div><span class="text-[var(--text-muted)] text-[11px]">Obj. Score</span><br><strong class="text-lg">${row.objective_score != null ? Number(row.objective_score).toFixed(1) : '—'}</strong></div>
            <div><span class="text-[var(--text-muted)] text-[11px]">Final Score</span><br><strong class="text-lg text-navy">${row.final_score != null ? Number(row.final_score).toFixed(1) : '—'}</strong></div>
            <div><span class="text-[var(--text-muted)] text-[11px]">Rank (Capítulo)</span><br><strong>${row.rank_chapter != null ? '#' + row.rank_chapter : '—'}</strong></div>
            <div><span class="text-[var(--text-muted)] text-[11px]">Rank (Geral)</span><br><strong>${row.rank_overall != null ? '#' + row.rank_overall : '—'}</strong></div>
          </div>

          ${row.tags?.length ? `<div class="flex gap-1 flex-wrap">${row.tags.map((t: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 font-semibold">${esc(t)}</span>`).join('')}</div>` : ''}
        </div>

        <!-- Right: Actions -->
        <div class="space-y-4">
          <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">Alterar Status</h4>
          <select id="modal-status-select" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
            ${Object.entries(STATUS_LABELS).map(([k, v]) => `<option value="${k}" ${k === row.status ? 'selected' : ''}>${v}</option>`).join('')}
          </select>
          <textarea id="modal-feedback" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="Feedback / observações...">${esc(row.feedback || '')}</textarea>
          <button id="modal-save-btn" data-id="${esc(row.id)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Salvar alterações</button>
        </div>
      </div>
    `;

    // Save handler — uses admin_update_application RPC (validates auth, seeds onboarding on approve)
    body.querySelector('#modal-save-btn')?.addEventListener('click', async () => {
      const newStatus = (body.querySelector('#modal-status-select') as HTMLSelectElement)?.value;
      const feedback = (body.querySelector('#modal-feedback') as HTMLTextAreaElement)?.value;
      const btn = body.querySelector('#modal-save-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }
      try {
        const { data, error } = await sb.rpc('admin_update_application', {
          p_application_id: row.id,
          p_data: { status: newStatus, feedback },
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        const msg = newStatus === 'approved' ? 'Candidato aprovado — onboarding iniciado' : 'Candidato atualizado';
        toast(msg);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao salvar', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Salvar alterações'; }
      }
    });

    modal.classList.remove('hidden');
  }

  /* ── CSV import ───────────────────────────────────── */
  function parseCSV(text: string): any[] {
    const lines = text.split('\n');
    if (lines.length < 2) return [];
    // Handle quoted fields with commas
    function parseLine(line: string): string[] {
      const fields: string[] = [];
      let field = '';
      let inQuotes = false;
      for (let i = 0; i < line.length; i++) {
        const ch = line[i];
        if (ch === '"') { inQuotes = !inQuotes; }
        else if (ch === ',' && !inQuotes) { fields.push(field.trim()); field = ''; }
        else { field += ch; }
      }
      fields.push(field.trim());
      return fields;
    }
    const headers = parseLine(lines[0]).map(h => h.trim().replace(/^\uFEFF/, ''));
    const rows: any[] = [];
    for (let i = 1; i < lines.length; i++) {
      const line = lines[i].trim();
      if (!line) continue;
      const vals = parseLine(line);
      if (vals.length < 5) continue;
      const hIdx = (name: string) => headers.findIndex(h => h.toLowerCase().includes(name.toLowerCase()));
      rows.push({
        application_id: vals[hIdx('Application ID')] || '',
        pmi_id: (vals[hIdx('PMI ID')] || '').replace(/"/g, ''),
        first_name: vals[hIdx('First Name')] || '',
        last_name: vals[hIdx('Last Name')] || '',
        email: vals[hIdx('Email')] || '',
        membership_status: vals[hIdx('Membership')] || '',
        certifications: vals[hIdx('Certification')] || '',
        state: vals[hIdx('State')] || '',
        country: vals[hIdx('Country')] || '',
        app_status: vals[hIdx('App Status')] || '',
        reason_for_applying: vals[hIdx('Reason for Applying')] || '',
        resume_url: vals[hIdx('Resume')] || '',
        areas_of_interest: vals[hIdx('Areas of Interest')] || '',
        industry: vals[hIdx('Industry')] || '',
        availability: vals[hIdx('Essay Question 4')] || '',
      });
    }
    return rows;
  }

  function renderCSVPreview(rows: any[]) {
    csvParsedRows = rows;
    const preview = document.getElementById('csv-preview');
    const summary = document.getElementById('csv-summary');
    const body = document.getElementById('csv-preview-body');
    if (!preview || !body || !summary) return;

    const submitted = rows.filter(r => r.app_status === 'Submitted' || r.app_status === 'Active' || r.app_status === 'Complete');
    const declined = rows.filter(r => r.app_status === 'OfferNotExtended' || r.app_status === 'Declined' || r.app_status === 'Withdrawn');

    summary.innerHTML = [
      { label: 'Total no CSV', value: rows.length, color: 'text-navy' },
      { label: 'Para importar', value: submitted.length, color: 'text-emerald-600' },
      { label: 'Serão ignorados', value: declined.length, color: 'text-red-600' },
    ].map(s => `<div class="bg-[var(--surface-base)] rounded-xl px-4 py-2 text-center">
      <div class="text-lg font-extrabold ${s.color}">${s.value}</div>
      <div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">${s.label}</div>
    </div>`).join('');

    body.innerHTML = rows.map(r => {
      const isSkip = ['OfferNotExtended', 'Declined', 'Withdrawn'].includes(r.app_status);
      return `<tr class="${isSkip ? 'opacity-40' : ''}">
        <td class="px-3 py-2 text-[12px] font-semibold">${esc(r.first_name)} ${esc(r.last_name)}</td>
        <td class="px-3 py-2 text-[12px] text-[var(--text-secondary)]">${esc(r.email)}</td>
        <td class="px-3 py-2 text-[12px]">${esc(r.membership_status?.substring(0, 40) || '—')}</td>
        <td class="px-3 py-2 text-[12px]"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${isSkip ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-700'}">${esc(r.app_status)}</span></td>
        <td class="px-3 py-2 text-[12px]">${isSkip ? 'Skip' : 'Importar'}</td>
      </tr>`;
    }).join('');

    document.getElementById('csv-dropzone')?.classList.add('hidden');
    preview.classList.remove('hidden');
    document.getElementById('csv-result')?.classList.add('hidden');
  }

  async function executeImport() {
    if (!csvParsedRows.length || !currentCycleId) return;
    const opportunityId = (document.getElementById('import-opportunity') as HTMLSelectElement)?.value || '64967';
    const role = (document.getElementById('import-role') as HTMLSelectElement)?.value || 'researcher';
    const btn = document.getElementById('csv-import-btn') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Importando...'; }
    try {
      const { data, error } = await sb.rpc('import_vep_applications', {
        p_cycle_id: currentCycleId,
        p_opportunity_id: opportunityId,
        p_rows: csvParsedRows,
        p_role: role,
      });
      if (error) throw error;
      const result = document.getElementById('csv-result');
      if (result) {
        result.classList.remove('hidden');
        result.innerHTML = `
          <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 space-y-2">
            <h3 class="font-bold text-emerald-800">Import concluído</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-center text-[13px]">
              <div><div class="text-lg font-extrabold text-emerald-700">${data.imported}</div><div class="text-[.6rem] text-emerald-600">Importados</div></div>
              <div><div class="text-lg font-extrabold text-amber-600">${data.skipped_dedup}</div><div class="text-[.6rem] text-amber-500">Duplicados</div></div>
              <div><div class="text-lg font-extrabold text-red-600">${data.skipped_declined}</div><div class="text-[.6rem] text-red-500">Ignorados</div></div>
              <div><div class="text-lg font-extrabold text-blue-600">${data.returning_members}</div><div class="text-[.6rem] text-blue-500">Retornantes</div></div>
            </div>
          </div>`;
      }
      document.getElementById('csv-preview')?.classList.add('hidden');
      toast(`${data.imported} candidatos importados`);
      loadDashboard();
    } catch (e: any) {
      toast(e.message || 'Erro no import', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Importar candidatos'; }
    }
  }

  /* ── committee ────────────────────────────────────── */
  async function loadCommittee() {
    if (!currentCycleId) return;
    const { data } = await sb.from('selection_committee')
      .select('id, role, can_interview, member_id, members!inner(name, operational_role)')
      .eq('cycle_id', currentCycleId);
    const el = document.getElementById('committee-list');
    if (!el) return;
    if (!data?.length) {
      el.innerHTML = '<p class="text-sm text-[var(--text-muted)] py-4">Nenhum membro no comitê. Adicione membros para iniciar a avaliação.</p>';
      return;
    }
    el.innerHTML = data.map((c: any) => `
      <div class="flex items-center justify-between bg-[var(--surface-base)] rounded-xl px-4 py-3">
        <div>
          <span class="font-semibold text-sm text-[var(--text-primary)]">${esc(c.members?.name || '—')}</span>
          <span class="text-[11px] text-[var(--text-muted)] ml-2">${esc(c.members?.operational_role || '')}</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${c.role === 'lead' ? 'bg-purple-50 text-purple-700' : 'bg-blue-50 text-blue-700'}">${c.role}</span>
          ${c.can_interview ? '<span class="text-[10px] text-emerald-600">pode entrevistar</span>' : ''}
          <button class="text-[11px] text-red-500 hover:underline cursor-pointer bg-transparent border-0 p-0" data-action="remove-committee" data-member-id="${esc(c.member_id)}">remover</button>
        </div>
      </div>
    `).join('');
  }

  async function addCommitteeMember() {
    if (!currentCycleId) return;
    const name = prompt('Nome do membro a adicionar ao comitê:');
    if (!name) return;
    const { data: members } = await sb.from('members').select('id, name, operational_role')
      .ilike('name', `%${name}%`).eq('is_active', true).limit(5);
    if (!members?.length) { toast('Membro não encontrado', 'error'); return; }
    const member = members.length === 1 ? members[0] :
      members[parseInt(prompt(`Encontrados:\n${members.map((m: any, i: number) => `${i}: ${m.name} (${m.operational_role})`).join('\n')}\n\nDigite o número:`) || '0', 10)];
    if (!member) return;
    const role = prompt('Papel (evaluator / lead / observer):', 'evaluator') || 'evaluator';
    const { data, error } = await sb.rpc('manage_selection_committee', {
      p_cycle_id: currentCycleId, p_action: 'add', p_member_id: member.id, p_role: role,
    });
    if (error) { toast(error.message, 'error'); return; }
    toast(`${member.name} adicionado ao comitê`);
    loadCommittee();
  }

  async function removeCommitteeMember(memberId: string) {
    if (!currentCycleId || !confirm('Remover este membro do comitê?')) return;
    const { error } = await sb.rpc('manage_selection_committee', {
      p_cycle_id: currentCycleId, p_action: 'remove', p_member_id: memberId,
    });
    if (error) { toast(error.message, 'error'); return; }
    toast('Membro removido do comitê');
    loadCommittee();
  }

  /* ── event binding ────────────────────────────────── */
  let searchTimeout: any = null;

  function bindEvents() {
    // Tabs
    document.querySelectorAll('.sel-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.selTab;
        if (tab) {
          switchTab(tab);
          if (tab === 'committee') loadCommittee();
        }
      });
    });

    // Cycle picker
    document.getElementById('sel-cycle-picker')?.addEventListener('change', (e) => {
      const newId = (e.target as HTMLSelectElement).value;
      if (newId && newId !== currentCycleId) {
        currentCycleId = newId;
        // Reload with specific cycle — need to use cycle_code
        const cycle = allCycles.find((c: any) => c.id === newId);
        if (cycle) {
          sb.rpc('get_selection_dashboard', { p_cycle_code: cycle.cycle_code }).then(({ data }: any) => {
            if (data) {
              allRows = data.applications || [];
              const badge = document.getElementById('sel-cycle-badge');
              if (badge && data.cycle) {
                const cs = CYCLE_STATUS_COLORS[data.cycle.status] || CYCLE_STATUS_COLORS.draft;
                badge.className = `text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase ${cs.bg} ${cs.color}`;
                badge.textContent = data.cycle.status.toUpperCase();
              }
              populateChapterDropdown();
              applyFilters();
            }
          });
        }
      }
    });

    // Role toggle
    document.getElementById('sel-role-toggle')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.sel-role-btn');
      if (!btn) return;
      filterRole = btn.dataset.role || 'all';
      document.querySelectorAll('.sel-role-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.role === filterRole;
        b.classList.toggle('bg-navy', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-[var(--surface-card)]', !isActive);
        b.classList.toggle('text-[var(--text-secondary)]', !isActive);
      });
      applyFilters();
    });

    // Dropdowns
    document.getElementById('sel-chapter')?.addEventListener('change', (e) => { filterChapter = (e.target as HTMLSelectElement).value; applyFilters(); });
    document.getElementById('sel-status')?.addEventListener('change', (e) => { filterStatus = (e.target as HTMLSelectElement).value; applyFilters(); });

    // Search
    document.getElementById('sel-search')?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => { filterSearch = ((e.target as HTMLInputElement).value || '').trim(); applyFilters(); }, 300);
    });

    // Column sorting
    document.querySelectorAll<HTMLElement>('[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort!;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = col === 'applicant_name'; }
        applyFilters();
      });
    });

    // Delegated click actions
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      const action = target.dataset.action;
      if (action === 'view-applicant' && target.dataset.id) { openApplicantModal(target.dataset.id); }
      else if (action === 'remove-committee' && target.dataset.memberId) { removeCommitteeMember(target.dataset.memberId); }
    });

    // Committee add button
    document.getElementById('committee-add-btn')?.addEventListener('click', addCommitteeMember);

    // Modal close
    document.getElementById('modal-close')?.addEventListener('click', () => {
      document.getElementById('applicant-modal')?.classList.add('hidden');
    });
    document.getElementById('applicant-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) (e.target as HTMLElement).classList.add('hidden');
    });

    // CSV file input
    const dropzone = document.getElementById('csv-dropzone');
    const fileInput = document.getElementById('csv-file-input') as HTMLInputElement;
    dropzone?.addEventListener('click', () => fileInput?.click());
    dropzone?.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('dragleave', () => { dropzone.classList.remove('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-navy', 'bg-blue-50/30');
      const file = e.dataTransfer?.files[0];
      if (file) handleCSVFile(file);
    });
    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleCSVFile(file);
    });
    document.getElementById('csv-import-btn')?.addEventListener('click', executeImport);
    document.getElementById('csv-cancel-btn')?.addEventListener('click', () => {
      document.getElementById('csv-preview')?.classList.add('hidden');
      document.getElementById('csv-dropzone')?.classList.remove('hidden');
      csvParsedRows = [];
    });
  }

  function handleCSVFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target?.result as string;
      if (!text) return;
      const rows = parseCSV(text);
      if (rows.length === 0) { toast('CSV vazio ou formato inválido', 'error'); return; }
      renderCSVPreview(rows);
    };
    reader.readAsText(file, 'UTF-8');
  }

  /* ── permission gate ──────────────────────────────── */
  function applyGate(m: any) {
    if (m && canAccessAdminRoute(m, 'admin_selection')) {
      showPanel();
      loadCycles().then(() => loadDashboard());
    } else {
      showDenied();
    }
  }

  /* ── boot ─────────────────────────────────────────── */
  let bootRetries = 0;
  async function boot() {
    sb = (window as any).navGetSb?.();
    const m = (window as any).navGetMember?.();
    if (!sb || !m) {
      bootRetries += 1;
      if (bootRetries >= 20) { showDenied(); return; }
      setTimeout(boot, 200);
      return;
    }
    MEMBER = m;
    bindEvents();
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);
    applyGate(MEMBER);
  }

  boot();
</script>
