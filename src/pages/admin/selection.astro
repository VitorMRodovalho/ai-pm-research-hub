    dropzone?.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('dragleave', () => { dropzone.classList.remove('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-navy', 'bg-blue-50/30');
      const file = e.dataTransfer?.files[0];
      if (file) handleCSVFile(file);
    });
    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleCSVFile(file);
    });
    document.getElementById('csv-import-btn')?.addEventListener('click', executeImport);
    document.getElementById('csv-cancel-btn')?.addEventListener('click', () => {
      document.getElementById('csv-preview')?.classList.add('hidden');
      document.getElementById('csv-dropzone')?.classList.remove('hidden');
      csvParsedRows = [];
    });

    // p151 C: JSON consolidado import handlers.
    // Wrapped in try/catch — initJsonImport must NEVER block bindEvents().
    // If anything goes wrong here, applyGate() must still run so the
    // candidate list loads. Sediment p151: regression caused empty table.
    try { initJsonImport(); } catch (e) { console.warn('[p151 C] initJsonImport failed (non-fatal):', e); }
  }

  // ── p151 C: VEP JSON import (server-side proxy → worker /ingest) ─────
  let pendingJsonPayload: any = null;
  let pendingDryRunSummary: any = null;

  function initJsonImport() {
    const dz = document.getElementById('json-dropzone');
    const fi = document.getElementById('json-file-input') as HTMLInputElement | null;
    if (!dz || !fi) return;
    dz.addEventListener('click', () => fi.click());
    dz.addEventListener('dragover', (e) => { e.preventDefault(); dz.classList.add('border-navy', 'bg-purple-50/30'); });
    dz.addEventListener('dragleave', () => dz.classList.remove('border-navy', 'bg-purple-50/30'));
    dz.addEventListener('drop', (e: any) => {
      e.preventDefault();
      dz.classList.remove('border-navy', 'bg-purple-50/30');
      const file = e.dataTransfer?.files?.[0];
      if (file) handleJsonFile(file);
    });
    fi.addEventListener('change', () => {
      const file = fi.files?.[0];
      if (file) handleJsonFile(file);
    });
    document.getElementById('json-dry-run-btn')?.addEventListener('click', runJsonDryRun);
    document.getElementById('json-apply-btn')?.addEventListener('click', runJsonApply);
  }

  async function handleJsonFile(file: File) {
    const sr = document.getElementById('json-schema-result')!;
    const dryBtn = document.getElementById('json-dry-run-btn') as HTMLButtonElement;
    const applyBtn = document.getElementById('json-apply-btn') as HTMLButtonElement;
    try {
      const text = await file.text();
      const parsed = JSON.parse(text);
      const v = validateConsolidatedJsonShape(parsed);
      if (!v.ok) {
        sr.classList.remove('hidden');
        sr.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-lg p-2 text-red-800">❌ ${esc(v.error!)}</div>`;
        dryBtn.disabled = true; applyBtn.disabled = true; pendingJsonPayload = null;
        return;
      }
      pendingJsonPayload = parsed;
      pendingDryRunSummary = null;
      sr.classList.remove('hidden');
      sr.innerHTML = `<div class="bg-emerald-50 border border-emerald-200 rounded-lg p-2 text-emerald-800">
        ✓ ${esc(file.name)} — ${parsed.applications?.length ?? 0} applications · ${parsed.opportunities?.length ?? 0} opportunities · ${parsed.questionResponses?.length ?? 0} QRs · ${parsed.serviceHistory?.length ?? 0} history
      </div>`;
      dryBtn.disabled = false; applyBtn.disabled = true;
      document.getElementById('json-preview')?.classList.add('hidden');
      document.getElementById('json-apply-result')?.classList.add('hidden');
    } catch (e: any) {
      sr.classList.remove('hidden');
      sr.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-lg p-2 text-red-800">❌ JSON inválido: ${esc(e.message)}</div>`;
      dryBtn.disabled = true; applyBtn.disabled = true; pendingJsonPayload = null;
    }
  }

  function validateConsolidatedJsonShape(obj: any): { ok: boolean; error?: string } {
    if (!obj || typeof obj !== 'object') return { ok: false, error: 'root deve ser object JSON' };
    if (!Array.isArray(obj.applications)) return { ok: false, error: 'falta applications array' };
    if (obj.applications.length === 0) return { ok: false, error: 'applications array vazio' };
    if (obj.opportunities && !Array.isArray(obj.opportunities)) return { ok: false, error: 'opportunities deve ser array' };
    if (obj.questionResponses && !Array.isArray(obj.questionResponses)) return { ok: false, error: 'questionResponses deve ser array' };
    if (obj.serviceHistory && !Array.isArray(obj.serviceHistory)) return { ok: false, error: 'serviceHistory deve ser array' };
    const a = obj.applications[0];
    if (!a.applicationId) return { ok: false, error: 'applications[0].applicationId ausente' };
    if (!a._opportunityId) return { ok: false, error: 'applications[0]._opportunityId ausente (campo synthetic do script extract)' };
    return { ok: true };
  }

  async function callImportEndpoint(payload: any, dryRun: boolean): Promise<any> {
    if (!sb) throw new Error('Supabase client não inicializado');
    const { data: session } = await sb.auth.getSession();
    const jwt = session?.session?.access_token;
    if (!jwt) throw new Error('Sem sessão Supabase — faça login novamente');
    const resp = await fetch('/api/admin/import-pmi-vep-json', {
      method: 'POST',
      headers: { 'content-type': 'application/json', 'Authorization': `Bearer ${jwt}` },
      body: JSON.stringify({ payload, dry_run: dryRun })
    });
    const data = await resp.json();
    if (!resp.ok) throw new Error(data.error + (data.detail ? `: ${data.detail}` : '') + (data.message ? ` — ${data.message}` : ''));
    return data;
  }

  async function runJsonDryRun() {
    if (!pendingJsonPayload) return;
    const btn = document.getElementById('json-dry-run-btn') as HTMLButtonElement;
    btn.disabled = true; const old = btn.textContent; btn.textContent = '⏳ Calculando...';
    try {
      const data = await callImportEndpoint(pendingJsonPayload, true);
      pendingDryRunSummary = data;
      renderJsonDryRunPreview(data);
      (document.getElementById('json-apply-btn') as HTMLButtonElement).disabled = false;
    } catch (e: any) {
      toast(`Erro no preview: ${e.message}`, 'error');
    } finally {
      btn.disabled = false; btn.textContent = old;
    }
  }

  async function runJsonApply() {
    if (!pendingJsonPayload || !pendingDryRunSummary) return;
    const ins = pendingDryRunSummary.will_insert?.length ?? 0;
    const upd = pendingDryRunSummary.will_update?.length ?? 0;
    const ccr = pendingDryRunSummary.will_cross_cycle_refresh?.length ?? 0; // p153 hotfix7
    const skp = pendingDryRunSummary.will_skip?.length ?? 0;
    const ccrPart = ccr > 0 ? ` + ${ccr} CROSS-CYCLE REFRESH` : '';
    if (!confirm(`Aplicar import: ${ins} NEW + ${upd} UPDATE${ccrPart} + ${skp} SKIP. Confirma?`)) return;
    const btn = document.getElementById('json-apply-btn') as HTMLButtonElement;
    btn.disabled = true; const old = btn.textContent; btn.textContent = '⏳ Aplicando...';
    try {
      const data = await callImportEndpoint(pendingJsonPayload, false);
      renderJsonApplyResult(data);
      pendingJsonPayload = null; pendingDryRunSummary = null;
      (document.getElementById('json-file-input') as HTMLInputElement).value = '';
      document.getElementById('json-schema-result')?.classList.add('hidden');
      document.getElementById('json-preview')?.classList.add('hidden');
      (document.getElementById('json-dry-run-btn') as HTMLButtonElement).disabled = true;
      btn.disabled = true;
    } catch (e: any) {
      toast(`Erro no apply: ${e.message}`, 'error');
      btn.disabled = false;
    } finally {
      btn.textContent = old;
    }
  }

  function renderJsonDryRunPreview(d: any) {
    const sumEl = document.getElementById('json-preview-summary');
    const detEl = document.getElementById('json-preview-details');
    if (!sumEl || !detEl) return;
    const wi = d.will_insert?.length ?? 0;
    const wu = d.will_update?.length ?? 0;
    const wcc = d.will_cross_cycle_refresh?.length ?? 0; // p153 hotfix7
    const ws = d.will_skip?.length ?? 0;
    sumEl.innerHTML = `
      <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-3 text-center"><div class="text-2xl font-extrabold text-emerald-800">${wi}</div><div class="text-[10px] text-emerald-700 uppercase font-semibold">WILL_INSERT</div></div>
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 text-center"><div class="text-2xl font-extrabold text-blue-800">${wu}</div><div class="text-[10px] text-blue-700 uppercase font-semibold">WILL_UPDATE</div></div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-3 text-center" title="p153 hotfix7 — rows em ciclos anteriores que vão receber PARTIAL refresh (resume_url + profile + vep_status). Decisão histórica preservada (cycle_id/status/role_applied)."><div class="text-2xl font-extrabold text-purple-800">${wcc}</div><div class="text-[10px] text-purple-700 uppercase font-semibold">CROSS-CYCLE</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 text-center"><div class="text-2xl font-extrabold text-gray-700">${ws}</div><div class="text-[10px] text-gray-600 uppercase font-semibold">WILL_SKIP</div></div>
    `;
    const wiRows = (d.will_insert ?? []).map((r: any) => `<div class="py-1 border-b border-gray-100">➕ <strong>${esc(r.applicant_name)}</strong> · ${esc(r.email)} · opp ${esc(r.opportunity_id)} · ${esc(r.chapter ?? '—')}</div>`).join('');
    const wuRows = (d.will_update ?? []).map((r: any) => `<div class="py-1 border-b border-gray-100">🔄 <strong>${esc(r.applicant_name)}</strong> · status=${esc(r.existing_status)} · cycle=${esc(r.existing_cycle_id?.slice(0,8))}…</div>`).join('');
    const wccRows = (d.will_cross_cycle_refresh ?? []).map((r: any) => `<div class="py-1 border-b border-gray-100">♻️ <strong>${esc(r.applicant_name)}</strong> · status=${esc(r.existing_status)} (preservado) · cycle=${esc(r.existing_cycle_id?.slice(0,8))}… → partial refresh</div>`).join('');
    const wsRows = (d.will_skip ?? []).map((r: any) => `<div class="py-1 border-b border-gray-100">⏭ ${esc(r.ref)}: ${esc(r.reason)}</div>`).join('');
    detEl.innerHTML = `${wiRows}${wuRows}${wccRows}${wsRows}` || '<p class="text-[var(--text-muted)] italic">Sem detalhes.</p>';
    document.getElementById('json-preview')?.classList.remove('hidden');
  }

  function renderJsonApplyResult(d: any) {
    const el = document.getElementById('json-apply-result');
    if (!el) return;
    const errs = d.errors?.length ?? 0;
    el.classList.remove('hidden');
    // p153 hotfix7: surface applications_cross_cycle_refreshed so the PM can see
    // the 65 prior-cycle rows that got partial-refreshed (resume_url SAS + profile
    // data) instead of silently disappearing from the new/updated/skipped totals.
    const crossCycle = d.applications_cross_cycle_refreshed ?? 0;
    el.innerHTML = `
      <div class="font-bold text-emerald-900 mb-1">✓ Import concluído</div>
      <div class="grid grid-cols-2 gap-2 text-[11px] text-emerald-800">
        <div>processed: <strong>${d.applications_processed ?? 0}</strong></div>
        <div>new: <strong>${d.applications_new ?? 0}</strong></div>
        <div>updated (mesmo ciclo): <strong>${d.applications_updated ?? 0}</strong></div>
        <div title="p153 hotfix7 — refresh parcial em rows de ciclos anteriores (resume_url + profile + vep_status), preservando cycle_id/status/role_applied/motivation">cross-cycle refreshed: <strong>${crossCycle}</strong></div>
        <div>skipped: <strong>${d.applications_skipped ?? 0}</strong></div>
        <div>welcome dispatched: <strong>${d.welcome_dispatched ?? 0}</strong></div>
        <div>service_history rows: <strong>${d.service_history_inserted ?? 0}</strong></div>
        <div>phase_b processed: <strong>${d.phase_b_processed ?? 0}</strong></div>
        <div>pmi_chapter_memberships: <strong>${d.pmi_chapter_memberships_upserted ?? 0}</strong></div>
      </div>
      ${errs > 0 ? `<div class="mt-2 text-[11px] text-amber-700"><strong>${errs} erro(s)</strong> — ver detalhes no cron_run_log do worker.</div>` : ''}
    `;
  }

  function handleCSVFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target?.result as string;
      if (!text) return;
      const rows = parseCSV(text);
      if (rows.length === 0) { toast('CSV vazio ou formato inválido', 'error'); return; }
      renderCSVPreview(rows);
    };
    reader.readAsText(file, 'UTF-8');
  }

  /* ── permission gate ──────────────────────────────── */
  function applyGate(m: any) {
    if (m && canAccessAdminRoute(m, 'admin_selection')) {
      showPanel();
      loadCycles().then(() => loadDashboard());
    } else {
      showDenied();
    }
  }

  /* ── boot ─────────────────────────────────────────── */
  let bootRetries = 0;
  async function boot() {
    sb = (window as any).navGetSb?.();
    const m = (window as any).navGetMember?.();
    if (!sb || !m) {
      bootRetries += 1;
      if (bootRetries >= 20) { showDenied(); return; }
      setTimeout(boot, 200);
      return;
    }
    MEMBER = m;
    bindEvents();
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);
    applyGate(MEMBER);
  }

  boot();
</script>
