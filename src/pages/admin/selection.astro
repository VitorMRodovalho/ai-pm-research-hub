    pmiProfileSiblings: t('admin.selection.modal.pmiProfileSiblings', lang),
    pmiProfileSiblingsHint: t('admin.selection.modal.pmiProfileSiblingsHint', lang),
    // p152 W2.5: chapter discrepancy + Phase B summary inline panel
    chapterDiscrepancyTitle: t('admin.selection.modal.chapterDiscrepancyTitle', lang),
    chapterDiscrepancyForm: t('admin.selection.modal.chapterDiscrepancyForm', lang),
    chapterDiscrepancyCanonical: t('admin.selection.modal.chapterDiscrepancyCanonical', lang),
    phaseBSummaryTitle: t('admin.selection.modal.phaseBSummaryTitle', lang),
    phaseBMemberStatus: t('admin.selection.modal.phaseBMemberStatus', lang),
    phaseBChapterCanonical: t('admin.selection.modal.phaseBChapterCanonical', lang),
