  /**
   * Trigger Sonnet 4.6 triage via pmi-ai-triage EF.
   * Refreshes evaluation form on success to show new score.
   */
  async function triggerTriage(applicationId: string, btn: HTMLButtonElement | null) {
    const oldText = btn?.textContent ?? '';
    if (btn) { btn.disabled = true; btn.textContent = '⏳ Rodando…'; }
    try {
      const { data, error } = await sb.functions.invoke('pmi-ai-triage', {
        body: { application_id: applicationId, triggered_by: 'admin_inline_panel' },
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error + (data.detail ? ` (${data.detail})` : ''));
      if (!data?.success) throw new Error('Resposta inesperada do EF');
      toast(`Triage gerado: ${data.score}/10 (${data.confidence})`);
      loadEvaluationForm(applicationId);
      loadDashboard();
    } catch (e: any) {
      toast(e.message || 'Erro ao rodar triage', 'error');
      if (btn) { btn.disabled = false; btn.textContent = oldText; }
    }
  }

  /**
   * Trigger Haiku 4.5 briefing via pmi-ai-briefing EF.
   * Persists to last_briefing_jsonb. Auto-switches to interview tab on success.
   */
  async function triggerBriefing(applicationId: string, btn: HTMLButtonElement | null) {
    const oldText = btn?.textContent ?? '';
    if (btn) { btn.disabled = true; btn.textContent = '⏳ Gerando…'; }
    try {
      const { data, error } = await sb.functions.invoke('pmi-ai-briefing', {
        body: { application_id: applicationId },
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error + (data.detail ? ` (${data.detail})` : ''));
      if (!data?.success) throw new Error('Resposta inesperada do EF');
      toast('Briefing pronto — abrindo tab Entrevista');
      // Auto-switch to interview tab (Opção C — briefing vive lá)
      const modalBody = document.getElementById('modal-body');
      const interviewBtn = modalBody?.querySelector('[data-modal-tab="interview"]') as HTMLButtonElement | null;
      interviewBtn?.click();
    } catch (e: any) {
      toast(e.message || 'Erro ao gerar briefing', 'error');
      if (btn) { btn.disabled = false; btn.textContent = oldText; }
    }
  }

  /**
   * Render the briefing card for the interview tab.
   * Reads last_briefing_jsonb from the application object (extended in get_evaluation_form).
   * If no briefing yet → CTA to generate. If exists → expanded card with questions/focus/notes.
   */
  function renderBriefingCard(applicationId: string, app: any): string {
    const briefing = app?.last_briefing_jsonb;
    const generatedAt = app?.last_briefing_at;
    const model = app?.last_briefing_model || 'claude-haiku-4-5';
    const hasConsent = !!app?.consent_ai_analysis_at;

    if (!briefing) {
      // No briefing yet — placeholder + CTA (only if consent exists)
      const cta = hasConsent
        ? `<button class="briefing-generate-btn px-3 py-1.5 bg-purple-600 text-white rounded-lg text-[12px] font-bold cursor-pointer border-0 hover:opacity-90" data-app-id="${esc(applicationId)}">📝 Gerar briefing entrevista (Haiku 4.5)</button>`
        : `<span class="text-[11px] text-[var(--text-muted)] italic">Briefing AI indisponível — sem consent.</span>`;
      return `<div class="bg-purple-50/40 border border-purple-200 rounded-xl p-3 mb-3">
        <div class="flex items-center justify-between flex-wrap gap-2">
          <div>
            <h4 class="text-[12px] font-bold text-purple-700">📋 Briefing entrevista (Haiku 4.5)</h4>
            <p class="text-[10px] text-[var(--text-muted)] mt-0.5">Gere 3 perguntas personalizadas + áreas de foco + notas de preparação. ~1-3s.</p>
          </div>
          ${cta}
        </div>
      </div>`;
    }

    // Briefing exists — render full card
    const questions = Array.isArray(briefing.personalized_questions) ? briefing.personalized_questions : [];
    const focusAreas = Array.isArray(briefing.interview_focus_areas) ? briefing.interview_focus_areas : [];
    const prepNotes = briefing.preparation_notes || '';
    const dateStr = generatedAt ? new Date(generatedAt).toLocaleString('pt-BR') : '—';

    const questionsHtml = questions.map((q: any, i: number) => `
      <div class="bg-[var(--surface-card)] rounded-lg p-3 border border-purple-100">
        <div class="flex items-start gap-2">
          <span class="text-[11px] font-bold text-purple-700 shrink-0">${i + 1}.</span>
          <div class="flex-1">
            <p class="text-[13px] font-semibold text-[var(--text-primary)] mb-1">${esc(q.question || '')}</p>
            ${q.rationale ? `<p class="text-[11px] text-[var(--text-muted)] italic">→ ${esc(q.rationale)}</p>` : ''}
          </div>
        </div>
      </div>`).join('');

    const focusHtml = focusAreas.length
      ? `<ul class="space-y-1 mt-2">${focusAreas.map((f: string) => `<li class="text-[12px] text-[var(--text-primary)] flex items-start gap-1.5"><span class="text-purple-700 shrink-0">▸</span><span>${esc(f)}</span></li>`).join('')}</ul>`
      : '<p class="text-[11px] text-[var(--text-muted)] italic mt-1">—</p>';

    return `<details open class="bg-purple-50/30 border border-purple-200 rounded-xl mb-3" id="briefing-card">
      <summary class="px-4 py-2.5 cursor-pointer select-none flex items-center justify-between gap-2 flex-wrap">
        <div class="flex items-center gap-2">
          <span class="text-[12px] font-bold text-purple-700">📋 Briefing entrevista</span>
          <span class="text-[10px] text-[var(--text-muted)]">${esc(model)} · ${dateStr}</span>
        </div>
        <div class="flex gap-2">
          <button class="briefing-copy-btn text-[10px] px-2 py-1 rounded bg-[var(--surface-card)] text-purple-700 font-semibold hover:bg-purple-100 cursor-pointer border border-purple-300" data-app-id="${esc(applicationId)}" title="Copiar para clipboard">📋 Copiar</button>
          <button class="briefing-regenerate-btn text-[10px] px-2 py-1 rounded bg-[var(--surface-card)] text-purple-700 font-semibold hover:bg-purple-100 cursor-pointer border border-purple-300" data-app-id="${esc(applicationId)}">↻ Regenerar</button>
        </div>
      </summary>
      <div class="px-4 pb-4 border-t border-purple-200 pt-3 space-y-3">
        ${prepNotes ? `<div><h5 class="text-[11px] font-bold text-purple-700 mb-1">Notas de preparação</h5><p class="text-[12px] text-[var(--text-primary)] bg-[var(--surface-card)] rounded p-2.5 leading-relaxed">${esc(prepNotes)}</p></div>` : ''}
        <div>
          <h5 class="text-[11px] font-bold text-purple-700 mb-1">Perguntas personalizadas (${questions.length})</h5>
          <div class="space-y-2">${questionsHtml}</div>
        </div>
        <div>
          <h5 class="text-[11px] font-bold text-purple-700 mb-1">Áreas de atenção (${focusAreas.length})</h5>
          ${focusHtml}
        </div>
        <p class="text-[10px] text-[var(--text-muted)] italic">⚠️ Sugestão AI — ajuste conforme dinâmica real da entrevista.</p>
      </div>
    </details>`;
  }

  /**
   * Wire up briefing card buttons (generate / regenerate / copy) in the interview tab.
   */
  function wireUpInterviewBriefing(container: Element, applicationId: string) {
    container.querySelector('.briefing-generate-btn')?.addEventListener('click', (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      triggerBriefing(applicationId, ev.currentTarget as HTMLButtonElement);
    });
    container.querySelector('.briefing-regenerate-btn')?.addEventListener('click', (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      triggerBriefing(applicationId, ev.currentTarget as HTMLButtonElement);
    });
    container.querySelector('.briefing-copy-btn')?.addEventListener('click', async (ev) => {
      ev.preventDefault();
      ev.stopPropagation();
      const card = container.querySelector('#briefing-card');
      if (!card) return;
      const text = (card as HTMLElement).innerText.trim();
      try {
        await navigator.clipboard.writeText(text);
        toast('Briefing copiado');
      } catch { toast('Erro ao copiar', 'error'); }
    });
  }

  /* ── evaluation form ──────────────────────────────── */
  async function loadEvaluationForm(applicationId: string) {
    const container = document.getElementById('eval-form-container');
    if (!container) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando...</p>';
    try {
      // p109 Onda 4 Fase 2: fetch validations in parallel for inline thumbs state
      const [formRes, validationsRes] = await Promise.all([
        sb.rpc('get_evaluation_form', { p_application_id: applicationId, p_evaluation_type: 'objective' }),
        sb.rpc('list_my_ai_validations', { p_application_id: applicationId }),
      ]);
      if (formRes.error) throw formRes.error;
      const data = formRes.data;
      if (!data) throw new Error('Sem dados');
      const validations = Array.isArray(validationsRes?.data?.validations) ? validationsRes.data.validations : [];

      const criteria = data.criteria || [];
      const draft = data.draft;
      const isLocked = data.is_locked;
      const app = data.application || {};

      // Candidate context panel — quick access while evaluating
      const appRow = allRows.find(r => r.id === applicationId);
      const contactLinks = [
        appRow?.phone ? `<a href="https://wa.me/${appRow.phone.replace(/\\D/g, '')}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-semibold no-underline hover:bg-emerald-100">WhatsApp</a>` : '',
        appRow?.linkedin_url ? `<a href="${esc(appRow.linkedin_url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-blue-50 text-blue-700 text-[10px] font-semibold no-underline hover:bg-blue-100">LinkedIn</a>` : '',
        app.resume_url ? `<a href="${esc(app.resume_url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-purple-50 text-purple-700 text-[10px] font-semibold no-underline hover:bg-purple-100">CV</a>` : '',
        appRow?.member_credly_url ? `<a href="${esc(appRow.member_credly_url)}" target="_blank" rel="noopener" class="px-2 py-1 rounded-lg bg-amber-50 text-amber-700 text-[10px] font-semibold no-underline hover:bg-amber-100">Credly</a>` : '',
      ].filter(Boolean).join(' ');

      const contextPanel = `
        <div class="bg-[var(--surface-base)] rounded-xl p-3 mb-4 border border-[var(--border-default)]">
          <div class="flex items-center gap-3 mb-2">
            ${appRow?.member_photo_url ? `<img src="${esc(appRow.member_photo_url)}" class="w-10 h-10 rounded-full object-cover" alt="" />` : ''}
            <div class="flex-1 min-w-0">
              <div class="text-[12px] font-bold text-navy">${esc(app.applicant_name || appRow?.applicant_name || '—')}</div>
              <div class="text-[10px] text-[var(--text-muted)]">${esc(app.chapter || '')} · ${esc(app.membership_status || 'Membership: —')}</div>
            </div>
          </div>
          ${app.certifications ? `<div class="text-[10px] mb-1.5"><span class="font-bold text-[var(--text-secondary)]">Certificações:</span> ${esc(app.certifications)}</div>` : ''}
          ${contactLinks ? `<div class="flex gap-1.5 flex-wrap">${contactLinks}</div>` : ''}
        </div>`;

      // p109 Onda 4 Fase 1: inline AI panel (Pain #2 — sinais IA inline ao avaliar).
      // Fase 2: thumbs/override por purpose (sonnet_triage + gemini_qualitative).
      const aiPanel = renderInlineAiPanel(app, validations);

      // Essay display
      const essayFields = [
        { key: 'motivation_letter', label: 'Motivação' },
        { key: 'chapter_affiliation', label: 'Capítulo / Filiação PMI' },
        { key: 'areas_of_interest', label: 'Perfil / Áreas de Interesse' },
        { key: 'academic_background', label: 'Formação / PMBOK' },
        { key: 'availability_declared', label: 'Disponibilidade' },
        { key: 'proposed_theme', label: 'Tema Proposto' },
        { key: 'leadership_experience', label: 'Experiência em Liderança' },
        { key: 'non_pmi_experience', label: 'Experiência Extra-PMI' },
      ];
      const essayItems = essayFields
        .filter(f => app[f.key])
        .map(f => `<div class="mb-2"><h5 class="text-[11px] font-bold text-[var(--text-secondary)] mb-0.5">${esc(f.label)}</h5><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-2.5 whitespace-pre-wrap max-h-[150px] overflow-y-auto">${esc(app[f.key])}</p></div>`)
        .join('');
      const essaySection = essayItems ? `
        <details open class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl mb-4">
          <summary class="px-4 py-3 text-sm font-bold text-navy cursor-pointer">Respostas do Candidato</summary>
          <div class="px-4 pb-3">${essayItems}</div>
        </details>` : '';

      // Gap 6: Check if leader role
      const isLeader = app.role_applied === 'leader';
      const committeeRole = data.committee_role || 'evaluator';
      const isObserver = committeeRole === 'observer';
      const canScore = !isLocked && !isObserver;

      container.innerHTML = `
        <div class="space-y-4">
          ${contextPanel}
          ${aiPanel}
          ${essaySection}
          ${isObserver ? '<div class="bg-blue-50 border border-blue-200 rounded-xl px-4 py-3 text-sm text-blue-800 font-semibold">Modo observador — você pode ver as informações mas não pode pontuar.</div>' : ''}
          ${isLocked ? '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold">Avaliação já submetida e bloqueada.</div>' : ''}
          ${!isObserver ? `<h4 class="text-sm font-bold text-navy">Avaliação Objetiva</h4>` : ''}
          ${!isObserver ? criteria.map((c: any) => {
            const cMax = c.max || 10;
            const savedScore = draft?.scores?.[c.key];
            const defaultVal = savedScore ?? Math.round(cMax / 2);
            const submittedNote = draft?.criterion_notes?.[c.key] || '';
            // p109 Onda 4 Fase 4 (FP-5): when locked, render value read-only (not disabled slider)
            const valueDisplay = isLocked
              ? `<div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 rounded-lg px-3 py-2">
                  <span class="text-2xl font-extrabold text-emerald-700">${savedScore ?? '—'}</span>
                  <span class="text-[11px] text-emerald-600 font-semibold">/ ${cMax} (lock)</span>
                </div>`
              : `<input type="range" min="0" max="${cMax}" step="1" value="${defaultVal}"
                  data-eval-key="${esc(c.key)}" aria-label="${esc(c.label)} score 0-${cMax}"
                  class="w-full accent-navy" />`;
            const noteDisplay = isLocked
              ? (submittedNote
                  ? `<div class="text-[12px] text-[var(--text-primary)] bg-emerald-50/40 border border-emerald-200 rounded-lg p-2 mt-1.5"><strong class="text-[10px] text-emerald-700 uppercase">Pré-nota</strong><br>${esc(submittedNote)}</div>`
                  : '')
              : `<textarea data-eval-note-key="${esc(c.key)}" aria-label="Pré-nota ${esc(c.label)}" class="w-full mt-1.5 px-2 py-1.5 text-[11px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-10 resize-none" placeholder="Pré-nota: justifique o score deste critério...">${esc(submittedNote)}</textarea>`;
            const pillarHints = renderPillarHintsCallout(app.ai_analysis, c.label);
            return `
            <div class="bg-[var(--surface-base)] rounded-xl p-3">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight}, 0-${cMax})</span></label>
                ${!isLocked ? `<span class="eval-score-display text-sm font-bold text-navy" data-key="${esc(c.key)}">${savedScore ?? '—'}</span>` : ''}
              </div>
              ${pillarHints}
              ${valueDisplay}
              ${c.guide ? `<div class="mt-1.5 text-[10px] leading-relaxed text-[var(--text-muted)] bg-[var(--surface-card)] rounded-lg px-2.5 py-1.5 border border-[var(--border-subtle)]">${c.guide.split('|').map((s: string) => '<span class="block">' + esc(s.trim()) + '</span>').join('')}</div>` : ''}
              ${noteDisplay}
            </div>`;
          }).join('') : ''}
          ${!isObserver ? `<textarea id="eval-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas privadas (só você vê)..." ${!canScore ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>` : ''}
          ${canScore ? `<button id="submit-evaluation-btn" data-app-id="${esc(applicationId)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliação (bloqueia edição)</button>` : ''}
          ${isLocked || isObserver ? `<button id="view-results-btn" data-app-id="${esc(applicationId)}" class="w-full px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90 mt-2">Ver Resultados Consolidados</button>` : ''}
          <div id="leader-extra-container"></div>
        </div>
      `;

      // p109 Onda 4 Fase 1: inline AI panel handlers
      container.querySelector('.run-triage-btn')?.addEventListener('click', (ev) => {
        ev.preventDefault();
        ev.stopPropagation();
        triggerTriage(applicationId, ev.currentTarget as HTMLButtonElement);
      });
      container.querySelector('#generate-briefing-btn')?.addEventListener('click', (ev) => {
        ev.preventDefault();
        ev.stopPropagation();
        triggerBriefing(applicationId, ev.currentTarget as HTMLButtonElement);
      });
      container.querySelector('.goto-ai-tab-btn')?.addEventListener('click', (ev) => {
        ev.preventDefault();
        ev.stopPropagation();
        const modalBody = document.getElementById('modal-body');
        const aiTabBtn = modalBody?.querySelector('[data-modal-tab="ai-runs"]') as HTMLButtonElement | null;
        aiTabBtn?.click();
      });

      // p109 Onda 4 Fase 2: validation thumbs/override handlers
      container.querySelectorAll<HTMLButtonElement>('.ai-validation-btn').forEach((btn) => {
        btn.addEventListener('click', async (ev) => {
          ev.preventDefault();
          ev.stopPropagation();
          const purpose = btn.dataset.validationPurpose as 'sonnet_triage' | 'gemini_qualitative';
          const action = btn.dataset.validationAction as 'agree' | 'disagree' | 'override';
          if (!purpose || !action) return;

          // For override action on sonnet_triage, require non-empty override input
          let overrideScore: number | null = null;
          if (action === 'override') {
            const inp = container.querySelector(`.ai-validation-override-input[data-validation-purpose="${purpose}"]`) as HTMLInputElement | null;
            if (inp) inp.classList.remove('hidden');
            const v = inp?.value?.trim() ?? '';
            if (v === '') {
              inp?.focus();
              toast('Digite o score (0-10) para override', 'error');
              return;
            }
            const n = Number(v);
            if (Number.isNaN(n) || n < 0 || n > 10) {
              toast('Override score deve ser entre 0 e 10', 'error');
              return;
            }
            overrideScore = n;
          }

          // Snapshot AI signal at validation time (from current app data)
          const aiScore = purpose === 'sonnet_triage' ? (app.ai_triage_score ?? null) : null;
          const aiVerdict = purpose === 'gemini_qualitative' ? (app.ai_analysis?.raises_the_bar?.verdict ?? null) : null;
          const aiModel = purpose === 'sonnet_triage' ? (app.ai_triage_model ?? 'claude-sonnet-4-6') : 'gemini-2.5-flash';

          btn.disabled = true;
          try {
            const { data, error } = await sb.rpc('record_ai_validation', {
              p_application_id: applicationId,
              p_ai_purpose: purpose,
              p_validation_action: action,
              p_ai_score: aiScore,
              p_ai_verdict: aiVerdict,
              p_ai_model: aiModel,
              p_override_score: overrideScore,
              p_comment: null,
            });
            if (error) throw error;
            if (data?.error) throw new Error(data.error);
            toast(`Validação salva: ${action === 'agree' ? '👍 Concordo' : action === 'disagree' ? '👎 Discordo' : `✏️ Override ${overrideScore}`}`);
            loadEvaluationForm(applicationId);  // refresh state
          } catch (e: any) {
            toast(e.message || 'Erro ao salvar validação', 'error');
            btn.disabled = false;
          }
        });
      });

      // Range slider live display
      container.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.evalKey;
        slider.addEventListener('input', () => {
          const display = container.querySelector(`.eval-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Submit evaluation
      container.querySelector('#submit-evaluation-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        container.querySelectorAll<HTMLInputElement>('input[type="range"][data-eval-key]').forEach(slider => {
          if (slider.dataset.evalKey) scores[slider.dataset.evalKey] = parseInt(slider.value, 10);
        });
        // p109 Onda 4 Fase 1.1: criterion_notes per pillar (mirrors interview tab pattern)
        const criterionNotes: Record<string, string> = {};
        container.querySelectorAll<HTMLTextAreaElement>('textarea[data-eval-note-key]').forEach(ta => {
          if (ta.dataset.evalNoteKey && ta.value.trim()) criterionNotes[ta.dataset.evalNoteKey] = ta.value.trim();
        });
        const notes = (container.querySelector('#eval-notes') as HTMLTextAreaElement)?.value || '';
        const btn = container.querySelector('#submit-evaluation-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Submetendo...'; }
        try {
          const { data: result, error } = await sb.rpc('submit_evaluation', {
            p_application_id: applicationId, p_evaluation_type: 'objective',
            p_scores: scores, p_notes: notes, p_criterion_notes: criterionNotes,
          });
          if (error) throw error;
          toast(result?.all_submitted ? `Avaliacao submetida — PERT: ${result.pert_score}` : 'Avaliacao submetida');
          loadEvaluationForm(applicationId);
          loadDashboard();
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn) { btn.disabled = false; btn.textContent = 'Submeter Avaliacao'; }
        }
      });

      // Gap 1: View results button
      container.querySelector('#view-results-btn')?.addEventListener('click', () => {
        loadEvaluationResults(applicationId);
      });

      // Gap 6: Leader extra criteria
      if (isLeader) {
        loadLeaderExtraCriteria(applicationId);
      }
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar formulario')}</p>`;
    }
  }

  /* ── leader extra criteria (Gap 6) ───────────────── */
  async function loadLeaderExtraCriteria(applicationId: string) {
    const leaderContainer = document.getElementById('leader-extra-container');
    if (!leaderContainer) return;
    try {
      const { data, error } = await sb.rpc('get_evaluation_form', {
        p_application_id: applicationId, p_evaluation_type: 'leader_extra',
      });
      if (error) throw error;
      if (!data) return;

      const criteria = data.criteria || [];
      if (!criteria.length) return;
      const draft = data.draft;
      const isLocked = data.is_locked;

      leaderContainer.innerHTML = `
        <div class="space-y-4 mt-4 border-t border-[var(--border-default)] pt-4">
          ${isLocked ? '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold">Avaliacao de lideranca ja submetida.</div>' : ''}
          <h4 class="text-sm font-bold text-purple-700">Criterios Extra de Lideranca (0-10)</h4>
          ${criteria.map((c: any) => `
            <div class="bg-[var(--surface-base)] rounded-xl p-3">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight})</span></label>
                <span class="leader-score-display text-sm font-bold text-purple-700" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
              </div>
              <input type="range" min="0" max="10" step="1" value="${draft?.scores?.[c.key] ?? 5}"
                data-leader-key="${esc(c.key)}" ${isLocked ? 'disabled' : ''}
                class="w-full accent-purple-600" />
              <p class="text-[10px] text-[var(--text-muted)] mt-1">${esc(c.guide || '')}</p>
              <textarea data-leader-note-key="${esc(c.key)}" class="w-full mt-1.5 px-2 py-1.5 text-[11px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-10 resize-none" placeholder="Pré-nota: justifique este critério de liderança..." ${isLocked ? 'disabled' : ''}>${esc(draft?.criterion_notes?.[c.key] || '')}</textarea>
            </div>
          `).join('')}
          <textarea id="leader-eval-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas sobre lideranca..." ${isLocked ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>
          ${!isLocked ? `<button id="submit-leader-eval-btn" class="w-full px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliacao de Lideranca</button>` : ''}
        </div>
      `;

      // Slider live display
      leaderContainer.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.leaderKey;
        slider.addEventListener('input', () => {
          const display = leaderContainer.querySelector(`.leader-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Submit leader extra evaluation
      leaderContainer.querySelector('#submit-leader-eval-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        leaderContainer.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
          if (slider.dataset.leaderKey) scores[slider.dataset.leaderKey] = parseInt(slider.value, 10);
        });
        // p109 Onda 4 Fase 1.1: criterion_notes per pillar (leader_extra)
        const criterionNotes: Record<string, string> = {};
        leaderContainer.querySelectorAll<HTMLTextAreaElement>('textarea[data-leader-note-key]').forEach(ta => {
          if (ta.dataset.leaderNoteKey && ta.value.trim()) criterionNotes[ta.dataset.leaderNoteKey] = ta.value.trim();
        });
        const notes = (leaderContainer.querySelector('#leader-eval-notes') as HTMLTextAreaElement)?.value || '';
        const btn = leaderContainer.querySelector('#submit-leader-eval-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Submetendo...'; }
        try {
          const { data: result, error } = await sb.rpc('submit_evaluation', {
            p_application_id: applicationId, p_evaluation_type: 'leader_extra',
            p_scores: scores, p_notes: notes, p_criterion_notes: criterionNotes,
          });
          if (error) throw error;
          toast('Avaliacao de lideranca submetida');
          loadLeaderExtraCriteria(applicationId);
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn) { btn.disabled = false; btn.textContent = 'Submeter Avaliacao de Lideranca'; }
        }
      });
    } catch { /* leader_extra not configured, skip silently */ }
  }

  /* ── CSV import ───────────────────────────────────── */
  function parseCSV(text: string): any[] {
    // RFC 4180 compliant parser — handles newlines inside quoted fields
    const records: string[][] = [];
    let field = '';
    let inQuotes = false;
    let currentRecord: string[] = [];

    for (let i = 0; i < text.length; i++) {
      const ch = text[i];
      const next = text[i + 1];

      if (inQuotes) {
        if (ch === '"' && next === '"') {
          field += '"'; i++; // escaped quote
        } else if (ch === '"') {
          inQuotes = false;
        } else {
          field += ch;
        }
      } else {
        if (ch === '"') {
          inQuotes = true;
        } else if (ch === ',') {
          currentRecord.push(field.trim());
          field = '';
        } else if (ch === '\r' && next === '\n') {
          currentRecord.push(field.trim());
          records.push(currentRecord);
          currentRecord = [];
          field = '';
          i++; // skip \n
        } else if (ch === '\n') {
          currentRecord.push(field.trim());
          records.push(currentRecord);
          currentRecord = [];
          field = '';
        } else {
          field += ch;
        }
      }
    }
    // Last field/record
    if (field || currentRecord.length > 0) {
      currentRecord.push(field.trim());
      records.push(currentRecord);
    }

    if (records.length < 2) return [];
    const headers = records[0].map(h => h.replace(/^\uFEFF/, ''));
    const hIdx = (name: string) => headers.findIndex(h => h.toLowerCase().includes(name.toLowerCase()));

    const rows: any[] = [];
    for (let i = 1; i < records.length; i++) {
      const vals = records[i];
      if (vals.length < 5) continue;
      // Skip if no application_id (garbage row)
      const appId = vals[hIdx('Application ID')] || '';
      if (!appId || !/^\d+$/.test(appId)) continue;

      rows.push({
        application_id: appId,
        pmi_id: (vals[hIdx('PMI ID')] || '').replace(/"/g, ''),
        first_name: vals[hIdx('First Name')] || '',
        last_name: vals[hIdx('Last Name')] || '',
        email: vals[hIdx('Email')] || '',
        membership_status: vals[hIdx('Membership')] || '',
        certifications: vals[hIdx('Certification')] || '',
        state: vals[hIdx('State')] || '',
        country: vals[hIdx('Country')] || '',
        app_status: vals[hIdx('App Status')] || '',
        reason_for_applying: vals[hIdx('Reason for Applying')] || '',
        resume_url: vals[hIdx('Resume')] || '',
        industry: vals[hIdx('Industry')] || '',
        // Essay fields passed by index — RPC maps them via vep_opportunities.essay_mapping
        essay_q1: vals[hIdx('Essay Question 1')] || '',
        essay_q2: vals[hIdx('Essay Question 2')] || '',
        essay_q3: vals[hIdx('Essay Question 3')] || '',
        essay_q4: vals[hIdx('Essay Question 4')] || '',
        essay_q5: vals[hIdx('Essay Question 5')] || '',
        // Additional structured fields
        areas_of_interest: vals[hIdx('Areas of Interest')] || '',
        application_date: vals[hIdx('Application Submitted')] || '',
      });
    }
    return rows;
  }

  function renderCSVPreview(rows: any[]) {
    csvParsedRows = rows;
    const preview = document.getElementById('csv-preview');
    const summary = document.getElementById('csv-summary');
    const body = document.getElementById('csv-preview-body');
    if (!preview || !body || !summary) return;

    const newCandidates = rows.filter(r => r.app_status === 'Submitted');
    const alreadyActive = rows.filter(r => r.app_status === 'Active' || r.app_status === 'Complete');
    const declined = rows.filter(r => r.app_status === 'OfferNotExtended' || r.app_status === 'Declined' || r.app_status === 'Withdrawn');

    summary.innerHTML = [
      { label: 'Total no CSV', value: rows.length, color: 'text-navy' },
      { label: 'Novos (importar)', value: newCandidates.length, color: 'text-emerald-600' },
      { label: 'Já ativos (skip)', value: alreadyActive.length, color: 'text-gray-600' },
      { label: 'Serão ignorados', value: declined.length, color: 'text-red-600' },
    ].map(s => `<div class="bg-[var(--surface-base)] rounded-xl px-4 py-2 text-center">
      <div class="text-lg font-extrabold ${s.color}">${s.value}</div>
      <div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">${s.label}</div>
    </div>`).join('');

    body.innerHTML = rows.map(r => {
      const isDeclined = ['OfferNotExtended', 'Declined', 'Withdrawn'].includes(r.app_status);
      const isActive = ['Active', 'Complete'].includes(r.app_status);
      const isSkip = isDeclined || isActive;
      const actionLabel = isDeclined ? 'Rejeitado VEP' : isActive ? 'Já ativo (skip)' : 'Importar';
      return `<tr class="${isSkip ? 'opacity-40' : ''}">
        <td class="px-3 py-2 text-[12px] font-semibold">${esc(r.first_name)} ${esc(r.last_name)}</td>
        <td class="px-3 py-2 text-[12px] text-[var(--text-secondary)]">${esc(r.email)}</td>
        <td class="px-3 py-2 text-[12px]">${esc(r.membership_status?.substring(0, 40) || '—')}</td>
        <td class="px-3 py-2 text-[12px]"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${isSkip ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-700'}">${esc(r.app_status)}</span></td>
        <td class="px-3 py-2 text-[12px]">${actionLabel}</td>
      </tr>`;
    }).join('');

    document.getElementById('csv-dropzone')?.classList.add('hidden');
    preview.classList.remove('hidden');
    document.getElementById('csv-result')?.classList.add('hidden');
  }

  async function executeImport() {
    if (!csvParsedRows.length) { toast('Nenhum CSV carregado — faça upload primeiro', 'error'); return; }
    if (!currentCycleId) { toast('Nenhum ciclo selecionado', 'error'); return; }
    const opportunityId = (document.getElementById('import-opportunity') as HTMLInputElement)?.value?.trim();
    if (!opportunityId) { toast('Informe o Opportunity ID do PMI VEP', 'error'); return; }
    const role = (document.getElementById('import-role') as HTMLSelectElement)?.value || 'researcher';
    const btn = document.getElementById('csv-import-btn') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Importando...'; }
    try {
      const { data, error } = await sb.rpc('import_vep_applications', {
        p_cycle_id: currentCycleId,
        p_opportunity_id: opportunityId,
        p_rows: csvParsedRows,
        p_role: role,
      });
      if (error) throw error;
      const result = document.getElementById('csv-result');
      if (result) {
        result.classList.remove('hidden');
        result.innerHTML = `
          <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 space-y-2">
            <h3 class="font-bold text-emerald-800">Import concluído</h3>
            <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 text-center text-[13px]">
              <div><div class="text-lg font-extrabold text-emerald-700">${data.imported}</div><div class="text-[.6rem] text-emerald-600">Importados</div></div>
              <div><div class="text-lg font-extrabold text-amber-600">${data.skipped_dedup}</div><div class="text-[.6rem] text-amber-500">Duplicados</div></div>
              <div><div class="text-lg font-extrabold text-gray-600">${data.skipped_active || 0}</div><div class="text-[.6rem] text-gray-500">Já Ativos</div></div>
              <div><div class="text-lg font-extrabold text-red-600">${data.skipped_declined}</div><div class="text-[.6rem] text-red-500">Rejeitados VEP</div></div>
              <div><div class="text-lg font-extrabold text-orange-600">${data.flagged_review || 0}</div><div class="text-[.6rem] text-orange-500">Revisão GP</div></div>
              <div><div class="text-lg font-extrabold text-blue-600">${data.returning_members}</div><div class="text-[.6rem] text-blue-500">Retornantes</div></div>
            </div>
          </div>`;
      }
      document.getElementById('csv-preview')?.classList.add('hidden');
      toast(`${data.imported} candidatos importados`);
      loadDashboard();
    } catch (e: any) {
      toast(e.message || 'Erro no import', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Importar candidatos'; }
    }
  }

  /* ── committee ────────────────────────────────────── */
