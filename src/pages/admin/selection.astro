      const criteria = data.criteria || [];
      if (!criteria.length) return;
      const draft = data.draft;
      const isLocked = data.is_locked;

      leaderContainer.innerHTML = `
        <div class="space-y-4 mt-4 border-t border-[var(--border-default)] pt-4">
          ${isLocked ? '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold">Avaliacao de lideranca ja submetida.</div>' : ''}
          <h4 class="text-sm font-bold text-purple-700">Criterios Extra de Lideranca (0-10)</h4>
          ${criteria.map((c: any) => `
            <div class="bg-[var(--surface-base)] rounded-xl p-3">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight})</span></label>
                <span class="leader-score-display text-sm font-bold text-purple-700" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
              </div>
              <input type="range" min="0" max="10" step="1" value="${draft?.scores?.[c.key] ?? 5}"
                data-leader-key="${esc(c.key)}" ${isLocked ? 'disabled' : ''}
                class="w-full accent-purple-600" />
              <p class="text-[10px] text-[var(--text-muted)] mt-1">${esc(c.guide || '')}</p>
            </div>
          `).join('')}
          <textarea id="leader-eval-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas sobre lideranca..." ${isLocked ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>
          ${!isLocked ? `<button id="submit-leader-eval-btn" class="w-full px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliacao de Lideranca</button>` : ''}
        </div>
      `;

      // Slider live display
      leaderContainer.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.leaderKey;
        slider.addEventListener('input', () => {
          const display = leaderContainer.querySelector(`.leader-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Submit leader extra evaluation
      leaderContainer.querySelector('#submit-leader-eval-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        leaderContainer.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
          if (slider.dataset.leaderKey) scores[slider.dataset.leaderKey] = parseInt(slider.value, 10);
        });
        const notes = (leaderContainer.querySelector('#leader-eval-notes') as HTMLTextAreaElement)?.value || '';
        const btn = leaderContainer.querySelector('#submit-leader-eval-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Submetendo...'; }
        try {
          const { data: result, error } = await sb.rpc('submit_evaluation', {
            p_application_id: applicationId, p_evaluation_type: 'leader_extra',
            p_scores: scores, p_notes: notes,
          });
          if (error) throw error;
          toast('Avaliacao de lideranca submetida');
          loadLeaderExtraCriteria(applicationId);
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn) { btn.disabled = false; btn.textContent = 'Submeter Avaliacao de Lideranca'; }
        }
      });
    } catch { /* leader_extra not configured, skip silently */ }
  }

  /* ── CSV import ───────────────────────────────────── */
  function parseCSV(text: string): any[] {
    // RFC 4180 compliant parser — handles newlines inside quoted fields
    const records: string[][] = [];
    let field = '';
    let inQuotes = false;
    let currentRecord: string[] = [];

    for (let i = 0; i < text.length; i++) {
      const ch = text[i];
      const next = text[i + 1];

      if (inQuotes) {
        if (ch === '"' && next === '"') {
          field += '"'; i++; // escaped quote
        } else if (ch === '"') {
          inQuotes = false;
        } else {
          field += ch;
        }
      } else {
        if (ch === '"') {
          inQuotes = true;
        } else if (ch === ',') {
          currentRecord.push(field.trim());
          field = '';
        } else if (ch === '\r' && next === '\n') {
          currentRecord.push(field.trim());
          records.push(currentRecord);
          currentRecord = [];
          field = '';
          i++; // skip \n
        } else if (ch === '\n') {
          currentRecord.push(field.trim());
          records.push(currentRecord);
          currentRecord = [];
          field = '';
        } else {
          field += ch;
        }
      }
    }
    // Last field/record
    if (field || currentRecord.length > 0) {
      currentRecord.push(field.trim());
      records.push(currentRecord);
    }

    if (records.length < 2) return [];
    const headers = records[0].map(h => h.replace(/^\uFEFF/, ''));
    const hIdx = (name: string) => headers.findIndex(h => h.toLowerCase().includes(name.toLowerCase()));

    const rows: any[] = [];
    for (let i = 1; i < records.length; i++) {
      const vals = records[i];
      if (vals.length < 5) continue;
      // Skip if no application_id (garbage row)
      const appId = vals[hIdx('Application ID')] || '';
      if (!appId || !/^\d+$/.test(appId)) continue;

      rows.push({
        application_id: appId,
        pmi_id: (vals[hIdx('PMI ID')] || '').replace(/"/g, ''),
        first_name: vals[hIdx('First Name')] || '',
        last_name: vals[hIdx('Last Name')] || '',
        email: vals[hIdx('Email')] || '',
        membership_status: vals[hIdx('Membership')] || '',
        certifications: vals[hIdx('Certification')] || '',
        state: vals[hIdx('State')] || '',
        country: vals[hIdx('Country')] || '',
        app_status: vals[hIdx('App Status')] || '',
        reason_for_applying: vals[hIdx('Reason for Applying')] || '',
        resume_url: vals[hIdx('Resume')] || '',
        industry: vals[hIdx('Industry')] || '',
        // Essay fields passed by index — RPC maps them via vep_opportunities.essay_mapping
        essay_q1: vals[hIdx('Essay Question 1')] || '',
        essay_q2: vals[hIdx('Essay Question 2')] || '',
        essay_q3: vals[hIdx('Essay Question 3')] || '',
        essay_q4: vals[hIdx('Essay Question 4')] || '',
        essay_q5: vals[hIdx('Essay Question 5')] || '',
        // Additional structured fields
        areas_of_interest: vals[hIdx('Areas of Interest')] || '',
        application_date: vals[hIdx('Application Submitted')] || '',
      });
    }
    return rows;
  }

  function renderCSVPreview(rows: any[]) {
    csvParsedRows = rows;
    const preview = document.getElementById('csv-preview');
    const summary = document.getElementById('csv-summary');
    const body = document.getElementById('csv-preview-body');
    if (!preview || !body || !summary) return;

    const newCandidates = rows.filter(r => r.app_status === 'Submitted');
    const alreadyActive = rows.filter(r => r.app_status === 'Active' || r.app_status === 'Complete');
    const declined = rows.filter(r => r.app_status === 'OfferNotExtended' || r.app_status === 'Declined' || r.app_status === 'Withdrawn');

    summary.innerHTML = [
      { label: 'Total no CSV', value: rows.length, color: 'text-navy' },
      { label: 'Novos (importar)', value: newCandidates.length, color: 'text-emerald-600' },
      { label: 'Já ativos (skip)', value: alreadyActive.length, color: 'text-gray-600' },
      { label: 'Serão ignorados', value: declined.length, color: 'text-red-600' },
    ].map(s => `<div class="bg-[var(--surface-base)] rounded-xl px-4 py-2 text-center">
      <div class="text-lg font-extrabold ${s.color}">${s.value}</div>
      <div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">${s.label}</div>
    </div>`).join('');

    body.innerHTML = rows.map(r => {
      const isDeclined = ['OfferNotExtended', 'Declined', 'Withdrawn'].includes(r.app_status);
      const isActive = ['Active', 'Complete'].includes(r.app_status);
      const isSkip = isDeclined || isActive;
      const actionLabel = isDeclined ? 'Rejeitado VEP' : isActive ? 'Já ativo (skip)' : 'Importar';
      return `<tr class="${isSkip ? 'opacity-40' : ''}">
        <td class="px-3 py-2 text-[12px] font-semibold">${esc(r.first_name)} ${esc(r.last_name)}</td>
        <td class="px-3 py-2 text-[12px] text-[var(--text-secondary)]">${esc(r.email)}</td>
        <td class="px-3 py-2 text-[12px]">${esc(r.membership_status?.substring(0, 40) || '—')}</td>
        <td class="px-3 py-2 text-[12px]"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${isSkip ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-700'}">${esc(r.app_status)}</span></td>
        <td class="px-3 py-2 text-[12px]">${actionLabel}</td>
      </tr>`;
    }).join('');

    document.getElementById('csv-dropzone')?.classList.add('hidden');
    preview.classList.remove('hidden');
    document.getElementById('csv-result')?.classList.add('hidden');
  }

  async function executeImport() {
    if (!csvParsedRows.length) { toast('Nenhum CSV carregado — faça upload primeiro', 'error'); return; }
    if (!currentCycleId) { toast('Nenhum ciclo selecionado', 'error'); return; }
    const opportunityId = (document.getElementById('import-opportunity') as HTMLInputElement)?.value?.trim();
    if (!opportunityId) { toast('Informe o Opportunity ID do PMI VEP', 'error'); return; }
    const role = (document.getElementById('import-role') as HTMLSelectElement)?.value || 'researcher';
    const btn = document.getElementById('csv-import-btn') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Importando...'; }
    try {
      const { data, error } = await sb.rpc('import_vep_applications', {
        p_cycle_id: currentCycleId,
        p_opportunity_id: opportunityId,
        p_rows: csvParsedRows,
        p_role: role,
      });
      if (error) throw error;
      const result = document.getElementById('csv-result');
      if (result) {
        result.classList.remove('hidden');
        result.innerHTML = `
          <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 space-y-2">
            <h3 class="font-bold text-emerald-800">Import concluído</h3>
            <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 text-center text-[13px]">
              <div><div class="text-lg font-extrabold text-emerald-700">${data.imported}</div><div class="text-[.6rem] text-emerald-600">Importados</div></div>
              <div><div class="text-lg font-extrabold text-amber-600">${data.skipped_dedup}</div><div class="text-[.6rem] text-amber-500">Duplicados</div></div>
              <div><div class="text-lg font-extrabold text-gray-600">${data.skipped_active || 0}</div><div class="text-[.6rem] text-gray-500">Já Ativos</div></div>
              <div><div class="text-lg font-extrabold text-red-600">${data.skipped_declined}</div><div class="text-[.6rem] text-red-500">Rejeitados VEP</div></div>
              <div><div class="text-lg font-extrabold text-orange-600">${data.flagged_review || 0}</div><div class="text-[.6rem] text-orange-500">Revisão GP</div></div>
              <div><div class="text-lg font-extrabold text-blue-600">${data.returning_members}</div><div class="text-[.6rem] text-blue-500">Retornantes</div></div>
            </div>
          </div>`;
      }
      document.getElementById('csv-preview')?.classList.add('hidden');
      toast(`${data.imported} candidatos importados`);
      loadDashboard();
    } catch (e: any) {
      toast(e.message || 'Erro no import', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Importar candidatos'; }
    }
  }

  /* ── committee ────────────────────────────────────── */
  async function loadCommittee() {
    if (!currentCycleId) return;
    const { data } = await sb.rpc('get_selection_committee', { p_cycle_id: currentCycleId });
    const members = Array.isArray(data) ? data : [];
    const el = document.getElementById('committee-list');
    if (!el) return;
    if (!members.length) {
      el.innerHTML = '<p class="text-sm text-[var(--text-muted)] py-4">Nenhum membro no comitê. Use a busca acima para adicionar membros.</p>';
      return;
    }
    el.innerHTML = members.map((c: any) => `
      <div class="flex items-center justify-between bg-[var(--surface-base)] rounded-xl px-4 py-3">
        <div>
          <span class="font-semibold text-sm text-[var(--text-primary)]">${esc(c.member_name || '—')}</span>
          <span class="text-[11px] text-[var(--text-muted)] ml-2">${esc(c.member_role || '')}</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${c.role === 'lead' ? 'bg-purple-50 text-purple-700' : 'bg-blue-50 text-blue-700'}">${c.role}</span>
          ${c.can_interview ? '<span class="text-[10px] text-emerald-600">pode entrevistar</span>' : ''}
          <button class="text-[11px] text-red-500 hover:underline cursor-pointer bg-transparent border-0 p-0" data-action="remove-committee" data-member-id="${esc(c.member_id)}">remover</button>
        </div>
      </div>
    `).join('');
  }

  let committeeSearchTimeout: any = null;

  function setupCommitteeSearch() {
    const input = document.getElementById('committee-search') as HTMLInputElement;
    const results = document.getElementById('committee-search-results');
    if (!input || !results) return;

    input.addEventListener('input', () => {
      clearTimeout(committeeSearchTimeout);
      const query = input.value.trim();
      if (query.length < 2) { results.classList.add('hidden'); return; }
      committeeSearchTimeout = setTimeout(async () => {
        const { data: members } = await sb.from('members')
          .select('id, name, operational_role')
          .ilike('name', `%${query}%`)
          .eq('is_active', true)
          .order('name')
          .limit(8);
        if (!members?.length) {
          results.innerHTML = '<div class="px-4 py-3 text-[12px] text-[var(--text-muted)]">Nenhum membro encontrado</div>';
        } else {
          results.innerHTML = members.map((m: any) =>
            `<div class="px-4 py-2.5 hover:bg-[var(--surface-hover)] cursor-pointer text-[13px] flex items-center justify-between" data-action="add-committee-member" data-member-id="${esc(m.id)}" data-member-name="${esc(m.name)}">
              <span class="font-semibold text-[var(--text-primary)]">${esc(m.name)}</span>
              <span class="text-[11px] text-[var(--text-muted)]">${esc(m.operational_role || '')}</span>
            </div>`
          ).join('');
        }
        results.classList.remove('hidden');
      }, 300);
    });

    // Close on click outside (delayed to let action handler fire first)
    document.addEventListener('mousedown', (e) => {
      if (!input.contains(e.target as Node) && !results.contains(e.target as Node)) {
        setTimeout(() => results.classList.add('hidden'), 150);
      }
    });

    // Direct click handler on results (more reliable than delegated)
    results.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest<HTMLElement>('[data-action="add-committee-member"]');
      if (item?.dataset.memberId) {
        addCommitteeMemberById(item.dataset.memberId, item.dataset.memberName || '');
      }
    });
  }

  async function addCommitteeMemberById(memberId: string, memberName: string) {
    if (!currentCycleId) return;
    const role = (document.getElementById('committee-role-select') as HTMLSelectElement)?.value || 'evaluator';
    try {
      const { data, error } = await sb.rpc('manage_selection_committee', {
        p_cycle_id: currentCycleId, p_action: 'add', p_member_id: memberId, p_role: role,
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error);
      toast(`${memberName} adicionado como ${role}`);
      const input = document.getElementById('committee-search') as HTMLInputElement;
      if (input) input.value = '';
      document.getElementById('committee-search-results')?.classList.add('hidden');
      loadCommittee();
    } catch (e: any) {
      toast(e.message || 'Erro ao adicionar', 'error');
    }
  }

  async function removeCommitteeMember(memberId: string) {
    if (!currentCycleId || !confirm('Remover este membro do comitê?')) return;
    const { error } = await sb.rpc('manage_selection_committee', {
      p_cycle_id: currentCycleId, p_action: 'remove', p_member_id: memberId,
    });
    if (error) { toast(error.message, 'error'); return; }
    toast('Membro removido do comitê');
    loadCommittee();
  }

  /* ── bulk selection helpers ─────────────────────────── */
  function updateBulkBar() {
    const checks = document.querySelectorAll<HTMLInputElement>('.sel-row-check:checked');
    const bar = document.getElementById('bulk-actions');
    const countEl = document.getElementById('bulk-count');
    if (bar) bar.classList.toggle('hidden', checks.length === 0);
    if (countEl) countEl.textContent = `${checks.length} selecionado${checks.length !== 1 ? 's' : ''}`;
  }

  async function executeBulkDecision(decision: string) {
    const checks = document.querySelectorAll<HTMLInputElement>('.sel-row-check:checked');
    const ids = Array.from(checks).map(c => c.value);
    if (!ids.length) return;
    const bulkFeedback = (document.getElementById('bulk-feedback') as HTMLInputElement)?.value?.trim() || '';
    const labels: Record<string, string> = { approved: 'aprovar', rejected: 'rejeitar', waitlist: 'colocar em lista de espera' };
    if (!confirm(`Deseja ${labels[decision] || decision} ${ids.length} candidato(s)?`)) return;
    let ok = 0;
    let fail = 0;
    for (const id of ids) {
      try {
        const updateData: any = { status: decision };
        if (bulkFeedback) updateData.feedback = bulkFeedback;
        const { error } = await sb.rpc('admin_update_application', {
          p_application_id: id,
          p_data: updateData,
        });
        if (error) throw error;
        ok++;
      } catch { fail++; }
    }
    toast(`${ok} atualizado(s)${fail ? `, ${fail} erro(s)` : ''}`);
    if (bulkFeedback) (document.getElementById('bulk-feedback') as HTMLInputElement).value = '';
    loadDashboard();
  }

  /* ── evaluation results ──────────────────────────── */
  async function loadEvaluationResults(applicationId: string) {
    const container = document.getElementById('eval-form-container');
    if (!container) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando resultados...</p>';
    try {
      const { data, error } = await sb.rpc('get_evaluation_results', { p_application_id: applicationId });
      if (error) throw error;
      if (!data) throw new Error('Sem dados');

      const evaluations = data.evaluations || [];
      const consolidated = data.consolidated || {};
      const alerts = data.calibration_alerts || [];

      // Group evaluations by type
      const byType: Record<string, any[]> = {};
      for (const ev of evaluations) {
        const t = ev.evaluation_type || 'objective';
        if (!byType[t]) byType[t] = [];
        byType[t].push(ev);
      }

      const TYPE_LABELS: Record<string, string> = {
        objective: 'Avaliação Quantitativa (Pesquisador)',
        interview: 'Avaliação Qualitativa (Entrevista)',
        leader_extra: 'Avaliação Quantitativa (Líder)',
      };

      let html = '<div class="space-y-4">';
      html += '<h4 class="text-sm font-bold text-navy">Resultados Consolidados</h4>';

      // Render table per evaluation type
      for (const [evalType, evals] of Object.entries(byType)) {
        const criteriaKeys = Object.keys(evals[0]?.scores || {});
        if (!criteriaKeys.length) continue;

        const evaluatorNames = evals.map((ev: any) => esc(ev.evaluator_name || 'Avaliador'));
        html += `<div class="border border-[var(--border-default)] rounded-xl overflow-hidden">`;
        html += `<div class="bg-[var(--surface-base)] px-3 py-2 text-[12px] font-bold text-navy border-b border-[var(--border-subtle)]">${TYPE_LABELS[evalType] || evalType}</div>`;
        html += '<div class="overflow-x-auto"><table class="w-full text-[12px] text-left"><thead><tr class="bg-[var(--surface-base)]">';
        html += '<th class="px-3 py-2 font-bold text-[var(--text-secondary)]">Critério</th>';
        evaluatorNames.forEach((n: string) => { html += `<th class="px-3 py-2 font-bold text-[var(--text-secondary)]">${n}</th>`; });
        html += '<th class="px-3 py-2 font-bold text-navy">PERT</th></tr></thead><tbody>';

        for (const key of criteriaKeys) {
          html += '<tr class="border-t border-[var(--border-subtle)]">';
          html += `<td class="px-3 py-2 font-semibold">${esc(key)}</td>`;
          const allVals: number[] = [];
          for (const ev of evals) {
            const val = ev.scores?.[key];
            if (val != null) allVals.push(Number(val));
            html += `<td class="px-3 py-2">${val != null ? val : '—'}</td>`;
          }
          const divergence = allVals.length >= 2 ? Math.max(...allVals) - Math.min(...allVals) : 0;
          const pertBg = divergence > 3 ? 'bg-amber-100' : '';
          const pertVal = allVals.length >= 2
            ? ((2 * Math.min(...allVals) + 4 * (allVals.reduce((a, b) => a + b, 0) / allVals.length) + 2 * Math.max(...allVals)) / 8).toFixed(1)
            : (allVals.length === 1 ? allVals[0].toFixed(1) : '—');
          html += `<td class="px-3 py-2 font-bold text-navy ${pertBg}">${pertVal}</td>`;
          html += '</tr>';
        }

        // Subtotal row
        const subtotals = evals.map((ev: any) => ev.weighted_subtotal).filter((v: any) => v != null).map(Number);
        const pertSubtotal = subtotals.length >= 2
          ? ((2 * Math.min(...subtotals) + 4 * (subtotals.reduce((a, b) => a + b, 0) / subtotals.length) + 2 * Math.max(...subtotals)) / 8).toFixed(1)
          : (subtotals.length === 1 ? subtotals[0].toFixed(1) : '—');
        html += '<tr class="border-t-2 border-navy bg-[var(--surface-base)]">';
        html += '<td class="px-3 py-2 font-bold text-navy">Subtotal Ponderado</td>';
        for (const ev of evals) {
          html += `<td class="px-3 py-2 font-bold">${ev.weighted_subtotal != null ? Number(ev.weighted_subtotal).toFixed(1) : '—'}</td>`;
        }
        html += `<td class="px-3 py-2 font-extrabold text-navy">${pertSubtotal}</td>`;
        html += '</tr></tbody></table></div></div>';
      }

      // Calibration alerts
      if (alerts.length) {
        html += '<div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3">';
        html += '<h5 class="text-[12px] font-bold text-amber-800 mb-1">Alertas de Calibração (divergência > 3)</h5>';
        html += alerts.map((a: any) => `<div class="text-[11px] text-amber-700">${esc(a.type)}: <strong>${esc(a.criterion)}</strong> — divergência ${a.divergence}</div>`).join('');
        html += '</div>';
      }

      // Final scores
      html += '<div class="grid grid-cols-3 gap-3 mt-3">';
      html += `<div class="bg-[var(--surface-base)] rounded-xl p-3 text-center"><div class="text-lg font-extrabold text-navy">${consolidated.objective_pert != null ? Number(consolidated.objective_pert).toFixed(1) : (consolidated.objective_score_avg != null ? Number(consolidated.objective_score_avg).toFixed(1) : '—')}</div><div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">PERT Quantitativa</div></div>`;
      html += `<div class="bg-[var(--surface-base)] rounded-xl p-3 text-center"><div class="text-lg font-extrabold text-navy">${consolidated.interview_pert != null ? Number(consolidated.interview_pert).toFixed(1) : (consolidated.interview_score != null ? Number(consolidated.interview_score).toFixed(1) : '—')}</div><div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">PERT Qualitativa</div></div>`;
      html += `<div class="bg-[var(--surface-base)] rounded-xl p-3 text-center"><div class="text-lg font-extrabold text-navy">${consolidated.final_score != null ? Number(consolidated.final_score).toFixed(1) : '—'}</div><div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">Score Final</div></div>`;
      html += '</div>';

      // Calculation explanation
      html += '<div class="text-[10px] text-[var(--text-muted)] mt-2 bg-[var(--surface-base)] rounded-lg p-2.5">';
      html += '<strong>Cálculo:</strong> PERT por fase = (2×Min + 4×Avg + 2×Max) / 8 dos subtotais ponderados de cada avaliador. ';
      html += 'Score Final = PERT Quantitativa + PERT Qualitativa' + (byType.leader_extra ? ' + PERT Líder' : '') + '.';
      html += '</div>';

      html += '</div>';
      container.innerHTML = html;
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar resultados')}</p>`;
    }
  }

  /* ── interview scoring form ──────────────────────── */
  async function loadInterviewForm(row: any) {
    const container = document.getElementById('modal-tab-interview');
    if (!container) return;

    // Keep existing scheduling section, append interview scoring below
    let scoringDiv = container.querySelector('#interview-scoring-section');
    if (scoringDiv) scoringDiv.remove();

    scoringDiv = document.createElement('div');
    scoringDiv.id = 'interview-scoring-section';
    scoringDiv.className = 'space-y-4 mt-4 border-t border-[var(--border-default)] pt-4';
    scoringDiv.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando entrevista...</p>';
    container.appendChild(scoringDiv);

    try {
      const { data: interviewsRaw } = await sb.rpc('get_application_interviews', { p_application_id: row.id });
      const interviews = Array.isArray(interviewsRaw) ? interviewsRaw : [];

      if (!interviews?.length) {
        scoringDiv.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Nenhuma entrevista agendada.</p>';
        return;
      }

      const interview = interviews[0];
      const statusLabel = STATUS_LABELS[`interview_${interview.status}`] || interview.status;
      let html = `<div class="bg-[var(--surface-base)] rounded-xl p-3 mb-3">
        <div class="flex items-center justify-between">
          <span class="text-[12px] font-bold text-[var(--text-secondary)]">Entrevista: ${esc(statusLabel)}</span>
          <span class="text-[11px] text-[var(--text-muted)]">${interview.scheduled_at ? new Date(interview.scheduled_at).toLocaleString('pt-BR') : '—'}</span>
        </div>
      </div>`;

      // Gap 3: Interview status buttons
      if (interview.status === 'scheduled') {
        html += `<div class="flex gap-2 mb-3">
          <button class="interview-status-btn px-3 py-1.5 bg-orange-500 text-white rounded-lg text-[12px] font-bold cursor-pointer border-0 hover:opacity-90" data-interview-id="${esc(interview.id)}" data-status="noshow">No-Show</button>
          <button class="interview-status-btn px-3 py-1.5 bg-red-500 text-white rounded-lg text-[12px] font-bold cursor-pointer border-0 hover:opacity-90" data-interview-id="${esc(interview.id)}" data-status="cancelled">Cancelar</button>
        </div>`;
      }

      // Gap 2: Interview scoring form
      if (interview.status === 'scheduled' || interview.status === 'completed') {
        try {
          const { data: formData, error: formError } = await sb.rpc('get_evaluation_form', {
            p_application_id: row.id, p_evaluation_type: 'interview',
          });
          if (!formError && formData) {
            const criteria = formData.criteria || [];
            const draft = formData.draft;
            const isLocked = formData.is_locked;

            html += `<h4 class="text-sm font-bold text-navy">Avaliação da Entrevista</h4>`;
            if (isLocked) {
              html += '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold mb-3">Avaliacao da entrevista ja submetida.</div>';
            }
            html += criteria.map((c: any) => {
              const cMax = c.max || 10;
              const defaultVal = draft?.scores?.[c.key] ?? Math.round(cMax / 2);
              return `
              <div class="bg-[var(--surface-base)] rounded-xl p-3">
                <div class="flex items-center justify-between mb-1">
                  <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight}, 0-${cMax})</span></label>
                  <span class="intv-score-display text-sm font-bold text-navy" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
                </div>
                <input type="range" min="0" max="${cMax}" step="1" value="${defaultVal}"
                  data-intv-key="${esc(c.key)}" ${isLocked ? 'disabled' : ''}
                  class="w-full accent-navy" />
                ${c.guide ? `<div class="mt-1.5 text-[10px] leading-relaxed text-[var(--text-muted)] bg-[var(--surface-card)] rounded-lg px-2.5 py-1.5 border border-[var(--border-subtle)]">${c.guide.split('|').map((s: string) => '<span class="block">' + esc(s.trim()) + '</span>').join('')}</div>` : ''}
                <textarea data-intv-note-key="${esc(c.key)}" class="w-full mt-1.5 px-2 py-1.5 text-[11px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-10 resize-none" placeholder="Notas sobre ${esc(c.label)}..." ${isLocked ? 'disabled' : ''}>${esc(draft?.criterion_notes?.[c.key] || '')}</textarea>
              </div>`;
            }).join('');

            html += `<input type="text" id="intv-theme" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" placeholder="Tema discutido..." value="${esc(draft?.theme || '')}" ${isLocked ? 'disabled' : ''} />`;
            html += `<textarea id="intv-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas da entrevista..." ${isLocked ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>`;
            if (!isLocked) {
              html += `<button id="submit-interview-scores-btn" data-interview-id="${esc(interview.id)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliacao da Entrevista</button>`;
            }
          }
        } catch { /* scoring form not available */ }
      }

      scoringDiv.innerHTML = html;

      // Wire up slider live display
      scoringDiv.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.intvKey;
        slider.addEventListener('input', () => {
          const display = scoringDiv!.querySelector(`.intv-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Wire up interview status buttons (Gap 3)
      scoringDiv.querySelectorAll<HTMLButtonElement>('.interview-status-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const intvId = btn.dataset.interviewId;
          const status = btn.dataset.status;
          if (!intvId || !status) return;
          try {
            const { error } = await sb.rpc('mark_interview_status', { p_interview_id: intvId, p_status: status });
            if (error) throw error;
            toast(status === 'noshow' ? 'Marcado como No-Show' : 'Entrevista cancelada');
            loadInterviewForm(row);
            loadDashboard();
          } catch (e: any) { toast(e.message || 'Erro', 'error'); }
        });
      });

      // Wire up interview scoring submit (Gap 2)
      scoringDiv.querySelector('#submit-interview-scores-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        scoringDiv!.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
          if (slider.dataset.intvKey) scores[slider.dataset.intvKey] = parseInt(slider.value, 10);
        });
        const criterionNotes: Record<string, string> = {};
        scoringDiv!.querySelectorAll<HTMLTextAreaElement>('textarea[data-intv-note-key]').forEach(ta => {
          if (ta.dataset.intvNoteKey && ta.value.trim()) criterionNotes[ta.dataset.intvNoteKey] = ta.value.trim();
        });
        const theme = (scoringDiv!.querySelector('#intv-theme') as HTMLInputElement)?.value || '';
        const notes = (scoringDiv!.querySelector('#intv-notes') as HTMLTextAreaElement)?.value || '';
        const btn2 = scoringDiv!.querySelector('#submit-interview-scores-btn') as HTMLButtonElement;
        if (btn2) { btn2.disabled = true; btn2.textContent = 'Submetendo...'; }
        try {
          const { error } = await sb.rpc('submit_interview_scores', {
            p_interview_id: interview.id,
            p_scores: scores,
            p_theme: theme,
            p_notes: notes,
            p_criterion_notes: criterionNotes,
          });
          if (error) throw error;
          toast('Avaliacao da entrevista submetida');
          loadInterviewForm(row);
          loadDashboard();
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn2) { btn2.disabled = false; btn2.textContent = 'Submeter Avaliacao da Entrevista'; }
        }
      });
    } catch (e: any) {
      scoringDiv.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar entrevista')}</p>`;
    }
  }

  /* ── event binding ────────────────────────────────── */
  let searchTimeout: any = null;

  /* ── VEP opportunities config ────────────────────── */
  const ESSAY_FIELD_OPTIONS = [
    { value: 'motivation_letter', label: 'Motivação' },
    { value: 'areas_of_interest', label: 'Áreas de Interesse / Perfil' },
    { value: 'academic_background', label: 'Formação / PMBOK' },
    { value: 'availability_declared', label: 'Disponibilidade' },
    { value: 'proposed_theme', label: 'Tema Proposto' },
    { value: 'leadership_experience', label: 'Experiência em Liderança' },
    { value: 'non_pmi_experience', label: 'Experiência Extra-PMI' },
  ];

  let editingOppId: string | null = null;

  async function loadOpportunities() {
    const list = document.getElementById('vep-opportunities-list');
    if (!list) return;
    const { data, error } = await sb.from('vep_opportunities').select('*').order('created_at');
    if (error || !data?.length) {
      list.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Nenhuma vaga configurada.</p>';
      return;
    }
    list.innerHTML = data.map((o: any) => {
      const mappingStr = o.essay_mapping ? Object.entries(o.essay_mapping).map(([k, v]) => {
        const field = typeof v === 'string' ? v : (v as any)?.field || '?';
        return `Q${k}→${field}`;
      }).join(', ') : '—';
      return `<div class="flex items-start gap-3 p-3 bg-[var(--surface-base)] rounded-xl border border-[var(--border-subtle)]">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-[12px] font-bold text-navy">${esc(o.title || o.opportunity_id)}</span>
            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full ${o.is_active ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-500'}">${o.is_active ? 'Ativa' : 'Inativa'}</span>
            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-blue-50 text-blue-700">${esc(o.role_default)}</span>
          </div>
          <div class="text-[10px] text-[var(--text-muted)]">ID: ${esc(o.opportunity_id)} · ${esc(o.chapter_posted || '—')} · ${o.positions_available || '—'} vagas · ${esc(o.time_commitment || '—')}</div>
          <div class="text-[10px] text-[var(--text-muted)] mt-0.5">Essay mapping: ${esc(mappingStr)}</div>
          ${o.vep_url ? `<a href="${esc(o.vep_url)}" target="_blank" rel="noopener" class="text-[10px] text-navy hover:underline">Abrir no VEP</a>` : ''}
        </div>
        <button class="edit-opp-btn px-2 py-1 text-[10px] text-navy font-semibold bg-transparent border border-navy rounded-lg cursor-pointer hover:bg-navy/5" data-opp='${JSON.stringify(o).replace(/'/g, "&#39;")}'>Editar</button>
      </div>`;
    }).join('');

    // Wire edit buttons
    list.querySelectorAll<HTMLButtonElement>('.edit-opp-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const opp = JSON.parse(btn.dataset.opp || '{}');
        openOpportunityForm(opp);
      });
    });
  }

  function openOpportunityForm(opp?: any) {
    const form = document.getElementById('opportunity-form');
    const title = document.getElementById('opp-form-title');
    if (!form || !title) return;

    editingOppId = opp?.id || null;
    title.textContent = opp ? 'Editar Vaga VEP' : 'Nova Vaga VEP';

    (document.getElementById('opp-id') as HTMLInputElement).value = opp?.opportunity_id || '';
    (document.getElementById('opp-title') as HTMLInputElement).value = opp?.title || '';
    (document.getElementById('opp-role') as HTMLSelectElement).value = opp?.role_default || 'researcher';
    (document.getElementById('opp-url') as HTMLInputElement).value = opp?.vep_url || '';
    (document.getElementById('opp-chapter') as HTMLInputElement).value = opp?.chapter_posted || '';
    (document.getElementById('opp-positions') as HTMLInputElement).value = String(opp?.positions_available || 42);
    (document.getElementById('opp-time') as HTMLInputElement).value = opp?.time_commitment || '';
    (document.getElementById('opp-start') as HTMLInputElement).value = opp?.start_date || '';
    (document.getElementById('opp-end') as HTMLInputElement).value = opp?.end_date || '';
    (document.getElementById('opp-eligibility') as HTMLTextAreaElement).value = opp?.eligibility || '';

    // Essay mapping — supports both old {"1":"field"} and new {"1":{"field":"x","question":"y"}} formats
    const mappingContainer = document.getElementById('essay-mapping-fields');
    if (mappingContainer) {
      mappingContainer.innerHTML = '';
      const mapping = opp?.essay_mapping || {};
      const entries = Object.entries(mapping);
      if (entries.length) {
        entries.forEach(([idx, val]) => {
          const field = typeof val === 'string' ? val : (val as any)?.field || '';
          const question = typeof val === 'string' ? '' : (val as any)?.question || '';
          addEssayMappingRow(mappingContainer, idx, field, question);
        });
      } else {
        addEssayMappingRow(mappingContainer, '1', 'motivation_letter');
      }
    }

    form.classList.remove('hidden');
  }

  function addEssayMappingRow(container: HTMLElement, idx: string, field: string, question: string = '') {
    const row = document.createElement('div');
    row.className = 'space-y-1 p-2 bg-[var(--surface-card)] rounded-lg border border-[var(--border-subtle)]';
    row.innerHTML = `
      <div class="flex gap-2 items-center">
        <input type="text" class="essay-q-idx w-10 px-1.5 py-1 text-[11px] border border-[var(--border-default)] rounded bg-[var(--surface-input)] text-center font-bold" value="${esc(idx)}" />
        <select class="essay-q-field flex-1 px-2 py-1 text-[11px] border border-[var(--border-default)] rounded bg-[var(--surface-input)]">
          ${ESSAY_FIELD_OPTIONS.map(o => `<option value="${o.value}" ${o.value === field ? 'selected' : ''}>${o.label}</option>`).join('')}
        </select>
        <button class="remove-essay-row text-red-400 hover:text-red-600 bg-transparent border-0 cursor-pointer text-sm">×</button>
      </div>
      <textarea class="essay-q-text w-full px-2 py-1 text-[10px] border border-[var(--border-default)] rounded bg-[var(--surface-input)] h-8 resize-none" placeholder="Texto da pergunta no VEP (ex: Você é filiado a um dos capítulos...)">${esc(question)}</textarea>
    `;
    row.querySelector('.remove-essay-row')?.addEventListener('click', () => row.remove());
    container.appendChild(row);
  }

  async function saveOpportunity() {
    const data: any = {
      opportunity_id: (document.getElementById('opp-id') as HTMLInputElement).value.trim(),
      title: (document.getElementById('opp-title') as HTMLInputElement).value.trim(),
      role_default: (document.getElementById('opp-role') as HTMLSelectElement).value,
      vep_url: (document.getElementById('opp-url') as HTMLInputElement).value.trim() || null,
      chapter_posted: (document.getElementById('opp-chapter') as HTMLInputElement).value.trim() || null,
      positions_available: parseInt((document.getElementById('opp-positions') as HTMLInputElement).value) || null,
      time_commitment: (document.getElementById('opp-time') as HTMLInputElement).value.trim() || null,
      start_date: (document.getElementById('opp-start') as HTMLInputElement).value || null,
      end_date: (document.getElementById('opp-end') as HTMLInputElement).value || null,
      eligibility: (document.getElementById('opp-eligibility') as HTMLTextAreaElement).value.trim() || null,
      is_active: true,
    };

    if (!data.opportunity_id || !data.title) { toast('ID e Título são obrigatórios', 'error'); return; }

    // Collect essay mapping (new rich format)
    const mapping: Record<string, any> = {};
    document.querySelectorAll('#essay-mapping-fields > div').forEach(row => {
      const idx = (row.querySelector('.essay-q-idx') as HTMLInputElement)?.value?.trim();
      const field = (row.querySelector('.essay-q-field') as HTMLSelectElement)?.value;
      const question = (row.querySelector('.essay-q-text') as HTMLTextAreaElement)?.value?.trim();
      if (idx && field) {
        mapping[idx] = question ? { field, question } : field;
      }
    });
    data.essay_mapping = mapping;

    try {
      if (editingOppId) {
        const { error } = await sb.from('vep_opportunities').update(data).eq('id', editingOppId);
        if (error) throw error;
        toast('Vaga atualizada');
      } else {
        const { error } = await sb.from('vep_opportunities').insert(data);
        if (error) throw error;
        toast('Vaga criada');
      }
      document.getElementById('opportunity-form')?.classList.add('hidden');
      editingOppId = null;
      loadOpportunities();
    } catch (e: any) { toast(e.message || 'Erro ao salvar', 'error'); }
  }

  function bindEvents() {
    // Tabs
    document.querySelectorAll('.sel-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.selTab;
        if (tab) {
          switchTab(tab);
          if (tab === 'committee') loadCommittee();
          if (tab === 'import') loadOpportunities();
        }
      });
    });

    // Cycle picker
    document.getElementById('sel-cycle-picker')?.addEventListener('change', (e) => {
      const newId = (e.target as HTMLSelectElement).value;
      if (newId && newId !== currentCycleId) {
        currentCycleId = newId;
        // Reload with specific cycle — need to use cycle_code
        const cycle = allCycles.find((c: any) => c.id === newId);
        if (cycle) {
          // Notify React islands (DiversityDashboard) about cycle change
          window.dispatchEvent(new CustomEvent('selection:cycle-changed', { detail: { cycleId: newId } }));
          sb.rpc('get_selection_dashboard', { p_cycle_code: cycle.cycle_code }).then(({ data }: any) => {
            if (data) {
              allRows = data.applications || [];
              const badge = document.getElementById('sel-cycle-badge');
              if (badge && data.cycle) {
                const cs = CYCLE_STATUS_COLORS[data.cycle.status] || CYCLE_STATUS_COLORS.draft;
                badge.className = `text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase ${cs.bg} ${cs.color}`;
                badge.textContent = data.cycle.status.toUpperCase();
              }
              populateChapterDropdown();
              applyFilters();
            }
          });
        }
      }
    });

    // Role toggle
    document.getElementById('sel-role-toggle')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.sel-role-btn');
      if (!btn) return;
      filterRole = btn.dataset.role || 'all';
      document.querySelectorAll('.sel-role-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.role === filterRole;
        b.classList.toggle('bg-navy', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-[var(--surface-card)]', !isActive);
        b.classList.toggle('text-[var(--text-secondary)]', !isActive);
      });
      applyFilters();
    });

    // Dropdowns
    document.getElementById('sel-chapter')?.addEventListener('change', (e) => { filterChapter = (e.target as HTMLSelectElement).value; applyFilters(); });
    document.getElementById('sel-status')?.addEventListener('change', (e) => { filterStatus = (e.target as HTMLSelectElement).value; applyFilters(); });

    // Search
    document.getElementById('sel-search')?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => { filterSearch = ((e.target as HTMLInputElement).value || '').trim(); applyFilters(); }, 300);
    });

    // Column sorting
    document.querySelectorAll<HTMLElement>('[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort!;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = col === 'applicant_name'; }
        applyFilters();
      });
    });

    // Delegated click actions
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      const action = target.dataset.action;
      if (action === 'view-applicant' && target.dataset.id) { openApplicantModal(target.dataset.id); }
      else if (action === 'remove-committee' && target.dataset.memberId) { removeCommitteeMember(target.dataset.memberId); }
      else if (action === 'add-committee-member' && target.dataset.memberId) {
        addCommitteeMemberById(target.dataset.memberId, target.dataset.memberName || '');
      }
    });

    // Check-all checkbox (Gap 4)
    document.getElementById('sel-check-all')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      document.querySelectorAll<HTMLInputElement>('.sel-row-check').forEach(cb => { cb.checked = checked; });
      updateBulkBar();
    });
    document.addEventListener('change', (e) => {
      if ((e.target as HTMLElement).classList.contains('sel-row-check')) updateBulkBar();
    });

    // Bulk action buttons (Gap 4)
    document.querySelectorAll<HTMLButtonElement>('.bulk-action-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const decision = btn.dataset.decision;
        if (decision) executeBulkDecision(decision);
      });
    });

    // Recalculate rankings (Gap 5)
    document.getElementById('recalc-rankings-btn')?.addEventListener('click', async () => {
      if (!currentCycleId) { toast('Nenhum ciclo selecionado', 'error'); return; }
      const btn = document.getElementById('recalc-rankings-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Calculando...'; }
      try {
        const { error } = await sb.rpc('calculate_rankings', { p_cycle_id: currentCycleId });
        if (error) throw error;
        toast('Rankings recalculados');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao recalcular', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Recalcular Rankings'; }
      }
    });

    // Start screening (Gap 10)
    document.getElementById('start-screening-btn')?.addEventListener('click', async () => {
      const submitted = allRows.filter(r => r.status === 'submitted');
      if (!submitted.length) { toast('Nenhum candidato com status "submitted"', 'error'); return; }
      if (!confirm(`Iniciar triagem para ${submitted.length} candidato(s)?`)) return;
      const btn = document.getElementById('start-screening-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Processando...'; }
      let ok = 0;
      let fail = 0;
      for (const r of submitted) {
        try {
          const { error } = await sb.rpc('admin_update_application', {
            p_application_id: r.id,
            p_data: { status: 'screening' },
          });
          if (error) throw error;
          ok++;
        } catch { fail++; }
      }
      toast(`${ok} candidato(s) movidos para triagem${fail ? `, ${fail} erro(s)` : ''}`);
      if (btn) { btn.disabled = false; btn.textContent = 'Iniciar Triagem'; }
      loadDashboard();
    });

    // Committee search setup
    setupCommitteeSearch();

    // VEP Opportunities
    document.getElementById('add-opportunity-btn')?.addEventListener('click', () => openOpportunityForm());
    document.getElementById('save-opportunity-btn')?.addEventListener('click', () => saveOpportunity());
    document.getElementById('cancel-opportunity-btn')?.addEventListener('click', () => {
      document.getElementById('opportunity-form')?.classList.add('hidden');
      editingOppId = null;
    });
    document.getElementById('add-essay-mapping-btn')?.addEventListener('click', () => {
      const container = document.getElementById('essay-mapping-fields');
      if (!container) return;
      const nextIdx = String(container.children.length + 1);
      addEssayMappingRow(container, nextIdx, 'motivation_letter');
    });

    // Modal close
    document.getElementById('modal-close')?.addEventListener('click', () => {
      document.getElementById('applicant-modal')?.classList.add('hidden');
    });
    document.getElementById('applicant-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) (e.target as HTMLElement).classList.add('hidden');
    });

    // CSV file input
    const dropzone = document.getElementById('csv-dropzone');
    const fileInput = document.getElementById('csv-file-input') as HTMLInputElement;
    dropzone?.addEventListener('click', () => fileInput?.click());
    dropzone?.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('dragleave', () => { dropzone.classList.remove('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-navy', 'bg-blue-50/30');
      const file = e.dataTransfer?.files[0];
      if (file) handleCSVFile(file);
    });
    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleCSVFile(file);
    });
    document.getElementById('csv-import-btn')?.addEventListener('click', executeImport);
    document.getElementById('csv-cancel-btn')?.addEventListener('click', () => {
      document.getElementById('csv-preview')?.classList.add('hidden');
      document.getElementById('csv-dropzone')?.classList.remove('hidden');
      csvParsedRows = [];
    });
  }

  function handleCSVFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target?.result as string;
      if (!text) return;
      const rows = parseCSV(text);
      if (rows.length === 0) { toast('CSV vazio ou formato inválido', 'error'); return; }
      renderCSVPreview(rows);
    };
    reader.readAsText(file, 'UTF-8');
  }

  /* ── permission gate ──────────────────────────────── */
  function applyGate(m: any) {
    if (m && canAccessAdminRoute(m, 'admin_selection')) {
      showPanel();
      loadCycles().then(() => loadDashboard());
    } else {
      showDenied();
    }
  }

  /* ── boot ─────────────────────────────────────────── */
  let bootRetries = 0;
  async function boot() {
    sb = (window as any).navGetSb?.();
    const m = (window as any).navGetMember?.();
    if (!sb || !m) {
      bootRetries += 1;
      if (bootRetries >= 20) { showDenied(); return; }
      setTimeout(boot, 200);
      return;
    }
    MEMBER = m;
    bindEvents();
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);
    applyGate(MEMBER);
  }

  boot();
</script>
