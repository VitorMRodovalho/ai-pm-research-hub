              <div><span class="text-[var(--text-muted)] text-[11px]">Papel</span><br><strong>${esc(ROLE_LABELS[row.role_applied] || row.role_applied)}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Data Aplicação</span><br><strong>${row.application_date || row.created_at ? new Date(row.application_date || row.created_at).toLocaleDateString('pt-BR') : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Certificações</span><br><strong>${esc(row.certifications || '—')}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Experiência</span><br><strong>${row.experience_years ? row.experience_years + ' anos' : '—'}</strong></div>
            </div>
            <!-- Contact: Phone + WhatsApp + LinkedIn + CV + Credly -->
            <div class="flex flex-wrap gap-2 items-center text-[13px]">
