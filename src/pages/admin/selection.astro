        <div>
          <span class="font-semibold text-sm text-[var(--text-primary)]">${esc(c.member_name || '—')}</span>
          <span class="text-[11px] text-[var(--text-muted)] ml-2">${esc(c.member_role || '')}</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${c.role === 'lead' ? 'bg-purple-50 text-purple-700' : 'bg-blue-50 text-blue-700'}">${c.role}</span>
          ${c.can_interview ? '<span class="text-[10px] text-emerald-600">pode entrevistar</span>' : ''}
          <button class="text-[11px] text-red-500 hover:underline cursor-pointer bg-transparent border-0 p-0" data-action="remove-committee" data-member-id="${esc(c.member_id)}">remover</button>
        </div>
      </div>
    `).join('');
