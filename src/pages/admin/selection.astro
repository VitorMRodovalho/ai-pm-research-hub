    pmiProfileSpecialties: t('admin.selection.modal.pmiProfileSpecialties', lang),
    pmiProfileVolInterest: t('admin.selection.modal.pmiProfileVolInterest', lang),
    pmiProfileServiceHistory: t('admin.selection.modal.pmiProfileServiceHistory', lang),
    pmiProfilePreviousCycles: t('admin.selection.modal.pmiProfilePreviousCycles', lang),
    pmiProfileNonPmi: t('admin.selection.modal.pmiProfileNonPmi', lang),
