---

<AdminLayout title={t('selection.title', lang)} breadcrumbs={[{label: t('admin.breadcrumb.people', lang)},{label: t('selection.title', lang)}]}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <div class="max-w-[1200px] mx-auto px-4 pb-8">

    <!-- Loading -->
    <div id="sel-loading" class="text-center py-10 text-[var(--text-muted)]">{t('common.loading', lang)}</div>

    <!-- Access denied -->
    <div id="sel-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1F512;</div>
      <p class="font-semibold text-amber-800">{t('selection.denied', lang)}</p>
      <a href={`${langPrefix}/admin`} class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{t('admin.backToAdmin', lang)}</a>
    </div>

    <!-- Main panel -->
    <div id="sel-panel" class="hidden space-y-5">

      <!-- HEADER + CYCLE SELECTOR -->
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-2xl font-extrabold text-navy">{t('selection.title', lang)}</h1>
        <span id="sel-cycle-badge" class="text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase bg-gray-100 text-gray-600">—</span>
        <select id="sel-cycle-picker" class="ml-auto px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none"></select>
      </div>

      <!-- TABS -->
      <div class="flex gap-1 border-b border-[var(--border-default)]">
        <button data-sel-tab="pipeline" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-navy text-navy bg-transparent cursor-pointer">{t('admin.selection.tabPipeline', lang)}</button>
        <button data-sel-tab="import" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer hover:text-navy">{t('admin.selection.tabImportCsv', lang)}</button>
        <button data-sel-tab="committee" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer hover:text-navy">{t('admin.selection.committee', lang)}</button>
        <button data-sel-tab="diversity" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer hover:text-navy">{t('admin.selection.tabDiversity', lang)}</button>
      </div>

      <!-- TAB: PIPELINE -->
      <div id="tab-pipeline">
        <!-- Quick stats -->
        <div id="sel-quick-stats" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4"></div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-3 mb-4">
          <button id="recalc-rankings-btn" class="px-4 py-2 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">{t('admin.selection.recalcRankings', lang)}</button>
          <button id="start-screening-btn" class="px-4 py-2 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">{t('admin.selection.startScreening', lang)}</button>
        </div>
        <!-- p152 W4 OPP-152.6: alert when most rows have rank null (closed cycle reopened com legacy) -->
        <div id="rank-empty-alert" class="hidden mb-4 px-3 py-2 rounded-lg bg-amber-50 border border-amber-200 text-[12px] text-amber-800">
          ⚠ <strong>Rankings vazios:</strong> <span id="rank-empty-msg">a maioria das aplicações está sem rank calculado.</span> Clique <strong>Recalcular Rankings</strong> acima para regenerar via `calculate_cycle_rankings` + `recalculate_cycle_rankings`.
        </div>

        <!-- p109 Onda 4 Fase 3: quick filters (hideDecided + myEval) + p152 hideShadowVep -->
        <div class="flex flex-wrap gap-2 items-center mb-2 text-[12px]">
          <span class="text-[var(--text-muted)] font-semibold">{t('admin.selection.quickFilters', lang)}</span>
          <button id="filter-hide-decided" class="px-3 py-1 rounded-full font-semibold border border-navy/30 text-navy bg-navy/10 cursor-pointer hover:bg-navy/20" data-active="true" title={t('admin.selection.hideStatusesHint', lang)}>{t('admin.selection.hideDecided', lang)}</button>
          <button id="filter-hide-shadow-vep" class="px-3 py-1 rounded-full font-semibold border border-amber-500/30 text-amber-700 bg-amber-500/10 cursor-pointer hover:bg-amber-500/20" data-active="true" title={t('admin.selection.hideShadowVepHint', lang)}>{t('admin.selection.hideShadowVep', lang)}</button>
          <button id="filter-interview-today" class="px-3 py-1 rounded-full font-semibold border border-purple-500/30 text-[var(--text-secondary)] bg-[var(--surface-card)] cursor-pointer hover:bg-purple-500/10" data-active="false" title={t('admin.selection.interviewTodayHint', lang)}>{t('admin.selection.interviewToday', lang)}</button>
          <div class="flex rounded-lg overflow-hidden border border-[var(--border-default)]" id="filter-myeval-toggle">
            <button class="filter-myeval-btn px-3 py-1 font-semibold cursor-pointer border-0 bg-navy text-white" data-myeval="all">{t('admin.selection.allOption', lang)}</button>
            <button class="filter-myeval-btn px-3 py-1 font-semibold cursor-pointer border-0 bg-[var(--surface-card)] text-[var(--text-secondary)] hover:text-navy" data-myeval="pending_mine" title={t('admin.selection.pendingReviewHint', lang)}>{t('admin.selection.myPending', lang)}</button>
            <button class="filter-myeval-btn px-3 py-1 font-semibold cursor-pointer border-0 bg-[var(--surface-card)] text-[var(--text-secondary)] hover:text-navy" data-myeval="evaluated_mine" title={t('admin.selection.alreadyReviewedHint', lang)}>{t('admin.selection.iAlreadyEvaluated', lang)}</button>
          </div>
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-3 items-center mb-4">
          <div class="flex rounded-lg overflow-hidden border border-[var(--border-default)]" id="sel-role-toggle">
            <button class="sel-role-btn px-3 py-1.5 text-[12px] font-semibold cursor-pointer border-0 bg-navy text-white" data-role="all">{t('admin.selection.allOption', lang)}</button>
            <button class="sel-role-btn px-3 py-1.5 text-[12px] font-semibold cursor-pointer border-0 bg-[var(--surface-card)] text-[var(--text-secondary)]" data-role="researcher">{t('admin.selection.researcher', lang)}</button>
            <button class="sel-role-btn px-3 py-1.5 text-[12px] font-semibold cursor-pointer border-0 bg-[var(--surface-card)] text-[var(--text-secondary)]" data-role="leader">{t('admin.selection.leader', lang)}</button>
          </div>
          <select id="sel-chapter" class="px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none">
            <option value="all">{t('admin.selection.allChapters', lang)}</option>
          </select>
          <select id="sel-status" class="px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none">
            <option value="all">{t('admin.selection.allStatusOption', lang)}</option>
            <option value="submitted">Submitted</option><option value="screening">Screening</option>
            <option value="objective_eval">Objective Eval</option><option value="objective_cutoff">Objective Cutoff</option>
            <option value="interview_pending">Interview Pending</option><option value="interview_scheduled">Interview Scheduled</option>
            <option value="interview_done">Interview Done</option><option value="interview_noshow">Interview No-Show</option>
            <option value="final_eval">Final Eval</option><option value="approved">Approved</option>
            <option value="rejected">Rejected</option><option value="waitlist">Waitlist</option>
            <option value="converted">Converted</option><option value="withdrawn">Withdrawn</option><option value="cancelled">Cancelled</option>
          </select>
          <select id="sel-video" class="px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none">
            <option value="all">{t('admin.selection.videoFilterAll', lang)}</option>
            <option value="uploaded">{t('admin.selection.videoFilterUploaded', lang)}</option>
            <option value="opted_out">{t('admin.selection.videoFilterOptedOut', lang)}</option>
            <option value="none">{t('admin.selection.videoFilterNone', lang)}</option>
          </select>
          <input type="text" id="sel-search" placeholder={t('admin.selection.searchNameEmail', lang)}
            class="flex-1 min-w-[180px] px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] focus:outline-none" />
          <span id="sel-count" class="text-[12px] text-[var(--text-muted)] font-semibold whitespace-nowrap"></span>
        </div>

        <!-- Pipeline kanban -->
        <div id="sel-kanban" class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-4"></div>

        <!-- Table -->
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-[13px]">
              <thead>
                <tr class="bg-[var(--surface-base)] border-b border-[var(--border-default)]">
                  <th class="px-2 py-2.5 w-8"><input type="checkbox" id="sel-check-all" class="cursor-pointer" /></th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="applicant_name">{t('admin.selection.colName', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">{t('admin.selection.colTrack', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">{t('admin.selection.chapter', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="research_score">{t('admin.selection.colResearch', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="leader_score">{t('admin.selection.colLeaderShort', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="rank">{t('admin.selection.colRank', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">{t('admin.selection.colStatus', lang)}</th>
                  <th class="px-3 py-2.5 font-bold text-[var(--text-secondary)]" title={t('admin.selection.personalEvalHint', lang)}>{t('admin.selection.colMyEval', lang)}</th>
                  <th class="px-3 py-2.5 font-bold text-[var(--text-secondary)]" title={t('admin.selection.workflowIndicators', lang)}>{t('admin.selection.colPipeline', lang)}</th>
                  <th class="px-3 py-2.5 font-bold text-[var(--text-secondary)]" title={t('admin.selection.colInterviewHint', lang)}>{t('admin.selection.colInterview', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="application_date">{t('admin.selection.colDate', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">{t('admin.selection.colOnboarding', lang)}</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">{t('admin.selection.actions', lang)}</th>
                </tr>
              </thead>
              <tbody id="sel-tbody" class="divide-y divide-[var(--border-subtle)]"></tbody>
            </table>
          </div>
        </div>

        <!-- Bulk actions bar -->
        <div id="bulk-actions" class="hidden bg-[var(--surface-base)] rounded-xl px-4 py-3 mt-3 space-y-2">
          <div class="flex gap-3 items-center flex-wrap">
            <span id="bulk-count" class="text-sm font-bold text-navy">0 {t('admin.selection.bulkSelectedSuffix', lang)}</span>
            <button class="bulk-action-btn px-4 py-2 bg-emerald-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90" data-decision="approved">{t('admin.selection.bulkApprove', lang)}</button>
            <button class="bulk-action-btn px-4 py-2 bg-red-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90" data-decision="rejected">{t('admin.selection.bulkReject', lang)}</button>
