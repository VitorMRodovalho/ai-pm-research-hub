  // p152 W4 P2 OPP-152.9: per-pillar AI hint matching via keyword scan.
  // Inputs: ai_analysis (Gemini) + criterion label. Output: top-2 strengths +
  // top-2 areas_to_probe + top-1 evidence quote with label-token overlap.
  // Token = 4+ char word in lowercase. Empty if no signal.
  function matchPillarHints(aa: any, label: string): { strengths: string[]; probes: string[]; quotes: string[] } {
    const empty = { strengths: [] as string[], probes: [] as string[], quotes: [] as string[] };
    if (!aa || !label) return empty;
    const tokens = String(label).toLowerCase()
      .normalize('NFD').replace(/[̀-ͯ]/g, '') // strip accents
      .split(/[\s,/.()\-]+/)
      .filter(t => t.length >= 4);
    if (!tokens.length) return empty;
    const norm = (s: string) => String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    const matches = (arr: any) => (Array.isArray(arr) ? arr : []).filter((s: any) => {
      const lower = norm(s);
      return tokens.some(t => lower.includes(t));
    });
    return {
      strengths: matches(aa.key_strengths).slice(0, 2),
      probes: matches(aa.areas_to_probe).slice(0, 2),
      quotes: matches(aa.evidence_quotes).slice(0, 1),
    };
  }

  function renderPillarHintsCallout(aa: any, label: string): string {
    const h = matchPillarHints(aa, label);
    if (!h.strengths.length && !h.probes.length && !h.quotes.length) return '';
    return `<div class="bg-purple-50 border-l-4 border-purple-300 rounded-r p-2 mb-2 text-[11px]">
      <div class="text-[9px] font-bold uppercase text-purple-700 mb-1">🤖 IA sugere para este pilar</div>
      ${h.strengths.length ? `<div class="mb-0.5"><strong class="text-emerald-700">💪 Forças:</strong> <span class="text-[var(--text-primary)]">${h.strengths.map((s: string) => esc(s)).join(' · ')}</span></div>` : ''}
      ${h.probes.length ? `<div class="mb-0.5"><strong class="text-blue-700">🔎 Probar:</strong> <span class="text-[var(--text-primary)]">${h.probes.map((s: string) => esc(s)).join(' · ')}</span></div>` : ''}
      ${h.quotes.length ? `<div class="text-[10px] italic text-purple-700">📝 "${h.quotes.map((s: string) => esc(s)).join('" · "')}"</div>` : ''}
    </div>`;
  }

