---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import Toast from '../../components/ui/Toast.astro';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---

<AdminLayout title={t('selection.title', lang)} breadcrumbs={[{label:'Pessoas'},{label: t('selection.title', lang)}]}>
  <div class="max-w-[1200px] mx-auto px-4 pb-8">

    <!-- Loading -->
    <div id="sel-loading" class="text-center py-10 text-[var(--text-muted)]">{t('common.loading', lang)}</div>

    <!-- Access denied -->
    <div id="sel-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1F512;</div>
      <p class="font-semibold text-amber-800">{t('selection.denied', lang)}</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{t('admin.backToAdmin', lang)}</a>
    </div>

    <!-- Main panel -->
    <div id="sel-panel" class="hidden space-y-5">

      <!-- HEADER + CYCLE SELECTOR -->
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-2xl font-extrabold text-navy">{t('selection.title', lang)}</h1>
        <span id="sel-cycle-badge" class="text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase bg-gray-100 text-gray-600">—</span>
        <select id="sel-cycle-picker" class="ml-auto px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none"></select>
      </div>

      <!-- TABS -->
      <div class="flex gap-1 border-b border-[var(--border-default)]">
        <button data-sel-tab="pipeline" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-navy text-navy bg-transparent cursor-pointer">Pipeline</button>
        <button data-sel-tab="import" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer hover:text-navy">Import CSV</button>
        <button data-sel-tab="committee" class="sel-tab-btn px-4 py-2 text-sm font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer hover:text-navy">Comitê</button>
      </div>

      <!-- TAB: PIPELINE -->
      <div id="tab-pipeline">
        <!-- Quick stats -->
        <div id="sel-quick-stats" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4"></div>

        <!-- Action buttons -->
        <div class="flex flex-wrap gap-3 mb-4">
          <button id="recalc-rankings-btn" class="px-4 py-2 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Recalcular Rankings</button>
          <button id="start-screening-btn" class="px-4 py-2 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Iniciar Triagem</button>
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-3 items-center mb-4">
          <div class="flex rounded-lg overflow-hidden border border-[var(--border-default)]" id="sel-role-toggle">
            <button class="sel-role-btn px-3 py-1.5 text-[12px] font-semibold cursor-pointer border-0 bg-navy text-white" data-role="all">Todos</button>
            <button class="sel-role-btn px-3 py-1.5 text-[12px] font-semibold cursor-pointer border-0 bg-[var(--surface-card)] text-[var(--text-secondary)]" data-role="researcher">Pesquisador</button>
            <button class="sel-role-btn px-3 py-1.5 text-[12px] font-semibold cursor-pointer border-0 bg-[var(--surface-card)] text-[var(--text-secondary)]" data-role="leader">Líder</button>
          </div>
          <select id="sel-chapter" class="px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none">
            <option value="all">Todos os Capítulos</option>
          </select>
          <select id="sel-status" class="px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] text-[var(--text-primary)] focus:outline-none">
            <option value="all">Todos os Status</option>
            <option value="submitted">Submitted</option><option value="screening">Screening</option>
            <option value="objective_eval">Objective Eval</option><option value="objective_cutoff">Objective Cutoff</option>
            <option value="interview_pending">Interview Pending</option><option value="interview_scheduled">Interview Scheduled</option>
            <option value="interview_done">Interview Done</option><option value="interview_noshow">Interview No-Show</option>
            <option value="final_eval">Final Eval</option><option value="approved">Approved</option>
            <option value="rejected">Rejected</option><option value="waitlist">Waitlist</option>
            <option value="converted">Converted</option><option value="withdrawn">Withdrawn</option><option value="cancelled">Cancelled</option>
          </select>
          <input type="text" id="sel-search" placeholder="Buscar nome ou e-mail..."
            class="flex-1 min-w-[180px] px-3 py-1.5 text-[12px] border border-[var(--border-default)] rounded-lg bg-[var(--surface-card)] focus:outline-none" />
          <span id="sel-count" class="text-[12px] text-[var(--text-muted)] font-semibold whitespace-nowrap"></span>
        </div>

        <!-- Pipeline kanban -->
        <div id="sel-kanban" class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-4"></div>

        <!-- Table -->
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left text-[13px]">
              <thead>
                <tr class="bg-[var(--surface-base)] border-b border-[var(--border-default)]">
                  <th class="px-2 py-2.5 w-8"><input type="checkbox" id="sel-check-all" class="cursor-pointer" /></th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="applicant_name">Nome</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">Papel</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">Capítulo</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="objective_score">Obj. Score</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="final_score">Final Score</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)] cursor-pointer hover:text-navy" data-sort="rank_chapter">Rank</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">Status</th>
                  <th class="px-4 py-2.5 font-bold text-[var(--text-secondary)]">Ações</th>
                </tr>
              </thead>
              <tbody id="sel-tbody" class="divide-y divide-[var(--border-subtle)]"></tbody>
            </table>
          </div>
        </div>

        <!-- Bulk actions bar -->
        <div id="bulk-actions" class="hidden flex gap-3 items-center bg-[var(--surface-base)] rounded-xl px-4 py-3 mt-3">
          <span id="bulk-count" class="text-sm font-bold text-navy">0 selecionados</span>
          <button class="bulk-action-btn px-4 py-2 bg-emerald-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90" data-decision="approved">Aprovar</button>
          <button class="bulk-action-btn px-4 py-2 bg-red-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90" data-decision="rejected">Rejeitar</button>
          <button class="bulk-action-btn px-4 py-2 bg-amber-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90" data-decision="waitlist">Lista Espera</button>
        </div>
      </div>

      <!-- TAB: IMPORT CSV -->
      <div id="tab-import" class="hidden space-y-4">
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-6 space-y-4">
          <h2 class="text-lg font-bold text-navy">Importar CSV do PMI VEP</h2>
          <p class="text-sm text-[var(--text-secondary)]">Faça upload do CSV exportado do PMI Volunteer Engagement Platform. O sistema detecta candidatos duplicados, membros retornantes e capítulos parceiros automaticamente.</p>

          <div class="flex flex-wrap gap-4 items-end">
            <div>
              <label class="block text-[12px] font-semibold text-[var(--text-secondary)] mb-1">Opportunity ID (do PMI VEP)</label>
              <input type="text" id="import-opportunity" value="" placeholder="Ex: 64967"
                class="px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] w-40" />
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-[var(--text-secondary)] mb-1">Título da vaga</label>
              <input type="text" id="import-opportunity-title" value="" placeholder="Ex: Pesquisador e multiplicador"
                class="px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] w-64" />
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-[var(--text-secondary)] mb-1">Papel default</label>
              <select id="import-role" class="px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
                <option value="researcher">Pesquisador</option>
                <option value="leader">Líder</option>
              </select>
            </div>
          </div>
          <p class="text-[11px] text-[var(--text-muted)]">O Opportunity ID está na URL do VEP: volunteer.pmi.org/.../opportunity/<strong>64967</strong>. O papel default é aplicado a todos os candidatos do CSV, podendo ser alterado individualmente depois.</p>

          <!-- Drop zone -->
          <div id="csv-dropzone" class="border-2 border-dashed border-[var(--border-default)] rounded-xl p-8 text-center cursor-pointer hover:border-navy hover:bg-[var(--surface-hover)] transition-all">
            <div class="text-3xl mb-2">&#x1F4C4;</div>
            <p class="text-sm font-semibold text-[var(--text-secondary)]">Arraste o CSV aqui ou clique para selecionar</p>
            <p class="text-[11px] text-[var(--text-muted)] mt-1">Formato: CSV exportado do PMI VEP (Opportunity Applications)</p>
            <input type="file" id="csv-file-input" accept=".csv" class="hidden" />
          </div>

          <!-- Preview -->
          <div id="csv-preview" class="hidden space-y-3">
            <div id="csv-summary" class="flex flex-wrap gap-3"></div>
            <div class="overflow-x-auto max-h-[300px] overflow-y-auto">
              <table class="w-full text-left text-[12px]">
                <thead class="sticky top-0 bg-[var(--surface-base)]">
                  <tr>
                    <th class="px-3 py-2 font-bold text-[var(--text-secondary)]">Nome</th>
                    <th class="px-3 py-2 font-bold text-[var(--text-secondary)]">Email</th>
                    <th class="px-3 py-2 font-bold text-[var(--text-secondary)]">Capítulo</th>
                    <th class="px-3 py-2 font-bold text-[var(--text-secondary)]">VEP Status</th>
                    <th class="px-3 py-2 font-bold text-[var(--text-secondary)]">Ação</th>
                  </tr>
                </thead>
                <tbody id="csv-preview-body"></tbody>
              </table>
            </div>
            <div class="flex gap-3">
              <button id="csv-import-btn" class="px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Importar candidatos</button>
              <button id="csv-cancel-btn" class="px-5 py-2.5 bg-[var(--surface-hover)] text-[var(--text-secondary)] rounded-xl text-sm font-semibold cursor-pointer border-0">Cancelar</button>
            </div>
          </div>

          <!-- Result -->
          <div id="csv-result" class="hidden"></div>
        </div>
      </div>

      <!-- TAB: COMMITTEE -->
      <div id="tab-committee" class="hidden space-y-4">
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-6 space-y-4">
          <div class="flex items-center justify-between">
            <h2 class="text-lg font-bold text-navy">Comitê de Seleção</h2>
          </div>
          <p class="text-sm text-[var(--text-secondary)]">Membros do comitê avaliam candidatos em revisão cega. Mínimo de 2 avaliadores por candidato.</p>

          <!-- Add member search -->
          <div class="bg-[var(--surface-base)] rounded-xl p-4 space-y-3">
            <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">Adicionar membro ao comitê</h4>
            <div class="flex gap-3 items-end">
              <div class="flex-1 relative">
                <input type="text" id="committee-search" placeholder="Buscar por nome..."
                  class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] focus:outline-none focus:ring-2 focus:ring-navy/40" />
                <div id="committee-search-results" class="hidden absolute z-20 w-full mt-1 bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl shadow-xl max-h-[200px] overflow-y-auto"></div>
              </div>
              <select id="committee-role-select" class="px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
                <option value="evaluator">Avaliador</option>
                <option value="lead">Líder do Comitê</option>
                <option value="observer">Observador</option>
              </select>
            </div>
          </div>

          <div id="committee-list" class="space-y-2"></div>
        </div>
      </div>

    </div>
  </div>

  <!-- APPLICANT DETAIL MODAL -->
  <div id="applicant-modal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-[var(--surface-card)] rounded-2xl shadow-2xl max-w-[800px] w-full max-h-[90vh] overflow-y-auto">
      <div class="sticky top-0 bg-[var(--surface-card)] border-b border-[var(--border-default)] px-6 py-4 flex items-center justify-between rounded-t-2xl z-10">
        <h2 id="modal-name" class="text-lg font-extrabold text-navy">—</h2>
        <button id="modal-close" class="text-2xl text-[var(--text-muted)] cursor-pointer bg-transparent border-0 hover:text-navy">&times;</button>
      </div>
      <div class="p-6 space-y-5" id="modal-body">
        <!-- Populated dynamically -->
      </div>
    </div>
  </div>

  <Toast />
  <span id="ai18n-nor" class="hidden">{t('admin.noResults', lang)}</span>
</AdminLayout>

<script>
  import { canAccessAdminRoute } from '../../lib/admin/constants';

  /* ── state ────────────────────────────────────────── */
  let sb: any = null;
  let MEMBER: any = null;
  let allRows: any[] = [];
  let filteredRows: any[] = [];
  let currentCycleId: string | null = null;
  let allCycles: any[] = [];
  let csvParsedRows: any[] = [];

  let filterRole = 'all';
  let filterChapter = 'all';
  let filterStatus = 'all';
  let filterSearch = '';
  let sortCol = 'final_score';
  let sortAsc = false;

  /* ── helpers ──────────────────────────────────────── */
  function esc(s: any): string {
    return String(s ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function toast(msg: string, type: 'success' | 'error' = 'success') {
    const el = document.getElementById('toast-container');
    if (!el) return;
    const div = document.createElement('div');
    div.className = `px-4 py-3 rounded-xl text-sm font-semibold shadow-lg ${type === 'error' ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white'}`;
    div.textContent = msg;
    el.appendChild(div);
    setTimeout(() => div.remove(), 4000);
  }

  function showDenied() {
    document.getElementById('sel-loading')?.classList.add('hidden');
    document.getElementById('sel-denied')?.classList.remove('hidden');
  }

  function showPanel() {
    document.getElementById('sel-loading')?.classList.add('hidden');
    document.getElementById('sel-panel')?.classList.remove('hidden');
  }

  /* ── tabs ─────────────────────────────────────────── */
  function switchTab(name: string) {
    document.querySelectorAll('.sel-tab-btn').forEach(btn => {
      const isActive = (btn as HTMLElement).dataset.selTab === name;
      btn.classList.toggle('border-navy', isActive);
      btn.classList.toggle('text-navy', isActive);
      btn.classList.toggle('border-transparent', !isActive);
      btn.classList.toggle('text-[var(--text-secondary)]', !isActive);
    });
    ['pipeline', 'import', 'committee'].forEach(t => {
      document.getElementById(`tab-${t}`)?.classList.toggle('hidden', t !== name);
    });
  }

  /* ── status helpers ───────────────────────────────── */
  const STATUS_GROUPS: Record<string, { label: string; color: string; bg: string; statuses: string[] }> = {
    submitted:  { label: 'Submetidos',  color: 'text-gray-700',    bg: 'bg-gray-100',    statuses: ['submitted'] },
    evaluation: { label: 'Avaliação',   color: 'text-blue-700',    bg: 'bg-blue-50',     statuses: ['screening', 'objective_eval', 'objective_cutoff'] },
    interview:  { label: 'Entrevista',  color: 'text-yellow-700',  bg: 'bg-yellow-50',   statuses: ['interview_pending', 'interview_scheduled', 'interview_done', 'interview_noshow'] },
    approved:   { label: 'Aprovados',   color: 'text-emerald-700', bg: 'bg-emerald-50',  statuses: ['approved', 'converted'] },
    rejected:   { label: 'Rejeitados',  color: 'text-red-700',     bg: 'bg-red-50',      statuses: ['rejected', 'cancelled', 'withdrawn'] },
  };

  function statusGroup(status: string): string {
    for (const [key, g] of Object.entries(STATUS_GROUPS)) {
      if (g.statuses.includes(status)) return key;
    }
    return 'submitted';
  }

  const STATUS_BADGE: Record<string, { color: string; bg: string }> = {
    submitted: { color: 'text-gray-700', bg: 'bg-gray-100' },
    screening: { color: 'text-blue-700', bg: 'bg-blue-50' },
    objective_eval: { color: 'text-blue-700', bg: 'bg-blue-50' },
    objective_cutoff: { color: 'text-blue-700', bg: 'bg-blue-50' },
    interview_pending: { color: 'text-yellow-700', bg: 'bg-yellow-50' },
    interview_scheduled: { color: 'text-yellow-700', bg: 'bg-yellow-50' },
    interview_done: { color: 'text-yellow-700', bg: 'bg-yellow-50' },
    interview_noshow: { color: 'text-orange-700', bg: 'bg-orange-50' },
    final_eval: { color: 'text-indigo-700', bg: 'bg-indigo-50' },
    approved: { color: 'text-emerald-700', bg: 'bg-emerald-50' },
    converted: { color: 'text-emerald-700', bg: 'bg-emerald-50' },
    rejected: { color: 'text-red-700', bg: 'bg-red-50' },
    cancelled: { color: 'text-red-700', bg: 'bg-red-50' },
    withdrawn: { color: 'text-red-600', bg: 'bg-red-50' },
    waitlist: { color: 'text-amber-700', bg: 'bg-amber-50' },
  };

  const ROLE_LABELS: Record<string, string> = { researcher: 'Pesquisador', leader: 'Líder', both: 'Ambos' };

  const CYCLE_STATUS_COLORS: Record<string, { color: string; bg: string }> = {
    draft: { color: 'text-gray-600', bg: 'bg-gray-100' },
    open: { color: 'text-emerald-700', bg: 'bg-emerald-50' },
    evaluation: { color: 'text-blue-700', bg: 'bg-blue-50' },
    interview: { color: 'text-yellow-700', bg: 'bg-yellow-50' },
    decision: { color: 'text-purple-700', bg: 'bg-purple-50' },
    closed: { color: 'text-red-700', bg: 'bg-red-50' },
  };

  const STATUS_LABELS: Record<string, string> = {
    submitted: 'Submetido', screening: 'Triagem', objective_eval: 'Avaliação Objetiva',
    objective_cutoff: 'Abaixo do Corte', interview_pending: 'Aguardando Entrevista',
    interview_scheduled: 'Entrevista Agendada', interview_done: 'Entrevistado',
    interview_noshow: 'No-Show', final_eval: 'Avaliação Final',
    approved: 'Aprovado', rejected: 'Rejeitado', waitlist: 'Lista de Espera',
    converted: 'Convertido', withdrawn: 'Desistiu', cancelled: 'Cancelado',
  };

  /* ── load cycles ──────────────────────────────────── */
  async function loadCycles() {
    const { data } = await sb.rpc('get_selection_cycles');
    allCycles = Array.isArray(data) ? data : [];
    const picker = document.getElementById('sel-cycle-picker') as HTMLSelectElement;
    if (picker && allCycles.length) {
      picker.innerHTML = allCycles.map((c: any) =>
        `<option value="${c.id}">${esc(c.title)} (${c.status})</option>`
      ).join('');
      currentCycleId = allCycles[0].id;
    }
  }

  /* ── load data via RPC ────────────────────────────── */
  async function loadDashboard() {
    if (!sb) return;
    try {
      const { data: dashboard } = await sb.rpc('get_selection_dashboard');
      if (dashboard?.error === 'Unauthorized') { showDenied(); return; }
      if (dashboard?.error) { console.warn('Dashboard error:', dashboard.error); }
      const cycle = dashboard?.cycle;
      const applications = dashboard?.applications || [];

      if (cycle) {
        currentCycleId = cycle.id;
        const badge = document.getElementById('sel-cycle-badge');
        if (badge) {
          const cs = CYCLE_STATUS_COLORS[cycle.status] || CYCLE_STATUS_COLORS.draft;
          badge.className = `text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase ${cs.bg} ${cs.color}`;
          badge.textContent = cycle.status.toUpperCase();
        }
        // Sync cycle picker
        const picker = document.getElementById('sel-cycle-picker') as HTMLSelectElement;
        if (picker) picker.value = cycle.id;
      }

      allRows = applications;
      populateChapterDropdown();
      applyFilters();
    } catch (e: any) {
      console.error('Selection load:', e);
      const tbody = document.getElementById('sel-tbody');
      if (tbody) tbody.innerHTML = `<tr><td colspan="9" class="px-4 py-6 text-center text-red-500">Erro: ${esc(e.message || 'desconhecido')}</td></tr>`;
    }
  }

  function populateChapterDropdown() {
    const sel = document.getElementById('sel-chapter') as HTMLSelectElement | null;
    if (!sel) return;
    const chapters = [...new Set(allRows.map(r => r.chapter).filter(Boolean))].sort();
    const current = sel.value;
    sel.innerHTML = '<option value="all">Todos os Capítulos</option>' +
      chapters.map(c => `<option value="${esc(c)}">${esc(c)}</option>`).join('');
    sel.value = current;
  }

  /* ── filtering + sorting ──────────────────────────── */
  function applyFilters() {
    const search = filterSearch.toLowerCase();
    filteredRows = allRows.filter(r => {
      if (filterRole !== 'all' && r.role_applied !== filterRole) return false;
      if (filterChapter !== 'all' && r.chapter !== filterChapter) return false;
      if (filterStatus !== 'all' && r.status !== filterStatus) return false;
      if (search) {
        const name = (r.applicant_name || '').toLowerCase();
        const email = (r.email || '').toLowerCase();
        if (!name.includes(search) && !email.includes(search)) return false;
      }
      return true;
    });
    filteredRows.sort((a, b) => {
      let va = a[sortCol], vb = b[sortCol];
      if (va == null && vb == null) return 0;
      if (va == null) return 1;
      if (vb == null) return -1;
      if (typeof va === 'string') va = va.toLowerCase();
      if (typeof vb === 'string') vb = vb.toLowerCase();
      return (va < vb ? -1 : va > vb ? 1 : 0) * (sortAsc ? 1 : -1);
    });
    renderQuickStats();
    renderKanban();
    renderTable();
  }

  function renderQuickStats() {
    const el = document.getElementById('sel-quick-stats');
    if (!el) return;
    const total = filteredRows.length;
    const approved = filteredRows.filter(r => ['approved', 'converted'].includes(r.status)).length;
    const rejected = filteredRows.filter(r => ['rejected', 'cancelled', 'withdrawn'].includes(r.status)).length;
    const pending = total - approved - rejected;
    const stats = [
      { label: 'Total', value: total, color: 'text-navy' },
      { label: 'Aprovados', value: approved, color: 'text-emerald-600' },
      { label: 'Rejeitados', value: rejected, color: 'text-red-600' },
      { label: 'Pendentes', value: pending, color: 'text-amber-600' },
    ];
    el.innerHTML = stats.map(s =>
      `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3 text-center">
        <div class="text-xl font-extrabold ${s.color}">${s.value}</div>
        <div class="text-[.65rem] text-[var(--text-secondary)] font-semibold">${esc(s.label)}</div>
      </div>`
    ).join('');
  }

  function renderKanban() {
    const el = document.getElementById('sel-kanban');
    if (!el) return;
    const counts: Record<string, number> = {};
    for (const key of Object.keys(STATUS_GROUPS)) counts[key] = 0;
    filteredRows.forEach(r => { counts[statusGroup(r.status)]++; });
    el.innerHTML = Object.entries(STATUS_GROUPS).map(([key, g]) =>
      `<div class="border border-[var(--border-default)] rounded-xl p-3 text-center ${g.bg}">
        <div class="text-2xl font-extrabold ${g.color}">${counts[key]}</div>
        <div class="text-[.65rem] ${g.color} font-bold">${esc(g.label)}</div>
      </div>`
    ).join('');
  }

  function renderTable() {
    const tbody = document.getElementById('sel-tbody');
    const countEl = document.getElementById('sel-count');
    if (!tbody) return;
    if (countEl) countEl.textContent = `${filteredRows.length} resultado${filteredRows.length !== 1 ? 's' : ''}`;
    if (!filteredRows.length) {
      tbody.innerHTML = `<tr><td colspan="9" class="px-4 py-6 text-center text-[var(--text-muted)]">${document.getElementById('ai18n-nor')?.textContent || 'Nenhum candidato'}</td></tr>`;
      return;
    }
    tbody.innerHTML = filteredRows.map(r => {
      const sb2 = STATUS_BADGE[r.status] || STATUS_BADGE.submitted;
      const objScore = r.objective_score != null ? Number(r.objective_score).toFixed(1) : '—';
      const finalScore = r.final_score != null ? Number(r.final_score).toFixed(1) : '—';
      const rank = r.rank_chapter != null ? `#${r.rank_chapter}` : '—';
      const roleLabel = ROLE_LABELS[r.role_applied] || r.role_applied || '—';
      const statusLabel = STATUS_LABELS[r.status] || r.status?.replace(/_/g, ' ') || '—';
      return `<tr class="hover:bg-[var(--surface-hover)] cursor-pointer" data-action="view-applicant" data-id="${esc(r.id)}">
        <td class="px-2 py-2.5 w-8" onclick="event.stopPropagation()"><input type="checkbox" class="sel-row-check cursor-pointer" value="${esc(r.id)}" /></td>
        <td class="px-4 py-2.5 font-semibold text-navy">${esc(r.applicant_name)}</td>
        <td class="px-4 py-2.5 text-[12px]">${esc(roleLabel)}</td>
        <td class="px-4 py-2.5 text-[12px] text-[var(--text-secondary)]">${esc(r.chapter || '—')}</td>
        <td class="px-4 py-2.5 text-[12px] font-mono font-semibold">${objScore}</td>
        <td class="px-4 py-2.5 text-[12px] font-mono font-bold text-navy">${finalScore}</td>
        <td class="px-4 py-2.5 text-[12px] font-semibold">${rank}</td>
        <td class="px-4 py-2.5"><span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${sb2.bg} ${sb2.color}">${esc(statusLabel)}</span></td>
        <td class="px-4 py-2.5">
          <button class="text-[11px] text-purple-600 hover:underline cursor-pointer bg-transparent border-0 p-0" data-action="view-applicant" data-id="${esc(r.id)}">Detalhes</button>
        </td>
      </tr>`;
    }).join('');
    updateBulkBar();
  }

  /* ── applicant detail modal ───────────────────────── */
  function openApplicantModal(id: string) {
    const row = allRows.find(r => r.id === id);
    if (!row) return;
    const modal = document.getElementById('applicant-modal');
    const nameEl = document.getElementById('modal-name');
    const body = document.getElementById('modal-body');
    if (!modal || !body || !nameEl) return;

    nameEl.textContent = row.applicant_name || '—';
    const sb2 = STATUS_BADGE[row.status] || STATUS_BADGE.submitted;
    const statusLabel = STATUS_LABELS[row.status] || row.status;

    body.innerHTML = `
      <!-- Modal tabs -->
      <div class="flex gap-1 border-b border-[var(--border-default)] mb-4">
        <button data-modal-tab="info" class="modal-tab-btn px-3 py-1.5 text-[12px] font-semibold rounded-t-lg border-b-2 border-navy text-navy bg-transparent cursor-pointer">Informações</button>
        <button data-modal-tab="evaluate" class="modal-tab-btn px-3 py-1.5 text-[12px] font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer">Avaliar</button>
        <button data-modal-tab="interview" class="modal-tab-btn px-3 py-1.5 text-[12px] font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer">Entrevista</button>
      </div>

      <!-- TAB: Info -->
      <div id="modal-tab-info">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-4">
            <div class="grid grid-cols-2 gap-3 text-[13px]">
              <div><span class="text-[var(--text-muted)] text-[11px]">Email</span><br><strong>${esc(row.email)}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Capítulo</span><br><strong>${esc(row.chapter || '—')}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Papel</span><br><strong>${esc(ROLE_LABELS[row.role_applied] || row.role_applied)}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Status</span><br><span class="text-[11px] font-bold px-2 py-0.5 rounded-full ${sb2.bg} ${sb2.color}">${esc(statusLabel)}</span></div>
            </div>
            ${row.motivation ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">Motivação</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[200px] overflow-y-auto">${esc(row.motivation)}</p></div>` : ''}
            <div class="grid grid-cols-2 gap-3 text-[13px]">
              <div><span class="text-[var(--text-muted)] text-[11px]">Obj. Score</span><br><strong class="text-lg">${row.objective_score != null ? Number(row.objective_score).toFixed(1) : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Final Score</span><br><strong class="text-lg text-navy">${row.final_score != null ? Number(row.final_score).toFixed(1) : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Rank (Cap.)</span><br><strong>${row.rank_chapter != null ? '#' + row.rank_chapter : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">Rank (Geral)</span><br><strong>${row.rank_overall != null ? '#' + row.rank_overall : '—'}</strong></div>
            </div>
            ${row.tags?.length ? `<div class="flex gap-1 flex-wrap">${row.tags.map((t: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 font-semibold">${esc(t)}</span>`).join('')}</div>` : ''}
          </div>
          <div class="space-y-4">
            <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">Alterar Status</h4>
            <select id="modal-status-select" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
              ${Object.entries(STATUS_LABELS).map(([k, v]) => `<option value="${k}" ${k === row.status ? 'selected' : ''}>${v}</option>`).join('')}
            </select>
            <textarea id="modal-feedback" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="Feedback / observações...">${esc(row.feedback || '')}</textarea>
            <button id="modal-save-btn" data-id="${esc(row.id)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Salvar alterações</button>
          </div>
        </div>
      </div>

      <!-- TAB: Evaluate (blind review) -->
      <div id="modal-tab-evaluate" class="hidden">
        <div id="eval-form-container" class="space-y-4">
          <p class="text-sm text-[var(--text-muted)]">Carregando formulário de avaliação...</p>
        </div>
      </div>

      <!-- TAB: Interview -->
      <div id="modal-tab-interview" class="hidden">
        <div class="space-y-4">
          <h4 class="text-sm font-bold text-navy">Agendar Entrevista</h4>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] font-semibold text-[var(--text-secondary)] mb-1">Data/Hora</label>
              <input type="datetime-local" id="interview-datetime" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
            </div>
            <div>
              <label class="block text-[11px] font-semibold text-[var(--text-secondary)] mb-1">Duração (min)</label>
              <input type="number" id="interview-duration" value="30" min="15" max="120" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
            </div>
          </div>
          <button id="schedule-interview-btn" data-app-id="${esc(row.id)}" class="px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Agendar</button>
        </div>
      </div>
    `;

    // Modal tab switching
    body.querySelectorAll('.modal-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.modalTab;
        body.querySelectorAll('.modal-tab-btn').forEach(b => {
          const isActive = (b as HTMLElement).dataset.modalTab === tab;
          b.classList.toggle('border-navy', isActive);
          b.classList.toggle('text-navy', isActive);
          b.classList.toggle('border-transparent', !isActive);
          b.classList.toggle('text-[var(--text-secondary)]', !isActive);
        });
        ['info', 'evaluate', 'interview'].forEach(t => {
          body.querySelector(`#modal-tab-${t}`)?.classList.toggle('hidden', t !== tab);
        });
        if (tab === 'evaluate') loadEvaluationForm(row.id);
        if (tab === 'interview') loadInterviewForm(row);
      });
    });

    // Interview scheduling
    body.querySelector('#schedule-interview-btn')?.addEventListener('click', async () => {
      const dt = (body.querySelector('#interview-datetime') as HTMLInputElement)?.value;
      const dur = parseInt((body.querySelector('#interview-duration') as HTMLInputElement)?.value || '30', 10);
      if (!dt) { toast('Selecione data e hora', 'error'); return; }
      try {
        const { data, error } = await sb.rpc('schedule_interview', {
          p_application_id: row.id,
          p_interviewer_ids: [MEMBER.id],
          p_scheduled_at: new Date(dt).toISOString(),
          p_duration_minutes: dur,
        });
        if (error) throw error;
        toast('Entrevista agendada');
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) { toast(e.message || 'Erro ao agendar', 'error'); }
    });

    // Save handler — uses admin_update_application RPC (validates auth, seeds onboarding on approve)
    body.querySelector('#modal-save-btn')?.addEventListener('click', async () => {
      const newStatus = (body.querySelector('#modal-status-select') as HTMLSelectElement)?.value;
      const feedback = (body.querySelector('#modal-feedback') as HTMLTextAreaElement)?.value;
      const btn = body.querySelector('#modal-save-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }
      try {
        const { data, error } = await sb.rpc('admin_update_application', {
          p_application_id: row.id,
          p_data: { status: newStatus, feedback },
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        const msg = newStatus === 'approved' ? 'Candidato aprovado — onboarding iniciado' : 'Candidato atualizado';
        toast(msg);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao salvar', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Salvar alterações'; }
      }
    });

    modal.classList.remove('hidden');
  }

  /* ── evaluation form ──────────────────────────────── */
  async function loadEvaluationForm(applicationId: string) {
    const container = document.getElementById('eval-form-container');
    if (!container) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando...</p>';
    try {
      const { data, error } = await sb.rpc('get_evaluation_form', {
        p_application_id: applicationId, p_evaluation_type: 'objective',
      });
      if (error) throw error;
      if (!data) throw new Error('Sem dados');

      const criteria = data.criteria || [];
      const draft = data.draft;
      const isLocked = data.is_locked;
      const app = data.application || {};

      // Gap 8: Build essay display
      const essayFields = [
        { key: 'motivation_letter', label: 'Motivacao' },
        { key: 'areas_of_interest', label: 'Perfil / Areas de Interesse' },
        { key: 'academic_background', label: 'Familiaridade com PMBOK' },
        { key: 'availability_declared', label: 'Disponibilidade' },
        { key: 'proposed_theme', label: 'Tema Proposto' },
      ];
      const essayItems = essayFields
        .filter(f => app[f.key])
        .map(f => `<div class="mb-2"><h5 class="text-[11px] font-bold text-[var(--text-secondary)] mb-0.5">${esc(f.label)}</h5><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-2.5 whitespace-pre-wrap max-h-[150px] overflow-y-auto">${esc(app[f.key])}</p></div>`)
        .join('');
      const resumeLink = app.resume_url ? `<div class="mb-2"><a href="${esc(app.resume_url)}" target="_blank" rel="noopener noreferrer" class="text-[12px] text-purple-600 hover:underline font-semibold">Ver CV / Curriculo</a></div>` : '';
      const essaySection = (essayItems || resumeLink) ? `
        <details open class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl mb-4">
          <summary class="px-4 py-3 text-sm font-bold text-navy cursor-pointer">Respostas do Candidato</summary>
          <div class="px-4 pb-3">${essayItems}${resumeLink}</div>
        </details>` : '';

      // Gap 6: Check if leader role
      const isLeader = app.role_applied === 'leader';

      container.innerHTML = `
        <div class="space-y-4">
          ${essaySection}
          ${isLocked ? '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold">Avaliacao ja submetida e bloqueada.</div>' : ''}
          <h4 class="text-sm font-bold text-navy">Avaliacao Objetiva (0-10)</h4>
          ${criteria.map((c: any) => `
            <div class="bg-[var(--surface-base)] rounded-xl p-3">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight})</span></label>
                <span class="eval-score-display text-sm font-bold text-navy" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
              </div>
              <input type="range" min="0" max="10" step="1" value="${draft?.scores?.[c.key] ?? 5}"
                data-eval-key="${esc(c.key)}" ${isLocked ? 'disabled' : ''}
                class="w-full accent-navy" />
              <p class="text-[10px] text-[var(--text-muted)] mt-1">${esc(c.guide || '')}</p>
            </div>
          `).join('')}
          <textarea id="eval-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas privadas (so voce ve)..." ${isLocked ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>
          ${!isLocked ? `<button id="submit-evaluation-btn" data-app-id="${esc(applicationId)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliacao (bloqueia edicao)</button>` : ''}
          ${isLocked ? `<button id="view-results-btn" data-app-id="${esc(applicationId)}" class="w-full px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90 mt-2">Ver Resultados Consolidados</button>` : ''}
          <div id="leader-extra-container"></div>
        </div>
      `;

      // Range slider live display
      container.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.evalKey;
        slider.addEventListener('input', () => {
          const display = container.querySelector(`.eval-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Submit evaluation
      container.querySelector('#submit-evaluation-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        container.querySelectorAll<HTMLInputElement>('input[type="range"][data-eval-key]').forEach(slider => {
          if (slider.dataset.evalKey) scores[slider.dataset.evalKey] = parseInt(slider.value, 10);
        });
        const notes = (container.querySelector('#eval-notes') as HTMLTextAreaElement)?.value || '';
        const btn = container.querySelector('#submit-evaluation-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Submetendo...'; }
        try {
          const { data: result, error } = await sb.rpc('submit_evaluation', {
            p_application_id: applicationId, p_evaluation_type: 'objective',
            p_scores: scores, p_notes: notes,
          });
          if (error) throw error;
          toast(result?.all_submitted ? `Avaliacao submetida — PERT: ${result.pert_score}` : 'Avaliacao submetida');
          loadEvaluationForm(applicationId);
          loadDashboard();
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn) { btn.disabled = false; btn.textContent = 'Submeter Avaliacao'; }
        }
      });

      // Gap 1: View results button
      container.querySelector('#view-results-btn')?.addEventListener('click', () => {
        loadEvaluationResults(applicationId);
      });

      // Gap 6: Leader extra criteria
      if (isLeader) {
        loadLeaderExtraCriteria(applicationId);
      }
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar formulario')}</p>`;
    }
  }

  /* ── leader extra criteria (Gap 6) ───────────────── */
  async function loadLeaderExtraCriteria(applicationId: string) {
    const leaderContainer = document.getElementById('leader-extra-container');
    if (!leaderContainer) return;
    try {
      const { data, error } = await sb.rpc('get_evaluation_form', {
        p_application_id: applicationId, p_evaluation_type: 'leader_extra',
      });
      if (error) throw error;
      if (!data) return;

      const criteria = data.criteria || [];
      if (!criteria.length) return;
      const draft = data.draft;
      const isLocked = data.is_locked;

      leaderContainer.innerHTML = `
        <div class="space-y-4 mt-4 border-t border-[var(--border-default)] pt-4">
          ${isLocked ? '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold">Avaliacao de lideranca ja submetida.</div>' : ''}
          <h4 class="text-sm font-bold text-purple-700">Criterios Extra de Lideranca (0-10)</h4>
          ${criteria.map((c: any) => `
            <div class="bg-[var(--surface-base)] rounded-xl p-3">
              <div class="flex items-center justify-between mb-1">
                <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight})</span></label>
                <span class="leader-score-display text-sm font-bold text-purple-700" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
              </div>
              <input type="range" min="0" max="10" step="1" value="${draft?.scores?.[c.key] ?? 5}"
                data-leader-key="${esc(c.key)}" ${isLocked ? 'disabled' : ''}
                class="w-full accent-purple-600" />
              <p class="text-[10px] text-[var(--text-muted)] mt-1">${esc(c.guide || '')}</p>
            </div>
          `).join('')}
          <textarea id="leader-eval-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas sobre lideranca..." ${isLocked ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>
          ${!isLocked ? `<button id="submit-leader-eval-btn" class="w-full px-4 py-2.5 bg-purple-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliacao de Lideranca</button>` : ''}
        </div>
      `;

      // Slider live display
      leaderContainer.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.leaderKey;
        slider.addEventListener('input', () => {
          const display = leaderContainer.querySelector(`.leader-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Submit leader extra evaluation
      leaderContainer.querySelector('#submit-leader-eval-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        leaderContainer.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
          if (slider.dataset.leaderKey) scores[slider.dataset.leaderKey] = parseInt(slider.value, 10);
        });
        const notes = (leaderContainer.querySelector('#leader-eval-notes') as HTMLTextAreaElement)?.value || '';
        const btn = leaderContainer.querySelector('#submit-leader-eval-btn') as HTMLButtonElement;
        if (btn) { btn.disabled = true; btn.textContent = 'Submetendo...'; }
        try {
          const { data: result, error } = await sb.rpc('submit_evaluation', {
            p_application_id: applicationId, p_evaluation_type: 'leader_extra',
            p_scores: scores, p_notes: notes,
          });
          if (error) throw error;
          toast('Avaliacao de lideranca submetida');
          loadLeaderExtraCriteria(applicationId);
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn) { btn.disabled = false; btn.textContent = 'Submeter Avaliacao de Lideranca'; }
        }
      });
    } catch { /* leader_extra not configured, skip silently */ }
  }

  /* ── CSV import ───────────────────────────────────── */
  function parseCSV(text: string): any[] {
    // RFC 4180 compliant parser — handles newlines inside quoted fields
    const records: string[][] = [];
    let field = '';
    let inQuotes = false;
    let currentRecord: string[] = [];

    for (let i = 0; i < text.length; i++) {
      const ch = text[i];
      const next = text[i + 1];

      if (inQuotes) {
        if (ch === '"' && next === '"') {
          field += '"'; i++; // escaped quote
        } else if (ch === '"') {
          inQuotes = false;
        } else {
          field += ch;
        }
      } else {
        if (ch === '"') {
          inQuotes = true;
        } else if (ch === ',') {
          currentRecord.push(field.trim());
          field = '';
        } else if (ch === '\r' && next === '\n') {
          currentRecord.push(field.trim());
          records.push(currentRecord);
          currentRecord = [];
          field = '';
          i++; // skip \n
        } else if (ch === '\n') {
          currentRecord.push(field.trim());
          records.push(currentRecord);
          currentRecord = [];
          field = '';
        } else {
          field += ch;
        }
      }
    }
    // Last field/record
    if (field || currentRecord.length > 0) {
      currentRecord.push(field.trim());
      records.push(currentRecord);
    }

    if (records.length < 2) return [];
    const headers = records[0].map(h => h.replace(/^\uFEFF/, ''));
    const hIdx = (name: string) => headers.findIndex(h => h.toLowerCase().includes(name.toLowerCase()));

    const rows: any[] = [];
    for (let i = 1; i < records.length; i++) {
      const vals = records[i];
      if (vals.length < 5) continue;
      // Skip if no application_id (garbage row)
      const appId = vals[hIdx('Application ID')] || '';
      if (!appId || !/^\d+$/.test(appId)) continue;

      rows.push({
        application_id: appId,
        pmi_id: (vals[hIdx('PMI ID')] || '').replace(/"/g, ''),
        first_name: vals[hIdx('First Name')] || '',
        last_name: vals[hIdx('Last Name')] || '',
        email: vals[hIdx('Email')] || '',
        membership_status: vals[hIdx('Membership')] || '',
        certifications: vals[hIdx('Certification')] || '',
        state: vals[hIdx('State')] || '',
        country: vals[hIdx('Country')] || '',
        app_status: vals[hIdx('App Status')] || '',
        reason_for_applying: vals[hIdx('Reason for Applying')] || '',
        resume_url: vals[hIdx('Resume')] || '',
        areas_of_interest: vals[hIdx('Essay Question 2')] || vals[hIdx('Areas of Interest')] || '',
        role_preference: vals[hIdx('Essay Question 2')] || '',
        pmbok_familiarity: vals[hIdx('Essay Question 3')] || '',
        proposed_theme: vals[hIdx('Essay Question 5')] || '',
        industry: vals[hIdx('Industry')] || '',
        availability: vals[hIdx('Essay Question 4')] || '',
      });
    }
    return rows;
  }

  function renderCSVPreview(rows: any[]) {
    csvParsedRows = rows;
    const preview = document.getElementById('csv-preview');
    const summary = document.getElementById('csv-summary');
    const body = document.getElementById('csv-preview-body');
    if (!preview || !body || !summary) return;

    const submitted = rows.filter(r => r.app_status === 'Submitted' || r.app_status === 'Active' || r.app_status === 'Complete');
    const declined = rows.filter(r => r.app_status === 'OfferNotExtended' || r.app_status === 'Declined' || r.app_status === 'Withdrawn');

    summary.innerHTML = [
      { label: 'Total no CSV', value: rows.length, color: 'text-navy' },
      { label: 'Para importar', value: submitted.length, color: 'text-emerald-600' },
      { label: 'Serão ignorados', value: declined.length, color: 'text-red-600' },
    ].map(s => `<div class="bg-[var(--surface-base)] rounded-xl px-4 py-2 text-center">
      <div class="text-lg font-extrabold ${s.color}">${s.value}</div>
      <div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">${s.label}</div>
    </div>`).join('');

    body.innerHTML = rows.map(r => {
      const isSkip = ['OfferNotExtended', 'Declined', 'Withdrawn'].includes(r.app_status);
      return `<tr class="${isSkip ? 'opacity-40' : ''}">
        <td class="px-3 py-2 text-[12px] font-semibold">${esc(r.first_name)} ${esc(r.last_name)}</td>
        <td class="px-3 py-2 text-[12px] text-[var(--text-secondary)]">${esc(r.email)}</td>
        <td class="px-3 py-2 text-[12px]">${esc(r.membership_status?.substring(0, 40) || '—')}</td>
        <td class="px-3 py-2 text-[12px]"><span class="px-1.5 py-0.5 rounded text-[10px] font-bold ${isSkip ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-700'}">${esc(r.app_status)}</span></td>
        <td class="px-3 py-2 text-[12px]">${isSkip ? 'Skip' : 'Importar'}</td>
      </tr>`;
    }).join('');

    document.getElementById('csv-dropzone')?.classList.add('hidden');
    preview.classList.remove('hidden');
    document.getElementById('csv-result')?.classList.add('hidden');
  }

