  /* p109 Onda 4 Fase 1.2 — "Minha avaliação" badge na lista (FP-4).
     Resolve PM pain "já avaliei?" sem precisar abrir o modal.
     Reads my_eval_status from get_selection_dashboard (Onda 2.3). */
  function myEvalBadge(r: any): string {
    const status = r.my_eval_status as 'submitted' | 'draft' | 'invited' | 'not_invited' | undefined;
    const score = r.my_eval_score;
    if (status === 'submitted') {
      const scoreStr = score != null ? ` (${Number(score).toFixed(1)})` : '';
      return `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700 whitespace-nowrap" title="Você submeteu avaliação objetiva${scoreStr}">✓ Avaliei${scoreStr}</span>`;
    }
    if (status === 'draft') {
      return `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 whitespace-nowrap" title="Você tem rascunho — falta submeter">⚠ Rascunho</span>`;
    }
    if (status === 'invited') {
      return `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-blue-50 text-blue-700 whitespace-nowrap" title="Você foi convidado — pendente">📨 Convidado</span>`;
    }
    return `<span class="text-[10px] text-[var(--text-muted)]" title="Sem convite individual">—</span>`;
  }

  /* p92 Phase D — pipeline workflow indicators (5 mini-badges per candidate).
     Compact one-glance status for AI / peer review / interview / token usage / video.
     Each badge: dot color (emerald=done, amber=partial, gray=pending) + tooltip. */
  function pipelineBadges(r: any): string {
    // p150 hotfix2: read from meta + peer_extra subgroups (fallback to flat for backwards compat)
    const aiDone = (r.meta?.ai_analysis_done ?? r.ai_analysis_done) === true;
    const peerCount = Number(r.peer_eval_count ?? 0);
    const peerDistinct = Number(r.peer_extra?.distinct_evaluators ?? r.peer_eval_distinct_evaluators ?? 0);
    const peerPending = Number(r.peer_extra?.invites_pending ?? r.peer_invites_pending ?? 0);
    const interviewSched = (r.meta?.interview_scheduled ?? r.interview_scheduled) === true;
    const tokenUsed = (r.meta?.token_consumed ?? r.token_consumed) === true;
    const videoDone = (r.meta?.video_screening_done ?? r.video_screening_done) === true;

    const dot = (color: string, label: string, hint: string) =>
      `<span title="${esc(hint)}" class="inline-flex items-center justify-center w-5 h-5 rounded text-[9px] font-bold ${color}">${label}</span>`;

    const aiBadge = aiDone
      ? dot('bg-emerald-100 text-emerald-700', 'IA', 'AI analysis concluída + consent dado')
      : dot('bg-gray-100 text-gray-400', 'IA', 'Aguardando AI / consent');

    // p150 fix — peer review = 2 avaliações OBJETIVAS por avaliadores DISTINTOS.
    // peerCount já é filtrado no RPC (objective + submitted); peerDistinct é o gate verde.
    const peerLabel = `${peerDistinct}/2`;
    const peerColor = peerDistinct >= 2
      ? 'bg-emerald-100 text-emerald-700'
      : peerDistinct === 1
        ? 'bg-amber-100 text-amber-700'
        : peerPending > 0
          ? 'bg-blue-100 text-blue-700'
          : 'bg-gray-100 text-gray-400';
    const peerHint = `${peerDistinct} avaliador(es) distinto(s), ${peerCount} avaliação(ões) objetiva(s) submetida(s)` +
      (peerPending > 0 ? `, ${peerPending} convite(s) pendente(s)` : '');
    const peerBadge = dot(peerColor, peerLabel, peerHint);

    const interviewBadge = interviewSched
      ? dot('bg-emerald-100 text-emerald-700', 'EN', 'Entrevista agendada/realizada')
      : dot('bg-gray-100 text-gray-400', 'EN', 'Sem entrevista agendada');

    const tokenBadge = tokenUsed
      ? dot('bg-emerald-100 text-emerald-700', 'TK', 'Candidato acessou portal pelo menos 1×')
      : dot('bg-gray-100 text-gray-400', 'TK', 'Token nunca consumido (não acessou portal)');

    // p150 B-light: tri-state video badge (replaces binary VD).
    // uploaded   → 📹 emerald — candidato escolheu rota e subiu pelo menos 1 vídeo
    // opted_out  → ⏭ blue    — candidato decidiu não submeter vídeos (não confundir com "sem dado")
    // partial    → ⚠ amber   — algumas rows uploaded, outras opted-out (raro)
    // none       → — gray    — candidato ainda não decidiu
    // p150 hotfix 100-args: video_agg subgroup (fallback to flat fields for backwards compat)
    const videoAgg = r.video_agg?.status_agg || r.video_screening_status_agg || ((r.meta?.video_screening_done ?? r.video_screening_done) ? 'uploaded' : 'none');
    const videoUploaded = Number(r.video_agg?.uploaded_count ?? r.video_screening_uploaded_count ?? 0);
    const videoTotal = Number(r.video_agg?.total_rows ?? r.video_screening_total_rows ?? 0);
    const videoBadge = (() => {
      if (videoAgg === 'uploaded')
        return dot('bg-emerald-100 text-emerald-700', '📹', `Candidato subiu ${videoUploaded} de ${videoTotal} pilares`);
      if (videoAgg === 'opted_out')
        return dot('bg-blue-100 text-blue-700', '⏭', 'Candidato escolheu opt-out (não submete vídeos)');
      if (videoAgg === 'partial')
        return dot('bg-amber-100 text-amber-700', '⚠', `Vídeo parcial: ${videoUploaded} uploaded, restante opted-out`);
      return dot('bg-gray-100 text-gray-400', '—', 'Candidato ainda não decidiu sobre a rota de vídeos');
    })();

    return `<div class="inline-flex items-center gap-1">${aiBadge}${peerBadge}${interviewBadge}${tokenBadge}${videoBadge}</div>`;
  }

  /* Issue #116 Part 2 — 6-stage pipeline timeline (modal info tab expanded view).
     Verbose counterpart of pipelineBadges(). Shows stage label + state + detail
     so committee (Fabricio) can see at-a-glance where each candidate is in flow.
     States: done (emerald) / current (amber) / pending (gray). */
  function pipelineTimeline(r: any): string {
    const isTerminal = ['approved', 'rejected', 'converted', 'withdrawn', 'cancelled'].includes(r.status);
    const peerCount = Number(r.peer_eval_count ?? 0);
    // p150 hotfix 100-args: peer_extra subgroup (fallback to flat field)
    const peerDistinct = Number(r.peer_extra?.distinct_evaluators ?? r.peer_eval_distinct_evaluators ?? 0);
    const submittedAt = r.application_date || r.created_at;

    const stages = [
      { label: 'Aplicação', state: 'done', detail: submittedAt ? new Date(submittedAt).toLocaleDateString('pt-BR') : 'Submetida' },
      { label: 'Análise IA', state: (r.meta?.ai_analysis_done ?? r.ai_analysis_done) ? 'done' : (r.consent_ai_analysis_at ? 'current' : 'pending'), detail: (r.meta?.ai_analysis_done ?? r.ai_analysis_done) ? 'Concluída' : (r.consent_ai_analysis_at ? 'Em curso' : 'Aguardando consent') },
      { label: 'Par-revisão', state: peerDistinct >= 2 ? 'done' : peerDistinct > 0 ? 'current' : 'pending', detail: `${peerDistinct}/2 avaliadores · ${peerCount} obj. submetida(s)` },
      { label: 'Vídeo', state: (r.meta?.video_screening_done ?? r.video_screening_done) ? 'done' : 'pending', detail: (r.meta?.video_screening_done ?? r.video_screening_done) ? 'OK ou opt-out' : 'Não realizado' },
      { label: 'Entrevista', state: (r.meta?.interview_scheduled ?? r.interview_scheduled) ? 'done' : 'pending', detail: (r.meta?.interview_scheduled ?? r.interview_scheduled) ? 'Agendada' : 'Não agendada' },
      { label: 'Decisão', state: isTerminal ? 'done' : 'pending', detail: isTerminal ? (STATUS_LABELS[r.status] || r.status) : 'Em andamento' },
    ];

    const colors: Record<string, { bg: string; brd: string; ic: string; tx: string; sub: string }> = {
      done:    { bg: 'bg-emerald-50', brd: 'border-emerald-200', ic: 'bg-emerald-500 text-white',                            tx: 'text-emerald-800', sub: 'text-emerald-600' },
      current: { bg: 'bg-amber-50',   brd: 'border-amber-200',   ic: 'bg-amber-500 text-white',                              tx: 'text-amber-800',   sub: 'text-amber-600' },
      pending: { bg: 'bg-gray-50',    brd: 'border-gray-200',    ic: 'bg-white text-gray-400 border border-gray-300',         tx: 'text-gray-500',    sub: 'text-gray-400' },
    };

    return `<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-2">
      ${stages.map((s, i) => {
        const c = colors[s.state];
        const icon = s.state === 'done' ? '✓' : s.state === 'current' ? '●' : (i + 1).toString();
        return `<div class="flex flex-col items-center text-center px-2 py-2 rounded-lg border ${c.bg} ${c.brd}">
          <div class="w-7 h-7 rounded-full ${c.ic} flex items-center justify-center text-[12px] font-bold mb-1">${icon}</div>
          <div class="text-[11px] font-bold ${c.tx}">${esc(s.label)}</div>
          <div class="text-[10px] ${c.sub} mt-0.5 leading-tight">${esc(s.detail)}</div>
        </div>`;
      }).join('')}
    </div>`;
  }

  /* ── load cycles ──────────────────────────────────── */
  async function loadCycles() {
    const { data } = await sb.rpc('get_selection_cycles');
    allCycles = Array.isArray(data) ? data : [];
    const picker = document.getElementById('sel-cycle-picker') as HTMLSelectElement;
    if (picker && allCycles.length) {
      picker.innerHTML = allCycles.map((c: any) =>
        `<option value="${c.id}">${esc(c.title)} (${c.status})</option>`
      ).join('');
      currentCycleId = allCycles[0].id;
    }
  }

  /* ── load data via RPC ────────────────────────────── */
  async function loadDashboard() {
    if (!sb) return;
    try {
      const { data: dashboard } = await sb.rpc('get_selection_dashboard');
      if (dashboard?.error === 'Unauthorized') { showDenied(); return; }
      if (dashboard?.error) { console.warn('Dashboard error:', dashboard.error); }
      const cycle = dashboard?.cycle;
      const applications = dashboard?.applications || [];

      if (cycle) {
        currentCycleId = cycle.id;
        currentCycle = cycle;
        const badge = document.getElementById('sel-cycle-badge');
        if (badge) {
          const cs = CYCLE_STATUS_COLORS[cycle.status] || CYCLE_STATUS_COLORS.draft;
          badge.className = `text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase ${cs.bg} ${cs.color}`;
          badge.textContent = cycle.status.toUpperCase();
        }
        // Sync cycle picker
        const picker = document.getElementById('sel-cycle-picker') as HTMLSelectElement;
        if (picker) picker.value = cycle.id;
      }

      allRows = applications;
      // p153 GAP-152.5 — compute latest VEP ingest timestamp across the dataset
      // so the row helper can flag stale rows ("missing from latest VEP" — likely
      // removed from the PMI recruiter dashboard between Apply rounds).
      latestVepSeenMs = 0;
      for (const r of allRows) {
        const ts = r?.vep_recon?.last_seen_at;
        if (!ts) continue;
        const ms = new Date(ts).getTime();
        if (Number.isFinite(ms) && ms > latestVepSeenMs) latestVepSeenMs = ms;
      }
      // Fetch onboarding % for approved/converted candidates
      const approvedIds = applications
        .filter((r: any) => ['approved', 'converted'].includes(r.status))
        .map((r: any) => r.id);
      if (approvedIds.length > 0 && sb) {
        try {
          const pctPromises = approvedIds.map((appId: string) =>
            sb.rpc('get_application_onboarding_pct', { p_application_id: appId })
              .then((res: any) => ({ id: appId, pct: res.data }))
          );
          const pctResults = await Promise.all(pctPromises);
          for (const { id: appId, pct } of pctResults) {
            const row = allRows.find((r: any) => r.id === appId);
            if (row) row.onboarding_pct = pct;
          }
        } catch { /* optional enhancement */ }
      }
      populateChapterDropdown();
      applyFilters();
    } catch (e: any) {
      console.error('Selection load:', e);
      const tbody = document.getElementById('sel-tbody');
      if (tbody) tbody.innerHTML = `<tr><td colspan="13" class="px-4 py-6 text-center text-red-500">${T.errorPrefix}: ${esc(e.message || 'desconhecido')}</td></tr>`;
    }
  }

  function populateChapterDropdown() {
    const sel = document.getElementById('sel-chapter') as HTMLSelectElement | null;
    if (!sel) return;
    const chapters = [...new Set(allRows.map(r => r.chapter).filter(Boolean))].sort();
    const current = sel.value;
    sel.innerHTML = `<option value="all">${T.allChaptersOption}</option>` +
      chapters.map(c => `<option value="${esc(c)}">${esc(c)}</option>`).join('');
    sel.value = current;
  }

  /* ── filtering + sorting ──────────────────────────── */
  function applyFilters() {
    const search = filterSearch.toLowerCase();
    filteredRows = allRows.filter(r => {
      // Track-aware filter: when viewing "leader" track, hide the researcher-track paired row
      // (triaged candidates have 2 rows — we want only the leader one visible in leader view)
      if (filterRole === 'leader') {
        if (r.role_applied !== 'leader') return false;
      } else if (filterRole === 'researcher') {
        // Show researcher rows BUT exclude those promoted (linked to approved leader)
        if (r.role_applied !== 'researcher') return false;
        if (r.promotion_path === 'triaged_to_leader' && r.linked_application_id) {
          // Hide the researcher pair when the leader pair exists and is approved
          const leaderPair = allRows.find((x: any) => x.id === r.linked_application_id);
          if (leaderPair && ['approved','converted'].includes(leaderPair.status)) return false;
        }
      }
      // "Todos": hide duplicates — keep only the primary row per email (prefer leader if exists)
      if (filterRole === 'all') {
        if (r.promotion_path === 'triaged_to_leader' && r.role_applied === 'researcher' && r.linked_application_id) {
          const leaderPair = allRows.find((x: any) => x.id === r.linked_application_id);
          if (leaderPair) return false; // hide researcher row, show only leader
        }
      }
      if (filterChapter !== 'all' && r.chapter !== filterChapter) return false;
      if (filterStatus !== 'all' && r.status !== filterStatus) return false;
      // p150 B-light: video screening filter (p150 hotfix: video_agg subgroup)
      if (filterVideo !== 'all') {
        const agg = r.video_agg?.status_agg || r.video_screening_status_agg || 'none';
        if (filterVideo === 'uploaded' && agg !== 'uploaded') return false;
        if (filterVideo === 'opted_out' && agg !== 'opted_out') return false;
        if (filterVideo === 'none' && agg !== 'none') return false;
      }
      // p109 Onda 4 Fase 3: hideDecided + myEval quick filters
      if (filterHideDecided && ['approved', 'rejected', 'cancelled', 'withdrawn', 'converted', 'waitlist'].includes(r.status)) return false;
      if (filterMyEval === 'pending_mine' && r.my_eval_status === 'submitted') return false;
      if (filterMyEval === 'evaluated_mine' && r.my_eval_status !== 'submitted') return false;
      // p152 Wave 1.0: shadow VEP = email matches active member created before this app, terminal status
      if (filterHideShadowVep && r.extra_flags?.is_shadow_vep === true) return false;
      // p152 W3+: "Entrevistas hoje" — uses meta.has_interview_today (canonical SP-tz check in RPC)
      if (filterInterviewToday && r.meta?.has_interview_today !== true) return false;
      if (search) {
        const name = (r.applicant_name || '').toLowerCase();
        const email = (r.email || '').toLowerCase();
        if (!name.includes(search) && !email.includes(search)) return false;
      }
      return true;
    });
    filteredRows.sort((a, b) => {
      let va = a[sortCol], vb = b[sortCol];
      if (va == null && vb == null) return 0;
      if (va == null) return 1;
      if (vb == null) return -1;
      if (typeof va === 'string') va = va.toLowerCase();
      if (typeof vb === 'string') vb = vb.toLowerCase();
      return (va < vb ? -1 : va > vb ? 1 : 0) * (sortAsc ? 1 : -1);
    });
    renderQuickStats();
    renderKanban();
    renderTable();
    renderRankEmptyAlert();
  }

  // p152 W4 OPP-152.6: show alert when >80% of filtered rows have NO rank
  function renderRankEmptyAlert() {
    const alertEl = document.getElementById('rank-empty-alert');
    const msgEl = document.getElementById('rank-empty-msg');
    if (!alertEl || !msgEl) return;
    if (filteredRows.length < 5) { alertEl.classList.add('hidden'); return; }
    const noRank = filteredRows.filter((r: any) =>
      r.rank_chapter == null && r.rank_leader == null && r.rank_researcher == null && r.rank_overall == null
    ).length;
    const pct = (noRank / filteredRows.length) * 100;
    if (pct >= 80) {
      const totalText = `${noRank}/${filteredRows.length} aplicações sem rank (${pct.toFixed(0)}%).`;
      msgEl.textContent = totalText;
      alertEl.classList.remove('hidden');
    } else {
      alertEl.classList.add('hidden');
    }
  }

  function renderQuickStats() {
    const el = document.getElementById('sel-quick-stats');
    if (!el) return;
    const total = filteredRows.length;
    const approved = filteredRows.filter(r => ['approved', 'converted'].includes(r.status)).length;
    const rejected = filteredRows.filter(r => ['rejected', 'cancelled', 'withdrawn'].includes(r.status)).length;
    const pending = total - approved - rejected;
    const stats = [
      { label: T.qsTotal, value: total, color: 'text-navy' },
      { label: T.qsApproved, value: approved, color: 'text-emerald-600' },
      { label: T.qsRejected, value: rejected, color: 'text-red-600' },
      { label: T.qsPending, value: pending, color: 'text-amber-600' },
    ];
    el.innerHTML = stats.map(s =>
      `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3 text-center">
        <div class="text-xl font-extrabold ${s.color}">${s.value}</div>
        <div class="text-[.65rem] text-[var(--text-secondary)] font-semibold">${esc(s.label)}</div>
      </div>`
    ).join('');
  }

  function renderKanban() {
    const el = document.getElementById('sel-kanban');
    if (!el) return;
    const counts: Record<string, number> = {};
    for (const key of Object.keys(STATUS_GROUPS)) counts[key] = 0;
    filteredRows.forEach(r => { counts[statusGroup(r.status)]++; });
    el.innerHTML = Object.entries(STATUS_GROUPS).map(([key, g]) =>
      `<div class="border border-[var(--border-default)] rounded-xl p-3 text-center ${g.bg}">
        <div class="text-2xl font-extrabold ${g.color}">${counts[key]}</div>
        <div class="text-[.65rem] ${g.color} font-bold">${esc(g.label)}</div>
      </div>`
    ).join('');
  }

  function renderTable() {
    const tbody = document.getElementById('sel-tbody');
    const countEl = document.getElementById('sel-count');
    if (!tbody) return;
    if (countEl) {
      // p152 W3.7 + B-153.4: count + per-filter breakdown chips
      const hidden = allRows.length - filteredRows.length;
      const base = `${filteredRows.length} ${filteredRows.length !== 1 ? T.resultSuffixMany : T.resultSuffixOne}`;
      if (hidden <= 0) {
        countEl.textContent = base;
      } else {
        // Compute per-filter individual hidden counts (overlapping; meant as quick what-each-filter-hides intuition).
        const parts: string[] = [];
        if (filterHideShadowVep) {
          const n = allRows.filter((r: any) => r.extra_flags?.is_shadow_vep === true).length;
          if (n > 0) parts.push(`${n} shadow VEP`);
        }
        if (filterHideDecided) {
          const decidedStatus = ['approved','rejected','cancelled','withdrawn','converted','waitlist'];
          const n = allRows.filter((r: any) => decidedStatus.includes(r.status)).length;
          if (n > 0) parts.push(`${n} decididos`);
        }
        if (filterInterviewToday) {
          const n = allRows.filter((r: any) => r.meta?.has_interview_today !== true).length;
          if (n > 0) parts.push(`${n} sem entrevista hoje`);
        }
        if (filterMyEval === 'pending_mine') {
          const n = allRows.filter((r: any) => r.my_eval_status === 'submitted').length;
          if (n > 0) parts.push(`${n} já avaliados`);
        } else if (filterMyEval === 'evaluated_mine') {
          const n = allRows.filter((r: any) => r.my_eval_status !== 'submitted').length;
          if (n > 0) parts.push(`${n} não-avaliados`);
        }
        if (filterRole !== 'all') {
          const n = allRows.filter((r: any) => r.role_applied !== filterRole).length;
          if (n > 0) parts.push(`${n} outro track`);
        }
        if (filterChapter !== 'all') {
          const n = allRows.filter((r: any) => r.chapter !== filterChapter).length;
          if (n > 0) parts.push(`${n} outro capítulo`);
        }
        if (filterStatus !== 'all') {
          const n = allRows.filter((r: any) => r.status !== filterStatus).length;
          if (n > 0) parts.push(`${n} outro status`);
        }
        if (filterVideo !== 'all') {
          const n = allRows.filter((r: any) => (r.video_agg?.status_agg || 'none') !== filterVideo).length;
          if (n > 0) parts.push(`${n} outro vídeo state`);
        }
        if (filterSearch) {
          parts.push(`busca "${filterSearch}"`);
        }
        const breakdown = parts.length ? ` · oculto: ${parts.join(' · ')}` : ` · ${hidden} ${T.hiddenByFilter}`;
        countEl.textContent = base + breakdown;
      }
    }
    if (!filteredRows.length) {
      tbody.innerHTML = `<tr><td colspan="13" class="px-4 py-6 text-center text-[var(--text-muted)]">${document.getElementById('ai18n-nor')?.textContent || T.noCandidates}</td></tr>`;
      return;
    }
    // Sort by active track's rank: leader track → rank_leader, researcher → rank_researcher
    const useLeaderRank = filterRole === 'leader';
    const useResearcherRank = filterRole === 'researcher';
    const displayRows = [...filteredRows].sort((a: any, b: any) => {
      const ra = useLeaderRank ? a.rank_leader : useResearcherRank ? a.rank_researcher : (a.rank_leader || a.rank_researcher);
      const rb = useLeaderRank ? b.rank_leader : useResearcherRank ? b.rank_researcher : (b.rank_leader || b.rank_researcher);
      if (ra == null && rb == null) return 0;
      if (ra == null) return 1;
      if (rb == null) return -1;
      return ra - rb;
    });

    tbody.innerHTML = displayRows.map(r => {
      const sb2 = STATUS_BADGE[r.status] || STATUS_BADGE.submitted;
      const researchScore = r.research_score != null ? Number(r.research_score).toFixed(1) : '—';
      const leaderScore = r.leader_score != null ? Number(r.leader_score).toFixed(1) : '—';
      // Track-aware rank
      let rankDisplay: string;
      if (useLeaderRank) {
        rankDisplay = r.rank_leader != null ? `#${r.rank_leader}` : '—';
      } else if (useResearcherRank) {
        rankDisplay = r.rank_researcher != null ? `#${r.rank_researcher}` : '—';
      } else {
        // "Todos": show both if applicable
        const parts: string[] = [];
        if (r.rank_researcher != null) parts.push(`P#${r.rank_researcher}`);
        if (r.rank_leader != null) parts.push(`L#${r.rank_leader}`);
        rankDisplay = parts.length ? parts.join(' · ') : '—';
      }
      // Track badge
      let trackBadge = '';
      if (r.role_applied === 'leader') {
        trackBadge = r.promotion_path === 'triaged_to_leader'
          ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-purple-100 text-purple-700" title="Triado: aplicou como pesquisador, foi promovido para líder">👑⇡ Triado</span>'
          : '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-amber-100 text-amber-700">👑 Líder</span>';
      } else {
        trackBadge = r.promotion_path === 'triaged_to_leader'
          ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-gray-100 text-gray-500" title="Pesquisador original — foi promovido; esta linha é histórica">🎓 (promovido)</span>'
          : '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-blue-100 text-blue-700">🎓 Pesquisador</span>';
      }
      const statusLabel = STATUS_LABELS[r.status] || r.status?.replace(/_/g, ' ') || '—';
      const noMembership = !r.membership_status || r.membership_status === 'No';
      // p150 PM feedback — chapter canonical from PMI Member History (vs form-declared).
      // canonicalRaw: e.g. "Ceará, Brazil Chapter". Mapped to "PMI-CE" via PMI_CHAPTER_CODE_MAP.
      // If both present and differ, show canonical primary + form in tooltip (⚠ discrepancy).
      // If only form present, fallback to form (free-text, unverified).
      const pmiCanonical = r.pmi_canonical || {};
      const chapterCanonicalRaw: string | null = pmiCanonical.chapter_canonical || null;
      const chapterCanonicalCode = chapterCanonicalRaw ? mapPmiChapterToCode(chapterCanonicalRaw) : null;
      const formChapter: string | null = r.chapter || null;
      const chapterDisplay = chapterCanonicalCode || chapterCanonicalRaw || formChapter || '—';
      const chapterDivergent = chapterCanonicalCode && formChapter && chapterCanonicalCode !== formChapter;
      const chapterTooltip = chapterDivergent
        ? `Canonical PMI: ${chapterCanonicalRaw}. Declarou no form: ${formChapter}.`
        : chapterCanonicalRaw
        ? `Canonical PMI: ${chapterCanonicalRaw}`
        : formChapter
        ? `Declarou (free text, não verificado): ${formChapter}`
        : 'Sem capítulo identificado';
      const chapterSourceBadge = chapterCanonicalRaw
        ? '<span class="text-[8px] font-bold ml-1 text-emerald-600" title="Fonte PMI Member History">✓</span>'
        : formChapter
        ? '<span class="text-[8px] font-bold ml-1 text-amber-500" title="Apenas form do candidato (não verificado PMI)">~</span>'
        : '';
      const chapterDivergentBadge = chapterDivergent
        ? `<span class="text-[8px] font-bold ml-0.5 text-amber-600" title="Form declarou: ${esc(formChapter ?? '')}">⚠</span>`
        : '';
      // p152 W4 P1: interview column — show next scheduled date/time (SP-tz) + HOJE badge if today
      const intvNextIso: string | null = r.meta?.interview_next_at || null;
      const hasIntvToday: boolean = r.meta?.has_interview_today === true;
      const interviewCell = intvNextIso
        ? (() => {
            const d = new Date(intvNextIso);
            const dateStr = d.toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo', day: '2-digit', month: '2-digit' });
            const timeStr = d.toLocaleTimeString('pt-BR', { timeZone: 'America/Sao_Paulo', hour: '2-digit', minute: '2-digit' });
            if (hasIntvToday) {
              return `<div class="flex flex-col items-start gap-0.5"><span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-purple-100 text-purple-700">HOJE</span><span class="text-[11px] font-bold text-navy">${esc(timeStr)}</span></div>`;
            }
            return `<div class="flex flex-col items-start gap-0.5 text-[11px] text-[var(--text-secondary)]"><span class="font-semibold">${esc(dateStr)}</span><span class="text-[10px] text-[var(--text-muted)]">${esc(timeStr)} SP</span></div>`;
          })()
        : '<span class="text-[var(--text-muted)] text-[11px]">—</span>';
      // PMI member status badge (active/past/unknown).
      const memberStatus = pmiCanonical.member_status || 'unknown';
      const memberBadge = pmiCanonical.is_pmi_member
        ? memberStatus === 'active'
          ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-emerald-50 text-emerald-700" title="Membro PMI ativo (service_latest_end_date >= hoje)">✓PMI</span>'
          : memberStatus === 'past'
          ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-gray-100 text-gray-600" title="Membro PMI passado (cadastro existe, expirado)">⚪PMI</span>'
          : '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-amber-50 text-amber-700" title="Cadastro PMI existe mas sem service history (Phase B pendente)">?PMI</span>'
        : '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-red-50 text-red-700" title="Sem pmi_id (não cadastrado no PMI)">—</span>';
      return `<tr class="hover:bg-[var(--surface-hover)] cursor-pointer" data-action="view-applicant" data-id="${esc(r.id)}">
        <td class="px-2 py-2.5 w-8" onclick="event.stopPropagation()"><input type="checkbox" class="sel-row-check cursor-pointer" value="${esc(r.id)}" /></td>
        <td class="px-4 py-2.5 font-semibold text-navy">${esc(r.applicant_name)}${noMembership ? ' <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-amber-50 text-amber-700" title="Sem membership PMI">!M</span>' : ''}${r.is_returning_member ? ' <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-blue-50 text-blue-700" title="Retornante (ex-voluntário do Núcleo)">R</span>' : ''}${reApplicantBadge(r)}${briefingBadge(r)}${aiTriageBadge(r)}${vepBadge(r)}</td>
        <td class="px-4 py-2.5 text-[12px]">${trackBadge}</td>
        <td class="px-4 py-2.5 text-[12px] text-[var(--text-secondary)]" title="${esc(chapterTooltip)}">${esc(chapterDisplay)}${chapterSourceBadge}${chapterDivergentBadge} ${memberBadge}</td>
        <td class="px-4 py-2.5 text-[12px] font-mono ${r.research_score != null ? 'font-semibold text-navy' : 'text-[var(--text-muted)]'}">${researchScore}</td>
        <td class="px-4 py-2.5 text-[12px] font-mono ${r.leader_score != null ? 'font-bold text-navy' : 'text-[var(--text-muted)]'}">${leaderScore}</td>
        <td class="px-4 py-2.5 text-[12px] font-bold">${rankDisplay}</td>
        <td class="px-4 py-2.5"><span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${sb2.bg} ${sb2.color}">${esc(statusLabel)}</span></td>
        <td class="px-3 py-2.5">${myEvalBadge(r)}</td>
        <td class="px-3 py-2.5">${pipelineBadges(r)}</td>
        <td class="px-3 py-2.5 whitespace-nowrap">${interviewCell}</td>
        <td class="px-4 py-2.5 text-[11px] text-[var(--text-secondary)] whitespace-nowrap">${r.application_date || r.created_at ? new Date(r.application_date || r.created_at).toLocaleDateString('pt-BR') : '—'}</td>
        <td class="px-4 py-2.5 text-[12px]" id="onb-${esc(r.id)}">${r.onboarding_pct != null && r.onboarding_pct >= 0 ? `<span class="font-semibold ${r.onboarding_pct === 100 ? 'text-emerald-600' : r.onboarding_pct >= 50 ? 'text-amber-600' : 'text-[var(--text-muted)]'}">${r.onboarding_pct}%</span>` : '<span class="text-[var(--text-muted)]">—</span>'}</td>
        <td class="px-4 py-2.5">
          <div class="flex gap-1.5 items-center flex-wrap">
            ${r.status === 'final_eval' ? `
              <button class="text-[11px] px-2 py-1 rounded-md bg-emerald-600 text-white font-bold cursor-pointer border-0 hover:opacity-90 inline-flex items-center gap-1" data-action="inline-approve" data-id="${esc(r.id)}" data-name="${esc(r.applicant_name)}" title="${esc(T.inlineApproveTitle)}">✓ ${esc(T.bulkApprove)}</button>
              <button class="text-[11px] px-2 py-1 rounded-md bg-red-600 text-white font-bold cursor-pointer border-0 hover:opacity-90 inline-flex items-center gap-1" data-action="inline-reject" data-id="${esc(r.id)}" data-name="${esc(r.applicant_name)}" title="${esc(T.inlineRejectTitle)}">✗ ${esc(T.bulkReject)}</button>
            ` : ''}
            <button class="text-[11px] text-purple-600 hover:underline cursor-pointer bg-transparent border-0 p-0" data-action="view-applicant" data-id="${esc(r.id)}">${T.detailsBtn}</button>
          </div>
        </td>
      </tr>`;
    }).join('');
    updateBulkBar();
  }

  /* ── applicant detail modal ───────────────────────── */
  function openApplicantModal(id: string) {
    const row = allRows.find(r => r.id === id);
    if (!row) return;
    const modal = document.getElementById('applicant-modal');
    const nameEl = document.getElementById('modal-name');
    const body = document.getElementById('modal-body');
    if (!modal || !body || !nameEl) return;

    nameEl.textContent = row.applicant_name || '—';
    const sb2 = STATUS_BADGE[row.status] || STATUS_BADGE.submitted;
    const statusLabel = STATUS_LABELS[row.status] || row.status;

    // S1: Membership badge
    const membershipBadge = row.membership_status
      ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${row.membership_status === 'Active' ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700'}">${esc(row.membership_status)}</span>`
      : '';
    const returningBadge = row.is_returning_member
      ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">${T.modal.returningBadge}</span>`
      : '';

    // p152 W2.5: chapter discrepancy alert (form chapter vs canonical PMI service_history)
    const pmiC = row.pmi_canonical || {};
    const chapterCanonical = pmiC.chapter_canonical || null;
    const chapterMismatch = chapterCanonical
      && row.chapter
      && String(chapterCanonical).trim().toLowerCase() !== String(row.chapter).trim().toLowerCase();
    const chapterDiscrepancyAlert = chapterMismatch
      ? `<div class="mb-4 px-3 py-2 rounded-lg bg-amber-50 border border-amber-200 text-[12px] text-amber-800">
           <strong>⚠ ${T.modal.chapterDiscrepancyTitle}:</strong> ${T.modal.chapterDiscrepancyForm} <strong>${esc(row.chapter)}</strong> · ${T.modal.chapterDiscrepancyCanonical} <strong>${esc(chapterCanonical)}</strong>
         </div>`
      : '';

    // p152 W2.5: Phase B summary inline (uses pmi_canonical subgroup already in row)
    const phaseBSummary = (pmiC.is_pmi_member || pmiC.member_status === 'active' || pmiC.member_status === 'past' || pmiC.service_history_count > 0)
      ? `<div class="mt-3 p-3 rounded-xl border border-navy/15 bg-navy/5 text-[12px]">
           <h4 class="text-[11px] font-bold text-navy mb-1.5">${T.modal.phaseBSummaryTitle}</h4>
           <div class="grid grid-cols-2 gap-x-4 gap-y-1">
             ${pmiC.pmi_id ? `<div><span class="text-[var(--text-muted)] text-[10px]">PMI ID</span><br><strong>${esc(pmiC.pmi_id)}</strong></div>` : ''}
             ${pmiC.member_status ? `<div><span class="text-[var(--text-muted)] text-[10px]">${T.modal.phaseBMemberStatus}</span><br><strong>${esc(pmiC.member_status)}</strong></div>` : ''}
             ${chapterCanonical ? `<div><span class="text-[var(--text-muted)] text-[10px]">${T.modal.phaseBChapterCanonical}</span><br><strong>${esc(chapterCanonical)}</strong></div>` : ''}
             ${pmiC.service_history_count != null ? `<div><span class="text-[var(--text-muted)] text-[10px]">${T.modal.phaseBHistoryCount}</span><br><strong>${pmiC.service_history_count}</strong></div>` : ''}
             ${pmiC.member_since ? `<div><span class="text-[var(--text-muted)] text-[10px]">${T.modal.phaseBMemberSince}</span><br><strong>${esc(pmiC.member_since)}</strong></div>` : ''}
             ${pmiC.member_until ? `<div><span class="text-[var(--text-muted)] text-[10px]">${T.modal.phaseBMemberUntil}</span><br><strong>${esc(pmiC.member_until)}</strong></div>` : ''}
           </div>
           ${pmiC.phase_b_fetched_at ? `<div class="mt-1.5 text-[10px] text-[var(--text-muted)]">${T.modal.phaseBFetchedAt}: ${esc(pmiC.phase_b_fetched_at)}</div>` : ''}
         </div>`
      : '';

    body.innerHTML = `
      <!-- Modal tabs -->
      <div class="flex gap-1 border-b border-[var(--border-default)] mb-4">
        <button data-modal-tab="info" class="modal-tab-btn px-3 py-1.5 text-[12px] font-semibold rounded-t-lg border-b-2 border-navy text-navy bg-transparent cursor-pointer">${T.modal.tabInfo}</button>
        <button data-modal-tab="evaluate" class="modal-tab-btn px-3 py-1.5 text-[12px] font-semibold rounded-t-lg border-b-2 border-transparent text-[var(--text-secondary)] bg-transparent cursor-pointer">${T.modal.tabEvaluate}</button>
