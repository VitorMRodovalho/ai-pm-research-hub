  /* ── committee ────────────────────────────────────── */
  async function loadCommittee() {
    if (!currentCycleId) return;
    const { data } = await sb.rpc('get_selection_committee', { p_cycle_id: currentCycleId });
    const members = Array.isArray(data) ? data : [];
    const el = document.getElementById('committee-list');
    if (!el) return;
    if (!members.length) {
      el.innerHTML = '<p class="text-sm text-[var(--text-muted)] py-4">Nenhum membro no comitê. Use a busca acima para adicionar membros.</p>';
      return;
    }
    el.innerHTML = members.map((c: any) => `
      <div class="flex items-center justify-between bg-[var(--surface-base)] rounded-xl px-4 py-3">
        <div>
          <span class="font-semibold text-sm text-[var(--text-primary)]">${esc(c.member_name || '—')}</span>
          <span class="text-[11px] text-[var(--text-muted)] ml-2">${esc(c.member_role || '')}</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${c.role === 'lead' ? 'bg-purple-50 text-purple-700' : 'bg-blue-50 text-blue-700'}">${c.role}</span>
          ${c.can_interview ? '<span class="text-[10px] text-emerald-600">pode entrevistar</span>' : ''}
          <button class="text-[11px] text-red-500 hover:underline cursor-pointer bg-transparent border-0 p-0" data-action="remove-committee" data-member-id="${esc(c.member_id)}">remover</button>
        </div>
      </div>
    `).join('');
  }

  let committeeSearchTimeout: any = null;

  function setupCommitteeSearch() {
    const input = document.getElementById('committee-search') as HTMLInputElement;
    const results = document.getElementById('committee-search-results');
    if (!input || !results) return;

    input.addEventListener('input', () => {
      clearTimeout(committeeSearchTimeout);
      const query = input.value.trim();
      if (query.length < 2) { results.classList.add('hidden'); return; }
      committeeSearchTimeout = setTimeout(async () => {
        const { data: members } = await sb.from('members')
          .select('id, name, operational_role')
          .ilike('name', `%${query}%`)
          .eq('is_active', true)
          .order('name')
          .limit(8);
        if (!members?.length) {
          results.innerHTML = '<div class="px-4 py-3 text-[12px] text-[var(--text-muted)]">Nenhum membro encontrado</div>';
        } else {
          results.innerHTML = members.map((m: any) =>
            `<div class="px-4 py-2.5 hover:bg-[var(--surface-hover)] cursor-pointer text-[13px] flex items-center justify-between" data-action="add-committee-member" data-member-id="${esc(m.id)}" data-member-name="${esc(m.name)}">
              <span class="font-semibold text-[var(--text-primary)]">${esc(m.name)}</span>
              <span class="text-[11px] text-[var(--text-muted)]">${esc(m.operational_role || '')}</span>
            </div>`
          ).join('');
        }
        results.classList.remove('hidden');
      }, 300);
    });

    // Close on click outside (delayed to let action handler fire first)
    document.addEventListener('mousedown', (e) => {
      if (!input.contains(e.target as Node) && !results.contains(e.target as Node)) {
        setTimeout(() => results.classList.add('hidden'), 150);
      }
    });

    // Direct click handler on results (more reliable than delegated)
    results.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest<HTMLElement>('[data-action="add-committee-member"]');
      if (item?.dataset.memberId) {
        addCommitteeMemberById(item.dataset.memberId, item.dataset.memberName || '');
      }
    });
  }

  async function addCommitteeMemberById(memberId: string, memberName: string) {
    if (!currentCycleId) return;
    const role = (document.getElementById('committee-role-select') as HTMLSelectElement)?.value || 'evaluator';
    try {
      const { data, error } = await sb.rpc('manage_selection_committee', {
        p_cycle_id: currentCycleId, p_action: 'add', p_member_id: memberId, p_role: role,
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error);
      toast(`${memberName} adicionado como ${role}`);
      const input = document.getElementById('committee-search') as HTMLInputElement;
      if (input) input.value = '';
      document.getElementById('committee-search-results')?.classList.add('hidden');
      loadCommittee();
    } catch (e: any) {
      toast(e.message || 'Erro ao adicionar', 'error');
    }
  }

  async function removeCommitteeMember(memberId: string) {
    if (!currentCycleId || !confirm('Remover este membro do comitê?')) return;
    const { error } = await sb.rpc('manage_selection_committee', {
      p_cycle_id: currentCycleId, p_action: 'remove', p_member_id: memberId,
    });
    if (error) { toast(error.message, 'error'); return; }
    toast('Membro removido do comitê');
    loadCommittee();
  }

  /* ── bulk selection helpers ─────────────────────────── */
  function updateBulkBar() {
    const checks = document.querySelectorAll<HTMLInputElement>('.sel-row-check:checked');
    const bar = document.getElementById('bulk-actions');
    const countEl = document.getElementById('bulk-count');
    if (bar) bar.classList.toggle('hidden', checks.length === 0);
    if (countEl) countEl.textContent = `${checks.length} selecionado${checks.length !== 1 ? 's' : ''}`;
  }

  async function executeBulkDecision(decision: string) {
    const checks = document.querySelectorAll<HTMLInputElement>('.sel-row-check:checked');
    const ids = Array.from(checks).map(c => c.value);
    if (!ids.length) return;
    const labels: Record<string, string> = { approved: 'aprovar', rejected: 'rejeitar', waitlist: 'colocar em lista de espera' };
    if (!confirm(`Deseja ${labels[decision] || decision} ${ids.length} candidato(s)?`)) return;
    let ok = 0;
    let fail = 0;
    for (const id of ids) {
      try {
        const { error } = await sb.rpc('admin_update_application', {
          p_application_id: id,
          p_data: { status: decision },
        });
        if (error) throw error;
        ok++;
      } catch { fail++; }
    }
    toast(`${ok} atualizado(s)${fail ? `, ${fail} erro(s)` : ''}`);
    loadDashboard();
  }

  /* ── evaluation results ──────────────────────────── */
  async function loadEvaluationResults(applicationId: string) {
    const container = document.getElementById('eval-form-container');
    if (!container) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando resultados...</p>';
    try {
      const { data, error } = await sb.rpc('get_evaluation_results', { p_application_id: applicationId });
      if (error) throw error;
      if (!data) throw new Error('Sem dados');

      const evaluations = data.evaluations || [];
      const consolidated = data.consolidated || {};
      const criteriaKeys = evaluations.length ? Object.keys(evaluations[0].scores || {}) : [];
      const evaluatorNames = evaluations.map((ev: any) => esc(ev.evaluator_name || 'Avaliador'));

      let html = '<div class="space-y-4">';
      html += '<h4 class="text-sm font-bold text-navy">Resultados Consolidados</h4>';

      if (criteriaKeys.length && evaluations.length) {
        html += '<div class="overflow-x-auto"><table class="w-full text-[12px] text-left"><thead><tr class="bg-[var(--surface-base)]">';
        html += '<th class="px-3 py-2 font-bold text-[var(--text-secondary)]">Criterio</th>';
        evaluatorNames.forEach((n: string) => { html += `<th class="px-3 py-2 font-bold text-[var(--text-secondary)]">${n}</th>`; });
        html += '<th class="px-3 py-2 font-bold text-navy">PERT</th></tr></thead><tbody>';
        for (const key of criteriaKeys) {
          html += '<tr class="border-t border-[var(--border-subtle)]">';
          html += `<td class="px-3 py-2 font-semibold">${esc(key)}</td>`;
          const scores: number[] = [];
          for (const ev of evaluations) {
            const val = ev.scores?.[key];
            scores.push(val != null ? Number(val) : 0);
            const maxDiv = scores.length >= 2 ? Math.max(...scores) - Math.min(...scores) : 0;
            const bgClass = maxDiv > 3 ? 'bg-amber-100' : '';
            html += `<td class="px-3 py-2 ${bgClass}">${val != null ? val : '—'}</td>`;
          }
          // Check divergence across all evaluators for this criterion
          const allVals = evaluations.map((ev: any) => ev.scores?.[key]).filter((v: any) => v != null).map(Number);
          const divergence = allVals.length >= 2 ? Math.max(...allVals) - Math.min(...allVals) : 0;
          const pertBg = divergence > 3 ? 'bg-amber-100' : '';
          const pert = consolidated.criteria_pert?.[key];
          html += `<td class="px-3 py-2 font-bold text-navy ${pertBg}">${pert != null ? Number(pert).toFixed(1) : '—'}</td>`;
          html += '</tr>';
        }
        html += '</tbody></table></div>';
      } else {
        html += '<p class="text-sm text-[var(--text-muted)]">Nenhuma avaliacao encontrada.</p>';
      }

      // Consolidated scores
      html += '<div class="grid grid-cols-3 gap-3 mt-3">';
      html += `<div class="bg-[var(--surface-base)] rounded-xl p-3 text-center"><div class="text-lg font-extrabold text-navy">${consolidated.objective_score != null ? Number(consolidated.objective_score).toFixed(1) : '—'}</div><div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">Obj. Score</div></div>`;
      html += `<div class="bg-[var(--surface-base)] rounded-xl p-3 text-center"><div class="text-lg font-extrabold text-navy">${consolidated.interview_score != null ? Number(consolidated.interview_score).toFixed(1) : '—'}</div><div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">Interview Score</div></div>`;
      html += `<div class="bg-[var(--surface-base)] rounded-xl p-3 text-center"><div class="text-lg font-extrabold text-navy">${consolidated.final_score != null ? Number(consolidated.final_score).toFixed(1) : '—'}</div><div class="text-[.6rem] text-[var(--text-secondary)] font-semibold">Final Score</div></div>`;
      html += '</div>';
      html += '</div>';
      container.innerHTML = html;
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar resultados')}</p>`;
    }
  }

  /* ── interview scoring form ──────────────────────── */
  async function loadInterviewForm(row: any) {
    const container = document.getElementById('modal-tab-interview');
    if (!container) return;

    // Keep existing scheduling section, append interview scoring below
    let scoringDiv = container.querySelector('#interview-scoring-section');
    if (scoringDiv) scoringDiv.remove();

    scoringDiv = document.createElement('div');
    scoringDiv.id = 'interview-scoring-section';
    scoringDiv.className = 'space-y-4 mt-4 border-t border-[var(--border-default)] pt-4';
    scoringDiv.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando entrevista...</p>';
    container.appendChild(scoringDiv);

    try {
      const { data: interviewsRaw } = await sb.rpc('get_application_interviews', { p_application_id: row.id });
      const interviews = Array.isArray(interviewsRaw) ? interviewsRaw : [];

      if (!interviews?.length) {
        scoringDiv.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Nenhuma entrevista agendada.</p>';
        return;
      }

      const interview = interviews[0];
      const statusLabel = STATUS_LABELS[`interview_${interview.status}`] || interview.status;
      let html = `<div class="bg-[var(--surface-base)] rounded-xl p-3 mb-3">
        <div class="flex items-center justify-between">
          <span class="text-[12px] font-bold text-[var(--text-secondary)]">Entrevista: ${esc(statusLabel)}</span>
          <span class="text-[11px] text-[var(--text-muted)]">${interview.scheduled_at ? new Date(interview.scheduled_at).toLocaleString('pt-BR') : '—'}</span>
        </div>
      </div>`;

      // Gap 3: Interview status buttons
      if (interview.status === 'scheduled') {
        html += `<div class="flex gap-2 mb-3">
          <button class="interview-status-btn px-3 py-1.5 bg-orange-500 text-white rounded-lg text-[12px] font-bold cursor-pointer border-0 hover:opacity-90" data-interview-id="${esc(interview.id)}" data-status="noshow">No-Show</button>
          <button class="interview-status-btn px-3 py-1.5 bg-red-500 text-white rounded-lg text-[12px] font-bold cursor-pointer border-0 hover:opacity-90" data-interview-id="${esc(interview.id)}" data-status="cancelled">Cancelar</button>
        </div>`;
      }

      // Gap 2: Interview scoring form
      if (interview.status === 'scheduled' || interview.status === 'completed') {
        try {
          const { data: formData, error: formError } = await sb.rpc('get_evaluation_form', {
            p_application_id: row.id, p_evaluation_type: 'interview',
          });
          if (!formError && formData) {
            const criteria = formData.criteria || [];
            const draft = formData.draft;
            const isLocked = formData.is_locked;

            html += `<h4 class="text-sm font-bold text-navy">Avaliacao da Entrevista (0-10)</h4>`;
            if (isLocked) {
              html += '<div class="bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3 text-sm text-emerald-800 font-semibold mb-3">Avaliacao da entrevista ja submetida.</div>';
            }
            html += criteria.map((c: any) => `
              <div class="bg-[var(--surface-base)] rounded-xl p-3">
                <div class="flex items-center justify-between mb-1">
                  <label class="text-[12px] font-bold text-[var(--text-primary)]">${esc(c.label)} <span class="text-[var(--text-muted)] font-normal">(peso ${c.weight})</span></label>
                  <span class="intv-score-display text-sm font-bold text-navy" data-key="${esc(c.key)}">${draft?.scores?.[c.key] ?? '—'}</span>
                </div>
                <input type="range" min="0" max="10" step="1" value="${draft?.scores?.[c.key] ?? 5}"
                  data-intv-key="${esc(c.key)}" ${isLocked ? 'disabled' : ''}
                  class="w-full accent-navy" />
                <p class="text-[10px] text-[var(--text-muted)] mt-1">${esc(c.guide || '')}</p>
              </div>
            `).join('');

            html += `<input type="text" id="intv-theme" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" placeholder="Tema discutido..." value="${esc(draft?.theme || '')}" ${isLocked ? 'disabled' : ''} />`;
            html += `<textarea id="intv-notes" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-16" placeholder="Notas da entrevista..." ${isLocked ? 'disabled' : ''}>${esc(draft?.notes || '')}</textarea>`;
            if (!isLocked) {
              html += `<button id="submit-interview-scores-btn" data-interview-id="${esc(interview.id)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Submeter Avaliacao da Entrevista</button>`;
            }
          }
        } catch { /* scoring form not available */ }
      }

      scoringDiv.innerHTML = html;

      // Wire up slider live display
      scoringDiv.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
        const key = slider.dataset.intvKey;
        slider.addEventListener('input', () => {
          const display = scoringDiv!.querySelector(`.intv-score-display[data-key="${key}"]`);
          if (display) display.textContent = slider.value;
        });
      });

      // Wire up interview status buttons (Gap 3)
      scoringDiv.querySelectorAll<HTMLButtonElement>('.interview-status-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const intvId = btn.dataset.interviewId;
          const status = btn.dataset.status;
          if (!intvId || !status) return;
          try {
            const { error } = await sb.rpc('mark_interview_status', { p_interview_id: intvId, p_status: status });
            if (error) throw error;
            toast(status === 'noshow' ? 'Marcado como No-Show' : 'Entrevista cancelada');
            loadInterviewForm(row);
            loadDashboard();
          } catch (e: any) { toast(e.message || 'Erro', 'error'); }
        });
      });

      // Wire up interview scoring submit (Gap 2)
      scoringDiv.querySelector('#submit-interview-scores-btn')?.addEventListener('click', async () => {
        const scores: Record<string, number> = {};
        scoringDiv!.querySelectorAll<HTMLInputElement>('input[type="range"]').forEach(slider => {
          if (slider.dataset.intvKey) scores[slider.dataset.intvKey] = parseInt(slider.value, 10);
        });
        const theme = (scoringDiv!.querySelector('#intv-theme') as HTMLInputElement)?.value || '';
        const notes = (scoringDiv!.querySelector('#intv-notes') as HTMLTextAreaElement)?.value || '';
        const btn2 = scoringDiv!.querySelector('#submit-interview-scores-btn') as HTMLButtonElement;
        if (btn2) { btn2.disabled = true; btn2.textContent = 'Submetendo...'; }
        try {
          const { error } = await sb.rpc('submit_interview_scores', {
            p_interview_id: interview.id,
            p_scores: scores,
            p_theme: theme,
            p_notes: notes,
          });
          if (error) throw error;
          toast('Avaliacao da entrevista submetida');
          loadInterviewForm(row);
          loadDashboard();
        } catch (e: any) {
          toast(e.message || 'Erro ao submeter', 'error');
          if (btn2) { btn2.disabled = false; btn2.textContent = 'Submeter Avaliacao da Entrevista'; }
        }
      });
    } catch (e: any) {
      scoringDiv.innerHTML = `<p class="text-sm text-red-500">${esc(e.message || 'Erro ao carregar entrevista')}</p>`;
    }
  }

  /* ── event binding ────────────────────────────────── */
  let searchTimeout: any = null;

  function bindEvents() {
    // Tabs
    document.querySelectorAll('.sel-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.selTab;
        if (tab) {
          switchTab(tab);
          if (tab === 'committee') loadCommittee();
        }
      });
    });

    // Cycle picker
    document.getElementById('sel-cycle-picker')?.addEventListener('change', (e) => {
      const newId = (e.target as HTMLSelectElement).value;
      if (newId && newId !== currentCycleId) {
        currentCycleId = newId;
        // Reload with specific cycle — need to use cycle_code
        const cycle = allCycles.find((c: any) => c.id === newId);
        if (cycle) {
          sb.rpc('get_selection_dashboard', { p_cycle_code: cycle.cycle_code }).then(({ data }: any) => {
            if (data) {
              allRows = data.applications || [];
              const badge = document.getElementById('sel-cycle-badge');
              if (badge && data.cycle) {
                const cs = CYCLE_STATUS_COLORS[data.cycle.status] || CYCLE_STATUS_COLORS.draft;
                badge.className = `text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase ${cs.bg} ${cs.color}`;
                badge.textContent = data.cycle.status.toUpperCase();
              }
              populateChapterDropdown();
              applyFilters();
            }
          });
        }
      }
    });

    // Role toggle
    document.getElementById('sel-role-toggle')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.sel-role-btn');
      if (!btn) return;
      filterRole = btn.dataset.role || 'all';
      document.querySelectorAll('.sel-role-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.role === filterRole;
        b.classList.toggle('bg-navy', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('bg-[var(--surface-card)]', !isActive);
        b.classList.toggle('text-[var(--text-secondary)]', !isActive);
      });
      applyFilters();
    });

    // Dropdowns
    document.getElementById('sel-chapter')?.addEventListener('change', (e) => { filterChapter = (e.target as HTMLSelectElement).value; applyFilters(); });
    document.getElementById('sel-status')?.addEventListener('change', (e) => { filterStatus = (e.target as HTMLSelectElement).value; applyFilters(); });

    // Search
    document.getElementById('sel-search')?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => { filterSearch = ((e.target as HTMLInputElement).value || '').trim(); applyFilters(); }, 300);
    });

    // Column sorting
    document.querySelectorAll<HTMLElement>('[data-sort]').forEach(th => {
      th.addEventListener('click', () => {
        const col = th.dataset.sort!;
        if (sortCol === col) { sortAsc = !sortAsc; } else { sortCol = col; sortAsc = col === 'applicant_name'; }
        applyFilters();
      });
    });

    // Delegated click actions
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      const action = target.dataset.action;
      if (action === 'view-applicant' && target.dataset.id) { openApplicantModal(target.dataset.id); }
      else if (action === 'remove-committee' && target.dataset.memberId) { removeCommitteeMember(target.dataset.memberId); }
      else if (action === 'add-committee-member' && target.dataset.memberId) {
        addCommitteeMemberById(target.dataset.memberId, target.dataset.memberName || '');
      }
    });

    // Check-all checkbox (Gap 4)
    document.getElementById('sel-check-all')?.addEventListener('change', (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      document.querySelectorAll<HTMLInputElement>('.sel-row-check').forEach(cb => { cb.checked = checked; });
      updateBulkBar();
    });
    document.addEventListener('change', (e) => {
      if ((e.target as HTMLElement).classList.contains('sel-row-check')) updateBulkBar();
    });

    // Bulk action buttons (Gap 4)
    document.querySelectorAll<HTMLButtonElement>('.bulk-action-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const decision = btn.dataset.decision;
        if (decision) executeBulkDecision(decision);
      });
    });

    // Recalculate rankings (Gap 5)
    document.getElementById('recalc-rankings-btn')?.addEventListener('click', async () => {
      if (!currentCycleId) { toast('Nenhum ciclo selecionado', 'error'); return; }
      const btn = document.getElementById('recalc-rankings-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Calculando...'; }
      try {
        const { error } = await sb.rpc('calculate_rankings', { p_cycle_id: currentCycleId });
        if (error) throw error;
        toast('Rankings recalculados');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao recalcular', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Recalcular Rankings'; }
      }
    });

    // Start screening (Gap 10)
    document.getElementById('start-screening-btn')?.addEventListener('click', async () => {
      const submitted = allRows.filter(r => r.status === 'submitted');
      if (!submitted.length) { toast('Nenhum candidato com status "submitted"', 'error'); return; }
      if (!confirm(`Iniciar triagem para ${submitted.length} candidato(s)?`)) return;
      const btn = document.getElementById('start-screening-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Processando...'; }
      let ok = 0;
      let fail = 0;
      for (const r of submitted) {
        try {
          const { error } = await sb.rpc('admin_update_application', {
            p_application_id: r.id,
            p_data: { status: 'screening' },
          });
          if (error) throw error;
          ok++;
        } catch { fail++; }
      }
      toast(`${ok} candidato(s) movidos para triagem${fail ? `, ${fail} erro(s)` : ''}`);
      if (btn) { btn.disabled = false; btn.textContent = 'Iniciar Triagem'; }
      loadDashboard();
    });

    // Committee search setup
    setupCommitteeSearch();

    // Modal close
    document.getElementById('modal-close')?.addEventListener('click', () => {
      document.getElementById('applicant-modal')?.classList.add('hidden');
    });
    document.getElementById('applicant-modal')?.addEventListener('click', (e) => {
      if (e.target === e.currentTarget) (e.target as HTMLElement).classList.add('hidden');
    });

    // CSV file input
    const dropzone = document.getElementById('csv-dropzone');
    const fileInput = document.getElementById('csv-file-input') as HTMLInputElement;
    dropzone?.addEventListener('click', () => fileInput?.click());
    dropzone?.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('dragleave', () => { dropzone.classList.remove('border-navy', 'bg-blue-50/30'); });
    dropzone?.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('border-navy', 'bg-blue-50/30');
      const file = e.dataTransfer?.files[0];
      if (file) handleCSVFile(file);
    });
    fileInput?.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (file) handleCSVFile(file);
    });
    document.getElementById('csv-import-btn')?.addEventListener('click', executeImport);
    document.getElementById('csv-cancel-btn')?.addEventListener('click', () => {
      document.getElementById('csv-preview')?.classList.add('hidden');
      document.getElementById('csv-dropzone')?.classList.remove('hidden');
      csvParsedRows = [];
    });
  }

  function handleCSVFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      const text = e.target?.result as string;
      if (!text) return;
      const rows = parseCSV(text);
      if (rows.length === 0) { toast('CSV vazio ou formato inválido', 'error'); return; }
      renderCSVPreview(rows);
    };
    reader.readAsText(file, 'UTF-8');
  }

  /* ── permission gate ──────────────────────────────── */
  function applyGate(m: any) {
    if (m && canAccessAdminRoute(m, 'admin_selection')) {
      showPanel();
      loadCycles().then(() => loadDashboard());
    } else {
      showDenied();
    }
  }

  /* ── boot ─────────────────────────────────────────── */
  let bootRetries = 0;
  async function boot() {
    sb = (window as any).navGetSb?.();
    const m = (window as any).navGetMember?.();
    if (!sb || !m) {
      bootRetries += 1;
      if (bootRetries >= 20) { showDenied(); return; }
      setTimeout(boot, 200);
      return;
    }
    MEMBER = m;
    bindEvents();
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) { MEMBER = e.detail; applyGate(MEMBER); }
    }) as EventListener);
    applyGate(MEMBER);
  }

  boot();
</script>
