  // p152 Wave 1.0: shadow VEP filter button toggle text
  hideShadowVep: t('admin.selection.hideShadowVep', lang),
  showShadowVep: t('admin.selection.showShadowVep', lang),
  // p152 Wave 3.7: hidden-by-filter inline count
  hiddenByFilter: t('admin.selection.hiddenByFilter', lang),
