            </div>` : ''}
            ${row.academic_background ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">${T.modal.academicBackground}</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[120px] overflow-y-auto">${esc(row.academic_background)}</p></div>` : ''}
            ${row.motivation ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">${T.modal.motivation}</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[200px] overflow-y-auto">${esc(row.motivation)}</p></div>` : ''}
            ${row.areas_of_interest ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">${T.modal.areasOfInterest}</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3">${esc(row.areas_of_interest)}</p></div>` : ''}
            ${row.proposed_theme ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">Tema Proposto</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[200px] overflow-y-auto">${esc(row.proposed_theme)}</p></div>` : ''}
            ${row.leadership_experience ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">Experiência em Liderança</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[200px] overflow-y-auto">${esc(row.leadership_experience)}</p></div>` : ''}
            ${row.non_pmi_experience ? `<div><h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">${T.modal.nonPmiExperience}</h4><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded-lg p-3 whitespace-pre-wrap max-h-[120px] overflow-y-auto">${esc(row.non_pmi_experience)}</p></div>` : ''}
            <div class="grid grid-cols-2 gap-3 text-[13px]">
              <div><span class="text-[var(--text-muted)] text-[11px]">${T.modal.objScore}</span><br><strong class="text-lg">${row.objective_score != null ? Number(row.objective_score).toFixed(1) : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">${T.modal.finalScore}</span><br><strong class="text-lg text-navy">${row.final_score != null ? Number(row.final_score).toFixed(1) : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">${T.modal.rankChapter}</span><br><strong>${row.rank_chapter != null ? '#' + row.rank_chapter : '—'}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[11px]">${T.modal.rankOverall}</span><br><strong>${row.rank_overall != null ? '#' + row.rank_overall : '—'}</strong></div>
            </div>
            ${row.tags?.length ? `<div class="flex gap-1 flex-wrap">${row.tags.map((t: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-purple-50 text-purple-700 font-semibold">${esc(t)}</span>`).join('')}</div>` : ''}
            ${phaseBSummary}
            ${row.is_returning_member ? `<div id="returning-context-panel" data-app-id="${esc(row.id)}" class="border border-blue-100 bg-blue-50/40 rounded-xl p-3"><p class="text-[12px] text-blue-700">${T.modal.loadingReturningContext}</p></div>` : ''}
          </div>
          <div class="space-y-4">
            ${row.promotion_path === 'dual_track' && row.linked_application_id ? `
              <div class="px-3 py-2 rounded-lg bg-purple-50 border border-purple-200 text-[11px] text-purple-900">
                <strong>🔗 Dual Track</strong> · Candidato submeteu 2 candidaturas (Pesquisador + Líder). Decisão pode ser independente para cada papel.
              </div>
              <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">Decisão como Pesquisador</h4>
              <select id="modal-status-researcher" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
                <option value="" disabled selected>— Selecionar —</option>
                <option value="approved">${T.statusLabels?.approved || 'Aprovado'}</option>
                <option value="rejected">${T.statusLabels?.rejected || 'Rejeitado'}</option>
                <option value="waitlist">${T.statusLabels?.waitlist || 'Lista de Espera'}</option>
              </select>
              <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">Decisão como Líder</h4>
              <select id="modal-status-leader" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
                <option value="" disabled selected>— Selecionar —</option>
                <option value="approved">${T.statusLabels?.approved || 'Aprovado'}</option>
                <option value="rejected">${T.statusLabels?.rejected || 'Rejeitado'}</option>
                <option value="waitlist">${T.statusLabels?.waitlist || 'Lista de Espera'}</option>
              </select>
              <textarea id="modal-feedback" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="${T.modal.feedbackPlaceholder}">${esc(row.feedback || '')}</textarea>
              <button id="modal-dual-save-btn" data-id="${esc(row.id)}" class="w-full px-4 py-2.5 bg-purple-700 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Aplicar decisões duplas</button>
            ` : `
              <h4 class="text-[12px] font-bold text-[var(--text-secondary)]">${T.modal.changeStatus}</h4>
              <select id="modal-status-select" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]">
                ${Object.entries(STATUS_LABELS).map(([k, v]) => `<option value="${k}" ${k === row.status ? 'selected' : ''}>${v}</option>`).join('')}
              </select>
              <textarea id="modal-feedback" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="${T.modal.feedbackPlaceholder}">${esc(row.feedback || '')}</textarea>
              <button id="modal-save-btn" data-id="${esc(row.id)}" class="w-full px-4 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">${T.modal.saveChanges}</button>
            `}
          </div>
        </div>
      </div>

      <!-- TAB: Evaluate (blind review) -->
      <div id="modal-tab-evaluate" class="hidden">
        <div id="eval-form-container" class="space-y-4">
          <p class="text-sm text-[var(--text-muted)]">${T.modal.loadingEvaluation}</p>
        </div>
      </div>

      <!-- TAB: Interview (p109 Onda 4 Fase 1.4: scoringDiv prepended renders briefing + contextual + unified scoring; Roteiro estático removido — fundido com sliders por pilar) -->
      <div id="modal-tab-interview" class="hidden">
        ${currentCycle?.interview_booking_url ? `<a href="${esc(currentCycle.interview_booking_url)}" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[12px] font-semibold text-navy hover:underline mb-3">${T.modal.scheduleViaExternal}</a>` : ''}
        <!-- p152 W4: wrapped Agendar form with #manual-agendar-section so loadInterviewForm can collapse it
             when há entrevista ativa (toggle button revela quando admin precisa override). -->
        <div id="manual-agendar-section" class="space-y-4">
          <h4 class="text-sm font-bold text-navy">${T.modal.scheduleInterviewTitle}</h4>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] font-semibold text-[var(--text-secondary)] mb-1">${T.modal.dateTimeLabel}</label>
              <input type="datetime-local" id="interview-datetime" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
            </div>
            <div>
              <label class="block text-[11px] font-semibold text-[var(--text-secondary)] mb-1">${T.modal.durationLabel}</label>
              <input type="number" id="interview-duration" value="30" min="15" max="120" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)]" />
            </div>
          </div>
          <button id="schedule-interview-btn" data-app-id="${esc(row.id)}" class="px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">${T.modal.scheduleBtn}</button>
        </div>
        ${(row.status === 'interview_pending' || row.status === 'interview_scheduled' || row.status === 'interview_noshow') ? `
        <div class="space-y-3 mt-6 pt-4 border-t border-[var(--border-default)]">
          <div class="flex items-center gap-2">
            <h4 class="text-sm font-bold text-amber-700">Pedir Reagendamento</h4>
            ${row.interview_status === 'needs_reschedule' ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">Já solicitado</span>' : ''}
          </div>
          <p class="text-[12px] text-[var(--text-muted)]">Marca a aplicação como needs_reschedule e envia email ao candidato com novo link de booking.</p>
          ${row.interview_reschedule_reason ? `<div class="text-[12px] text-[var(--text-secondary)] bg-[var(--surface-base)] rounded-lg p-2"><strong>Motivo anterior:</strong> ${esc(row.interview_reschedule_reason)}</div>` : ''}
          <textarea id="reschedule-reason" class="w-full px-3 py-2 text-sm border border-[var(--border-default)] rounded-lg bg-[var(--surface-input)] h-20" placeholder="Motivo (visível ao candidato)..."></textarea>
          <button id="reschedule-btn" data-app-id="${esc(row.id)}" class="px-5 py-2.5 bg-amber-600 text-white rounded-xl text-sm font-bold cursor-pointer border-0 hover:opacity-90">Pedir Reagendamento</button>
        </div>
        ` : ''}
      </div>

      <!-- TAB: Comunicação (p86 #5) -->
      <div id="modal-tab-comms" class="hidden">
        <div id="comms-container" class="space-y-3">
          <p class="text-sm text-[var(--text-muted)]">${T.modal.loadingComms}</p>
        </div>
      </div>

      <!-- TAB: Análises IA (p86 Wave 5b-3) -->
      <div id="modal-tab-ai-runs" class="hidden">
        <div id="ai-runs-container" class="space-y-3">
          <p class="text-sm text-[var(--text-muted)]">${T.modal.loadingAi}</p>
        </div>
      </div>

      <!-- p150 B-light: TAB Vídeos — pmi_video_screenings tri-state visibility -->
      <div id="modal-tab-videos" class="hidden">
        <div id="videos-container" class="space-y-3">
          <p class="text-sm text-[var(--text-muted)]">${T.modal.loadingVideos}</p>
        </div>
      </div>

      <!-- p152 W4 P2: TAB PMI Profile — Phase B enriched data + service history + previous cycles -->
      <div id="modal-tab-pmi-profile" class="hidden">
        <div id="pmi-profile-container" class="space-y-3">
          <p class="text-sm text-[var(--text-muted)]">${T.modal.loadingPmiProfile}</p>
        </div>
      </div>

      <!-- TAB: Auditoria — gate_attempts timeline (p87 Sprint A.3.b / Issue #117) -->
      <div id="modal-tab-audit-log" class="hidden">
        <div id="audit-log-container" class="space-y-3">
          <p class="text-sm text-[var(--text-muted)]">${T.modal.loadingAudit}</p>
        </div>
      </div>
    `;

    // #91 G4: lazy-load returning candidate offboarding context
    if (row.is_returning_member) {
      loadReturningContext(row.id);
    }

    // Modal tab switching
    body.querySelectorAll('.modal-tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.modalTab;
        body.querySelectorAll('.modal-tab-btn').forEach(b => {
          const isActive = (b as HTMLElement).dataset.modalTab === tab;
          b.classList.toggle('border-navy', isActive);
          b.classList.toggle('text-navy', isActive);
          b.classList.toggle('border-transparent', !isActive);
          b.classList.toggle('text-[var(--text-secondary)]', !isActive);
        });
        ['info', 'evaluate', 'interview', 'comms', 'ai-runs', 'videos', 'pmi-profile', 'audit-log'].forEach(t => {
          body.querySelector(`#modal-tab-${t}`)?.classList.toggle('hidden', t !== tab);
        });
        if (tab === 'evaluate') loadEvaluationForm(row.id);
        if (tab === 'interview') loadInterviewForm(row);
        if (tab === 'comms') loadCommunications(row.id);
        if (tab === 'ai-runs') loadAiAnalysisRuns(row.id);
        if (tab === 'videos') loadVideoScreenings(row.id);
        if (tab === 'pmi-profile') loadPmiProfile(row.id);
        if (tab === 'audit-log') loadGateAuditLog(row.id);
      });
    });

    // Interview scheduling
    body.querySelector('#schedule-interview-btn')?.addEventListener('click', async () => {
      const dt = (body.querySelector('#interview-datetime') as HTMLInputElement)?.value;
      const dur = parseInt((body.querySelector('#interview-duration') as HTMLInputElement)?.value || '30', 10);
      if (!dt) { toast(T.modal.toastSelectDateTime, 'error'); return; }
      try {
        const { data, error } = await sb.rpc('schedule_interview', {
          p_application_id: row.id,
          p_interviewer_ids: [MEMBER.id],
          p_scheduled_at: new Date(dt).toISOString(),
          p_duration_minutes: dur,
        });
        if (error) throw error;
        toast(T.modal.toastInterviewScheduled);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) { toast(e.message || T.modal.toastErrorScheduling, 'error'); }
    });

    // p86 Wave 5d: request reschedule
    body.querySelector('#reschedule-btn')?.addEventListener('click', async () => {
      const reason = (body.querySelector('#reschedule-reason') as HTMLTextAreaElement)?.value?.trim();
      if (!reason) { toast(T.modal.toastReasonRequired, 'error'); return; }
      const btn = body.querySelector('#reschedule-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
      try {
        const { data, error } = await sb.rpc('request_interview_reschedule', {
          p_application_id: row.id,
          p_reason: reason,
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        toast(T.modal.toastRescheduleSent);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || T.modal.toastErrorReschedule, 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Pedir Reagendamento'; }
      }
    });

    // Save handler — uses admin_update_application RPC (validates auth, seeds onboarding on approve)
    body.querySelector('#modal-save-btn')?.addEventListener('click', async () => {
      const newStatus = (body.querySelector('#modal-status-select') as HTMLSelectElement)?.value;
      const feedback = (body.querySelector('#modal-feedback') as HTMLTextAreaElement)?.value;
      const btn = body.querySelector('#modal-save-btn') as HTMLButtonElement;
      if (btn) { btn.disabled = true; btn.textContent = 'Salvando...'; }
      try {
        const { data, error } = await sb.rpc('admin_update_application', {
          p_application_id: row.id,
          p_data: { status: newStatus, feedback },
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        const msg = newStatus === 'approved' ? 'Candidato aprovado — onboarding iniciado' : 'Candidato atualizado';
        toast(msg);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao salvar', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Salvar alterações'; }
      }
    });

    // p158 F4: dual_track save handler — uses admin_decide_dual_track RPC (cross-role decision +
    // auto-copy of role-agnostic scores). Mutually exclusive with #modal-save-btn (UI renders one
    // or the other based on row.promotion_path === 'dual_track').
    body.querySelector('#modal-dual-save-btn')?.addEventListener('click', async () => {
      const researcherDecision = (body.querySelector('#modal-status-researcher') as HTMLSelectElement)?.value;
      const leaderDecision = (body.querySelector('#modal-status-leader') as HTMLSelectElement)?.value;
      const feedback = (body.querySelector('#modal-feedback') as HTMLTextAreaElement)?.value;
      const btn = body.querySelector('#modal-dual-save-btn') as HTMLButtonElement;
      if (!researcherDecision || !leaderDecision) {
        toast('Selecione decisão para Pesquisador E Líder', 'error');
        return;
      }
      if (btn) { btn.disabled = true; btn.textContent = 'Aplicando…'; }
      try {
        const { data, error } = await sb.rpc('admin_decide_dual_track', {
          p_application_id:      row.id,
          p_researcher_decision: researcherDecision,
          p_leader_decision:     leaderDecision,
          p_feedback:            feedback || null,
        });
        if (error) throw error;
        if (data?.error) throw new Error(data.error);
        toast(`Decisões aplicadas — Pesquisador: ${researcherDecision} · Líder: ${leaderDecision}`);
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) {
        toast(e.message || 'Erro ao aplicar decisões duplas', 'error');
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Aplicar decisões duplas'; }
      }
    });

    // p158 F4: dual_track post-render — fetch merged_payload + inject sibling essay fields and
    // scores summary panel. Runs async after modal renders; silently no-ops on non-pair apps.
    if (row.promotion_path === 'dual_track' && row.linked_application_id) {
      sb.rpc('get_dual_track_merged_payload', { p_application_id: row.id }).then(({ data, error }) => {
        if (error || !data || data.error || !data.is_dual_track) return;
        const merged = data.merged_essays || {};
        const scores = data.scores_summary || {};
        const leftCol = body.querySelector('#modal-tab-info .grid > div.space-y-4');
        if (!leftCol) return;

        const appendMergedSection = (label: string, value: string | null | undefined, originRole: 'pesquisador' | 'líder') => {
          if (!value || !value.trim()) return;
          const div = document.createElement('div');
          div.dataset.mergedField = label;
          div.innerHTML = `<h4 class="text-[12px] font-bold text-[var(--text-secondary)] mb-1">${esc(label)} <span class="text-[10px] font-normal text-purple-700">(da candidatura ${originRole})</span></h4><p class="text-[13px] text-[var(--text-primary)] bg-purple-50/50 rounded-lg p-3 whitespace-pre-wrap max-h-[200px] overflow-y-auto">${esc(value)}</p>`;
          leftCol.appendChild(div);
        };

        if (!row.areas_of_interest && merged.areas_of_interest) {
          appendMergedSection(T.modal.areasOfInterest || 'Áreas de Interesse', merged.areas_of_interest, 'pesquisador');
        }
        if (!row.proposed_theme && merged.proposed_theme) {
          appendMergedSection('Tema Proposto', merged.proposed_theme, 'líder');
        }
        if (!row.leadership_experience && merged.leadership_experience) {
          appendMergedSection('Experiência em Liderança', merged.leadership_experience, 'líder');
        }

        const scoresDiv = document.createElement('div');
        scoresDiv.dataset.mergedField = 'pair_scores';
        const fmt = (v: number | null | undefined) => v != null ? Number(v).toFixed(1) : '—';
        scoresDiv.innerHTML = `
          <div class="mt-2 p-3 rounded-xl border border-purple-200 bg-purple-50/30 text-[12px]">
            <h4 class="text-[11px] font-bold text-purple-900 mb-1.5">🔗 Pair Scores (Dual Track)</h4>
            <div class="grid grid-cols-2 gap-x-4 gap-y-1">
              <div><span class="text-[var(--text-muted)] text-[10px]">Pesquisador</span><br><strong class="text-[12px]">obj ${fmt(scores.researcher_objective)} · entr ${fmt(scores.researcher_interview)} · final ${fmt(scores.researcher_final)}</strong></div>
              <div><span class="text-[var(--text-muted)] text-[10px]">Líder</span><br><strong class="text-[12px]">obj ${fmt(scores.leader_objective)} · entr ${fmt(scores.leader_interview)} · final ${fmt(scores.leader_final)}</strong></div>
            </div>
          </div>`;
        leftCol.appendChild(scoresDiv);
      }).catch(() => { /* silent */ });
    }

    // Save contact handler (phone/linkedin inline edit)
    body.querySelector('#save-contact-btn')?.addEventListener('click', async () => {
      const phone = (body.querySelector('#edit-phone') as HTMLInputElement)?.value?.trim();
      const linkedin = (body.querySelector('#edit-linkedin') as HTMLInputElement)?.value?.trim();
      if (!phone && !linkedin) { toast('Preencha ao menos um campo', 'error'); return; }
      try {
        const { error } = await sb.rpc('update_application_contact', {
          p_application_id: row.id,
          p_phone: phone || null,
          p_linkedin_url: linkedin || null,
        });
        if (error) throw error;
        toast('Contato atualizado');
        modal.classList.add('hidden');
        loadDashboard();
      } catch (e: any) { toast(e.message || 'Erro', 'error'); }
    });

    modal.classList.remove('hidden');
    // p109 Onda 4 Fase 4: a11y — sync aria-hidden + initial focus
    modal.setAttribute('aria-hidden', 'false');
    setTimeout(() => (document.getElementById('modal-close') as HTMLButtonElement | null)?.focus(), 0);
  }

  /* ── p86 Wave 5b-3: Análises IA tab — ai_analysis_runs timeline ─── */
  async function loadAiAnalysisRuns(applicationId: string) {
    const container = document.getElementById('ai-runs-container');
    if (!container || !sb) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando análises IA...</p>';
    try {
      const { data, error } = await sb.rpc('get_application_ai_analysis_runs', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      const runs = data?.runs || [];
      const topicsViews = data?.topics_views || { count: 0 };

      const triggeredByLabels: Record<string,string> = {
        consent: 'Consent inicial',
        enrichment_request: 'Pedido de enriquecimento',
        admin_retry: 'Retry admin',
        cron_retry: 'Retry cron',
      };
      const triggeredByColors: Record<string,string> = {
        consent: 'bg-blue-50 text-blue-700',
        enrichment_request: 'bg-amber-50 text-amber-700',
        admin_retry: 'bg-purple-50 text-purple-700',
        cron_retry: 'bg-slate-50 text-slate-700',
      };
      const statusColors: Record<string,string> = {
        running: 'text-amber-600',
        completed: 'text-emerald-700',
        failed: 'text-red-700',
      };

      const summary = `
        <div class="bg-[var(--surface-base)] border border-[var(--border-default)] rounded-xl p-3">
          <div class="flex flex-wrap items-center gap-3 text-[12px]">
            <div><span class="text-[var(--text-muted)]">Re-análises:</span> <strong>${data?.enrichment_count || 0} / 2</strong></div>
            ${data?.last_enrichment_at ? `<div><span class="text-[var(--text-muted)]">Última:</span> <strong>${new Date(data.last_enrichment_at).toLocaleString('pt-BR')}</strong></div>` : ''}
            <div class="ml-auto text-[var(--text-muted)]">
              ${topicsViews.count > 0 ? `👁️ Tópicos vistos ${topicsViews.count}x ${topicsViews.last_view_at ? `(último: ${new Date(topicsViews.last_view_at).toLocaleString('pt-BR')})` : ''}` : 'Tópicos não visualizados'}
            </div>
          </div>
        </div>
      `;

      if (runs.length === 0) {
        container.innerHTML = summary + '<p class="text-sm text-[var(--text-muted)] py-4">Nenhuma análise IA registrada (candidato não consentiu ou ainda não foi processado).</p>';
        return;
      }

      const raisesBarColors: Record<string,string> = {
        yes: 'bg-emerald-50 text-emerald-700 border-emerald-300',
        no: 'bg-red-50 text-red-700 border-red-300',
        uncertain: 'bg-amber-50 text-amber-700 border-amber-300',
      };
      const raisesBarLabels: Record<string,string> = {
        yes: '⬆ ELEVA A BARRA',
        no: '⬇ NÃO ELEVA',
        uncertain: '◐ INCERTO',
      };

      const runsHtml = runs.map((r: any) => {
        const tbBadge = `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${triggeredByColors[r.triggered_by] || 'bg-gray-100 text-gray-700'}">${triggeredByLabels[r.triggered_by] || r.triggered_by}</span>`;
        const statusBadge = `<span class="${statusColors[r.status] || 'text-gray-500'} text-[11px] font-bold uppercase">${r.status}</span>`;
        const startedDt = new Date(r.started_at).toLocaleString('pt-BR');
        const completedDt = r.completed_at ? new Date(r.completed_at).toLocaleString('pt-BR') : '—';
        const duration = r.duration_ms ? `${(r.duration_ms / 1000).toFixed(1)}s` : '—';
        const snapshot = r.ai_analysis_snapshot;
        const fitScore = snapshot?.fit_for_role?.score ?? '—';
        const seniority = snapshot?.seniority_signal ?? '—';
        const summary2 = snapshot?.summary || '';
        const redFlags = Array.isArray(snapshot?.red_flags) ? snapshot.red_flags : [];
        const areasToProbe = Array.isArray(snapshot?.areas_to_probe) ? snapshot.areas_to_probe : [];
        const strengths = Array.isArray(snapshot?.key_strengths) ? snapshot.key_strengths : [];
        const fieldsChanged = Array.isArray(r.fields_changed) ? r.fields_changed : [];
        const errorMsg = r.error_message ? `<div class="mt-2 text-[12px] text-red-700 bg-red-50 rounded-lg p-2">⚠️ ${esc(r.error_message)}</div>` : '';

        // p87 Sprint C.c: raises_the_bar prominent display (PM mindset Vitor 2026-05-01)
        // p87 Sprint #119 ratify: adicionar hint operacional baseado em validation report
        // (precision YES 75%, recall YES 33% — usar como filtro positivo, não auto-reject)
        const raisesBar = snapshot?.raises_the_bar;
        const fitForRoleScore = snapshot?.fit_for_role?.score ?? 0;
        const raisesBarBadge = raisesBar?.verdict
          ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full border ${raisesBarColors[raisesBar.verdict] || 'bg-gray-50 text-gray-700 border-gray-300'}">${raisesBarLabels[raisesBar.verdict] || raisesBar.verdict.toUpperCase()}</span>`
          : '';

        // Operational hint baseado em #119 validation findings (n=14 cycle3-2026)
        let operationalHint = '';
        if (raisesBar?.verdict === 'yes' && fitForRoleScore >= 4) {
          operationalHint = `<div class="text-[11px] mt-1 text-emerald-800 font-semibold">⭐ Skip-to-interview eligible — high precision shortlist (validated 75% precision em cycle3-2026)</div>`;
        } else if (raisesBar?.verdict === 'no') {
          operationalHint = `<div class="text-[11px] mt-1 text-amber-700">⚠️ Soft signal apenas — NÃO usar como auto-reject (validated 67% false-negative rate em cycle3-2026; comissão deve revisar via LinkedIn/par-revisão)</div>`;
        } else if (raisesBar?.verdict === 'uncertain') {
          operationalHint = `<div class="text-[11px] mt-1 text-blue-700">↺ Par-revisão prioritária — AI sinal não-conclusivo</div>`;
        }

        const raisesBarBlock = raisesBar?.verdict
          ? `<div class="border-l-4 ${raisesBar.verdict === 'yes' ? 'border-emerald-500' : raisesBar.verdict === 'no' ? 'border-red-500' : 'border-amber-500'} bg-[var(--surface-base)] rounded-r p-3 mb-2">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[11px] font-bold ${raisesBar.verdict === 'yes' ? 'text-emerald-700' : raisesBar.verdict === 'no' ? 'text-red-700' : 'text-amber-700'}">Raise the bar?</span>
                ${raisesBarBadge}
              </div>
              <p class="text-[12px] text-[var(--text-primary)]">${esc(raisesBar.rationale || '—')}</p>
              ${operationalHint}
            </div>`
          : '';

        return `<details class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl">
          <summary class="cursor-pointer px-4 py-3 flex items-center gap-2 flex-wrap select-none">
            <strong class="text-[13px] text-navy">Run #${r.run_index}</strong>
            ${tbBadge}
            ${statusBadge}
            ${raisesBarBadge}
            <span class="text-[11px] text-[var(--text-muted)]">${startedDt}</span>
            <span class="text-[11px] text-[var(--text-muted)] ml-auto">⏱ ${duration} • Fit ${fitScore}/5 • ${seniority}</span>
          </summary>
          <div class="px-4 pb-4 space-y-2 border-t border-[var(--border-default)] pt-3">
            ${raisesBarBlock}
            ${summary2 ? `<div><span class="text-[11px] text-[var(--text-muted)]">Sumário</span><p class="text-[13px] text-[var(--text-primary)] bg-[var(--surface-base)] rounded p-2 mt-1">${esc(summary2)}</p></div>` : ''}
            ${strengths.length ? `<div><span class="text-[11px] text-[var(--text-muted)]">Forças identificadas</span><ul class="text-[12px] mt-1 list-disc list-inside text-emerald-700">${strengths.map((s: string) => `<li>${esc(s)}</li>`).join('')}</ul></div>` : ''}
            ${areasToProbe.length ? `<div><span class="text-[11px] text-[var(--text-muted)]">Áreas a explorar (entrevista)</span><ul class="text-[12px] mt-1 list-disc list-inside text-blue-700">${areasToProbe.map((s: string) => `<li>${esc(s)}</li>`).join('')}</ul></div>` : ''}
            ${redFlags.length ? `<div><span class="text-[11px] text-[var(--text-muted)]">Red flags</span><ul class="text-[12px] mt-1 list-disc list-inside text-red-700">${redFlags.map((s: string) => `<li>${esc(s)}</li>`).join('')}</ul></div>` : ''}
            ${fieldsChanged.length ? `<div><span class="text-[11px] text-[var(--text-muted)]">Campos modificados (vs. run anterior)</span><div class="flex flex-wrap gap-1 mt-1">${fieldsChanged.map((f: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-amber-50 text-amber-700">${esc(f)}</span>`).join('')}</div></div>` : ''}
            <div class="text-[10px] text-[var(--text-muted)] flex flex-wrap gap-3 pt-1">
              <span>Modelo: ${esc(r.model_version || 'gemini-2.5-flash')}</span>
              <span>Concluída: ${completedDt}</span>
              ${r.input_token_estimate ? `<span>In: ${r.input_token_estimate} tk</span>` : ''}
              ${r.output_token_estimate ? `<span>Out: ${r.output_token_estimate} tk</span>` : ''}
            </div>
            ${errorMsg}
          </div>
        </details>`;
      }).join('');

      container.innerHTML = summary + '<div class="space-y-2 mt-3">' + runsHtml + '</div>';
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-700">Erro ao carregar análises IA: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── p150 B-light: Vídeos tab — per-application pmi_video_screenings detail.
     Renders 3 states:
       1) summary.total === 0 → "candidato ainda não decidiu" (T.modal.videosEmpty)
       2) summary.uploaded === 0 AND summary.opted_out > 0 → opt-out banner
       3) any uploaded → per-pillar list with transcription + drive/youtube links
     B-full (next sessions) will add ai_subjective_score per pillar in this same view. */
  async function loadVideoScreenings(applicationId: string) {
    const container = document.getElementById('videos-container');
    if (!container || !sb) return;
    container.innerHTML = `<p class="text-sm text-[var(--text-muted)]">${T.modal.loadingVideos}</p>`;
    try {
      const { data, error } = await sb.rpc('get_application_video_screenings', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error);
      const rows = Array.isArray(data?.rows) ? data.rows : [];
      const summary = data?.summary || { total: 0, uploaded: 0, opted_out: 0, failed: 0, total_duration_seconds: 0 };

      // State 1: no decision yet
      if ((summary.total || 0) === 0) {
        container.innerHTML = `<div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center text-sm text-[var(--text-muted)]">${esc(T.modal.videosEmpty)}</div>`;
        return;
      }

      // State 2: opted-out entirely (no uploads)
      if ((summary.uploaded || 0) === 0 && (summary.opted_out || 0) > 0) {
        container.innerHTML = `<div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-sm text-blue-900">⏭ ${esc(T.modal.videosOptedOut)}</div>`;
        return;
      }

      // State 3: at least one uploaded — render per-pillar cards
      const summaryLine = T.modal.videosSummary
        .replace('{uploaded}', String(summary.uploaded ?? 0))
        .replace('{total}', String(summary.total ?? 0))
        .replace('{durSec}', String(summary.total_duration_seconds ?? 0));

      const headerHtml = `
        <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-3 flex items-center justify-between flex-wrap gap-2">
          <div class="text-sm font-semibold text-emerald-900">📹 ${esc(summaryLine)}</div>
          <div class="text-[10px] text-emerald-700 italic">${esc(T.modal.videosNoAiScoreYet)}</div>
        </div>`;

      const rowsHtml = rows.map((v: any) => {
        const pillarLabel = `${esc(T.modal.videosPillar)} ${esc(v.pillar || '—')} · Q${v.question_index ?? '?'}`;
        const statusColor = v.status === 'transcribed' ? 'bg-emerald-100 text-emerald-700'
          : v.status === 'uploaded' || v.status === 'transcribing' ? 'bg-amber-100 text-amber-700'
          : v.status === 'opted_out' ? 'bg-blue-100 text-blue-700'
          : 'bg-gray-100 text-gray-500';
        const statusBadge = `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${statusColor}">${esc(v.status || '—')}</span>`;
        const durationStr = v.duration_seconds ? T.modal.videosDuration.replace('{sec}', String(v.duration_seconds)) : '';
        const confidenceStr = v.transcription_confidence
          ? T.modal.videosConfidence.replace('{pct}', String(Math.round(Number(v.transcription_confidence) * 100)))
          : '';
        const driveLink = (v.drive_file_id || v.drive_folder_id)
          ? `<a href="https://drive.google.com/file/d/${esc(v.drive_file_id || v.drive_folder_id)}/view" target="_blank" rel="noopener" class="text-[11px] text-navy underline">${esc(T.modal.videosViewFile)} ↗</a>`
          : '';
        const youtubeLink = v.youtube_url
          ? `<a href="${esc(v.youtube_url)}" target="_blank" rel="noopener" class="text-[11px] text-red-600 underline">${esc(T.modal.videosViewYoutube)} ↗</a>`
          : '';
        const transcription = v.transcription
          ? `<pre class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded p-2 text-[11px] whitespace-pre-wrap font-sans text-[var(--text-primary)] max-h-[200px] overflow-y-auto">${esc(v.transcription)}</pre>`
          : `<p class="text-[11px] text-[var(--text-muted)] italic">${esc(T.modal.videosNoTranscription)}</p>`;
        return `
          <div class="border border-[var(--border-default)] rounded-lg p-3 bg-[var(--surface-card)]">
            <div class="flex items-center justify-between flex-wrap gap-2 mb-1.5">
              <div class="text-[12px] font-bold text-navy">${pillarLabel}</div>
              <div class="flex items-center gap-2">${statusBadge}${durationStr ? `<span class="text-[10px] text-[var(--text-muted)]">${esc(durationStr)}</span>` : ''}</div>
            </div>
            <div class="text-[11px] text-[var(--text-secondary)] mb-2">${esc(v.question_text || '')}</div>
            <div class="mb-2">
              <div class="text-[10px] font-semibold text-[var(--text-muted)] mb-1">${esc(T.modal.videosTranscription)} ${confidenceStr ? `<span class="font-normal">(${esc(confidenceStr)})</span>` : ''}</div>
              ${transcription}
            </div>
            <div class="flex gap-3">${driveLink}${youtubeLink}</div>
          </div>`;
      }).join('');

      container.innerHTML = headerHtml + '<div class="space-y-2 mt-3">' + rowsHtml + '</div>';
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-700">Erro ao carregar vídeos: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── p152 W4 P2: PMI Profile tab — Phase B enriched + service history + previous cycles ─── */
  async function loadPmiProfile(applicationId: string) {
    const container = document.getElementById('pmi-profile-container');
    if (!container) return;
    container.innerHTML = `<p class="text-sm text-[var(--text-muted)]">${esc(T.modal.loadingPmiProfile)}</p>`;
    try {
      const { data, error } = await sb.rpc('get_application_pmi_profile', { p_application_id: applicationId });
      if (error) throw error;
      if (!data) { container.innerHTML = `<p class="text-sm text-[var(--text-muted)]">${esc(T.modal.pmiProfileEmpty)}</p>`; return; }

      const identity = data.identity || {};
      const chapters = data.chapters || {};
      const certs = data.certifications || {};
      const profile = data.profile || {};
      const serviceHistory = Array.isArray(data.service_history) ? data.service_history : [];
      const previousCycles = Array.isArray(data.previous_cycles) ? data.previous_cycles : [];

      const memberStatusBadge = (() => {
        const s = identity.member_status;
        if (s === 'active') return '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700">✓ Membro PMI ativo</span>';
        if (s === 'past') return '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">⚪ Membro PMI passado</span>';
        if (s === 'unknown' && identity.is_pmi_member) return '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">? PMI sem history</span>';
        return '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-red-50 text-red-700">— Sem pmi_id</span>';
      })();

      const identitySection = `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <div class="flex items-center justify-between mb-2 flex-wrap gap-2">
            <h4 class="text-[12px] font-bold text-navy">${esc(T.modal.pmiProfileIdentity)}</h4>
            ${memberStatusBadge}
          </div>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[12px]">
            ${identity.pmi_id ? `<div><span class="text-[var(--text-muted)] text-[10px]">PMI ID</span><br><strong>${esc(identity.pmi_id)}</strong></div>` : ''}
            <div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileServiceCount)}</span><br><strong>${identity.service_history_count || 0}</strong></div>
            ${identity.member_since ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileMemberSince)}</span><br><strong>${esc(identity.member_since)}</strong></div>` : ''}
            ${identity.member_until ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileMemberUntil)}</span><br><strong>${esc(identity.member_until)}</strong></div>` : ''}
          </div>
          ${identity.community_profile_private ? `<div class="mt-2 text-[10px] text-amber-700 italic">⚠ ${esc(T.modal.pmiProfilePrivate)}</div>` : ''}
          ${identity.phase_b_fetched_at ? `<div class="mt-1.5 text-[10px] text-[var(--text-muted)]">${esc(T.modal.pmiProfileFetched)}: ${esc(identity.phase_b_fetched_at)}</div>` : ''}
        </div>`;

      // Chapters
      const memberships = Array.isArray(chapters.memberships) ? chapters.memberships : [];
      const chaptersSection = (memberships.length || chapters.form_chapter || chapters.chapter_affiliation) ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">${esc(T.modal.pmiProfileChapters)}</h4>
          ${memberships.length ? `<div class="flex flex-wrap gap-1.5 mb-2">${memberships.map((m: any) => `<span class="text-[10px] font-semibold px-2 py-0.5 rounded-full bg-blue-50 text-blue-700">${esc(typeof m === 'string' ? m : (m.chapterName || JSON.stringify(m)))}</span>`).join('')}</div>` : ''}
          ${chapters.form_chapter ? `<div class="text-[11px] mb-0.5"><strong class="text-[var(--text-secondary)]">${esc(T.modal.pmiProfileFormChapter)}:</strong> ${esc(chapters.form_chapter)}</div>` : ''}
          ${chapters.chapter_affiliation ? `<div class="text-[11px] mb-0.5"><strong class="text-[var(--text-secondary)]">${esc(T.modal.pmiProfileChapterAffiliation)}:</strong> ${esc(chapters.chapter_affiliation)}</div>` : ''}
        </div>` : '';

      // Certifications
      const verifiedCerts = Array.isArray(certs.verified) ? certs.verified : [];
      const certsSection = (verifiedCerts.length || certs.form_declared) ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">${esc(T.modal.pmiProfileCertifications)}</h4>
          ${verifiedCerts.length ? `<div class="flex flex-wrap gap-1.5 mb-2">${verifiedCerts.map((c: string) => `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-amber-50 text-amber-700" title="PMI-verified">✓ ${esc(c)}</span>`).join('')}</div>` : ''}
          ${certs.form_declared ? `<div class="text-[11px] text-[var(--text-secondary)]"><strong>${esc(T.modal.pmiProfileFormDeclared)}:</strong> <span class="font-mono">${esc(certs.form_declared)}</span></div>` : ''}
        </div>` : '';

      // Profile (LinkedIn-style)
      const profileHasContent = profile.company || profile.designation || profile.about_me || profile.specialties || profile.industry || profile.location;
      const profileSection = profileHasContent ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">${esc(T.modal.pmiProfileProfile)}</h4>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[12px] mb-2">
            ${profile.company ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileCompany)}</span><br><strong>${esc(profile.company)}</strong></div>` : ''}
            ${profile.designation ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileDesignation)}</span><br><strong>${esc(profile.designation)}</strong></div>` : ''}
            ${profile.industry ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileIndustry)}</span><br><strong>${esc(profile.industry)}</strong></div>` : ''}
            ${profile.location ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileLocation)}</span><br><strong>${esc(profile.location)}</strong></div>` : ''}
          </div>
          ${profile.about_me ? `<details class="mt-2"><summary class="text-[11px] font-bold text-[var(--text-secondary)] cursor-pointer">${esc(T.modal.pmiProfileAboutMe)} (PMI Community bio)</summary><p class="text-[12px] mt-1.5 text-[var(--text-primary)] whitespace-pre-wrap bg-[var(--surface-base)] rounded-lg p-2 max-h-[200px] overflow-y-auto">${esc(profile.about_me)}</p></details>` : ''}
          ${(() => {
            // p153 polish — render comma-separated PMI Community fields as chips.
            // Same defensive guard (skip if "[object Object]" leak still present).
            const chipify = (val: string, prefixLabel: string, pillCls: string) => {
              if (!val || String(val).includes('[object Object]')) return '';
              const items = String(val).split(',').map(s => s.trim()).filter(Boolean);
              if (items.length === 0) return '';
              const chips = items.map(s => `<span class="text-[10px] font-semibold px-2 py-0.5 rounded-full ${pillCls}">${esc(s)}</span>`).join('');
              return `<div class="mt-2 text-[11px]"><strong class="text-[var(--text-secondary)] block mb-1">${esc(prefixLabel)}:</strong><div class="flex flex-wrap gap-1">${chips}</div></div>`;
            };
            return chipify(profile.specialties, T.modal.pmiProfileSpecialties, 'bg-purple-50 text-purple-700')
                 + chipify(profile.volunteer_interest, T.modal.pmiProfileVolInterest, 'bg-blue-50 text-blue-700');
          })()}
          ${profile.linkedin_url ? `<a href="${esc(profile.linkedin_url)}" target="_blank" rel="noopener" class="inline-block mt-2 text-[11px] text-blue-700 hover:underline">LinkedIn (PMI) →</a>` : ''}
        </div>` : '';

      // Service history
      const historySection = serviceHistory.length ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">${esc(T.modal.pmiProfileServiceHistory)} (${serviceHistory.length})</h4>
          <div class="space-y-2">
            ${serviceHistory.map((s: any) => {
              const ongoing = !s.end_date || new Date(s.end_date).getTime() >= Date.now();
              return `<div class="border-l-4 ${ongoing ? 'border-emerald-500 bg-emerald-50/30' : 'border-gray-300 bg-[var(--surface-base)]'} rounded-r p-2 text-[12px]">
                <div class="flex items-center justify-between gap-2 flex-wrap">
                  <strong class="text-[var(--text-primary)]">${esc(s.role_name || '—')}</strong>
                  ${ongoing ? '<span class="text-[9px] font-bold px-1.5 py-0.5 rounded bg-emerald-100 text-emerald-700">ATIVO</span>' : ''}
                </div>
                <div class="text-[11px] text-[var(--text-secondary)]">${esc(s.chapter_name || '—')}</div>
                <div class="text-[10px] text-[var(--text-muted)]">${esc(s.start_date || '?')} → ${esc(s.end_date || (ongoing ? 'em curso' : '?'))}</div>
              </div>`;
            }).join('')}
          </div>
        </div>` : '';

      // Previous cycles
      const prevSection = previousCycles.length ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">${esc(T.modal.pmiProfilePreviousCycles)} (${previousCycles.length})</h4>
          <div class="space-y-1.5">
            ${previousCycles.map((p: any) => `
              <div class="text-[12px] border border-[var(--border-subtle)] rounded p-2 flex items-center justify-between gap-2 flex-wrap">
                <div>
                  <strong class="text-navy">${esc(p.cycle_code || '?')}</strong>
                  <span class="text-[10px] text-[var(--text-muted)] ml-1">${esc(p.role_applied || '')}</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[10px] font-bold px-1.5 py-0.5 rounded ${(STATUS_BADGE[p.status]?.bg ?? 'bg-gray-100')} ${(STATUS_BADGE[p.status]?.color ?? 'text-gray-700')}">${esc(STATUS_LABELS[p.status] || p.status)}</span>
                  ${p.final_score != null ? `<span class="text-[10px] text-[var(--text-muted)]">${Number(p.final_score).toFixed(1)} pts</span>` : ''}
                  ${p.rank_overall != null ? `<span class="text-[10px] font-bold text-navy">#${p.rank_overall}</span>` : ''}
                </div>
              </div>`).join('')}
          </div>
        </div>` : '';

      // p152 W4 OPP-152.7-lite: sibling applications (same email + same cycle)
      const siblings = Array.isArray(data.sibling_applications) ? data.sibling_applications : [];
      const siblingSection = siblings.length ? `
        <div class="bg-amber-50 border-l-4 border-amber-400 rounded-r p-3">
          <h4 class="text-[12px] font-bold text-amber-800 mb-1">⚠ ${esc(T.modal.pmiProfileSiblings)} (${siblings.length})</h4>
          <p class="text-[11px] text-amber-700 mb-2">${esc(T.modal.pmiProfileSiblingsHint)}</p>
          <div class="space-y-1.5">
            ${siblings.map((s: any) => `
              <div class="text-[12px] border border-amber-200 bg-white rounded p-2 flex items-center justify-between gap-2 flex-wrap">
                <div>
                  <strong class="text-amber-900">${esc(s.role_applied || '?')}</strong>
                  <span class="text-[10px] text-[var(--text-muted)] ml-1 font-mono">${esc(String(s.application_id).slice(0,8))}…</span>
                </div>
                <div class="flex items-center gap-2 text-[10px]">
                  <span class="font-bold px-1.5 py-0.5 rounded ${(STATUS_BADGE[s.status]?.bg ?? 'bg-gray-100')} ${(STATUS_BADGE[s.status]?.color ?? 'text-gray-700')}">${esc(STATUS_LABELS[s.status] || s.status)}</span>
                  ${s.objective_score_avg != null ? `<span class="text-[var(--text-muted)]">Obj ${Number(s.objective_score_avg).toFixed(1)}</span>` : ''}
                  ${s.final_score != null ? `<span class="text-[var(--text-muted)]">Final ${Number(s.final_score).toFixed(1)}</span>` : ''}
                  <span class="text-[var(--text-muted)]" title="Interviews vinculadas a esta aplicação">🎯 ${s.interview_count}</span>
                </div>
              </div>`).join('')}
          </div>
        </div>` : '';

      // p152 W4 GAP-152.1: funnel attribution
      const funnel = data.funnel || {};
      const utm = funnel.utm_data;
      const hasFunnelSignal = funnel.referral_source || funnel.referrer_member_name || (utm && Object.keys(utm).length) || funnel.vep_application_id;
      const funnelSection = hasFunnelSignal ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">🎯 ${esc(T.modal.pmiProfileFunnel)}</h4>
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[12px]">
            ${funnel.referral_source ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileFunnelSource)}</span><br><strong>${esc(funnel.referral_source)}</strong></div>` : ''}
            ${funnel.referrer_member_name ? `<div><span class="text-[var(--text-muted)] text-[10px]">${esc(T.modal.pmiProfileFunnelReferrer)}</span><br><strong class="text-emerald-700">${esc(funnel.referrer_member_name)}</strong></div>` : ''}
            ${funnel.vep_application_id ? `<div><span class="text-[var(--text-muted)] text-[10px]">VEP App ID</span><br><span class="font-mono text-[10px]">${esc(String(funnel.vep_application_id))}</span></div>` : ''}
            ${funnel.vep_opportunity_id ? `<div><span class="text-[var(--text-muted)] text-[10px]">VEP Opportunity</span><br><span class="font-mono text-[10px]">${esc(String(funnel.vep_opportunity_id))}</span></div>` : ''}
          </div>
          ${utm && Object.keys(utm).length ? `<details class="mt-2"><summary class="text-[11px] font-bold text-[var(--text-secondary)] cursor-pointer">UTM data</summary><pre class="text-[10px] mt-1.5 bg-[var(--surface-base)] rounded-lg p-2 overflow-x-auto">${esc(JSON.stringify(utm, null, 2))}</pre></details>` : ''}
          ${funnel.imported_at ? `<div class="mt-1.5 text-[10px] text-[var(--text-muted)]">${esc(T.modal.pmiProfileImportedAt)}: ${esc(funnel.imported_at)}</div>` : ''}
        </div>` : '';

      // Non-PMI volunteering (form-declared)
      const nonPmi = data.non_pmi_volunteering;
      const nonPmiSection = nonPmi ? `
        <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
          <h4 class="text-[12px] font-bold text-navy mb-2">${esc(T.modal.pmiProfileNonPmi)}</h4>
          <p class="text-[12px] text-[var(--text-primary)] whitespace-pre-wrap bg-[var(--surface-base)] rounded-lg p-2 max-h-[150px] overflow-y-auto">${esc(nonPmi)}</p>
        </div>` : '';

      // Empty state
      const hasAny = identitySection || chaptersSection || certsSection || profileSection || historySection || prevSection || siblingSection || funnelSection || nonPmiSection;
      if (!hasAny || (!verifiedCerts.length && !memberships.length && !profileHasContent && !serviceHistory.length && !previousCycles.length && !nonPmi && !identity.pmi_id && !hasFunnelSignal && !siblings.length)) {
        container.innerHTML = `<div class="bg-amber-50 border border-amber-200 rounded-xl p-4 text-[12px] text-amber-800">⚠ ${esc(T.modal.pmiProfileEmpty)}</div>`;
        return;
      }

      // Siblings goes first (alert pattern), then identity, then others
      container.innerHTML = `<div class="space-y-3">${siblingSection}${identitySection}${chaptersSection}${certsSection}${profileSection}${historySection}${prevSection}${funnelSection}${nonPmiSection}</div>`;
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-700">${esc(T.modal.pmiProfileError)}: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── p87 Sprint A.3.b: Auditoria tab — gate_attempts timeline (Issue #117) ─── */
  async function loadGateAuditLog(applicationId: string) {
    const container = document.getElementById('audit-log-container');
    if (!container || !sb) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando auditoria...</p>';
    try {
      const { data, error } = await sb.rpc('get_application_gate_attempts', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      const attempts = Array.isArray(data) ? data : [];

      if (attempts.length === 0) {
        container.innerHTML = '<p class="text-sm text-[var(--text-muted)] py-4">Nenhuma tentativa de schedule_interview ou issue_interview_booking_token registrada para este candidato.</p>';
        return;
      }

      const gateCodeColors: Record<string,string> = {
        P0001: 'bg-red-50 text-red-700',
        P0002: 'bg-orange-50 text-orange-700',
        P0003: 'bg-amber-50 text-amber-700',
        P0004: 'bg-purple-50 text-purple-700',
      };
      const gateCodeLabels: Record<string,string> = {
        P0001: 'Sem AI',
        P0002: 'Sem par-revisão',
        P0003: 'Sem score',
        P0004: 'Status inválido',
      };
      const rpcLabels: Record<string,string> = {
        schedule_interview: 'Agendar entrevista',
        issue_interview_booking_token: 'Emitir link booking',
      };

      const passed = attempts.filter((a: any) => a.gate_passed).length;
      const failed = attempts.filter((a: any) => !a.gate_passed).length;
      const bypassUsed = attempts.filter((a: any) => a.bypass_granted).length;

      const summary = `
        <div class="bg-[var(--surface-base)] border border-[var(--border-default)] rounded-xl p-3">
          <div class="flex flex-wrap items-center gap-3 text-[12px]">
            <div><span class="text-[var(--text-muted)]">Tentativas:</span> <strong>${attempts.length}</strong></div>
            <div class="text-emerald-700"><span class="text-[var(--text-muted)]">Passaram:</span> <strong>${passed}</strong></div>
            <div class="text-red-700"><span class="text-[var(--text-muted)]">Falharam:</span> <strong>${failed}</strong></div>
            ${bypassUsed > 0 ? `<div class="text-purple-700"><span class="text-[var(--text-muted)]">Bypass usado:</span> <strong>${bypassUsed}x</strong></div>` : ''}
          </div>
        </div>
      `;

      const rowsHtml = attempts.map((a: any) => {
        const dt = new Date(a.attempted_at).toLocaleString('pt-BR');
        const passedBadge = a.gate_passed
          ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">PASSOU</span>'
          : `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${gateCodeColors[a.gate_failed_code] || 'bg-red-50 text-red-700'}">${gateCodeLabels[a.gate_failed_code] || 'FALHOU'}</span>`;
        const bypassBadge = a.bypass_requested
          ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${a.bypass_granted ? 'bg-purple-50 text-purple-700' : 'bg-gray-50 text-gray-600'}">${a.bypass_granted ? 'BYPASS GRANTED' : 'BYPASS DENIED'}</span>`
          : '';
        const rpcLabel = rpcLabels[a.rpc_name] || a.rpc_name;
        const callerName = a.caller_name || '—';
        const reason = a.gate_failed_reason ? `<div class="mt-1 text-[11px] text-red-700">⚠️ ${esc(a.gate_failed_reason)}</div>` : '';

        const payloadEntries = a.payload && typeof a.payload === 'object' ? Object.entries(a.payload) : [];
        const payloadHtml = payloadEntries.length > 0
          ? `<div class="mt-2 grid grid-cols-2 gap-1 text-[10px]">${payloadEntries.map(([k, v]: [string, any]) => `<div class="bg-[var(--surface-base)] rounded px-2 py-1"><span class="text-[var(--text-muted)]">${esc(k)}:</span> <code class="text-[var(--text-primary)]">${esc(String(v ?? '—'))}</code></div>`).join('')}</div>`
          : '';

        return `<details class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl">
          <summary class="cursor-pointer px-4 py-3 flex items-center gap-2 flex-wrap select-none">
            <strong class="text-[13px] text-navy">${esc(rpcLabel)}</strong>
            ${passedBadge}
            ${bypassBadge}
            <span class="text-[11px] text-[var(--text-muted)]">${dt}</span>
            <span class="text-[11px] text-[var(--text-muted)] ml-auto">por ${esc(callerName)}</span>
          </summary>
          <div class="px-4 pb-4 space-y-1 border-t border-[var(--border-default)] pt-3">
            ${reason}
            ${payloadHtml}
            <div class="text-[10px] text-[var(--text-muted)] pt-1">
              <span>Code: ${esc(a.gate_failed_code || '—')}</span>
            </div>
          </div>
        </details>`;
      }).join('');

      container.innerHTML = summary + '<div class="space-y-2 mt-3">' + rowsHtml + '</div>';
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-700">Erro ao carregar auditoria: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── p86 #5: Comunicação tab — campaign sends to applicant.email ─── */
  async function loadCommunications(applicationId: string) {
    const container = document.getElementById('comms-container');
    if (!container || !sb) return;
    container.innerHTML = '<p class="text-sm text-[var(--text-muted)]">Carregando comunicações...</p>';
    try {
      const { data, error } = await sb.rpc('get_application_communications', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      const comms = data?.communications || [];
      if (comms.length === 0) {
        container.innerHTML = '<p class="text-sm text-[var(--text-muted)] py-4">Nenhuma comunicação enviada a este candidato ainda.</p>';
        return;
      }
      const catLabels: Record<string,string> = {
        onboarding: 'Onboarding', operational: 'Operacional',
        announcement: 'Comunicado', newsletter: 'Newsletter',
      };
      const catColors: Record<string,string> = {
        onboarding: 'bg-purple-50 text-purple-700',
        operational: 'bg-amber-50 text-amber-700',
        announcement: 'bg-blue-50 text-blue-700',
        newsletter: 'bg-emerald-50 text-emerald-700',
      };
      container.innerHTML = `
        <p class="text-[11px] text-[var(--text-muted)]">${comms.length} comunicação(ões) enviada(s) para <strong>${esc(data.applicant_email)}</strong></p>
        ${comms.map((c: any) => {
          const dt = c.send_sent_at ? new Date(c.send_sent_at).toLocaleString('pt-BR') : new Date(c.send_created_at).toLocaleString('pt-BR');
          const cat = c.template_category;
          const catBadge = cat ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${catColors[cat] || 'bg-gray-100 text-gray-700'}">${catLabels[cat] || cat}</span>` : '';
          const srcBadge = c.audience_source && c.audience_source !== 'manual' ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-slate-100 text-slate-700">${esc(c.audience_source)}</span>` : '';
          const statusColors: Record<string,string> = { sent: 'text-emerald-700', sending: 'text-amber-600', pending_delivery: 'text-amber-600', throttled: 'text-amber-600', failed: 'text-red-600', draft: 'text-gray-500' };
          const deliveryStatus = c.recipient_delivered ? 'Entregue' : (c.recipient_bounced_at ? 'Bounced' : c.recipient_error_message ? 'Erro' : c.send_status === 'pending_delivery' ? 'Pendente' : '—');
          const deliveryColor = c.recipient_delivered ? 'text-emerald-700' : (c.recipient_bounced_at || c.recipient_error_message) ? 'text-red-700' : 'text-amber-600';
          const openInfo = c.recipient_opened_at && !c.recipient_bot_suspected ? `<span class="text-[11px] text-[var(--text-muted)]">👁️ Aberto ${c.recipient_open_count || 1}x · primeiro em ${new Date(c.recipient_opened_at).toLocaleString('pt-BR')}</span>` : '';
          const clickInfo = c.recipient_clicked_at ? `<span class="text-[11px] text-[var(--text-muted)]">🖱️ Clicou ${c.recipient_click_count || 1}x</span>` : '';
          const bounceInfo = c.recipient_bounced_at ? `<span class="text-[11px] text-red-700">🔴 Bounce ${esc(c.recipient_bounce_type || '')} em ${new Date(c.recipient_bounced_at).toLocaleString('pt-BR')}</span>` : '';
          const errorInfo = c.recipient_error_message ? `<div class="text-[11px] text-red-700 mt-1">⚠️ ${esc(c.recipient_error_message)}</div>` : '';
          return `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-3">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <strong class="text-[13px] text-navy">${esc(c.template_name)}</strong>
              ${catBadge}
              ${srcBadge}
            </div>
            <div class="flex flex-wrap gap-x-3 gap-y-1 text-[11px] text-[var(--text-muted)]">
              <span>${dt}</span>
              <span class="${statusColors[c.send_status] || 'text-gray-500'} font-semibold">${esc(c.send_status)}</span>
              <span class="${deliveryColor} font-semibold">📬 ${deliveryStatus}</span>
              ${openInfo}
              ${clickInfo}
              ${bounceInfo}
            </div>
            ${errorInfo}
          </div>`;
        }).join('')}
      `;
    } catch (e: any) {
      container.innerHTML = `<p class="text-sm text-red-700">Erro ao carregar comunicações: ${esc(e.message || 'desconhecido')}</p>`;
    }
  }

  /* ── #91 G4: returning candidate offboarding context ─────────────── */
  async function loadReturningContext(applicationId: string) {
    const panel = document.getElementById('returning-context-panel');
    if (!panel) return;
    try {
      const { data, error } = await sb.rpc('get_application_returning_context', {
        p_application_id: applicationId,
      });
      if (error) throw error;
      if (!data || !data.found) {
        panel.innerHTML = '<p class="text-[11px] text-[var(--text-muted)]">Sem histórico recuperável.</p>';
        return;
      }

      const ctx = data.offboarding_context;
      const member = data.matched_member;

      if (!member) {
        panel.innerHTML = `<div class="space-y-1">
          <h4 class="text-[12px] font-bold text-blue-700">Candidato Retornante</h4>
          <p class="text-[11px] text-[var(--text-secondary)]">Membro anterior não localizado por email; flag baseada em ${data.application_count || 1} aplicação(ões) prévia(s).</p>
        </div>`;
        return;
      }

      if (!ctx) {
        panel.innerHTML = `<div class="space-y-1">
          <h4 class="text-[12px] font-bold text-blue-700">Candidato Retornante</h4>
          <p class="text-[11px] text-[var(--text-secondary)]">Membro encontrado (${esc(member.name || '')}, ${esc(member.member_status || '')}), mas sem registro estruturado de saída.</p>
        </div>`;
        return;
      }

      const offboardDate = ctx.offboarded_at ? new Date(ctx.offboarded_at).toLocaleDateString('pt-BR') : '—';
      const returnInterestBadge = ctx.return_interest === true
        ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700">Quer voltar</span>'
        : ctx.return_interest === false
          ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-rose-50 text-rose-700">Não declarou retorno</span>'
          : '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">Interesse não registrado</span>';
      const eligibilityBadge = ctx.preserves_return_eligibility === false
