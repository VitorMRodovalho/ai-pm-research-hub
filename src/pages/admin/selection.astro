  /* p150 b2-light — extra_flags inline badges in name column.
     Surfaces application_count, last_briefing_at, ai_triage_score from the
     extra_flags subgroup added in migration 20260529000000. Each badge
     returns '' when the underlying signal is absent, so the row stays clean
     for candidates without these flags. */
  function reApplicantBadge(r: any): string {
    const n = Number(r.extra_flags?.application_count ?? 1);
    if (n <= 1) return '';
    return ` <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-purple-50 text-purple-700" title="${n}ª aplicação deste candidato no Núcleo (re-applicant)">🔄${n}</span>`;
  }

  function briefingBadge(r: any): string {
    if (!r.extra_flags?.has_briefing) return '';
    const model = r.extra_flags?.briefing_model || 'IA';
    const at = r.extra_flags?.briefing_at ? new Date(r.extra_flags.briefing_at).toLocaleDateString('pt-BR') : '';
    return ` <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-indigo-50 text-indigo-700" title="Briefing de entrevista gerado por ${esc(model)} em ${esc(at)}">📋</span>`;
  }

  function aiTriageBadge(r: any): string {
    const score = r.extra_flags?.ai_triage_score;
    if (score == null) return '';
    const confidence = r.extra_flags?.ai_triage_confidence || 'medium';
    // Color band by score (0-10): green ≥7, amber 4-6.9, gray <4
    const numScore = Number(score);
    const color = numScore >= 7
      ? 'bg-emerald-50 text-emerald-700'
      : numScore >= 4
        ? 'bg-amber-50 text-amber-700'
        : 'bg-gray-100 text-gray-600';
    return ` <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full ${color}" title="AI Triage score (Sonnet 4.6) ${numScore.toFixed(1)}/10 · confidence ${esc(confidence)} · NÃO entra na decisão final (LGPD Art. 20 §1)">IA:${numScore.toFixed(1)}</span>`;
  }

  /* p153 GAP-152.3 — VEP status raw badge inline on row name cell.
     Reads from vep_recon sub-object (added by migration 20260613000000).
     Color-coded by status: in-flight (blue), active (emerald), terminal (gray/rose/amber).
     p153 GAP-152.5 — adds a separate "off" badge when vep_last_seen_at is more than
     5min older than the dataset's latest ingest (= app was NOT in the latest Apply
     UI C → PMI removed it from the recruiter dashboard between rounds). */
  function vepBadge(r: any): string {
    const status = r.vep_recon?.status_raw;
    const lastSeenAt = r.vep_recon?.last_seen_at;
    if (!status && !lastSeenAt) return '';
    const VB = T.vepBadge || {};
    let statusBadge = '';
    if (status) {
      const labelMap: Record<string, { short: string; long: string; cls: string }> = {
        Submitted: { short: VB.submitted || 'VEP·Subm', long: VB.statusSubmitted || 'Submetido', cls: 'bg-blue-50 text-blue-700' },
        Active: { short: VB.active || 'VEP·Ativ', long: VB.statusActive || 'Ativo', cls: 'bg-emerald-50 text-emerald-700' },
        Withdrawn: { short: VB.withdrawn || 'VEP·Saiu', long: VB.statusWithdrawn || 'Desistiu', cls: 'bg-gray-100 text-gray-600' },
        Declined: { short: VB.declined || 'VEP·Recus', long: VB.statusDeclined || 'Recusado', cls: 'bg-rose-50 text-rose-700' },
        OfferNotExtended: { short: VB.offerNotExtended || 'VEP·SemOf', long: VB.statusOfferNotExtended || 'Sem oferta', cls: 'bg-amber-50 text-amber-700' },
      };
      const entry = labelMap[status] || { short: VB.unknown || 'VEP·?', long: status, cls: 'bg-slate-100 text-slate-600' };
      const lastSyncStr = lastSeenAt ? new Date(lastSeenAt).toLocaleDateString('pt-BR') : '—';
      const reconciledStr = r.vep_recon?.reconciled_at ? new Date(r.vep_recon.reconciled_at).toLocaleDateString('pt-BR') : null;
      const reconciledLine = reconciledStr ? ` · ${VB.reconciled || 'Reconciliado em'} ${reconciledStr}` : '';
      const tooltip = `${VB.tooltipPrefix || 'Status no PMI VEP'}: ${entry.long} · ${VB.lastSync || 'Última sync VEP'} ${lastSyncStr}${reconciledLine}`;
      statusBadge = ` <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full ${entry.cls}" title="${esc(tooltip)}">${esc(entry.short)}</span>`;
    }
    // GAP-152.5 stale flag — only render if lastSeenAt is meaningfully older than dataset max
    let staleBadge = '';
    if (lastSeenAt && latestVepSeenMs > 0) {
      const rowMs = new Date(lastSeenAt).getTime();
      if (Number.isFinite(rowMs) && (latestVepSeenMs - rowMs) > 5 * 60 * 1000) {
        const offSince = new Date(lastSeenAt).toLocaleDateString('pt-BR');
        const offTip = `${VB.offTooltip || 'Não veio no Apply VEP mais recente — provavelmente removida do recruiter dashboard pela PMI'} · ${VB.lastSync || 'Última sync VEP'} ${offSince}`;
        staleBadge = ` <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full bg-orange-50 text-orange-700 border border-orange-200" title="${esc(offTip)}">${esc(VB.off || 'VEP·OFF')}</span>`;
      }
    }
    return `${statusBadge}${staleBadge}`;
  }

