---
/**
 * /admin/audit-log — Audit log page (superadmin only).
 * React island: AuditLogIsland.
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import AuditLogIsland from '../../components/admin/audit/AuditLogIsland';
import Toast from '../../components/ui/Toast.astro';
import { getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const i18nBundle = buildPageI18n(['comp.auditLog', 'comp.common'], lang);
---

<AdminLayout
  title="Registro de Auditoria"
  breadcrumbs={[
    { label: 'Operações' },
    { label: 'Registro de Auditoria' }
  ]}
>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <AuditLogIsland client:load />
  <Toast />
</AdminLayout>
