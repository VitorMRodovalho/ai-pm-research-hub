---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const CHAPTERS = ['CE','DF','GO','MG','RS','ALL'];

// Pre-render strings for inline TS script via define:vars (Ω-B+.5.a p142)
const WEBINARS_I18N = {
  statusPlanned: t('admin.webinars.statusPlanned', lang),
  statusConfirmed: t('admin.webinars.statusConfirmed', lang),
  statusCompleted: t('admin.webinars.statusCompleted', lang),
  statusCancelled: t('admin.webinars.statusCancelled', lang),
  chapterGeneral: t('admin.webinars.chapterGeneral', lang),
  statPlanned: t('admin.webinars.statPlanned', lang),
  statConfirmed: t('admin.webinars.statConfirmed', lang),
  statCompleted: t('admin.webinars.statCompleted', lang),
  statTotalAttendees: t('admin.webinars.statTotalAttendees', lang),
  actionConfirm: t('admin.webinars.actionConfirm', lang),
  actionCreateSession: t('admin.webinars.actionCreateSession', lang),
  actionAddMeetingLink: t('admin.webinars.actionAddMeetingLink', lang),
  actionPrepareCommunication: t('admin.webinars.actionPrepareCommunication', lang),
  actionMarkCompleted: t('admin.webinars.actionMarkCompleted', lang),
  actionPublishReplay: t('admin.webinars.actionPublishReplay', lang),
  actionFollowupComms: t('admin.webinars.actionFollowupComms', lang),
  actionComplete: t('admin.webinars.actionComplete', lang),
  cardLinkedSession: t('admin.webinars.cardLinkedSession', lang),
  cardNoSession: t('admin.webinars.cardNoSession', lang),
  cardCoManagersLabel: t('admin.webinars.cardCoManagersLabel', lang),
  cardOrganizerLabel: t('admin.webinars.cardOrganizerLabel', lang),
  cardLinkedCardLabel: t('admin.webinars.cardLinkedCardLabel', lang),
  cardAttendeesLabel: t('admin.webinars.cardAttendeesLabel', lang),
  cardMinSuffix: t('admin.webinars.cardMinSuffix', lang),
  cardReplayBtn: t('admin.webinars.cardReplayBtn', lang),
  cardJoinBtn: t('admin.webinars.cardJoinBtn', lang),
  cardEditBtn: t('admin.webinars.cardEditBtn', lang),
  cardCommsBtn: t('admin.webinars.cardCommsBtn', lang),
  cardOpenBtn: t('admin.webinars.cardOpenBtn', lang),
  emptyFollowup: t('admin.webinars.emptyFollowup', lang),
  emptyAllStart: t('admin.webinars.emptyAllStart', lang),
  validateTitleAndDate: t('admin.webinars.validateTitleAndDate', lang),
  linkSessionSuccess: t('admin.webinars.linkSessionSuccess', lang),
  coManagersCountSuffix: t('admin.webinars.coManagersCountSuffix', lang),
  lifecycleCreated: t('admin.webinars.lifecycleCreated', lang),
  lifecycleStatusChange: t('admin.webinars.lifecycleStatusChange', lang),
  lifecycleEventLinked: t('admin.webinars.lifecycleEventLinked', lang),
  modalAddTitle: t('admin.webinars.modal.addTitle', lang),
  modalEditTitle: t('admin.webinars.modal.editTitle', lang),
  modalSelectTribe: t('admin.webinars.modal.selectTribe', lang),
  saveError: t('admin.webinars.msg.saveError', lang),
  roleShort: {
    manager: t('admin.webinars.roleShortGP', lang),
    deputy_manager: t('admin.webinars.roleShortViceGP', lang),
    tribe_leader: t('admin.webinars.roleShortLeader', lang),
    comms_leader: t('admin.webinars.roleShortCommsL', lang),
    researcher: t('admin.webinars.roleShortResearcher', lang),
    facilitator: t('admin.webinars.roleShortFacilitator', lang),
    communicator: t('admin.webinars.roleShortComms', lang),
    none: '—',
    guest: t('admin.webinars.roleShortGuest', lang),
  },
};
---

<AdminLayout title={t('nav.adminWebinars', lang)} activePage="webinars" breadcrumbs={[{label: t('admin.breadcrumb.content', lang)},{label: t('nav.adminWebinars', lang)}]}>
  <div id="webinars-loading" class="max-w-[1200px] mx-auto px-4 py-12 text-center text-[var(--text-muted)]">
    {t('admin.loadingPanel', lang)}
  </div>

  <div id="webinars-content" class="hidden max-w-[1200px] mx-auto px-4 pb-12 space-y-6">
    <!-- Header -->
    <section class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
      <div class="p-6 sm:p-8">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="max-w-3xl">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-50 border border-emerald-200 text-[.72rem] font-semibold text-emerald-700 mb-3">
              <span>Webinar Governance</span>
              <span class="text-emerald-400">•</span>
              <span>Multi-Entity</span>
            </div>
            <h1 class="text-2xl font-extrabold text-navy mb-2">{t('nav.adminWebinars', lang)}</h1>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">
              {t('admin.webinars.heroSubtitle', lang)}
            </p>
          </div>
          <div class="flex flex-col gap-2 min-w-[200px]">
            <button id="btn-new-webinar" type="button" class="px-4 py-2.5 rounded-xl bg-navy text-white text-[.78rem] font-semibold border-0 cursor-pointer hover:opacity-90 transition-all">
              {t('admin.webinars.addBtn', lang)}
            </button>
            <a href="/attendance?tab=events&type=webinar" class="px-4 py-2.5 rounded-xl bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.78rem] font-semibold no-underline text-center hover:bg-[var(--overlay-card-hover)] transition-all">
              {t('admin.webinars.attendanceBtn', lang)}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Filters -->
    <section class="flex items-center gap-3 flex-wrap">
      <select id="filter-status" class="text-[.78rem] rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-primary)] px-3 py-2">
        <option value="">{t('admin.webinars.filterAllStatus', lang)}</option>
        <option value="planned">{t('admin.webinars.statusPlanned', lang)}</option>
        <option value="confirmed">{t('admin.webinars.statusConfirmed', lang)}</option>
        <option value="completed">{t('admin.webinars.statusCompleted', lang)}</option>
        <option value="cancelled">{t('admin.webinars.statusCancelled', lang)}</option>
      </select>
      <select id="filter-chapter" class="text-[.78rem] rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-primary)] px-3 py-2">
        <option value="">{t('admin.webinars.filterAllChapters', lang)}</option>
        {CHAPTERS.map(ch => <option value={ch}>{ch === 'ALL' ? t('admin.webinars.chapterGeneralAll', lang) : `PMI-${ch}`}</option>)}
      </select>
    </section>

    <!-- Stats -->
    <section id="webinars-stats" class="grid grid-cols-2 sm:grid-cols-4 gap-4"></section>

    <!-- Priority Actions -->
    <section class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-[var(--border-default)]">
        <h2 class="text-sm font-bold text-navy">{t('admin.webinars.priorityActionsTitle', lang)}</h2>
        <p class="text-[.72rem] text-[var(--text-muted)]">{t('admin.webinars.priorityActionsSubtitle', lang)}</p>
      </div>
      <div id="webinars-actions" class="p-5"></div>
    </section>

    <!-- Upcoming + Follow-up -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.webinars.upcomingTitle', lang)}</h2>
        </div>
        <div id="webinars-upcoming" class="p-5"></div>
      </div>
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-[var(--border-default)]">
          <h2 class="text-sm font-bold text-navy">{t('admin.webinars.followupTitle', lang)}</h2>
        </div>
        <div id="webinars-followup" class="p-5"></div>
      </div>
    </section>

    <!-- Operational Flow -->
    <section class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-[var(--border-default)]">
        <h2 class="text-sm font-bold text-navy">{t('admin.webinars.flowTitle', lang)}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-4 p-5">
        <div class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-base)] p-4">
          <div class="text-lg mb-2">1.</div>
          <h3 class="text-[.82rem] font-bold text-navy mb-1">{t('admin.webinars.flow1Label', lang)}</h3>
          <p class="text-[.74rem] text-[var(--text-secondary)]">{t('admin.webinars.flow1Desc', lang)}</p>
        </div>
        <div class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-base)] p-4">
          <div class="text-lg mb-2">2.</div>
          <h3 class="text-[.82rem] font-bold text-navy mb-1">{t('admin.webinars.flow2Label', lang)}</h3>
          <p class="text-[.74rem] text-[var(--text-secondary)]">{t('admin.webinars.flow2Desc', lang)}</p>
        </div>
        <div class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-base)] p-4">
          <div class="text-lg mb-2">3.</div>
          <h3 class="text-[.82rem] font-bold text-navy mb-1">{t('admin.webinars.flow3Label', lang)}</h3>
          <p class="text-[.74rem] text-[var(--text-secondary)]">{t('admin.webinars.flow3Desc', lang)}</p>
        </div>
        <div class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-base)] p-4">
          <div class="text-lg mb-2">4.</div>
          <h3 class="text-[.82rem] font-bold text-navy mb-1">{t('admin.webinars.flow4Label', lang)}</h3>
          <p class="text-[.74rem] text-[var(--text-secondary)]">{t('admin.webinars.flow4Desc', lang)}</p>
        </div>
        <div class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-base)] p-4">
          <div class="text-lg mb-2">5.</div>
          <h3 class="text-[.82rem] font-bold text-navy mb-1">{t('admin.webinars.flow5Label', lang)}</h3>
          <p class="text-[.74rem] text-[var(--text-secondary)]">{t('admin.webinars.flow5Desc', lang)}</p>
        </div>
      </div>
    </section>

    <!-- Full List -->
    <section class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-[var(--border-default)]">
        <h2 class="text-sm font-bold text-navy">{t('admin.webinars.allWebinarsTitle', lang)}</h2>
      </div>
      <div id="webinars-list" class="p-5"></div>
    </section>
  </div>

  <!-- Denied -->
  <div id="webinars-denied" class="hidden max-w-[900px] mx-auto px-4 py-16 text-center">
    <div class="text-4xl mb-3">🔒</div>
    <p class="font-semibold text-[var(--text-secondary)]">{t('admin.webinars.deniedDetail', lang)}</p>
    <a href="/" class="inline-block mt-4 px-5 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{t('admin.webinars.backHome', lang)}</a>
  </div>

  <!-- CRUD Modal -->
  <div id="webinar-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
    <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] shadow-xl w-full max-w-lg p-6 mx-4 max-h-[90vh] overflow-y-auto">
      <h2 id="modal-title" class="text-lg font-extrabold text-navy mb-4">{t('admin.webinars.modal.addTitle', lang)}</h2>
      <input type="hidden" id="modal-id" />
      <div class="space-y-3">
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelTitle', lang)}</label>
          <input id="modal-wTitle" type="text" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" />
        </div>
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelDesc', lang)}</label>
          <textarea id="modal-desc" rows="2" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2"></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelDate', lang)}</label>
            <input id="modal-date" type="datetime-local" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" />
          </div>
          <div>
            <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelDuration', lang)}</label>
            <input id="modal-duration" type="number" value="60" min="15" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelChapter', lang)}</label>
            <select id="modal-chapter" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2">
              <option value="ALL">{t('admin.webinars.chapterGeneral', lang)}</option>
              <option value="CE">PMI-CE</option>
              <option value="DF">PMI-DF</option>
              <option value="GO">PMI-GO</option>
              <option value="MG">PMI-MG</option>
              <option value="RS">PMI-RS</option>
            </select>
          </div>
          <div>
            <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelStatus', lang)}</label>
            <select id="modal-status" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2">
              <option value="planned">{t('admin.webinars.statusPlanned', lang)}</option>
              <option value="confirmed">{t('admin.webinars.statusConfirmed', lang)}</option>
              <option value="completed">{t('admin.webinars.statusCompleted', lang)}</option>
              <option value="cancelled">{t('admin.webinars.statusCancelled', lang)}</option>
            </select>
          </div>
        </div>
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelTribe', lang)}</label>
          <select id="modal-tribe" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2">
            <option value="">{t('admin.webinars.modal.selectTribe', lang)}</option>
          </select>
        </div>
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelLink', lang)}</label>
          <input id="modal-link" type="url" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" placeholder="https://..." />
        </div>
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelYoutube', lang)}</label>
          <input id="modal-youtube" type="url" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2" placeholder="https://youtube.com/..." />
        </div>
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelNotes', lang)}</label>
          <textarea id="modal-notes" rows="2" class="w-full text-sm rounded-lg border border-[var(--border-default)] bg-[var(--surface-base)] text-[var(--text-primary)] px-3 py-2"></textarea>
        </div>
        <div>
          <label class="text-xs font-semibold text-[var(--text-secondary)] block mb-1">{t('admin.webinars.modal.labelCoManagers', lang)}</label>
          <div id="modal-co-managers" class="max-h-48 overflow-y-auto rounded-lg border border-[var(--border-default)] p-2 space-y-1">
            <span class="text-[.72rem] text-[var(--text-muted)]">{t('admin.loadingMembers', lang)}</span>
          </div>
          <p id="modal-co-count" class="mt-1 text-[.68rem] text-[var(--text-secondary)] hidden"></p>
        </div>
      </div>
      <div id="modal-lifecycle" class="hidden mt-4 pt-4 border-t border-[var(--border-default)]">
        <h3 class="text-xs font-bold text-navy mb-2">{t('admin.webinars.modal.lifecycleHeader', lang)}</h3>
        <div id="modal-lifecycle-body" class="space-y-1 text-[.72rem] text-[var(--text-secondary)] max-h-32 overflow-y-auto"></div>
      </div>
      <div class="flex items-center justify-between gap-3 mt-5 pt-4 border-t border-[var(--border-default)]">
        <div class="flex gap-2">
          <button id="btn-create-event" type="button" class="hidden px-3 py-2 rounded-lg bg-teal text-white text-[.78rem] font-semibold border-0 cursor-pointer hover:opacity-90">
            {t('admin.webinars.modal.createEventBtn', lang)}
          </button>
        </div>
        <div class="flex gap-2">
          <button id="btn-modal-cancel" type="button" class="px-4 py-2 rounded-lg bg-[var(--surface-base)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.78rem] font-semibold cursor-pointer hover:bg-[var(--surface-hover)]">
            {t('admin.webinars.modal.cancel', lang)}
          </button>
          <button id="btn-modal-save" type="button" class="px-4 py-2 rounded-lg bg-navy text-white text-[.78rem] font-semibold border-0 cursor-pointer hover:opacity-90">
            {t('admin.webinars.modal.save', lang)}
          </button>
        </div>
      </div>
    </div>
  </div>
  <span id="i18n-noUpcoming" class="hidden">{t('admin.noUpcomingWebinar', lang)}</span>
  <span id="ai18n-nor" class="hidden">{t('admin.noResults', lang)}</span>
  <span id="ai18n-sav" class="hidden">{t('admin.saveError', lang)}</span>
</AdminLayout>

<script is:inline define:vars={{ WEBINARS_I18N }}>
  window.__WEBINARS_I18N = WEBINARS_I18N;
</script>
<script>
  import { canAccessWebinarsWorkspace } from '../../lib/admin/constants';

  // PT-BR fallbacks (graceful degradation if define:vars injection fails)
  const T = (typeof window !== 'undefined' && (window as any).__WEBINARS_I18N) || {
    statusPlanned: 'Planejado', statusConfirmed: 'Confirmado', statusCompleted: 'Realizado', statusCancelled: 'Cancelado',
    chapterGeneral: 'Geral',
    statPlanned: 'Planejados', statConfirmed: 'Confirmados', statCompleted: 'Realizados', statTotalAttendees: 'Total presentes',
    actionConfirm: 'Confirmar webinar', actionCreateSession: 'Criar sessão Attendance',
    actionAddMeetingLink: 'Adicionar link da reunião', actionPrepareCommunication: 'Preparar divulgação',
    actionMarkCompleted: 'Marcar como realizado', actionPublishReplay: 'Publicar replay',
    actionFollowupComms: 'Follow-up Comms', actionComplete: 'Completo',
    cardLinkedSession: 'Sessão vinculada', cardNoSession: 'Sem sessão',
    cardCoManagersLabel: 'Co-gestores', cardOrganizerLabel: 'Org', cardLinkedCardLabel: 'Card',
    cardAttendeesLabel: 'presentes', cardMinSuffix: 'min',
    cardReplayBtn: 'Replay', cardJoinBtn: 'Entrar', cardEditBtn: 'Editar', cardCommsBtn: 'Comms', cardOpenBtn: 'Abrir',
    emptyFollowup: 'Sem fila de follow-up.', emptyAllStart: 'Clique em "+ Novo Webinar" para começar.',
    validateTitleAndDate: 'Título e data são obrigatórios.',
    linkSessionSuccess: 'Sessão de Attendance criada com sucesso!',
    coManagersCountSuffix: 'selecionados',
    lifecycleCreated: 'Criado', lifecycleStatusChange: 'Status alterado', lifecycleEventLinked: 'Sessão vinculada',
    modalAddTitle: 'Agendar Webinar', modalEditTitle: 'Editar Webinar', modalSelectTribe: '— Opcional —',
    saveError: 'Erro ao salvar webinar',
    roleShort: { manager: 'GP', deputy_manager: 'Vice-GP', tribe_leader: 'Líder', comms_leader: 'Comms-L',
      researcher: 'Pesq.', facilitator: 'Facil.', communicator: 'Comms', none: '—', guest: 'Guest' },
  };

  const TRIBE_NAMES: Record<number, string> = {
    1: 'Radar Tecnologico', 2: 'Agentes Autonomos', 3: 'TMO & PMO do Futuro',
    4: 'Cultura & Change', 5: 'Talentos & Upskilling', 6: 'ROI & Portfolio',
    7: 'Governanca & Trustworthy AI', 8: 'Inclusao & Colaboracao'
  };

  const STATUS_LABELS: Record<string, string> = {
    planned: T.statusPlanned, confirmed: T.statusConfirmed, completed: T.statusCompleted, cancelled: T.statusCancelled
  };
  const STATUS_TONES: Record<string, string> = {
    planned: 'bg-gray-100 text-gray-700 border-gray-200',
    confirmed: 'bg-blue-50 text-blue-700 border-blue-200',
    completed: 'bg-emerald-50 text-emerald-700 border-emerald-200',
    cancelled: 'bg-red-50 text-red-700 border-red-200',
  };

  let sb: any = null;
  let MEMBER: any = null;
  let ALL_WEBINARS: any[] = [];
  let coManagerIds: string[] = [];
  let allActiveMembers: { id: string; name: string; operational_role: string }[] = [];

  function showDenied() {
    document.getElementById('webinars-loading')?.classList.add('hidden');
    document.getElementById('webinars-content')?.classList.add('hidden');
    document.getElementById('webinars-denied')?.classList.remove('hidden');
  }
  function showPanel() {
    document.getElementById('webinars-loading')?.classList.add('hidden');
    document.getElementById('webinars-denied')?.classList.add('hidden');
    document.getElementById('webinars-content')?.classList.remove('hidden');
  }
  function esc(s: any): string {
    return String(s || '').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function fmtDate(iso: string): string {
    if (!iso) return '—';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return String(iso).slice(0,10);
    return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
  }
  function fmtDateTime(iso: string): string {
    if (!iso) return '—';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return String(iso);
    return d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' }) + ' ' +
      d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  }
  function isFuture(iso: string): boolean {
    return new Date(iso).getTime() > Date.now();
  }
  function canEdit(): boolean {
    if (!MEMBER) return false;
    return MEMBER.is_superadmin || ['manager','deputy_manager'].includes(MEMBER.operational_role)
      || (MEMBER.designations || []).includes('co_gp');
  }

  function nextAction(w: any): { label: string; href: string; tone: string; priority: number } {
    const future = isFuture(w.scheduled_at);
    if (w.status === 'planned') {
      return { label: T.actionConfirm, href: '#', tone: 'bg-amber-50 text-amber-700 border-amber-200', priority: 1 };
    }
    if (w.status === 'confirmed' && future && !w.event_id) {
      return { label: T.actionCreateSession, href: '#', tone: 'bg-amber-50 text-amber-700 border-amber-200', priority: 2 };
    }
    if (w.status === 'confirmed' && future && !w.meeting_link) {
      return { label: T.actionAddMeetingLink, href: '#', tone: 'bg-amber-50 text-amber-700 border-amber-200', priority: 3 };
    }
    if (w.status === 'confirmed' && future) {
      return { label: T.actionPrepareCommunication, href: `/admin/comms-ops?context=webinar&title=${encodeURIComponent(w.title)}&stage=invite`, tone: 'bg-blue-50 text-blue-700 border-blue-200', priority: 5 };
    }
    if (w.status === 'confirmed' && !future) {
      return { label: T.actionMarkCompleted, href: '#', tone: 'bg-purple-50 text-purple-700 border-purple-200', priority: 2 };
    }
    if (w.status === 'completed' && !w.youtube_url) {
      return { label: T.actionPublishReplay, href: '#', tone: 'bg-amber-50 text-amber-700 border-amber-200', priority: 3 };
    }
    if (w.status === 'completed' && w.youtube_url) {
      return { label: T.actionFollowupComms, href: `/admin/comms-ops?context=webinar&title=${encodeURIComponent(w.title)}&stage=followup`, tone: 'bg-teal-50 text-teal-700 border-teal-200', priority: 6 };
    }
    return { label: T.actionComplete, href: '#', tone: 'bg-emerald-50 text-emerald-700 border-emerald-200', priority: 9 };
  }

  // ── Rendering ──

  function renderStats(webinars: any[]) {
    const el = document.getElementById('webinars-stats');
    if (!el) return;
    const planned = webinars.filter(w => w.status === 'planned').length;
    const confirmed = webinars.filter(w => w.status === 'confirmed').length;
    const completed = webinars.filter(w => w.status === 'completed').length;
    const totalAttendees = webinars.reduce((s: number, w: any) => s + Number(w.attendee_count || 0), 0);
    const cards = [
      { label: T.statPlanned, value: planned, tone: 'bg-gray-50 text-gray-700 border-gray-200' },
      { label: T.statConfirmed, value: confirmed, tone: 'bg-blue-50 text-blue-700 border-blue-200' },
      { label: T.statCompleted, value: completed, tone: 'bg-emerald-50 text-emerald-700 border-emerald-200' },
      { label: T.statTotalAttendees, value: totalAttendees, tone: 'bg-purple-50 text-purple-700 border-purple-200' },
    ];
    el.innerHTML = cards.map(c => `
      <div class="rounded-2xl border ${c.tone} p-4">
        <div class="text-[.72rem] font-semibold uppercase tracking-wide opacity-75">${c.label}</div>
        <div class="text-2xl font-extrabold mt-2">${c.value}</div>
      </div>
    `).join('');
  }

  function webinarCard(w: any): string {
    const action = nextAction(w);
    const statusBadge = `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold border ${STATUS_TONES[w.status] || ''}">${STATUS_LABELS[w.status] || w.status}</span>`;
    const chapterBadge = `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-orange-50 text-orange-700 border border-orange-200">${w.chapter_code === 'ALL' ? T.chapterGeneral : 'PMI-' + w.chapter_code}</span>`;
    const tribeBadge = w.tribe_name ? `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-purple-50 text-purple-700">${esc(w.tribe_name)}</span>` : '';
    const eventBadge = w.event_id
      ? `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-teal-50 text-teal-700">${T.cardLinkedSession}</span>`
      : `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-gray-100 text-gray-500">${T.cardNoSession}</span>`;
    const coManagers = (w.co_managers || []).length
      ? `<div class="text-[.68rem] text-[var(--text-muted)] mt-1">${T.cardCoManagersLabel}: ${(w.co_managers || []).map((cm: any) => esc(cm.name)).join(', ')}</div>`
      : '';
    const replayLink = w.youtube_url ? `<a href="${esc(w.youtube_url)}" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg bg-red-50 text-red-700 text-[.72rem] font-semibold no-underline hover:bg-red-100">${T.cardReplayBtn}</a>` : '';
    const meetLink = w.meeting_link && isFuture(w.scheduled_at) ? `<a href="${esc(w.meeting_link)}" target="_blank" rel="noopener" class="px-3 py-1.5 rounded-lg bg-blue-50 text-blue-700 text-[.72rem] font-semibold no-underline hover:bg-blue-100">${T.cardJoinBtn}</a>` : '';

    return `
      <article class="rounded-2xl border border-[var(--border-default)] p-4">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <h3 class="text-sm font-bold text-navy">${esc(w.title)}</h3>
              ${statusBadge} ${chapterBadge} ${tribeBadge} ${eventBadge}
            </div>
            <div class="text-[.76rem] text-[var(--text-secondary)] flex items-center gap-2 flex-wrap">
              <span>${fmtDateTime(w.scheduled_at)}</span>
              <span>·</span>
              <span>${w.duration_min} ${T.cardMinSuffix}</span>
              ${w.attendee_count > 0 ? `<span>·</span><span>${w.attendee_count} ${T.cardAttendeesLabel}</span>` : ''}
              ${w.organizer_name ? `<span>·</span><span>${T.cardOrganizerLabel}: ${esc(w.organizer_name)}</span>` : ''}
            </div>
            ${coManagers}
            ${w.board_item_title ? `<div class="text-[.68rem] text-[var(--text-muted)] mt-1">${T.cardLinkedCardLabel}: ${esc(w.board_item_title)} (${esc(w.board_item_status)})</div>` : ''}
            <div class="mt-2 inline-flex items-center gap-2 px-2.5 py-1 rounded-full border text-[.68rem] font-bold ${action.tone}">
              ${esc(action.label)}
            </div>
          </div>
          <div class="flex items-center gap-2 flex-wrap">
            ${canEdit() ? `<button type="button" data-edit="${w.id}" class="px-3 py-1.5 rounded-lg bg-navy text-white text-[.72rem] font-semibold border-0 cursor-pointer hover:opacity-90">${T.cardEditBtn}</button>` : ''}
            ${meetLink} ${replayLink}
            <a href="/admin/comms-ops?context=webinar&title=${encodeURIComponent(w.title)}&stage=${w.status === 'completed' ? 'followup' : 'invite'}" class="px-3 py-1.5 rounded-lg bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.72rem] font-semibold no-underline hover:bg-[var(--surface-hover)]">${T.cardCommsBtn}</a>
          </div>
        </div>
      </article>
    `;
  }

  function renderUpcoming(webinars: any[]) {
    const el = document.getElementById('webinars-upcoming');
    if (!el) return;
    const items = webinars.filter(w => isFuture(w.scheduled_at) && w.status !== 'cancelled').slice(0, 5);
    el.innerHTML = items.length
      ? `<div class="space-y-3">${items.map(webinarCard).join('')}</div>`
      : `<div class="rounded-2xl border border-dashed border-[var(--border-default)] p-5 text-center"><div class="text-3xl mb-2">📭</div><div class="text-sm font-semibold text-[var(--text-secondary)]">${document.getElementById('i18n-noUpcoming')?.textContent || 'No upcoming webinar.'}</div></div>`;
  }

  function renderFollowup(webinars: any[]) {
    const el = document.getElementById('webinars-followup');
    if (!el) return;
    const items = webinars.filter(w => !isFuture(w.scheduled_at) && w.status === 'completed' && !w.youtube_url).slice(0, 5);
    el.innerHTML = items.length
      ? `<div class="space-y-3">${items.map(webinarCard).join('')}</div>`
      : `<div class="rounded-2xl border border-dashed border-emerald-200 bg-emerald-50 p-5 text-center"><div class="text-3xl mb-2">✅</div><div class="text-sm font-semibold text-emerald-700">${T.emptyFollowup}</div></div>`;
  }

  function renderActions(webinars: any[]) {
    const el = document.getElementById('webinars-actions');
    if (!el) return;
    const items = webinars.filter(w => w.status !== 'cancelled')
      .map(w => ({ ...w, _action: nextAction(w) }))
      .sort((a, b) => a._action.priority - b._action.priority)
      .slice(0, 6);
    if (!items.length) {
      el.innerHTML = `<div class="text-sm text-[var(--text-muted)] text-center py-4">${document.getElementById('i18n-noUpcoming')?.textContent || 'No webinar registered.'}</div>`;
      return;
    }
    el.innerHTML = `<div class="grid grid-cols-1 lg:grid-cols-2 gap-3">${items.map((w: any) => `
      <article class="rounded-2xl border border-[var(--border-default)] p-4">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <div class="text-sm font-bold text-navy">${esc(w.title)}</div>
            <div class="text-[.72rem] text-[var(--text-muted)] mt-1">${fmtDate(w.scheduled_at)} · ${w.chapter_code === 'ALL' ? T.chapterGeneral : 'PMI-' + w.chapter_code}</div>
            <div class="mt-2 inline-flex items-center gap-2 px-2.5 py-1 rounded-full border text-[.68rem] font-bold ${w._action.tone}">${esc(w._action.label)}</div>
          </div>
          ${canEdit() ? `<button type="button" data-edit="${w.id}" class="shrink-0 px-3 py-1.5 rounded-lg bg-navy text-white text-[.72rem] font-semibold border-0 cursor-pointer hover:opacity-90">${T.cardOpenBtn}</button>` : ''}
        </div>
      </article>
    `).join('')}</div>`;
  }

  function renderList(webinars: any[]) {
    const el = document.getElementById('webinars-list');
    if (!el) return;
    if (!webinars.length) {
      el.innerHTML = `
        <div class="rounded-2xl border border-dashed border-[var(--border-default)] p-10 text-center">
          <div class="text-4xl mb-3">🎥</div>
          <div class="text-sm font-semibold text-[var(--text-secondary)]">${document.getElementById('ai18n-nor')?.textContent || 'No webinar.'}</div>
          <p class="text-[.78rem] text-[var(--text-muted)] mt-1 mb-4">${T.emptyAllStart}</p>
        </div>`;
      return;
    }
    el.innerHTML = `<div class="space-y-3">${webinars.map(webinarCard).join('')}</div>`;
  }

  function renderAll(webinars: any[]) {
    renderStats(webinars);
    renderActions(webinars);
    renderUpcoming(webinars);
    renderFollowup(webinars);
    renderList(webinars);
    // Attach edit handlers
    document.querySelectorAll('[data-edit]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = (btn as HTMLElement).dataset.edit;
        const w = ALL_WEBINARS.find((x: any) => x.id === id);
        if (w) openModal(w);
      });
    });
  }

  // ── Modal ──

  async function loadActiveMembers() {
    if (allActiveMembers.length > 0) return;
    try {
      const { data } = await sb.from('public_members')
        .select('id, name, operational_role')
        .eq('current_cycle_active', true)
        .order('name');
      if (data) allActiveMembers = data;
    } catch (_) {}
  }

  function renderCoManagerSelector() {
    const container = document.getElementById('modal-co-managers');
    const countEl = document.getElementById('modal-co-count');
    if (!container) return;
    if (allActiveMembers.length === 0) {
      container.innerHTML = `<span class="text-[.72rem] text-[var(--text-muted)]">${document.getElementById('ai18n-nor')?.textContent || 'No member found.'}</span>`;
      return;
    }
    const ROLE_SHORT: Record<string, string> = T.roleShort;
    container.innerHTML = allActiveMembers.map(function(m) {
      var checked = coManagerIds.includes(m.id) ? 'checked' : '';
      return '<label class="flex items-center gap-2 px-2 py-1.5 rounded hover:bg-[var(--surface-hover)] cursor-pointer text-sm">'
        + '<input type="checkbox" data-cm-id="' + m.id + '" ' + checked + ' class="rounded border-[var(--border-default)]" />'
        + '<span class="text-[var(--text-primary)]">' + esc(m.name) + '</span>'
        + '<span class="text-[.68rem] text-[var(--text-muted)]">(' + (ROLE_SHORT[m.operational_role] || m.operational_role) + ')</span>'
        + '</label>';
    }).join('');

    // Bind change events
    container.querySelectorAll('input[data-cm-id]').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var input = cb as HTMLInputElement;
        var mid = input.dataset.cmId || '';
        if (input.checked) {
          if (!coManagerIds.includes(mid)) coManagerIds.push(mid);
        } else {
          coManagerIds = coManagerIds.filter(function(x) { return x !== mid; });
        }
        updateCoCount();
      });
    });
    updateCoCount();
  }

  function updateCoCount() {
    var countEl = document.getElementById('modal-co-count');
    if (!countEl) return;
    if (coManagerIds.length > 0) {
      countEl.textContent = coManagerIds.length + ' ' + T.coManagersCountSuffix;
      countEl.classList.remove('hidden');
    } else {
      countEl.classList.add('hidden');
    }
  }

  function openModal(w?: any) {
    if (w) { try { if ((window as any).posthog) (window as any).posthog.capture('webinar_viewed', { webinar_id: w.id, webinar_title: w.title, status: w.status, chapter: w.chapter_code }); } catch {} }
    const modal = document.getElementById('webinar-modal')!;
    const titleEl = document.getElementById('modal-title')!;
    const idEl = document.getElementById('modal-id') as HTMLInputElement;
    const wTitleEl = document.getElementById('modal-wTitle') as HTMLInputElement;
    const descEl = document.getElementById('modal-desc') as HTMLTextAreaElement;
    const dateEl = document.getElementById('modal-date') as HTMLInputElement;
    const durationEl = document.getElementById('modal-duration') as HTMLInputElement;
    const chapterEl = document.getElementById('modal-chapter') as HTMLSelectElement;
    const statusEl = document.getElementById('modal-status') as HTMLSelectElement;
    const tribeEl = document.getElementById('modal-tribe') as HTMLSelectElement;
    const linkEl = document.getElementById('modal-link') as HTMLInputElement;
    const youtubeEl = document.getElementById('modal-youtube') as HTMLInputElement;
    const notesEl = document.getElementById('modal-notes') as HTMLTextAreaElement;
    const createEventBtn = document.getElementById('btn-create-event')!;
    const lifecycleSection = document.getElementById('modal-lifecycle')!;

    // Populate tribe select
    tribeEl.innerHTML = `<option value="">${T.modalSelectTribe}</option>`;
    Object.entries(TRIBE_NAMES).forEach(([id, name]) => {
      tribeEl.innerHTML += `<option value="${id}">${name}</option>`;
    });

    // Co-managers
    coManagerIds = w?.co_managers?.map((cm: any) => cm.id) || [];
    loadActiveMembers().then(renderCoManagerSelector);

    if (w) {
      titleEl.textContent = T.modalEditTitle;
      idEl.value = w.id;
      wTitleEl.value = w.title || '';
      descEl.value = w.description || '';
      const dt = w.scheduled_at ? new Date(w.scheduled_at) : null;
      dateEl.value = dt ? dt.toISOString().slice(0, 16) : '';
      durationEl.value = String(w.duration_min || 60);
      chapterEl.value = w.chapter_code || 'ALL';
      statusEl.value = w.status || 'planned';
      tribeEl.value = w.tribe_id ? String(w.tribe_id) : '';
      linkEl.value = w.meeting_link || '';
      youtubeEl.value = w.youtube_url || '';
      notesEl.value = w.notes || '';

      // Show create event button if no event linked
      if (!w.event_id && w.status !== 'cancelled') {
        createEventBtn.classList.remove('hidden');
        createEventBtn.onclick = () => linkEvent(w.id);
      } else {
        createEventBtn.classList.add('hidden');
      }

      // Load lifecycle
      loadLifecycle(w.id);
    } else {
      titleEl.textContent = T.modalAddTitle;
      idEl.value = '';
      wTitleEl.value = '';
      descEl.value = '';
      dateEl.value = '';
      durationEl.value = '60';
      chapterEl.value = 'ALL';
      statusEl.value = 'planned';
      tribeEl.value = '';
      linkEl.value = '';
      youtubeEl.value = '';
      notesEl.value = '';
      createEventBtn.classList.add('hidden');
      lifecycleSection.classList.add('hidden');
    }

    modal.classList.remove('hidden');
  }

  function closeModal() {
    document.getElementById('webinar-modal')?.classList.add('hidden');
  }

  async function loadLifecycle(webinarId: string) {
    const section = document.getElementById('modal-lifecycle')!;
    const body = document.getElementById('modal-lifecycle-body')!;
    try {
      const { data, error } = await sb.rpc('get_webinar_lifecycle', { p_webinar_id: webinarId });
      if (error || !data?.length) {
        section.classList.add('hidden');
        return;
      }
      const events = Array.isArray(data) ? data : JSON.parse(data);
      section.classList.remove('hidden');
      body.innerHTML = events.map((e: any) => {
        const actionLabel: Record<string, string> = {
          created: T.lifecycleCreated, status_change: T.lifecycleStatusChange, event_linked: T.lifecycleEventLinked,
        };
        return `<div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-teal shrink-0"></span>
          <span class="font-semibold">${actionLabel[e.action] || e.action}</span>
          ${e.old_status && e.new_status ? `<span>${e.old_status} → ${e.new_status}</span>` : ''}
          <span class="text-[var(--text-muted)]">— ${esc(e.actor_name || '?')} · ${fmtDate(e.created_at)}</span>
        </div>`;
      }).join('');
    } catch { section.classList.add('hidden'); }
  }

  async function saveWebinar() {
    const id = (document.getElementById('modal-id') as HTMLInputElement).value || undefined;
    const title = (document.getElementById('modal-wTitle') as HTMLInputElement).value.trim();
    const description = (document.getElementById('modal-desc') as HTMLTextAreaElement).value.trim() || undefined;
    const scheduled_at = (document.getElementById('modal-date') as HTMLInputElement).value;
    const duration_min = Number((document.getElementById('modal-duration') as HTMLInputElement).value) || 60;
    const chapter_code = (document.getElementById('modal-chapter') as HTMLSelectElement).value;
    const status = (document.getElementById('modal-status') as HTMLSelectElement).value;
    const tribe_id = Number((document.getElementById('modal-tribe') as HTMLSelectElement).value) || undefined;
    const meeting_link = (document.getElementById('modal-link') as HTMLInputElement).value.trim() || undefined;
    const youtube_url = (document.getElementById('modal-youtube') as HTMLInputElement).value.trim() || undefined;
    const notes = (document.getElementById('modal-notes') as HTMLTextAreaElement).value.trim() || undefined;

    if (!title || !scheduled_at) {
      alert(T.validateTitleAndDate);
      return;
    }

    try {
      const params: any = {
        p_title: title,
        p_description: description,
        p_scheduled_at: new Date(scheduled_at).toISOString(),
        p_duration_min: duration_min,
        p_status: status,
        p_chapter_code: chapter_code,
        p_tribe_id: tribe_id || null,
        p_meeting_link: meeting_link || null,
        p_youtube_url: youtube_url || null,
        p_notes: notes || null,
        p_co_manager_ids: coManagerIds.length > 0 ? coManagerIds : null,
      };
      if (id) params.p_id = id;

      const { error } = await sb.rpc('upsert_webinar', params);
      if (error) throw error;

      closeModal();
      await reload();
    } catch (err: any) {
      alert((document.getElementById('ai18n-sav')?.textContent || 'Error: ') + (err?.message || err));
    }
  }

  async function linkEvent(webinarId: string) {
    try {
      const { data, error } = await sb.rpc('link_webinar_event', { p_webinar_id: webinarId });
      if (error) throw error;
      closeModal();
      await reload();
      alert(T.linkSessionSuccess);
    } catch (err: any) {
      alert((document.getElementById('ai18n-sav')?.textContent || 'Error: ') + (err?.message || err));
    }
  }

  // ── Load & Filter ──

  async function reload() {
    const statusFilter = (document.getElementById('filter-status') as HTMLSelectElement)?.value || undefined;
    const chapterFilter = (document.getElementById('filter-chapter') as HTMLSelectElement)?.value || undefined;

    const params: any = {};
    if (statusFilter) params.p_status = statusFilter;
    if (chapterFilter) params.p_chapter = chapterFilter;

    const { data, error } = await sb.rpc('list_webinars_v2', params);
    if (error) throw error;

    ALL_WEBINARS = Array.isArray(data) ? data : (data ? JSON.parse(data) : []);
    renderAll(ALL_WEBINARS);
  }

  // ── Boot ──

  async function boot() {
    const member = (window as any).navGetMember?.();
    if (!member) {
      if (!(window as any).__webinarsWaitForMember) {
        (window as any).__webinarsWaitForMember = true;
        window.addEventListener('nav:member', () => {
          (window as any).__webinarsWaitForMember = false;
          boot();
        }, { once: true });
      }
      const navSb = (window as any).navGetSb?.();
      if (navSb?.auth?.getSession) {
        const { data: { session } } = await navSb.auth.getSession();
        if (!session) { showDenied(); return; }
      }
      return;
    }

    MEMBER = member;
    if (!canAccessWebinarsWorkspace(member)) { showDenied(); return; }

    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 300); return; }

    // Hide new button if not admin
    if (!canEdit()) {
      document.getElementById('btn-new-webinar')?.classList.add('hidden');
    }

    try {
      await reload();
      showPanel();
    } catch (err) {
      console.warn('Webinars panel:', err);
      showPanel();
    }

    // Event listeners
    document.getElementById('btn-new-webinar')?.addEventListener('click', () => openModal());
    document.getElementById('btn-modal-cancel')?.addEventListener('click', closeModal);
    document.getElementById('btn-modal-save')?.addEventListener('click', saveWebinar);
    document.getElementById('filter-status')?.addEventListener('change', reload);
    document.getElementById('filter-chapter')?.addEventListener('change', reload);

    // Close modal on backdrop click
    document.getElementById('webinar-modal')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'webinar-modal') closeModal();
    });
  }

  boot();
</script>
