---
/**
 * /admin/governance/ip-ratification — Admin panel para gestão de ratificação IP.
 * Client-side fetch via window.navGetSb() (user JWT context, RPCs passam auth.uid()).
 * Ações: advance_approval_gate (abrir review, ativar, retirar, superseder).
 *
 * Escopo: Phase IP-2 Chunk 4. ADR-0016. Trilingue p137 Ω-B+.1.
 * Auth: manage_member (RPC gate; AdminLayout role check is visual only, real gate is no DB).
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

// Pre-render strings for inline script via define:vars
const IP_RATIF_I18N = {
  status: {
    draft: t('admin.governance.ipRatif.status.draft', lang),
    review: t('admin.governance.ipRatif.status.review', lang),
    approved: t('admin.governance.ipRatif.status.approved', lang),
    active: t('admin.governance.ipRatif.status.active', lang),
    withdrawn: t('admin.governance.ipRatif.status.withdrawn', lang),
    superseded: t('admin.governance.ipRatif.status.superseded', lang),
  },
  gate: {
    curator: t('admin.governance.ipRatif.gate.curator', lang),
    leader: t('admin.governance.ipRatif.gate.leader', lang),
    president_go: t('admin.governance.ipRatif.gate.president_go', lang),
    president_others: t('admin.governance.ipRatif.gate.president_others', lang),
    member_ratification: t('admin.governance.ipRatif.gate.member_ratification', lang),
    external_signer: t('admin.governance.ipRatif.gate.external_signer', lang),
  },
  action: {
    openReview: t('admin.governance.ipRatif.action.openReview', lang),
    activate: t('admin.governance.ipRatif.action.activate', lang),
    withdraw: t('admin.governance.ipRatif.action.withdraw', lang),
    supersede: t('admin.governance.ipRatif.action.supersede', lang),
    signPrefix: t('admin.governance.ipRatif.action.signPrefix', lang),
  },
  error: {
    sbUnavailable: t('admin.governance.ipRatif.error.sbUnavailable', lang),
    prefix: t('admin.governance.ipRatif.error.prefix', lang),
    defaultDocTitle: t('admin.governance.ipRatif.error.defaultDocTitle', lang),
  },
  prompt: {
    reason: t('admin.governance.ipRatif.prompt.reason', lang),
  },
  alert: {
    sbUnavailableShort: t('admin.governance.ipRatif.alert.sbUnavailableShort', lang),
  },
};
---

<AdminLayout
  title={t('admin.governance.ipRatif.title', lang)}
  breadcrumbs={[
    { label: t('admin.layout.breadcrumb.operations', lang) },
    { label: t('admin.layout.breadcrumb.governance', lang) },
    { label: t('admin.layout.breadcrumb.ipRatification', lang) },
  ]}
>
  <div class="max-w-[1200px] mx-auto px-4 py-8 space-y-6">
    <header class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-extrabold text-navy">{t('admin.governance.ipRatif.h1', lang)}</h1>
        <p class="text-sm text-[var(--text-muted)] mt-1" set:html={
          t('admin.governance.ipRatif.desc', lang).replace(
            '{sign_ip_ratification}',
            '<code class="text-xs bg-gray-100 px-1 rounded">sign_ip_ratification</code>'
          )
        } />
      </div>
      <div class="flex gap-2 items-center">
        <a href={`${langPrefix}/admin/governance/documents`} class="text-xs font-semibold text-white bg-navy px-3 py-1.5 rounded-lg no-underline hover:opacity-90">
          {t('admin.governance.ipRatif.linkUseNew', lang)}
        </a>
        <a href={`${langPrefix}/admin/governance-v2`} class="text-sm text-[var(--text-muted)] hover:text-navy no-underline">
          {t('admin.governance.ipRatif.linkBackGov', lang)}
        </a>
      </div>
    </header>

    <div id="ip-loading" class="rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] px-6 py-12 text-center text-sm text-[var(--text-muted)]">
      {t('admin.governance.ipRatif.loading', lang)}
    </div>

    <div id="ip-error" class="hidden rounded-lg border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-800"></div>

    <div id="ip-empty" class="hidden rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] px-6 py-12 text-center text-sm text-[var(--text-muted)]">
      {t('admin.governance.ipRatif.emptyState', lang)}
    </div>

    <section id="ip-table-wrap" class="hidden rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-[var(--surface-hover)] text-xs font-semibold uppercase tracking-wide text-[var(--text-secondary)]">
          <tr>
            <th class="px-4 py-3 text-left">{t('admin.governance.ipRatif.col.document', lang)}</th>
            <th class="px-4 py-3 text-left">{t('admin.governance.ipRatif.col.version', lang)}</th>
            <th class="px-4 py-3 text-left">{t('admin.governance.ipRatif.col.status', lang)}</th>
            <th class="px-4 py-3 text-right">{t('admin.governance.ipRatif.col.gates', lang)}</th>
            <th class="px-4 py-3 text-right">{t('admin.governance.ipRatif.col.signoffs', lang)}</th>
            <th class="px-4 py-3 text-right">{t('admin.governance.ipRatif.col.pending', lang)}</th>
            <th class="px-4 py-3 text-right">{t('admin.governance.ipRatif.col.sign', lang)}</th>
            <th class="px-4 py-3 text-right">{t('admin.governance.ipRatif.col.actions', lang)}</th>
          </tr>
        </thead>
        <tbody id="ip-tbody"></tbody>
      </table>
    </section>

    <p class="text-xs text-[var(--text-muted)]" set:html={
      t('admin.governance.ipRatif.reminderNote', lang).replace(
        '{get_ratification_reminder_targets}',
        '<code class="bg-gray-100 px-1 rounded">get_ratification_reminder_targets</code>'
      )
    } />
  </div>

  <script is:inline define:vars={{ IP_RATIF_I18N }}>
    window.__IP_RATIF_I18N = typeof IP_RATIF_I18N !== 'undefined' ? IP_RATIF_I18N : {};
  </script>
  <script is:inline>
    const I18N = window.__IP_RATIF_I18N || {};
    const STATUS_LABELS = {
      draft:      { label: I18N.status?.draft || 'Rascunho',      cls: 'bg-gray-100 text-gray-700 border-gray-300' },
      review:     { label: I18N.status?.review || 'Em revisão',   cls: 'bg-amber-100 text-amber-800 border-amber-300' },
      approved:   { label: I18N.status?.approved || 'Aprovado',   cls: 'bg-blue-100 text-blue-800 border-blue-300' },
      active:     { label: I18N.status?.active || 'Vigente',      cls: 'bg-emerald-100 text-emerald-800 border-emerald-300' },
      withdrawn:  { label: I18N.status?.withdrawn || 'Retirado',  cls: 'bg-red-100 text-red-700 border-red-300' },
      superseded: { label: I18N.status?.superseded || 'Substituído', cls: 'bg-gray-200 text-gray-600 border-gray-400' },
    };

    async function waitForSb(maxRetries) {
      maxRetries = maxRetries || 15;
      var sb = window.navGetSb && window.navGetSb();
      var retries = 0;
      while (!sb && retries < maxRetries) {
        await new Promise(function (r) { setTimeout(r, 250); });
        sb = window.navGetSb && window.navGetSb();
        retries++;
      }
      return sb;
    }

    function escapeHtml(s) {
      return String(s || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function actionButtons(row) {
      var btns = [];
      if (row.status === 'draft') {
        btns.push('<button class="ip-advance-btn rounded bg-amber-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-amber-700" data-chain-id="' + row.chain_id + '" data-target="review">' + (I18N.action?.openReview || 'Abrir review') + '</button>');
      }
      if (row.status === 'approved') {
        btns.push('<button class="ip-advance-btn rounded bg-emerald-600 px-2 py-1 text-[11px] font-semibold text-white hover:bg-emerald-700" data-chain-id="' + row.chain_id + '" data-target="active">' + (I18N.action?.activate || 'Ativar') + '</button>');
      }
      if (row.status === 'review' || row.status === 'approved') {
        btns.push('<button class="ip-advance-btn rounded border border-red-300 bg-white px-2 py-1 text-[11px] font-semibold text-red-700 hover:bg-red-50" data-chain-id="' + row.chain_id + '" data-target="withdrawn">' + (I18N.action?.withdraw || 'Retirar') + '</button>');
      }
      if (row.status === 'active') {
        btns.push('<button class="ip-advance-btn rounded border border-gray-300 bg-white px-2 py-1 text-[11px] font-semibold text-gray-700 hover:bg-gray-50" data-chain-id="' + row.chain_id + '" data-target="superseded">' + (I18N.action?.supersede || 'Substituir') + '</button>');
      }
      return '<div class="flex justify-end gap-1 flex-wrap">' + btns.join('') + '</div>';
    }

    var GATE_LABELS = {
      curator: I18N.gate?.curator || 'curador',
      leader: I18N.gate?.leader || 'liderança',
      president_go: I18N.gate?.president_go || 'pres. GO',
      president_others: I18N.gate?.president_others || 'pres. capítulo',
      member_ratification: I18N.gate?.member_ratification || 'membro',
      external_signer: I18N.gate?.external_signer || 'signatário ext.',
    };

    function signButtons(row) {
      var eligible = Array.isArray(row.eligible_gates) ? row.eligible_gates : [];
      if (!eligible.length) return '<span class="text-[11px] text-[var(--text-muted)]">—</span>';
      var signPrefix = I18N.action?.signPrefix || 'Assinar';
      return '<div class="flex justify-end gap-1 flex-wrap">' + eligible.map(function (g) {
        var label = GATE_LABELS[g] || g;
        var href = '/governance/ip-agreement?chain_id=' + encodeURIComponent(row.chain_id) + '&gate_kind=' + encodeURIComponent(g);
        return '<a href="' + href + '" class="rounded border border-navy bg-white px-2 py-1 text-[10px] font-semibold text-navy hover:bg-navy hover:text-white transition-colors no-underline">' + signPrefix + ' ' + label + '</a>';
      }).join('') + '</div>';
    }

    function renderRow(row) {
      var s = STATUS_LABELS[row.status] || { label: row.status, cls: 'bg-gray-100' };
      var pendingCell = row.pending_members > 0
        ? '<span class="text-amber-700 font-semibold">' + row.pending_members + '</span>'
        : '—';
      return (
        '<tr class="border-t border-[var(--border-default)] hover:bg-[var(--surface-hover)]">' +
          '<td class="px-4 py-3 font-semibold text-[var(--text-primary)]">' + escapeHtml(row.document_title) + '</td>' +
          '<td class="px-4 py-3 text-[var(--text-muted)]">' + escapeHtml(row.version_label) + '</td>' +
          '<td class="px-4 py-3"><span class="inline-block rounded-full border px-2 py-0.5 text-[11px] font-semibold ' + s.cls + '">' + s.label + '</span></td>' +
          '<td class="px-4 py-3 text-right tabular-nums text-[var(--text-secondary)]">' + row.gate_count + '</td>' +
          '<td class="px-4 py-3 text-right tabular-nums text-[var(--text-secondary)]">' + row.signoff_count + '</td>' +
          '<td class="px-4 py-3 text-right tabular-nums text-[var(--text-secondary)]">' + pendingCell + '</td>' +
          '<td class="px-4 py-3 text-right">' + signButtons(row) + '</td>' +
          '<td class="px-4 py-3 text-right">' + actionButtons(row) + '</td>' +
        '</tr>'
      );
    }

    async function loadOverview() {
      const sb = await waitForSb();
      if (!sb) {
        document.getElementById('ip-loading').classList.add('hidden');
        const err = document.getElementById('ip-error');
        err.textContent = I18N.error?.sbUnavailable || 'Cliente Supabase indisponível. Recarregue a página.';
        err.classList.remove('hidden');
        return;
      }

      const chainsRes = await sb
        .from('approval_chains')
        .select('id, status, gates, document_id, version_id, governance_documents!inner(id, title, doc_type), document_versions!inner(id, version_label)')
        .in('status', ['draft', 'review', 'approved', 'active']);

      if (chainsRes.error) {
        document.getElementById('ip-loading').classList.add('hidden');
        const err = document.getElementById('ip-error');
        err.textContent = (I18N.error?.prefix || 'Erro:') + ' ' + chainsRes.error.message;
        err.classList.remove('hidden');
        return;
      }

      const chains = chainsRes.data || [];

      // Callers' eligibility map (chain_id → eligible_gates[]) for inline sign buttons
      const eligMap = {};
      const pendRes = await sb.rpc('get_pending_ratifications');
      if (!pendRes.error && Array.isArray(pendRes.data)) {
        for (var i = 0; i < pendRes.data.length; i++) {
          var p = pendRes.data[i];
          if (p && p.chain_id) eligMap[p.chain_id] = p.eligible_gates || [];
        }
      }

      const overview = [];

      for (const c of chains) {
        const sCountRes = await sb
          .from('approval_signoffs')
          .select('id', { count: 'exact', head: true })
          .eq('approval_chain_id', c.id);
        const signoff_count = sCountRes.count || 0;

        let pending_members = 0;
        if (c.status === 'review' || c.status === 'approved') {
          const rem = await sb.rpc('get_ratification_reminder_targets', { p_document_id: c.document_id });
          if (!rem.error && Array.isArray(rem.data)) {
            pending_members = rem.data.filter(function (r) { return r.target_type === 'member_pending_ratification'; }).length;
          }
        }

        const gates = Array.isArray(c.gates) ? c.gates : [];
        overview.push({
          chain_id: c.id,
          document_id: c.document_id,
          document_title: (c.governance_documents && c.governance_documents.title) || (I18N.error?.defaultDocTitle || '(sem título)'),
          status: c.status,
          gate_count: gates.length,
          signoff_count: signoff_count,
          pending_members: pending_members,
          version_label: (c.document_versions && c.document_versions.version_label) || '',
          eligible_gates: eligMap[c.id] || [],
        });
      }

      overview.sort(function (a, b) { return a.document_title.localeCompare(b.document_title); });

      document.getElementById('ip-loading').classList.add('hidden');
      if (overview.length === 0) {
        document.getElementById('ip-empty').classList.remove('hidden');
        return;
      }

      document.getElementById('ip-tbody').innerHTML = overview.map(renderRow).join('');
      document.getElementById('ip-table-wrap').classList.remove('hidden');
      attachAdvanceHandlers();
    }

    function attachAdvanceHandlers() {
      document.querySelectorAll('.ip-advance-btn').forEach(function (btn) {
        btn.addEventListener('click', async function (ev) {
          const b = ev.currentTarget;
          const chainId = b.dataset.chainId;
          const target = b.dataset.target;
          const reason = target === 'withdrawn' || target === 'superseded'
            ? window.prompt(I18N.prompt?.reason || 'Motivo (obrigatório para retirada/substituição):')
            : null;
          if ((target === 'withdrawn' || target === 'superseded') && !reason) return;

          b.disabled = true;
          const orig = b.textContent;
          b.textContent = '...';

          const sb = await waitForSb();
          if (!sb) {
            alert(I18N.alert?.sbUnavailableShort || 'Erro: cliente Supabase indisponível.');
            b.disabled = false; b.textContent = orig;
            return;
          }
          const res = await sb.rpc('advance_approval_gate', {
            p_chain_id: chainId,
            p_target_status: target,
            p_reason: reason,
          });
          if (res.error) {
            alert((I18N.error?.prefix || 'Erro:') + ' ' + res.error.message);
            b.disabled = false; b.textContent = orig;
            return;
          }
          window.location.reload();
        });
      });
    }

    loadOverview();
  </script>
</AdminLayout>
