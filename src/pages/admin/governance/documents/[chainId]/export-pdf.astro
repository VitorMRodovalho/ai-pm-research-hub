---
/**
 * /admin/governance/documents/[chainId]/export-pdf — IP-4 Chunk 2
 * Exporta a cadeia de ratificação como PDF via @react-pdf/renderer client-side.
 */
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import ChainPDFExportIsland from '../../../../../components/governance/ChainPDFExportIsland';
import { t, getLangFromURL, type Lang } from '../../../../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const { chainId } = Astro.params;
---
<AdminLayout
  title={t('admin.governance.exportPdf.title', lang)}
  breadcrumbs={[
    { label: t('admin.layout.breadcrumb.operations', lang) },
    { label: t('admin.layout.breadcrumb.governance', lang) },
    { label: t('admin.layout.breadcrumb.documents', lang), href: '/admin/governance/documents' },
    { label: t('admin.layout.breadcrumb.review', lang), href: `/admin/governance/documents/${chainId}` },
    { label: t('admin.governance.exportPdf.breadcrumb', lang) },
  ]}
>
  <div class="max-w-[900px] mx-auto px-4 py-6">
    <ChainPDFExportIsland client:only="react" chainId={chainId || ''} />
  </div>
</AdminLayout>
