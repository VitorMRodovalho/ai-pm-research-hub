---
/**
 * /admin/governance/documents/[chainId]/audit-report — IP-4 Chunk 3
 * Relatório de auditoria para Conselho Fiscal (complementa PDF oficial).
 */
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import ChainAuditReportIsland from '../../../../../components/governance/ChainAuditReportIsland';
import { t, getLangFromURL, type Lang } from '../../../../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const { chainId } = Astro.params;
---
<AdminLayout
  title={t('admin.governance.auditReport.title', lang)}
  breadcrumbs={[
    { label: t('admin.layout.breadcrumb.operations', lang) },
    { label: t('admin.layout.breadcrumb.governance', lang) },
    { label: t('admin.layout.breadcrumb.documents', lang), href: '/admin/governance/documents' },
    { label: t('admin.layout.breadcrumb.review', lang), href: `/admin/governance/documents/${chainId}` },
    { label: t('admin.governance.auditReport.breadcrumb', lang) },
  ]}
>
  <div class="max-w-[900px] mx-auto px-4 py-6">
    <ChainAuditReportIsland client:only="react" chainId={chainId || ''} />
  </div>
</AdminLayout>
