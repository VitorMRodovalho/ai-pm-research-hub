---
/**
 * /admin/governance/documents/[chainId]/export-docx — IP-4 Chunk 3 (p128 D2)
 *
 * Exporta o conteúdo da versão como DOCX (Word) para envio offline a
 * curadores externos sem conta na plataforma. Reuso get_chain_for_pdf RPC.
 */
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import ChainDocxExportIsland from '../../../../../components/governance/ChainDocxExportIsland';
import { t, getLangFromURL, type Lang } from '../../../../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const { chainId } = Astro.params;
---
<AdminLayout
  title={t('admin.governance.exportDocx.title', lang)}
  breadcrumbs={[
    { label: t('admin.layout.breadcrumb.operations', lang) },
    { label: t('admin.layout.breadcrumb.governance', lang) },
    { label: t('admin.layout.breadcrumb.documents', lang), href: '/admin/governance/documents' },
    { label: t('admin.layout.breadcrumb.review', lang), href: `/admin/governance/documents/${chainId}` },
    { label: t('admin.governance.exportDocx.breadcrumb', lang) },
  ]}
>
  <div class="max-w-[900px] mx-auto px-4 py-6">
    <ChainDocxExportIsland client:only="react" chainId={chainId || ''} />
  </div>
</AdminLayout>
