---
/**
 * /admin/governance/documents/[chainId]/export-docx — IP-4 Chunk 3 (p128 D2)
 *
 * Exporta o conteúdo da versão como DOCX (Word) para envio offline a
 * curadores externos sem conta na plataforma. Reuso get_chain_for_pdf RPC.
 */
import AdminLayout from '../../../../../layouts/AdminLayout.astro';
import ChainDocxExportIsland from '../../../../../components/governance/ChainDocxExportIsland';

const { chainId } = Astro.params;
---
<AdminLayout
  title="Exportar DOCX — conteúdo da versão"
  breadcrumbs={[
    { label: 'Operações' },
    { label: 'Governança' },
    { label: 'Documentos', href: '/admin/governance/documents' },
    { label: 'Revisar', href: `/admin/governance/documents/${chainId}` },
    { label: 'Exportar DOCX' },
  ]}
>
  <div class="max-w-[900px] mx-auto px-4 py-6">
    <ChainDocxExportIsland client:only="react" chainId={chainId || ''} />
  </div>
</AdminLayout>
