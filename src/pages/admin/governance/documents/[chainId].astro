---
/**
 * /admin/governance/documents/[chainId] — Review view (React island).
 *
 * Full flow via ReviewChainIsland: workflow detail, pipeline, sign actions, comment drawer.
 * Escopo: Phase IP-3c P0. ADR-0016 + correções PM 2026-04-18 p33.
 */
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import ReviewChainIsland from '../../../../components/governance/ReviewChainIsland';
import { t, getLangFromURL, type Lang } from '../../../../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const { chainId } = Astro.params;
---
<AdminLayout
  title={t('admin.governance.review.title', lang)}
  breadcrumbs={[
    { label: t('admin.layout.breadcrumb.operations', lang) },
    { label: t('admin.layout.breadcrumb.governance', lang) },
    { label: t('admin.layout.breadcrumb.documents', lang), href: '/admin/governance/documents' },
    { label: t('admin.layout.breadcrumb.review', lang) },
  ]}
>
  <div class="max-w-[1600px] mx-auto px-4 py-6">
    <ReviewChainIsland client:load chainId={chainId || ''} />
  </div>
</AdminLayout>
