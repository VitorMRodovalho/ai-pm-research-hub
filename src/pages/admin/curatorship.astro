---
/**
 * admin/curatorship.astro — Curatorship Super-Kanban
 * Single React Island: CuratorshipBoardIsland handles all UI, DnD, RPCs.
 * Access: admin+, curator, co_gp.
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
import CuratorshipBoardIsland from '../../components/boards/CuratorshipBoardIsland';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.curation', 'comp.common'], lang);

const CUR_I18N = {
  title: t('admin.curatorship.title', lang),
  subtitle: t('admin.curatorship.subtitle', lang),
  loading: t('admin.curatorship.loading', lang),
  denied: t('admin.curatorship.denied', lang),
  empty: t('admin.curatorship.empty', lang),
  filterAll: t('admin.curatorship.filterAll', lang),
  filterArtifacts: t('admin.curatorship.filterArtifacts', lang),
  filterResources: t('admin.curatorship.filterResources', lang),
  approve: t('admin.curatorship.approve', lang),
  reject: t('admin.curatorship.reject', lang),
  editTags: t('admin.curatorship.editTags', lang),
  saveTags: t('admin.curatorship.saveTags', lang),
  source: t('admin.curatorship.source', lang),
  suggestedTags: t('admin.curatorship.suggestedTags', lang),
  currentTags: t('admin.curatorship.currentTags', lang),
  approved: t('admin.curatorship.approved', lang),
  rejected: t('admin.curatorship.rejected', lang),
  tagsSaved: t('admin.curatorship.tagsSaved', lang),
  backAdmin: t('admin.curatorship.backAdmin', lang),
  meta: t('admin.curatorship.meta', lang),
  searchPlaceholder: t('admin.curatorship.searchPlaceholder', lang),
  visibilityLabel: t('admin.curatorship.visibilityLabel', lang),
  visibilityGlobal: t('admin.curatorship.visibilityGlobal', lang),
  audienceLabel: t('admin.curatorship.audienceLabel', lang),
  audienceAll: t('admin.curatorship.audienceAll', lang),
  audienceLeaders: t('admin.curatorship.audienceLeaders', lang),
  audienceMembers: t('admin.curatorship.audienceMembers', lang),
  saveApprove: t('admin.curatorship.saveApprove', lang),
};
---

<AdminLayout title={CUR_I18N.meta} breadcrumbs={[{label:'Conteúdo'},{label:'Curadoria'}]}>
  <div class="max-w-[1400px] mx-auto px-4 pb-8">
    <div class="mb-4">
      <h1 class="text-2xl font-extrabold text-navy">{CUR_I18N.title}</h1>
      <p class="text-sm text-[var(--text-secondary)]">{CUR_I18N.subtitle}</p>
    </div>
    <!-- SSR denied fallback for smoke-routes (hidden once React hydrates) -->
    <div id="cur-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">&#x1F512;</div>
      <p class="font-semibold text-amber-800">Acesso restrito a administradores e lideres</p>
      <a href="/admin" class="inline-block mt-3 px-4 py-2 bg-navy text-white rounded-xl text-sm font-semibold no-underline hover:opacity-90">{t('admin.backToAdmin', lang)}</a>
    </div>
    <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
    <CuratorshipBoardIsland client:load i18n={CUR_I18N} />
  </div>
  <script>
    // Show SSR denied fallback after timeout if React island doesn't take over
    const DENY_TIMEOUT_MS = 4000;
    let islandReady = false;
    window.addEventListener('cur:island-ready', () => { islandReady = true; });
    setTimeout(() => {
      if (islandReady) return;
      const denied = document.getElementById('cur-denied');
      const loading = document.querySelector('[data-cur-loading]');
      if (denied && !document.getElementById('cur-board')) {
        denied.classList.remove('hidden');
        loading?.classList.add('hidden');
      }
    }, DENY_TIMEOUT_MS);
  </script>
</AdminLayout>
