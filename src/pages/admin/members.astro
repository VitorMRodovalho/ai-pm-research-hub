---
/**
 * /admin/members — Dedicated member management page.
 * React island with search, filters, edit modal, checkbox selection.
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
import MemberListIsland from '../../components/admin/members/MemberListIsland';
import Toast from '../../components/ui/Toast.astro';

const filterParam = Astro.url.searchParams.get('filter');
if (filterParam === 'inactive_candidates') {
  const langParam = Astro.url.searchParams.get('lang');
  const target = langParam ? `/admin/members/inactive-candidates?lang=${encodeURIComponent(langParam)}` : '/admin/members/inactive-candidates';
  return Astro.redirect(target);
}

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.memberList', 'comp.common', 'comp.vepBadge'], lang);
---

<AdminLayout title={t('admin.breadcrumb.members', lang)} breadcrumbs={[{label: t('admin.breadcrumb.people', lang)},{label: t('admin.breadcrumb.members', lang)}]}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <MemberListIsland client:load />
  <Toast />
</AdminLayout>
