---
import AdminLayout from '../../layouts/AdminLayout.astro';
import KnowledgeIsland from '../../components/admin/KnowledgeIsland';
import Toast from '../../components/ui/Toast.astro';
import { getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.knowledge', 'comp.common'], lang);
---

<AdminLayout title="Biblioteca de Recursos" breadcrumbs={[{label:'Conteúdo'},{label:'Biblioteca de Recursos'}]}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <div class="max-w-[1100px] mx-auto px-4 pb-12">
    <KnowledgeIsland client:load />
  </div>
  <Toast />
</AdminLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const check = () => {
      const member = window.navGetMember?.();
      if (!member) { setTimeout(check, 300); return; }
      const isAdmin = member.is_superadmin || ['manager', 'deputy_manager', 'tribe_leader', 'sponsor', 'chapter_liaison'].includes(member.operational_role) || (member.designations || []).some(function(d) { return d === 'deputy_manager' || d === 'curator'; });
      if (!isAdmin) {
        document.querySelector('.max-w-\\[1100px\\]').innerHTML = '<div class="text-center py-20 text-[var(--text-muted)]">Acesso restrito a administradores.</div>';
      }
    };
    check();
  });
</script>
