---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Toast from '../../components/ui/Toast.astro';
import LoadingSkeleton from '../../components/ui/LoadingSkeleton.astro';
import InitiativeBoardWrapper from '../../components/initiatives/InitiativeBoardWrapper';
import EventMinutesIsland from '../../components/events/EventMinutesIsland';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['initiative', 'comp.board', 'comp.card', 'comp.common', 'common'], lang);
const { id } = Astro.params;

const INIT_I18N = {
  loading: t('initiative.loading', lang),
  notFound: t('initiative.notFound', lang),
  accessRestricted: t('initiative.accessRestricted', lang),
  generalTab: t('initiative.generalTab', lang),
  boardTab: t('initiative.boardTab', lang),
  membersTab: t('initiative.membersTab', lang),
  deliverablesTab: t('initiative.deliverablesTab', lang),
  attendanceTab: t('initiative.attendanceTab', lang),
  gamificationTab: t('initiative.gamificationTab', lang),
  addMember: t('initiative.addMember', lang),
  removeMember: t('initiative.removeMember', lang),
  roleLabel: t('initiative.roleLabel', lang),
  memberCount: t('initiative.memberCount', lang),
  leader: t('initiative.leader', lang),
  coordinator: t('initiative.coordinator', lang),
  participant: t('initiative.participant', lang),
  observer: t('initiative.observer', lang),
  since: t('initiative.since', lang),
  emptyDraft: t('initiative.emptyDraft', lang),
  emptyNoEvents: t('initiative.emptyNoEvents', lang),
  emptyNoMembers: t('initiative.emptyNoMembers', lang),
  archivedBanner: t('initiative.archivedBanner', lang),
  concludedBanner: t('initiative.concludedBanner', lang),
  setupCta: t('initiative.setupCta', lang),
  description: t('initiative.description', lang),
  noBoard: t('initiative.noBoard', lang),
  viewBoard: t('initiative.viewBoard', lang),
  upcomingEvents: t('initiative.upcomingEvents', lang),
  pastMeetings: t('initiative.pastMeetings', lang),
  noUpcoming: t('initiative.noUpcoming', lang),
  kindBadges: {
    committee: t('initiative.kindBadge.committee', lang),
    workgroup: t('initiative.kindBadge.workgroup', lang),
    study_group: t('initiative.kindBadge.study_group', lang),
    book_club: t('initiative.kindBadge.book_club', lang),
    congress: t('initiative.kindBadge.congress', lang),
    workshop: t('initiative.kindBadge.workshop', lang),
    research_tribe: t('initiative.kindBadge.research_tribe', lang),
  },
  stats: {
    members: t('initiative.stats.members', lang),
    cards: t('initiative.stats.cards', lang),
    done: t('initiative.stats.done', lang),
    progress: t('initiative.stats.progress', lang),
    backlog: t('initiative.stats.backlog', lang),
  },
};
---
<BaseLayout title="Iniciativa" activePage="initiatives" lang={lang}>
  <Toast />
  <div class="max-w-[1400px] mx-auto px-4 py-8">
    <div id="init-loading" class="text-center py-10 text-[var(--text-muted)]">{INIT_I18N.loading}</div>
    <div id="init-denied" class="hidden bg-amber-50 border border-amber-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">{INIT_I18N.accessRestricted}</p>
    </div>
    <div id="init-not-found" class="hidden bg-red-50 border border-red-200 rounded-2xl p-6 text-center">
      <div class="text-2xl mb-2">🔍</div>
      <p class="font-semibold text-red-800">{INIT_I18N.notFound}</p>
    </div>
    <div id="init-shell" class="hidden">
      <!-- Header -->
      <div id="init-header" class="mb-6">
        <LoadingSkeleton variant="profile" />
      </div>

      <!-- Status banners -->
      <div id="init-status-banner" class="hidden mb-4 rounded-2xl px-4 py-3 text-sm"></div>

      <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>

      <!-- Tabs (config-driven, rendered by JS) -->
      <div class="flex gap-2 mb-5 flex-wrap" id="init-tabs"></div>

      <!-- Tab panels -->
      <div id="panel-general"><LoadingSkeleton variant="card" count={2} /></div>
      <div id="panel-board" class="hidden">
        <InitiativeBoardWrapper client:load initiativeId={id || ''} />
      </div>
      <div id="panel-members" class="hidden"><LoadingSkeleton variant="card" count={4} /></div>
      <div id="panel-deliverables" class="hidden"><LoadingSkeleton variant="card" count={2} /></div>
      <div id="panel-attendance" class="hidden"></div>
      <div id="panel-gamification" class="hidden"></div>

      <EventMinutesIsland client:load />
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ INIT_I18N, initiativeId: id }}>
  window.__INIT_I18N = typeof INIT_I18N !== 'undefined' ? INIT_I18N : {};
  window.__INITIATIVE_ID = typeof initiativeId !== 'undefined' ? initiativeId : '';
</script>

<script>
  import { marked } from 'marked';

  const I18N = (typeof window !== 'undefined' && (window as any).__INIT_I18N) || {};
  const INITIATIVE_ID: string = (typeof window !== 'undefined' && (window as any).__INITIATIVE_ID) || '';

  function getSb() { return (window as any).navGetSb?.(); }

  function escapeHtml(s: string): string {
    return String(s || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  const KIND_ICONS: Record<string, string> = {
    committee: '👥', workgroup: '💼', study_group: '📖', book_club: '📚',
    congress: '🎤', workshop: '🔧', research_tribe: '🔬',
  };
  const KIND_COLORS: Record<string, string> = {
    committee: '#06B6D4', workgroup: '#0891B2', study_group: '#8B5CF6', book_club: '#10B981',
    congress: '#F59E0B', workshop: '#EF4444', research_tribe: '#4F17A8',
  };
  const ROLE_LABELS: Record<string, string> = {
    leader: I18N.leader || 'Leader', coordinator: I18N.coordinator || 'Coordinator',
    participant: I18N.participant || 'Participant', observer: I18N.observer || 'Observer',
  };

  let initData: any = null;
  let kindConfig: any = null;
  let currentMember: any = null;
  let canManage = false;
  let activeTab = 'general';

  // ── Tab switching ──
  function switchTab(tabName: string) {
    activeTab = tabName;
    const panels = ['general', 'board', 'members', 'deliverables', 'attendance', 'gamification'];
    panels.forEach(p => {
      const el = document.getElementById(`panel-${p}`);
      if (el) el.classList.toggle('hidden', p !== tabName);
    });
    document.querySelectorAll('.init-tab').forEach(btn => {
      const isActive = (btn as HTMLElement).dataset.tab === tabName;
      btn.classList.toggle('bg-navy', isActive);
      btn.classList.toggle('text-white', isActive);
      btn.classList.toggle('border-navy', isActive);
      btn.classList.toggle('bg-[var(--surface-card)]', !isActive);
      btn.classList.toggle('text-[var(--text-secondary)]', !isActive);
      btn.classList.toggle('border-[var(--border-default)]', !isActive);
    });
  }

  // ── Build tabs from kind_config ──
  function renderTabs() {
    const container = document.getElementById('init-tabs');
    if (!container || !kindConfig) return;

    const tabs: { key: string; label: string }[] = [
      { key: 'general', label: I18N.generalTab || 'General' },
    ];
    if (kindConfig.has_board && initData?.board_id) {
      tabs.push({ key: 'board', label: I18N.boardTab || 'Board' });
    }
    tabs.push({ key: 'members', label: I18N.membersTab || 'Members' });
    if (kindConfig.has_deliverables) {
      tabs.push({ key: 'deliverables', label: I18N.deliverablesTab || 'Deliverables' });
    }
    if (kindConfig.has_attendance) {
      tabs.push({ key: 'attendance', label: I18N.attendanceTab || 'Attendance' });
    }
    if (kindConfig.has_certificate) {
      tabs.push({ key: 'gamification', label: '🏆 ' + (I18N.gamificationTab || 'Gamification') });
    }

    container.innerHTML = tabs.map((tab, i) => {
      const isFirst = i === 0;
      return `<button class="init-tab px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 transition-all ${
        isFirst
          ? 'bg-navy text-white border-navy'
          : 'bg-[var(--surface-card)] text-[var(--text-secondary)] border-[var(--border-default)]'
      }" data-tab="${tab.key}">${tab.label}</button>`;
    }).join('');

    container.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.init-tab') as HTMLElement | null;
      if (btn?.dataset.tab) switchTab(btn.dataset.tab);
    });
  }

  // ── Header ──
  function renderHeader() {
    const el = document.getElementById('init-header');
    if (!el || !initData) return;

    const init = initData.initiative;
    const leader = initData.leader;
    const kind = init.kind;
    const color = KIND_COLORS[kind] || '#4F17A8';
    const icon = KIND_ICONS[kind] || '📋';
    const badgeLabel = (I18N.kindBadges || {})[kind] || kindConfig?.display_name || kind;

    const leaderName = leader?.name || '—';
    const leaderInitials = leader?.name
      ? leader.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase()
      : '?';
    const leaderPhotoHtml = leader?.photo_url
      ? `<img src="${escapeHtml(leader.photo_url)}" class="w-[42px] h-[42px] rounded-xl object-cover" alt="${escapeHtml(leaderName)}">`
      : `<div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center text-white font-extrabold text-base" style="background:${color}">${leaderInitials}</div>`;

    el.innerHTML = `
      <div class="bg-[var(--surface-card)] rounded-2xl overflow-hidden border border-[var(--border-subtle)] hover:shadow-md transition-all duration-300">
        <div class="flex items-center gap-4 px-5 py-4">
          <div class="flex-shrink-0">${leaderPhotoHtml}</div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-[.95rem] font-bold text-[var(--text-primary)] truncate">${escapeHtml(init.title)}</h1>
              <span class="text-xs px-2 py-0.5 rounded-full font-semibold text-white" style="background:${color}">${icon} ${escapeHtml(badgeLabel)}</span>
              ${init.status !== 'active' ? `<span class="text-xs px-2 py-0.5 rounded-full bg-gray-200 text-gray-600 font-semibold">${escapeHtml(init.status)}</span>` : ''}
            </div>
            <div class="text-xs text-[var(--text-secondary)] mt-1 flex flex-wrap gap-x-3">
              <span>👤 ${escapeHtml(leaderName)}</span>
              <span>👥 ${initData.member_count} ${(I18N.stats?.members || 'members').toLowerCase()}</span>
              ${init.metadata?.whatsapp_url ? `<a href="${escapeHtml(init.metadata.whatsapp_url)}" target="_blank" rel="noopener" class="text-emerald-600 no-underline hover:underline font-semibold">💬 WhatsApp</a>` : ''}
            </div>
            ${init.description ? `<p class="text-xs text-[var(--text-muted)] mt-1.5 line-clamp-2">${escapeHtml(init.description)}</p>` : ''}
          </div>
        </div>
        ${canManage ? `<div class="flex items-center gap-2 px-5 pb-3 pt-0">
          ${init.status === 'draft' ? `<button data-action="activate-initiative" class="px-3 py-1.5 rounded-lg bg-emerald-600 text-white text-xs font-semibold border-0 cursor-pointer hover:bg-emerald-700 transition-all">Ativar Iniciativa</button>` : ''}
          <button data-action="add-member-prompt" class="px-3 py-1.5 rounded-lg bg-navy text-white text-xs font-semibold border-0 cursor-pointer hover:opacity-90 transition-all">${I18N.addMember || 'Adicionar Membro'}</button>
        </div>` : ''}
      </div>`;
  }

  // ── Status banners ──
  function renderStatusBanner() {
    const banner = document.getElementById('init-status-banner');
    if (!banner || !initData) return;
    const status = initData.initiative.status;
    if (status === 'archived') {
      banner.className = 'mb-4 rounded-2xl px-4 py-3 text-sm bg-gray-100 border border-gray-300 text-gray-700';
      banner.textContent = I18N.archivedBanner || 'Archived (read-only).';
      banner.classList.remove('hidden');
    } else if (status === 'concluded') {
      banner.className = 'mb-4 rounded-2xl px-4 py-3 text-sm bg-blue-50 border border-blue-200 text-blue-700';
      banner.textContent = I18N.concludedBanner || 'Concluded (read-only).';
      banner.classList.remove('hidden');
    } else if (status === 'draft' && initData.member_count === 0) {
      banner.className = 'mb-4 rounded-2xl px-4 py-3 text-sm bg-amber-50 border border-amber-200 text-amber-800';
      banner.textContent = I18N.emptyDraft || 'Draft — add members to get started.';
      banner.classList.remove('hidden');
    }
  }

  // ── General tab: Stats + Events ──
  async function loadGeneralTab() {
    const el = document.getElementById('panel-general');
    const sb = getSb();
    if (!el || !sb) return;

    // Stats
    try {
      const { data } = await sb.rpc('get_initiative_stats', { p_initiative_id: INITIATIVE_ID });
      if (data) {
        const rateColor = (data.attendance_rate || 0) >= 75 ? '#10B981' : (data.attendance_rate || 0) >= 50 ? '#D97706' : '#BE2027';
        const statsHtml = `<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
          <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
            <div class="text-2xl font-extrabold text-navy">${data.member_count || 0}</div>
            <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">${I18N.stats?.members || 'Members'}</div>
          </div>
          ${kindConfig?.has_attendance ? `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
            <div class="text-2xl font-extrabold" style="color:${rateColor}">${data.attendance_rate ?? 0}%</div>
            <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Presença</div>
          </div>` : ''}
          <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
            <div class="text-lg font-extrabold text-[var(--text-primary)]">
              <span class="text-green-600">${data.cards_done || 0}</span>
              <span class="text-[var(--text-muted)]">/</span>
              <span class="text-blue-600">${data.cards_in_progress || 0}</span>
              <span class="text-[var(--text-muted)]">/</span>
              <span class="text-gray-400">${data.cards_backlog || 0}</span>
            </div>
            <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">${I18N.stats?.cards || 'Cards'} (${I18N.stats?.done || 'done'}/${I18N.stats?.progress || 'prog'}/${I18N.stats?.backlog || 'bklog'})</div>
          </div>
          ${data.impact_hours ? `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
            <div class="text-2xl font-extrabold text-[var(--color-teal)]">${data.impact_hours}h</div>
            <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Horas</div>
          </div>` : ''}
        </div>`;
        el.innerHTML = statsHtml;
      }
    } catch { /* stats not critical */ }

    // "Criar Evento" button
    if (canManage) {
      el.insertAdjacentHTML('beforeend', `<div class="mb-4">
        <button data-action="create-event-prompt" class="px-4 py-2 rounded-xl bg-navy text-white text-sm font-semibold border-0 cursor-pointer hover:opacity-90 transition-all">+ Criar Evento</button>
      </div>`);
    }

    // Cross-link for study_group → /cpmai
    if (initData.initiative.kind === 'study_group') {
      el.insertAdjacentHTML('beforeend', `<a href="/cpmai" class="block mb-4 no-underline bg-purple-50 border border-purple-200 rounded-xl px-4 py-3 text-sm text-purple-800 hover:bg-purple-100 transition-all">
        📖 Ver pagina publica do curso preparatorio → /cpmai
      </a>`);
    }

    // Events timeline
    try {
      const { data } = await sb.rpc('get_initiative_events_timeline', {
        p_initiative_id: INITIATIVE_ID, p_upcoming_limit: 3, p_past_limit: 5,
      });
      if (data) {
        const locale = 'pt-BR';
        const upcoming = Array.isArray(data.upcoming) ? data.upcoming : [];
        const past = Array.isArray(data.past) ? data.past : [];

        let eventsHtml = '';
        if (upcoming.length > 0) {
          eventsHtml += `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 mb-4">
            <h3 class="text-sm font-bold text-navy mb-2">📅 ${I18N.upcomingEvents || 'Upcoming'}</h3>
            <div class="space-y-2">${upcoming.map((e: any) => {
              const d = new Date(e.date + 'T12:00:00').toLocaleDateString(locale, { weekday: 'short', day: '2-digit', month: 'short' });
              return `<div class="flex items-center gap-3 py-1.5 border-b border-[var(--border-subtle)] last:border-0">
                <span class="text-xs font-semibold text-[var(--text-secondary)] w-[80px]">${d}</span>
                <span class="text-sm text-[var(--text-primary)]">${escapeHtml(e.title)}</span>
                ${e.meeting_link ? `<a href="${escapeHtml(e.meeting_link)}" target="_blank" rel="noopener" class="ml-auto text-xs text-teal-600 font-semibold no-underline hover:underline">Entrar →</a>` : ''}
              </div>`;
            }).join('')}</div>
          </div>`;
        } else {
          eventsHtml += `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 mb-4 text-center text-sm text-[var(--text-muted)]">
            ${I18N.noUpcoming || 'No upcoming events.'}
          </div>`;
        }

        if (past.length > 0) {
          eventsHtml += `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
            <h3 class="text-sm font-bold text-navy mb-2">📼 ${I18N.pastMeetings || 'Past Meetings'}</h3>
            <div class="space-y-2">${past.map((e: any) => {
              const d = new Date(e.date + 'T12:00:00').toLocaleDateString(locale, { day: '2-digit', month: 'short' });
              const hasMinutes = e.minutes_text || e.has_minutes;
              const minutesBtn = canManage
                ? `<button data-action="open-minutes-editor" data-event-id="${e.id}" data-event-title="${escapeHtml(e.title)}" data-mode="minutes" data-content="${escapeHtml(e.minutes_text || '')}" class="text-[.65rem] font-semibold text-navy hover:underline cursor-pointer border-0 bg-transparent px-0">${hasMinutes ? '✏️ Editar ata' : '📝 Adicionar ata'}</button>`
                : (hasMinutes ? `<button data-action="open-minutes-editor" data-event-id="${e.id}" data-event-title="${escapeHtml(e.title)}" data-mode="minutes" data-content="${escapeHtml(e.minutes_text || '')}" class="text-[.65rem] font-semibold text-teal-600 hover:underline cursor-pointer border-0 bg-transparent px-0">📝 Ver ata</button>` : '');
              return `<div class="flex items-center gap-3 py-1.5 border-b border-[var(--border-subtle)] last:border-0">
                <span class="text-xs font-semibold text-[var(--text-muted)] w-[50px]">${d}</span>
                <span class="text-sm text-[var(--text-primary)] flex-1">${escapeHtml(e.title)}</span>
                ${minutesBtn}
                ${e.recording_url || e.youtube_url ? `<a href="${escapeHtml(e.youtube_url || e.recording_url)}" target="_blank" rel="noopener" class="text-xs text-purple-600 no-underline hover:underline">▶️</a>` : ''}
              </div>`;
            }).join('')}</div>
          </div>`;
        }
        el.insertAdjacentHTML('beforeend', eventsHtml);
      }
    } catch { /* events not critical */ }
  }

  // ── Members tab (via RPC — client queries blocked by RLS) ──
  const ROLE_COLORS: Record<string, string> = {
    leader: '#FF610F', coordinator: '#4F17A8', participant: '#06B6D4', observer: '#94A3B8',
  };
  const AVAILABLE_ROLES = ['leader', 'coordinator', 'participant', 'observer'];
  const ROLE_PERMISSIONS: Record<string, string> = {
    leader: 'Gestao completa: criar eventos, gerenciar membros, usar quadro, ver contatos',
    coordinator: 'Supervisao: criar/editar conteudo, usar quadro, ver contatos',
    participant: 'Colaborador: usar quadro, ver materiais',
    observer: 'Somente leitura: acompanha atividades sem acoes',
  };

  async function loadMembersTab() {
    const el = document.getElementById('panel-members');
    const sb = getSb();
    if (!el || !sb) return;

    const { data, error } = await sb.rpc('get_initiative_members', { p_initiative_id: INITIATIVE_ID });

    if (error || !Array.isArray(data) || !data.length) {
      el.innerHTML = `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-6 text-center text-sm text-[var(--text-muted)]">
        ${I18N.emptyNoMembers || 'No active members.'}
      </div>`;
      return;
    }

    // Permissions legend
    const legendHtml = `<div class="bg-[var(--surface-section-cool)] border border-[var(--border-default)] rounded-xl p-3 mb-3">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs font-bold text-[var(--text-secondary)] uppercase">Papeis e Permissoes</span>
        <span class="text-[10px] text-[var(--text-muted)]">(governanca visivel)</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-1.5">
        ${AVAILABLE_ROLES.map(r => `<div class="flex items-start gap-2">
          <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full text-white shrink-0 mt-0.5" style="background:${ROLE_COLORS[r]}">${ROLE_LABELS[r] || r}</span>
          <span class="text-[11px] text-[var(--text-muted)]">${ROLE_PERMISSIONS[r]}</span>
        </div>`).join('')}
      </div>
    </div>`;

    el.innerHTML = legendHtml + `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl divide-y divide-[var(--border-subtle)]">
      ${data.map((eng: any) => {
        const name = eng.name || '?';
        const initials = name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
        const photoUrl = eng.photo_url;
        const roleColor = ROLE_COLORS[eng.role] || '#94A3B8';
        const roleLabel = ROLE_LABELS[eng.role] || eng.role;
        const startDate = eng.start_date ? new Date(eng.start_date + 'T12:00:00').toLocaleDateString('pt-BR', { month: 'short', year: 'numeric' }) : '';

        const actionBtns = canManage ? `
          <button data-action="change-role" data-person-id="${eng.person_id}" data-current-role="${eng.role}" data-kind="${eng.kind}"
            class="text-[10px] px-1.5 py-0.5 rounded bg-[var(--surface-hover)] text-[var(--text-secondary)] border-0 cursor-pointer hover:bg-[var(--surface-section-cool)] transition-all" title="Alterar papel">✏️</button>
          <button data-action="remove-member" data-person-id="${eng.person_id}" data-name="${escapeHtml(name)}"
            class="text-[10px] px-1.5 py-0.5 rounded bg-red-50 text-red-600 border-0 cursor-pointer hover:bg-red-100 transition-all" title="Remover">✕</button>` : '';

        return `<div class="flex items-center gap-3 px-4 py-3">
          ${photoUrl
            ? `<img src="${escapeHtml(photoUrl)}" class="w-9 h-9 rounded-xl object-cover" alt="">`
            : `<div class="w-9 h-9 rounded-xl flex items-center justify-center text-white font-bold text-sm" style="background:${roleColor}">${initials}</div>`}
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold text-[var(--text-primary)] truncate">${escapeHtml(name)}</div>
            <div class="text-xs text-[var(--text-muted)]">${escapeHtml(eng.kind_display || eng.kind.replace(/_/g, ' '))} ${startDate ? `· ${I18N.since || 'since'} ${startDate}` : ''}</div>
          </div>
          <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full text-white cursor-help" style="background:${roleColor}" title="${ROLE_PERMISSIONS[eng.role] || ''}">${escapeHtml(roleLabel)}</span>
          ${actionBtns}
        </div>`;
      }).join('')}
    </div>`;
  }

  // Board tab is mounted as an Astro island (InitiativeBoardWrapper) — no JS needed here

  // ── Gamification tab ──
  let gamificationLoaded = false;
  async function loadGamificationTab() {
    if (gamificationLoaded) return;
    const el = document.getElementById('panel-gamification');
    const sb = getSb();
    if (!el || !sb) return;

    const { data, error } = await sb.rpc('get_initiative_gamification', { p_initiative_id: INITIATIVE_ID });
    gamificationLoaded = true;

    if (error || !data || (!data.leaderboard?.length && !data.total_xp)) {
      el.innerHTML = `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-6 text-center text-sm text-[var(--text-muted)]">
        Gamificacao ainda sem dados. XP e badges serao computados conforme membros participam de eventos e entregas.
      </div>`;
      return;
    }

    const board = Array.isArray(data.leaderboard) ? data.leaderboard : [];
    const summaryHtml = `<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-4">
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-navy">${data.total_xp || 0}</div>
        <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">XP Total</div>
      </div>
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-purple">${data.avg_xp || 0}</div>
        <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">XP Medio</div>
      </div>
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-[var(--color-teal)]">${data.cert_count || 0}</div>
        <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">Certificacoes</div>
      </div>
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4 text-center">
        <div class="text-2xl font-extrabold text-amber-600">${board.length}</div>
        <div class="text-[10px] text-[var(--text-muted)] uppercase font-semibold">No Ranking</div>
      </div>
    </div>`;

    const rankHtml = board.length ? `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-4">
      <h4 class="text-xs font-bold text-[var(--text-secondary)] uppercase mb-2">Ranking XP</h4>
      <div class="space-y-1.5">${board.map((m: any, i: number) => {
        const medal = i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `${i + 1}.`;
        return `<div class="flex items-center gap-2">
          <span class="text-sm w-6 text-center">${medal}</span>
          <span class="text-[11px] font-medium text-[var(--text-primary)] flex-1 truncate">${escapeHtml(m.name?.split(' ').slice(0, 2).join(' ') || '?')}</span>
          <span class="text-xs font-bold text-navy">${m.xp || 0} XP</span>
        </div>`;
      }).join('')}</div>
    </div>` : '';

    el.innerHTML = summaryHtml + rankHtml;
  }

  // ── Deliverables tab ──
  let deliverablesLoaded = false;
  async function loadDeliverablesTab() {
    if (deliverablesLoaded) return;
    const el = document.getElementById('panel-deliverables');
    const sb = getSb();
    if (!el || !sb) return;

    const { data, error } = await sb.rpc('list_initiative_deliverables', {
      p_initiative_id: INITIATIVE_ID, p_cycle_code: null,
    });

    deliverablesLoaded = true;
    const items = Array.isArray(data) ? data : [];

    if (error || !items.length) {
      el.innerHTML = `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-6 text-center text-sm text-[var(--text-muted)]">
        Nenhuma entrega registrada ainda.
      </div>`;
      return;
    }

    const STATUS_COLORS: Record<string, { bg: string; text: string; label: string }> = {
      planned:     { bg: 'bg-gray-100', text: 'text-gray-600', label: 'Planejado' },
      in_progress: { bg: 'bg-blue-50', text: 'text-blue-700', label: 'Em Progresso' },
      completed:   { bg: 'bg-emerald-50', text: 'text-emerald-700', label: 'Concluido' },
      cancelled:   { bg: 'bg-red-50', text: 'text-red-600', label: 'Cancelado' },
    };

    // Summary counts
    const counts: Record<string, number> = {};
    items.forEach((d: any) => { counts[d.status] = (counts[d.status] || 0) + 1; });
    const summaryHtml = Object.entries(counts).map(([s, c]) => {
      const sc = STATUS_COLORS[s] || STATUS_COLORS.planned;
      return `<span class="text-xs font-semibold px-2 py-0.5 rounded-full ${sc.bg} ${sc.text}">${c} ${sc.label}</span>`;
    }).join(' ');

    el.innerHTML = `
      <div class="flex items-center gap-2 mb-3">${summaryHtml}</div>
      <div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl divide-y divide-[var(--border-subtle)]">
        ${items.map((d: any) => {
          const sc = STATUS_COLORS[d.status] || STATUS_COLORS.planned;
          const due = d.due_date ? new Date(d.due_date + 'T12:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' }) : '';
          return `<div class="flex items-center gap-3 px-4 py-3">
            <span class="w-2 h-2 rounded-full flex-shrink-0 ${sc.bg.replace('bg-', 'bg-').replace('-50', '-400').replace('-100', '-400')}"></span>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-semibold text-[var(--text-primary)] truncate">${escapeHtml(d.title)}</div>
              ${d.description ? `<div class="text-xs text-[var(--text-muted)] truncate">${escapeHtml(d.description)}</div>` : ''}
            </div>
            ${due ? `<span class="text-[10px] text-[var(--text-muted)]">📅 ${due}</span>` : ''}
            <span class="text-[10px] font-semibold px-2 py-0.5 rounded-full ${sc.bg} ${sc.text}">${sc.label}</span>
          </div>`;
        }).join('')}
      </div>`;
  }

  // ── Attendance tab ──
  let attendanceLoaded = false;
  async function loadAttendanceTab() {
    if (attendanceLoaded) return;
    const el = document.getElementById('panel-attendance');
    const sb = getSb();
    if (!el || !sb) return;

    const { data, error } = await sb.rpc('get_initiative_attendance_grid', {
      p_initiative_id: INITIATIVE_ID,
    });

    attendanceLoaded = true;

    if (error || !data || (!data.events?.length && !data.grid?.length)) {
      el.innerHTML = `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl p-6 text-center text-sm text-[var(--text-muted)]">
        Nenhum registro de presenca ainda. Crie eventos e registre presenca para ver a grade.
      </div>`;
      return;
    }

    const events = Array.isArray(data.events) ? data.events : [];
    const grid = Array.isArray(data.grid) ? data.grid : [];

    // Simple attendance grid
    const headerCells = events.map((e: any) => {
      const d = new Date(e.date + 'T12:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
      return `<th class="text-[10px] font-semibold text-[var(--text-muted)] px-2 py-1 text-center" title="${escapeHtml(e.title)}">${d}</th>`;
    }).join('');

    const rows = grid.map((m: any) => {
      const name = m.member_name || '?';
      const cells = (m.attendance || []).map((a: any) => {
        const icon = a.present ? '✅' : a.excused ? '🟡' : '❌';
        return `<td class="text-center px-2 py-1 text-xs">${icon}</td>`;
      }).join('');
      const rate = m.attendance_rate != null ? `${m.attendance_rate}%` : '';
      const rColor = (m.attendance_rate || 0) >= 75 ? 'text-emerald-600' : (m.attendance_rate || 0) >= 50 ? 'text-amber-600' : 'text-red-600';
      return `<tr class="border-b border-[var(--border-subtle)]">
        <td class="text-xs font-semibold text-[var(--text-primary)] px-3 py-2 truncate max-w-[120px]">${escapeHtml(name.split(' ').slice(0, 2).join(' '))}</td>
        ${cells}
        <td class="text-xs font-bold ${rColor} px-2 py-1 text-center">${rate}</td>
      </tr>`;
    }).join('');

    el.innerHTML = `<div class="bg-[var(--surface-card)] border border-[var(--border-default)] rounded-xl overflow-x-auto">
      <table class="w-full">
        <thead><tr class="border-b border-[var(--border-default)]">
          <th class="text-[10px] font-bold text-[var(--text-secondary)] px-3 py-2 text-left">Membro</th>
          ${headerCells}
          <th class="text-[10px] font-bold text-[var(--text-secondary)] px-2 py-1 text-center">%</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
    </div>`;
  }

  // ── Boot ──
  async function boot() {
    const sb = getSb();
    currentMember = (window as any).navGetMember?.();

    if (!sb || !currentMember) {
      window.addEventListener('nav:member', boot, { once: true });
      return;
    }

    if (!currentMember?.id) {
      // Not authenticated — show login wall
      document.getElementById('init-loading')?.classList.add('hidden');
      document.getElementById('init-denied')?.classList.remove('hidden');
      return;
    }

    // Fetch initiative detail
    const { data, error } = await sb.rpc('get_initiative_detail', { p_initiative_id: INITIATIVE_ID });
    if (error || !data || data.error) {
      document.getElementById('init-loading')?.classList.add('hidden');
      document.getElementById('init-not-found')?.classList.remove('hidden');
      return;
    }

    initData = data;
    kindConfig = data.kind_config;

    // Determine management permission
    canManage = currentMember.is_superadmin
      || ['manager', 'deputy_manager'].includes(currentMember.operational_role || '')
      || (data.user_engagement && data.user_engagement.role === 'leader');

    // Reveal shell
    document.getElementById('init-loading')?.classList.add('hidden');
    document.getElementById('init-shell')?.classList.remove('hidden');

    // Render UI
    renderHeader();
    renderStatusBanner();
    renderTabs();

    // Load initial tab data
    await loadGeneralTab();

    // Lazy-load other tabs on switch
    document.getElementById('init-tabs')?.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('.init-tab') as HTMLElement | null;
      if (!btn?.dataset.tab) return;
      const tab = btn.dataset.tab;
      if (tab === 'members') await loadMembersTab();
      if (tab === 'deliverables') await loadDeliverablesTab();
      if (tab === 'attendance') await loadAttendanceTab();
      if (tab === 'gamification') await loadGamificationTab();
    });

    // Action handlers (delegated)
    document.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      const action = target.dataset.action || target.closest('[data-action]')?.getAttribute('data-action');
      if (!action) return;

      if (action === 'create-event-prompt') {
        const title = prompt('Titulo do evento:');
        if (!title?.trim()) return;
        const dateStr = prompt('Data (YYYY-MM-DD):', new Date(Date.now() + 7 * 86400000).toISOString().slice(0, 10));
        if (!dateStr?.match(/^\d{4}-\d{2}-\d{2}$/)) { alert('Formato invalido. Use YYYY-MM-DD.'); return; }
        const timeStr = prompt('Horario de inicio (HH:MM):', '19:00');
        if (!timeStr?.match(/^\d{2}:\d{2}$/)) { alert('Formato invalido. Use HH:MM.'); return; }
        const durStr = prompt('Duracao em minutos:', '60');
        const duration = parseInt(durStr || '60', 10);
        const meetLink = prompt('Link da reuniao (opcional):', '') || null;

        const { data: evtResult, error: evtErr } = await sb.rpc('create_initiative_event', {
          p_initiative_id: INITIATIVE_ID,
          p_title: title.trim(),
          p_date: dateStr,
          p_time_start: timeStr + ':00',
          p_duration_minutes: duration,
          p_meeting_link: meetLink,
        });
        if (evtErr) { alert('Erro: ' + evtErr.message); return; }
        if (evtResult?.error) { alert(evtResult.error); return; }
        alert('Evento criado com sucesso!');
        window.location.reload();
      }

      if (action === 'activate-initiative') {
        if (!confirm('Ativar esta iniciativa? O status mudara de "draft" para "active".')) return;
        const { data: actResult, error: actErr } = await sb.rpc('activate_initiative', { p_initiative_id: INITIATIVE_ID });
        if (actErr) { alert('Erro: ' + actErr.message); return; }
        if (actResult?.error) { alert(actResult.error); return; }
        window.location.reload();
      }

      if (action === 'add-member-prompt') {
        const nameQuery = prompt('Digite o nome do membro para buscar:');
        if (!nameQuery?.trim()) return;
        // Search via public_members view (accessible to authenticated users)
        const { data: members, error: searchErr } = await sb
          .from('public_members')
          .select('id, name, operational_role, photo_url')
          .ilike('name', `%${nameQuery.trim()}%`)
          .eq('is_active', true)
          .limit(10);
        if (searchErr || !members?.length) { alert('Nenhum membro encontrado com "' + nameQuery + '"'); return; }

        // Show simple selection
        const list = members;
        const options = list.map((p: any, i: number) => `${i + 1}. ${p.name} (${p.operational_role || 'member'})`).join('\n');
        const choice = prompt('Selecione o numero:\n' + options);
        const idx = parseInt(choice || '0', 10) - 1;
        if (idx < 0 || idx >= list.length) return;

        const selected = list[idx];

        // Select role
        const roleOptions = AVAILABLE_ROLES.map((r, i) => `${i + 1}. ${ROLE_LABELS[r] || r}`).join('\n');
        const roleChoice = prompt('Selecione o papel:\n' + roleOptions + '\n(default: 3 = Participante)');
        const roleIdx = parseInt(roleChoice || '3', 10) - 1;
        const selectedRole = AVAILABLE_ROLES[roleIdx >= 0 && roleIdx < AVAILABLE_ROLES.length ? roleIdx : 2];

        // Resolve person_id from member_id
        const { data: pRow } = await sb.from('persons').select('id').eq('legacy_member_id', selected.id).maybeSingle();
        if (!pRow?.id) { alert('Pessoa nao encontrada no modelo V4. Contacte o admin.'); return; }

        const kindChoice = kindConfig?.allowed_engagement_kinds?.[0] || 'volunteer';
        const { data: result, error: engErr } = await sb.rpc('manage_initiative_engagement', {
          p_initiative_id: INITIATIVE_ID,
          p_person_id: pRow.id,
          p_kind: kindChoice,
          p_role: selectedRole,
          p_action: 'add',
        });
        if (engErr) { alert('Erro: ' + engErr.message); return; }
        if (result?.error) { alert(result.error); return; }
        alert(`${selected.name} adicionado(a) como ${ROLE_LABELS[selectedRole] || selectedRole}!`);
        await loadMembersTab();
        switchTab('members');
      }

      if (action === 'change-role') {
        const btn = (target.closest('[data-person-id]') || target) as HTMLElement;
        const personId = btn.dataset.personId;
        const currentRole = btn.dataset.currentRole || '';
        const engKind = btn.dataset.kind || '';
        if (!personId) return;

        const roleOptions = AVAILABLE_ROLES.map((r, i) => `${i + 1}. ${ROLE_LABELS[r] || r}${r === currentRole ? ' (atual)' : ''}`).join('\n');
        const roleChoice = prompt('Alterar papel para:\n' + roleOptions);
        const roleIdx = parseInt(roleChoice || '0', 10) - 1;
        if (roleIdx < 0 || roleIdx >= AVAILABLE_ROLES.length) return;
        const newRole = AVAILABLE_ROLES[roleIdx];
        if (newRole === currentRole) return;

        const { data: result, error: roleErr } = await sb.rpc('manage_initiative_engagement', {
          p_initiative_id: INITIATIVE_ID,
          p_person_id: personId,
          p_kind: engKind,
          p_role: newRole,
          p_action: 'update_role',
        });
        if (roleErr) { alert('Erro: ' + roleErr.message); return; }
        if (result?.error) { alert(result.error); return; }
        await loadMembersTab();
      }

      if (action === 'remove-member') {
        const btn = (target.closest('[data-person-id]') || target) as HTMLElement;
        const personId = btn.dataset.personId;
        const memberName = btn.dataset.name || '';
        if (!personId) return;
        if (!confirm(`Remover ${memberName} desta iniciativa?`)) return;

        const { data: result, error: rmErr } = await sb.rpc('manage_initiative_engagement', {
          p_initiative_id: INITIATIVE_ID,
          p_person_id: personId,
          p_kind: '',
          p_role: '',
          p_action: 'remove',
        });
        if (rmErr) { alert('Erro: ' + rmErr.message); return; }
        if (result?.error) { alert(result.error); return; }
        await loadMembersTab();
      }

      // Minutes editor: open-minutes-editor buttons
      if (action === 'open-minutes-editor') {
        const btn = (target.closest('[data-action="open-minutes-editor"]') || target) as HTMLElement;
        window.dispatchEvent(new CustomEvent('open-event-editor', {
          detail: {
            eventId: btn.dataset.eventId,
            eventTitle: btn.dataset.eventTitle,
            mode: btn.dataset.mode || 'minutes',
            initialContent: btn.dataset.content || '',
            initialUrl: '',
          },
        }));
      }
    });

    // Refresh timeline after minutes save
    window.addEventListener('event-editor-saved', () => {
      loadGeneralTab();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
