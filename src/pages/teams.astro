---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);

const i18nClient = {
  tribeFallback: t('teams.tribeFallback', lang),
  tribeTypeOperational: t('teams.tribeTypeOperational', lang),
  tribeTypeResearch: t('teams.tribeTypeResearch', lang),
  tribeTypeSubproject: t('teams.tribeTypeSubproject', lang),
  activeResearchFallback: t('teams.activeResearchFallback', lang),
  emptyActive: t('teams.emptyActive', lang),
  emptyOperational: t('teams.emptyOperational', lang),
  emptyLegacy: t('teams.emptyLegacy', lang),
};
---

<BaseLayout title={t('nav.exploreTribes', lang)} activePage="projects" lang={lang}>
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <header class="mb-6">
      <h1 class="text-2xl font-extrabold text-[var(--text-primary)]">{t('teams.title', lang)}</h1>
      <p class="text-sm text-[var(--text-secondary)] mt-1">{t('teams.subtitle', lang)}</p>
    </header>

    <div id="teams-loading" class="text-center py-10 text-[var(--text-muted)]">{t('common.loading', lang)}</div>
    <div id="teams-denied" class="hidden rounded-2xl border border-amber-200 bg-amber-50 dark:bg-amber-900/30 p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">{t('teams.accessDenied', lang)}</p>
    </div>

    <div id="teams-shell" class="hidden space-y-6">
      <section class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5">
        <h2 class="text-sm font-bold text-[var(--text-primary)] mb-3">{t('teams.activeSection', lang)}</h2>
        <div id="teams-active" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>

      <section class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5">
        <h2 class="text-sm font-bold text-[var(--text-primary)] mb-3">{t('teams.operationalSection', lang)}</h2>
        <div id="teams-operational" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>

      <section class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5">
        <h2 class="text-sm font-bold text-[var(--text-primary)] mb-3">{t('teams.legacySection', lang)}</h2>
        <div id="teams-legacy" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>
    </div>
  </div>
</BaseLayout>

<script type="application/json" id="i18n-teams" set:html={JSON.stringify(i18nClient)}></script>

<script>
  import { canExploreTribes } from '../lib/tribes/access';
  import { buildTribeLabel } from '../lib/tribes/catalog';

  const i18nNode = document.getElementById('i18n-teams');
  const i18n = JSON.parse(i18nNode!.textContent || '{}');

  let sb: any = null;
  let member: any = null;

  function cardHtml(title: string, subtitle: string, href: string, readonly = false): string {
    const lock = readonly ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-[var(--surface-base)] text-[var(--text-secondary)]">READ ONLY</span>' : '';
    return `<a href="${href}" class="rounded-xl border border-[var(--border-default)] p-4 no-underline hover:border-[var(--border-strong)] hover:shadow-sm transition-all">
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-sm font-bold text-[var(--text-primary)]">${title}</h3>
        ${lock}
      </div>
      <p class="text-[12px] text-[var(--text-secondary)] mt-1">${subtitle}</p>
    </a>`;
  }

  function showDenied() {
    document.getElementById('teams-loading')?.classList.add('hidden');
    document.getElementById('teams-shell')?.classList.add('hidden');
    document.getElementById('teams-denied')?.classList.remove('hidden');
  }

  function showShell() {
    document.getElementById('teams-loading')?.classList.add('hidden');
    document.getElementById('teams-denied')?.classList.add('hidden');
    document.getElementById('teams-shell')?.classList.remove('hidden');
  }

  function renderBlock(targetId: string, cards: string[], emptyText: string) {
    const el = document.getElementById(targetId);
    if (!el) return;
    el.innerHTML = cards.length
      ? cards.join('')
      : `<div class="rounded-xl border border-dashed border-[var(--border-default)] p-5 text-sm text-[var(--text-muted)]">${emptyText}</div>`;
  }

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function legacyCycleHtml(cycleCode: string, cycleLabel: string, rows: any[]): string {
    const cards = rows.map((r: any) => {
      const leader = r.leader_name ? `👤 ${escapeHtml(r.leader_name)}` : '';
      const members = r.member_count > 0 ? ` · 👥 ${r.member_count}` : '';
      const typeLabel = r.tribe_type === 'operational' ? i18n.tribeTypeOperational : i18n.tribeTypeResearch;
      return cardHtml(
        escapeHtml(r.tribe_name || i18n.tribeFallback),
        `${escapeHtml(typeLabel)} · ${leader}${members}`,
        '#',
        true
      );
    }).join('');
    return `<div class="mb-4">
      <h3 class="text-[13px] font-bold text-[var(--text-secondary)] mb-2">${escapeHtml(cycleLabel)}</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3">${cards}</div>
    </div>`;
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    member = (window as any).navGetMember?.();

    if (!sb || !member) {
      window.addEventListener('nav:member', () => boot(), { once: true });
      return;
    }

    if (!canExploreTribes(member)) {
      showDenied();
      return;
    }

    showShell();

    const { data: dim } = await sb.from('cycle_tribe_dim').select('*').order('dim_id');
    const rows = dim || [];

    const c3Research = rows.filter((r: any) => r.cycle_code === 'cycle_3' && r.tribe_type === 'research' && r.is_active);
    const active = c3Research.map((r: any) => cardHtml(
      `T${r.tribe_number}: ${r.tribe_name}`,
      r.quadrant_name || i18n.activeResearchFallback,
      `/tribe/${r.tribe_number}`
    ));

    const c3Ops = rows.filter((r: any) => r.cycle_code === 'cycle_3' && (r.tribe_type === 'operational' || r.tribe_type === 'subproject'));
    const operational = c3Ops.map((r: any) => {
      const href = r.tribe_name === 'Webinars' ? '/webinars'
        : r.tribe_name === 'Comitê de Curadoria' ? '/admin/curatorship'
        : r.tribe_name === 'Hub de Comunicação' ? '/admin/comms-ops'
        : '#';
      const typeLabel = r.tribe_type === 'subproject' ? i18n.tribeTypeSubproject : i18n.tribeTypeOperational;
      return cardHtml(r.tribe_name, `${r.leader_name || '—'} · ${typeLabel}`, href);
    });

    const CYCLE_LABELS: Record<string, string> = {
      pilot: 'Piloto (2024)',
      cycle_1: 'Ciclo 1 (2025/1)',
      cycle_2: 'Ciclo 2 (2025/2)',
    };
    const legacyCycles = ['cycle_1', 'cycle_2'];
    const legacyHtml = legacyCycles.map(cc => {
      const cycleRows = rows.filter((r: any) => r.cycle_code === cc);
      return cycleRows.length ? legacyCycleHtml(cc, CYCLE_LABELS[cc] || cc, cycleRows) : '';
    }).filter(Boolean).join('');

    renderBlock('teams-active', active, i18n.emptyActive);
    renderBlock('teams-operational', operational, i18n.emptyOperational);

    const legacyEl = document.getElementById('teams-legacy');
    if (legacyEl) {
      legacyEl.innerHTML = legacyHtml || `<div class="rounded-xl border border-dashed border-[var(--border-default)] p-5 text-sm text-[var(--text-muted)]">${i18n.emptyLegacy}</div>`;
    }
  }

  boot();
</script>
