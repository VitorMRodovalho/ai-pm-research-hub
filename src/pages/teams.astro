---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('nav.exploreTribes', lang)} activePage="projects">
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <header class="mb-6">
      <h1 class="text-2xl font-extrabold text-navy dark:text-slate-100">Projetos e Frentes</h1>
      <p class="text-sm text-slate-500 dark:text-slate-300 mt-1">Navegação única de Ativas, Subprojetos operacionais e Legado para consulta histórica.</p>
    </header>

    <div id="teams-loading" class="text-center py-10 text-slate-400">Carregando projetos...</div>
    <div id="teams-denied" class="hidden rounded-2xl border border-amber-200 bg-amber-50 dark:bg-amber-900/30 p-6 text-center">
      <div class="text-2xl mb-2">🔒</div>
      <p class="font-semibold text-amber-800">Acesso restrito a membros ativos da plataforma.</p>
    </div>

    <div id="teams-shell" class="hidden space-y-6">
      <section class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-5">
        <h2 class="text-sm font-bold text-navy dark:text-slate-100 mb-3">🟢 Ativas (Pesquisa)</h2>
        <div id="teams-active" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>

      <section class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-5">
        <h2 class="text-sm font-bold text-navy dark:text-slate-100 mb-3">⚙️ Subprojetos (Operação)</h2>
        <div id="teams-operational" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>

      <section class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-5">
        <h2 class="text-sm font-bold text-navy dark:text-slate-100 mb-3">🏛️ Legado (Read-only)</h2>
        <div id="teams-legacy" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  import { canExploreTribes } from '../lib/tribes/access';
  import { buildTribeLabel } from '../lib/tribes/catalog';

  let sb: any = null;
  let member: any = null;

  function cardHtml(title: string, subtitle: string, href: string, readonly = false): string {
    const lock = readonly ? '<span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-slate-100 text-slate-500">READ ONLY</span>' : '';
    return `<a href="${href}" class="rounded-xl border border-slate-200 dark:border-slate-700 p-4 no-underline hover:border-slate-300 dark:hover:border-slate-600 hover:shadow-sm transition-all">
      <div class="flex items-start justify-between gap-2">
        <h3 class="text-sm font-bold text-navy dark:text-slate-100">${title}</h3>
        ${lock}
      </div>
      <p class="text-[12px] text-slate-500 dark:text-slate-300 mt-1">${subtitle}</p>
    </a>`;
  }

  function showDenied() {
    document.getElementById('teams-loading')?.classList.add('hidden');
    document.getElementById('teams-shell')?.classList.add('hidden');
    document.getElementById('teams-denied')?.classList.remove('hidden');
  }

  function showShell() {
    document.getElementById('teams-loading')?.classList.add('hidden');
    document.getElementById('teams-denied')?.classList.add('hidden');
    document.getElementById('teams-shell')?.classList.remove('hidden');
  }

  function renderBlock(targetId: string, cards: string[], emptyText: string) {
    const el = document.getElementById(targetId);
    if (!el) return;
    el.innerHTML = cards.length
      ? cards.join('')
      : `<div class="rounded-xl border border-dashed border-slate-200 dark:border-slate-700 p-5 text-sm text-slate-400 dark:text-slate-500">${emptyText}</div>`;
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    member = (window as any).navGetMember?.();

    if (!sb || !member) {
      window.addEventListener('nav:member', () => boot(), { once: true });
      return;
    }

    if (!canExploreTribes(member)) {
      showDenied();
      return;
    }

    showShell();

    const [{ data: tribes }, { data: legacyTribes }, { data: lineage }] = await Promise.all([
      sb.from('tribes').select('id, name, quadrant_name, is_active, workstream_type').order('id'),
      sb.from('legacy_tribes').select('id, legacy_key, display_name, cycle_label, quadrant, tribe_id, status, notes').order('id'),
      sb.from('tribe_lineage').select('legacy_tribe_id, current_tribe_id, relation_type, cycle_scope, notes').eq('is_active', true),
    ]);

    const lineageMap: Record<number, { currentId: number; note: string }> = {};
    (lineage || []).forEach((l: any) => {
      lineageMap[l.legacy_tribe_id] = { currentId: l.current_tribe_id, note: l.notes || '' };
    });
    const tribeNameMap: Record<number, string> = {};
    (tribes || []).forEach((t: any) => { tribeNameMap[t.id] = t.name; });

    const active = (tribes || [])
      .filter((tribe: any) => tribe.is_active !== false && String(tribe.workstream_type || 'research') === 'research')
      .map((tribe: any) => cardHtml(
        buildTribeLabel(tribe, { prefix: 'Tribo' }),
        tribe.quadrant_name || 'Pesquisa ativa do ciclo',
        `/tribe/${tribe.id}`
      ));

    const operational = (tribes || [])
      .filter((tribe: any) => String(tribe.workstream_type || '') === 'operational')
      .map((tribe: any) => cardHtml(
        buildTribeLabel(tribe, { prefix: 'Tribo' }),
        'Subprojeto operacional contínuo',
        `/tribe/${tribe.id}`
      ));

    const webinars = cardHtml(
      'Webinars',
      'Funil operacional de eventos e publicação de replays',
      '/webinars'
    );
    operational.unshift(webinars);

    const legacy = (legacyTribes || []).map((tribe: any) => {
      const currentTribeId = tribe.tribe_id;
      const successor = currentTribeId ? tribeNameMap[currentTribeId] : null;
      const cycleTag = tribe.cycle_label || '';
      const subtitle = successor
        ? `${cycleTag} · Continuou como T${currentTribeId}: ${successor}`
        : `${cycleTag} · ${tribe.notes || 'Consulta histórica'}`;
      return cardHtml(
        tribe.display_name || 'Tribo histórica',
        subtitle,
        currentTribeId ? `/tribe/${currentTribeId}` : '/#tribes',
        true
      );
    });

    renderBlock('teams-active', active, 'Sem tribos ativas cadastradas.');
    renderBlock('teams-operational', operational, 'Sem subprojetos operacionais cadastrados.');
    renderBlock('teams-legacy', legacy, 'Sem tribos legadas registradas.');
  }

  boot();
</script>
