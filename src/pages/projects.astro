---
import BaseLayout from '../layouts/BaseLayout.astro';
import PilotsIsland from '../components/islands/PilotsIsland';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);

const PILOTS_I18N: Record<string, string> = {
  loading: t('common.loading', lang),
  subtitle: t('pilots.subtitle', lang),
  progress: t('pilots.progress', lang),
  active: t('pilots.active', lang),
  draft: t('pilots.draft', lang),
  completed: t('pilots.completed', lang),
  planning: t('projects.statusPlanning', lang),
  hypothesis: t('pilots.hypothesis', lang),
  problem: t('pilots.problem', lang),
  scope: t('pilots.scope', lang),
  team: t('pilots.team', lang),
  metrics: t('pilots.metrics', lang),
  timeline: t('pilots.timeline', lang),
  lessons: t('pilots.lessons', lang),
  viewDetails: t('pilots.viewDetails', lang),
  tbd: t('pilots.tbd', lang),
  register: t('pilots.register', lang),
  metricName: t('pilots.metricName', lang),
  metricCurrent: t('pilots.metricCurrent', lang),
};
---

<BaseLayout title={t('pilots.title', lang)} activePage="projects">
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-teal mb-2">
      {t('projects.label', lang)}
    </div>
    <h1 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-2 text-navy">
      {t('pilots.title', lang)}
    </h1>
    <p class="text-base text-[var(--text-secondary)] max-w-[700px] mb-8">
      {t('pilots.subtitle', lang)}
    </p>

    <PilotsIsland client:load i18n={PILOTS_I18N} />
  </div>
</BaseLayout>
