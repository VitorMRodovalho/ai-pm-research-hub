---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('projects.title', lang)} activePage="projects">
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-teal mb-2">
      {t('projects.label', lang)}
    </div>
    <h1 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-2 text-navy">
      {t('projects.title', lang)}
    </h1>
    <p class="text-base text-[var(--text-secondary)] max-w-[700px] mb-8" id="projects-subtitle">
      {t('projects.subtitle', lang)}
    </p>

    <div id="projects-loading" class="text-[var(--text-muted)] text-sm py-8 text-center">
      {t('common.loading', lang)}
    </div>

    <div id="projects-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    </div>

    <div id="projects-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-3">🚀</div>
      <p class="text-[var(--text-secondary)] text-sm">{t('projects.noPilots', lang)}</p>
    </div>

    <!-- Admin: register pilot button (hidden by default, shown via JS for admins) -->
    <div id="projects-admin-actions" class="hidden mt-8 text-center">
      <button id="btn-register-pilot" class="px-4 py-2 rounded-lg bg-teal text-white text-sm font-semibold hover:bg-teal/90 transition-colors">
        {t('projects.registerPilot', lang)}
      </button>
    </div>
  </div>
</BaseLayout>

<!-- Hidden i18n texts for JS -->
<span id="i18n-active" class="hidden">{t('projects.statusActive', lang)}</span>
<span id="i18n-completed" class="hidden">{t('projects.statusCompleted', lang)}</span>
<span id="i18n-planning" class="hidden">{t('projects.statusPlanning', lang)}</span>
<span id="i18n-demo" class="hidden">{t('projects.demo', lang)}</span>
<span id="i18n-github" class="hidden">{t('projects.github', lang)}</span>
<span id="i18n-lead" class="hidden">{t('projects.lead', lang)}</span>
<span id="i18n-placeholder-title" class="hidden">{t('projects.placeholderTitle', lang)}</span>
<span id="i18n-placeholder-desc" class="hidden">{t('projects.placeholderDesc', lang)}</span>

<script>
  import { getSupabase } from '../lib/supabase';

  (async () => {
    // Wait for Nav runtime config
    await new Promise<void>((resolve) => {
      if ((window as any).__PUBLIC_SUPABASE_URL) { resolve(); return; }
      const observer = new MutationObserver(() => {
        if ((window as any).__PUBLIC_SUPABASE_URL) { observer.disconnect(); resolve(); }
      });
      observer.observe(document.documentElement, { childList: true, subtree: true });
      setTimeout(() => { observer.disconnect(); resolve(); }, 3000);
    });

    let sb: ReturnType<typeof getSupabase>;
    try { sb = getSupabase(); } catch { return; }

    const loading = document.getElementById('projects-loading');
    const grid = document.getElementById('projects-grid');
    const empty = document.getElementById('projects-empty');
    const subtitle = document.getElementById('projects-subtitle');
    if (!loading || !grid || !empty) return;

    const i18n = (id: string) => document.getElementById(id)?.textContent || '';

    try {
      const { data: pilots, error } = await sb
        .from('ia_pilots')
        .select('id, title, description, objectives, technologies, status, start_date, end_date, results_summary, impact_metrics, github_url, demo_url, lead_member_id')
        .in('status', ['active', 'completed', 'planning'])
        .order('start_date', { ascending: true });

      loading.classList.add('hidden');

      if (error || !pilots || pilots.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      // Update subtitle with progress
      const activeCount = pilots.filter((p: any) => p.status === 'active' || p.status === 'completed').length;
      if (subtitle) {
        subtitle.textContent = subtitle.textContent?.replace(/\d+\/\d+/, `${activeCount}/3`) || subtitle.textContent || '';
      }

      const STATUS_BADGES: Record<string, { label: string; color: string }> = {
        active: { label: i18n('i18n-active') || 'Ativo', color: 'bg-emerald-100 text-emerald-800' },
        completed: { label: i18n('i18n-completed') || 'Concluído', color: 'bg-blue-100 text-blue-800' },
        planning: { label: i18n('i18n-planning') || 'Planejamento', color: 'bg-amber-100 text-amber-800' },
      };

      // Render pilot cards + placeholder cards up to 3
      const totalSlots = Math.max(3, pilots.length);
      let html = '';

      for (let i = 0; i < totalSlots; i++) {
        const p = pilots[i];
        if (p) {
          const badge = STATUS_BADGES[p.status] || STATUS_BADGES.planning;
          const techChips = (p.technologies || [])
            .map((t: string) => `<span class="inline-block px-2 py-0.5 rounded-full text-[.65rem] bg-[var(--surface-hover)] text-[var(--text-secondary)] mr-1 mb-1">${t}</span>`)
            .join('');
          const objectives = (p.objectives || [])
            .map((o: string) => `<li class="flex items-start gap-1.5"><span class="text-teal mt-0.5">✓</span><span>${o}</span></li>`)
            .join('');
          const links = [
            p.demo_url ? `<a href="${p.demo_url}" target="_blank" rel="noopener" class="text-teal hover:underline text-xs">${i18n('i18n-demo') || 'Demo'} →</a>` : '',
            p.github_url ? `<a href="${p.github_url}" target="_blank" rel="noopener" class="text-teal hover:underline text-xs">${i18n('i18n-github') || 'GitHub'} →</a>` : '',
          ].filter(Boolean).join(' · ');

          html += `
            <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-5 shadow-sm hover:-translate-y-px hover:shadow-md transition-all duration-200">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-extrabold text-navy">${p.title}</h3>
                <span class="px-2 py-0.5 rounded-full text-[.6rem] font-bold ${badge.color}">${badge.label}</span>
              </div>
              <p class="text-[.78rem] text-[var(--text-secondary)] mb-3">${p.description || ''}</p>
              ${techChips ? `<div class="mb-3">${techChips}</div>` : ''}
              ${objectives ? `<ul class="text-[.75rem] text-[var(--text-secondary)] space-y-1 mb-3">${objectives}</ul>` : ''}
              ${links ? `<div class="mt-3 pt-3 border-t border-[var(--border-default)]">${links}</div>` : ''}
            </div>
          `;
        } else {
          html += `
            <div class="bg-[var(--surface-card)] rounded-2xl border border-dashed border-[var(--border-default)] p-5 flex flex-col items-center justify-center min-h-[200px] opacity-60">
              <div class="text-3xl mb-2">🔮</div>
              <div class="text-sm font-bold text-[var(--text-muted)]">${i18n('i18n-placeholder-title') || 'Em planejamento'}</div>
              <div class="text-xs text-[var(--text-muted)] mt-1">${i18n('i18n-placeholder-desc') || `Q${i + 1} 2026`}</div>
            </div>
          `;
        }
      }

      grid.innerHTML = html;
      grid.classList.remove('hidden');

      // Show admin actions for GP/DM
      const member = (window as any).navGetMember?.();
      if (member) {
        const role = String(member.operational_role || '');
        if (member.is_superadmin || ['manager', 'deputy_manager'].includes(role)) {
          document.getElementById('projects-admin-actions')?.classList.remove('hidden');
        }
      }

    } catch (err) {
      console.warn('Projects load error:', err);
      loading.classList.add('hidden');
      empty.classList.remove('hidden');
    }
  })();
</script>
