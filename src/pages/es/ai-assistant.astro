---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';
const lang = 'es-LATAM' as const;
---
<BaseLayout title={t('assistant.meta', lang)} activePage="" lang={lang}>
  <meta http-equiv="refresh" content="0;url=/ai-assistant?lang=es-LATAM">
  <div class="flex items-center justify-center min-h-[60vh]">
    <p class="text-slate-400 text-sm">{t('common.loading', lang)}</p>
  </div>
</BaseLayout>
