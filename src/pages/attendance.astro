---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import KpiBar from '../components/attendance/KpiBar.astro';
import NewEventModal from '../components/attendance/NewEventModal.astro';
import RecurringModal from '../components/attendance/RecurringModal.astro';
import EditEventModal from '../components/attendance/EditEventModal.astro';
import RosterModal from '../components/attendance/RosterModal.astro';
import LoadingSkeleton from '../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { buildPageI18n } from '../i18n/pageI18n';
import AttendanceGridTab from '../components/attendance/AttendanceGridTab';
import EventMinutesIsland from '../components/events/EventMinutesIsland';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
const i18nBundle = buildPageI18n(['attendance', 'meetings', 'comp.common', 'comp.attendance', 'common'], lang);
---

<BaseLayout title={t('attendance.meta', lang)} activePage="attendance" lang={lang}>
  <Toast />

  <!-- AUTH GATE (hidden by default, shown only if no session) -->
  <div id="auth-gate" class="hidden items-center justify-center min-h-screen bg-[var(--surface-base)]">
    <div class="bg-[var(--surface-card)] rounded-2xl p-9 max-w-[360px] w-full text-center border border-[var(--border-default)]">
      <div class="text-4xl mb-3">⏱️</div>
      <h2 class="text-navy font-bold text-xl mb-2">{t('attendance.authTitle', lang)}</h2>
      <p class="text-[var(--text-secondary)] text-sm mb-6">{t('attendance.authDesc', lang)}</p>
      <button id="attendance-auth-btn"
              class="w-full py-3 rounded-lg bg-navy text-white font-semibold text-sm border-0 cursor-pointer hover:bg-navy/90 transition-colors"
              data-action="open-auth">
        {t('attendance.authBtn', lang)}
      </button>
      <p id="auth-not-found-msg" class="hidden mt-4 text-[13px] text-amber-700">
        {t('guest.notRegistered', lang)} {t('guest.contactAdmin', lang)}
        <br />
        <a href={`mailto:${t('guest.contactEmail', lang)}`} class="text-amber-800 font-semibold underline">{t('guest.contactEmail', lang)}</a>
      </p>
    </div>
  </div>

  <!-- LOADING STATE -->
  <div id="loading-gate" class="flex items-center justify-center min-h-[60vh]">
    <p class="text-[var(--text-muted)] text-sm">{t('attendance.loading', lang)}</p>
  </div>

  <!-- APP (hidden until auth) -->
  <div id="app" class="hidden">
    <KpiBar />

    <main class="max-w-[1100px] mx-auto px-4 py-6">
      <!-- Tabs -->
      <div class="flex gap-2 mb-5 flex-wrap">
        <button class="tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
                data-tab="events" data-action="switch-tab">
          {t('attendance.events', lang)}
        </button>
        <button class="tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                data-tab="ranking" data-action="switch-tab">
          {t('attendance.ranking', lang)}
        </button>
        <button class="tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                data-tab="grid" data-action="switch-tab">
          📊 Quadro de Presença
        </button>
        <button class="hidden tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                id="tab-new-event" data-action="open-new-event">
          {t('attendance.newEvent', lang)}
        </button>
        <button class="hidden tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-[var(--border-default)] bg-[var(--surface-card)] text-[var(--text-secondary)] transition-all"
                id="tab-recurring" data-action="open-recurring">
          {t('attendance.recurring', lang)}
        </button>
        <a href={`${langPrefix}/meetings`} class="ml-auto px-4 py-2 rounded-full text-[13px] font-semibold no-underline border-2 border-teal-500/30 bg-teal-50 dark:bg-teal-950/20 text-teal-700 dark:text-teal-300 hover:bg-teal-100 dark:hover:bg-teal-900/30 transition-all">
          📝 {t('nav.meetings', lang)}
        </a>
      </div>

      <!-- Events tab -->
      <div id="tab-events">
        <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
          <div class="px-5 py-3.5 border-b border-[var(--border-default)] flex items-center justify-between">
            <h3 class="text-sm font-bold text-navy">{t('attendance.eventsTitle', lang)}</h3>
            <button class="px-3 py-1.5 rounded-lg text-[12px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--surface-hover)] cursor-pointer"
                    data-action="refresh-events">{t('attendance.refresh', lang)}</button>
          </div>
          <div class="px-5 py-4 border-b border-[var(--border-subtle)]">
            <div class="flex gap-3 flex-wrap items-center">
              <select id="events-type-filter"
                class="px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm text-[var(--text-primary)] focus:outline-none focus:border-navy">
                <option value="todos">Todos os tipos</option>
              </select>
              <select id="events-tribe-filter" class="hidden px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm text-[var(--text-primary)] focus:outline-none focus:border-navy">
                <option value="">Todas as Tribos</option>
              </select>
              <input id="attendance-search" type="text"
                     class="flex-1 min-w-[200px] px-3 py-2 rounded-lg border border-[var(--border-default)] text-sm bg-[var(--surface-input)] focus:outline-none focus:border-navy transition-colors"
                     placeholder="🔍 Buscar evento..." />
            </div>
          </div>
          <div id="attendance-tag-filter" class="hidden px-5 py-2 border-b border-[var(--border-subtle)] flex gap-2 flex-wrap"></div>
          <div class="p-5" id="events-list">
            <LoadingSkeleton variant="row" count={3} />
          </div>
        </div>
      </div>

      <!-- Ranking tab -->
      <div id="tab-ranking" class="hidden">
        <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
          <div class="px-5 py-3.5 border-b border-[var(--border-default)] flex items-center justify-between flex-wrap gap-2">
            <h3 class="text-sm font-bold text-navy">{t('attendance.rankingTitle', lang)}</h3>
            <select id="ranking-role-filter"
              class="px-2 py-1.5 rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] text-[.75rem] text-[var(--text-primary)]">
              <option value="">{t('attendance.filterAllRoles', lang)}</option>
              <option value="manager">{t('attendance.role.manager', lang)}</option>
              <option value="deputy_manager">{t('attendance.role.deputy_manager', lang) || 'Deputy'}</option>
              <option value="tribe_leader">{t('attendance.role.tribe_leader', lang)}</option>
              <option value="comms_leader">{t('attendance.role.comms_leader', lang) || 'Líder de Comunicação'}</option>
              <option value="researcher">{t('attendance.role.researcher', lang)}</option>
              <option value="facilitator">{t('attendance.role.facilitator', lang)}</option>
              <option value="communicator">{t('attendance.role.communicator', lang)}</option>
            </select>
            <select id="ranking-designation-filter"
              class="px-2 py-1.5 rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] text-[.75rem] text-[var(--text-primary)]">
              <option value="">{t('attendance.filterAllDesignations', lang)}</option>
              <option value="ambassador">{t('attendance.role.ambassador', lang)}</option>
              <option value="founder">{t('attendance.role.founder', lang)}</option>
              <option value="chapter_liaison">{t('attendance.role.chapterLiaison', lang)}</option>
              <option value="curator">{t('attendance.role.curator', lang)}</option>
              <option value="sponsor">{t('attendance.role.sponsor', lang)}</option>
            </select>
          </div>
          <div class="p-5" id="ranking-list">
            <LoadingSkeleton variant="row" count={3} />
          </div>
        </div>
      </div>

      <!-- Grid tab -->
      <div id="tab-grid" class="hidden">
        <AttendanceGridTab client:load />
      </div>
      <EventMinutesIsland client:load />
    </main>
  </div>

  <!-- Modals -->
  <NewEventModal />
  <RecurringModal />
  <EditEventModal />
  <RosterModal />
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
</BaseLayout>

<script is:inline define:vars={{ __ATTENDANCE_I18N: JSON.stringify({
  loading: t('attendance.loading', lang),
  noEvents: t('attendance.noEvents', lang),
  hours: t('attendance.hours', lang),
  dateLocale: t('attendance.dateLocale', lang),
  roleManager: t('attendance.role.manager', lang),
  roleTribeLeader: t('attendance.role.tribe_leader', lang),
  roleResearcher: t('attendance.role.researcher', lang),
  roleFacilitator: t('attendance.role.facilitator', lang),
  roleCommunicator: t('attendance.role.communicator', lang),
  roleSponsor: t('attendance.role.sponsor', lang),
  roleAmbassador: t('attendance.role.ambassador', lang),
  roleCurator: t('attendance.role.curator', lang),
  roleFounder: t('attendance.role.founder', lang),
  roleGuest: t('attendance.role.guest', lang),
  eventTypeTribe: t('attendance.eventType.tribe', lang),
  eventTypeGeneral: t('attendance.eventType.general', lang),
  eventTypeWebinar: t('attendance.eventType.webinar', lang),
  eventTypeOther: t('attendance.eventType.other', lang),
  audienceLeadership: t('attendance.audience.leadership', lang),
  audienceTribe: t('attendance.audience.tribe', lang),
  audienceCurators: t('attendance.audience.curators', lang),
  badgeRecorded: t('attendance.badge.recorded', lang),
  emptyNewEvent: t('attendance.empty.newEvent', lang),
  emptyRefresh: t('attendance.empty.refresh', lang),
  emptyManagerHint: t('attendance.empty.managerHint', lang),
  emptyMemberHint: t('attendance.empty.memberHint', lang),
  eventJoin: t('attendance.event.join', lang),
  eventYoutube: t('attendance.event.youtube', lang),
  eventYoutubeSoon: t('attendance.event.youtubeSoon', lang),
  eventAttendees: t('attendance.event.attendees', lang),
  eventCheckIn: t('attendance.event.checkIn', lang),
  eventRosterTooltip: t('attendance.event.rosterTooltip', lang),
  eventEditTooltip: t('attendance.event.editTooltip', lang),
  msgCheckedIn: t('attendance.msg.checkedIn', lang),
  msgCheckInError: t('attendance.msg.checkInError', lang),
  msgFillTitleDate: t('attendance.msg.fillTitleDate', lang),
  msgEventCreated: t('attendance.msg.eventCreated', lang),
  msgEventCreateError: t('attendance.msg.eventCreateError', lang),
  msgFillTemplateDate: t('attendance.msg.fillTemplateDate', lang),
  msgEventsCreated: t('attendance.msg.eventsCreated', lang),
  msgRecurringError: t('attendance.msg.recurringError', lang),
  msgEventUpdated: t('attendance.msg.eventUpdated', lang),
  msgEventSaveError: t('attendance.msg.eventSaveError', lang),
  msgError: t('attendance.msg.error', lang),
  rosterLoading: t('attendance.roster.loading', lang),
  rosterNoParticipants: t('attendance.roster.noParticipants', lang),
  rosterCount: t('attendance.roster.count', lang),
  rosterVisible: t('attendance.modal.visible', lang),
  rankingNoData: t('attendance.ranking.noData', lang),
  rankingNoDataHint: t('attendance.ranking.noDataHint', lang),
  bulkSuccess: t('attendance.modal.bulkSuccess', lang),
  checkinWindowExpired: t('attendance.checkin.windowExpired', lang),
  checkinTooEarly: t('attendance.checkin.tooEarly', lang),
  feedbackCycleTotal: t('attendance.feedback.cycleTotal', lang),
  feedbackEvents: t('attendance.feedback.events', lang),
  windowClosed: t('attendance.windowClosed', lang),
  adminOverride: t('attendance.adminOverride', lang),
  deleteEvent: t('attendance.deleteEvent', lang),
  deleteConfirm: t('attendance.deleteConfirm', lang),
  deleteWarning: t('attendance.deleteWarning', lang),
  deleteSuccess: t('attendance.msg.deleteSuccess', lang),
  deleteForcePrompt: t('attendance.deleteForcePrompt', lang),
  deleteSuccessWithAttendance: t('attendance.msg.deleteSuccessWithAttendance', lang),
  recurrenceTitle: t('attendance.recurrence.title', lang),
  recurrenceThisOnly: t('attendance.recurrence.thisOnly', lang),
  recurrenceThisFuture: t('attendance.recurrence.thisFuture', lang),
  recurrencePrompt: t('attendance.recurrence.prompt', lang),
  recurrenceFutureUpdated: t('attendance.recurrence.futureUpdated', lang),
}) }}>
  window.__ATTENDANCE_I18N = JSON.parse(__ATTENDANCE_I18N);
</script>

<script>
  // ════════════════════════════════════════════════════════════════
  // ATTENDANCE PAGE — Client-side logic
  // Uses window.navGetSb() and nav:member event from Nav.astro
  // ════════════════════════════════════════════════════════════════

  import { hasMinimumTier, resolveTierFromMember } from '../lib/admin/constants';
  import { ROLE_LABELS, ROLE_COLORS } from '../lib/supabase';
  import { getMemberRole } from '../lib/routing';
  import { buildWebinarCommsHref, getAttendanceEditAssistantCopy, getAttendanceHandoffCopy } from '../lib/webinars/context-aids';
  import { marked } from 'marked';

  const I18N = (window as any).__ATTENDANCE_I18N || {
    loading: 'Carregando...',
    noEvents: 'Nenhum evento encontrado.',
    hours: 'horas',
    dateLocale: 'pt-BR',
    roleManager: 'Gerente de Projeto',
    roleTribeLeader: 'Líder de Tribo',
    roleResearcher: 'Pesquisador',
    roleFacilitator: 'Facilitador',
    roleCommunicator: 'Multiplicador',
    roleSponsor: 'Patrocinador',
    roleAmbassador: 'Embaixador',
    roleCurator: 'Curador',
    roleFounder: 'Fundador',
    roleGuest: 'Convidado',
    eventTypeTribe: 'Tribo',
    eventTypeGeneral: 'Geral',
    eventTypeWebinar: 'Webinar',
    eventTypeOther: 'Outro',
    audienceLeadership: '🏛️ Liderança',
    audienceTribe: '🔷 Tribo',
    audienceCurators: '📋 Curadoria',
    badgeRecorded: '● Gravada',
    emptyNewEvent: '+ Novo Evento',
    emptyRefresh: 'Atualizar',
    emptyManagerHint: 'Crie um evento para iniciar os registros de presença.',
    emptyMemberHint: 'Novos eventos aparecerão aqui assim que forem publicados.',
    eventJoin: '🎥 Entrar',
    eventYoutube: '▶ YouTube',
    eventYoutubeSoon: 'gravada · YouTube em breve',
    eventAttendees: 'presentes',
    eventCheckIn: 'Check-in',
    eventRosterTooltip: 'Lista de presença',
    eventEditTooltip: 'Editar evento',
    msgCheckedIn: 'Presença registrada! ✅',
    msgCheckInError: 'Erro ao registrar presença',
    msgFillTitleDate: 'Preencha título e data',
    msgEventCreated: 'Evento criado ✅',
    msgEventCreateError: 'Erro ao criar evento',
    msgFillTemplateDate: 'Preencha template e data de início',
    msgEventsCreated: '{n} eventos criados ✅',
    msgRecurringError: 'Erro ao criar série',
    msgEventUpdated: 'Evento atualizado ✅',
    msgEventSaveError: 'Erro ao salvar',
    msgError: 'Erro',
    rosterLoading: 'Carregando...',
    rosterNoParticipants: 'Nenhum participante encontrado.',
    rosterCount: '✅ {present}/{total} presentes',
    rosterVisible: 'visíveis',
    rankingNoData: 'Sem dados de ranking ainda',
    rankingNoDataHint: 'Quando os eventos tiverem presença registrada, o ranking aparecerá aqui.',
    recurrenceTitle: 'Evento recorrente',
    recurrenceThisOnly: 'Somente este evento',
    recurrenceThisFuture: 'Este e futuros',
    recurrencePrompt: 'Este evento faz parte de uma série recorrente. Aplicar alterações em:',
    recurrenceFutureUpdated: 'eventos atualizados na série.',
  };

  let sb: any = null;
  let MEMBER: any = null;
  let CAN_MANAGE = false;
  let CURRENT_EVENT_ID: string | null = null;
  let ALL_EVENTS: any[] = [];
  let ALL_TAGS: any[] = [];
  let ACTIVE_TAG_FILTER = '';
  let EVENT_TAG_MAP: Record<string, string[]> = {}; // event_id → tag_names[]
  let SHOW_INTERVIEWS = false;
  const PAGE_SIZE = 20;
  let VISIBLE_COUNT = PAGE_SIZE;
  const ATTENDANCE_ROUTE = {
    tab: 'events',
    query: '',
    type: '',
    eventId: '',
    action: '',
    edit: false,
    autoOpened: false,
    scrolled: false,
  };

  function escapeAttr(s: string): string {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  const ROLE_MAP: Record<string, { label: string; color: string; bg: string }> = {
    manager:      { label: I18N.roleManager,      color: '#003865', bg: '#EFF6FF' },
    tribe_leader: { label: I18N.roleTribeLeader,   color: '#065F46', bg: '#F0FDF4' },
    comms_leader: { label: I18N.roleCommsLeader || 'Líder de Comunicação', color: '#0E7490', bg: '#ECFEFF' },
    researcher:   { label: I18N.roleResearcher,    color: '#1E293B', bg: '#F1F5F9' },
    facilitator:  { label: I18N.roleFacilitator,   color: '#92400E', bg: '#FFF7ED' },
    communicator: { label: I18N.roleCommunicator,  color: '#6B21A8', bg: '#FAF5FF' },
    sponsor:      { label: I18N.roleSponsor,       color: '#BE2027', bg: '#FFF0F0' },
    ambassador:   { label: I18N.roleAmbassador,    color: '#0369A1', bg: '#E0F2FE' },
    curator:      { label: I18N.roleCurator,       color: '#78350F', bg: '#FEF3C7' },
    founder:      { label: I18N.roleFounder,       color: '#7C3AED', bg: '#EDE9FE' },
    guest:        { label: I18N.roleGuest,         color: '#6B7280', bg: '#F9FAFB' },
  };

  // ── HELPERS ──
  function roleBadges(roles: string[]): string {
    if (!roles?.length) return '';
    return roles.map(r => {
      const m = ROLE_MAP[r] || { label: r, color: '#6B7280', bg: '#F1F5F9' };
      return `<span style="display:inline-block;padding:2px 7px;border-radius:99px;font-size:10px;font-weight:700;color:${m.color};background:${m.bg};border:1px solid ${m.color}22;margin:1px">${m.label}</span>`;
    }).join('');
  }

  function rolesFromMember(member: any): string[] {
    if (!member) return [];
    const roles: string[] = [];
    const op = member.operational_role;
    if (op && op !== 'guest' && op !== 'none') roles.push(op);
    const desigs: string[] = Array.isArray(member.designations) ? member.designations : [];
    desigs.forEach((d) => {
      if (d && !roles.includes(d)) roles.push(d);
    });
    return roles.length ? roles : ['guest'];
  }

  function toast(msg: string, type = '') {
    (window as any).toast?.(msg, type);
  }

  function parseAttendanceRoute() {
    const params = new URLSearchParams(window.location.search);
    ATTENDANCE_ROUTE.tab = params.get('tab') === 'ranking' ? 'ranking' : 'events';
    ATTENDANCE_ROUTE.query = (params.get('q') || '').trim();
    ATTENDANCE_ROUTE.type = params.get('type') || '';
    ATTENDANCE_ROUTE.eventId = params.get('eventId') || '';
    ATTENDANCE_ROUTE.action = params.get('action') || '';
    ATTENDANCE_ROUTE.edit = params.get('edit') === '1';
    const searchInput = document.getElementById('attendance-search') as HTMLInputElement | null;
    const typeSelect = document.getElementById('events-type-filter') as HTMLSelectElement | null;
    if (searchInput) searchInput.value = ATTENDANCE_ROUTE.query;
    if (typeSelect) typeSelect.value = ATTENDANCE_ROUTE.type;
  }

  function loadingRows(count = 3): string {
    return Array.from({ length: count }).map(() => `
      <div class="flex items-center gap-3 px-1 py-3 border-b border-[var(--border-subtle)] last:border-b-0 animate-pulse">
        <div class="w-9 h-9 rounded-full bg-[var(--surface-section-cool)] flex-shrink-0"></div>
        <div class="flex-1 space-y-1.5">
          <div class="h-3 w-40 bg-[var(--surface-section-cool)] rounded"></div>
          <div class="h-2.5 w-56 bg-[var(--surface-section-cool)] rounded"></div>
        </div>
        <div class="h-5 w-14 rounded-full bg-[var(--surface-section-cool)]"></div>
      </div>
    `).join('');
  }

  function today(): string { return new Date().toISOString().slice(0, 10); }

  function fmtDate(d: string): string {
    if (!d) return '';
    return new Date(d + 'T12:00:00').toLocaleDateString(I18N.dateLocale, { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function renderAttendanceContext(filteredCount: number, totalCount: number) {
    const note = document.getElementById('attendance-context-note');
    const actions = document.getElementById('attendance-context-actions');
    if (!note || !actions) return;
    const hasContext = !!(ATTENDANCE_ROUTE.query || ATTENDANCE_ROUTE.type || ATTENDANCE_ROUTE.eventId || ATTENDANCE_ROUTE.action);
    if (!hasContext) {
      note.classList.add('hidden');
      note.innerHTML = '';
      actions.classList.add('hidden');
      actions.innerHTML = '';
      return;
    }
    const parts = [
      getAttendanceHandoffCopy(ATTENDANCE_ROUTE.action),
    ];
    if (ATTENDANCE_ROUTE.query) parts.push(`Filtro atual: "${escapeAttr(ATTENDANCE_ROUTE.query)}".`);
    if (ATTENDANCE_ROUTE.type) parts.push(`Tipo: ${escapeAttr(ATTENDANCE_ROUTE.type)}.`);
    if (filteredCount !== totalCount) parts.push(`Mostrando ${filteredCount} de ${totalCount} evento(s).`);
    note.innerHTML = parts.join(' ');
    note.classList.remove('hidden');

    const focused = currentFocusedEvent();
    const commsHref = focused ? buildWebinarCommsHref(ATTENDANCE_ROUTE, focused) : '';
    actions.innerHTML = `
      ${focused && CAN_MANAGE
        ? '<button type="button" class="px-3 py-1.5 rounded-lg bg-navy text-white text-[.72rem] font-semibold border-0 cursor-pointer hover:opacity-90" data-action="open-focused-edit">Editar webinar focado</button>'
        : ''}
      ${commsHref
        ? `<a href="${escapeAttr(commsHref)}" class="px-3 py-1.5 rounded-lg bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.72rem] font-semibold no-underline hover:bg-[var(--surface-hover)] transition-all">Abrir Comms contextual</a>`
        : ''}
      <button type="button" class="px-3 py-1.5 rounded-lg bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-primary)] text-[.72rem] font-semibold cursor-pointer hover:bg-[var(--surface-hover)]" data-action="clear-event-filters">Limpar contexto</button>
    `;
    actions.classList.remove('hidden');
  }

  function getTypeFilter(): string {
    return (document.getElementById('events-type-filter') as HTMLSelectElement)?.value || 'todos';
  }
  function getTribeFilter(): number | null {
    const v = (document.getElementById('events-tribe-filter') as HTMLSelectElement)?.value;
    return v ? parseInt(v, 10) : null;
  }

  function filteredEvents(): any[] {
    const query = ATTENDANCE_ROUTE.query.toLowerCase();
    const typeF = getTypeFilter();
    const tribeF = getTribeFilter();
    // debug: console.log('[FILTER] type:', typeF, 'tribe:', tribeF, 'query:', query, 'tagFilter:', ACTIVE_TAG_FILTER);
    const gp = isGPLevel();
    return ALL_EVENTS.filter((ev: any) => {
      // Participant override: user always sees events they participated in
      const isParticipant = ev.i_attended != null; // has attendance record
      // Visibility filtering (unless participant)
      if (!isParticipant && !gp) {
        if (ev.visibility === 'gp_only') return false;
        if ((ev.type === '1on1' || ev.type === 'parceria' || ev.type === 'entrevista' || ev.type === 'interview') && !CAN_MANAGE) return false;
      }
      if (ev.visibility === 'leadership' && !CAN_MANAGE && MEMBER?.operational_role !== 'tribe_leader' && !isParticipant) return false;
      // Type filter
      if (typeF !== 'todos' && ev.type !== typeF) return false;
      // Tribe filter (use == for type coercion: tribe_id may be string or number)
      if (tribeF && ev.tribe_id != tribeF) return false;
      // Tag filter
      if (ACTIVE_TAG_FILTER) {
        const evTags = EVENT_TAG_MAP[ev.id] || [];
        if (!evTags.includes(ACTIVE_TAG_FILTER)) return false;
      }
      // Search
      // Search filter
      if (query && !(ev.title || '').toLowerCase().includes(query) && !(ev.meeting_link || '').toLowerCase().includes(query)) return false;
      // Focus filter (deep-link to specific event)
      if (ATTENDANCE_ROUTE.eventId && ev.id !== ATTENDANCE_ROUTE.eventId) return false;
      return true;
    });
  }

  function currentFocusedEvent(): any | null {
    if (!ATTENDANCE_ROUTE.eventId) return null;
    return ALL_EVENTS.find((ev: any) => ev.id === ATTENDANCE_ROUTE.eventId) || null;
  }

  function maybeHandleFocusedEvent(events: any[]) {
    if (!ATTENDANCE_ROUTE.eventId) return;
    const focused = events.find((ev: any) => ev.id === ATTENDANCE_ROUTE.eventId);
    if (!focused) return;
    if (!ATTENDANCE_ROUTE.scrolled) {
      ATTENDANCE_ROUTE.scrolled = true;
      requestAnimationFrame(() => {
        document.getElementById(`attendance-event-${focused.id}`)?.scrollIntoView({ block: 'center', behavior: 'smooth' });
      });
    }
    if (ATTENDANCE_ROUTE.edit && CAN_MANAGE && !ATTENDANCE_ROUTE.autoOpened) {
      ATTENDANCE_ROUTE.autoOpened = true;
      openEditEvent(focused);
    }
  }

  function clearAttendanceFilters() {
    ATTENDANCE_ROUTE.query = '';
    ATTENDANCE_ROUTE.type = '';
    ATTENDANCE_ROUTE.eventId = '';
    ATTENDANCE_ROUTE.action = '';
    ATTENDANCE_ROUTE.edit = false;
    ATTENDANCE_ROUTE.autoOpened = true;
    ATTENDANCE_ROUTE.scrolled = true;
    VISIBLE_COUNT = PAGE_SIZE;
    const searchInput = document.getElementById('attendance-search') as HTMLInputElement | null;
    const typeSelect = document.getElementById('events-type-filter') as HTMLSelectElement | null;
    if (searchInput) searchInput.value = '';
    if (typeSelect) typeSelect.value = 'todos';
    renderEvents();
  }

  function applyEditContext(ev: any) {
    const box = document.getElementById('edit-ev-context');
    if (!box) return;
    if (ev.id !== ATTENDANCE_ROUTE.eventId || !ATTENDANCE_ROUTE.action) {
      box.classList.add('hidden');
      box.innerHTML = '';
      return;
    }
    if (ATTENDANCE_ROUTE.action === 'meeting-link') {
      box.innerHTML = getAttendanceEditAssistantCopy(ATTENDANCE_ROUTE.action);
      box.classList.remove('hidden');
      requestAnimationFrame(() => {
        (document.getElementById('edit-ev-link') as HTMLInputElement | null)?.focus();
      });
      return;
    }
    if (ATTENDANCE_ROUTE.action === 'youtube-url') {
      box.innerHTML = getAttendanceEditAssistantCopy(ATTENDANCE_ROUTE.action);
      box.classList.remove('hidden');
      requestAnimationFrame(() => {
        (document.getElementById('edit-ev-youtube') as HTMLInputElement | null)?.focus();
      });
      return;
    }
    box.classList.add('hidden');
    box.innerHTML = '';
  }

  // ── MODAL HELPERS ──
  function closeModal(id: string) {
    const el = document.getElementById(id);
    if (el) { el.classList.add('hidden'); el.classList.remove('flex'); }
  }

  function openModal(id: string) {
    const el = document.getElementById(id);
    if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
  }

  function rosterFilter(query: string) {
    const rows = document.querySelectorAll('#roster-body tr[data-name]') as NodeListOf<HTMLElement>;
    const q = query.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const name = row.dataset.name || '';
      const match = !q || name.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const countEl = document.getElementById('roster-count');
    if (countEl) {
      countEl.textContent = q ? `${visible}/${rows.length} ${I18N.rosterVisible}` : (countEl.dataset.full || '');
    }
  }

  // ── TABS ──
  function switchTab(el: HTMLElement, name: string) {
    document.querySelectorAll('.tab-btn').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-[var(--surface-card)]', 'text-[var(--text-secondary)]', 'border-[var(--border-default)]');
    });
    el.classList.remove('bg-[var(--surface-card)]', 'text-[var(--text-secondary)]', 'border-[var(--border-default)]');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    document.getElementById('tab-events')!.classList.toggle('hidden', name !== 'events');
    document.getElementById('tab-ranking')!.classList.toggle('hidden', name !== 'ranking');
    document.getElementById('tab-grid')!.classList.toggle('hidden', name !== 'grid');
    if (name === 'ranking') loadRanking();
  }

  // ── KPIs ──
  async function loadKPIs() {
    try {
      const { data } = await sb.from('impact_hours_total').select('*').single();
      if (!data) return;
      const hrs = Math.round(parseFloat(data.total_impact_hours || 0));
      const pct = parseFloat(data.percent_of_target || 0);
      const el = (id: string) => document.getElementById(id);
      el('kpi-hours')!.textContent = hrs + 'h';
      el('kpi-pct')!.textContent = pct + '%';
      el('kpi-events')!.textContent = data.total_events || '0';
      el('kpi-att')!.textContent = data.total_attendances || '0';
      const bar = el('kpi-bar')!;
      bar.style.width = Math.min(pct, 100) + '%';
      bar.className = 'h-full rounded-full transition-all duration-600 ' +
        (pct >= 70 ? 'bg-emerald-500' : pct >= 35 ? 'bg-yellow-500' : 'bg-red-500');
    } catch (e) {
      console.warn('Attendance: failed to load KPIs:', e);
      toast('Failed to load KPI data.', 'error');
    }
  }

  // ── EVENTS LIST ──
  function isGPLevel(): boolean {
    return MEMBER?.is_superadmin === true
      || ['manager'].includes(MEMBER?.operational_role || '')
      || (MEMBER?.designations || []).includes('deputy_manager');
  }

  function canAdminCheckin(): boolean {
    return isGPLevel() || MEMBER?.operational_role === 'tribe_leader';
  }

  function isInCheckinWindow(ev: any): boolean {
    if (!ev?.date) return false;
    const now = Date.now();
    const evStart = new Date(ev.date + 'T00:00:00').getTime();
    const windowOpen = evStart - 2 * 60 * 60 * 1000;   // -2h
    const windowClose = evStart + 24 * 60 * 60 * 1000;  // +24h
    return now >= windowOpen && now <= windowClose;
  }

  function populateTypeDropdown() {
    const sel = document.getElementById('events-type-filter') as HTMLSelectElement;
    if (!sel) return;
    // Remove old options except "Todos"
    while (sel.options.length > 1) sel.remove(1);
    // Determine which types the user can see
    const gp = isGPLevel();
    // Also check if user has participation in GP-only event types
    const participatedTypes = new Set(ALL_EVENTS.filter((ev: any) => ev.i_attended != null).map((ev: any) => ev.type));
    SECTION_ORDER.forEach(s => {
      if (s.gpOnly && !gp && !participatedTypes.has(s.type)) return;
      const opt = document.createElement('option');
      opt.value = s.type;
      opt.textContent = `${s.icon} ${s.label}`;
      sel.appendChild(opt);
    });
  }

  async function populateTribeDropdown() {
    try {
      // Build tribe list from loaded events (covers all cycles, not just active tribes)
      const { data: allTribes } = await sb.from('tribes').select('id, name, is_active').order('id');
      const tribesInEvents = new Set(ALL_EVENTS.filter((ev: any) => ev.tribe_id).map((ev: any) => ev.tribe_id));
      const sel = document.getElementById('events-tribe-filter') as HTMLSelectElement;
      if (!sel || !allTribes) return;
      // Clear existing options beyond default
      while (sel.options.length > 1) sel.remove(1);
      allTribes
        .filter((t: any) => tribesInEvents.has(t.id))
        .forEach((t: any) => {
          const opt = document.createElement('option');
          opt.value = String(t.id);
          opt.textContent = `T${t.id} — ${t.name}${!t.is_active ? ' (inativa)' : ''}`;
          sel.appendChild(opt);
        });
      // Non-GP members with a tribe: default filter to their own tribe
      if (!isGPLevel() && MEMBER?.tribe_id) {
        sel.value = String(MEMBER.tribe_id);
        sel.classList.remove('hidden');
        renderEvents();
      }
    } catch (e: any) {
      console.error('[TRIBE POPULATE] Error:', e?.message);
    }
  }

  /** Smart classification: event is "past" if any of:
   *  1. date < today
   *  2. date = today AND time_start + duration has passed
   *  3. has recording (youtube_url or recording_url)
   *  4. has attendees (someone checked in) AND date = today AND evening */
  function isEventPast(ev: any): boolean {
    const now = new Date();
    const endOfDay = new Date(ev.date + 'T23:59:59');
    if (endOfDay < now) return true; // yesterday or before
    // Same day — check time_start + duration
    if (ev.time_start) {
      const [h, m] = ev.time_start.split(':').map(Number);
      const eventEnd = new Date(ev.date + 'T00:00:00');
      eventEnd.setHours(h, m + (ev.duration_minutes || 60), 0);
      if (eventEnd < now) return true;
    }
    // Has recording = definitely happened
    if (ev.youtube_url || ev.recording_url) return true;
    // Has attendees + it's evening = likely done
    if ((ev.attendee_count || 0) > 0 && ev.time_start) {
      const [h] = ev.time_start.split(':').map(Number);
      if (now.getHours() >= h + 1) return true; // 1h after start
    }
    return false;
  }

  function renderEventCard(ev: any): string {
    const isPast = isEventPast(ev);
    const attIcon = ev.i_attended === true ? '✅' : ev.i_attended === false ? '❌' : '—';
    const linkHtml = ev.meeting_link && !isPast
      ? ` · <a href="${ev.meeting_link}" target="_blank" rel="noopener" class="text-navy font-semibold no-underline text-[11px]">🔗 Entrar</a>`
      : '';
    const recHtml = ev.youtube_url
      ? ` · <a href="${ev.youtube_url}" target="_blank" rel="noopener" class="text-red-600 font-semibold no-underline text-[11px]">🎥</a>`
      : '';
    const hasMinutes = !!(ev.minutes_text || ev.minutes_url);
    const hasAgenda = !!(ev.agenda_text || ev.agenda_url);
    const badges = [
      hasMinutes ? `<span class="text-[10px] cursor-pointer hover:bg-blue-100 rounded px-0.5" title="Ver Ata" data-action="toggle-minutes" data-event-id="${ev.id}">📝</span>` : '',
      hasAgenda ? '<span class="text-[10px]" title="Pauta">📋</span>' : '',
    ].filter(Boolean).join('');
    const canRoster = CAN_MANAGE;
    const canEdit = CAN_MANAGE || ev.created_by === MEMBER?.auth_id;

    ((window as any).__attendanceEventsById = (window as any).__attendanceEventsById || {})[ev.id] = ev;

    const minutesRendered = ev.minutes_text ? marked.parse(ev.minutes_text) : '';
    const canEditThisMinutes = CAN_MANAGE || (MEMBER?.operational_role === 'researcher' && MEMBER?.tribe_id === ev.tribe_id) || !!ev.initiative_id;
    const editMinutesBtn = canEditThisMinutes
      ? `<button class="text-[10px] font-semibold text-navy hover:underline cursor-pointer border-0 bg-transparent px-0 mt-1" data-action="open-minutes-editor" data-event-id="${ev.id}" data-event-title="${escapeAttr(ev.title)}" data-content="${escapeAttr(ev.minutes_text || '')}">${ev.minutes_text ? '✏️ Editar ata' : '📝 Adicionar ata'}</button>`
      : '';
    const minutesHtml = ev.minutes_text
      ? `<div id="minutes-${ev.id}" class="hidden mt-2 mx-6 mb-2 p-4 bg-[var(--surface-section-cool)] rounded-lg text-sm text-[var(--text-primary)] prose prose-sm max-w-none border-l-3 border-[var(--color-teal)]">${minutesRendered}${editMinutesBtn ? `<div class="mt-2 border-t border-[var(--border-subtle)] pt-2">${editMinutesBtn}</div>` : ''}</div>`
      : (canEditThisMinutes ? `<div id="minutes-${ev.id}" class="hidden mt-2 mx-6 mb-2 p-3 bg-amber-50 rounded-lg text-[11px] text-amber-700">${editMinutesBtn}</div>` : '');

    return `<div>
      <div class="py-2 border-b border-[var(--border-subtle)] last:border-b-0 flex items-center gap-2">
      <span class="text-xs">${attIcon}</span>
      <div class="flex-1 min-w-0">
        <div class="text-[13px] font-medium text-[var(--text-primary)] truncate${hasMinutes ? ' cursor-pointer hover:text-navy' : ''}" ${hasMinutes ? `data-action="toggle-minutes" data-event-id="${ev.id}"` : ''}>${ev.title}</div>
        <div class="text-[11px] text-[var(--text-muted)]">${fmtDate(ev.date)} · ${ev.duration_minutes || 60}min${isPast ? ` · ${ev.attendee_count || 0} presentes` : ''}${ev.initiative_name ? ` · <span class="text-[10px] font-semibold text-purple">📌 ${escapeAttr(ev.initiative_name)}</span>` : ''}${linkHtml}${recHtml} ${badges}</div>
      </div>
      <div class="flex gap-1 items-center flex-shrink-0">
        ${ev.i_attended !== true ? (isInCheckinWindow(ev)
          ? `<button class="px-2 py-1 rounded text-[11px] font-semibold bg-navy text-white border-0 cursor-pointer" data-action="check-in" data-event-id="${ev.id}">Check-In</button>`
          : (canAdminCheckin()
            ? `<button class="px-2 py-1 rounded text-[11px] font-semibold bg-amber-600 text-white border-0 cursor-pointer" data-action="admin-check-in" data-event-id="${ev.id}">${I18N.adminOverride || 'Register (Admin)'}</button>`
            : `<span class="px-2 py-1 rounded text-[10px] text-[var(--text-muted)] bg-[var(--surface-section-cool)]">${I18N.windowClosed || 'Check-in closed'}</span>`
          )) : ''}
        ${canRoster ? `<button class="px-1.5 py-1 text-xs bg-[var(--surface-base)] border border-[var(--border-default)] rounded cursor-pointer" data-action="open-roster" data-event-id="${ev.id}" data-event-title="${ev.title || ''}">📋</button>` : ''}
        ${canEdit ? `<button class="px-1.5 py-1 text-xs bg-[var(--surface-base)] border border-[var(--border-default)] rounded cursor-pointer" data-action="edit-event" data-event-id="${ev.id}">✏️</button>` : ''}
        ${canRoster && isPast && (ev.attendee_count || 0) === 0 ? `<button class="px-1.5 py-1 text-xs bg-red-50 border border-red-200 rounded cursor-pointer text-red-600 hover:bg-red-100" data-action="delete-event" data-event-id="${ev.id}" data-event-title="${ev.title || ''}" title="${I18N.deleteEvent || 'Cancelar esta reunião'}">🗑️</button>` : ''}
      </div>
    </div>${minutesHtml}</div>`;
  }

  const SECTION_ORDER = [
    { type: 'geral',          icon: '🌐', label: 'Gerais',          gpOnly: false },
    { type: 'tribo',          icon: '🔬', label: 'Tribos',          gpOnly: false },
    { type: 'kickoff',        icon: '🚀', label: 'Kickoff',         gpOnly: false },
    { type: 'lideranca',      icon: '👥', label: 'Liderança',       gpOnly: false },
    { type: 'webinar',        icon: '🎙️', label: 'Webinar',         gpOnly: false },
    { type: 'evento_externo', icon: '🌍', label: 'Evento Externo',  gpOnly: false },
    { type: 'comms',          icon: '📢', label: 'Comunicação',      gpOnly: false },
    { type: '1on1',           icon: '🔒', label: '1-on-1',          gpOnly: true  },
    { type: 'parceria',       icon: '🤝', label: 'Parcerias',       gpOnly: true  },
    { type: 'entrevista',     icon: '📌', label: 'Entrevistas',     gpOnly: true  },
  ];

  function renderEvents() {
    const el = document.getElementById('events-list')!;
    const filtered = filteredEvents();
    renderAttendanceContext(filtered.length, ALL_EVENTS.length);
    if (!ALL_EVENTS.length) {
      const cta = CAN_MANAGE
        ? `<button class="mt-3 px-4 py-2 bg-navy text-white rounded-xl text-[12px] font-semibold border-0 cursor-pointer hover:opacity-90" data-action="open-new-event">${I18N.emptyNewEvent}</button>`
        : `<button class="mt-3 px-4 py-2 bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-secondary)] rounded-xl text-[12px] font-semibold cursor-pointer hover:bg-[var(--surface-hover)]" data-action="refresh-events">${I18N.emptyRefresh}</button>`;
      el.innerHTML = `<div class="text-center py-8"><div class="text-3xl mb-2">📅</div><div class="font-semibold text-[var(--text-secondary)] text-sm">${I18N.noEvents}</div><p class="text-[var(--text-muted)] text-[12px] mt-1">${CAN_MANAGE ? I18N.emptyManagerHint : I18N.emptyMemberHint}</p>${cta}</div>`;
      return;
    }
    if (!filtered.length) {
      el.innerHTML = `<div class="text-center py-8"><div class="text-3xl mb-2">🔎</div><div class="font-semibold text-[var(--text-secondary)] text-sm">Nenhum evento corresponde ao filtro atual.</div><button class="mt-3 px-4 py-2 bg-[var(--surface-card)] border border-[var(--border-default)] text-[var(--text-secondary)] rounded-xl text-[12px] font-semibold cursor-pointer hover:bg-[var(--surface-hover)]" data-action="clear-event-filters">Limpar filtros</button></div>`;
      return;
    }

    // Separate initiative events from type-based events
    const initiativeEvents: Record<string, { name: string; past: any[]; future: any[] }> = {};
    const typeEvents: any[] = [];
    filtered.forEach((ev: any) => {
      if (ev.initiative_id && ev.initiative_name) {
        if (!initiativeEvents[ev.initiative_id]) initiativeEvents[ev.initiative_id] = { name: ev.initiative_name, past: [], future: [] };
        if (isEventPast(ev)) initiativeEvents[ev.initiative_id].past.push(ev);
        else initiativeEvents[ev.initiative_id].future.push(ev);
      } else {
        typeEvents.push(ev);
      }
    });

    // Group remaining (non-initiative) events by type
    const groups: Record<string, { past: any[]; future: any[] }> = {};
    typeEvents.forEach((ev: any) => {
      const t = ev.type || 'other';
      if (!groups[t]) groups[t] = { past: [], future: [] };
      if (isEventPast(ev)) groups[t].past.push(ev);
      else groups[t].future.push(ev);
    });
    Object.values(groups).forEach(g => {
      g.past.sort((a: any, b: any) => b.date.localeCompare(a.date));
      g.future.sort((a: any, b: any) => a.date.localeCompare(b.date));
    });
    Object.values(initiativeEvents).forEach(g => {
      g.past.sort((a: any, b: any) => b.date.localeCompare(a.date));
      g.future.sort((a: any, b: any) => a.date.localeCompare(b.date));
    });

    const gp = isGPLevel();
    // For section visibility: show GP-only sections if GP OR if user has events in that type
    const participatedTypes = new Set(typeEvents.filter((ev: any) => ev.i_attended != null).map((ev: any) => ev.type));
    const sections: Array<{ type: string; icon: string; label: string; gpOnly: boolean; past: any[]; future: any[]; pastCount: number; futureCount: number }> = [];

    // Add initiative sections first
    Object.entries(initiativeEvents).forEach(([initId, g]) => {
      sections.push({ type: `init_${initId}`, icon: '📌', label: g.name, gpOnly: false, past: g.past, future: g.future, pastCount: g.past.length, futureCount: g.future.length });
    });

    // Then type-based sections
    SECTION_ORDER
      .filter(s => !s.gpOnly || gp || participatedTypes.has(s.type))
      .filter(s => groups[s.type])
      .forEach(s => {
        const g = groups[s.type];
        sections.push({ ...s, past: g.past, future: g.future, pastCount: g.past.length, futureCount: g.future.length });
      });

    // Also collect any types not in SECTION_ORDER
    const knownTypes = new Set(SECTION_ORDER.map(s => s.type));
    Object.entries(groups).forEach(([type, g]) => {
      if (!knownTypes.has(type) && (g.past.length || g.future.length)) {
        sections.push({ type, icon: '📌', label: type, gpOnly: false, past: g.past, future: g.future, pastCount: g.past.length, futureCount: g.future.length });
      }
    });

    el.innerHTML = sections.map(s => {
      const countLabel = [
        s.pastCount > 0 ? `${s.pastCount} realizados` : '',
        s.futureCount > 0 ? `${s.futureCount} agendados` : '',
      ].filter(Boolean).join(' · ');

      const gpBadge = s.gpOnly ? ' <span class="text-[9px] px-1.5 py-0.5 rounded bg-amber-100 text-amber-700 font-bold ml-1">GP</span>' : '';

      const PAST_LIMIT = 10;
      const visiblePast = s.past.slice(0, PAST_LIMIT);
      const hiddenPast = s.past.slice(PAST_LIMIT);
      const pastHtml = s.past.length ? `<div class="mb-2"><div class="text-[10px] font-bold uppercase tracking-wider text-[var(--text-muted)] mb-1">📌 Realizados</div>${visiblePast.map((ev: any) => renderEventCard(ev)).join('')}${hiddenPast.length ? `<div id="more-past-${s.type}" class="hidden">${hiddenPast.map((ev: any) => renderEventCard(ev)).join('')}</div><button class="text-xs text-navy font-semibold mt-1 cursor-pointer border-0 bg-transparent hover:underline js-show-more" data-target="more-past-${s.type}">Ver todos os ${s.pastCount} realizados ▾</button>` : ''}</div>` : '';

      const FUTURE_LIMIT = 3;
      const visibleFuture = s.future.slice(0, FUTURE_LIMIT);
      const hiddenFuture = s.future.slice(FUTURE_LIMIT);
      const futureHtml = s.future.length ? `<div><div class="text-[10px] font-bold uppercase tracking-wider text-[var(--text-muted)] mb-1">📅 Agendados</div>${visibleFuture.map((ev: any) => renderEventCard(ev)).join('')}${hiddenFuture.length ? `<div id="more-${s.type}" class="hidden">${hiddenFuture.map((ev: any) => renderEventCard(ev)).join('')}</div><button class="text-xs text-navy font-semibold mt-1 cursor-pointer border-0 bg-transparent hover:underline js-show-more" data-target="more-${s.type}">Ver todos os ${s.futureCount} agendados ▾</button>` : ''}</div>` : '';

      const autoExpand = (getTypeFilter() !== 'todos' || ATTENDANCE_ROUTE.query) ? ' open' : '';
      return `<details class="border-b border-[var(--border-subtle)] last:border-b-0"${autoExpand}><summary class="flex items-center justify-between px-1 py-3 cursor-pointer hover:bg-[var(--surface-hover)] transition-colors select-none"><span class="text-sm font-semibold text-[var(--text-primary)]">${s.icon} ${s.label}${gpBadge}</span><span class="text-[11px] text-[var(--text-muted)]">${countLabel}</span></summary><div class="pl-2 pr-1 pb-3 space-y-2">${pastHtml}${futureHtml}</div></details>`;
    }).join('');

    maybeHandleFocusedEvent(filtered);
  }

  async function loadEventTagMap() {
    if (!ALL_EVENTS.length || !ALL_TAGS.length) return;
    try {
      const eventIds = ALL_EVENTS.map((ev: any) => ev.id);
      const { data: allTags } = await sb.rpc('get_event_tags_batch', { p_event_ids: eventIds });
      EVENT_TAG_MAP = {};
      (allTags || []).forEach((t: any) => {
        if (!EVENT_TAG_MAP[t.event_id]) EVENT_TAG_MAP[t.event_id] = [];
        EVENT_TAG_MAP[t.event_id].push(t.tag_name);
      });
    } catch { /* tag map load is best-effort */ }
  }

  async function loadEvents() {
    const el = document.getElementById('events-list')!;
    el.innerHTML = loadingRows(3);
    try {
      const { data } = await sb.rpc('get_events_with_attendance', { p_limit: 500, p_offset: 0 });
      ALL_EVENTS = data || [];
      renderEvents();
    } catch (e) {
      console.warn('Attendance: failed to load events:', e);
      el.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">Failed to load events. Please try again later.</div>`;
      toast('Failed to load events.', 'error');
    }
  }

  if (!(window as any).__attendanceDelegationBound) {
    (window as any).__attendanceDelegationBound = true;

    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;

      // Show-more buttons (delegated from template literals)
      const showMoreBtn = (e.target as HTMLElement).closest('.js-show-more') as HTMLElement | null;
      if (showMoreBtn) {
        const tgt = document.getElementById(showMoreBtn.dataset.target || '');
        if (tgt) tgt.classList.remove('hidden');
        showMoreBtn.remove();
        return;
      }
      // Tag filter pill buttons — sync with type dropdown for compound filtering
      const tagFilterBtn = (e.target as HTMLElement).closest('.tag-filter-btn') as HTMLElement | null;
      if (tagFilterBtn && tagFilterBtn.dataset.tagFilter !== undefined) {
        const tagName = tagFilterBtn.dataset.tagFilter || '';
        VISIBLE_COUNT = PAGE_SIZE;

        // Map tag names to event types for type-based pills
        const TAG_TO_TYPE: Record<string, string> = {
          general_meeting: 'geral', tribe_meeting: 'tribo', kickoff: 'kickoff',
          leadership_meeting: 'lideranca', interview: 'entrevista',
          external_event: 'evento_externo', webinar: 'webinar',
        };
        const typeSelect = document.getElementById('events-type-filter') as HTMLSelectElement | null;
        const tribeSel = document.getElementById('events-tribe-filter');
        const mappedType = TAG_TO_TYPE[tagName];

        if (!tagName) {
          // "Todos" pill — reset both filters
          ACTIVE_TAG_FILTER = '';
          if (typeSelect) { typeSelect.value = 'todos'; ATTENDANCE_ROUTE.type = 'todos'; }
          if (tribeSel) tribeSel.classList.add('hidden');
        } else if (mappedType) {
          // Type-mapped pill (Geral, Tribo, etc.) — set type dropdown, clear tag filter
          ACTIVE_TAG_FILTER = '';
          if (typeSelect) { typeSelect.value = mappedType; ATTENDANCE_ROUTE.type = mappedType; }
          // Show tribe sub-filter for type-based pills (Tribo mapped or Todos)
          if (tribeSel) tribeSel.classList.toggle('hidden', mappedType !== 'tribo');
        } else {
          // Non-type pill (Ciclo 2, Ciclo 3, etc.) — use as tag filter, reset type to todos, show tribe dropdown
          ACTIVE_TAG_FILTER = tagName;
          if (typeSelect) { typeSelect.value = 'todos'; ATTENDANCE_ROUTE.type = 'todos'; }
          if (tribeSel) tribeSel.classList.remove('hidden');
        }

        // Update pill styling via inline styles (classList with var() classes breaks in browsers)
        document.querySelectorAll('.tag-filter-btn').forEach(btn => {
          const el = btn as HTMLElement;
          el.dataset.active = 'false';
          el.style.background = 'var(--surface-card)';
          el.style.color = 'var(--text-secondary)';
          el.style.borderColor = 'var(--border-default)';
        });
        tagFilterBtn.dataset.active = 'true';
        tagFilterBtn.style.background = 'var(--color-navy)';
        tagFilterBtn.style.color = '#fff';
        tagFilterBtn.style.borderColor = 'var(--color-navy)';
        renderEvents();
        return;
      }

      const target = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!target) return;

      switch (target.dataset.action) {
        case 'open-auth':
          document.dispatchEvent(new CustomEvent('open-auth'));
          break;
        case 'close-modal':
          closeModal(target.dataset.modalId || '');
          break;
        case 'switch-tab':
          switchTab(target, target.dataset.tab || '');
          break;
        case 'open-new-event':
          openNewEventModal();
          break;
        case 'open-recurring':
          openRecurringModal();
          break;
        case 'refresh-events':
          loadEvents();
          break;
        case 'open-focused-edit': {
          const focused = currentFocusedEvent();
          if (focused) openEditEvent(focused);
          break;
        }
        case 'load-more-events':
          VISIBLE_COUNT += PAGE_SIZE;
          renderEvents();
          break;
        case 'clear-event-filters':
          clearAttendanceFilters();
          break;
        case 'check-in':
          checkIn(target.dataset.eventId || '');
          break;
        case 'admin-check-in':
          adminCheckIn(target.dataset.eventId || '');
          break;
        case 'open-roster':
          openRoster(target.dataset.eventId || '', target.dataset.eventTitle || '');
          break;
        case 'toggle-tag-picker':
          toggleTagPicker(target.dataset.target || '');
          break;
        case 'edit-event': {
          const ev = (window as any).__attendanceEventsById?.[target.dataset.eventId || ''];
          if (ev) openEditEvent(ev);
          break;
        }
        case 'delete-event': {
          const evId = target.dataset.eventId || '';
          const evTitle = target.dataset.eventTitle || '';
          deleteEventInstance(evId, evTitle);
          break;
        }
        case 'toggle-minutes': {
          const minutesEl = document.getElementById(`minutes-${target.dataset.eventId}`);
          if (minutesEl) minutesEl.classList.toggle('hidden');
          break;
        }
        case 'open-minutes-editor': {
          window.dispatchEvent(new CustomEvent('open-event-editor', {
            detail: {
              eventId: target.dataset.eventId,
              eventTitle: target.dataset.eventTitle,
              mode: 'minutes',
              initialContent: target.dataset.content || '',
              initialUrl: '',
            }
          }));
          break;
        }
        case 'toggle-presence':
          togglePresence(target.dataset.eventId || '', target.dataset.memberId || '', target);
          break;
        case 'roster-bulk-all':
          bulkSelectAll();
          break;
        case 'roster-bulk-confirm':
          bulkConfirmPresence();
          break;
        case 'toggle-showcase-form':
          document.getElementById('roster-showcase-form')?.classList.toggle('hidden');
          break;
        case 'save-showcase':
          saveShowcase();
          break;
        case 'remove-showcase':
          if (target.dataset.showcaseId) removeShowcase(target.dataset.showcaseId);
          break;
      }
    });

    document.addEventListener('change', (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      // W140: tag checkbox change
      if (target instanceof HTMLInputElement && target.classList.contains('tag-checkbox')) {
        const option = target.closest('[data-picker-id]') as HTMLElement | null;
        const pickerId = option?.dataset.pickerId;
        if (pickerId === 'ev-tag-picker') updateTagSelection('ev-tag-picker', 'ev-tags-container', 'ev-selected-tags');
        else if (pickerId === 'edit-ev-tag-picker') updateTagSelection('edit-ev-tag-picker', 'edit-ev-tags-container', 'edit-ev-selected-tags');
        else if (pickerId === 'rec-tag-picker') updateTagSelection('rec-tag-picker', 'rec-tags-container', 'rec-selected-tags');
        return;
      }
      if (target instanceof HTMLSelectElement) {
        if (target.id === 'ev-type') updateAudienceFromType('ev-audience', 'ev-type');
        if (target.id === 'rec-type') updateAudienceFromType('rec-audience', 'rec-type');
        if (target.id === 'events-tribe-filter') {
          VISIBLE_COUNT = PAGE_SIZE;
          renderEvents();
        }
        if (target.id === 'events-type-filter') {
          ATTENDANCE_ROUTE.type = target.value;
          ACTIVE_TAG_FILTER = '';
          VISIBLE_COUNT = PAGE_SIZE;
          const tribeSel = document.getElementById('events-tribe-filter');
          if (tribeSel) tribeSel.classList.toggle('hidden', target.value !== 'todos' && target.value !== 'tribo');
          // Sync pill styling: highlight matching pill or reset to "Todos"
          const TYPE_TO_TAG: Record<string, string> = {
            geral: 'general_meeting', tribo: 'tribe_meeting', kickoff: 'kickoff',
            lideranca: 'leadership_meeting', entrevista: 'interview',
            evento_externo: 'external_event', webinar: 'webinar',
          };
          const activeTag = TYPE_TO_TAG[target.value] || '';
          document.querySelectorAll('.tag-filter-btn').forEach(btn => {
            const el = btn as HTMLElement;
            const isMatch = (activeTag && el.dataset.tagFilter === activeTag) || (!activeTag && el.dataset.tagFilter === '');
            el.dataset.active = String(isMatch);
            if (isMatch) {
              el.style.background = 'var(--color-navy)';
              el.style.color = '#fff';
              el.style.borderColor = 'var(--color-navy)';
            } else {
              el.style.background = 'var(--surface-card)';
              el.style.color = 'var(--text-secondary)';
              el.style.borderColor = 'var(--border-default)';
            }
          });
          renderEvents();
        }
      }
      if (target instanceof HTMLInputElement && target.id === 'attendance-interview-toggle') {
        SHOW_INTERVIEWS = target.checked;
        VISIBLE_COUNT = PAGE_SIZE;
        renderEvents();
      }
    });

    // Tribe filter dropdown (type filter handled by delegated change handler above)
    document.getElementById('events-tribe-filter')?.addEventListener('change', () => renderEvents());
    // Type dropdown populated later in populateTypeDropdown() after CAN_MANAGE is set
    // Tribe dropdown is now populated in onMemberReady() via populateTribeDropdown()

    document.addEventListener('input', (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.id === 'roster-search') rosterFilter(target.value);
      if (target.id === 'attendance-search') {
        ATTENDANCE_ROUTE.query = target.value.trim();
        renderEvents();
      }
    });

    document.addEventListener('submit', (e: SubmitEvent) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      if (target.id === 'new-event-form') {
        e.preventDefault();
        createEvent();
      }
      if (target.id === 'recurring-event-form') {
        e.preventDefault();
        createRecurring();
      }
      if (target.id === 'edit-event-form') {
        e.preventDefault();
        saveEventEdit();
      }
    });

    document.addEventListener('error', (e: Event) => {
      if (e.target instanceof HTMLImageElement && (e.target as HTMLElement).hasAttribute('data-hide-on-error')) {
        (e.target as HTMLImageElement).style.visibility = 'hidden';
      }
    }, true);
  }

  // ── CHECK-IN ──
  async function checkIn(eventId: string) {
    const safePH = (window as any).__safePH;
    safePH?.('capture', 'checkin_attempted', { event_id: eventId });
    try {
      const { data, error } = await sb.rpc('register_own_presence', { p_event_id: eventId });
      if (error) throw error;
      if (data?.success) {
        // Enriched feedback: show XP + hours after check-in
        let feedbackMsg = I18N.msgCheckedIn;
        try {
          const ev = ALL_EVENTS.find((e: any) => e.id === eventId);
          const evHours = ev?.duration_minutes ? (ev.duration_minutes / 60).toFixed(1) : null;
          const { data: ahRows } = await sb.rpc('get_member_attendance_hours', { p_member_id: MEMBER.id });
          const ah = ahRows?.[0];
          if (ah) {
            feedbackMsg += `\n+10 XP${evHours ? ' · +' + evHours + 'h' : ''}`;
            feedbackMsg += `\n${I18N.feedbackCycleTotal}: ${Number(ah.total_hours).toFixed(1)}h · ${ah.total_events} ${I18N.feedbackEvents}`;
          }
        } catch (_) { /* fallback to simple toast */ }
        toast(feedbackMsg, 'success');
        safePH?.('capture', 'checkin_success', { event_id: eventId });
        loadEvents(); loadKPIs();
      } else {
        let errMsg = data?.message || I18N.msgCheckInError;
        if (data?.error === 'checkin_window_expired') errMsg = I18N.checkinWindowExpired;
        else if (data?.error === 'checkin_too_early') errMsg = I18N.checkinTooEarly;
        toast(errMsg, 'error');
        safePH?.('capture', 'checkin_failed', { event_id: eventId, error: data?.error || errMsg });
      }
    } catch (e: any) {
      const errMsg = e?.message || I18N.msgCheckInError;
      toast(errMsg, 'error');
      safePH?.('capture', 'checkin_failed', { event_id: eventId, error: errMsg });
      console.error('register_own_presence failed:', e);
    }
  }

  // ── ADMIN CHECK-IN (bypasses time window) ──
  async function adminCheckIn(eventId: string) {
    if (!canAdminCheckin()) return;
    try {
      const { data, error } = await sb.rpc('mark_member_present', {
        p_event_id: eventId,
        p_member_id: MEMBER.id,
        p_present: true,
      });
      if (error) throw error;
      if (data?.success) {
        toast(I18N.msgCheckedIn, 'success');
        loadEvents(); loadKPIs();
      } else {
        toast(data?.error || I18N.msgCheckInError, 'error');
      }
    } catch (e: any) {
      toast(e?.message || I18N.msgCheckInError, 'error');
    }
  }

  // ── DELETE EVENT INSTANCE ──
  async function deleteEventInstance(eventId: string, eventTitle: string) {
    if (!CAN_MANAGE) return;
    const confirmed = confirm(
      `${I18N.deleteConfirm || 'Tem certeza que deseja cancelar esta reunião?'}\n\n${eventTitle}\n\n${I18N.deleteWarning || 'Esta ação não pode ser desfeita.'}`
    );
    if (!confirmed) return;

    const doDelete = async (force: boolean) => sb.rpc('drop_event_instance', {
      p_event_id: eventId,
      p_force_delete_attendance: force
    });

    try {
      let { data, error } = await doDelete(false);
      // Two-step flow: if attendance exists, confirm and retry with force
      if (error && /attendance_exists:(\d+)/.test(error.message || '')) {
        const count = Number((error.message.match(/attendance_exists:(\d+)/) || [])[1] || 0);
        const template = (I18N.deleteForcePrompt as string) || 'Este evento tem {count} presença(s) registrada(s).\n\nConfirmar remoção das presenças E cancelamento do evento?';
        const ok = confirm(template.replace('{count}', String(count)));
        if (!ok) return;
        ({ data, error } = await doDelete(true));
      }
      if (error) throw error;
      if (data?.success) {
        const attCount = Number(data.deleted_attendance_count || 0);
        const msg = attCount > 0
          ? ((I18N.deleteSuccessWithAttendance as string) || 'Evento cancelado. {count} presença(s) também foram removidas.').replace('{count}', String(attCount))
          : (I18N.deleteSuccess || 'Evento cancelado com sucesso.');
        toast(msg, 'success');
        loadEvents(); loadKPIs();
      } else {
        toast(data?.error || 'Erro ao deletar evento.', 'error');
      }
    } catch (e: any) {
      toast(e?.message || 'Erro ao deletar evento.', 'error');
    }
  }

  // ── W140: TAG SYSTEM ──
  const LEGACY_TYPE_MAP: Record<string, string> = {
    general_meeting: 'general_meeting',
    tribe_meeting: 'tribe_meeting',
    webinar: 'webinar',
    kickoff: 'kickoff',
    leadership_meeting: 'leadership_meeting',
    interview: 'interview',
    external_event: 'external_event',
  };

  async function loadTags() {
    try {
      const { data, error } = await sb.rpc('get_tags', { p_domain: 'event' });
      if (error) throw error;
      ALL_TAGS = data || [];
      populateTagPickers();
      populateTagFilterBar();
    } catch (e) {
      console.warn('W140: failed to load tags:', e);
    }
  }

  function populateTagPickers() {
    const pickerIds = ['ev-tag-picker', 'edit-ev-tag-picker', 'rec-tag-picker'];
    pickerIds.forEach(pickerId => {
      const picker = document.getElementById(pickerId);
      if (!picker) return;
      picker.innerHTML = ALL_TAGS.map(tag => `
        <label class="flex items-center gap-2 px-3 py-2 hover:bg-[var(--surface-hover)] cursor-pointer text-[13px]" data-tag-option data-tag-id="${escapeAttr(tag.id)}" data-tag-name="${escapeAttr(tag.name)}" data-picker-id="${escapeAttr(pickerId)}">
          <input type="checkbox" class="w-3.5 h-3.5 accent-navy tag-checkbox" data-tag-id="${escapeAttr(tag.id)}" />
          <span class="inline-block w-2.5 h-2.5 rounded-full flex-shrink-0" style="background:${tag.color}"></span>
          <span>${tag.label_pt || tag.name}</span>
          <span class="text-[10px] text-[var(--text-muted)] ml-auto">${tag.tier}</span>
        </label>
      `).join('');
    });
  }

  function populateTagFilterBar() {
    const bar = document.getElementById('attendance-tag-filter');
    if (!bar) return;
    const systemTags = ALL_TAGS.filter(t => t.tier === 'system' && !t.name.startsWith('tribe_'));
    if (!systemTags.length) return;
    bar.classList.remove('hidden');
    bar.innerHTML = `
      <button type="button" class="tag-filter-btn px-2.5 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border" data-tag-filter="" data-active="true" style="background:var(--color-navy);color:#fff;border-color:var(--color-navy)">Todos</button>
      ${systemTags.map(tag => `
        <button type="button" class="tag-filter-btn px-2.5 py-1.5 rounded-full text-[12px] font-semibold cursor-pointer border" data-tag-filter="${escapeAttr(tag.name)}" data-active="false" style="background:var(--surface-card);color:var(--text-secondary);border-color:${tag.color}40">
          <span class="inline-block w-2 h-2 rounded-full mr-1" style="background:${tag.color}"></span>${tag.label_pt || tag.name}
        </button>
      `).join('')}
    `;
  }

  function toggleTagPicker(targetId: string) {
    const picker = document.getElementById(targetId);
    if (!picker) return;
    picker.classList.toggle('hidden');
  }

  function getSelectedTagIds(hiddenInputId: string): string[] {
    const val = (document.getElementById(hiddenInputId) as HTMLInputElement)?.value || '';
    return val ? val.split(',').filter(Boolean) : [];
  }

  function updateTagSelection(pickerId: string, containerId: string, hiddenInputId: string) {
    const picker = document.getElementById(pickerId);
    if (!picker) return;
    const checkboxes = picker.querySelectorAll('.tag-checkbox:checked') as NodeListOf<HTMLInputElement>;
    const selectedIds: string[] = [];
    checkboxes.forEach(cb => { if (cb.dataset.tagId) selectedIds.push(cb.dataset.tagId); });

    (document.getElementById(hiddenInputId) as HTMLInputElement).value = selectedIds.join(',');

    const container = document.getElementById(containerId);
    if (!container) return;
    if (!selectedIds.length) {
      container.innerHTML = '<span class="text-[12px] text-[var(--text-muted)]">Clique para selecionar tags...</span>';
    } else {
      container.innerHTML = selectedIds.map(id => {
        const tag = ALL_TAGS.find(t => t.id === id);
        if (!tag) return '';
        return `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold" style="background:${tag.color}18;color:${tag.color};border:1px solid ${tag.color}40">
          <span class="w-1.5 h-1.5 rounded-full" style="background:${tag.color}"></span>${tag.label_pt || tag.name}
        </span>`;
      }).join('');
    }

    // Auto-set legacy type from primary tag
    const legacyTypeId = pickerId === 'ev-tag-picker' ? 'ev-type' : pickerId === 'rec-tag-picker' ? 'rec-type' : null;
    if (legacyTypeId && selectedIds.length) {
      const primaryTag = ALL_TAGS.find(t => t.id === selectedIds[0]);
      if (primaryTag && LEGACY_TYPE_MAP[primaryTag.name]) {
        (document.getElementById(legacyTypeId) as HTMLInputElement).value = primaryTag.name;
      }
    }

    // Auto-set audience from primary tag
    const audienceId = pickerId === 'ev-tag-picker' ? 'ev-audience'
      : pickerId === 'edit-ev-tag-picker' ? 'edit-ev-audience'
      : pickerId === 'rec-tag-picker' ? 'rec-audience' : null;
    if (audienceId && selectedIds.length) {
      const primaryTag = ALL_TAGS.find(t => t.id === selectedIds[0]);
      if (primaryTag) {
        const audienceMap: Record<string, string> = {
          tribe_meeting: 'tribe',
          general_meeting: 'all',
          webinar: 'all',
          kickoff: 'all',
          leadership_meeting: 'leadership',
          interview: 'curators',
          external_event: 'all',
        };
        const mapped = audienceMap[primaryTag.name];
        if (mapped) (document.getElementById(audienceId) as HTMLSelectElement).value = mapped;
      }
    }
  }

  function setTagPickerFromIds(pickerId: string, containerId: string, hiddenInputId: string, tagIds: string[]) {
    (document.getElementById(hiddenInputId) as HTMLInputElement).value = tagIds.join(',');
    const picker = document.getElementById(pickerId);
    if (picker) {
      picker.querySelectorAll('.tag-checkbox').forEach((cb: Element) => {
        (cb as HTMLInputElement).checked = tagIds.includes((cb as HTMLInputElement).dataset.tagId || '');
      });
    }
    updateTagSelection(pickerId, containerId, hiddenInputId);
  }

  async function assignEventTagsAndAudience(eventId: string, tagIds: string[], audienceValue: string) {
    if (tagIds.length) {
      await sb.rpc('assign_event_tags', { p_event_id: eventId, p_tag_ids: tagIds });
    }
    const audienceRules = buildAudienceRules(audienceValue);
    if (audienceRules.length) {
      await sb.rpc('set_event_audience', { p_event_id: eventId, p_rules: audienceRules });
    }
  }

  function buildAudienceRules(audienceValue: string): any[] {
    const rules: any[] = [];
    if (audienceValue === 'all_active_operational') {
      rules.push({ attendance_type: 'mandatory', target_type: 'all_active_operational', target_value: null });
    } else if (audienceValue === 'tribe') {
      rules.push({ attendance_type: 'mandatory', target_type: 'tribe', target_value: MEMBER?.tribe_id ? String(MEMBER.tribe_id) : null });
    } else if (audienceValue === 'role') {
      ['manager', 'deputy_manager', 'tribe_leader'].forEach(r => {
        rules.push({ attendance_type: 'mandatory', target_type: 'role', target_value: r });
      });
    } else if (audienceValue === 'specific_members') {
      rules.push({ attendance_type: 'mandatory', target_type: 'specific_members', target_value: null });
    }
    return rules;
  }

  // ── AUDIENCE HELPER (legacy) ──
  function updateAudienceFromType(audienceId: string, typeId: string) {
    const type = (document.getElementById(typeId) as HTMLSelectElement).value;
