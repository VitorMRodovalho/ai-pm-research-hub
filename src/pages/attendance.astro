---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import KpiBar from '../components/attendance/KpiBar.astro';
import NewEventModal from '../components/attendance/NewEventModal.astro';
import RecurringModal from '../components/attendance/RecurringModal.astro';
import EditEventModal from '../components/attendance/EditEventModal.astro';
import RosterModal from '../components/attendance/RosterModal.astro';
import LoadingSkeleton from '../components/ui/LoadingSkeleton.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<BaseLayout title={t('attendance.meta', lang)} activePage="attendance">
  <Toast />

  <!-- AUTH GATE (hidden by default, shown only if no session) -->
  <div id="auth-gate" class="hidden items-center justify-center min-h-screen bg-slate-50">
    <div class="bg-white rounded-2xl p-9 max-w-[360px] w-full text-center border border-slate-200">
      <div class="text-4xl mb-3">⏱️</div>
      <h2 class="text-navy font-bold text-xl mb-2">{t('attendance.authTitle', lang)}</h2>
      <p class="text-slate-500 text-sm mb-6">{t('attendance.authDesc', lang)}</p>
      <button id="attendance-auth-btn"
              class="w-full py-3 rounded-lg bg-navy text-white font-semibold text-sm border-0 cursor-pointer hover:bg-navy/90 transition-colors"
              data-action="open-auth">
        {t('attendance.authBtn', lang)}
      </button>
      <p id="auth-not-found-msg" class="hidden mt-4 text-[13px] text-amber-700">
        {t('guest.notRegistered', lang)} {t('guest.contactAdmin', lang)}
        <br />
        <a href={`mailto:${t('guest.contactEmail', lang)}`} class="text-amber-800 font-semibold underline">{t('guest.contactEmail', lang)}</a>
      </p>
    </div>
  </div>

  <!-- LOADING STATE -->
  <div id="loading-gate" class="flex items-center justify-center min-h-[60vh]">
    <p class="text-slate-400 text-sm">{t('attendance.loading', lang)}</p>
  </div>

  <!-- APP (hidden until auth) -->
  <div id="app" class="hidden">
    <KpiBar />

    <main class="max-w-[1100px] mx-auto px-4 py-6">
      <!-- Tabs -->
      <div class="flex gap-2 mb-5 flex-wrap">
        <button class="tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-navy bg-navy text-white transition-all"
                data-tab="events" data-action="switch-tab">
          {t('attendance.events', lang)}
        </button>
        <button class="tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
                data-tab="ranking" data-action="switch-tab">
          {t('attendance.ranking', lang)}
        </button>
        <button class="hidden tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
                id="tab-new-event" data-action="open-new-event">
          {t('attendance.newEvent', lang)}
        </button>
        <button class="hidden tab-btn px-4 py-2 rounded-full text-[13px] font-semibold cursor-pointer border-2 border-slate-200 bg-white text-slate-500 transition-all"
                id="tab-recurring" data-action="open-recurring">
          {t('attendance.recurring', lang)}
        </button>
      </div>

      <!-- Events tab -->
      <div id="tab-events">
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-200 flex items-center justify-between">
            <h3 class="text-sm font-bold text-navy">{t('attendance.eventsTitle', lang)}</h3>
            <button class="px-3 py-1.5 rounded-lg text-[12px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-slate-50 cursor-pointer"
                    data-action="refresh-events">{t('attendance.refresh', lang)}</button>
          </div>
          <div class="p-5" id="events-list">
            <LoadingSkeleton variant="row" count={3} />
          </div>
        </div>
      </div>

      <!-- Ranking tab -->
      <div id="tab-ranking" class="hidden">
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <div class="px-5 py-3.5 border-b border-slate-200">
            <h3 class="text-sm font-bold text-navy">{t('attendance.rankingTitle', lang)}</h3>
          </div>
          <div class="p-5" id="ranking-list">
            <LoadingSkeleton variant="row" count={3} />
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Modals -->
  <NewEventModal />
  <RecurringModal />
  <EditEventModal />
  <RosterModal />
</BaseLayout>

<script is:inline define:vars={{ __ATTENDANCE_I18N: JSON.stringify({
  loading: t('attendance.loading', lang),
  noEvents: t('attendance.noEvents', lang),
  hours: t('attendance.hours', lang),
  dateLocale: t('attendance.dateLocale', lang),
  roleManager: t('attendance.role.manager', lang),
  roleTribeLeader: t('attendance.role.tribe_leader', lang),
  roleResearcher: t('attendance.role.researcher', lang),
  roleFacilitator: t('attendance.role.facilitator', lang),
  roleCommunicator: t('attendance.role.communicator', lang),
  roleSponsor: t('attendance.role.sponsor', lang),
  roleAmbassador: t('attendance.role.ambassador', lang),
  roleCurator: t('attendance.role.curator', lang),
  roleFounder: t('attendance.role.founder', lang),
  roleGuest: t('attendance.role.guest', lang),
  eventTypeTribe: t('attendance.eventType.tribe', lang),
  eventTypeGeneral: t('attendance.eventType.general', lang),
  eventTypeWebinar: t('attendance.eventType.webinar', lang),
  eventTypeOther: t('attendance.eventType.other', lang),
  audienceLeadership: t('attendance.audience.leadership', lang),
  audienceTribe: t('attendance.audience.tribe', lang),
  audienceCurators: t('attendance.audience.curators', lang),
  badgeRecorded: t('attendance.badge.recorded', lang),
  emptyNewEvent: t('attendance.empty.newEvent', lang),
  emptyRefresh: t('attendance.empty.refresh', lang),
  emptyManagerHint: t('attendance.empty.managerHint', lang),
  emptyMemberHint: t('attendance.empty.memberHint', lang),
  eventJoin: t('attendance.event.join', lang),
  eventYoutube: t('attendance.event.youtube', lang),
  eventYoutubeSoon: t('attendance.event.youtubeSoon', lang),
  eventAttendees: t('attendance.event.attendees', lang),
  eventCheckIn: t('attendance.event.checkIn', lang),
  eventRosterTooltip: t('attendance.event.rosterTooltip', lang),
  eventEditTooltip: t('attendance.event.editTooltip', lang),
  msgCheckedIn: t('attendance.msg.checkedIn', lang),
  msgCheckInError: t('attendance.msg.checkInError', lang),
  msgFillTitleDate: t('attendance.msg.fillTitleDate', lang),
  msgEventCreated: t('attendance.msg.eventCreated', lang),
  msgEventCreateError: t('attendance.msg.eventCreateError', lang),
  msgFillTemplateDate: t('attendance.msg.fillTemplateDate', lang),
  msgEventsCreated: t('attendance.msg.eventsCreated', lang),
  msgRecurringError: t('attendance.msg.recurringError', lang),
  msgEventUpdated: t('attendance.msg.eventUpdated', lang),
  msgEventSaveError: t('attendance.msg.eventSaveError', lang),
  msgError: t('attendance.msg.error', lang),
  rosterLoading: t('attendance.roster.loading', lang),
  rosterNoParticipants: t('attendance.roster.noParticipants', lang),
  rosterCount: t('attendance.roster.count', lang),
  rosterVisible: t('attendance.modal.visible', lang),
  rankingNoData: t('attendance.ranking.noData', lang),
  rankingNoDataHint: t('attendance.ranking.noDataHint', lang),
}) }}>
  window.__ATTENDANCE_I18N = JSON.parse(__ATTENDANCE_I18N);
</script>

<script>
  // ════════════════════════════════════════════════════════════════
  // ATTENDANCE PAGE — Client-side logic
  // Uses window.navGetSb() and nav:member event from Nav.astro
  // ════════════════════════════════════════════════════════════════

  import { hasMinimumTier, resolveTierFromMember } from '../lib/admin/constants';
  import { ROLE_LABELS, ROLE_COLORS } from '../lib/supabase';
  import { getMemberRole } from '../lib/routing';

  const I18N = (window as any).__ATTENDANCE_I18N || {
    loading: 'Carregando...',
    noEvents: 'Nenhum evento encontrado.',
    hours: 'horas',
    dateLocale: 'pt-BR',
    roleManager: 'Gerente de Projeto',
    roleTribeLeader: 'Líder de Tribo',
    roleResearcher: 'Pesquisador',
    roleFacilitator: 'Facilitador',
    roleCommunicator: 'Multiplicador',
    roleSponsor: 'Patrocinador',
    roleAmbassador: 'Embaixador',
    roleCurator: 'Curador',
    roleFounder: 'Fundador',
    roleGuest: 'Convidado',
    eventTypeTribe: 'Tribo',
    eventTypeGeneral: 'Geral',
    eventTypeWebinar: 'Webinar',
    eventTypeOther: 'Outro',
    audienceLeadership: '🏛️ Liderança',
    audienceTribe: '🔷 Tribo',
    audienceCurators: '📋 Curadoria',
    badgeRecorded: '● Gravada',
    emptyNewEvent: '+ Novo Evento',
    emptyRefresh: 'Atualizar',
    emptyManagerHint: 'Crie um evento para iniciar os registros de presença.',
    emptyMemberHint: 'Novos eventos aparecerão aqui assim que forem publicados.',
    eventJoin: '🎥 Entrar',
    eventYoutube: '▶ YouTube',
    eventYoutubeSoon: 'gravada · YouTube em breve',
    eventAttendees: 'presentes',
    eventCheckIn: 'Check-in',
    eventRosterTooltip: 'Lista de presença',
    eventEditTooltip: 'Editar evento',
    msgCheckedIn: 'Presença registrada! ✅',
    msgCheckInError: 'Erro ao registrar presença',
    msgFillTitleDate: 'Preencha título e data',
    msgEventCreated: 'Evento criado ✅',
    msgEventCreateError: 'Erro ao criar evento',
    msgFillTemplateDate: 'Preencha template e data de início',
    msgEventsCreated: '{n} eventos criados ✅',
    msgRecurringError: 'Erro ao criar série',
    msgEventUpdated: 'Evento atualizado ✅',
    msgEventSaveError: 'Erro ao salvar',
    msgError: 'Erro',
    rosterLoading: 'Carregando...',
    rosterNoParticipants: 'Nenhum participante encontrado.',
    rosterCount: '✅ {present}/{total} presentes',
    rosterVisible: 'visíveis',
    rankingNoData: 'Sem dados de ranking ainda',
    rankingNoDataHint: 'Quando os eventos tiverem presença registrada, o ranking aparecerá aqui.',
  };

  let sb: any = null;
  let MEMBER: any = null;
  let CAN_MANAGE = false;
  let CURRENT_EVENT_ID: string | null = null;

  function escapeAttr(s: string): string {
    return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  const ROLE_MAP: Record<string, { label: string; color: string; bg: string }> = {
    manager:      { label: I18N.roleManager,      color: '#003865', bg: '#EFF6FF' },
    tribe_leader: { label: I18N.roleTribeLeader,   color: '#065F46', bg: '#F0FDF4' },
    researcher:   { label: I18N.roleResearcher,    color: '#1E293B', bg: '#F1F5F9' },
    facilitator:  { label: I18N.roleFacilitator,   color: '#92400E', bg: '#FFF7ED' },
    communicator: { label: I18N.roleCommunicator,  color: '#6B21A8', bg: '#FAF5FF' },
    sponsor:      { label: I18N.roleSponsor,       color: '#BE2027', bg: '#FFF0F0' },
    ambassador:   { label: I18N.roleAmbassador,    color: '#0369A1', bg: '#E0F2FE' },
    curator:      { label: I18N.roleCurator,       color: '#78350F', bg: '#FEF3C7' },
    founder:      { label: I18N.roleFounder,       color: '#7C3AED', bg: '#EDE9FE' },
    guest:        { label: I18N.roleGuest,         color: '#6B7280', bg: '#F9FAFB' },
  };

  // ── HELPERS ──
  function roleBadges(roles: string[]): string {
    if (!roles?.length) return '';
    return roles.map(r => {
      const m = ROLE_MAP[r] || { label: r, color: '#6B7280', bg: '#F1F5F9' };
      return `<span style="display:inline-block;padding:2px 7px;border-radius:99px;font-size:10px;font-weight:700;color:${m.color};background:${m.bg};border:1px solid ${m.color}22;margin:1px">${m.label}</span>`;
    }).join('');
  }

  function rolesFromMember(member: any): string[] {
    if (!member) return [];
    const roles: string[] = [];
    const op = member.operational_role;
    if (op && op !== 'guest' && op !== 'none') roles.push(op);
    const desigs: string[] = Array.isArray(member.designations) ? member.designations : [];
    desigs.forEach((d) => {
      if (d && !roles.includes(d)) roles.push(d);
    });
    return roles.length ? roles : ['guest'];
  }

  function toast(msg: string, type = '') {
    (window as any).toast?.(msg, type);
  }
  function loadingRows(count = 3): string {
    return Array.from({ length: count }).map(() => `
      <div class="flex items-center gap-3 px-1 py-3 border-b border-slate-100 last:border-b-0 animate-pulse">
        <div class="w-9 h-9 rounded-full bg-slate-200 flex-shrink-0"></div>
        <div class="flex-1 space-y-1.5">
          <div class="h-3 w-40 bg-slate-200 rounded"></div>
          <div class="h-2.5 w-56 bg-slate-200 rounded"></div>
        </div>
        <div class="h-5 w-14 rounded-full bg-slate-200"></div>
      </div>
    `).join('');
  }

  function today(): string { return new Date().toISOString().slice(0, 10); }

  function fmtDate(d: string): string {
    if (!d) return '';
    return new Date(d + 'T12:00:00').toLocaleDateString(I18N.dateLocale, { day: '2-digit', month: 'short', year: 'numeric' });
  }

  // ── MODAL HELPERS ──
  function closeModal(id: string) {
    const el = document.getElementById(id);
    if (el) { el.classList.add('hidden'); el.classList.remove('flex'); }
  }

  function openModal(id: string) {
    const el = document.getElementById(id);
    if (el) { el.classList.remove('hidden'); el.classList.add('flex'); }
  }

  function rosterFilter(query: string) {
    const rows = document.querySelectorAll('#roster-body tr[data-name]') as NodeListOf<HTMLElement>;
    const q = query.toLowerCase().trim();
    let visible = 0;
    rows.forEach(row => {
      const name = row.dataset.name || '';
      const match = !q || name.includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const countEl = document.getElementById('roster-count');
    if (countEl) {
      countEl.textContent = q ? `${visible}/${rows.length} ${I18N.rosterVisible}` : (countEl.dataset.full || '');
    }
  }

  // ── TABS ──
  function switchTab(el: HTMLElement, name: string) {
    document.querySelectorAll('.tab-btn').forEach(t => {
      t.classList.remove('bg-navy', 'text-white', 'border-navy');
      t.classList.add('bg-white', 'text-slate-500', 'border-slate-200');
    });
    el.classList.remove('bg-white', 'text-slate-500', 'border-slate-200');
    el.classList.add('bg-navy', 'text-white', 'border-navy');
    document.getElementById('tab-events')!.classList.toggle('hidden', name !== 'events');
    document.getElementById('tab-ranking')!.classList.toggle('hidden', name !== 'ranking');
    if (name === 'ranking') loadRanking();
  }

  // ── KPIs ──
  async function loadKPIs() {
    try {
      const { data } = await sb.from('impact_hours_total').select('*').single();
      if (!data) return;
      const hrs = parseFloat(data.total_impact_hours || 0).toFixed(1);
      const pct = parseFloat(data.percent_of_target || 0);
      const el = (id: string) => document.getElementById(id);
      el('kpi-hours')!.textContent = hrs + 'h';
      el('kpi-pct')!.textContent = pct + '%';
      el('kpi-events')!.textContent = data.total_events || '0';
      el('kpi-att')!.textContent = data.total_attendances || '0';
      const bar = el('kpi-bar')!;
      bar.style.width = Math.min(pct, 100) + '%';
      bar.className = 'h-full rounded-full transition-all duration-600 ' +
        (pct >= 70 ? 'bg-emerald-500' : pct >= 35 ? 'bg-yellow-500' : 'bg-red-500');
    } catch (e) {
      console.warn('Attendance: failed to load KPIs:', e);
      toast('Failed to load KPI data.', 'error');
    }
  }

  // ── EVENTS LIST ──
  async function loadEvents() {
    const el = document.getElementById('events-list')!;
    el.innerHTML = loadingRows(3);
    try {
    const { data } = await sb.rpc('get_events_with_attendance', { p_limit: 40, p_offset: 0 });
    if (!data?.length) {
      const cta = CAN_MANAGE
        ? `<button class="mt-3 px-4 py-2 bg-navy text-white rounded-xl text-[12px] font-semibold border-0 cursor-pointer hover:opacity-90" data-action="open-new-event">${I18N.emptyNewEvent}</button>`
        : `<button class="mt-3 px-4 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl text-[12px] font-semibold cursor-pointer hover:bg-slate-50" data-action="refresh-events">${I18N.emptyRefresh}</button>`;
      el.innerHTML = `
        <div class="text-center py-8">
          <div class="text-3xl mb-2">📅</div>
          <div class="font-semibold text-slate-600 text-sm">${I18N.noEvents}</div>
          <p class="text-slate-400 text-[12px] mt-1">${CAN_MANAGE ? I18N.emptyManagerHint : I18N.emptyMemberHint}</p>
          ${cta}
        </div>
      `;
      return;
    }

    const typeLabel: Record<string, string> = { tribe_meeting: I18N.eventTypeTribe, general_meeting: I18N.eventTypeGeneral, webinar: I18N.eventTypeWebinar, other: I18N.eventTypeOther };
    const badgeClass: Record<string, string> = {
      tribe_meeting: 'bg-blue-50 text-navy',
      general_meeting: 'bg-green-50 text-green-800',
      webinar: 'bg-orange-50 text-amber-800',
      other: 'bg-blue-50 text-navy',
    };
    const audienceLabel: Record<string, string> = { leadership: I18N.audienceLeadership, tribe: I18N.audienceTribe, curators: I18N.audienceCurators };

    function eventBadges(ev: any): string {
      const rec = ev.is_recorded ? `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-red-50 text-red-700">${I18N.badgeRecorded}</span>` : '';
      if (ev.audience_level && audienceLabel[ev.audience_level]) {
        return `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold bg-green-50 text-green-800">${audienceLabel[ev.audience_level]}</span>${rec}`;
      }
      return `<span class="px-2 py-0.5 rounded-full text-[11px] font-bold ${badgeClass[ev.type] || 'bg-blue-50 text-navy'}">${typeLabel[ev.type] || ev.type}</span>${rec}`;
    }

    el.innerHTML = data.map((ev: any) => {
      const attIcon = ev.i_attended === true ? '✅' : ev.i_attended === false ? '❌' : '—';
      const attBg = ev.i_attended === true ? 'bg-green-100 text-green-800' : ev.i_attended === false ? 'bg-red-100 text-red-800' : 'bg-slate-100 text-slate-500';
      const canEdit = CAN_MANAGE || ev.created_by === MEMBER.auth_id;
      const canRoster = CAN_MANAGE;

      const isPast = new Date(ev.date + 'T23:59:59') < new Date();
      const linkHtml = ev.meeting_link && !isPast
        ? `<a href="${ev.meeting_link}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-navy font-semibold no-underline px-2 py-0.5 bg-blue-50 rounded-md text-[12px]">${I18N.eventJoin}</a>`
        : '';
      const ytHtml = ev.youtube_url
        ? `<a href="${ev.youtube_url}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 text-white font-semibold no-underline px-2 py-0.5 bg-red-600 rounded-md text-[12px]">${I18N.eventYoutube}</a>`
        : (ev.is_recorded ? `<span class="text-[11px] text-slate-400 italic">${I18N.eventYoutubeSoon}</span>` : '');

      ((window as any).__attendanceEventsById = (window as any).__attendanceEventsById || {})[ev.id] = ev;
      return `
      <div class="py-3.5 border-b border-slate-100 last:border-b-0">
        <div class="flex items-center gap-2.5">
          <div class="w-7 h-7 rounded-full flex items-center justify-center text-[13px] flex-shrink-0 ${attBg}">${attIcon}</div>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-semibold">${ev.title}</div>
            <div class="text-[12px] text-slate-500 mt-0.5 flex items-center gap-2 flex-wrap">
              <span>${fmtDate(ev.date)}</span><span>·</span>
              <span>${ev.duration_minutes}min</span><span>·</span>
              <span>${ev.attendee_count || 0} ${I18N.eventAttendees}</span>
              ${linkHtml ? '<span>·</span>' + linkHtml : ''}
              ${ytHtml ? '<span>·</span>' + ytHtml : ''}
            </div>
          </div>
          <div class="flex gap-1.5 items-center flex-wrap">${eventBadges(ev)}</div>
          <div class="flex gap-1.5 items-center flex-shrink-0">
            ${ev.i_attended !== true
              ? `<button type="button" class="px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-navy text-white border-0 cursor-pointer hover:opacity-90" data-action="check-in" data-event-id="${escapeAttr(ev.id)}">${I18N.eventCheckIn}</button>`
              : `<button class="px-3 py-1.5 rounded-lg text-[12px] font-semibold border-[1.5px] border-navy text-navy bg-transparent cursor-not-allowed opacity-40" disabled>✓</button>`}
            ${canRoster ? `<button type="button" class="px-2 py-1.5 text-sm bg-slate-50 border border-slate-200 rounded-md cursor-pointer" title="${I18N.eventRosterTooltip}" data-action="open-roster" data-event-id="${escapeAttr(ev.id)}" data-event-title="${escapeAttr(ev.title || '')}">📋</button>` : ''}
            ${canEdit ? `<button type="button" class="px-2 py-1.5 text-sm bg-slate-50 border border-slate-200 rounded-md cursor-pointer" title="${I18N.eventEditTooltip}" data-action="edit-event" data-event-id="${escapeAttr(ev.id)}">✏️</button>` : ''}
          </div>
        </div>
      </div>`;
    }).join('');
    } catch (e) {
      console.warn('Attendance: failed to load events:', e);
      el.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">Failed to load events. Please try again later.</div>`;
      toast('Failed to load events.', 'error');
    }
  }

  if (!(window as any).__attendanceDelegationBound) {
    (window as any).__attendanceDelegationBound = true;

    document.addEventListener('click', (e: MouseEvent) => {
      const target = (e.target as HTMLElement).closest('[data-action]') as HTMLElement | null;
      if (!target) return;

      switch (target.dataset.action) {
        case 'open-auth':
          document.dispatchEvent(new CustomEvent('open-auth'));
          break;
        case 'close-modal':
          closeModal(target.dataset.modalId || '');
          break;
        case 'switch-tab':
          switchTab(target, target.dataset.tab || '');
          break;
        case 'open-new-event':
          openNewEventModal();
          break;
        case 'open-recurring':
          openRecurringModal();
          break;
        case 'refresh-events':
          loadEvents();
          break;
        case 'check-in':
          checkIn(target.dataset.eventId || '');
          break;
        case 'open-roster':
          openRoster(target.dataset.eventId || '', target.dataset.eventTitle || '');
          break;
        case 'edit-event': {
          const ev = (window as any).__attendanceEventsById?.[target.dataset.eventId || ''];
          if (ev) openEditEvent(ev);
          break;
        }
        case 'toggle-presence':
          togglePresence(target.dataset.eventId || '', target.dataset.memberId || '', target);
          break;
      }
    });

    document.addEventListener('change', (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (!(target instanceof HTMLSelectElement)) return;
      if (target.id === 'ev-type') updateAudienceFromType('ev-audience', 'ev-type');
      if (target.id === 'rec-type') updateAudienceFromType('rec-audience', 'rec-type');
    });

    document.addEventListener('input', (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.id === 'roster-search') rosterFilter(target.value);
    });

    document.addEventListener('submit', (e: SubmitEvent) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;
      if (target.id === 'new-event-form') {
        e.preventDefault();
        createEvent();
      }
      if (target.id === 'recurring-event-form') {
        e.preventDefault();
        createRecurring();
      }
      if (target.id === 'edit-event-form') {
        e.preventDefault();
        saveEventEdit();
      }
    });

    document.addEventListener('error', (e: Event) => {
      if (e.target instanceof HTMLImageElement && (e.target as HTMLElement).hasAttribute('data-hide-on-error')) {
        (e.target as HTMLImageElement).style.visibility = 'hidden';
      }
    }, true);
  }

  // ── CHECK-IN ──
  async function checkIn(eventId: string) {
    const { data } = await sb.rpc('register_own_presence', { p_event_id: eventId });
    if (data?.success) { toast(I18N.msgCheckedIn, 'success'); loadEvents(); loadKPIs(); }
    else toast(data?.error || I18N.msgCheckInError, 'error');
  }

  // ── AUDIENCE HELPER ──
  function updateAudienceFromType(audienceId: string, typeId: string) {
    const type = (document.getElementById(typeId) as HTMLSelectElement).value;
    const map: Record<string, string> = { tribe_meeting: 'tribe', general_meeting: 'all', webinar: 'all', other: 'all' };
    (document.getElementById(audienceId) as HTMLSelectElement).value = map[type] || 'all';
  }

  // ── NEW EVENT ──
  function openNewEventModal() {
    (document.getElementById('ev-date') as HTMLInputElement).value = today();
    (document.getElementById('ev-link') as HTMLInputElement).value = '';
    openModal('modal-new-event');
  }

  async function createEvent() {
    const title = (document.getElementById('ev-title') as HTMLInputElement).value.trim();
    const type = (document.getElementById('ev-type') as HTMLSelectElement).value;
    const date = (document.getElementById('ev-date') as HTMLInputElement).value;
    const duration = parseInt((document.getElementById('ev-duration') as HTMLInputElement).value);
    const link = (document.getElementById('ev-link') as HTMLInputElement).value.trim() || null;
    const recorded = (document.getElementById('ev-recorded') as HTMLInputElement).checked;
    const audience = (document.getElementById('ev-audience') as HTMLSelectElement).value;
    if (!title || !date) return toast(I18N.msgFillTitleDate, 'error');

    const { data } = await sb.rpc('create_event', {
      p_type: type, p_title: title, p_date: date,
      p_duration_minutes: duration,
      p_tribe_id: type === 'tribe_meeting' ? MEMBER.tribe_id : null,
      p_audience_level: audience
    });
    if (data?.success) {
      if (link || recorded) {
        await sb.rpc('update_event', { p_event_id: data.event_id, p_meeting_link: link, p_is_recorded: recorded });
      }
      closeModal('modal-new-event');
      toast(I18N.msgEventCreated, 'success');
      loadEvents(); loadKPIs();
    } else toast(data?.error || I18N.msgEventCreateError, 'error');
  }

  // ── RECURRING ──
  function openRecurringModal() {
    (document.getElementById('rec-start') as HTMLInputElement).value = today();
    openModal('modal-recurring');
  }

  async function createRecurring() {
    const titleTpl = (document.getElementById('rec-title') as HTMLInputElement).value.trim();
    const type = (document.getElementById('rec-type') as HTMLSelectElement).value;
    const start = (document.getElementById('rec-start') as HTMLInputElement).value;
    const duration = parseInt((document.getElementById('rec-duration') as HTMLInputElement).value);
    const weeks = parseInt((document.getElementById('rec-weeks') as HTMLInputElement).value);
    const link = (document.getElementById('rec-link') as HTMLInputElement).value.trim() || null;
    const recorded = (document.getElementById('rec-recorded') as HTMLInputElement).checked;
    const audience = (document.getElementById('rec-audience') as HTMLSelectElement).value;
    if (!titleTpl || !start) return toast(I18N.msgFillTemplateDate, 'error');

    const { data } = await sb.rpc('create_recurring_weekly_events', {
      p_type: type, p_title_template: titleTpl, p_start_date: start,
      p_duration_minutes: duration, p_n_weeks: weeks,
      p_meeting_link: link,
      p_tribe_id: type === 'tribe_meeting' ? MEMBER.tribe_id : null,
      p_is_recorded: recorded,
      p_audience_level: audience
    });
    if (data?.success) {
      closeModal('modal-recurring');
      toast(I18N.msgEventsCreated.replace('{n}', data.events_created), 'success');
      loadEvents(); loadKPIs();
    } else toast(data?.error || I18N.msgRecurringError, 'error');
  }

  // ── EDIT EVENT ──
  function openEditEvent(ev: any) {
    (document.getElementById('edit-ev-id') as HTMLInputElement).value = ev.id;
    (document.getElementById('edit-ev-title') as HTMLInputElement).value = ev.title || '';
    (document.getElementById('edit-ev-date') as HTMLInputElement).value = ev.date || '';
    (document.getElementById('edit-ev-duration') as HTMLInputElement).value = ev.duration_minutes || 90;
    (document.getElementById('edit-ev-link') as HTMLInputElement).value = ev.meeting_link || '';
    (document.getElementById('edit-ev-youtube') as HTMLInputElement).value = ev.youtube_url || '';
    (document.getElementById('edit-ev-recorded') as HTMLInputElement).checked = ev.is_recorded || false;
    (document.getElementById('edit-ev-audience') as HTMLSelectElement).value = ev.audience_level || 'all';
    openModal('modal-edit-event');
  }

  async function saveEventEdit() {
    const id = (document.getElementById('edit-ev-id') as HTMLInputElement).value;
    const title = (document.getElementById('edit-ev-title') as HTMLInputElement).value.trim();
    const date = (document.getElementById('edit-ev-date') as HTMLInputElement).value;
    const duration = parseInt((document.getElementById('edit-ev-duration') as HTMLInputElement).value);
    const link = (document.getElementById('edit-ev-link') as HTMLInputElement).value.trim() || null;
    const youtube = (document.getElementById('edit-ev-youtube') as HTMLInputElement).value.trim() || null;
    const recorded = (document.getElementById('edit-ev-recorded') as HTMLInputElement).checked;
    const audience = (document.getElementById('edit-ev-audience') as HTMLSelectElement).value;

    const { data } = await sb.rpc('update_event', {
      p_event_id: id, p_title: title, p_date: date,
      p_duration_minutes: duration, p_meeting_link: link,
      p_youtube_url: youtube, p_is_recorded: recorded,
      p_audience_level: audience
    });
    if (data?.success) {
      closeModal('modal-edit-event');
      toast(I18N.msgEventUpdated, 'success');
      loadEvents(); loadKPIs();
    } else toast(data?.error || I18N.msgEventSaveError, 'error');
  }

  // ── ROSTER ──
  async function openRoster(eventId: string, title: string) {
    CURRENT_EVENT_ID = eventId;
    document.getElementById('roster-title')!.textContent = '📋 ' + title;
    // Reset search
    const searchInput = document.getElementById('roster-search') as HTMLInputElement;
    if (searchInput) searchInput.value = '';
    openModal('modal-roster');
    document.getElementById('roster-body')!.innerHTML = `<tr><td colspan="3" class="text-center py-5 text-slate-500">${I18N.rosterLoading}</td></tr>`;
    const { data } = await sb.rpc('get_tribe_event_roster', { p_event_id: eventId });
    const tbody = document.getElementById('roster-body')!;
    if (!data?.length) {
      tbody.innerHTML = `<tr><td colspan="3" class="text-center text-slate-500 py-5">${I18N.rosterNoParticipants}</td></tr>`;
      return;
    }
    // Sort: present first, then alphabetically
    const sorted = [...data].sort((a: any, b: any) => {
      if (a.present !== b.present) return a.present ? -1 : 1;
      return (a.name || '').localeCompare(b.name || '');
    });
    const presentCount = sorted.filter((m: any) => m.present).length;
    // Update counter
    const countEl = document.getElementById('roster-count');
    if (countEl) {
      const text = I18N.rosterCount.replace('{present}', String(presentCount)).replace('{total}', String(sorted.length));
      countEl.textContent = text;
      countEl.dataset.full = text;
    }
    tbody.innerHTML = sorted.map((m: any) => `
      <tr class="roster-row" data-name="${(m.name || '').toLowerCase()}">
        <td class="px-3 py-2.5 border-b border-slate-100">
          <div class="flex items-center gap-2">
            <img class="w-7 h-7 rounded-full object-cover bg-slate-100 flex-shrink-0" src="${m.photo_url || ''}" data-hide-on-error alt="">
            <span class="${m.present ? 'font-semibold' : ''}">${m.name}</span>
          </div>
        </td>
        <td class="px-3 py-2.5 border-b border-slate-100">${roleBadges(rolesFromMember(m))}</td>
        <td class="px-3 py-2.5 border-b border-slate-100 text-center">
          ${CAN_MANAGE
            ? `<button type="button" class="toggle-btn ${m.present ? 'on' : 'off'}" id="tog-${m.id}"
                 data-action="toggle-presence" data-event-id="${escapeAttr(eventId)}" data-member-id="${escapeAttr(m.id)}"></button>`
            : `<div class="w-7 h-7 rounded-full flex items-center justify-center text-[13px] mx-auto ${m.present ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${m.present ? '✅' : '❌'}</div>`
          }
        </td>
      </tr>`).join('');
  }

  async function togglePresence(eventId: string, memberId: string, btn: HTMLElement) {
    const isOn = btn.classList.contains('on');
    const { data } = await sb.rpc('mark_member_present', { p_event_id: eventId, p_member_id: memberId, p_present: !isOn });
    if (data?.success) { btn.classList.toggle('on', !isOn); btn.classList.toggle('off', isOn); loadKPIs(); }
    else toast(data?.error || I18N.msgError, 'error');
  }

  // ── RANKING ──
  async function loadRanking() {
    const el = document.getElementById('ranking-list')!;
    el.innerHTML = loadingRows(4);
    try {
      const { data } = await sb.from('member_attendance_summary').select('*').limit(50);
      if (!data?.length) {
        el.innerHTML = `
          <div class="text-center py-8">
            <div class="text-3xl mb-2">📊</div>
            <div class="font-semibold text-slate-600 text-sm">${I18N.rankingNoData}</div>
            <p class="text-slate-400 text-[12px] mt-1">${I18N.rankingNoDataHint}</p>
          </div>
        `;
        return;
      }
      const max = Math.max(...data.map((m: any) => parseFloat(m.hours_attended || 0)), 1);
      el.innerHTML = data.map((m: any, i: number) => `
        <div class="flex items-center gap-2.5 py-2 border-b border-slate-100 last:border-b-0">
          <div class="text-[13px] font-bold text-slate-500 w-6 text-center flex-shrink-0">${i + 1}</div>
          <img class="w-8 h-8 rounded-full object-cover bg-slate-100 flex-shrink-0" src="${m.photo_url || ''}" data-hide-on-error alt="">
          <div class="flex-1 min-w-0">
            <div class="text-[13px] font-semibold truncate">${m.name}</div>
            <div>${roleBadges(rolesFromMember(m))}</div>
          </div>
          <div class="w-20 h-1.5 bg-slate-200 rounded-full overflow-hidden flex-shrink-0">
            <div class="h-full bg-crimson rounded-full" style="width:${(m.hours_attended / max * 100).toFixed(1)}%"></div>
          </div>
          <div class="text-[13px] text-navy font-bold flex-shrink-0">${m.hours_attended || 0}h</div>
        </div>`).join('');
    } catch (e) {
      console.warn('Attendance: failed to load ranking:', e);
      el.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">Failed to load ranking. Please try again later.</div>`;
      toast('Failed to load ranking.', 'error');
    }
  }

  // ── BOOT ──
  function showApp() {
    document.getElementById('loading-gate')?.classList.add('hidden');
    document.getElementById('auth-gate')?.classList.add('hidden');
    document.getElementById('auth-gate')?.classList.remove('flex');
    document.getElementById('app')!.classList.remove('hidden');
  }

  function showAuthGate() {
    document.getElementById('loading-gate')?.classList.add('hidden');
    document.getElementById('auth-gate')?.classList.remove('hidden');
    document.getElementById('auth-gate')?.classList.add('flex');
    document.getElementById('app')!.classList.add('hidden');
  }

  function showGuestNotRegistered() {
    showAuthGate();
    document.getElementById('auth-not-found-msg')?.classList.remove('hidden');
    const authBtn = document.getElementById('attendance-auth-btn');
    if (authBtn) authBtn.style.display = 'none';
  }

  async function onMemberReady() {
    CAN_MANAGE = hasMinimumTier(resolveTierFromMember(MEMBER), 'leader');
    if (CAN_MANAGE) {
      document.getElementById('tab-new-event')?.classList.remove('hidden');
      document.getElementById('tab-recurring')?.classList.remove('hidden');
    }
    showApp();
    loadKPIs();
    loadEvents();
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    // Listen for future auth changes
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest') {
        MEMBER = e.detail;
        onMemberReady();
      } else if (!e.detail) {
        showAuthGate();
      }
    }) as EventListener);

    window.addEventListener('nav:guest-with-session', (() => {
      showGuestNotRegistered();
    }) as EventListener);

    // 1) Check if nav already has a member loaded
    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') {
      MEMBER = m;
      onMemberReady();
      return;
    }

    // 2) Nav might not be ready yet — check session directly
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && getMemberRole(data) !== 'guest') {
        MEMBER = data;
        onMemberReady();
        return;
      }
      // Authenticated but not registered as member
      showGuestNotRegistered();
      return;
    }

    // 3) No session at all — show auth gate
    showAuthGate();
  }

  boot();
</script>
