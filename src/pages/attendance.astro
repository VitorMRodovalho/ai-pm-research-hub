  async function createRecurring() {
    const titleTpl = (document.getElementById('rec-title') as HTMLInputElement).value.trim();
    const type = (document.getElementById('rec-type') as HTMLInputElement).value;
    const start = (document.getElementById('rec-start') as HTMLInputElement).value;
    const duration = parseInt((document.getElementById('rec-duration') as HTMLInputElement).value);
    const weeks = parseInt((document.getElementById('rec-weeks') as HTMLInputElement).value);
    const link = (document.getElementById('rec-link') as HTMLInputElement).value.trim() || null;
    const recorded = (document.getElementById('rec-recorded') as HTMLInputElement).checked;
    const audience = (document.getElementById('rec-audience') as HTMLSelectElement).value;
    const tagIds = getSelectedTagIds('rec-selected-tags');
    if (!titleTpl || !start) return toast(I18N.msgFillTemplateDate, 'error');

    try {
      const { data, error } = await sb.rpc('create_recurring_weekly_events', {
        p_type: type, p_title_template: titleTpl, p_start_date: start,
        p_duration_minutes: duration, p_n_weeks: weeks,
        p_meeting_link: link,
        p_tribe_id: type === 'tribe_meeting' ? MEMBER.tribe_id : null,
        p_is_recorded: recorded,
        p_audience_level: audience
      });
      if (error) throw error;
      if (data?.success) {
        // W140: assign tags and audience to all created events
        if (tagIds.length && data.event_ids?.length) {
          for (const eid of data.event_ids) {
            await assignEventTagsAndAudience(eid, tagIds, audience);
          }
        }
        closeModal('modal-recurring');
        toast(I18N.msgEventsCreated.replace('{n}', data.events_created), 'success');
        loadEvents(); loadKPIs();
      } else toast(data?.error || I18N.msgRecurringError, 'error');
    } catch (e: any) {
      toast(e?.message || I18N.msgRecurringError, 'error');
      console.error('create_recurring_weekly_events failed:', e);
    }
  }

  // ── TRIBES CACHE for modal ──
  let _tribesCache: any[] = [];
  async function ensureTribesLoaded() {
    if (_tribesCache.length > 0) return _tribesCache;
    const { data } = await sb.from('tribes').select('id, name').eq('is_active', true).order('id');
    _tribesCache = data || [];
    // Populate both edit and create tribe selects
    for (const selId of ['edit-ev-tribe-select', 'ev-tribe-select']) {
      const sel = document.getElementById(selId) as HTMLSelectElement;
      if (sel) {
        while (sel.options.length > 1) sel.remove(1);
        for (const t of _tribesCache) {
          const opt = document.createElement('option');
          opt.value = String(t.id);
          opt.textContent = t.name;
          sel.appendChild(opt);
        }
      }
    }
    return _tribesCache;
  }

