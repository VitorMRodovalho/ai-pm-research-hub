  // ── NEW EVENT ──
  async function openNewEventModal() {
    (document.getElementById('ev-title') as HTMLInputElement).value = '';
    (document.getElementById('ev-date') as HTMLInputElement).value = today();
    (document.getElementById('ev-duration') as HTMLInputElement).value = '90';
    (document.getElementById('ev-link') as HTMLInputElement).value = '';
    (document.getElementById('ev-type') as HTMLSelectElement).value = 'geral';
    (document.getElementById('ev-nature') as HTMLSelectElement).value = 'avulsa';
    (document.getElementById('ev-visibility') as HTMLSelectElement).value = 'public';
    (document.getElementById('ev-agenda-text') as HTMLTextAreaElement).value = '';
    (document.getElementById('ev-agenda-url') as HTMLInputElement).value = '';
    (document.getElementById('ev-external-attendees') as HTMLInputElement).value = '';
    // Load tribes for tribe selector
    await ensureTribesLoaded();
    const tribeSelCreate = document.getElementById('ev-tribe-select') as HTMLSelectElement;
    if (tribeSelCreate && tribeSelCreate.options.length <= 1) {
      for (const t of _tribesCache) {
        const opt = document.createElement('option');
        opt.value = String(t.id);
        opt.textContent = t.name;
        tribeSelCreate.appendChild(opt);
      }
    }
    // Show/hide tribe wrapper based on type
    const tribeWrapper = document.getElementById('ev-tribe-wrapper')!;
    tribeWrapper.classList.add('hidden');
    const typeSelect = document.getElementById('ev-type') as HTMLSelectElement;
    typeSelect.onchange = () => {
      if (typeSelect.value === 'tribo') {
        tribeWrapper.classList.remove('hidden');
      } else {
        tribeWrapper.classList.add('hidden');
      }
      // Auto-set visibility for certain types
      const visEl = document.getElementById('ev-visibility') as HTMLSelectElement;
      if (['lideranca', '1on1'].includes(typeSelect.value)) {
        visEl.value = 'leadership';
      } else if (typeSelect.value === 'geral' || typeSelect.value === 'kickoff') {
        visEl.value = 'public';
      }
    };
    // For leaders: lock type to 'tribo' and lock tribe to own tribe
    if (MEMBER?.role === 'leader' && MEMBER?.tribe_id) {
      typeSelect.value = 'tribo';
      typeSelect.disabled = true;
      tribeWrapper.classList.remove('hidden');
      tribeSelCreate.value = String(MEMBER.tribe_id);
      tribeSelCreate.disabled = true;
    } else {
      typeSelect.disabled = false;
      tribeSelCreate.disabled = false;
    }
    openModal('modal-new-event');
  }

  async function createEvent() {
    const title = (document.getElementById('ev-title') as HTMLInputElement).value.trim();
    const type = (document.getElementById('ev-type') as HTMLSelectElement).value;
    const date = (document.getElementById('ev-date') as HTMLInputElement).value;
    const duration = parseInt((document.getElementById('ev-duration') as HTMLInputElement).value);
    const link = (document.getElementById('ev-link') as HTMLInputElement).value.trim() || null;
    const tribeId = type === 'tribo' ? parseInt((document.getElementById('ev-tribe-select') as HTMLSelectElement).value) : null;
    const nature = (document.getElementById('ev-nature') as HTMLSelectElement).value;
    const visibility = (document.getElementById('ev-visibility') as HTMLSelectElement)?.value || 'public';
    const agendaText = (document.getElementById('ev-agenda-text') as HTMLTextAreaElement)?.value?.trim() || null;
    const agendaUrl = (document.getElementById('ev-agenda-url') as HTMLInputElement)?.value?.trim() || null;
    const externalAttendees = (document.getElementById('ev-external-attendees') as HTMLInputElement)?.value?.trim() || null;
    const tagIds = getSelectedTagIds('ev-selected-tags');
    if (!title || !date) return toast(I18N.msgFillTitleDate, 'error');

    try {
      const { data, error } = await sb.rpc('create_event', {
        p_type: type, p_title: title, p_date: date,
        p_duration_minutes: duration,
        p_tribe_id: tribeId,
        p_meeting_link: link,
        p_nature: nature,
        p_visibility: visibility,
        p_agenda_text: agendaText,
        p_agenda_url: agendaUrl,
        p_external_attendees: externalAttendees ? externalAttendees.split('\n').map(s => s.trim()).filter(Boolean) : null,
      });
      if (error) throw error;
      if (data?.success) {
        // W140: assign tags
        if (tagIds.length) {
          await assignEventTagsAndAudience(data.event_id, tagIds, 'all_active_operational');
        }
        closeModal('modal-new-event');
        toast(I18N.msgEventCreated, 'success');
        loadEvents(); loadKPIs();
      } else toast(data?.error || I18N.msgEventCreateError, 'error');
    } catch (e: any) {
      toast(e?.message || I18N.msgEventCreateError, 'error');
      console.error('create_event failed:', e);
    }
  }

