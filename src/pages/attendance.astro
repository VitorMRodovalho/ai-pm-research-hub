      setTagPickerFromIds('edit-ev-tag-picker', 'edit-ev-tags-container', 'edit-ev-selected-tags', tagIds);
    } catch (_) {
      setTagPickerFromIds('edit-ev-tag-picker', 'edit-ev-tags-container', 'edit-ev-selected-tags', []);
    }
    // Recurrence group awareness
    (document.getElementById('edit-ev-recurrence-group') as HTMLInputElement).value = ev.recurrence_group || '';
    const recBanner = document.getElementById('edit-ev-recurrence-banner')!;
    const recLabel = document.getElementById('edit-ev-recurrence-label')!;
    if (ev.recurrence_group) {
      recBanner.classList.remove('hidden');
      recLabel.textContent = I18N.recurrenceTitle;
    } else {
      recBanner.classList.add('hidden');
    }
    applyEditContext(ev);
    openModal('modal-edit-event');
  }

  // Helper: show recurrence scope dialog (returns 'this' | 'future' | null for cancel)
  function askRecurrenceScope(): Promise<'this' | 'future' | null> {
    return new Promise((resolve) => {
      const overlay = document.createElement('div');
      overlay.className = 'fixed inset-0 bg-black/50 z-[200] flex items-center justify-center p-4';
      overlay.innerHTML = `
        <div class="bg-[var(--surface-card)] rounded-2xl w-full max-w-[380px] p-5 shadow-xl">
          <h4 class="text-base font-bold text-navy mb-2">${I18N.recurrenceTitle}</h4>
          <p class="text-[.82rem] text-[var(--text-secondary)] mb-4">${I18N.recurrencePrompt}</p>
          <div class="flex flex-col gap-2">
            <button data-scope="this" class="px-4 py-2.5 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--surface-hover)] cursor-pointer">${I18N.recurrenceThisOnly}</button>
            <button data-scope="future" class="px-4 py-2.5 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer">${I18N.recurrenceThisFuture}</button>
          </div>
        </div>`;
      document.body.appendChild(overlay);
      overlay.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-scope]') as HTMLElement | null;
        if (btn) {
          overlay.remove();
          resolve(btn.dataset.scope as 'this' | 'future');
        } else if (e.target === overlay) {
          overlay.remove();
          resolve(null);
        }
      });
    });
  }

  async function saveEventEdit() {
    const id = (document.getElementById('edit-ev-id') as HTMLInputElement).value;
    const title = (document.getElementById('edit-ev-title') as HTMLInputElement).value.trim();
    const date = (document.getElementById('edit-ev-date') as HTMLInputElement).value;
    const duration = parseInt((document.getElementById('edit-ev-duration') as HTMLInputElement).value);
    const link = (document.getElementById('edit-ev-link') as HTMLInputElement).value.trim() || null;
    const youtube = (document.getElementById('edit-ev-youtube') as HTMLInputElement).value.trim() || null;
    const recorded = (document.getElementById('edit-ev-recorded') as HTMLInputElement).checked;
    const audience = (document.getElementById('edit-ev-audience') as HTMLSelectElement).value;
    const editType = (document.getElementById('edit-ev-type') as HTMLSelectElement).value;
    const nature = (document.getElementById('edit-ev-nature') as HTMLSelectElement).value;
    const visibility = (document.getElementById('edit-ev-visibility') as HTMLSelectElement).value;
    const recordingUrl = (document.getElementById('edit-ev-recording-url') as HTMLInputElement).value.trim() || null;
    const externalAttendees = (document.getElementById('edit-ev-external-attendees') as HTMLInputElement).value.trim() || null;
    const tribeId = editType === 'tribo' ? (document.getElementById('edit-ev-tribe-select') as HTMLSelectElement).value || null : null;
    const tagIds = getSelectedTagIds('edit-ev-selected-tags');
    const recurrenceGroup = (document.getElementById('edit-ev-recurrence-group') as HTMLInputElement).value;
    const timeStart = (document.getElementById('edit-ev-time-start') as HTMLInputElement).value || null;
    const notes = (document.getElementById('edit-ev-notes') as HTMLTextAreaElement).value.trim() || null;

    // If recurring event, ask scope
    let scope: 'this' | 'future' = 'this';
    if (recurrenceGroup) {
      const choice = await askRecurrenceScope();
      if (!choice) return; // cancelled
      scope = choice;
    }

    try {
      if (scope === 'future' && recurrenceGroup) {
        // Update future events in recurrence group (shared fields, including type/nature)
        const { data: futureData, error: futureError } = await sb.rpc('update_future_events_in_group', {
          p_event_id: id,
          p_new_time_start: timeStart,
          p_duration_minutes: duration,
          p_meeting_link: link,
          p_notes: notes,
          p_visibility: visibility,
          p_type: editType,
          p_nature: nature,
        });
        if (futureError) throw futureError;
        // Also update this specific event's individual fields (title, date, type, etc.)
        const { data, error } = await sb.rpc('update_event', {
          p_event_id: id, p_title: title, p_date: date,
          p_duration_minutes: duration, p_meeting_link: link,
          p_youtube_url: youtube, p_is_recorded: recorded,
          p_audience_level: audience
        });
        if (error) throw error;
        const updateFields: Record<string, any> = { type: editType, nature, visibility };
        if (timeStart) updateFields.time_start = timeStart;
        if (notes !== undefined) updateFields.notes = notes;
        if (recordingUrl !== undefined) updateFields.recording_url = recordingUrl;
        if (externalAttendees !== undefined) updateFields.external_attendees = externalAttendees;
        if (tribeId !== null) {
          updateFields.tribe_id = tribeId;
          // ADR-0015 dual-write: derive initiative_id from legacy_tribe_id so the
          // write does not depend on sync_initiative_from_tribe trigger (to be
          // dropped in Phase 2).
          const { data: initRow } = await sb.from('initiatives')
            .select('id').eq('legacy_tribe_id', tribeId).limit(1).maybeSingle();
          updateFields.initiative_id = initRow?.id || null;
        }
        await sb.from('events').update(updateFields).eq('id', id);
        await assignEventTagsAndAudience(id, tagIds, audience);
        closeModal('modal-edit-event');
        const count = futureData?.updated_count || 0;
        toast(`${count} ${I18N.recurrenceFutureUpdated}`, 'success');
        loadEvents(); loadKPIs();
      } else {
        // Update this event only (original behavior)
        const { data, error } = await sb.rpc('update_event', {
          p_event_id: id, p_title: title, p_date: date,
          p_duration_minutes: duration, p_meeting_link: link,
          p_youtube_url: youtube, p_is_recorded: recorded,
          p_audience_level: audience
        });
        if (error) throw error;
        if (data?.success) {
          const updateFields: Record<string, any> = { type: editType, nature, visibility };
          if (timeStart) updateFields.time_start = timeStart;
          if (notes !== undefined) updateFields.notes = notes;
          if (recordingUrl !== undefined) updateFields.recording_url = recordingUrl;
          if (externalAttendees !== undefined) updateFields.external_attendees = externalAttendees;
          if (tribeId !== null) {
            updateFields.tribe_id = tribeId;
            // ADR-0015 dual-write: derive initiative_id so the write does not
            // depend on sync_initiative_from_tribe trigger (dropped in Phase 2).
            const { data: initRow } = await sb.from('initiatives')
              .select('id').eq('legacy_tribe_id', tribeId).limit(1).maybeSingle();
            updateFields.initiative_id = initRow?.id || null;
          }
          await sb.from('events').update(updateFields).eq('id', id);
          await assignEventTagsAndAudience(id, tagIds, audience);
          closeModal('modal-edit-event');
          toast(I18N.msgEventUpdated, 'success');
          loadEvents(); loadKPIs();
        } else toast(data?.error || I18N.msgEventSaveError, 'error');
      }
    } catch (e: any) {
      toast(e?.message || I18N.msgEventSaveError, 'error');
      console.error('update_event failed:', e);
    }
  }

  // ── ROSTER ──
  async function openRoster(eventId: string, title: string) {
    CURRENT_EVENT_ID = eventId;
    const rosterTitle = document.getElementById('roster-title');
    if (rosterTitle) rosterTitle.textContent = '📋 ' + title;
    // Reset search
    const searchInput = document.getElementById('roster-search') as HTMLInputElement;
    if (searchInput) searchInput.value = '';
    openModal('modal-roster');
    // Show bulk buttons for leaders+
    const bulkAllBtn = document.getElementById('roster-bulk-all');
    const bulkConfirmBtn = document.getElementById('roster-bulk-confirm');
    if (CAN_MANAGE) {
      bulkAllBtn?.classList.remove('hidden');
      bulkConfirmBtn?.classList.remove('hidden');
    } else {
      bulkAllBtn?.classList.add('hidden');
      bulkConfirmBtn?.classList.add('hidden');
    }
    const rosterBody = document.getElementById('roster-body');
    if (rosterBody) rosterBody.innerHTML = `<tr><td colspan="3" class="text-center py-5 text-[var(--text-secondary)]">${I18N.rosterLoading}</td></tr>`;
    let data: any;
    try {
      const res = await sb.rpc('get_tribe_event_roster', { p_event_id: eventId });
      if (res.error) throw res.error;
      data = res.data;
    } catch (e: any) {
      toast(e?.message || I18N.msgError, 'error');
      console.error('get_tribe_event_roster failed:', e);
      if (rosterBody) rosterBody.innerHTML = `<tr><td colspan="3" class="text-center py-5 text-red-500 text-sm">Error loading roster</td></tr>`;
      return;
    }
    const tbody = rosterBody;
    if (!tbody) return;
    if (!data?.length) {
      tbody.innerHTML = `<tr><td colspan="3" class="text-center text-[var(--text-secondary)] py-5">${I18N.rosterNoParticipants}</td></tr>`;
      return;
    }
    // Sort: present first, then alphabetically
    const sorted = [...data].sort((a: any, b: any) => {
      if (a.present !== b.present) return a.present ? -1 : 1;
      return (a.name || '').localeCompare(b.name || '');
    });
    const presentCount = sorted.filter((m: any) => m.present).length;
    // Update counter
    const countEl = document.getElementById('roster-count');
    if (countEl) {
      const text = I18N.rosterCount.replace('{present}', String(presentCount)).replace('{total}', String(sorted.length));
      countEl.textContent = text;
      countEl.dataset.full = text;
    }
    tbody.innerHTML = sorted.map((m: any) => `
      <tr class="roster-row" data-name="${(m.name || '').toLowerCase()}">
        <td class="px-3 py-2.5 border-b border-[var(--border-subtle)]">
          <div class="flex items-center gap-2">
            <img class="w-7 h-7 rounded-full object-cover bg-[var(--surface-section-cool)] flex-shrink-0" src="${m.photo_url || ''}" data-hide-on-error alt="">
            <span class="${m.present ? 'font-semibold' : ''}">${m.name}</span>
          </div>
        </td>
        <td class="px-3 py-2.5 border-b border-[var(--border-subtle)]">${roleBadges(rolesFromMember(m))}</td>
        <td class="px-3 py-2.5 border-b border-[var(--border-subtle)] text-center">
          ${CAN_MANAGE
            ? `<button type="button" class="toggle-btn ${m.present ? 'on' : 'off'}" id="tog-${m.id}"
                 data-action="toggle-presence" data-event-id="${escapeAttr(eventId)}" data-member-id="${escapeAttr(m.id)}"></button>`
            : `<div class="w-7 h-7 rounded-full flex items-center justify-center text-[13px] mx-auto ${m.present ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}">${m.present ? '✅' : '❌'}</div>`
          }
        </td>
      </tr>`).join('');
    // Load showcases after roster renders
    await loadShowcases(eventId);
  }

  /* ── Showcase logic in roster modal ── */
  const SHOWCASE_EMOJI: Record<string, string> = {
    case_study: '🎓', tool_review: '🔧', prompt_week: '💡', quick_insight: '⚡', awareness: '🌍',
  };
  const SHOWCASE_LABELS: Record<string, string> = {
    case_study: 'Case de Sucesso', tool_review: 'Review de Ferramenta', prompt_week: 'Prompt da Semana',
    quick_insight: 'Insight Rápido', awareness: 'Sensibilização',
  };
  const SHOWCASE_XP: Record<string, number> = {
    case_study: 25, tool_review: 20, prompt_week: 20, quick_insight: 15, awareness: 15,
  };

  async function loadShowcases(eventId: string) {
    const listEl = document.getElementById('roster-showcase-list');
    const addBtn = document.getElementById('roster-add-showcase-btn');
    const memberSelect = document.getElementById('showcase-member-select') as HTMLSelectElement;
    if (!listEl) return;

    // Load showcases from event_showcases table
    const { data: showcases, error } = await sb.from('event_showcases')
      .select('id, member_id, showcase_type, title, duration_min, members!event_showcases_member_id_fkey(name)')
      .eq('event_id', eventId)
      .order('created_at');

    if (error) { console.error('loadShowcases:', error); return; }

    // Show add button for managers
    if (CAN_MANAGE) addBtn?.classList.remove('hidden');
    else addBtn?.classList.add('hidden');

    // Render showcase list
    if (!showcases?.length) {
      listEl.innerHTML = '<p class="text-[11px] text-[var(--text-muted)] italic">Nenhum showcase registrado.</p>';
    } else {
      listEl.innerHTML = (showcases as any[]).map((s: any) => {
        const emoji = SHOWCASE_EMOJI[s.showcase_type] || '🎤';
        const label = SHOWCASE_LABELS[s.showcase_type] || s.showcase_type;
        const xp = SHOWCASE_XP[s.showcase_type] || 15;
        const memberName = s.members?.name || '?';
        return `<div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[var(--surface-base)] text-[12px]">
          <span>${emoji}</span>
          <span class="font-semibold text-[var(--text-primary)]">${memberName}</span>
          <span class="text-[var(--text-muted)] text-[11px]">${label}</span>
          ${s.title ? `<span class="text-[var(--text-secondary)] text-[11px]">— ${s.title}</span>` : ''}
          ${s.duration_min ? `<span class="text-[var(--text-muted)] text-[10px]">(${s.duration_min}min)</span>` : ''}
          <span class="ml-auto text-[11px] font-bold text-red-600">+${xp} XP</span>
          ${CAN_MANAGE ? `<button type="button" class="text-[var(--text-muted)] hover:text-red-500 text-[11px] cursor-pointer bg-transparent border-0 p-0" data-action="remove-showcase" data-showcase-id="${s.id}">✕</button>` : ''}
        </div>`;
      }).join('');
    }

    // Populate member dropdown with present members (max 2 filter)
    if (memberSelect) {
      const showcaseCounts: Record<string, number> = {};
      (showcases || []).forEach((s: any) => { showcaseCounts[s.member_id] = (showcaseCounts[s.member_id] || 0) + 1; });
      const presentToggles = document.querySelectorAll('#roster-body .toggle-btn.on') as NodeListOf<HTMLElement>;
      memberSelect.innerHTML = '<option value="">—</option>';
      presentToggles.forEach((btn) => {
        const memberId = btn.dataset.memberId || '';
        if ((showcaseCounts[memberId] || 0) < 2) {
          const row = btn.closest('tr');
          const name = row?.querySelector('span')?.textContent || '?';
          memberSelect.innerHTML += `<option value="${memberId}">${name}</option>`;
        }
      });
    }
  }

  async function saveShowcase() {
    const memberSelect = document.getElementById('showcase-member-select') as HTMLSelectElement;
    const typeSelect = document.getElementById('showcase-type-select') as HTMLSelectElement;
    const titleInput = document.getElementById('showcase-title-input') as HTMLInputElement;
    const durationInput = document.getElementById('showcase-duration-input') as HTMLInputElement;
    const memberId = memberSelect?.value;
    if (!memberId || !CURRENT_EVENT_ID) return;

    try {
      const { data, error } = await sb.rpc('register_event_showcase', {
        p_event_id: CURRENT_EVENT_ID, p_member_id: memberId,
        p_showcase_type: typeSelect?.value || 'tool_review',
        p_title: titleInput?.value?.trim() || null,
        p_duration_min: durationInput?.value ? parseInt(durationInput.value) : null,
      });
      if (error) throw error;
      if (data?.error) throw new Error(data.error);
      toast('🎤 Showcase registrado! +' + (SHOWCASE_XP[typeSelect?.value] || 15) + ' XP', 'success');
      titleInput.value = ''; durationInput.value = '';
      document.getElementById('roster-showcase-form')?.classList.add('hidden');
      await loadShowcases(CURRENT_EVENT_ID);
    } catch (e: any) { toast(e?.message || 'Erro', 'error'); }
  }

  async function removeShowcase(showcaseId: string) {
    try {
      const { data, error } = await sb.rpc('remove_event_showcase', { p_showcase_id: showcaseId });
      if (error) throw error;
      if (data?.error) throw new Error(data.error);
      toast('Showcase removido', 'success');
      if (CURRENT_EVENT_ID) await loadShowcases(CURRENT_EVENT_ID);
    } catch (e: any) { toast(e?.message || 'Erro', 'error'); }
  }

  async function togglePresence(eventId: string, memberId: string, btn: HTMLElement) {
    const isOn = btn.classList.contains('on');
    try {
      const { data, error } = await sb.rpc('mark_member_present', { p_event_id: eventId, p_member_id: memberId, p_present: !isOn });
      if (error) throw error;
      if (data?.success) { btn.classList.toggle('on', !isOn); btn.classList.toggle('off', isOn); loadKPIs(); }
      else toast(data?.error || I18N.msgError, 'error');
    } catch (e: any) {
      toast(e?.message || I18N.msgError, 'error');
      console.error('mark_member_present failed:', e);
    }
  }

  // ── BULK ROSTER ──
  function bulkSelectAll() {
    const toggles = document.querySelectorAll('#roster-body .toggle-btn.off') as NodeListOf<HTMLElement>;
    toggles.forEach(btn => {
      btn.classList.remove('off');
      btn.classList.add('on');
    });
  }

  async function bulkConfirmPresence() {
    if (!CURRENT_EVENT_ID) return;
    // Gather all member IDs that are toggled ON
    const togglesOn = document.querySelectorAll('#roster-body .toggle-btn.on') as NodeListOf<HTMLElement>;
    const memberIds: string[] = [];
    togglesOn.forEach(btn => {
      const mid = btn.dataset.memberId;
      if (mid) memberIds.push(mid);
    });
    if (!memberIds.length) return toast(I18N.msgError, 'error');

    try {
      const { data, error } = await sb.rpc('admin_bulk_mark_attendance', {
        p_event_id: CURRENT_EVENT_ID,
        p_member_ids: memberIds,
        p_present: true
      });
      if (error) throw error;
      if (data?.success) {
        toast(I18N.bulkSuccess.replace('{n}', String(data.marked)), 'success');
        loadKPIs();
        // Refresh roster
        const titleEl = document.getElementById('roster-title');
        openRoster(CURRENT_EVENT_ID, titleEl?.textContent?.replace('📋 ', '') || '');
      } else toast(data?.error || I18N.msgError, 'error');
    } catch (e: any) {
      toast(e?.message || I18N.msgError, 'error');
      console.error('admin_bulk_mark_attendance failed:', e);
    }
  }

  // ── RANKING (W140: uses get_attendance_panel for corrected denominators) ──
  let RANKING_DATA: any[] = [];

  function renderRankingRows(data: any[]) {
    const el = document.getElementById('ranking-list')!;
    if (!data.length) {
      el.innerHTML = `
        <div class="text-center py-8">
          <div class="text-3xl mb-2">📊</div>
          <div class="font-semibold text-[var(--text-secondary)] text-sm">${I18N.rankingNoData}</div>
          <p class="text-[var(--text-muted)] text-[12px] mt-1">${I18N.rankingNoDataHint}</p>
        </div>
      `;
      return;
    }
    const sorted = [...data].sort((a: any, b: any) => {
      if (b.combined_pct !== a.combined_pct) return b.combined_pct - a.combined_pct;
      return (a.member_name || '').localeCompare(b.member_name || '');
    });
    el.innerHTML = sorted.map((m: any, i: number) => {
      const pctColor = m.combined_pct >= 75 ? 'bg-emerald-500' : m.combined_pct >= 50 ? 'bg-yellow-500' : m.combined_pct > 0 ? 'bg-red-500' : 'bg-gray-300';
      const totalMand = (m.general_mandatory || 0) + (m.tribe_mandatory || 0);
      const totalAtt = (m.general_attended || 0) + (m.tribe_attended || 0);
      const riskBadge = m.dropout_risk ? '<span class="px-1.5 py-0.5 rounded-full text-[9px] font-bold bg-red-100 text-red-700 ml-1">risco</span>' : '';
      return `
      <div class="flex items-center gap-2.5 py-2 border-b border-[var(--border-subtle)] last:border-b-0">
        <div class="text-[13px] font-bold text-[var(--text-secondary)] w-6 text-center flex-shrink-0">${i + 1}</div>
        <div class="flex-1 min-w-0">
          <div class="text-[13px] font-semibold truncate">${m.member_name}${riskBadge}</div>
          <div class="text-[11px] text-[var(--text-muted)]">${totalAtt}/${totalMand} obrigatórias${m.tribe_name ? ' · ' + m.tribe_name : ''}</div>
        </div>
        <div class="w-20 h-1.5 bg-[var(--surface-section-cool)] rounded-full overflow-hidden flex-shrink-0">
          <div class="h-full ${pctColor} rounded-full" style="width:${Math.min(m.combined_pct, 100).toFixed(1)}%"></div>
        </div>
        <div class="text-[13px] text-navy font-bold flex-shrink-0 w-10 text-right">${m.combined_pct}%</div>
      </div>`;
    }).join('');
  }

  async function loadRanking() {
    const el = document.getElementById('ranking-list')!;
    el.innerHTML = loadingRows(4);
    try {
      const { data, error } = await sb.rpc('get_attendance_panel');
      if (error) throw error;
      RANKING_DATA = data || [];
      renderRankingRows(RANKING_DATA);

      // Bind role + designation filters
      const roleFilter = document.getElementById('ranking-role-filter') as HTMLSelectElement | null;
      const desigFilter = document.getElementById('ranking-designation-filter') as HTMLSelectElement | null;

      function applyRankingFilters() {
        let filtered = RANKING_DATA;
        const role = roleFilter?.value || '';
        const desig = desigFilter?.value || '';
        if (role) filtered = filtered.filter((m: any) => m.operational_role === role);
        if (desig) filtered = filtered.filter((m: any) => (m.designations || []).includes(desig));
        renderRankingRows(filtered);
      }

      if (roleFilter && !roleFilter.dataset.bound) {
        roleFilter.dataset.bound = '1';
        roleFilter.addEventListener('change', applyRankingFilters);
      }
      if (desigFilter && !desigFilter.dataset.bound) {
        desigFilter.dataset.bound = '1';
        desigFilter.addEventListener('change', applyRankingFilters);
      }
    } catch (e) {
      console.warn('Attendance: failed to load ranking:', e);
      el.innerHTML = `<div class="text-center py-8 text-red-500 text-sm">Failed to load ranking. Please try again later.</div>`;
      toast('Failed to load ranking.', 'error');
    }
  }

  // ── BOOT ──
  function showApp() {
    document.getElementById('loading-gate')?.classList.add('hidden');
    document.getElementById('auth-gate')?.classList.add('hidden');
    document.getElementById('auth-gate')?.classList.remove('flex');
    document.getElementById('app')!.classList.remove('hidden');
  }

  function showAuthGate() {
    document.getElementById('loading-gate')?.classList.add('hidden');
    document.getElementById('auth-gate')?.classList.remove('hidden');
    document.getElementById('auth-gate')?.classList.add('flex');
    document.getElementById('app')!.classList.add('hidden');
  }

  function showGuestNotRegistered() {
    showAuthGate();
    document.getElementById('auth-not-found-msg')?.classList.remove('hidden');
    const authBtn = document.getElementById('attendance-auth-btn');
    if (authBtn) authBtn.style.display = 'none';
  }

  async function onMemberReady() {
    parseAttendanceRoute();
    CAN_MANAGE = hasMinimumTier(resolveTierFromMember(MEMBER), 'leader');
    if (CAN_MANAGE) {
      document.getElementById('tab-new-event')?.classList.remove('hidden');
      document.getElementById('tab-recurring')?.classList.remove('hidden');
      const interviewToggle = document.getElementById('interview-toggle-wrapper');
      if (interviewToggle) { interviewToggle.classList.remove('hidden'); interviewToggle.classList.add('flex'); }
    }
    showApp();
    const routeTabBtn = document.querySelector(`[data-tab="${ATTENDANCE_ROUTE.tab}"]`) as HTMLElement | null;
    if (routeTabBtn) switchTab(routeTabBtn, ATTENDANCE_ROUTE.tab);
    await Promise.all([loadTags(), loadKPIs()]);
    await loadEvents();
    populateTypeDropdown();
    populateTribeDropdown();

    // Refresh events when minutes editor saves
    window.addEventListener('event-editor-saved', () => { loadEvents(); });
    // Load event-tag mappings in background for tag filter bar
    loadEventTagMap().then(() => {
      if (ACTIVE_TAG_FILTER) renderEvents();
    });

    // PostHog: track page view
    const safePH = (window as any).__safePH;
    safePH?.('capture', 'attendance_page_viewed', {
      member_tribe: MEMBER.tribe_id,
      events_visible: ALL_EVENTS.length
    });
  }

  async function boot() {
    sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    // Listen for future auth changes
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail && getMemberRole(e.detail) !== 'guest') {
        MEMBER = e.detail;
        onMemberReady();
      } else if (!e.detail) {
        showAuthGate();
      }
    }) as EventListener);

    window.addEventListener('nav:guest-with-session', (() => {
      showGuestNotRegistered();
    }) as EventListener);

    // 1) Check if nav already has a member loaded
    const m = (window as any).navGetMember?.();
    if (m && getMemberRole(m) !== 'guest') {
      MEMBER = m;
      onMemberReady();
      return;
    }

    // 2) Nav might not be ready yet — check session directly
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && getMemberRole(data) !== 'guest') {
        MEMBER = data;
        onMemberReady();
        return;
      }
      // Authenticated but not registered as member
      showGuestNotRegistered();
      return;
    }

    // 3) No session at all — show auth gate
    showAuthGate();
  }

  boot();
</script>
