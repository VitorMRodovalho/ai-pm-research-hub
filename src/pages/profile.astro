---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const PROFILE_I18N = {
  emailAlreadyRegistered: t('profile.emailAlreadyRegistered', lang),
  emailAdded: t('profile.emailAdded', lang),
  errorAddPrefix: t('profile.errorAddPrefix', lang),
  errorRemovePrefix: t('profile.errorRemovePrefix', lang),
  removeEmailConfirm: t('profile.removeEmailConfirm', lang),
  emailRemoved: t('profile.emailRemoved', lang),
  heading: t('profile.heading', lang),
  dateLocale: t('profile.dateLocale', lang),
  oproleManager: t('profile.oprole.manager', lang),
  oproleDeputyManager: t('profile.oprole.deputyManager', lang),
  oproleTribeLeader: t('profile.oprole.tribeLeader', lang),
  oproleResearcher: t('profile.oprole.researcher', lang),
  oproleFacilitator: t('profile.oprole.facilitator', lang),
  oproleCommunicator: t('profile.oprole.communicator', lang),
  oproleNone: t('profile.oprole.none', lang),
  oproleGuest: t('profile.oprole.guest', lang),
  desigSponsor: t('profile.desig.sponsor', lang),
  desigChapterLiaison: t('profile.desig.chapterLiaison', lang),
  desigAmbassador: t('profile.desig.ambassador', lang),
  desigFounder: t('profile.desig.founder', lang),
  desigCurator: t('profile.desig.curator', lang),
  desigCommsTeam: t('profile.desig.commsTeam', lang),
  desigCoGp: t('profile.desig.coGp', lang),
  desigTribeLeader: t('profile.desig.tribeLeader', lang),
  adminPlatform: t('profile.adminPlatform', lang),
  completenessLabel: t('profile.completenessLabel', lang),
  missingPrefix: t('profile.missingPrefix', lang),
  completenessFull: t('profile.completeness.full', lang),
  completenessAlmost: t('profile.completeness.almost', lang),
  completenessGood: t('profile.completeness.good', lang),
  completenessIncomplete: t('profile.completeness.incomplete', lang),
  fieldPhoto: t('profile.field.photo', lang),
  fieldPmiId: t('profile.field.pmiId', lang),
  fieldLinkedin: t('profile.field.linkedin', lang),
  fieldPhone: t('profile.field.phone', lang),
  fieldCredlyUrl: t('profile.field.credlyUrl', lang),
  fieldSecondaryEmail: t('profile.field.secondaryEmail', lang),
  fieldCycleLink: t('profile.field.cycleLink', lang),
  fieldTrailCourse: t('profile.field.trailCourse', lang),
  levelLegend: t('profile.level.legend', lang),
  levelMaster: t('profile.level.master', lang),
  levelExpert: t('profile.level.expert', lang),
  levelPractitioner: t('profile.level.practitioner', lang),
  levelExplorer: t('profile.level.explorer', lang),
  noActiveCycle: t('profile.noActiveCycle', lang),
  journeyTitle: t('profile.journeyTitle', lang),
  noHistory: t('profile.noHistory', lang),
  activeTag: t('profile.activeTag', lang),
  participant: t('profile.participant', lang),
  journeySummary: t('profile.journeySummary', lang),
  cyclesLabel: t('profile.cyclesLabel', lang),
  currentCycleLabel: t('profile.currentCycleLabel', lang),
  joinedLabel: t('profile.joinedLabel', lang),
  lastActivationLabel: t('profile.lastActivationLabel', lang),
  dashboardTitle: t('profile.dashboardTitle', lang),
  pointsLabel: t('profile.pointsLabel', lang),
  lifetimeXP: t('profile.lifetimeXP', lang),
  attendanceLabel: t('profile.attendanceLabel', lang),
  trailLabel: t('profile.trailLabel', lang),
  artifactsLabel: t('profile.artifactsLabel', lang),
  emailsTitle: t('profile.emailsTitle', lang),
  emailsDesc: t('profile.emailsDesc', lang),
  primaryBadge: t('profile.primaryBadge', lang),
  removeBtn: t('profile.removeBtn', lang),
  addBtn: t('profile.addBtn', lang),
  emailInputPlaceholder: t('profile.emailInputPlaceholder', lang),
  personalDataTitle: t('profile.personalDataTitle', lang),
  phoneLabel: t('profile.phoneLabel', lang),
  pmiIdLabel: t('profile.pmiIdLabel', lang),
  linkedinLabel: t('profile.linkedinLabel', lang),
  credlyLabel: t('profile.credlyLabel', lang),
  credlyHint: t('profile.credlyHint', lang),
  verifyCredly: t('profile.verifyCredly', lang),
  saveChanges: t('profile.saveChanges', lang),
  pmiIdPlaceholder: t('profile.pmiIdPlaceholder', lang),
  phonePlaceholder: t('profile.phonePlaceholder', lang),
  linkedinPlaceholder: t('profile.linkedinPlaceholder', lang),
  credlyPlaceholder: t('profile.credlyPlaceholder', lang),
  shareWhatsApp: t('profile.shareWhatsApp', lang),
  shareWhatsAppHint: t('profile.shareWhatsAppHint', lang),
  invalidCredlyUrl: t('profile.invalidCredlyUrl', lang),
  dataSaved: t('profile.dataSaved', lang),
  invalidEmail: t('profile.invalidEmail', lang),
  credlyInvalidSession: t('profile.credlyInvalidSession', lang),
  credlyRequired: t('profile.credlyRequired', lang),
  credlyVerifying: t('profile.credlyVerifying', lang),
  credlyCpmaiMsg: t('profile.credlyCpmaiMsg', lang),
  credlyBadgesMsg: t('profile.credlyBadgesMsg', lang),
  credlyNoBadgesMsg: t('profile.credlyNoBadgesMsg', lang),
  credlyVerifyError: t('profile.credlyVerifyError', lang),
  credlyConnectError: t('profile.credlyConnectError', lang),
  unknownError: t('profile.unknownError', lang),
  weekTitle: t('profile.week.title', lang),
  weekNextMeeting: t('profile.week.nextMeeting', lang),
  weekTrailProgress: t('profile.week.trailProgress', lang),
  weekDeliverables: t('profile.week.deliverables', lang),
  weekWeeklyXp: t('profile.week.weeklyXp', lang),
  weekNoTribe: t('profile.week.noTribe', lang),
  weekChooseTribe: t('profile.week.chooseTribe', lang),
  weekJoinMeet: t('profile.week.joinMeet', lang),
  weekCompleted: t('profile.week.completed', lang),
  weekPending: t('profile.week.pending', lang),
  weekPointsThisWeek: t('profile.week.pointsThisWeek', lang),
  weekViewRanking: t('profile.week.viewRanking', lang),
  weekNoMeeting: t('profile.week.noMeeting', lang),
  daySun: t('common.days.sun', lang),
  dayMon: t('common.days.mon', lang),
  dayTue: t('common.days.tue', lang),
  dayWed: t('common.days.wed', lang),
  dayThu: t('common.days.thu', lang),
  dayFri: t('common.days.fri', lang),
  daySat: t('common.days.sat', lang),
};
---
<BaseLayout title={t('profile.title', lang)} activePage="profile">
  <Toast />
  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-extrabold text-navy mb-6">{t('profile.heading', lang)}</h1>
    <div id="profile-content" class="space-y-5">
      <div class="text-center text-slate-400 py-8">{t('profile.loading', lang)}</div>
    </div>

    <div id="profile-not-registered" class="hidden">
      <div class="bg-white rounded-2xl border border-slate-200 p-8 text-center">
        <div class="text-4xl mb-3">🔒</div>
        <h2 class="text-lg font-bold text-navy mb-2">{t('guest.notRegistered', lang)}</h2>
        <p class="text-slate-500 text-sm mb-4">{t('guest.contactAdmin', lang)}</p>
        <a href={`mailto:${t('guest.contactEmail', lang)}`}
           class="inline-block px-5 py-2.5 bg-navy text-white rounded-xl font-semibold text-sm no-underline hover:opacity-90 transition-all">
          ✉️ {t('guest.contactEmail', lang)}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ PROFILE_I18N }}>
  window.__PROFILE_I18N = typeof PROFILE_I18N !== 'undefined' ? PROFILE_I18N : {};
</script>
<script>
  import { ROLE_COLORS } from '../lib/supabase';
  import { getCurrentCycle, getCycleMeta, loadCycles } from '../lib/cycles';
  import { shouldRedirectFromProfile } from '../lib/routing';
  import { normalizeCredlyUrl } from '../lib/credly';
  import { normalizeMemberCycleHistory } from '../lib/cycle-history';

  const PROFILE_I18N = (typeof window !== 'undefined' && (window as any).__PROFILE_I18N) || {};
  const OPROLE_LABELS: Record<string, string> = {
    manager: PROFILE_I18N.oproleManager, deputy_manager: PROFILE_I18N.oproleDeputyManager, tribe_leader: PROFILE_I18N.oproleTribeLeader, researcher: PROFILE_I18N.oproleResearcher,
    facilitator: PROFILE_I18N.oproleFacilitator, communicator: PROFILE_I18N.oproleCommunicator, none: PROFILE_I18N.oproleNone, guest: PROFILE_I18N.oproleGuest
  };
  const OPROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', deputy_manager: '#FF610F', tribe_leader: '#4F17A8', researcher: '#EC4899',
    facilitator: '#06B6D4', communicator: '#8B5CF6', none: '#94A3B8', guest: '#94A3B8'
  };
  const DESIG_LABELS: Record<string, string> = {
    sponsor: PROFILE_I18N.desigSponsor, chapter_liaison: PROFILE_I18N.desigChapterLiaison, ambassador: PROFILE_I18N.desigAmbassador, founder: PROFILE_I18N.desigFounder, curator: PROFILE_I18N.desigCurator, comms_team: PROFILE_I18N.desigCommsTeam, comms_leader: PROFILE_I18N.desigCommsLeader || 'Comms Leader', comms_member: PROFILE_I18N.desigCommsMember || 'Comms Member', co_gp: PROFILE_I18N.desigCoGp, tribe_leader: PROFILE_I18N.desigTribeLeader
  };
  const DESIG_COLORS: Record<string, string> = {
    sponsor: '#BE2027', chapter_liaison: '#BE2027', ambassador: '#10B981', founder: '#7C3AED', curator: '#D97706', comms_team: '#06B6D4', comms_leader: '#06B6D4', comms_member: '#06B6D4', co_gp: '#FF610F', tribe_leader: '#4F17A8'
  };

  let currentMember: any = null;
  let cycleHistory: any[] = [];
  let cycleStats: any = null;
  let journeyStats: any = null;
  let xpByCycle: Record<string, number> = {};
  let cycleXpData: any = null;
  let currentCycleCode: string = '';
  let currentCycleLabel: string = '';
  let cycleMeta: Record<string, { label: string; abbr: string; color: string }> = {};
  let weekData: {
    meetingSlots: any[]; tribeMeetingLink: string | null;
    pendingDeliverables: number; weeklyPoints: number; tribeId: number | null;
  } | null = null;
  let credlyNormalizeTimer: ReturnType<typeof setTimeout> | null = null;

  // ── Boot ──
  async function boot() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    try {
      const cycles = await loadCycles(sb);
      const currentCycle = getCurrentCycle(cycles);
      cycleMeta = getCycleMeta(cycles);
      currentCycleCode = currentCycle?.cycle_code || '';
      currentCycleLabel = currentCycle?.cycle_label || '';
    } catch (_) { /* fallback to i18n default */ }

    window.addEventListener('nav:member', (async (evt: Event) => {
      const e = evt as CustomEvent;
      if (shouldRedirectFromProfile(e.detail)) {
        const user = (window as any).navGetUser?.();
        if (user) { renderNotRegistered(); } else { location.href = '/?auth=required'; }
        return;
      }
      currentMember = e.detail;
      await loadExtras(sb);
      renderProfile(currentMember);
    }) as EventListener);

    window.addEventListener('nav:guest-with-session', (() => {
      renderNotRegistered();
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && !shouldRedirectFromProfile(m)) {
      currentMember = m;
      await loadExtras(sb);
      renderProfile(m);
      return;
    }

    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && !shouldRedirectFromProfile(data)) {
        currentMember = data;
        await loadExtras(sb);
        renderProfile(data);
        return;
      }
      renderNotRegistered();
      return;
    }
    location.href = '/?auth=required';
  }

  function renderNotRegistered() {
    document.getElementById('profile-content')?.classList.add('hidden');
    document.getElementById('profile-not-registered')?.classList.remove('hidden');
  }

  function getActiveCycleCode(): string {
    return currentCycleCode || cycleHistory.find((entry: any) => !!entry?.is_active)?.cycle_code || '';
  }

  async function loadExtras(sb: any) {
    if (!currentMember?.id) return;
    // Load cycle history
    try {
      const { data: hist } = await sb.from('member_cycle_history')
        .select('*')
        .eq('member_id', currentMember.id)
        .order('cycle_start', { ascending: true });
      cycleHistory = normalizeMemberCycleHistory(hist);
      journeyStats = buildJourneyStats(cycleHistory);
    } catch (e) {
      console.warn('Profile: failed to load cycle history:', e);
      cycleHistory = [];
      journeyStats = buildJourneyStats([]);
      (window as any).toast?.('Could not load cycle history. Some data may be incomplete.', 'error');
    }

    // Load stats for current cycle
    try {
      // Attendance count
      const { count: attendCount } = await sb.from('attendance')
        .select('*', { count: 'exact', head: true })
        .eq('member_id', currentMember.id);

      // Total events
      const { count: eventCount } = await sb.from('events')
        .select('*', { count: 'exact', head: true });

      // Course progress
      const { data: courses } = await sb.from('course_progress')
        .select('status')
        .eq('member_id', currentMember.id);

      // Gamification points
      const { data: points } = await sb.from('gamification_points')
        .select('points, created_at')
        .eq('member_id', currentMember.id);

      // Cycle XP breakdown via RPC
      try {
        const { data: cxd } = await sb.rpc('get_member_cycle_xp', { p_member_id: currentMember.id });
        cycleXpData = typeof cxd === 'string' ? JSON.parse(cxd) : cxd;
      } catch (_) { cycleXpData = null; }

      // Artifacts
      const { data: artifacts } = await sb.from('artifacts')
        .select('status')
        .eq('member_id', currentMember.id);

      const totalPoints = (points || []).reduce((s: number, p: any) => s + (p.points || 0), 0);
      const completedCourses = (courses || []).filter((c: any) => c.status === 'completed').length;
      const inProgressCourses = (courses || []).filter((c: any) => c.status === 'in_progress').length;

      // XP per cycle for timeline
      const allPoints = points || [];
      xpByCycle = {};
      cycleHistory.forEach(function(h: any) {
        var start = h.cycle_start ? new Date(h.cycle_start).getTime() : 0;
        var end = h.cycle_end ? new Date(h.cycle_end).getTime() : Date.now();
        var cycleXp = allPoints.filter(function(p: any) {
          var t = new Date(p.created_at).getTime();
          return t >= start && t <= end;
        }).reduce(function(s: number, p: any) { return s + (p.points || 0); }, 0);
        xpByCycle[h.cycle_code] = cycleXp;
      });

      cycleStats = {
        attendance: attendCount || 0,
        totalEvents: eventCount || 0,
        points: totalPoints,
        coursesCompleted: completedCourses,
        coursesInProgress: inProgressCourses,
        artifacts: {
          total: (artifacts || []).length,
          published: (artifacts || []).filter((a: any) => a.status === 'published').length,
          review: (artifacts || []).filter((a: any) => a.status === 'review').length,
          draft: (artifacts || []).filter((a: any) => a.status === 'draft').length,
        }
      };
    } catch (e) {
      console.warn('Profile: failed to load cycle stats:', e);
      cycleStats = null;
      (window as any).toast?.('Could not load cycle statistics. Some data may be incomplete.', 'error');
    }

    // Load My Week data
    try {
      let meetingSlots: any[] = [];
      let tribeMeetingLink: string | null = null;
      let pendingDeliverables = 0;
      let weeklyPoints = 0;
      const tribeId: number | null = currentMember.tribe_id || null;

      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
      const activeCycleCode = getActiveCycleCode();

      if (tribeId) {
        const deliverablesPromise = activeCycleCode
          ? sb.rpc('list_tribe_deliverables', { p_tribe_id: tribeId, p_cycle_code: activeCycleCode })
          : Promise.resolve({ data: [] });
        const [slotsRes, tribeRes, delivRes, weekPtsRes] = await Promise.all([
          sb.from('tribe_meeting_slots')
            .select('day_of_week, time_start, time_end')
            .eq('tribe_id', tribeId).eq('is_active', true).order('day_of_week'),
          sb.from('tribes').select('meeting_link').eq('id', tribeId).single(),
          deliverablesPromise,
          sb.from('gamification_points').select('points')
            .eq('member_id', currentMember.id).gte('created_at', sevenDaysAgo.toISOString()),
        ]);
        meetingSlots = slotsRes.data || [];
        tribeMeetingLink = tribeRes.data?.meeting_link || null;
        const allDelivs = delivRes.data || [];
        pendingDeliverables = allDelivs.filter((d: any) =>
          d.assigned_member_id === currentMember.id &&
          (d.status === 'in_progress' || d.status === 'planned')
        ).length;
        weeklyPoints = (weekPtsRes.data || []).reduce((s: number, p: any) => s + (p.points || 0), 0);
      } else {
        const { data: weekPts } = await sb.from('gamification_points')
          .select('points').eq('member_id', currentMember.id)
          .gte('created_at', sevenDaysAgo.toISOString());
        weeklyPoints = (weekPts || []).reduce((s: number, p: any) => s + (p.points || 0), 0);
      }

      weekData = { meetingSlots, tribeMeetingLink, pendingDeliverables, weeklyPoints, tribeId };
    } catch (e) {
      console.warn('Profile: failed to load My Week data:', e);
      weekData = null;
    }
  }

  function formatDatePt(value: string | null | undefined): string {
    if (!value) return '—';
    const dt = new Date(value);
    if (Number.isNaN(dt.getTime())) return '—';
    return dt.toLocaleDateString(PROFILE_I18N.dateLocale || 'pt-BR', { year: 'numeric', month: 'short' });
  }

  function buildJourneyStats(history: any[]) {
    const list = Array.isArray(history) ? history : [];
    const totalCycles = list.length;
    const active = list.find((h: any) => h?.is_active) || list[list.length - 1] || null;
    const first = list[0] || null;
    return {
      totalCycles,
      currentCycleLabel: active?.cycle_label || PROFILE_I18N.noActiveCycle,
      firstStart: formatDatePt(first?.cycle_start),
      latestStart: formatDatePt(active?.cycle_start),
      hasHistory: totalCycles > 0,
    };
  }

  function hasCurrentCycleContext(m: any): boolean {
    if (Array.isArray(cycleHistory) && cycleHistory.some((h: any) => !!h?.is_active)) return true;
    if (Array.isArray(cycleHistory) && cycleHistory.some((h: any) => !!h?.cycle_code)) return true;
    return !!m?.current_cycle_active;
  }

  // ── Completeness calculation ──
  function getCompleteness(m: any): { pct: number; missing: string[] } {
    const opRole = m.operational_role || 'guest';
    const isOperational = ['manager', 'deputy_manager', 'tribe_leader', 'researcher', 'facilitator', 'communicator'].includes(opRole);
    const missing: string[] = [];
    let earned = 0;
    let total = 0;

    const check = (field: any, label: string, weight: number) => {
      total += weight;
      if (field && String(field).trim() !== '') earned += weight;
      else missing.push(label);
    };

    if (isOperational) {
      check(m.photo_url, PROFILE_I18N.fieldPhoto, 15);
      check(m.pmi_id, PROFILE_I18N.fieldPmiId, 15);
      check(m.linkedin_url, PROFILE_I18N.fieldLinkedin, 15);
      check(m.phone, PROFILE_I18N.fieldPhone, 10);
      check(m.credly_url, PROFILE_I18N.fieldCredlyUrl, 15);
      check(m.secondary_emails?.length, PROFILE_I18N.fieldSecondaryEmail, 10);
      check(hasCurrentCycleContext(m), PROFILE_I18N.fieldCycleLink, 10);
      check(cycleStats?.coursesCompleted || cycleStats?.coursesInProgress, PROFILE_I18N.fieldTrailCourse, 10);
    } else {
      check(m.photo_url, PROFILE_I18N.fieldPhoto, 20);
      check(m.pmi_id, PROFILE_I18N.fieldPmiId, 20);
      check(m.linkedin_url, PROFILE_I18N.fieldLinkedin, 20);
      check(m.phone, PROFILE_I18N.fieldPhone, 15);
      check(m.credly_url, PROFILE_I18N.fieldCredlyUrl, 15);
      check(m.secondary_emails?.length, PROFILE_I18N.fieldSecondaryEmail, 10);
    }

    return { pct: total > 0 ? Math.round((earned / total) * 100) : 0, missing };
  }

  function completenessMessage(pct: number): string {
    if (pct >= 100) return PROFILE_I18N.completenessFull;
    if (pct >= 71) return PROFILE_I18N.completenessAlmost;
    if (pct >= 31) return PROFILE_I18N.completenessGood;
    return PROFILE_I18N.completenessIncomplete;
  }

  function completenessColor(pct: number): string {
    if (pct >= 100) return '#10B981';
    if (pct >= 71) return '#FF610F';
    if (pct >= 31) return '#D97706';
    return '#BE2027';
  }

  // ── Role badges (3-axis) ──
  function roleBadgesHtml(m: any): string {
    let html = '';
    const opRole = m.operational_role || 'guest';
    if (opRole !== 'none' && opRole !== 'guest') {
      const c = OPROLE_COLORS[opRole] || '#94A3B8';
      html += `<span class="inline-block px-2 py-0.5 rounded-md text-[.62rem] font-bold uppercase" style="background:${c}22;color:${c}">${OPROLE_LABELS[opRole] || opRole}</span> `;
    }
    const desigs: string[] = m.designations?.length ? m.designations : [];
    desigs.forEach(d => {
      const c = DESIG_COLORS[d] || '#94A3B8';
      html += `<span class="inline-block px-2 py-0.5 rounded-md text-[.62rem] font-bold uppercase" style="background:${c}22;color:${c}">${DESIG_LABELS[d] || d}</span> `;
    });
    if (m.is_superadmin) {
      html += `<span class="inline-block px-2 py-0.5 rounded-md text-[.62rem] font-bold uppercase bg-orange/10 text-orange">${PROFILE_I18N.adminPlatform}</span>`;
    }
    return html;
  }

  // ── XP Level ──
  function getLevel(totalHours: number): { name: string; emoji: string; next: string; hoursToNext: number } {
    if (totalHours >= 401) return { name: PROFILE_I18N.levelLegend, emoji: '🏆', next: '', hoursToNext: 0 };
    if (totalHours >= 201) return { name: PROFILE_I18N.levelMaster, emoji: '💎', next: PROFILE_I18N.levelLegend, hoursToNext: 401 - totalHours };
    if (totalHours >= 91) return { name: PROFILE_I18N.levelExpert, emoji: '🔥', next: PROFILE_I18N.levelMaster, hoursToNext: 201 - totalHours };
    if (totalHours >= 31) return { name: PROFILE_I18N.levelPractitioner, emoji: '⚡', next: PROFILE_I18N.levelExpert, hoursToNext: 91 - totalHours };
    return { name: PROFILE_I18N.levelExplorer, emoji: '🌱', next: PROFILE_I18N.levelPractitioner, hoursToNext: 31 - totalHours };
  }

  // ── Timeline ──
  function timelineHtml(): string {
    if (!cycleHistory.length) {
      return `
        <div class="bg-white rounded-2xl border border-slate-200 p-6">
          <h2 class="text-sm font-bold text-navy mb-2">${PROFILE_I18N.journeyTitle}</h2>
          <p class="text-[.78rem] text-slate-500">${PROFILE_I18N.noHistory}</p>
        </div>`;
    }
    return `
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-bold text-navy mb-4">${PROFILE_I18N.journeyTitle}</h2>
        <div class="relative pl-6 border-l-2 border-slate-200 space-y-4">
          ${cycleHistory.map(h => {
            const color = cycleMeta[h.cycle_code]?.color || '#94A3B8';
            const isCurrent = !h.cycle_end;
            const opLabel = OPROLE_LABELS[h.operational_role] || h.operational_role;
