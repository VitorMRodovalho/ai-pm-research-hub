              <span class="text-base">📚</span>
              <span class="text-[.68rem] font-bold text-[var(--text-secondary)] uppercase tracking-wide">${PROFILE_I18N.weekTrailProgress}</span>
            </div>
            <div class="text-sm font-bold text-navy">${coursesCompleted}/6 ${PROFILE_I18N.weekCompleted}</div>
            <div class="w-full h-1.5 bg-white/80 rounded-full overflow-hidden mt-1.5">
              <div class="h-full rounded-full bg-purple-500 transition-all duration-500" style="width:${trailPct}%"></div>
