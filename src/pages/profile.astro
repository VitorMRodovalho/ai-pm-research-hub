  function getNextMeetingSlot(slots: any[]): any {
    if (!slots.length) return null;
    const now = new Date();
    const currentDay = now.getDay();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    for (const slot of slots) {
      if (slot.day_of_week > currentDay) return slot;
      if (slot.day_of_week === currentDay) {
        const [h, m] = (slot.time_start || '00:00').split(':').map(Number);
        if (h * 60 + m > currentMinutes) return slot;
      }
    }
    return slots[0];
  }

