              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-publication" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefsTypePublication}
