      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-6">
        <h2 class="text-sm font-bold text-navy mb-4">${dashTitle}</h2>
        ${cardsHtml}
      </div>`;
  }

  // ── XP Pillars (ADR-0081 transparency) ──
  const PILLAR_META: Record<string, { emoji: string; pt: string; en: string; es: string }> = {
    presenca:      { emoji: '🎯', pt: 'Presença',       en: 'Attendance',     es: 'Asistencia' },
    trilha:        { emoji: '🛤️', pt: 'Trilha',          en: 'Trail',          es: 'Ruta' },
    certificacoes: { emoji: '🎖️', pt: 'Certificações',   en: 'Certifications', es: 'Certificaciones' },
    producao:      { emoji: '🏗️', pt: 'Produção',        en: 'Production',     es: 'Producción' },
    curadoria:     { emoji: '📚', pt: 'Curadoria',       en: 'Curation',       es: 'Curaduría' },
    champions:     { emoji: '🏆', pt: 'Champions',       en: 'Champions',      es: 'Champions' },
  };

  function pillarLabel(slug: string): string {
    const m = PILLAR_META[slug];
    if (!m) return slug;
    if (lang === 'en-US') return m.en;
    if (lang === 'es-LATAM') return m.es;
    return m.pt;
  }

  function pillarEmoji(slug: string): string {
    return PILLAR_META[slug]?.emoji || '⭐';
  }

  function ruleLabel(displayI18n: any, slug: string): string {
    if (!displayI18n) return slug;
    if (lang === 'en-US' && displayI18n['en-US']) return displayI18n['en-US'];
    if (lang === 'es-LATAM' && displayI18n['es-LATAM']) return displayI18n['es-LATAM'];
    return displayI18n['pt-BR'] || slug;
  }

  function ruleDescription(descI18n: any): string {
    if (!descI18n) return '';
    if (lang === 'en-US' && descI18n['en-US']) return descI18n['en-US'];
    if (lang === 'es-LATAM' && descI18n['es-LATAM']) return descI18n['es-LATAM'];
    return descI18n['pt-BR'] || '';
  }

  function formatDateShort(iso: string): string {
    if (!iso) return '';
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '';
    const day = String(d.getDate()).padStart(2, '0');
    const month = String(d.getMonth() + 1).padStart(2, '0');
    return `${day}/${month}`;
  }

  function escapeHtmlSafe(s: any): string {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function xpPillarsHtml(): string {
    const isLifetime = currentXpScope === 'lifetime';
    const data = isLifetime ? xpPillarsLifetimeData : xpPillarsCycleData;
    if (!data || data.error) return '';
    const pillars: any[] = data.pillars || [];
    if (pillars.length === 0) return '';
    const cycleCode = data.cycle_code || '';
    const cycleStartIso = data.cycle_start || null;
    const cycleEndIso = data.cycle_end || null;
    const totalPts = data.total_pts || 0;

    // Filter allGamificationPoints by scope for drilldown history
    const scopedPoints = isLifetime
      ? allGamificationPoints
      : allGamificationPoints.filter((gp: any) => {
          if (!cycleStartIso) return true;
          const ts = new Date(gp.created_at).getTime();
          const start = new Date(cycleStartIso).getTime();
          const end = cycleEndIso ? new Date(cycleEndIso).getTime() + 24*60*60*1000 : Infinity;
          return ts >= start && ts < end;
        });

    const ptsLabel = 'pts';
    const itemsLabel = (n: number) => {
      if (lang === 'en-US') return n === 1 ? 'item earned' : 'items earned';
      if (lang === 'es-LATAM') return n === 1 ? 'punto obtenido' : 'puntos obtenidos';
      return n === 1 ? 'item pontuado' : 'itens pontuados';
    };
    const howToLabelOpen = lang === 'en-US' ? 'How to earn'
                         : lang === 'es-LATAM' ? 'Cómo puntuar'
                         : 'Como pontuar';
    const howToLabelGrow = lang === 'en-US' ? 'How to grow here'
                         : lang === 'es-LATAM' ? 'Cómo crecer aquí'
                         : 'Como crescer aqui';
    const earnedListLabel = isLifetime
      ? (lang === 'en-US' ? 'All-time earnings'
        : lang === 'es-LATAM' ? 'Puntos histórico total'
        : 'Pontuação histórica total')
      : (lang === 'en-US' ? 'Earned this cycle'
        : lang === 'es-LATAM' ? 'Obtenido en este ciclo'
        : 'Pontuado neste ciclo');
    const noEarningsYet = lang === 'en-US' ? 'No earnings yet — see "How to grow here"'
                        : lang === 'es-LATAM' ? 'Aún sin puntos — vea "Cómo crecer aquí"'
                        : 'Ainda sem pontos — veja "Como crescer aqui"';
    const variableNote = lang === 'en-US' ? '(variable: 15–25 pts by type)'
                       : lang === 'es-LATAM' ? '(variable: 15–25 pts por tipo)'
                       : '(variável: 15–25 pts por tipo)';
    const tabLifetimeI18n = lang === 'en-US' ? 'All-time'
                          : lang === 'es-LATAM' ? 'Histórico'
                          : 'Vida toda';
    // p171 #6 — include cycle code/label in tab when available pra dar contexto temporal
    const cycleShort = cycleCode || '';
    const cycleSuffix = cycleShort ? ` (${cycleShort.replace(/^cycle_/, 'C')})` : '';
    const tabCycleI18n = (lang === 'en-US' ? 'Current cycle'
                       : lang === 'es-LATAM' ? 'Ciclo actual'
                       : 'Ciclo atual') + cycleSuffix;
    const ofTotalI18n = lang === 'en-US' ? '% of total'
                      : lang === 'es-LATAM' ? '% del total'
                      : '% do total';

    const cardsHtml = pillars.map((p: any) => {
      const rules: any[] = p.rules || [];
      const pillarRulesId = `pillar-rules-${p.pillar}-${currentXpScope}`;
      const hasPts = p.total_pts > 0;
      const headerColor = hasPts ? 'text-navy' : 'text-[var(--text-secondary)]';
      const pillarPct = totalPts > 0 ? Math.round((p.total_pts / totalPts) * 100) : 0;
      const barColor = hasPts ? 'bg-teal' : 'bg-[var(--border-default)]';

      const triggerMeta = (ts: string) => {
        if (ts === 'manual') return {
          icon: '✋',
          tip: lang === 'en-US' ? 'Manual recognition by leadership'
             : lang === 'es-LATAM' ? 'Reconocimiento manual por liderazgo'
             : 'Reconhecimento manual por liderança',
          color: 'text-amber-700'
        };
        if (ts === 'auto_trigger') return {
          icon: '⚡',
          tip: lang === 'en-US' ? 'Automatic when source action happens'
             : lang === 'es-LATAM' ? 'Automático cuando la acción fuente ocurre'
             : 'Automático quando a ação-fonte acontece',
          color: 'text-teal'
        };
        if (ts === 'rpc_callback') return {
          icon: '📋',
          tip: lang === 'en-US' ? 'Registered via system (e.g. showcase, certificate)'
             : lang === 'es-LATAM' ? 'Registrado vía sistema (ej. showcase, certificado)'
             : 'Registrado via sistema (ex: showcase, certificado)',
          color: 'text-purple-700'
        };
        return { icon: '', tip: '', color: 'text-[var(--text-muted)]' };
      };

      const rulesHtml = rules.map((r: any) => {
        const name = ruleLabel(r.display_name_i18n, r.slug);
        const desc = ruleDescription(r.description_i18n);
        const ptsHint = r.cap_points ? `${r.base_points}–${r.cap_points} ${ptsLabel}` : `${r.base_points} ${ptsLabel}`;
        const isShowcase = r.slug === 'showcase';
        const tm = triggerMeta(r.trigger_source || '');
        const earnedStyle = r.pts > 0 ? 'font-semibold text-navy' : 'text-[var(--text-secondary)]';
        const triggerBadge = tm.icon
          ? `<span class="inline-block mr-1 ${tm.color}" title="${escapeHtmlSafe(tm.tip)}">${tm.icon}</span>`
          : '';
        const ptsCell = r.pts > 0
          ? `<span class="font-bold text-emerald-700">+${r.pts}</span>`
          : `<span class="text-[var(--text-muted)]">${ptsHint}${isShowcase ? ' <span class="text-[.55rem]">'+variableNote+'</span>' : ''}</span>`;

        let detailHtml = '';
        if (r.pts > 0) {
          const earnings = scopedPoints.filter((gp: any) => gp.category === r.slug);
          if (earnings.length > 0) {
            const shown = earnings.slice(0, 30);
            const overflow = earnings.length - shown.length;
            const rowsHtml = shown.map((gp: any) => `
              <div class="flex items-center justify-between gap-2 text-[.58rem] text-[var(--text-muted)]">
                <span class="truncate flex-1">• ${escapeHtmlSafe(gp.reason || '—')}</span>
                <span class="shrink-0 font-mono">${formatDateShort(gp.created_at)} <span class="text-emerald-700 font-semibold">+${gp.points}</span></span>
              </div>`).join('');
            const overflowHtml = overflow > 0
              ? `<div class="text-[.55rem] text-[var(--text-muted)] italic">+${overflow}</div>`
              : '';
            detailHtml = `
              <div class="ml-2 mt-1 mb-1 pl-2 border-l-2 border-emerald-200 space-y-0.5">
                <div class="text-[.55rem] uppercase tracking-wider text-emerald-700 font-bold">${earnedListLabel}</div>
                ${rowsHtml}
                ${overflowHtml}
              </div>`;
          }
        } else if (desc) {
          detailHtml = `
            <div class="ml-2 mt-0.5 mb-1 text-[.58rem] text-[var(--text-muted)] italic">
              ${escapeHtmlSafe(desc)}
            </div>`;
        }

        return `
          <div class="py-0.5">
            <div class="flex items-center justify-between text-[.68rem]">
              <span class="${earnedStyle} truncate pr-2">${triggerBadge}${name}</span>
              ${ptsCell}
            </div>
            ${detailHtml}
          </div>`;
      }).join('');

      const emptyHint = !hasPts
        ? `<div class="text-[.58rem] text-amber-700 italic mb-1.5">${noEarningsYet}</div>`
        : '';

      return `
        <div class="bg-[var(--surface-base)] rounded-xl border border-[var(--border-default)] p-3 flex flex-col">
          <div class="flex items-center justify-between mb-1">
            <div class="font-bold text-[.78rem] ${headerColor}">${pillarEmoji(p.pillar)} ${pillarLabel(p.pillar)}</div>
            <div class="text-xl font-black text-navy">${p.total_pts}</div>
          </div>
          <div class="text-[.62rem] text-[var(--text-muted)] mb-1">
            ${p.earned_count} ${itemsLabel(p.earned_count)} ${hasPts ? `· ${pillarPct}${ofTotalI18n}` : ''}
          </div>
          <div class="w-full h-1.5 bg-[var(--surface-section-cool)] rounded-full overflow-hidden mb-1.5">
            <div class="h-full ${barColor} transition-all duration-500" style="width:${pillarPct}%"></div>
          </div>
          ${emptyHint}
          <button type="button" data-action="pillar-toggle" data-target="${pillarRulesId}"
                  class="text-[.62rem] text-teal font-semibold cursor-pointer bg-transparent border-0 p-0 hover:underline self-start mt-auto">
            ${hasPts ? howToLabelOpen : howToLabelGrow} ↓
          </button>
          <div id="${pillarRulesId}" class="hidden mt-2 space-y-0.5 border-t border-[var(--border-default)] pt-2">
            ${rulesHtml}
          </div>
        </div>`;
    }).join('');

    const titleI18n = lang === 'en-US' ? '🏆 Your XP Journey'
                    : lang === 'es-LATAM' ? '🏆 Tu Recorrido en XP'
                    : '🏆 Sua Jornada em XP';
    const scopeLabel = isLifetime
      ? (lang === 'en-US' ? 'all-time' : lang === 'es-LATAM' ? 'histórico' : 'vida toda')
      : (cycleCode ? cycleCode : (lang === 'en-US' ? 'current cycle' : lang === 'es-LATAM' ? 'ciclo actual' : 'ciclo atual'));
    const ptsSuffix = lang === 'en-US' ? 'pts' : 'pts';

    const tabBtn = (scope: string, label: string, active: boolean) => `
      <button type="button" data-action="xp-scope-toggle" data-scope="${scope}"
              class="px-3 py-1 text-[.65rem] font-semibold rounded-full transition-all border ${active
                ? 'bg-navy text-white border-navy'
                : 'bg-transparent text-[var(--text-secondary)] border-[var(--border-default)] hover:bg-[var(--surface-base)]'}">
        ${label}
      </button>`;

    const legendI18n = lang === 'en-US'
      ? '✋ Recognition · ⚡ Auto · 📋 System-registered'
      : lang === 'es-LATAM'
        ? '✋ Reconocimiento · ⚡ Automático · 📋 Registrado vía sistema'
        : '✋ Reconhecimento · ⚡ Automático · 📋 Registrado via sistema';

    return `
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-6" data-section="xp-pillars">
        <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
          <h2 class="text-sm font-bold text-navy">${titleI18n}</h2>
          <div class="text-[.7rem] text-[var(--text-muted)]">
            ${scopeLabel} · <strong class="text-navy">${totalPts}</strong> ${ptsSuffix}
          </div>
        </div>
        <div class="flex gap-1.5 mb-2">
          ${tabBtn('lifetime', tabLifetimeI18n, isLifetime)}
          ${tabBtn('cycle', tabCycleI18n, !isLifetime)}
        </div>
        <div class="text-[.6rem] text-[var(--text-muted)] mb-4">${legendI18n}</div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">${cardsHtml}</div>
      </div>`;
  }

  function championsHtml(): string {
    // Even on RPC error, render diagnostic empty card so section is never silently absent.
    const errorMsg = championsHistoryData?.error ? `[diagnostic: ${championsHistoryData.error}]` : '';
    const history: any[] = (championsHistoryData?.history || []).filter((c: any) => c.status === 'active');
    const totals = championsHistoryData?.totals || {};
    const total = totals.active_count || 0;

    const titleI18n = lang === 'en-US' ? '🏅 Your Champions'
                    : lang === 'es-LATAM' ? '🏅 Tus Champions'
                    : '🏅 Seus Champions';
    const subtitleI18n = lang === 'en-US'
      ? 'Manual recognition by leadership for exceptional contributions'
      : lang === 'es-LATAM'
        ? 'Reconocimiento manual de la liderazgo por contribuciones excepcionales'
        : 'Reconhecimento manual da liderança por contribuições excepcionais';
    const emptyTitleI18n = lang === 'en-US' ? 'No Champion yet'
                         : lang === 'es-LATAM' ? 'Aún no tienes Champion'
                         : 'Você ainda não foi conferido Champion';
    const emptyHintI18n = lang === 'en-US'
      ? 'Champion is awarded by tribe leaders, GP, co-GP, deputies and comms leaders in general meetings, tribe meetings, or for outstanding deliverables. Three surfaces: 🏛️ general (30 pts) · 🏕️ tribe (20 pts) · 📦 deliverable (40 pts) — plus 5 pts per criterion met.'
      : lang === 'es-LATAM'
        ? 'Champion es conferido por líderes de tribu, GP, co-GP, adjuntos y líderes de comunicación en reuniones generales, de tribu o por entregables destacados. Tres superficies: 🏛️ general (30 pts) · 🏕️ tribu (20 pts) · 📦 entregable (40 pts) — más 5 pts por criterio.'
        : 'Champion é conferido por líderes de tribo, GP, co-GP, deputies e líderes de comunicação em reuniões gerais, reuniões de tribo ou por entregáveis destacados. Três superfícies: 🏛️ geral (30 pts) · 🏕️ tribo (20 pts) · 📦 entregável (40 pts) — mais 5 pts por critério atendido.';

    if (total === 0) {
      return `
        <div class="bg-gradient-to-br from-amber-50/40 to-yellow-50/30 rounded-2xl border-2 border-amber-200/60 p-6" data-section="champions" data-state="empty">
          <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
            <h2 class="text-sm font-bold text-amber-900">${titleI18n}</h2>
            <div class="text-[.65rem] text-amber-700/80">${subtitleI18n}</div>
          </div>
          <div class="bg-white/50 rounded-xl p-4 mt-3 border border-amber-100">
            <div class="font-bold text-[.85rem] text-amber-900 mb-1">🏅 ${emptyTitleI18n}</div>
            <p class="text-[.7rem] text-[var(--text-secondary)] leading-relaxed">${emptyHintI18n}</p>
            ${errorMsg ? `<p class="text-[.55rem] text-red-500 mt-2 font-mono">${escapeHtmlSafe(errorMsg)}</p>` : ''}
          </div>
        </div>`;
    }

    const surfaceMeta: Record<string, { pt: string; en: string; es: string }> = {
      general:     { pt: '🏛️ Reunião geral',     en: '🏛️ General meeting',  es: '🏛️ Reunión general' },
      tribe:       { pt: '🏕️ Reunião de tribo',  en: '🏕️ Tribe meeting',    es: '🏕️ Reunión de tribu' },
      deliverable: { pt: '📦 Entregável',        en: '📦 Deliverable',       es: '📦 Entregable' },
    };
    const surfaceLabel = (s: string) => {
      const meta = surfaceMeta[s];
      if (!meta) return s;
      return lang === 'en-US' ? meta.en : lang === 'es-LATAM' ? meta.es : meta.pt;
    };

    const cards = history.slice(0, 5).map((c: any) => {
      const awarder = c.awarded_by?.name || (lang === 'en-US' ? 'Leadership' : lang === 'es-LATAM' ? 'Liderazgo' : 'Liderança');
      const initiative = c.initiative?.name ? ` · ${c.initiative.name}` : '';
      const criteriaLabel = lang === 'en-US' ? 'criteria' : lang === 'es-LATAM' ? 'criterios' : 'critérios';
      const safeJust = String(c.justification || '').replace(/[<>]/g, '');
      return `
        <div class="border border-[var(--border-default)] rounded-xl p-3 mb-2">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <span class="text-[.7rem] font-semibold text-navy">${surfaceLabel(c.surface)}</span>
            <span class="text-[.65rem] px-1.5 py-0.5 bg-emerald-50 text-emerald-700 rounded font-semibold">${c.points_awarded} pts</span>
            ${initiative ? `<span class="text-[.6rem] text-[var(--text-muted)]">${initiative}</span>` : ''}
          </div>
          <p class="text-[.7rem] text-[var(--text-secondary)] italic">"${safeJust}"</p>
          <p class="text-[.6rem] text-[var(--text-muted)] mt-1">— ${awarder} · ${criteriaLabel}: ${(c.criteria_met || []).join(', ')}</p>
        </div>`;
    }).join('');

    const totalSuffix = lang === 'en-US' ? `active · ${totals.active_points || 0} pts`
                      : lang === 'es-LATAM' ? `activo${total === 1 ? '' : 's'} · ${totals.active_points || 0} pts`
                      : `ativo${total === 1 ? '' : 's'} · ${totals.active_points || 0} pts`;

    return `
      <div class="bg-gradient-to-br from-amber-50/40 to-yellow-50/30 rounded-2xl border-2 border-amber-200/60 p-6" data-section="champions" data-state="active">
        <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
          <h2 class="text-sm font-bold text-amber-900">${titleI18n}</h2>
          <div class="text-[.7rem] text-amber-700/80">
            <strong class="text-amber-900">${total}</strong> ${totalSuffix}
          </div>
        </div>
        ${cards}
        ${history.length > 5 ? `<p class="text-[.65rem] text-amber-700/70 mt-1">+${history.length - 5}</p>` : ''}
      </div>`;
  }

  // ── Main render ──
  function attendanceHistoryHtml(): string {
    if (!attendanceHistory || attendanceHistory.length === 0) {
      return `
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-6">
          <h2 class="text-sm font-bold text-navy mb-3">${PROFILE_I18N.historyTitle}</h2>
          <p class="text-[.78rem] text-[var(--text-muted)]">${PROFILE_I18N.historyEmpty}</p>
        </div>`;
    }
    var attended = attendanceHistory.filter(function(r: any) { return r.present; }).length;
    var total = attendanceHistory.length;
    var rate = total > 0 ? Math.round((attended / total) * 100) : 0;
    var barColor = rate >= 75 ? '#22c55e' : rate >= 50 ? '#f59e0b' : '#ef4444';
    var summaryText = (PROFILE_I18N.historySummary || '')
      .replace('{attended}', String(attended))
      .replace('{total}', String(total))
      .replace('{rate}', String(rate));

    var locale = location.pathname.startsWith('/en') ? 'en-US' : location.pathname.startsWith('/es') ? 'es' : 'pt-BR';

    var rows = attendanceHistory.map(function(r: any) {
      var dateStr = '';
      try { dateStr = new Date(r.event_date + 'T00:00:00').toLocaleDateString(locale); } catch (_) { dateStr = r.event_date; }
      var typeLabel = HISTORY_TYPE_LABELS[r.event_type] || r.event_type || '';
      var statusDot = r.present
        ? '<span class="text-green-600 font-semibold text-[.75rem]" title="' + (PROFILE_I18N.historyPresent || 'Presente') + '">✅</span>'
        : r.excused
          ? '<span class="text-amber-500 font-semibold text-[.75rem]" title="' + (PROFILE_I18N.historyExcused || 'Justificado') + '">🟡</span>'
          : '<span class="text-red-400 font-semibold text-[.75rem]" title="' + (PROFILE_I18N.historyAbsent || 'Ausente') + '">❌</span>';

      return '<tr class="border-t border-[var(--border-default)] hover:bg-[var(--surface-hover)]">'
        + '<td class="px-3 py-2 whitespace-nowrap text-[.78rem]">' + dateStr + '</td>'
        + '<td class="px-3 py-2 text-[.78rem]">' + (r.event_title || '') + '</td>'
        + '<td class="px-3 py-2 whitespace-nowrap"><span class="px-2 py-0.5 rounded text-[.68rem] bg-[var(--surface-base)]">' + typeLabel + '</span></td>'
        + '<td class="px-3 py-2 text-center">' + statusDot + '</td>'
        + '</tr>';
    }).join('');

    return `
      <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-default)] p-6">
        <h2 class="text-sm font-bold text-navy mb-3">${PROFILE_I18N.historyTitle}</h2>
        <div class="mb-4 flex items-center gap-3">
          <div class="flex-1 h-3 rounded-full bg-[var(--surface-base)] overflow-hidden">
            <div class="h-full rounded-full transition-all" style="width:${rate}%;background:${barColor}"></div>
          </div>
          <span class="text-[.78rem] font-medium text-[var(--text-secondary)] whitespace-nowrap">${summaryText}</span>
        </div>
        <div class="overflow-x-auto rounded-lg border border-[var(--border-default)]">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-[var(--surface-base)] text-[var(--text-secondary)]">
                <th class="px-3 py-2 text-left font-medium text-[.75rem]">${PROFILE_I18N.historyDate}</th>
                <th class="px-3 py-2 text-left font-medium text-[.75rem]">${PROFILE_I18N.historyEvent}</th>
                <th class="px-3 py-2 text-left font-medium text-[.75rem]">${PROFILE_I18N.historyType}</th>
                <th class="px-3 py-2 text-center font-medium text-[.75rem]">${PROFILE_I18N.historyStatus}</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      </div>`;
  }

  function renderProfile(m: any) {
    const el = document.getElementById('profile-content');
    if (!el) return;

    // p123 i18n nav: `lp` (locale prefix) now module-level (p158 hotfix#8) so all sibling
    // template functions can reference it without scope issues.
