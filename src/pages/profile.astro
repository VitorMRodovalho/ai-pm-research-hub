              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-system" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefsTypeSystem}
              </label>
              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-mention" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefsTypeMention}
              </label>
              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-attendance_reminder" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefAttendanceReminder || 'Event reminders'}
              </label>
              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-attendance_detractor" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefDetractor || 'Detractor alerts'}
              </label>
              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-cr_approved" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefCr || 'CR updates'}
              </label>
              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-certificate_issued" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefCertificate || 'Certificates'}
