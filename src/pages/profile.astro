    // Card 2: Trail Progress
    const coursesCompleted = cycleStats?.coursesCompleted || 0;
    const trailPct = Math.round((coursesCompleted / 6) * 100);

    // Card 3: Pending Deliverables
    const pendingCount = weekData?.pendingDeliverables || 0;
    const tribeLink = weekData?.tribeId ? `/tribe/${weekData.tribeId}#deliverables` : '/#tribes';

