  // ── My Week helpers ──
  const DAY_NAMES = [
    PROFILE_I18N.daySun, PROFILE_I18N.dayMon, PROFILE_I18N.dayTue,
    PROFILE_I18N.dayWed, PROFILE_I18N.dayThu, PROFILE_I18N.dayFri,
    PROFILE_I18N.daySat,
  ];

  function getNextMeetingSlot(slots: any[]): any {
    if (!slots.length) return null;
    const now = new Date();
    const currentDay = now.getDay();
    const currentMinutes = now.getHours() * 60 + now.getMinutes();
    for (const slot of slots) {
      if (slot.day_of_week > currentDay) return slot;
      if (slot.day_of_week === currentDay) {
        const [h, m] = (slot.time_start || '00:00').split(':').map(Number);
        if (h * 60 + m > currentMinutes) return slot;
      }
    }
    return slots[0];
  }

  function myWeekHtml(_m: any): string {
    if (!weekData && !cycleStats) return '';

    // Card 1: Next Meeting
    let meetingContent = '';
    if (!weekData?.tribeId) {
      meetingContent = `<div class="text-[.75rem] text-amber-600">${PROFILE_I18N.weekChooseTribe}</div>`;
    } else if (!weekData.meetingSlots.length) {
      meetingContent = `<div class="text-[.75rem] text-[var(--text-muted)]">${PROFILE_I18N.weekNoMeeting}</div>`;
    } else {
      const next = getNextMeetingSlot(weekData.meetingSlots);
      if (next) {
        const day = DAY_NAMES[next.day_of_week] || '?';
        const time = next.time_start?.substring(0, 5) || '';
        meetingContent = `
          <div class="text-sm font-bold text-navy">${day}, ${time}</div>
          ${weekData.tribeMeetingLink
            ? `<a href="${weekData.tribeMeetingLink}" target="_blank" rel="noopener" data-action="external-link"
