  function normalizeCredlyFieldValue(input?: HTMLInputElement | null) {
    if (!input) return;
    const raw = input.value || '';
    const trimmed = raw.trim();
    if (!trimmed) {
      input.value = '';
      return;
    }
    const normalized = normalizeCredlyUrl(trimmed);
    if (normalized) input.value = normalized;
  }

  // ── Toggle password field visibility ──
  function toggleField(id: string) {
    const input = document.getElementById(id) as HTMLInputElement;
    if (!input) return;
    input.type = input.type === 'password' ? 'text' : 'password';
  }

  // ── Photo upload ──
  document.getElementById('self-photo-input')?.addEventListener('change', async (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    if (file.size > 2 * 1024 * 1024) { (window as any).toast?.('Foto excede 2MB', 'error'); return; }
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    try {
      const sanitized = (currentMember.email || 'user').replace(/[@.]/g, '_');
      const ext = file.type === 'image/png' ? 'png' : 'jpg';
      const path = `avatars/${sanitized}.${ext}`;
      const { error: uploadErr } = await sb.storage.from('member-photos').upload(path, file, { upsert: true });
      if (uploadErr) throw uploadErr;
      const { data: urlData } = sb.storage.from('member-photos').getPublicUrl(path);
      const photoUrl = urlData.publicUrl + '?t=' + Date.now();
      await sb.rpc('update_my_profile', { p_fields: { photo_url: photoUrl } });
      const avatarEl = document.getElementById('self-avatar');
      if (avatarEl) avatarEl.innerHTML = `<img src="${photoUrl}" class="w-16 h-16 rounded-full object-cover" alt="">`;
      (window as any).toast?.('Foto atualizada!', 'success');
    } catch (err: any) {
      (window as any).toast?.(err.message || PROFILE_I18N.photoUploadError || 'Error uploading photo', 'error');
    }
  });

  // ── Signature upload (event delegation — input may be re-rendered) ──
  document.addEventListener('change', async (e) => {
    const target = e.target as HTMLInputElement;
    if (target.id !== 'sig-upload') return;
    const file = target.files?.[0];
    if (!file) return;
    if (file.size > 500 * 1024) { (window as any).toast?.('Max 500KB', 'error'); return; }
    if (file.type !== 'image/png') { (window as any).toast?.('PNG only', 'error'); return; }
    const sb = (window as any).navGetSb?.();
    const member = (window as any).navGetMember?.();
    if (!sb || !member) return;
    try {
      const path = `signatures/${(member.email || 'user').replace(/[@.]/g, '_')}.png`;
      const { error } = await sb.storage.from('member-signatures').upload(path, file, { upsert: true });
      if (error) throw error;
      const { data: urlData } = sb.storage.from('member-signatures').getPublicUrl(path);
      const sigUrl = urlData.publicUrl + '?t=' + Date.now();
      await sb.rpc('update_my_profile', { p_fields: { signature_url: sigUrl } });
      const preview = document.getElementById('sig-preview');
      if (preview) preview.innerHTML = `<img src="${sigUrl}" class="max-w-[200px] max-h-[70px] border border-[var(--border-subtle)] rounded p-1" alt="">`;
      (window as any).toast?.('Assinatura salva!', 'success');
      target.value = '';
    } catch (err: any) { (window as any).toast?.(err.message || 'Erro', 'error'); }
  });
  document.addEventListener('click', async (e) => {
    if (!(e.target instanceof Element)) return;
    const target = e.target as HTMLElement;
    if (target.id !== 'sig-remove' && !target.closest('#sig-remove')) return;
    const sb = (window as any).navGetSb?.();
    const member = (window as any).navGetMember?.();
    if (!sb || !member) return;
    await sb.rpc('update_my_profile', { p_fields: { signature_url: '' } });
    const preview = document.getElementById('sig-preview');
    if (preview) preview.innerHTML = `<span class="text-[.7rem] text-[var(--text-muted)]">${PROFILE_I18N.noSignature || 'No signature'}</span>`;
    (window as any).toast?.('Assinatura removida', 'success');
  });

  // ── Save profile ──
  async function saveSelf() {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const credlyInput = (document.getElementById('self-credly') as HTMLInputElement)?.value || '';
    const credlyTrimmed = credlyInput.trim();
    let credlyToSave: string | null = null;
    if (credlyTrimmed) {
      const normalized = normalizeCredlyUrl(credlyTrimmed);
      if (!normalized) {
        (window as any).toast?.(PROFILE_I18N.invalidCredlyUrl, 'error');
        return;
      }
      credlyToSave = normalized;
      const credlyField = document.getElementById('self-credly') as HTMLInputElement;
      if (credlyField) credlyField.value = normalized;
    } else if (currentMember.credly_url) {
      credlyToSave = currentMember.credly_url;
    }
    const shareWaEl = document.getElementById('self-share-wa') as HTMLInputElement | null;
    const nameVal = (document.getElementById('self-name') as HTMLInputElement)?.value.trim();
    if (nameVal && nameVal.length < 2) {
      (window as any).toast?.('Nome precisa ter pelo menos 2 caracteres', 'error');
      return;
    }

    // Try new RPC first, fallback to old
    const fields: Record<string, any> = {};
    if (nameVal && nameVal !== currentMember.name) fields.name = nameVal;
    const phone = (document.getElementById('self-phone') as HTMLInputElement)?.value.trim() || null;
    if (phone !== (currentMember.phone || null)) fields.phone = phone;
    const li = (document.getElementById('self-li') as HTMLInputElement)?.value.trim() || null;
    if (li !== (currentMember.linkedin_url || null)) fields.linkedin_url = li;
    if (credlyToSave !== (currentMember.credly_url || null)) fields.credly_url = credlyToSave;
    const pmiId = (document.getElementById('self-pmi') as HTMLInputElement)?.value.trim() || null;
    if (pmiId !== (currentMember.pmi_id || null)) fields.pmi_id = pmiId;
    const shareWa = shareWaEl?.checked ?? false;
    if (shareWa !== currentMember.share_whatsapp) fields.share_whatsapp = shareWa;
    const stateVal = (document.getElementById('self-state') as HTMLInputElement)?.value.trim() || null;
    if (stateVal !== (currentMember.state || null)) fields.state = stateVal;
    const countryVal = (document.getElementById('self-country') as HTMLInputElement)?.value.trim() || null;
    if (countryVal !== (currentMember.country || null)) fields.country = countryVal;

    let data: any;
    if (Object.keys(fields).length > 0) {
      const res = await sb.rpc('update_my_profile', { p_fields: fields });
      data = res.data;
    } else {
      // No changes, but still call old RPC for backward compat
      const res = await sb.rpc('member_self_update', {
        p_pmi_id: pmiId, p_phone: phone, p_linkedin_url: li,
        p_credly_url: credlyToSave, p_share_whatsapp: shareWa,
      });
      data = res.data;
    }
    if (data?.error) (window as any).toast?.(data.error, 'error');
    else {
      try { if ((window as any).posthog) (window as any).posthog.capture('profile_updated', { fields_changed: Object.keys(fields) }); } catch {}
      (window as any).toast?.(PROFILE_I18N.dataSaved, 'success');
      const { data: updated } = await sb.rpc('get_member_by_auth');
      if (updated) { currentMember = updated; renderProfile(updated); }
    }
  }

  // ── Secondary email management ──
  async function addSecondaryEmail() {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const input = document.getElementById('new-secondary-email') as HTMLInputElement;
    const email = input?.value.trim().toLowerCase();
    if (!email || !email.includes('@')) {
      (window as any).toast?.(PROFILE_I18N.invalidEmail, 'error');
      return;
    }
    const existing = currentMember.secondary_emails || [];
    if (email === currentMember.email || existing.includes(email)) {
      (window as any).toast?.(PROFILE_I18N.emailAlreadyRegistered, 'error');
      return;
    }
    const newList = [...existing, email];
    const { error } = await sb.from('members').update({ secondary_emails: newList }).eq('id', currentMember.id);
    if (error) {
      (window as any).toast?.(PROFILE_I18N.errorAddPrefix + error.message, 'error');
    } else {
      currentMember.secondary_emails = newList;
      input.value = '';
      renderProfile(currentMember);
      (window as any).toast?.(PROFILE_I18N.emailAdded, 'success');
    }
  }

  async function removeSecondaryEmail(idx: number) {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const existing: string[] = currentMember.secondary_emails || [];
    const removed = existing[idx];
    if (!removed || !(await (window as any).confirmAction(PROFILE_I18N.removeEmailConfirm.replace('{email}', removed)))) return;
    const newList = existing.filter((_: string, i: number) => i !== idx);
    const { error } = await sb.from('members').update({ secondary_emails: newList }).eq('id', currentMember.id);
    if (error) {
      (window as any).toast?.(PROFILE_I18N.errorRemovePrefix + error.message, 'error');
    } else {
      currentMember.secondary_emails = newList;
      renderProfile(currentMember);
      (window as any).toast?.(PROFILE_I18N.emailRemoved.replace('{email}', removed), 'info');
    }
  }

  // ── Notification preferences ──
  async function loadNotifPrefs() {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const { data } = await sb.from('notification_preferences')
      .select('in_app, email_digest, muted_types')
      .eq('member_id', currentMember.id)
      .maybeSingle();
    if (!data) return; // defaults are all true / empty
    const inApp = document.getElementById('pref-in-app') as HTMLInputElement;
    const emailDigest = document.getElementById('pref-email-digest') as HTMLInputElement;
    if (inApp) inApp.checked = data.in_app !== false;
    if (emailDigest) emailDigest.checked = data.email_digest !== false;
    const mutedTypes: string[] = data.muted_types || [];
    for (const t of mutedTypes) {
      const el = document.getElementById(`mute-${t}`) as HTMLInputElement;
      if (el) el.checked = true;
    }
  }

  async function exportMyData() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { (window as any).toast?.('Supabase indisponível', 'error'); return; }
    try {
      const { data, error } = await sb.rpc('export_my_data');
      if (error) throw error;
      const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `meus-dados-${new Date().toISOString().slice(0,10)}.json`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      (window as any).toast?.('Dados exportados com sucesso', 'success');
    } catch (err: any) {
      (window as any).toast?.(err.message || PROFILE_I18N.exportError || 'Error exporting data', 'error');
    }
  }

  async function saveNotifPrefs() {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const inApp = (document.getElementById('pref-in-app') as HTMLInputElement)?.checked ?? true;
    const emailDigest = (document.getElementById('pref-email-digest') as HTMLInputElement)?.checked ?? true;
    const muteIds = ['assignment', 'curation_status', 'publication', 'system', 'mention', 'attendance_reminder', 'attendance_detractor', 'cr_approved', 'certificate_issued'];
    const mutedTypes = muteIds.filter(t => (document.getElementById(`mute-${t}`) as HTMLInputElement)?.checked);
    const { error } = await sb.rpc('update_notification_preferences', {
      p_prefs: { in_app: inApp, email_digest: emailDigest, muted_types: mutedTypes }
    });
    if (error) (window as any).toast?.(error.message, 'error');
    else (window as any).toast?.(PROFILE_I18N.notifPrefsSaved, 'success');
  }

  if (!(window as any).__profileDelegationBound) {
    (window as any).__profileDelegationBound = true;
    document.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!target) return;
      switch (target.dataset.action) {
        case 'toggle-field': {
          const fieldId = target.dataset.target;
          if (fieldId) toggleField(fieldId);
          break;
        }
        case 'save-self':
          saveSelf();
          break;
        case 'add-secondary-email':
          addSecondaryEmail();
          break;
        case 'remove-secondary-email': {
          const idx = parseInt(target.getAttribute('data-email-idx') || '0', 10);
          removeSecondaryEmail(idx);
          break;
        }
        case 'verify-credly':
          verifyCredly();
          break;
        case 'save-notif-prefs':
          saveNotifPrefs();
          break;
        case 'export-my-data':
          exportMyData();
          break;
        case 'link-provider': {
          const provider = (target as HTMLElement).dataset.provider;
          if (provider) linkProvider(provider);
          break;
        }
      }
    });

    document.addEventListener('focusout', (e: FocusEvent) => {
      const target = e.target as HTMLElement | null;
      if (target instanceof HTMLInputElement && target.id === 'self-credly') {
        normalizeCredlyFieldValue(target);
      }
    });

    document.addEventListener('paste', (e: ClipboardEvent) => {
      const target = e.target as HTMLElement | null;
      if (target instanceof HTMLInputElement && target.id === 'self-credly') {
        setTimeout(() => normalizeCredlyFieldValue(target), 100);
      }
    });

    document.addEventListener('input', (e: Event) => {
      const target = e.target as HTMLElement | null;
      if (target instanceof HTMLInputElement && target.id === 'self-credly') {
        if (credlyNormalizeTimer) clearTimeout(credlyNormalizeTimer);
        credlyNormalizeTimer = setTimeout(() => normalizeCredlyFieldValue(target), 300);
      }
    });
  }

  // ── Linked Providers ──
  async function loadLinkedProviders() {
    const list = document.getElementById('linked-providers-list');
    if (!list) return;
    try {
      const sb = (window as any).navGetSb?.();
      if (!sb) return;
      const { data: { user } } = await sb.auth.getUser();
      if (!user) return;
      const identities = user.identities || [];
      const providerIcons: Record<string, string> = { google: '🔵 Google', linkedin_oidc: '🔷 LinkedIn', azure: '🟦 Microsoft', email: '📧 Email' };
      if (!identities.length) {
        list.innerHTML = '<div class="text-[.72rem] text-[var(--text-muted)]">Nenhum provedor vinculado</div>';
        return;
      }
      list.innerHTML = identities.map((id: any) => {
        const label = providerIcons[id.provider] || `🔑 ${id.provider}`;
        const email = id.identity_data?.email || '';
        const date = id.created_at ? new Date(id.created_at).toLocaleDateString('pt-BR') : '';
        return `<div class="flex items-center justify-between py-1.5 px-3 bg-[var(--surface-base)] rounded-lg">
          <div class="text-[.78rem] font-medium">${label}</div>
          <div class="text-[.68rem] text-[var(--text-muted)]">${email} · ${date}</div>
        </div>`;
      }).join('');

      // Hide buttons for already-linked providers
      identities.forEach((id: any) => {
        const btn = document.querySelector(`[data-action="link-provider"][data-provider="${id.provider}"]`) as HTMLElement;
        if (btn) { btn.style.display = 'none'; }
      });
    } catch (e) { console.warn('loadLinkedProviders:', e); }
  }

  async function linkProvider(provider: string) {
    try {
      const sb = (window as any).navGetSb?.();
      if (!sb) { alert('Erro: cliente não inicializado'); return; }
      const { data, error } = await sb.auth.linkIdentity({
        provider,
        options: { redirectTo: window.location.origin + '/profile' }
      });
      if (error) throw error;
      // linkIdentity redirects to provider OAuth page
      if (data?.url) window.location.href = data.url;
    } catch (e: any) {
      alert('Erro ao vincular: ' + (e?.message || 'Erro desconhecido'));
    }
  }

  // ── Credly verification ──
  async function describeFnError(err: any): Promise<string> {
    if (!err) return PROFILE_I18N.unknownError;
    if (err.context && typeof err.context.json === 'function') {
      try {
        const payload = await err.context.json();
        const detail = payload?.error || payload?.message;
        if (detail) return detail;
      } catch {}
    }
    return err.message || PROFILE_I18N.unknownError;
  }

  async function verifyCredly() {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    await sb.auth.refreshSession();
    const { data: { session } } = await sb.auth.getSession();
    if (!session?.access_token) {
      (window as any).toast?.(PROFILE_I18N.credlyInvalidSession, 'error');
      return;
    }
    const credlyInput = (document.getElementById('self-credly') as HTMLInputElement)?.value || '';
    const credlyNormalized = credlyInput.trim() ? normalizeCredlyUrl(credlyInput) : normalizeCredlyUrl(currentMember.credly_url || '');
    if (!credlyNormalized) {
      (window as any).toast?.(PROFILE_I18N.credlyRequired, 'error');
      return;
    }
    const credlyField = document.getElementById('self-credly') as HTMLInputElement | null;
    if (credlyField) credlyField.value = credlyNormalized;

    // Persist the URL immediately so it survives page navigation
    await sb.rpc('member_self_update', { p_credly_url: credlyNormalized });

    const btn = document.getElementById('btn-credly-verify') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = PROFILE_I18N.credlyVerifying; }
    try {
      const supabaseUrl = (sb as any).supabaseUrl || (sb as any).rest?.url?.replace('/rest/v1', '') || '';
      const anonKey = (sb as any).supabaseKey || (sb as any).realtime?.params?.apikey || '';
      const callVerifyCredly = async (accessToken: string) => {
        const response = await fetch(supabaseUrl + '/functions/v1/verify-credly', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + accessToken, 'apikey': anonKey },
          body: JSON.stringify({ member_id: currentMember.id, credly_url: credlyNormalized }),
        });
        const body = await response.json().catch(() => ({}));
        return { response, body };
      };
      let data: any = null;
      let error: any = null;
      try {
        let accessToken = session.access_token;
        let { response, body } = await callVerifyCredly(accessToken);
        if (response.status === 401) {
          // Retry once with fresh session to reduce transient auth regressions.
          await sb.auth.refreshSession();
          const refreshed = await sb.auth.getSession();
          accessToken = refreshed?.data?.session?.access_token || '';
          if (!accessToken) {
            throw new Error(PROFILE_I18N.credlyInvalidSession);
          }
          ({ response, body } = await callVerifyCredly(accessToken));
        }
        if (!response.ok) { error = new Error(body?.error || response.statusText); }
        else { data = body; }
      } catch (e: any) { error = e; }
      if (error) throw new Error(await describeFnError(error));
      if (data?.success) {
        const matched = data.all_matched || 0;
        const total = data.total_badges || 0;
        const trailDetected = data.pmi_trail_count || 0;
        const trailSynced = data.pmi_trail_synced || 0;
        try { if ((window as any).posthog) (window as any).posthog.capture('credly_verified', { badges_found: total, has_cpmai: !!data.has_cpmai }); } catch {}
        const msg = data.has_cpmai
          ? PROFILE_I18N.credlyCpmaiMsg.replace('{matched}', matched).replace('{total}', total).replace('{trailDetected}', trailDetected).replace('{trailSynced}', trailSynced)
          : matched > 0
            ? PROFILE_I18N.credlyBadgesMsg.replace('{matched}', matched).replace('{total}', total).replace('{trailDetected}', trailDetected).replace('{trailSynced}', trailSynced)
            : PROFILE_I18N.credlyNoBadgesMsg.replace('{total}', total);
        (window as any).toast?.(msg, matched > 0 ? 'success' : 'info');
        const { data: updated } = await sb.rpc('get_member_by_auth');
        if (updated) { currentMember = updated; renderProfile(updated); }
      } else {
        (window as any).toast?.(data?.error || PROFILE_I18N.credlyVerifyError, 'error');
      }
    } catch (e: any) {
      (window as any).toast?.(e.message || PROFILE_I18N.credlyConnectError, 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = PROFILE_I18N.verifyCredly; }
    }
  }

  boot();
</script>
