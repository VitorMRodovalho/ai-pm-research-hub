---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
---
<BaseLayout title="Meu Perfil — Núcleo IA & GP" activePage="profile">
  <Toast />
  <div class="max-w-2xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-extrabold text-navy mb-6">👤 Meu Perfil</h1>
    <div id="profile-content" class="space-y-5">
      <div class="text-center text-slate-400 py-8">Carregando perfil…</div>
    </div>
  </div>
</BaseLayout>

<script>
  import { ROLE_COLORS } from '../lib/supabase';

  const OPROLE_LABELS: Record<string, string> = {
    manager: 'Gerente', deputy_manager: 'Deputy PM', tribe_leader: 'Líder de Tribo', researcher: 'Pesquisador',
    facilitator: 'Facilitador', communicator: 'Multiplicador', none: 'Sem papel operacional', guest: 'Convidado'
  };
  const OPROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', deputy_manager: '#FF610F', tribe_leader: '#4F17A8', researcher: '#EC4899',
    facilitator: '#06B6D4', communicator: '#8B5CF6', none: '#94A3B8', guest: '#94A3B8'
  };
  const DESIG_LABELS: Record<string, string> = {
    sponsor: 'Patrocinador', chapter_liaison: 'Ponto Focal', ambassador: 'Embaixador', founder: 'Fundador', curator: 'Curador', comms_team: 'Comunicação', co_gp: 'Co-GP', tribe_leader: 'Líder de Tribo'
  };
  const DESIG_COLORS: Record<string, string> = {
    sponsor: '#BE2027', chapter_liaison: '#BE2027', ambassador: '#10B981', founder: '#7C3AED', curator: '#D97706', comms_team: '#06B6D4', co_gp: '#FF610F', tribe_leader: '#4F17A8'
  };

  let currentMember: any = null;
  let cycleHistory: any[] = [];
  let cycleStats: any = null;

  // ── Boot ──
  async function boot() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(boot, 200); return; }

    window.addEventListener('nav:member', (async (e: CustomEvent) => {
      if (e.detail && e.detail.role !== 'guest') {
        currentMember = e.detail;
        await loadExtras(sb);
        renderProfile(currentMember);
      } else if (!e.detail) {
        location.href = '/?auth=required';
      }
    }) as EventListener);

    const m = (window as any).navGetMember?.();
    if (m && m.role !== 'guest') {
      currentMember = m;
      await loadExtras(sb);
      renderProfile(m);
      return;
    }

    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      const { data } = await sb.rpc('get_member_by_auth');
      if (data && data.role !== 'guest') {
        currentMember = data;
        await loadExtras(sb);
        renderProfile(data);
        return;
      }
    }
    location.href = '/?auth=required';
  }

  async function loadExtras(sb: any) {
    if (!currentMember?.id) return;
    // Load cycle history
    const { data: hist } = await sb.from('member_cycle_history')
      .select('*')
      .eq('member_id', currentMember.id)
      .order('cycle_start', { ascending: true });
    cycleHistory = hist || [];

    // Load stats for current cycle
    try {
      // Attendance count
      const { count: attendCount } = await sb.from('attendance')
        .select('*', { count: 'exact', head: true })
        .eq('member_id', currentMember.id);

      // Total events
      const { count: eventCount } = await sb.from('events')
        .select('*', { count: 'exact', head: true });

      // Course progress
      const { data: courses } = await sb.from('course_progress')
        .select('status')
        .eq('member_id', currentMember.id);

      // Gamification points
      const { data: points } = await sb.from('gamification_points')
        .select('points')
        .eq('member_id', currentMember.id);

      // Artifacts
      const { data: artifacts } = await sb.from('artifacts')
        .select('status')
        .eq('author_id', currentMember.id);

      const totalPoints = (points || []).reduce((s: number, p: any) => s + (p.points || 0), 0);
      const completedCourses = (courses || []).filter((c: any) => c.status === 'completed').length;
      const inProgressCourses = (courses || []).filter((c: any) => c.status === 'in_progress').length;

      cycleStats = {
        attendance: attendCount || 0,
        totalEvents: eventCount || 0,
        points: totalPoints,
        coursesCompleted: completedCourses,
        coursesInProgress: inProgressCourses,
        artifacts: {
          total: (artifacts || []).length,
          published: (artifacts || []).filter((a: any) => a.status === 'published').length,
          review: (artifacts || []).filter((a: any) => a.status === 'review').length,
          draft: (artifacts || []).filter((a: any) => a.status === 'draft').length,
        }
      };
    } catch (e) {
      cycleStats = null;
    }
  }

  // ── Completeness calculation ──
  function getCompleteness(m: any): { pct: number; missing: string[] } {
    const opRole = m.operational_role || 'guest';
    const isOperational = ['manager', 'deputy_manager', 'tribe_leader', 'researcher', 'facilitator', 'communicator'].includes(opRole);
    const missing: string[] = [];
    let earned = 0;
    let total = 0;

    const check = (field: any, label: string, weight: number) => {
      total += weight;
      if (field && String(field).trim() !== '') earned += weight;
      else missing.push(label);
    };

    if (isOperational) {
      check(m.photo_url, 'Foto', 15);
      check(m.pmi_id, 'PMI ID', 15);
      check(m.linkedin_url, 'LinkedIn', 15);
      check(m.phone, 'Telefone', 10);
      check(m.credly_url, 'Credly URL', 15);
      check(m.secondary_emails?.length, 'Email secundário', 10);
      check(m.tribe_id || null, 'Tribo selecionada', 10);
      check(cycleStats?.coursesCompleted || cycleStats?.coursesInProgress, '≥1 curso da trilha', 10);
    } else {
      check(m.photo_url, 'Foto', 20);
      check(m.pmi_id, 'PMI ID', 20);
      check(m.linkedin_url, 'LinkedIn', 20);
      check(m.phone, 'Telefone', 15);
      check(m.credly_url, 'Credly URL', 15);
      check(m.secondary_emails?.length, 'Email secundário', 10);
    }

    return { pct: total > 0 ? Math.round((earned / total) * 100) : 0, missing };
  }

  function completenessMessage(pct: number): string {
    if (pct >= 100) return '🏆 Perfil completo! +50 pontos de gamificação.';
    if (pct >= 71) return '🔥 Quase lá!';
    if (pct >= 31) return '💪 Bom progresso! Complete para aparecer no ranking.';
    return '📋 Seu perfil está incompleto — complete para ganhar pontos!';
  }

  function completenessColor(pct: number): string {
    if (pct >= 100) return '#10B981';
    if (pct >= 71) return '#FF610F';
    if (pct >= 31) return '#D97706';
    return '#BE2027';
  }

  // ── Role badges (3-axis) ──
  function roleBadgesHtml(m: any): string {
    let html = '';
    const opRole = m.operational_role || m.role || 'guest';
    if (opRole !== 'none' && opRole !== 'guest') {
      const c = OPROLE_COLORS[opRole] || '#94A3B8';
      html += `<span class="inline-block px-2 py-0.5 rounded-md text-[.62rem] font-bold uppercase" style="background:${c}22;color:${c}">${OPROLE_LABELS[opRole] || opRole}</span> `;
    }
    const desigs: string[] = m.designations?.length ? m.designations : [];
    desigs.forEach(d => {
      const c = DESIG_COLORS[d] || '#94A3B8';
      html += `<span class="inline-block px-2 py-0.5 rounded-md text-[.62rem] font-bold uppercase" style="background:${c}22;color:${c}">${DESIG_LABELS[d] || d}</span> `;
    });
    if (m.is_superadmin) {
      html += `<span class="inline-block px-2 py-0.5 rounded-md text-[.62rem] font-bold uppercase bg-orange/10 text-orange">🔧 Admin Plataforma</span>`;
    }
    return html;
  }

  // ── XP Level ──
  function getLevel(totalHours: number): { name: string; emoji: string; next: string; hoursToNext: number } {
    if (totalHours >= 401) return { name: 'Lenda IA', emoji: '🏆', next: '', hoursToNext: 0 };
    if (totalHours >= 201) return { name: 'Mestre IA', emoji: '💎', next: 'Lenda IA', hoursToNext: 401 - totalHours };
    if (totalHours >= 91) return { name: 'Especialista IA', emoji: '🔥', next: 'Mestre IA', hoursToNext: 201 - totalHours };
    if (totalHours >= 31) return { name: 'Praticante IA', emoji: '⚡', next: 'Especialista IA', hoursToNext: 91 - totalHours };
    return { name: 'Explorador IA', emoji: '🌱', next: 'Praticante IA', hoursToNext: 31 - totalHours };
  }

  // ── Timeline ──
  function timelineHtml(): string {
    if (!cycleHistory.length) return '';
    const CYCLE_COLORS: Record<string, string> = {
      pilot: '#D97706', cycle_1: '#4F17A8', cycle_2: '#00799E', cycle_3: '#FF610F'
    };
    return `
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-bold text-navy mb-4">📅 Minha Jornada no Núcleo</h2>
        <div class="relative pl-6 border-l-2 border-slate-200 space-y-4">
          ${cycleHistory.map(h => {
            const color = CYCLE_COLORS[h.cycle_code] || '#94A3B8';
            const isCurrent = !h.cycle_end;
            const opLabel = OPROLE_LABELS[h.operational_role] || h.operational_role;
            const dLabels = (h.designations || []).map((d: string) => DESIG_LABELS[d] || d);
            const allLabels = [
              ...(h.operational_role !== 'none' && h.operational_role !== 'guest' ? [opLabel] : []),
              ...dLabels
            ];

            return `
              <div class="relative">
                <div class="absolute -left-[25px] top-1 w-3 h-3 rounded-full border-2 border-white" 
                     style="background:${color}"></div>
                <div class="rounded-xl p-3 ${isCurrent ? 'bg-orange/5 border border-orange/20' : 'bg-slate-50 border border-slate-100'}">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="text-[.72rem] font-bold" style="color:${color}">${h.cycle_label}</span>
                    ${isCurrent ? '<span class="text-[.58rem] font-bold px-1.5 py-0.5 rounded-full bg-orange/10 text-orange animate-pulse">ATIVO</span>' : ''}
                  </div>
                  <div class="text-[.72rem] text-slate-600 mt-1">
                    ${allLabels.length ? allLabels.join(' · ') : '<span class="text-slate-400">Participante</span>'}
                  </div>
                  ${h.tribe_name ? `<div class="text-[.65rem] text-slate-400 mt-0.5">🏷️ ${h.tribe_name}</div>` : ''}
                  <div class="text-[.65rem] text-slate-400 mt-0.5">${h.chapter || ''}</div>
                </div>
              </div>`;
          }).join('')}
        </div>
      </div>`;
  }

  // ── Dashboard cards ──
  function dashboardHtml(m: any): string {
    const opRole = m.operational_role || 'guest';
    const isOperational = ['manager', 'deputy_manager', 'tribe_leader', 'researcher', 'facilitator', 'communicator'].includes(opRole);
    if (!cycleStats) return '';

    const pctAttend = cycleStats.totalEvents > 0
      ? Math.round((cycleStats.attendance / cycleStats.totalEvents) * 100)
      : 0;

    let cardsHtml = `
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-lg font-black text-navy">${cycleStats.points}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">🏆 Pontos</div>
        </div>`;

    if (isOperational) {
      cardsHtml += `
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-lg font-black text-navy">${cycleStats.attendance}/${cycleStats.totalEvents}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">📅 Presenças (${pctAttend}%)</div>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-lg font-black text-navy">${cycleStats.coursesCompleted}/8</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">📚 Trilha IA</div>
        </div>`;
    }

    cardsHtml += `
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <div class="text-lg font-black text-navy">${cycleStats.artifacts.total}</div>
          <div class="text-[.65rem] text-slate-400 font-semibold">📝 Artefatos</div>
        </div>
      </div>`;

    return `
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-bold text-navy mb-4">📊 Ciclo 3 (2026/1)</h2>
        ${cardsHtml}
      </div>`;
  }

  // ── Main render ──
  function renderProfile(m: any) {
    const el = document.getElementById('profile-content');
    if (!el) return;

    const initials = m.name.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
    const comp = getCompleteness(m);
    const barColor = completenessColor(comp.pct);
    const secondaryEmails: string[] = m.secondary_emails || [];

    // XP level (placeholder hours — would come from a view/RPC in production)
    const totalHours = cycleStats?.points ? Math.round(cycleStats.points / 10) : 0; // rough proxy
    const level = getLevel(totalHours);

    el.innerHTML = `
      <!-- Card: Identity + Completeness -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <div class="flex items-center gap-4 mb-4">
          ${m.photo_url
            ? `<img src="${m.photo_url}" class="w-16 h-16 rounded-full object-cover border-2 border-slate-100">`
            : `<div class="w-16 h-16 rounded-full bg-teal flex items-center justify-center text-white font-bold text-xl">${initials}</div>`
          }
          <div class="flex-1 min-w-0">
            <div class="font-extrabold text-lg text-navy">${m.name}</div>
            <div class="text-sm text-slate-500">${m.chapter || '—'}</div>
            <div class="mt-1 flex flex-wrap gap-1">${roleBadgesHtml(m)}</div>
          </div>
          <div class="text-center flex-shrink-0 hidden sm:block">
            <div class="text-2xl">${level.emoji}</div>
            <div class="text-[.65rem] font-bold text-slate-500">${level.name}</div>
          </div>
        </div>

        <!-- Completeness bar -->
        <div class="mt-2">
          <div class="flex items-center justify-between mb-1">
            <span class="text-[.7rem] font-semibold text-slate-500">Completude do Perfil</span>
            <span class="text-[.7rem] font-bold" style="color:${barColor}">${comp.pct}%</span>
          </div>
          <div class="w-full h-2.5 bg-slate-100 rounded-full overflow-hidden">
            <div class="h-full rounded-full transition-all duration-500" 
                 style="width:${comp.pct}%;background:${barColor}"></div>
          </div>
          <div class="mt-1.5 text-[.68rem] text-slate-400">
            ${completenessMessage(comp.pct)}
            ${comp.missing.length > 0 && comp.pct < 100
              ? ` Falta: <strong>${comp.missing.join(', ')}</strong>.`
              : ''}
          </div>
        </div>
      </div>

      <!-- Dashboard: Current Cycle -->
      ${dashboardHtml(m)}

      <!-- Timeline: Cycle History -->
      ${timelineHtml()}

      <!-- Card: Emails -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-bold text-navy mb-4">📧 Emails Cadastrados</h2>
        <p class="text-[.75rem] text-slate-400 mb-3">
          Usado para login, vinculação de certificações (Credly) e comunicações. Adicione emails alternativos para melhor matching.
        </p>
        <div class="flex items-center gap-2 py-2 px-3 bg-slate-50 rounded-lg mb-2">
          <span class="text-sm flex-1">${m.email}</span>
          <span class="text-[.65rem] font-bold text-teal uppercase bg-teal/10 px-2 py-0.5 rounded">Principal</span>
        </div>
        <div id="secondary-emails-list">
          ${secondaryEmails.map((e: string, i: number) => `
            <div class="flex items-center gap-2 py-2 px-3 bg-slate-50/50 rounded-lg mb-2">
              <span class="text-sm flex-1">${e}</span>
              <button onclick="removeSecondaryEmail(${i})"
                class="text-[.7rem] font-semibold text-red-500 hover:text-red-700 cursor-pointer bg-transparent border-0 px-2 py-0.5 rounded hover:bg-red-50 transition-all">✕ Remover</button>
            </div>
          `).join('')}
        </div>
        <div class="flex gap-2 mt-2">
          <input type="email" id="new-secondary-email" placeholder="outro@email.com"
            class="flex-1 px-3 py-2 border-[1.5px] border-slate-200 rounded-lg text-sm focus:outline-none focus:border-teal">
          <button onclick="addSecondaryEmail()"
            class="px-3 py-2 bg-teal text-white rounded-lg text-sm font-semibold cursor-pointer border-0 hover:opacity-90 transition-all flex-shrink-0">
            + Adicionar
          </button>
        </div>
      </div>

      <!-- Card: Personal data -->
      <div class="bg-white rounded-2xl border border-slate-200 p-6">
        <h2 class="text-sm font-bold text-navy mb-4">🔒 Dados Pessoais</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-[.7rem] font-bold text-slate-400 uppercase tracking-wide mb-1">PMI ID</label>
            <div class="relative">
              <input type="password" id="self-pmi" value="${m.pmi_id || ''}" placeholder="Ex: 5975367"
                class="w-full px-3 py-2 pr-10 border-[1.5px] border-slate-200 rounded-xl text-sm focus:outline-none focus:border-teal">
              <button onclick="toggleField('self-pmi')" type="button"
                class="absolute right-2 top-1/2 -translate-y-1/2 bg-transparent border-0 cursor-pointer text-slate-400 hover:text-slate-600 text-base p-1">👁</button>
            </div>
          </div>
          <div>
            <label class="block text-[.7rem] font-bold text-slate-400 uppercase tracking-wide mb-1">Telefone</label>
            <div class="relative">
              <input type="password" id="self-phone" value="${m.phone || ''}" placeholder="+55 (00) 00000-0000"
                class="w-full px-3 py-2 pr-10 border-[1.5px] border-slate-200 rounded-xl text-sm focus:outline-none focus:border-teal">
              <button onclick="toggleField('self-phone')" type="button"
                class="absolute right-2 top-1/2 -translate-y-1/2 bg-transparent border-0 cursor-pointer text-slate-400 hover:text-slate-600 text-base p-1">👁</button>
            </div>
          </div>
          <div class="sm:col-span-2">
            <label class="block text-[.7rem] font-bold text-slate-400 uppercase tracking-wide mb-1">LinkedIn</label>
            <input type="text" inputmode="url" id="self-li" value="${m.linkedin_url || ''}" placeholder="https://linkedin.com/in/…"
              class="w-full px-3 py-2 border-[1.5px] border-slate-200 rounded-xl text-sm focus:outline-none focus:border-teal">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-[.7rem] font-bold text-slate-400 uppercase tracking-wide mb-1">Credly (perfil público)</label>
            <input type="text" inputmode="url" id="self-credly" value="${m.credly_url || ''}" placeholder="https://www.credly.com/users/seu-nome"
              class="w-full px-3 py-2 border-[1.5px] border-slate-200 rounded-xl text-sm focus:outline-none focus:border-teal">
            <div class="flex items-center gap-2 mt-1">
              <p class="text-[.68rem] text-slate-400 flex-1">Usado para validar certificações PMI automaticamente. Opcional.</p>
              <button id="btn-credly-verify" onclick="verifyCredly()"
                class="px-3 py-1.5 bg-teal text-white rounded-lg text-[.7rem] font-semibold cursor-pointer border-0 hover:opacity-90 transition-all flex-shrink-0">
                🔍 Verificar Credly
              </button>
            </div>
          </div>
        </div>
        <div class="mt-5 flex justify-end">
          <button onclick="saveSelf()"
            class="px-5 py-2.5 bg-navy text-white rounded-xl font-semibold text-sm hover:opacity-90 transition-all cursor-pointer border-0">
            💾 Salvar Alterações
          </button>
        </div>
      </div>
    `;
  }

  // ── Toggle password field visibility ──
  (window as any).toggleField = (id: string) => {
    const input = document.getElementById(id) as HTMLInputElement;
    if (!input) return;
    input.type = input.type === 'password' ? 'text' : 'password';
  };

  // ── Save profile ──
  (window as any).saveSelf = async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const { data } = await sb.rpc('member_self_update', {
      p_pmi_id: (document.getElementById('self-pmi') as HTMLInputElement)?.value.trim() || null,
      p_phone: (document.getElementById('self-phone') as HTMLInputElement)?.value.trim() || null,
      p_linkedin_url: (document.getElementById('self-li') as HTMLInputElement)?.value.trim() || null,
      p_credly_url: (document.getElementById('self-credly') as HTMLInputElement)?.value.trim() || null,
    });
    if (data?.error) (window as any).toast?.(data.error, 'error');
    else {
      (window as any).toast?.('Dados salvos ✅', 'success');
      // Reload to update completeness bar
      const { data: updated } = await sb.rpc('get_member_by_auth');
      if (updated) { currentMember = updated; renderProfile(updated); }
    }
  };

  // ── Secondary email management ──
  (window as any).addSecondaryEmail = async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const input = document.getElementById('new-secondary-email') as HTMLInputElement;
    const email = input?.value.trim().toLowerCase();
    if (!email || !email.includes('@')) {
      (window as any).toast?.('Digite um email válido', 'error');
      return;
    }
    const existing = currentMember.secondary_emails || [];
    if (email === currentMember.email || existing.includes(email)) {
      (window as any).toast?.('Este email já está cadastrado', 'error');
      return;
    }
    const newList = [...existing, email];
    const { error } = await sb.from('members').update({ secondary_emails: newList }).eq('id', currentMember.id);
    if (error) {
      (window as any).toast?.('Erro ao adicionar: ' + error.message, 'error');
    } else {
      currentMember.secondary_emails = newList;
      input.value = '';
      renderProfile(currentMember);
      (window as any).toast?.('Email adicionado ✅', 'success');
    }
  };

  (window as any).removeSecondaryEmail = async (idx: number) => {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const existing: string[] = currentMember.secondary_emails || [];
    const removed = existing[idx];
    if (!removed || !confirm(`Remover ${removed}?`)) return;
    const newList = existing.filter((_: string, i: number) => i !== idx);
    const { error } = await sb.from('members').update({ secondary_emails: newList }).eq('id', currentMember.id);
    if (error) {
      (window as any).toast?.('Erro ao remover: ' + error.message, 'error');
    } else {
      currentMember.secondary_emails = newList;
      renderProfile(currentMember);
      (window as any).toast?.(`${removed} removido`, 'info');
    }
  };

  // ── Credly verification ──
  (window as any).verifyCredly = async () => {
    const sb = (window as any).navGetSb?.();
    if (!sb || !currentMember) return;
    const btn = document.getElementById('btn-credly-verify') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = '⏳ Verificando...'; }
    try {
      const { data, error } = await sb.functions.invoke('verify-credly', {
        body: { member_id: currentMember.id, credly_url: (document.getElementById('self-credly') as HTMLInputElement)?.value.trim() || currentMember.credly_url },
      });
      if (error) throw error;
      if (data?.success) {
        const matched = data.all_matched || 0;
        const total = data.total_badges || 0;
        const msg = data.has_cpmai
          ? `🎉 CPMAI verificada! ${matched} badge(s) encontrada(s) de ${total} no Credly.`
          : matched > 0
            ? `✅ ${matched} badge(s) verificada(s) de ${total} no Credly.`
            : `ℹ️ ${total} badge(s) encontrada(s) no Credly, nenhuma da trilha PMI-AI.`;
        (window as any).toast?.(msg, matched > 0 ? 'success' : 'info');
        const { data: updated } = await sb.rpc('get_member_by_auth');
        if (updated) { currentMember = updated; renderProfile(updated); }
      } else {
        (window as any).toast?.(data?.error || 'Erro na verificação', 'error');
      }
    } catch (e: any) {
      (window as any).toast?.(e.message || 'Erro ao conectar com Credly', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = '🔍 Verificar Credly'; }
    }
  };

  boot();
</script>
