  completenessGood: t('profile.completeness.good', lang),
  completenessIncomplete: t('profile.completeness.incomplete', lang),
  fieldPhoto: t('profile.field.photo', lang),
  fieldPmiId: t('profile.field.pmiId', lang),
  fieldLinkedin: t('profile.field.linkedin', lang),
  fieldPhone: t('profile.field.phone', lang),
  fieldCredlyUrl: t('profile.field.credlyUrl', lang),
  fieldSecondaryEmail: t('profile.field.secondaryEmail', lang),
  fieldCycleLink: t('profile.field.cycleLink', lang),
  fieldTrailCourse: t('profile.field.trailCourse', lang),
  levelLegend: t('profile.level.legend', lang),
  levelMaster: t('profile.level.master', lang),
  levelExpert: t('profile.level.expert', lang),
  levelPractitioner: t('profile.level.practitioner', lang),
