          <div class="border-t border-[var(--border-default)] pt-3">
            <div class="text-[.75rem] font-bold text-[var(--text-secondary)] mb-2">${PROFILE_I18N.notifPrefsMuteTypes}</div>
            <div class="flex flex-wrap gap-2">
              <label class="inline-flex items-center gap-1.5 text-[.75rem] text-navy cursor-pointer">
                <input type="checkbox" id="mute-assignment" class="accent-teal w-3.5 h-3.5"> ${PROFILE_I18N.notifPrefsTypeAssignment}
