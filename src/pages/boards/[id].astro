---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BoardEngine from '../../components/islands/BoardEngine';
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
import { buildPageI18n } from '../../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const { id } = Astro.params;
const i18nBundle = buildPageI18n(['comp.board', 'comp.card', 'common'], lang);
---
<BaseLayout title={t('boards.title', lang)} activePage="boards" lang={lang}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <main class="max-w-[1400px] mx-auto px-4 py-6">
    <div class="mb-4">
      <a href={lang === 'pt-BR' ? '/boards' : `/${lang.split('-')[0]}/boards`}
        class="text-xs font-semibold text-navy no-underline hover:underline">
        ← {t('boards.title', lang)}
      </a>
    </div>
    <BoardEngine client:load boardId={id} />
  </main>
</BaseLayout>
