---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromURL, t, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
---
<BaseLayout title={t('volunteer.title', lang)} activePage="volunteer-agreement" lang={lang}>
  <main class="max-w-[720px] mx-auto px-4 py-8" id="va-app">
    <div class="text-center py-12 text-[var(--text-muted)]" id="va-loading">...</div>
  </main>
</BaseLayout>

<script is:inline define:vars={{ lang }}>
  window.__vaLang = lang;
</script>

<script is:inline define:vars={{ langPrefix }}>
  window.__LANG_PREFIX = langPrefix;
</script>
<script>
  const lp: string = (typeof window !== 'undefined' && (window as any).__LANG_PREFIX) || '';
  import { getSupabase } from '../lib/supabase';
  import { t } from '../i18n/utils';
  import type { Lang } from '../i18n/utils';

  function esc(s: any): string { return String(s || '').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
  function fmtDatetime(d: string, lang: Lang): string {
    if (!d) return '';
    const locale = lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es-ES' : 'pt-BR';
    return new Date(d).toLocaleString(locale, { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  const CLAUSE_KEYS = [
    'clause1', 'clause2', 'clause3', 'clause4', 'clause5', 'clause6',
    'clause7', 'clause8', 'clause9', 'clause10', 'clause11', 'clause12',
  ] as const;

  const SUB_CLAUSES: Record<string, string[]> = {
    clause1: ['clause1a', 'clause1b', 'clause1c'],
    clause2: ['clause2_1', 'clause2_2', 'clause2_3', 'clause2_4', 'clause2_5'],
    clause7: ['clause7a'],
    clause9: ['clause9a', 'clause9b', 'clause9c', 'clause9d', 'clause9e', 'clause9f', 'clause9note'],
  };

  function renderForm(member: any, lang: Lang, template: any): string {
    const tribeName = member.tribe_name || '—';
    const roleName = member.operational_role || '—';
    const cycle = new Date().getFullYear();
    const subtitle = t('volunteer.subtitle', lang).replace('{cycle}', '3').replace('{year}', String(cycle));

    return `
      <header class="mb-6 text-center">
        <img src="/assets/logos/pmigo.png" alt="PMI Goiás" class="h-12 w-auto mx-auto mb-2" />
        <div class="text-[10px] font-bold uppercase tracking-[.15em] text-[var(--text-muted)] mb-1">PMI Goiás — Núcleo de Estudos e Pesquisa em IA & GP</div>
        <h1 class="text-xl font-bold text-[var(--text-primary)]">${t('volunteer.title', lang)}</h1>
        <p class="text-[var(--text-secondary)] text-sm mt-1">${subtitle}</p>
      </header>

      <!-- Header intro -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.headerIntro', lang)}</p>
      </div>

      <!-- Member data -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-3">${t('volunteer.memberData', lang)}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          ${member.pmi_id ? `<div><span class="text-[var(--text-muted)]">${t('volunteer.pmiId', lang)}:</span> <strong class="text-[var(--text-primary)]">${esc(member.pmi_id)}</strong></div>` : ''}
          <div><span class="text-[var(--text-muted)]">${t('volunteer.name', lang)}:</span> <strong class="text-[var(--text-primary)]">${esc(member.name)}</strong></div>
          <div><span class="text-[var(--text-muted)]">${t('volunteer.email', lang)}:</span> <span class="text-[var(--text-primary)]">${esc(member.email)}</span></div>
          <div><span class="text-[var(--text-muted)]">${t('volunteer.tribe', lang)}:</span> <span class="text-[var(--text-primary)]">${esc(tribeName)}</span></div>
          <div><span class="text-[var(--text-muted)]">${t('volunteer.role', lang)}:</span> <span class="text-[var(--text-primary)]">${esc(roleName)}</span></div>
        </div>
      </div>

      <!-- Preamble -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <p class="text-sm text-[var(--text-primary)] font-medium leading-relaxed">${t('volunteer.preamble', lang)}</p>
      </div>

      <!-- Terms (12 clauses) -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-4">${t('volunteer.termsTitle', lang)}</h3>
        <ol class="space-y-4 list-none">
          ${CLAUSE_KEYS.map((key, i) => {
            const subs = SUB_CLAUSES[key];
            const clauseText = template?.[key] || t('volunteer.' + key, lang);
            let html = `
              <li class="text-sm text-[var(--text-secondary)] leading-relaxed">
                <div class="flex gap-2">
                  <span class="text-[var(--text-muted)] font-bold shrink-0">${i + 1}.</span>
                  <span>${esc(clauseText)}</span>
                </div>`;
            if (subs) {
              html += `<ol class="mt-2 ml-6 space-y-2">`;
              subs.forEach((subKey) => {
                const subText = template?.[subKey] || t('volunteer.' + subKey, lang);
                const isNote = subKey.endsWith('note');
                const isNumbered = /_\d+$/.test(subKey);
                const letter = isNote || isNumbered ? '' : subKey.slice(-1) + ')';
                html += `
                  <li class="text-[13px] text-[var(--text-secondary)] leading-relaxed ${isNote ? 'mt-3 italic border-l-2 border-[var(--border-subtle)] pl-3' : ''}">
                    <div class="flex gap-2">
                      ${letter ? `<span class="text-[var(--text-muted)] font-semibold shrink-0">${letter}</span>` : ''}
                      <span>${esc(subText)}</span>
                    </div>
                  </li>`;
              });
              html += `</ol>`;
            }
            html += `</li>`;
            return html;
          }).join('')}
        </ol>
      </div>

      <!-- Annex: Lei 9.608 -->
      <details class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <summary class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] cursor-pointer">${t('volunteer.annexTitle', lang)}</summary>
        <div class="mt-3 space-y-3">
          <p class="text-[13px] text-[var(--text-muted)] italic">${t('volunteer.annexIntro', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed font-medium">${t('volunteer.annexArt1', lang)}</p>
          <p class="text-[13px] text-[var(--text-secondary)] leading-relaxed italic ml-4">${t('volunteer.annexArt1p', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt2', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt3', lang)}</p>
          <p class="text-[13px] text-[var(--text-secondary)] leading-relaxed italic ml-4">${t('volunteer.annexArt3p', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt4', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt5', lang)}</p>
        </div>
      </details>

      <!-- Sign section -->
      <div id="va-sign-section" class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 scroll-mt-4">
        <label class="flex items-start gap-3 cursor-pointer mb-4">
          <input type="checkbox" id="va-agree" class="mt-1 w-4 h-4 accent-navy" />
          <span class="text-sm font-medium text-[var(--text-primary)]">${t('volunteer.checkbox', lang)}</span>
        </label>
        <button id="va-sign-btn" disabled
          class="w-full py-3 rounded-lg bg-navy text-white text-sm font-bold border-0 cursor-pointer hover:opacity-90 disabled:opacity-40 disabled:cursor-not-allowed transition-opacity">
          ${t('volunteer.signButton', lang)}
        </button>
        <p class="text-[10px] text-[var(--text-muted)] mt-3 text-center leading-relaxed">
          \u24D8 ${t('volunteer.legalNotice', lang)}
        </p>
      </div>`;
  }

  function renderSuccess(result: any, lang: Lang, extras?: { tribeLink?: string | null }): string {
    const tribeLink = extras?.tribeLink || null;
    return `
      <div class="text-center py-8">
        <div class="text-4xl mb-3">\u2705</div>
        <h2 class="text-xl font-bold text-emerald-700 dark:text-emerald-400 mb-4">${t('volunteer.success.title', lang)}</h2>
        <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 text-left space-y-2 text-sm max-w-sm mx-auto">
          <div class="flex justify-between"><span class="text-[var(--text-muted)]">${t('volunteer.success.code', lang)}</span><code class="font-mono text-[12px] bg-[var(--surface-hover)] px-2 py-0.5 rounded">${esc(result.verification_code)}</code></div>
          <div class="flex justify-between"><span class="text-[var(--text-muted)]">${t('volunteer.success.hash', lang)}</span><code class="font-mono text-[10px] text-[var(--text-muted)]">${(result.signature_hash || '').slice(0, 16)}...</code></div>
          <div class="flex justify-between"><span class="text-[var(--text-muted)]">${t('volunteer.success.date', lang)}</span><span class="text-[var(--text-primary)]">${fmtDatetime(result.signed_at, lang)}</span></div>
        </div>

        <!-- A4: next steps (replaces the dead-end) -->
        <div class="mt-6 max-w-sm mx-auto text-left bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5">
          <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-2">${t('volunteer.success.nextTitle', lang)}</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed mb-4">${t('volunteer.success.nextIntro', lang)}</p>
          <a href="${lp}/workspace" class="block w-full text-center px-4 py-3 rounded-lg bg-navy text-white text-sm font-bold no-underline hover:opacity-90 transition-opacity">
            ${t('volunteer.success.workspaceCta', lang)} \u2192
          </a>
          <p class="text-[11px] text-[var(--text-muted)] mt-2 text-center">${t('volunteer.success.workspaceHint', lang)}</p>
          ${tribeLink ? `
          <a href="${encodeURI(tribeLink)}" target="_blank" rel="noopener noreferrer" class="block w-full text-center mt-3 px-4 py-2.5 rounded-lg bg-emerald-600 text-white text-sm font-semibold no-underline hover:bg-emerald-700 transition-colors">
            \uD83D\uDCAC ${t('volunteer.success.whatsappCta', lang)}
          </a>` : ''}
        </div>

        <p class="text-xs text-[var(--text-muted)] mt-4">${t('volunteer.success.pending', lang)}</p>
        <a href="${lp}/verify/${encodeURIComponent(result.verification_code)}" class="inline-block mt-2 px-4 py-2 rounded-lg bg-[var(--surface-card)] border border-[var(--border-default)] text-sm font-semibold text-navy no-underline hover:bg-[var(--surface-hover)]">
          \uD83D\uDD0D ${t('volunteer.success.verify', lang)}
        </a>
      </div>`;
  }

  // W3c-ii (B8): a returned (rejected) term shows a banner above the form so the member knows why
  // they must re-sign. Reuses the rejection reason surfaced by get_my_certificates (revoked_reason).
  function renderRejectedBanner(reason: string | null, lang: Lang): string {
    const reasonHtml = reason ? `<div class="mt-1 text-[13px] text-orange-800 dark:text-orange-300"><span class="font-semibold">${esc(t('volunteer.rejected.reasonLabel', lang))}:</span> ${esc(reason)}</div>` : '';
    return `
      <div class="rounded-xl border-2 border-orange-300 bg-orange-50 dark:bg-orange-900/20 dark:border-orange-700 p-4 mb-4">
        <div class="flex items-start gap-2">
          <span class="text-xl">↩️</span>
          <div>
            <div class="font-bold text-sm text-orange-800 dark:text-orange-300">${esc(t('volunteer.rejected.title', lang))}</div>
            <p class="text-[13px] text-orange-700 dark:text-orange-400 mt-0.5">${esc(t('volunteer.rejected.description', lang))}</p>
            ${reasonHtml}
            <a href="#va-sign-section" class="inline-block mt-2 text-[13px] font-semibold text-orange-700 dark:text-orange-300 underline">${esc(t('volunteer.rejected.goToSign', lang))} ↓</a>
          </div>
        </div>
      </div>`;
  }

  function renderAlreadySigned(lang: Lang): string {
    return `
      <div class="text-center py-12">
        <div class="text-4xl mb-3">\u2705</div>
        <h2 class="text-lg font-bold text-[var(--text-primary)]">${t('volunteer.alreadySigned', lang)}</h2>
        <a href="${lp}/certificates" class="inline-block mt-4 px-4 py-2 rounded-lg bg-navy text-white text-sm font-semibold no-underline hover:opacity-90">
          ${t('volunteer.alreadySigned.viewCerts', lang)}
        </a>
      </div>`;
  }

  // B4 (Wave 4): the volunteer term is under a governance "signature hold" whenever no
  // template is active (the term is being revised \u2014 new IP/governance version + corrective
  // addendum). In that state sign_volunteer_agreement returns template_not_found, so rather
  // than letting the member fill a form that errors at submit, communicate the pause with
  // dignity: it is not their fault, they will be notified, and an addendum is coming.
  function renderPaused(lang: Lang): string {
    return `
      <div class="max-w-md mx-auto py-4">
        <div class="rounded-2xl border-2 border-sky-300 bg-sky-50 dark:bg-sky-900/20 dark:border-sky-700 p-6 text-center">
          <div class="text-4xl mb-3"><span role="img" aria-label="${esc(t('volunteer.paused.iconLabel', lang))}">\u23f3</span></div>
          <h2 class="text-lg font-bold text-sky-800 dark:text-sky-300 mb-2">${esc(t('volunteer.paused.title', lang))}</h2>
          <p class="text-sm text-sky-700 dark:text-sky-400 leading-relaxed mb-3">${esc(t('volunteer.paused.description', lang))}</p>
          <p class="text-[13px] text-sky-600 dark:text-sky-400 italic mb-5">${esc(t('volunteer.paused.addendumNote', lang))}</p>
          <a href="${lp}/workspace" class="inline-block px-5 py-2.5 rounded-lg bg-navy text-white text-sm font-bold no-underline hover:opacity-90 transition-opacity">
            ${esc(t('volunteer.paused.backCta', lang))} \u2192
          </a>
          <p class="text-[11px] text-[var(--text-muted)] mt-3">
            <a href="${lp}/profile" class="underline hover:text-[var(--text-secondary)]">${esc(t('volunteer.paused.profileHint', lang))}</a>
          </p>
        </div>
      </div>`;
  }

  (async () => {
    const lang = ((window as any).__vaLang || 'pt-BR') as Lang;
    const app = document.getElementById('va-app');
    if (!app) return;

    let sb: any = null;
    const waitSb = () => new Promise<void>(r => {
      const check = () => { sb = (window as any).navGetSb?.(); if (sb) r(); else setTimeout(check, 300); };
      setTimeout(check, 300); setTimeout(r, 5000);
    });
    await waitSb();
    if (!sb) { try { sb = getSupabase(); } catch {} }
    if (!sb) { app.innerHTML = `<p class="text-center py-12 text-[var(--text-muted)]">${t('volunteer.error', lang)}</p>`; return; }

    // Get member — retry loop in case navGetMember loads async
    let member = (window as any).navGetMember?.();
    if (!member) {
      // Wait up to 5s for navGetMember to return data, then fallback to RPC
      const deadline = Date.now() + 5000;
      while (!member && Date.now() < deadline) {
        await new Promise(r => setTimeout(r, 250));
        member = (window as any).navGetMember?.();
      }
      // Last-resort: call get_member_by_auth directly
      if (!member) {
        try {
          const { data: m } = await sb.rpc('get_member_by_auth');
          if (m) member = m;
        } catch {}
      }
    }
    if (!member) {
      app.innerHTML = `<div class="text-center py-12"><p class="text-[var(--text-muted)]">${esc(t('volunteer.loginRequired', lang))}</p><button class="mt-3 px-4 py-2 bg-navy text-white rounded-lg border-0 cursor-pointer text-sm font-semibold" onclick="document.dispatchEvent(new CustomEvent('open-auth'))">${esc(t('volunteer.loginButton', lang))}</button></div>`;
      return;
    }

    // Check if already signed (include_volunteer_agreements=true → fetch TCVs)
    const { data: certs } = await sb.rpc('get_my_certificates', { p_include_volunteer_agreements: true });
    const currentYear = new Date().getFullYear();
    // W3c-ii: only a VALID (issued) term blocks re-signing. A rejected term must NOT short-circuit
    // to "already signed" — the member needs to re-sign. (superseded/revoked are already hidden by
    // get_my_certificates.) status may be null on legacy rows → treat as issued/valid.
    const vaCerts = (certs || []).filter((c: any) => c.type === 'volunteer_agreement' && c.cycle === currentYear);
    const validCert = vaCerts.find((c: any) => c.status === 'issued' || c.status == null);
    if (validCert) {
      app.innerHTML = renderAlreadySigned(lang);
      return;
    }
    const rejectedCert = vaCerts.find((c: any) => c.status === 'rejected');
    const rejectedBanner = rejectedCert ? renderRejectedBanner(rejectedCert.revoked_reason || null, lang) : '';

    // B4: detect the governance "signature hold" by the ABSENCE of an active template row
    // (not a parse failure of an existing one). No active template ⟺ sign_volunteer_agreement
    // would return template_not_found → show the paused screen instead of an un-submittable form.
    // This check runs BEFORE the profile-completeness gate: while signing is paused, telling the
    // member to "complete your profile first" would be misleading guidance.
    let activeTemplateRow: any = null;
    let template: any = null;
    try {
      const { data: docs } = await sb.from('governance_documents')
        .select('id, content')
        .eq('doc_type', 'volunteer_term_template')
        .eq('status', 'active')
        .order('created_at', { ascending: false })
        .limit(1);
      activeTemplateRow = docs?.[0] || null;
      if (activeTemplateRow?.content) {
        try { template = JSON.parse(activeTemplateRow.content); } catch { template = null; }
      }
    } catch { /* network error → cannot confirm a signable term; treat as paused (safe degraded state) */ }

    if (!activeTemplateRow) {
      app.innerHTML = renderPaused(lang);
      return;
    }

    // Pre-flight: check profile completeness before showing form.
    // Labels reuse the shared profile.field.* dictionary so the missing-fields list is localized.
    const requiredFields: Record<string, string> = {
      pmi_id: t('profile.field.pmiId', lang),
      phone: t('profile.field.phone', lang),
      address: t('profile.field.address', lang),
      city: t('profile.field.city', lang),
      state: t('profile.field.state', lang),
      country: t('profile.field.country', lang),
      birth_date: t('profile.field.birthDate', lang),
    };
    const missing: string[] = [];
    for (const [key, label] of Object.entries(requiredFields)) {
      const val = member[key];
      if (val === null || val === undefined || (typeof val === 'string' && val.trim() === '')) {
        missing.push(label);
      }
    }
    if (missing.length > 0) {
      const profileUrl = lang === 'pt-BR' ? '/profile' : lang === 'en-US' ? '/en/profile' : '/es/profile';
      app.innerHTML = rejectedBanner + `
        <div class="rounded-2xl border-2 border-amber-300 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 p-6 text-center">
          <div class="text-4xl mb-3">📋</div>
          <h2 class="text-lg font-bold text-amber-800 dark:text-amber-300 mb-2">${esc(t('volunteer.missing.title', lang))}</h2>
          <p class="text-sm text-amber-700 dark:text-amber-400 mb-4">
            ${esc(t('volunteer.missing.description', lang))}
          </p>
          <ul class="inline-block text-left text-sm text-amber-800 dark:text-amber-300 mb-4 space-y-1">
            ${missing.map(f => `<li>• <b>${esc(f)}</b></li>`).join('')}
          </ul>
          <p class="text-xs text-amber-600 dark:text-amber-400 mb-4 italic">
            ${esc(t('volunteer.missing.rationale', lang))}
          </p>
          <a href="${profileUrl}#personal-data" class="inline-block px-5 py-2.5 rounded-lg bg-amber-500 text-white text-sm font-bold no-underline hover:bg-amber-600 transition-colors">
            ${esc(t('volunteer.missing.action', lang))} →
          </a>
        </div>`;
      return;
    }

    // Load member tribe name for display
    const memberData = { ...member, tribe_name: member.tribe_name || (window as any).__memberTribeName || '—' };
    app.innerHTML = rejectedBanner + renderForm(memberData, lang, template);

    // Checkbox enables button
    const checkbox = document.getElementById('va-agree') as HTMLInputElement;
    const btn = document.getElementById('va-sign-btn') as HTMLButtonElement;
    checkbox?.addEventListener('change', () => { btn.disabled = !checkbox.checked; });

    // Sign handler
    btn?.addEventListener('click', async () => {
      if (!checkbox?.checked || btn.disabled) return;
      btn.disabled = true;
      btn.textContent = t('volunteer.signing', lang);

      try {
        const ua = typeof navigator !== 'undefined' ? navigator.userAgent.substring(0, 500) : null;
        const { data, error } = await sb.rpc('sign_volunteer_agreement', { p_language: lang, p_signed_user_agent: ua });
        if (error) throw error;
        if (data?.error === 'already_signed') { app.innerHTML = renderAlreadySigned(lang); return; }
        if (data?.error === 'profile_incomplete') {
          const missing = Array.isArray(data.missing_fields) ? data.missing_fields : [];
          (window as any).toast?.(`${t('volunteer.missing.toastPrefix', lang)}${missing.join(', ')}`, 'error');
          const profileUrl = lang === 'pt-BR' ? '/profile' : lang === 'en-US' ? '/en/profile' : '/es/profile';
          setTimeout(() => { window.location.href = profileUrl; }, 1500);
          return;
        }
        // B4: the active template could be pulled (signature hold) between page-load and submit.
        // Surface the same graceful paused screen instead of a cryptic generic error toast.
        if (data?.error === 'template_not_found') { app.innerHTML = renderPaused(lang); return; }
        if (data?.error) throw new Error(data.error);
        // A4: best-effort tribe WhatsApp link (term-gated RPC; returns success only
        // once the member is no longer pre-onboarding + belongs to the tribe — most
        // freshly-signed members have no tribe yet, so this simply stays hidden).
        let tribeLink: string | null = null;
        const tribeId = (member as any)?.tribe_id;
        if (tribeId) {
          try {
            const { data: waRes } = await sb.rpc('get_tribe_group_link', { p_tribe_id: tribeId });
            if (waRes?.success && waRes.whatsapp_url) tribeLink = waRes.whatsapp_url;
          } catch { /* non-blocking */ }
        }
        app.innerHTML = renderSuccess(data, lang, { tribeLink });
        (window as any).toast?.(t('volunteer.success.title', lang), 'success');
      } catch (e) {
        console.error('Sign failed:', e);
        (window as any).toast?.(t('volunteer.error', lang), 'error');
        btn.disabled = false;
        btn.textContent = t('volunteer.signButton', lang);
      }
    });
  })();
</script>
