---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromURL, t, type Lang } from '../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---
<BaseLayout title={t('volunteer.title', lang)} activePage="volunteer-agreement" lang={lang}>
  <main class="max-w-[720px] mx-auto px-4 py-8" id="va-app">
    <div class="text-center py-12 text-[var(--text-muted)]" id="va-loading">...</div>
  </main>
</BaseLayout>

<script is:inline define:vars={{ lang }}>
  window.__vaLang = lang;
</script>

<script>
  import { getSupabase } from '../lib/supabase';
  import { t } from '../i18n/utils';
  import type { Lang } from '../i18n/utils';

  function esc(s: any): string { return String(s || '').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
  function fmtDatetime(d: string, lang: Lang): string {
    if (!d) return '';
    const locale = lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es-ES' : 'pt-BR';
    return new Date(d).toLocaleString(locale, { day: '2-digit', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  const CLAUSE_KEYS = [
    'clause1', 'clause2', 'clause3', 'clause4', 'clause5', 'clause6',
    'clause7', 'clause8', 'clause9', 'clause10', 'clause11', 'clause12',
  ] as const;

  const SUB_CLAUSES: Record<string, string[]> = {
    clause1: ['clause1a', 'clause1b', 'clause1c'],
    clause7: ['clause7a'],
    clause9: ['clause9a', 'clause9b', 'clause9c', 'clause9d', 'clause9e', 'clause9f', 'clause9note'],
  };

  function renderForm(member: any, lang: Lang, template: any): string {
    const tribeName = member.tribe_name || '—';
    const roleName = member.operational_role || '—';
    const cycle = new Date().getFullYear();
    const subtitle = t('volunteer.subtitle', lang).replace('{cycle}', '3').replace('{year}', String(cycle));

    return `
      <header class="mb-6 text-center">
        <div class="text-[10px] font-bold uppercase tracking-[.15em] text-[var(--text-muted)] mb-1">PMI Goiás — Núcleo de Estudos e Pesquisa em IA & GP</div>
        <h1 class="text-xl font-bold text-[var(--text-primary)]">${t('volunteer.title', lang)}</h1>
        <p class="text-[var(--text-secondary)] text-sm mt-1">${subtitle}</p>
      </header>

      <!-- Header intro -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.headerIntro', lang)}</p>
      </div>

      <!-- Member data -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-3">${t('volunteer.memberData', lang)}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
          ${member.pmi_id ? `<div><span class="text-[var(--text-muted)]">${t('volunteer.pmiId', lang)}:</span> <strong class="text-[var(--text-primary)]">${esc(member.pmi_id)}</strong></div>` : ''}
          <div><span class="text-[var(--text-muted)]">${t('volunteer.name', lang)}:</span> <strong class="text-[var(--text-primary)]">${esc(member.name)}</strong></div>
          <div><span class="text-[var(--text-muted)]">${t('volunteer.email', lang)}:</span> <span class="text-[var(--text-primary)]">${esc(member.email)}</span></div>
          <div><span class="text-[var(--text-muted)]">${t('volunteer.tribe', lang)}:</span> <span class="text-[var(--text-primary)]">${esc(tribeName)}</span></div>
          <div><span class="text-[var(--text-muted)]">${t('volunteer.role', lang)}:</span> <span class="text-[var(--text-primary)]">${esc(roleName)}</span></div>
        </div>
      </div>

      <!-- Preamble -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <p class="text-sm text-[var(--text-primary)] font-medium leading-relaxed">${t('volunteer.preamble', lang)}</p>
      </div>

      <!-- Terms (12 clauses) -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-4">${t('volunteer.termsTitle', lang)}</h3>
        <ol class="space-y-4 list-none">
          ${CLAUSE_KEYS.map((key, i) => {
            const subs = SUB_CLAUSES[key];
            const clauseText = template?.[key] || t('volunteer.' + key, lang);
            let html = `
              <li class="text-sm text-[var(--text-secondary)] leading-relaxed">
                <div class="flex gap-2">
                  <span class="text-[var(--text-muted)] font-bold shrink-0">${i + 1}.</span>
                  <span>${esc(clauseText)}</span>
                </div>`;
            if (subs) {
              html += `<ol class="mt-2 ml-6 space-y-2">`;
              subs.forEach((subKey) => {
                const subText = template?.[subKey] || t('volunteer.' + subKey, lang);
                const isNote = subKey.endsWith('note');
                const letter = isNote ? '' : subKey.slice(-1) + ')';
                html += `
                  <li class="text-[13px] text-[var(--text-secondary)] leading-relaxed ${isNote ? 'mt-3 italic border-l-2 border-[var(--border-subtle)] pl-3' : ''}">
                    <div class="flex gap-2">
                      ${letter ? `<span class="text-[var(--text-muted)] font-semibold shrink-0">${letter}</span>` : ''}
                      <span>${esc(subText)}</span>
                    </div>
                  </li>`;
              });
              html += `</ol>`;
            }
            html += `</li>`;
            return html;
          }).join('')}
        </ol>
      </div>

      <!-- Annex: Lei 9.608 -->
      <details class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 mb-4">
        <summary class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] cursor-pointer">${t('volunteer.annexTitle', lang)}</summary>
        <div class="mt-3 space-y-3">
          <p class="text-[13px] text-[var(--text-muted)] italic">${t('volunteer.annexIntro', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed font-medium">${t('volunteer.annexArt1', lang)}</p>
          <p class="text-[13px] text-[var(--text-secondary)] leading-relaxed italic ml-4">${t('volunteer.annexArt1p', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt2', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt3', lang)}</p>
          <p class="text-[13px] text-[var(--text-secondary)] leading-relaxed italic ml-4">${t('volunteer.annexArt3p', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt4', lang)}</p>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">${t('volunteer.annexArt5', lang)}</p>
        </div>
      </details>

      <!-- Sign section -->
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5">
        <label class="flex items-start gap-3 cursor-pointer mb-4">
          <input type="checkbox" id="va-agree" class="mt-1 w-4 h-4 accent-navy" />
          <span class="text-sm font-medium text-[var(--text-primary)]">${t('volunteer.checkbox', lang)}</span>
        </label>
        <button id="va-sign-btn" disabled
          class="w-full py-3 rounded-lg bg-navy text-white text-sm font-bold border-0 cursor-pointer hover:opacity-90 disabled:opacity-40 disabled:cursor-not-allowed transition-opacity">
          ${t('volunteer.signButton', lang)}
        </button>
        <p class="text-[10px] text-[var(--text-muted)] mt-3 text-center leading-relaxed">
          \u24D8 ${t('volunteer.legalNotice', lang)}
        </p>
      </div>`;
  }

  function renderSuccess(result: any, lang: Lang): string {
    return `
      <div class="text-center py-8">
        <div class="text-4xl mb-3">\u2705</div>
        <h2 class="text-xl font-bold text-emerald-700 dark:text-emerald-400 mb-4">${t('volunteer.success.title', lang)}</h2>
        <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5 text-left space-y-2 text-sm max-w-sm mx-auto">
          <div class="flex justify-between"><span class="text-[var(--text-muted)]">${t('volunteer.success.code', lang)}</span><code class="font-mono text-[12px] bg-[var(--surface-hover)] px-2 py-0.5 rounded">${esc(result.verification_code)}</code></div>
          <div class="flex justify-between"><span class="text-[var(--text-muted)]">${t('volunteer.success.hash', lang)}</span><code class="font-mono text-[10px] text-[var(--text-muted)]">${(result.signature_hash || '').slice(0, 16)}...</code></div>
          <div class="flex justify-between"><span class="text-[var(--text-muted)]">${t('volunteer.success.date', lang)}</span><span class="text-[var(--text-primary)]">${fmtDatetime(result.signed_at, lang)}</span></div>
        </div>
        <p class="text-xs text-[var(--text-muted)] mt-4">${t('volunteer.success.pending', lang)}</p>
        <a href="/verify/${encodeURIComponent(result.verification_code)}" class="inline-block mt-4 px-4 py-2 rounded-lg bg-[var(--surface-card)] border border-[var(--border-default)] text-sm font-semibold text-navy no-underline hover:bg-[var(--surface-hover)]">
          \uD83D\uDD0D ${t('volunteer.success.verify', lang)}
        </a>
      </div>`;
  }

  function renderAlreadySigned(lang: Lang): string {
    return `
      <div class="text-center py-12">
        <div class="text-4xl mb-3">\u2705</div>
        <h2 class="text-lg font-bold text-[var(--text-primary)]">${t('volunteer.alreadySigned', lang)}</h2>
        <a href="/certificates" class="inline-block mt-4 px-4 py-2 rounded-lg bg-navy text-white text-sm font-semibold no-underline hover:opacity-90">
          ${t('volunteer.alreadySigned.viewCerts', lang)}
        </a>
      </div>`;
  }

  (async () => {
    const lang = ((window as any).__vaLang || 'pt-BR') as Lang;
    const app = document.getElementById('va-app');
    if (!app) return;

    let sb: any = null;
    const waitSb = () => new Promise<void>(r => {
      const check = () => { sb = (window as any).navGetSb?.(); if (sb) r(); else setTimeout(check, 300); };
      setTimeout(check, 300); setTimeout(r, 5000);
    });
    await waitSb();
    if (!sb) { try { sb = getSupabase(); } catch {} }
    if (!sb) { app.innerHTML = `<p class="text-center py-12 text-[var(--text-muted)]">${t('volunteer.error', lang)}</p>`; return; }

    // Get member
    const member = (window as any).navGetMember?.();
    if (!member) {
      app.innerHTML = `<div class="text-center py-12"><p class="text-[var(--text-muted)]">Login required</p><button class="mt-3 px-4 py-2 bg-navy text-white rounded-lg border-0 cursor-pointer text-sm font-semibold" onclick="document.dispatchEvent(new CustomEvent('open-auth'))">Login</button></div>`;
      return;
    }

    // Check if already signed
    const { data: certs } = await sb.rpc('get_my_certificates');
    const currentYear = new Date().getFullYear();
    const existing = (certs || []).find((c: any) => c.type === 'volunteer_agreement' && c.cycle === currentYear);
    if (existing) {
      app.innerHTML = renderAlreadySigned(lang);
      return;
    }

    // Load template from governance_documents (admin-editable)
    let template: any = null;
    try {
      const { data: docs } = await sb.from('governance_documents')
        .select('content')
        .eq('doc_type', 'volunteer_term_template')
        .eq('status', 'active')
        .order('created_at', { ascending: false })
        .limit(1);
      if (docs?.[0]?.content) {
        try { template = JSON.parse(docs[0].content); } catch { template = null; }
      }
    } catch { /* fallback to i18n */ }

    // Load member tribe name for display
    const memberData = { ...member, tribe_name: member.tribe_name || (window as any).__memberTribeName || '—' };
    app.innerHTML = renderForm(memberData, lang, template);

    // Checkbox enables button
    const checkbox = document.getElementById('va-agree') as HTMLInputElement;
    const btn = document.getElementById('va-sign-btn') as HTMLButtonElement;
    checkbox?.addEventListener('change', () => { btn.disabled = !checkbox.checked; });

    // Sign handler
    btn?.addEventListener('click', async () => {
      if (!checkbox?.checked || btn.disabled) return;
      btn.disabled = true;
      btn.textContent = t('volunteer.signing', lang);

      try {
        const { data, error } = await sb.rpc('sign_volunteer_agreement', { p_language: lang });
        if (error) throw error;
        if (data?.error === 'already_signed') { app.innerHTML = renderAlreadySigned(lang); return; }
        if (data?.error) throw new Error(data.error);
        app.innerHTML = renderSuccess(data, lang);
        (window as any).toast?.(t('volunteer.success.title', lang), 'success');
      } catch (e) {
        console.error('Sign failed:', e);
        (window as any).toast?.(t('volunteer.error', lang), 'error');
        btn.disabled = false;
        btn.textContent = t('volunteer.signButton', lang);
      }
    });
  })();
</script>
