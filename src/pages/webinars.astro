---
/**
 * /webinars — Public webinar listing (SSR for SEO)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { createClient } from '@supabase/supabase-js';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const locale = lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es-ES' : 'pt-BR';
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

// SSR: fetch webinars server-side
const sb = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: rawWebinars } = await sb.rpc('list_webinars_v2', {});
const webinars = Array.isArray(rawWebinars) ? rawWebinars : [];
const now = Date.now();

const upcoming = webinars.filter((w: any) =>
  w.status === 'confirmed' && new Date(w.scheduled_at).getTime() > now
);
const replays = webinars.filter((w: any) =>
  w.status === 'completed' && w.youtube_url
);

function fmtDate(iso: string): string {
  if (!iso) return '—';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return String(iso).slice(0, 10);
  return d.toLocaleDateString(locale, { day: '2-digit', month: 'long', year: 'numeric' });
}
function fmtTime(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d.getTime())) return '';
  return d.toLocaleTimeString(locale, { hour: '2-digit', minute: '2-digit' });
}
---

<BaseLayout title={`${t('webinars.title', lang)} — Núcleo IA & GP`} activePage="webinars" lang={lang}>
  <meta slot="head" property="og:title" content={t('webinars.title', lang)} />
  <meta slot="head" property="og:description" content={t('webinars.subtitle', lang)} />
  <meta slot="head" property="og:url" content={`https://nucleoia.vitormr.dev${langPrefix}/webinars`} />

  <main class="max-w-[900px] mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-navy mb-2">{t('webinars.title', lang)}</h1>
      <p class="text-sm text-[var(--text-secondary)]">
        {t('webinars.subtitle', lang)}
      </p>
    </div>

    {!upcoming.length && !replays.length ? (
      <div id="webinars-empty" class="text-center py-12">
        <div class="text-4xl mb-3">🎙️</div>
        <p class="text-sm font-semibold text-[var(--text-secondary)]">{t('webinars.empty', lang)}</p>
        <p class="text-[.78rem] text-[var(--text-muted)] mt-1">{t('webinars.emptyHint', lang)}</p>
      </div>
    ) : (
      <>
        {upcoming.length > 0 && (
          <section id="webinars-upcoming-section" class="mb-8">
            <h2 class="text-lg font-bold text-navy mb-3">{t('webinars.upcoming', lang)}</h2>
            <div class="space-y-3">
              {upcoming.map((w: any) => (
                <article class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
                  <div class="flex items-start justify-between gap-4 flex-wrap">
                    <div class="min-w-0 flex-1">
                      <h3 class="text-base font-bold text-navy">{w.title}</h3>
                      {w.description && <p class="text-sm text-[var(--text-secondary)] mt-1">{w.description}</p>}
                      <div class="flex items-center gap-3 flex-wrap mt-3 text-[.78rem] text-[var(--text-secondary)]">
                        <span class="font-semibold">{fmtDate(w.scheduled_at)}</span>
                        <span>{fmtTime(w.scheduled_at)}</span>
                        <span>&middot;</span>
                        <span>{w.duration_min} min</span>
                        {w.tribe_name && <><span>&middot;</span><span>{w.tribe_name}</span></>}
                        {w.chapter_code !== 'ALL' && <><span>&middot;</span><span class="font-semibold">PMI-{w.chapter_code}</span></>}
                      </div>
                    </div>
                    <div class="shrink-0">
                      {w.meeting_link
                        ? <a href={w.meeting_link} target="_blank" rel="noopener" class="px-4 py-2 rounded-xl bg-navy text-white text-sm font-semibold no-underline hover:opacity-90">{t('webinars.join', lang)}</a>
                        : <span class="text-[.78rem] text-[var(--text-muted)]">{t('webinars.linkSoon', lang)}</span>
                      }
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}

        {replays.length > 0 && (
          <section id="webinars-past-section">
            <h2 class="text-lg font-bold text-navy mb-3">{t('webinars.replays', lang)}</h2>
            <div class="space-y-3">
              {replays.map((w: any) => (
                <article class="rounded-2xl border border-[var(--border-default)] bg-[var(--surface-card)] p-5 shadow-sm">
                  <div class="flex items-start justify-between gap-4 flex-wrap">
                    <div class="min-w-0 flex-1">
                      <h3 class="text-base font-bold text-navy">{w.title}</h3>
                      <div class="flex items-center gap-3 flex-wrap mt-2 text-[.78rem] text-[var(--text-secondary)]">
                        <span>{fmtDate(w.scheduled_at)}</span>
                        {w.tribe_name && <><span>&middot;</span><span>{w.tribe_name}</span></>}
                        {w.attendee_count > 0 && <><span>&middot;</span><span>{w.attendee_count} {t('webinars.participants', lang)}</span></>}
                      </div>
                    </div>
                    <a href={w.youtube_url} target="_blank" rel="noopener" class="shrink-0 px-4 py-2 rounded-xl bg-red-600 text-white text-sm font-semibold no-underline hover:opacity-90">
                      {t('webinars.watchReplay', lang)}
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </main>
</BaseLayout>
