---
/**
 * /reunioes-gerais — #701 Slice 1 (public Agenda Viva de Protagonismo).
 * Public timeline of the next General Meetings + reserved/confirmed blocks
 * (get_geral_agenda_viva, anon-OK with layered PII). The reservation form for
 * signed-in volunteers is added in Slice 2 on this same page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import AgendaVivaPublic from '../components/agenda/AgendaVivaPublic.tsx';
import AgendaVivaReservationIsland from '../components/agenda/AgendaVivaReservationIsland.tsx';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { buildPageI18n } from '../i18n/pageI18n';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['comp.agendaViva'], lang);
---

<BaseLayout title={t('comp.agendaViva.heading', lang)} activePage="reunioes-gerais" lang={lang}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <Toast />
  <div class="max-w-[900px] mx-auto px-4 py-10">
    <header class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-extrabold text-navy">{t('comp.agendaViva.heading', lang)}</h1>
      <p class="text-[var(--text-muted)] mt-2 max-w-[58ch]">{t('comp.agendaViva.subtitle', lang)}</p>
    </header>
    <AgendaVivaReservationIsland client:load lang={lang} />
    <AgendaVivaPublic client:load lang={lang} />
  </div>
</BaseLayout>
