---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromURL, t, type Lang } from '../../i18n/utils';
import ManualDocumentViewer from '../../components/governance/ManualDocumentViewer';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---

<BaseLayout title={t('governance.preview.title', lang)} activePage="governance" lang={lang}>
  <main class="max-w-[1100px] mx-auto px-4 py-8">
    <div class="mb-4 print:hidden">
      <a href="/governance" class="inline-flex items-center gap-1 text-sm text-navy font-semibold no-underline hover:underline">
        ← {t('governance.dashboard.title', lang)}
      </a>
    </div>

    <!-- Manual Document (prose typography, TOC scroll-spy) -->
    <ManualDocumentViewer client:load lang={lang} />

    <!-- CR Pipeline (existing, below the document) -->
    <div class="mt-12 pt-8 border-t-2 border-[var(--border-default)]">
      <h2 class="text-xl font-bold text-[var(--text-primary)] mb-2">{t('governance.preview.crListTitle', lang)}</h2>
      <p class="text-sm text-[var(--text-secondary)] mb-4">{t('governance.preview.subtitle', lang)}</p>

      <div id="preview-loading" class="text-[var(--text-muted)] text-sm py-8 text-center">...</div>
      <div id="preview-content" class="hidden space-y-6"></div>
    </div>
  </main>
</BaseLayout>

<script is:inline define:vars={{ lang }}>
  window.__previewLang = lang;
</script>

<script>
  import { getSupabase } from '../../lib/supabase';
  import { t } from '../../i18n/utils';
  import type { Lang } from '../../i18n/utils';

  const CATEGORY_COLORS: Record<string, string> = {
    manual_update: 'bg-blue-100 text-blue-800 border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800',
    role_structure: 'bg-purple-100 text-purple-800 border-purple-200 dark:bg-purple-900/30 dark:text-purple-300 dark:border-purple-800',
    operational_procedure: 'bg-emerald-100 text-emerald-800 border-emerald-200 dark:bg-emerald-900/30 dark:text-emerald-300 dark:border-emerald-800',
    technical_architecture: 'bg-gray-100 text-gray-700 border-gray-200 dark:bg-gray-800/50 dark:text-gray-300 dark:border-gray-700',
  };

  const STATUS_BADGE: Record<string, { icon: string; cls: string }> = {
    new: { icon: '\u{1F195}', cls: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' },
    updated: { icon: '\u270F\uFE0F', cls: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' },
    proposals: { icon: '\u23F3', cls: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' },
  };

  const PRIORITY_COLORS: Record<string, string> = {
    critical: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
    high: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
    medium: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
    low: 'bg-gray-100 text-gray-600 dark:bg-gray-800/50 dark:text-gray-400',
  };

  const SPONSORS = [
    { name: 'Ivan', chapter: 'GO', status: 'pending' },
    { name: 'Jéssica', chapter: 'CE', status: 'pending' },
    { name: 'Matheus', chapter: 'DF', status: 'pending' },
    { name: 'Felipe', chapter: 'MG', status: 'pending' },
    { name: 'Márcio', chapter: 'RS', status: 'pending' },
  ];

  function esc(s: any): string { return String(s || '').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

  function renderSummary(data: any, lang: Lang): string {
    const total = data.total_crs || 0;
    const cats = data.by_category || {};
    const structure = data.manual_structure || [];
    const newCount = structure.filter((s: any) => s.status === 'new').length;
    const updatedCount = structure.filter((s: any) => s.status === 'updated').length;

    const catPills = Object.entries(cats).map(([cat, cnt]) => {
      const color = CATEGORY_COLORS[cat] || CATEGORY_COLORS.technical_architecture;
      const label = t(`governance.preview.category.${cat}`, lang) || cat;
      return `<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold border ${color}">${cnt} ${label}</span>`;
    }).join(' ');

    return `
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5">
        <h3 class="text-xs font-bold uppercase tracking-wide text-[var(--text-muted)] mb-3">${t('governance.preview.summary', lang)}</h3>
        <div class="flex flex-wrap gap-2 mb-3">
          <span class="text-sm font-bold text-[var(--text-primary)]">${total} ${t('governance.preview.crCount', lang)}</span>
          <span class="text-sm text-[var(--text-muted)]">|</span>
          <span class="text-sm text-emerald-600 dark:text-emerald-400 font-semibold">${newCount} ${t('governance.preview.manualSections', lang)}</span>
          <span class="text-sm text-[var(--text-muted)]">|</span>
          <span class="text-sm text-blue-600 dark:text-blue-400 font-semibold">${updatedCount} ${t('governance.preview.updatedSections', lang)}</span>
        </div>
        <div class="flex flex-wrap gap-1.5">${catPills}</div>
      </div>`;
  }

  function renderManualStructure(structure: any[], lang: Lang): string {
    const items = structure.map((s: any) => {
      const badge = STATUS_BADGE[s.status] || STATUS_BADGE.proposals;
      const label = s.status === 'new' ? t('governance.preview.newSection', lang)
                  : s.status === 'updated' ? t('governance.preview.updatedSection', lang)
                  : (s.note || t('governance.preview.pendingProposals', lang));
      const crRef = s.cr ? `(${s.cr})` : s.crs ? `(${s.crs.join(', ')})` : '';
      const isSubsection = s.id.includes('.');
      const indent = isSubsection ? 'pl-6' : '';

      return `<div class="flex items-center justify-between py-2.5 border-b border-[var(--border-subtle)] last:border-b-0 ${indent}">
        <span class="text-sm font-medium text-[var(--text-primary)]">${esc(s.title)}</span>
        <span class="flex items-center gap-1.5 text-[11px] font-semibold px-2 py-0.5 rounded-full ${badge.cls}">
          ${badge.icon} ${label} <span class="text-[var(--text-muted)]">${crRef}</span>
        </span>
      </div>`;
    }).join('');

    return `
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
        <div class="px-5 py-3.5 border-b border-[var(--border-default)]">
          <h3 class="text-sm font-bold text-[var(--text-primary)]">${t('governance.preview.structureTitle', lang)}</h3>
        </div>
        <div class="px-5 py-2">${items}</div>
      </div>`;
  }

  function renderCRSections(sections: any[], lang: Lang): string {
    if (!sections?.length) return '';

    const sectionCards = sections.map((sec: any) => {
      const catKey = `governance.preview.category.${sec.section_id}`;
      const title = t(catKey, lang) !== catKey ? t(catKey, lang) : (sec.section_title || sec.section_id);
      const crs = sec.crs || [];
      const color = CATEGORY_COLORS[sec.section_id] || CATEGORY_COLORS.technical_architecture;

      const crItems = crs.map((cr: any) => {
        const pColor = PRIORITY_COLORS[cr.priority] || PRIORITY_COLORS.low;
        const catColor = CATEGORY_COLORS[cr.category] || CATEGORY_COLORS.technical_architecture;

        const descHtml = cr.description ? `<div class="mt-2 text-xs text-[var(--text-secondary)] leading-relaxed">${esc(cr.description)}</div>` : '';
        const changesHtml = cr.proposed_changes
          ? `<details class="mt-2"><summary class="text-[11px] font-semibold text-[var(--text-muted)] cursor-pointer hover:text-[var(--text-primary)]">${t('governance.preview.proposedChanges', lang)}</summary><div class="mt-1 text-xs text-[var(--text-secondary)] whitespace-pre-line leading-relaxed bg-[var(--surface-hover)] rounded-lg p-3">${esc(cr.proposed_changes)}</div></details>`
          : '';
        const justHtml = cr.justification
          ? `<details class="mt-1"><summary class="text-[11px] font-semibold text-[var(--text-muted)] cursor-pointer hover:text-[var(--text-primary)]">${t('governance.preview.justification', lang)}</summary><div class="mt-1 text-xs text-[var(--text-secondary)] leading-relaxed bg-[var(--surface-hover)] rounded-lg p-3">${esc(cr.justification)}</div></details>`
          : '';

        return `<div class="py-3 border-b border-[var(--border-subtle)] last:border-b-0">
          <div class="flex items-start gap-2 flex-wrap">
            <span class="text-[11px] font-bold text-[var(--text-muted)]">${esc(cr.cr_number)}</span>
            <span class="text-sm font-medium text-[var(--text-primary)] flex-1">${esc(cr.title)}</span>
            ${cr.priority ? `<span class="text-[10px] font-bold px-1.5 py-0.5 rounded ${pColor}">${cr.priority}</span>` : ''}
            <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded border ${catColor}">${cr.status}</span>
          </div>
          ${descHtml}${changesHtml}${justHtml}
        </div>`;
      }).join('');

      return `<div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] overflow-hidden">
        <div class="px-5 py-3 border-b border-[var(--border-default)] flex items-center justify-between">
          <h3 class="text-sm font-bold text-[var(--text-primary)]">${esc(title)}</h3>
          <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full border ${color}">${crs.length} CRs</span>
        </div>
        <div class="px-5">${crItems}</div>
      </div>`;
    }).join('');

    return `
      <div>
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3">${t('governance.preview.crListTitle', lang)}</h2>
        <div class="space-y-4">${sectionCards}</div>
      </div>`;
  }

  function renderApprovals(lang: Lang): string {
    const pills = SPONSORS.map(s => {
      return `<div class="flex items-center gap-1.5 px-3 py-2 rounded-lg bg-[var(--surface-hover)] border border-[var(--border-subtle)]">
        <span class="w-7 h-7 rounded-full bg-[var(--surface-section-cool)] flex items-center justify-center text-[11px] font-bold text-[var(--text-muted)]">${s.name[0]}</span>
        <div>
          <div class="text-[12px] font-semibold text-[var(--text-primary)]">${s.name}</div>
          <div class="text-[10px] text-[var(--text-muted)]">PMI-${s.chapter}</div>
        </div>
        <span class="ml-auto text-sm">\u23F3</span>
      </div>`;
    }).join('');

    return `
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-5">
        <h3 class="text-sm font-bold text-[var(--text-primary)] mb-3">${t('governance.preview.approvals', lang)}</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2">${pills}</div>
        <p class="mt-3 text-xs text-[var(--text-muted)]">${t('governance.preview.quorum', lang)}: 0/3 ${t('governance.preview.quorumNeeded', lang)}</p>
      </div>`;
  }

  (async () => {
    const lang = ((window as any).__previewLang || 'pt-BR') as Lang;
    const loading = document.getElementById('preview-loading');
    const content = document.getElementById('preview-content');
    if (!loading || !content) return;

    let sb = (window as any).navGetSb?.();
    if (!sb) {
      await new Promise<void>(r => {
        const check = () => { sb = (window as any).navGetSb?.(); if (sb) r(); else setTimeout(check, 300); };
        setTimeout(check, 300);
        setTimeout(r, 5000);
      });
    }
    if (!sb) {
      try { sb = getSupabase(); } catch { /* noop */ }
    }
    if (!sb) {
      loading.textContent = t('governance.preview.noData', lang);
      return;
    }

    try {
      const [previewRes, diffRes] = await Promise.all([
        sb.rpc('get_governance_preview'),
        sb.rpc('get_manual_diff'),
      ]);
      if (previewRes.error) throw previewRes.error;
      const data = previewRes.data;
      const diff = diffRes.data || {};
      if (!data) { loading.textContent = t('governance.preview.noData', lang); return; }

      const isSuperadmin = (window as any).navGetMember?.()?.is_superadmin;
      const approvedReady = diff.total_approved_ready || 0;
      const currentVer = diff.current_version || 'R2';

      // Diff banner
      const diffBanner = `
        <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-4 print:hidden">
          <div class="flex flex-wrap items-center gap-3 text-sm">
            <span class="font-bold text-[var(--text-primary)]">Versao actual: ${esc(currentVer)}</span>
            <span class="text-[var(--text-muted)]">|</span>
            <span class="text-emerald-600 dark:text-emerald-400 font-semibold">${approvedReady} CRs aprovados prontos</span>
            <span class="text-[var(--text-muted)]">|</span>
            <span class="text-amber-600 dark:text-amber-400 font-semibold">${diff.total_pending || 0} pendentes</span>
            ${isSuperadmin && approvedReady > 0 ? `
              <button id="gen-version-btn" class="ml-auto px-3 py-1.5 rounded-lg bg-emerald-600 text-white text-[12px] font-semibold border-0 cursor-pointer hover:bg-emerald-700">
                Gerar Manual R3
              </button>` : ''}
          </div>
        </div>`;

      // Print header (only visible in print)
      const printHeader = `
        <div class="hidden print:block text-center mb-8 manual-header">
          <div class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">Nucleo de Estudos e Pesquisa em IA & Gerenciamento de Projetos</div>
          <h1 class="text-xl font-extrabold">Manual de Governanca e Operacoes</h1>
          <div class="text-sm text-gray-600 mt-1">Versao: ${esc(currentVer)} (Preview) | Data: ${new Date().toLocaleDateString('pt-BR')}</div>
          <div class="text-xs text-gray-400 mt-1">${data.total_crs || 0} Change Requests | Gerado automaticamente pela plataforma</div>
          <div class="text-[8px] text-gray-400 mt-2">platform.ai-pm-research-hub.workers.dev/governance/preview</div>
        </div>`;

      loading.classList.add('hidden');
      content.classList.remove('hidden');
      content.innerHTML = [
        printHeader,
        diffBanner,
        renderSummary(data, lang),
        renderManualStructure(data.manual_structure || [], lang),
        renderCRSections(data.sections || [], lang),
        renderApprovals(lang),
        `<div class="flex justify-end gap-2 print:hidden">
          <button onclick="window.print()" class="px-4 py-2 rounded-lg bg-navy text-white text-sm font-semibold border-0 cursor-pointer hover:opacity-90">${t('governance.preview.exportPdf', lang)}</button>
        </div>`,
      ].join('');

      // Generate version modal
      document.getElementById('gen-version-btn')?.addEventListener('click', async () => {
        const label = prompt('Label da versao (ex: R3):', 'R3');
        if (!label) return;
        const notes = prompt('Notas (opcional):', '');
        if (!confirm('Isto marcara ' + approvedReady + ' CRs como implementados. Continuar?')) return;
        try {
          const { data: r, error: e } = await sb.rpc('generate_manual_version', { p_version_label: label, p_notes: notes || null });
          if (e) throw e;
          if (r?.error) { alert(r.error); return; }
          (window as any).toast?.('Manual ' + label + ' gerado! ' + approvedReady + ' CRs implementados.', 'success');
          setTimeout(() => location.reload(), 1500);
        } catch (err) { console.error(err); (window as any).toast?.('Erro ao gerar versao', 'error'); }
      });
    } catch (err) {
      console.error('Preview load failed:', err);
      loading.textContent = t('governance.preview.noData', lang);
    }
  })();
</script>

<style>
  @media print {
    nav, footer, .print\:hidden, [class*="print\:hidden"] { display: none !important; }
    main { max-width: 100% !important; padding: 1rem !important; }
    .manual-header { display: block !important; }
    details { display: block !important; }
    details > summary { display: none !important; }
    details > div, details > pre, details > p { display: block !important; }
  }
</style>
