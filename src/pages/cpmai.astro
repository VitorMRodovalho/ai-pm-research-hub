---
import BaseLayout from '../layouts/BaseLayout.astro';
import CpmaiLanding from '../components/cpmai/CpmaiLanding';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { buildPageI18n } from '../i18n/pageI18n';
const lang: Lang = getLangFromURL(Astro.url.pathname);
const i18nBundle = buildPageI18n(['cpmai'], lang);
---
<BaseLayout title={t('cpmai.title', lang)} activePage="cpmai" lang={lang}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <CpmaiLanding client:load />
  </main>
</BaseLayout>
