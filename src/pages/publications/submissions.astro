---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromURL, t, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---
<BaseLayout title={t('publications.title', lang) + ' — ' + t('publications.subtitle', lang)} activePage="publications" lang={lang}>
  <main class="max-w-[900px] mx-auto px-4 py-8" id="pub-app">
    <div class="text-center py-12 text-[var(--text-muted)]" id="pub-loading">...</div>
  </main>
</BaseLayout>

<script is:inline define:vars={{ lang }}>
  window.__pubLang = lang;
</script>

<script>
  import { t } from '../../i18n/utils';
  import type { Lang } from '../../i18n/utils';

  function esc(s: any): string { return String(s || '').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
  function fmtDate(d: string, lang: Lang): string {
    if (!d) return '—';
    const dt = new Date(String(d).slice(0, 10) + 'T12:00:00');
    if (isNaN(dt.getTime())) return String(d);
    return dt.toLocaleDateString(lang === 'en-US' ? 'en-US' : lang === 'es-LATAM' ? 'es-ES' : 'pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  const STATUS_COLORS: Record<string, string> = {
    draft: 'bg-gray-100 text-gray-600 dark:bg-gray-800/50 dark:text-gray-400',
    submitted: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
    under_review: 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400',
    revision_requested: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
    accepted: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400',
    rejected: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
    published: 'bg-emerald-200 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
    presented: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400',
  };

  const STATUSES = ['draft','submitted','under_review','revision_requested','accepted','rejected','published','presented'];
  const TARGET_TYPES = ['pmi_global_conference','pmi_chapter_event','academic_journal','academic_conference','webinar','blog_post','other'];

  let sb: any = null;
  let MEMBER: any = null;
  let ALL_SUBS: any[] = [];
  let FILTER_STATUS = '';
  let FILTER_TRIBE = '';

  function canEdit(sub: any): boolean {
    if (!MEMBER) return false;
    if (MEMBER.is_superadmin) return true;
    if (MEMBER.operational_role === 'tribe_leader' || MEMBER.operational_role === 'comms_leader' || (MEMBER.designations || []).includes('curator')) return true;
    return sub.primary_author_id === MEMBER.id;
  }

  function renderStats(lang: Lang): string {
    const byStatus: Record<string, number> = {};
    ALL_SUBS.forEach(s => { byStatus[s.status] = (byStatus[s.status] || 0) + 1; });
    const cards = [
      { key: 'submitted', count: byStatus['submitted'] || 0, color: 'text-blue-600 dark:text-blue-400' },
      { key: 'under_review', count: byStatus['under_review'] || 0, color: 'text-amber-600 dark:text-amber-400' },
      { key: 'published', count: (byStatus['published'] || 0) + (byStatus['presented'] || 0), color: 'text-emerald-600 dark:text-emerald-400' },
    ];
    return `<div class="grid grid-cols-3 gap-3 mb-4">${cards.map(c => `
      <div class="text-center py-3 rounded-xl bg-[var(--surface-card)] border border-[var(--border-default)]">
        <div class="text-xl font-bold ${c.color}">${c.count}</div>
        <div class="text-[10px] font-semibold text-[var(--text-muted)] uppercase tracking-wide">${t('publications.stats.' + c.key, lang)}</div>
      </div>`).join('')}</div>`;
  }

  function renderFilters(lang: Lang): string {
    const tribes = [...new Set(ALL_SUBS.map(s => s.tribe_name).filter(Boolean))];
    return `<div class="flex gap-2 flex-wrap mb-4 print:hidden">
      <select id="pub-f-status" class="px-3 py-1.5 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm">
        <option value="">${t('publications.filter.all', lang)} (${ALL_SUBS.length})</option>
        ${STATUSES.map(s => `<option value="${s}" ${FILTER_STATUS === s ? 'selected' : ''}>${t('publications.status.' + s, lang)}</option>`).join('')}
      </select>
      ${tribes.length > 1 ? `<select id="pub-f-tribe" class="px-3 py-1.5 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm">
        <option value="">${t('publications.filter.all', lang)}</option>
        ${tribes.map(tr => `<option value="${esc(tr)}" ${FILTER_TRIBE === tr ? 'selected' : ''}>${esc(tr)}</option>`).join('')}
      </select>` : ''}
      <button id="pub-new-btn" class="ml-auto px-4 py-1.5 rounded-lg bg-navy text-white text-sm font-semibold border-0 cursor-pointer hover:opacity-90">+ ${t('publications.new', lang)}</button>
    </div>`;
  }

  function renderList(lang: Lang): string {
    let filtered = ALL_SUBS;
    if (FILTER_STATUS) filtered = filtered.filter(s => s.status === FILTER_STATUS);
    if (FILTER_TRIBE) filtered = filtered.filter(s => s.tribe_name === FILTER_TRIBE);

    if (!filtered.length) {
      return `<div class="text-center py-12"><div class="text-3xl mb-3">\uD83D\uDCDA</div>
        <p class="text-[var(--text-muted)] text-sm">${t('publications.empty', lang)}</p></div>`;
    }

    return `<div class="space-y-3">${filtered.map(sub => {
      const statusCls = STATUS_COLORS[sub.status] || STATUS_COLORS.draft;
      return `<a href="/publications/submissions/${sub.id}" class="block bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-4 no-underline hover:border-navy transition-colors">
        <div class="flex items-start gap-3">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${statusCls}">${t('publications.status.' + sub.status, lang)}</span>
              <span class="text-[10px] text-[var(--text-muted)]">${t('publications.target.' + (sub.target_type || 'other'), lang)}</span>
            </div>
            <p class="text-sm font-semibold text-[var(--text-primary)] leading-snug mb-1">${esc(sub.title)}</p>
            <div class="text-[11px] text-[var(--text-muted)]">
              ${sub.author_name ? `${t('publications.card.author', lang)}: ${esc(sub.author_name)}` : ''}
              ${sub.tribe_name ? ` · ${esc(sub.tribe_name)}` : ''}
              ${sub.target_name ? ` · ${esc(sub.target_name)}` : ''}
            </div>
          </div>
          <span class="text-[var(--text-muted)] text-sm shrink-0">\u203A</span>
        </div>
      </a>`;
    }).join('')}</div>`;
  }

  function renderCreateModal(lang: Lang): string {
    return `<div id="pub-create-modal" class="fixed inset-0 z-[500] flex items-center justify-center bg-black/50 p-4 hidden">
      <div class="bg-[var(--surface-card)] rounded-xl border border-[var(--border-default)] p-6 max-w-lg w-full shadow-xl max-h-[90vh] overflow-y-auto">
        <h3 class="text-base font-bold text-[var(--text-primary)] mb-4">${t('publications.new', lang)}</h3>
        <div class="space-y-3">
          <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.title', lang)} *</label>
            <input id="pub-c-title" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm" /></div>
          <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.abstract', lang)}</label>
            <textarea id="pub-c-abstract" rows="3" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm resize-none"></textarea></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.targetType', lang)} *</label>
              <select id="pub-c-target-type" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm">
                ${TARGET_TYPES.map(tt => `<option value="${tt}">${t('publications.target.' + tt, lang)}</option>`).join('')}
              </select></div>
            <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.targetName', lang)} *</label>
              <input id="pub-c-target-name" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm" /></div>
          </div>
          <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.targetUrl', lang)}</label>
            <input id="pub-c-target-url" type="url" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm" /></div>
          <div class="grid grid-cols-2 gap-3">
            <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.estimatedCost', lang)}</label>
              <input id="pub-c-cost" type="number" value="0" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm" /></div>
            <div><label class="text-xs font-semibold text-[var(--text-muted)]">${t('publications.form.costPaidBy', lang)}</label>
              <select id="pub-c-paid-by" class="w-full mt-1 px-3 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-input)] text-sm">
                <option value="zero_cost">Zero cost</option><option value="author">Author</option><option value="chapter">Chapter</option><option value="sponsor">Sponsor</option>
              </select></div>
          </div>
        </div>
        <div class="flex gap-2 justify-end mt-4">
          <button id="pub-c-cancel" class="px-4 py-2 rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] text-sm font-semibold text-[var(--text-secondary)] cursor-pointer">Cancelar</button>
          <button id="pub-c-submit" class="px-4 py-2 rounded-lg bg-navy text-white text-sm font-semibold border-0 cursor-pointer hover:opacity-90">${t('publications.form.submit', lang)}</button>
        </div>
      </div>
    </div>`;
  }

  async function loadAndRender() {
    const lang = ((window as any).__pubLang || 'pt-BR') as Lang;
    const app = document.getElementById('pub-app')!;
    try {
      const { data, error } = await sb.rpc('get_publication_submissions', {
        p_status: null, p_tribe_id: null
      });
      if (error) throw error;
      ALL_SUBS = data || [];

      app.innerHTML = `
        <header class="mb-4">
          <h1 class="text-xl font-bold text-[var(--text-primary)]">${t('publications.title', lang)}</h1>
          <p class="text-[var(--text-secondary)] text-sm mt-1">${t('publications.subtitle', lang)}</p>
        </header>
        ${renderStats(lang)}
        ${renderFilters(lang)}
        <div id="pub-list">${renderList(lang)}</div>
        ${renderCreateModal(lang)}`;

      // Filter listeners
      document.getElementById('pub-f-status')?.addEventListener('change', (e) => {
        FILTER_STATUS = (e.target as HTMLSelectElement).value;
        document.getElementById('pub-list')!.innerHTML = renderList(lang);
      });
      document.getElementById('pub-f-tribe')?.addEventListener('change', (e) => {
        FILTER_TRIBE = (e.target as HTMLSelectElement).value;
        document.getElementById('pub-list')!.innerHTML = renderList(lang);
      });

      // Create modal
      document.getElementById('pub-new-btn')?.addEventListener('click', () => {
        document.getElementById('pub-create-modal')?.classList.remove('hidden');
      });
      document.getElementById('pub-c-cancel')?.addEventListener('click', () => {
        document.getElementById('pub-create-modal')?.classList.add('hidden');
      });
      document.getElementById('pub-c-submit')?.addEventListener('click', async () => {
        const title = (document.getElementById('pub-c-title') as HTMLInputElement).value.trim();
        const targetName = (document.getElementById('pub-c-target-name') as HTMLInputElement).value.trim();
        if (!title || !targetName) { (window as any).toast?.('Preencha título e nome do alvo', 'error'); return; }

        try {
          const { data: r, error: e } = await sb.rpc('create_publication_submission', {
            p_title: title,
            p_target_type: (document.getElementById('pub-c-target-type') as HTMLSelectElement).value,
            p_target_name: targetName,
            p_primary_author_id: MEMBER.id,
            p_tribe_id: MEMBER.tribe_id || null,
            p_abstract: (document.getElementById('pub-c-abstract') as HTMLTextAreaElement).value || null,
            p_target_url: (document.getElementById('pub-c-target-url') as HTMLInputElement).value || null,
            p_estimated_cost_brl: parseFloat((document.getElementById('pub-c-cost') as HTMLInputElement).value) || 0,
          });
          if (e) throw e;
          (window as any).toast?.(t('publications.created', lang), 'success');
          document.getElementById('pub-create-modal')?.classList.add('hidden');
          await loadAndRender();
        } catch (err) { console.error(err); (window as any).toast?.('Erro ao criar', 'error'); }
      });
    } catch (e) {
      console.error('Publications load failed:', e);
      app.innerHTML = `<p class="text-center py-12 text-[var(--text-muted)]">${t('publications.empty', lang)}</p>`;
    }
  }

  (async () => {
    const lang = ((window as any).__pubLang || 'pt-BR') as Lang;
    const app = document.getElementById('pub-app')!;

    const waitSb = () => new Promise<void>(r => {
      const c = () => { sb = (window as any).navGetSb?.(); if (sb) r(); else setTimeout(c, 300); };
      setTimeout(c, 300); setTimeout(r, 5000);
    });
    await waitSb();
    if (!sb) { app.innerHTML = `<p class="text-center py-12">Login required</p>`; return; }

    MEMBER = (window as any).navGetMember?.();
    if (!MEMBER) {
      app.innerHTML = `<div class="text-center py-12"><button class="px-4 py-2 bg-navy text-white rounded-lg border-0 cursor-pointer text-sm font-semibold" onclick="document.dispatchEvent(new CustomEvent('open-auth'))">Login</button></div>`;
      return;
    }

    await loadAndRender();
  })();
</script>
