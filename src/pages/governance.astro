---
import BaseLayout from '../layouts/BaseLayout.astro';
import GovernancePage from '../components/governance/GovernancePage';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { buildPageI18n } from '../i18n/pageI18n';

const lang: Lang = getLangFromURL(Astro.url.pathname);
const i18nBundle = buildPageI18n(['governance'], lang);
---
<BaseLayout title={t('governance.title', lang)} activePage="governance" lang={lang}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <GovernancePage client:load />
  </main>
</BaseLayout>
