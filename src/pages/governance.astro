---
import BaseLayout from '../layouts/BaseLayout.astro';
import GovernancePage from '../components/governance/GovernancePage';
import { t, getLangFromURL, type Lang } from '../i18n/utils';
import { buildPageI18n } from '../i18n/pageI18n';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
const i18nBundle = buildPageI18n(['governance'], lang);
---
<BaseLayout title={t('governance.title', lang)} activePage="governance" lang={lang}>
  <script id="page-i18n" type="application/json" set:html={i18nBundle}></script>
  <main class="max-w-6xl mx-auto px-4 py-8">
    <GovernancePage client:load />
  </main>
</BaseLayout>

<style>
  @media print {
    nav, footer, [class*="print:hidden"], .print\:hidden { display: none !important; }
    main { max-width: 100% !important; padding: 1rem !important; }
    details { display: block !important; }
    details > summary { display: none !important; }
    details > div, details > pre, details > p { display: block !important; }
  }
</style>
