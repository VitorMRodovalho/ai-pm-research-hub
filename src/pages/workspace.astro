---
import BaseLayout from '../layouts/BaseLayout.astro';
import Toast from '../components/ui/Toast.astro';
import ConfirmModal from '../components/ui/ConfirmModal.astro';
import LoadingSkeleton from '../components/ui/LoadingSkeleton.astro';
import KpiDashboard from '../components/workspace/KpiDashboard';
import AttendanceDashboard from '../components/workspace/AttendanceDashboard';
import AttendanceForm from '../components/workspace/AttendanceForm';
import DropoutRiskBanner from '../components/workspace/DropoutRiskBanner';
import MyTasksIsland from '../components/workspace/MyTasksIsland';
import OnboardingChecklist from '../components/onboarding/OnboardingChecklist';
import { t, getLangFromURL, type Lang } from '../i18n/utils';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);

const WK = {
  meta: t('wk.meta', lang),
  heading: t('wk.heading', lang),
  subtitle: t('wk.subtitle', lang),
  loading: t('wk.loading', lang),
  authRequired: t('wk.authRequired', lang),
  authBtn: t('wk.authBtn', lang),
  checkinBanner: t('wk.checkinBanner', lang),
  checkinStarted: t('wk.checkinStarted', lang),
  checkinStartsSoon: t('wk.checkinStartsSoon', lang),
  checkinDone: t('wk.checkinDone', lang),
  sectionMyTribe: t('wk.sectionMyTribe', lang),
  sectionSubprojects: t('wk.sectionSubprojects', lang),
  myPublications: t('wk.myPublications', lang),
  sectionProduction: t('wk.sectionProduction', lang),
  sectionOnboarding: t('wk.sectionOnboarding', lang),
  onbProgress: t('wk.onbProgress', lang),
  onbOverdue: t('wk.onbOverdue', lang),
  onbCompleted: t('wk.onbCompleted', lang),
  onbPending: t('wk.onbPending', lang),
  onbMarkDone: t('wk.onbMarkDone', lang),
  onbAllDone: t('wk.onbAllDone', lang),
  onbAllDoneDesc: t('wk.onbAllDoneDesc', lang),
  tribeItems: t('wk.tribeItems', lang),
  tribePending: t('wk.tribePending', lang),
  tribeNextMeeting: t('wk.tribeNextMeeting', lang),
  tribeProgress: t('wk.tribeProgress', lang),
  tribeLeader: t('wk.tribeLeader', lang),
  tribeMembers: t('wk.tribeMembers', lang),
  tribeOpen: t('wk.tribeOpen', lang),
  tribeNoTribe: t('wk.tribeNoTribe', lang),
  tribeNoTribeDesc: t('wk.tribeNoTribeDesc', lang),
  commsHub: t('wk.commsHub', lang),
  commsBoard: t('wk.commsBoard', lang),
  pubBoard: t('wk.pubBoard', lang),
  webinars: t('wk.webinars', lang),
  curatorship: t('wk.curatorship', lang),
  leadership: t('wk.leadership', lang),
  publications: t('wk.publications', lang),
  artifacts: t('wk.artifacts', lang),
  library: t('wk.library', lang),
  presentations: t('wk.presentations', lang),
  subprojectItems: t('wk.subprojectItems', lang),
  subprojectPending: t('wk.subprojectPending', lang),
  open: t('wk.open', lang),
  done: t('wk.done', lang),
  inProgress: t('wk.inProgress', lang),
  tribeDashboard: t('wk.tribeDashboard', lang),
  tribePrefix: t('workspace.tribePrefix', lang),
  allTribesAccess: t('wk.allTribesAccess', lang),
  exploreTribes: t('wk.exploreTribes', lang),
  dayNames: [
    t('common.days.sun', lang), t('common.days.mon', lang), t('common.days.tue', lang),
    t('common.days.wed', lang), t('common.days.thu', lang), t('common.days.fri', lang),
    t('common.days.sat', lang),
  ],
};
---
<BaseLayout title={WK.meta} activePage="workspace" lang={lang}>
  <Toast />
  <ConfirmModal />
  <div class="max-w-[1200px] mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-2xl font-extrabold text-[var(--text-primary)]">{WK.heading}</h1>
      <p class="text-sm text-[var(--text-secondary)] mt-1">{WK.subtitle}</p>
    </div>

    <!-- Auth gate -->
    <div id="wk-auth-gate" class="hidden bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-8 text-center">
      <div class="text-3xl mb-3">🔒</div>
      <p class="font-semibold text-[var(--text-primary)] mb-2">{WK.authRequired}</p>
      <button id="wk-login-btn" class="mt-3 px-5 py-2.5 bg-navy text-white rounded-xl text-sm font-semibold border-0 cursor-pointer hover:opacity-90 transition-all">
        {WK.authBtn}
      </button>
    </div>

    <!-- Loading -->
    <div id="wk-loading" class="space-y-6">
      <LoadingSkeleton variant="profile" />
      <LoadingSkeleton variant="card" count={3} />
    </div>

    <!-- Onboarding Checklist -->
    <OnboardingChecklist client:load lang={lang} />

    <!-- Observer Banner -->
    <div id="wk-observer-banner" class="hidden rounded-2xl border border-amber-200 bg-amber-50 p-5 mb-6">
      <div class="flex items-center gap-3 mb-2">
        <span class="text-2xl">👁</span>
        <h2 class="text-base font-bold text-amber-800">{t('members.status_observer', lang)}</h2>
      </div>
      <p class="text-sm text-amber-700 mb-2">{t('members.observer_banner', lang)}</p>
      <p class="text-xs text-amber-600">{t('members.observer_return', lang)}</p>
    </div>

    <!-- Main content (hidden until loaded) -->
    <div id="wk-content" class="hidden space-y-8">

      <!-- Quick Check-in Banner (shown when near event exists) -->
      <div id="wk-checkin-banner" class="hidden"></div>

      <!-- ═══ Onboarding Checklist (shown for new members) ═══ -->
      <section id="wk-onboarding" class="hidden">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">📋</span> {WK.sectionOnboarding}
        </h2>
        <div id="wk-onboarding-card" class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-5">
          <div id="wk-onb-progress-bar" class="mb-4">
            <div class="flex justify-between text-xs font-semibold mb-1">
              <span id="wk-onb-label" class="text-[var(--text-secondary)]"></span>
              <span id="wk-onb-pct" class="text-navy"></span>
            </div>
            <div class="h-2.5 rounded-full bg-[var(--border-subtle)] overflow-hidden">
              <div id="wk-onb-bar" class="h-full rounded-full bg-teal transition-all" style="width:0%"></div>
            </div>
          </div>
          <div id="wk-onb-steps" class="space-y-2"></div>
          <div id="wk-onb-done" class="hidden text-center py-4">
            <div class="text-2xl mb-2">🎉</div>
            <p class="font-bold text-[var(--text-primary)]">{WK.onbAllDone}</p>
            <p class="text-xs text-[var(--text-secondary)] mt-1">{WK.onbAllDoneDesc}</p>
          </div>
        </div>
      </section>

      <!-- ═══ Section 1: Minha Tribo ═══ -->
      <section id="wk-my-tribe">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">🏠</span> {WK.sectionMyTribe}
        </h2>
        <!-- No tribe state -->
        <div id="wk-no-tribe" class="hidden bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-6 text-center">
          <div class="text-2xl mb-2">🔍</div>
          <p class="font-semibold text-[var(--text-primary)]">{WK.tribeNoTribe}</p>
          <p class="text-sm text-[var(--text-secondary)] mt-1">{WK.tribeNoTribeDesc}</p>
        </div>
        <!-- Tribe card (populated via JS) -->
        <div id="wk-tribe-card" class="hidden"></div>
      </section>

      <!-- ═══ Section 1.5: Alertas Operacionais (GP only) ═══ -->
      <section id="wk-alerts" class="hidden">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">🚨</span> {WK.sectionAlerts || 'Alertas Operacionais'}
        </h2>
        <div id="wk-alerts-card" class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-5"></div>
      </section>

      <!-- ═══ Dropout Risk Banner (GP/leader only, self-hides if 0) ═══ -->
      <section id="wk-dropout-risk" class="hidden">
        <DropoutRiskBanner client:load />
      </section>

      <!-- ═══ KPI Dashboard (all authenticated members) ═══ -->
      <section id="wk-kpis" class="hidden">
        <KpiDashboard client:load />
      </section>

      <!-- ═══ Attendance Form (manager/leader only) ═══ -->
      <section id="wk-attendance-form" class="hidden">
        <AttendanceForm client:load />
      </section>

      <!-- ═══ Attendance Dashboard ═══ -->
      <section id="wk-attendance" class="hidden">
        <AttendanceDashboard client:load />
      </section>

      <!-- ═══ Section 2: Subprojetos ═══ -->
      <section id="wk-subprojects">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">📋</span> {WK.sectionSubprojects}
        </h2>
        <div id="wk-subprojects-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
      </section>

      <!-- ═══ My Tasks (cross-board) ═══ -->
      <section id="wk-my-tasks">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">☑️</span> {t('boards.my_tasks', lang) || 'Minhas atividades'}
        </h2>
        <MyTasksIsland client:load lang={lang} />
      </section>

      <!-- ═══ My Publications card (researcher self-service) ═══ -->
      <section id="wk-my-pubs" class="hidden">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">📄</span> {WK.myPublications || 'Minhas Publicações'}
        </h2>
        <div id="wk-my-pubs-card" class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-5">
          <p class="text-xs text-[var(--text-secondary)]">Carregando...</p>
        </div>
      </section>

      <!-- ═══ Section 3: Produção & Recursos ═══ -->
      <section id="wk-production">
        <h2 class="text-base font-bold text-[var(--text-primary)] mb-3 flex items-center gap-2">
          <span class="text-lg">📄</span> {WK.sectionProduction}
        </h2>
        <div id="wk-production-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
      </section>
    </div>
  </div>

  <script id="wk-i18n" type="application/json" set:html={JSON.stringify(WK)}></script>
  <script>
    import { hasPermission } from '../lib/permissions';
    // ── Workspace Cockpit — client-side orchestration ──
    (async () => {
      const i18n: Record<string, any> = JSON.parse(
        document.getElementById('wk-i18n')?.textContent || '{}'
      );
      const dayNames: string[] = i18n.dayNames || ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];

      const $loading = document.getElementById('wk-loading')!;
      const $authGate = document.getElementById('wk-auth-gate')!;
      const $content = document.getElementById('wk-content')!;
      const $noTribe = document.getElementById('wk-no-tribe')!;
      const $tribeCard = document.getElementById('wk-tribe-card')!;
      const $subGrid = document.getElementById('wk-subprojects-grid')!;
      const $prodGrid = document.getElementById('wk-production-grid')!;

      // Login button
      document.getElementById('wk-login-btn')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('open-auth-modal'));
      });

      // ── Auth (matches attendance.astro pattern) ──
      const sb = (window as any).navGetSb?.();
      if (!sb) { setTimeout(() => location.reload(), 300); return; }

      // ── Helpers (declared before any async/event code to avoid TDZ) ──
      function escHtml(s: string): string {
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function getTribeColor(tribeId: number): string {
        const colors: Record<number, string> = {
          1: '#00799E', 2: '#00799E', 3: '#FF610F', 4: '#FF610F',
          5: '#4F17A8', 6: '#4F17A8', 7: '#10B981', 8: '#10B981',
        };
        return colors[tribeId] || '#94A3B8';
      }

      const TIER_RANK: Record<string, number> = {
        visitor: 0, member: 1, observer: 2, leader: 3, admin: 4, superadmin: 5,
      };

      function resolveTier(m: any): string {
        if (m.is_superadmin) return 'superadmin';
        const role = m.operational_role || m.role || 'guest';
        const map: Record<string, string> = {
          manager: 'admin', deputy_manager: 'admin',
          tribe_leader: 'leader', facilitator: 'leader',
          researcher: 'member', communicator: 'member',
          guest: 'member',
        };
        return map[role] || 'member';
      }

      function checkSubprojectAccess(
        sp: { minTier: string; designations: string[] },
        tier: string,
        desig: string[],
        opRole: string
      ): boolean {
        const meetsTier = (TIER_RANK[tier] || 0) >= (TIER_RANK[sp.minTier] || 0);
        const hasDesig = sp.designations.length > 0 && sp.designations.some(d => desig.includes(d));
        return meetsTier || hasDesig;
      }

      let member: any = null;
      let _wsLoaded = false;

      // Listen for future nav:member events
      window.addEventListener('nav:member', ((e: CustomEvent) => {
        if (e.detail) {
          member = e.detail;
          onMemberReady();
        } else {
          $loading.classList.add('hidden');
          $authGate.classList.remove('hidden');
        }
      }) as EventListener);

      // 1) Check if nav already has a member loaded
      const m = (window as any).navGetMember?.();
      if (m) {
        member = m;
      } else {
        // 2) Nav might not be ready yet — check session directly
        const { data: { session } } = await sb.auth.getSession();
        if (session) {
          const { data } = await sb.rpc('get_member_by_auth');
          if (data) {
            member = data;
          }
        }
      }

      if (!member) {
        $loading.classList.add('hidden');
        $authGate.classList.remove('hidden');
        return;
      }

      async function onMemberReady() {
        if (_wsLoaded) return;
        // Re-run data loading when member becomes available later
        $authGate.classList.add('hidden');
        $loading.classList.remove('hidden');
        await loadWorkspaceData();
      }

      async function loadWorkspaceData() {
      if (_wsLoaded) return;
      _wsLoaded = true;

      // Parallel data fetching
      const [boardsRes, meetingRes, tribeCountRes] = await Promise.allSettled([
        sb.rpc('list_active_boards'),
        member.tribe_id
          ? sb.from('tribe_meeting_slots')
              .select('day_of_week, time_start, time_end')
              .eq('tribe_id', member.tribe_id)
              .eq('is_active', true)
              .limit(1)
          : Promise.resolve({ data: null }),
        member.tribe_id
          ? sb.from('active_members')
              .select('id', { count: 'exact', head: true })
              .eq('tribe_id', member.tribe_id)
          : Promise.resolve({ count: 0 }),
      ]);

      const boards = boardsRes.status === 'fulfilled' ? (boardsRes.value?.data || []) : [];
      const meetingSlots = meetingRes.status === 'fulfilled' ? (meetingRes.value?.data || []) : [];
      const tribeMemberCount = tribeCountRes.status === 'fulfilled' ? (tribeCountRes.value?.count || 0) : 0;

      // ── Categorize boards ──
      const myTribeBoard = boards.find((b: any) => b.tribe_id === member.tribe_id && b.domain_key === 'research_delivery');
      const operationalBoards = boards.filter((b: any) => b.board_scope === 'operational');

      // ── Render Section 1: Minha Tribo ──
      if (member.tribe_id && myTribeBoard) {
        const totalItems = myTribeBoard.item_count || 0;
        // Get item status counts
        let doneCount = 0;
        let pendingCount = 0;
        try {
          const { data: statusData } = await sb
            .from('board_items')
            .select('status')
            .eq('board_id', myTribeBoard.id);
          if (statusData) {
            doneCount = statusData.filter((i: any) => i.status === 'done').length;
            pendingCount = statusData.filter((i: any) => i.status === 'todo' || i.status === 'backlog').length;
          }
        } catch {}

        const progressPct = totalItems > 0 ? Math.round((doneCount / totalItems) * 100) : 0;

        // Meeting schedule
        let meetingLabel = '';
        if (meetingSlots.length > 0) {
          const slot = meetingSlots[0];
          const day = dayNames[slot.day_of_week] || `Dia ${slot.day_of_week}`;
          meetingLabel = `${day} · ${(slot.time_start||'').substring(0,5).replace(/:00$/, 'h').replace(/:(\d\d)$/, 'h$1')}–${(slot.time_end||'').substring(0,5).replace(/:00$/, 'h').replace(/:(\d\d)$/, 'h$1')}`;
        }

        // Find tribe name from static data in DOM or fallback
        const tribeName = myTribeBoard.board_name?.replace(/^Board\s*/i, '') || `${i18n.tribePrefix} ${member.tribe_id}`;

        const tribeColor = getTribeColor(member.tribe_id);
        const isLeader = hasPermission(member, 'board.edit_tribe_items');

        $tribeCard.innerHTML = `
          <a href="/tribe/${member.tribe_id}?tab=board" class="block no-underline group">
            <div class="bg-[var(--surface-card)] border-2 rounded-2xl p-5 transition-all hover:shadow-lg hover:border-opacity-60"
                 style="border-color: ${tribeColor}">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <div class="text-xs font-bold uppercase tracking-wide mb-1" style="color: ${tribeColor}">
                    ${i18n.tribePrefix} ${member.tribe_id}
                  </div>
                  <h3 class="text-lg font-extrabold text-[var(--text-primary)] group-hover:underline">${escHtml(tribeName)}</h3>
                </div>
                <span class="text-xs font-semibold px-3 py-1 rounded-full text-white" style="background: ${tribeColor}">
                  ${i18n.tribeOpen} &rarr;
                </span>
              </div>
              <div class="flex flex-wrap gap-x-5 gap-y-1 text-[13px] text-[var(--text-secondary)] mb-3">
                <span>📋 ${totalItems} ${i18n.tribeItems} · ${pendingCount} ${i18n.tribePending}</span>
                ${meetingLabel ? `<span>📅 ${i18n.tribeNextMeeting}: ${meetingLabel}</span>` : ''}
                <span>👥 ${tribeMemberCount} ${i18n.tribeMembers}</span>
              </div>
              <!-- Progress bar -->
              <div class="flex items-center gap-3">
                <div class="flex-1 h-2 rounded-full bg-[var(--border-subtle)] overflow-hidden">
                  <div class="h-full rounded-full transition-all" style="width: ${progressPct}%; background: ${tribeColor}"></div>
                </div>
                <span class="text-xs font-bold" style="color: ${tribeColor}">${progressPct}%</span>
              </div>
              ${isLeader ? `<div class="mt-3 pt-3 border-t border-[var(--border-subtle)]"><a href="/admin/tribe/${member.tribe_id}" class="text-xs font-bold no-underline hover:underline" style="color: ${tribeColor}">📊 ${i18n.tribeDashboard} &rarr;</a></div>` : ''}
            </div>
          </a>
        `;
        $tribeCard.classList.remove('hidden');
      } else if (!member.tribe_id) {
        // Check if admin/stakeholder — show "access to all tribes" instead of "no tribe"
        const isAdminOrStakeholder = member.is_superadmin
          || ['manager'].includes(member.operational_role)
          || (member.designations || []).includes('deputy_manager')
          || ['sponsor', 'chapter_liaison'].includes(member.operational_role);

        if (isAdminOrStakeholder) {
          $tribeCard.innerHTML = `
            <a href="/tribe/1" class="block no-underline group">
              <div class="bg-[var(--surface-card)] border-2 border-navy/20 rounded-2xl p-5 hover:shadow-md transition-all">
                <div class="flex items-center gap-3">
                  <span class="text-2xl">🌐</span>
                  <div>
                    <h3 class="text-base font-bold text-navy group-hover:underline">${i18n.allTribesAccess || 'Acesso a todas as tribos'}</h3>
                    <p class="text-sm text-[var(--text-secondary)] mt-0.5">${i18n.exploreTribes || 'Explorar Tribos'} &rarr;</p>
                  </div>
                </div>
              </div>
            </a>
          `;
          $tribeCard.classList.remove('hidden');
        } else {
          $noTribe.classList.remove('hidden');
        }
      } else {
        // Has tribe but no board yet
        $tribeCard.innerHTML = `
          <a href="/tribe/${member.tribe_id}" class="block no-underline">
            <div class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-5 hover:shadow-md transition-all">
              <h3 class="text-base font-bold text-[var(--text-primary)]">${i18n.tribePrefix} ${member.tribe_id}</h3>
              <p class="text-sm text-[var(--text-secondary)] mt-1">${i18n.tribeOpen} &rarr;</p>
            </div>
          </a>
        `;
        $tribeCard.classList.remove('hidden');
      }

      // ── Render Section 1.5: Alertas Operacionais (GP only) ──
      const isGP = hasPermission(member, 'admin.access');
      if (isGP) {
        const $alertsSection = document.getElementById('wk-alerts');
        const $alertsCard = document.getElementById('wk-alerts-card');
        if ($alertsSection && $alertsCard && !$alertsSection.dataset.loaded) {
          $alertsSection.dataset.loaded = '1';
          try {
            const { data: alertData, error: alertError } = await sb.rpc('detect_operational_alerts');
            if (alertError) throw alertError;
            if (alertData && alertData.total > 0) {
              const sev = alertData.by_severity;
              const topAlerts = alertData.alerts.slice(0, 5);
              const sevIcons: Record<string, string> = { high: '🔴', medium: '⚠️', low: 'ℹ️' };
              $alertsCard.innerHTML = `
                <div class="flex items-center justify-between mb-3">
                  <div class="flex gap-2">
                    ${sev.high > 0 ? `<span class="text-xs font-bold px-2 py-0.5 rounded-full bg-red-100 text-red-700">🔴 ${sev.high} altos</span>` : ''}
                    ${sev.medium > 0 ? `<span class="text-xs font-bold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">⚠️ ${sev.medium} médios</span>` : ''}
                    ${sev.low > 0 ? `<span class="text-xs font-bold px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">ℹ️ ${sev.low} baixos</span>` : ''}
                  </div>
                  <a href="/admin/tribes" class="text-xs font-bold text-teal no-underline hover:underline">Ver tudo &rarr;</a>
                </div>
                <div class="space-y-1.5">
                  ${topAlerts.map((a: any) => `<div class="flex items-start gap-2 text-xs p-2 rounded-lg bg-[var(--surface-hover)]"><span>${sevIcons[a.severity] || ''}</span><span class="text-[var(--text-primary)]">${escHtml(a.message)}</span></div>`).join('')}
                </div>
              `;
              $alertsSection.classList.remove('hidden');
            }
          } catch (e) {
            console.warn('Workspace: detect_operational_alerts failed:', e);
          }
        }
      }

      // ── Render Section 2: Subprojetos ──
      const SUBPROJECTS = [
        { key: 'comms', label: i18n.commsHub, icon: '📡', href: '/admin/comms', domain: 'communication', minTier: 'leader', designations: ['comms_leader', 'comms_member'] },
        { key: 'webinars', label: i18n.webinars, icon: '🎬', href: '/webinars', domain: null, minTier: 'leader', designations: ['comms_leader', 'comms_member', 'curator', 'co_gp'] },
        { key: 'curatorship', label: i18n.curatorship, icon: '🔍', href: '/admin/curatorship', domain: 'publications_submissions', minTier: 'observer', designations: [] },
        { key: 'leadership', label: i18n.leadership, icon: '👥', href: '/teams', domain: null, minTier: 'leader', designations: [] },
        { key: 'publications', label: i18n.publications, icon: '📑', href: '/publications', domain: 'publications_submissions', minTier: 'leader', designations: ['curator', 'co_gp', 'comms_leader', 'comms_member'] },
        { key: 'board-comms', label: i18n.commsBoard, icon: '📋', href: '/admin/board/a6b78238-11aa-476a-b7e2-a674d224fd79', domain: 'communication', minTier: 'member', designations: ['comms_leader', 'comms_member', 'curator', 'co_gp'] },
        { key: 'board-pub', label: i18n.pubBoard, icon: '📄', href: '/admin/board/86a8959c-ddd0-4a7f-b45f-bf828230f949', domain: 'publications_submissions', minTier: 'member', designations: ['comms_leader', 'comms_member', 'curator', 'co_gp'] },
        { key: 'cpmai', label: 'CPMAI Prep Course', icon: '🎓', href: '/boards/75df916d-cc19-4d42-a58d-6017eb710a24', domain: 'cpmai_design', minTier: 'admin', designations: ['ambassador'] },
      ];

      const memberTier = resolveTier(member);
      const memberDesig = member.designations || [];
      const memberOpRole = member.operational_role || member.role || '';

      for (const sp of SUBPROJECTS) {
        const hasAccess = checkSubprojectAccess(sp, memberTier, memberDesig, memberOpRole);
        if (!hasAccess) continue;

        const board = sp.domain ? operationalBoards.find((b: any) => b.domain_key === sp.domain) : null;
        const itemCount = board?.item_count || 0;

        const card = document.createElement('a');
        card.href = sp.href;
        card.className = 'block no-underline';
        card.innerHTML = `
          <div class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-4 hover:shadow-md hover:border-[var(--border-default)] transition-all h-full">
            <div class="text-xl mb-2">${sp.icon}</div>
            <h3 class="text-sm font-bold text-[var(--text-primary)] mb-1">${escHtml(sp.label)}</h3>
            ${itemCount > 0 ? `<p class="text-xs text-[var(--text-secondary)]">${itemCount} ${i18n.subprojectItems}</p>` : ''}
          </div>
        `;
        $subGrid.appendChild(card);
      }

      // ── Render Section 3: Produção & Recursos ──
      const PRODUCTION = [
        { label: i18n.artifacts, icon: '📄', href: '/artifacts' },
        { label: i18n.library, icon: '📚', href: '/library' },
        { label: i18n.presentations, icon: '🎬', href: '/presentations' },
      ];

      for (const item of PRODUCTION) {
        const card = document.createElement('a');
        card.href = item.href;
        card.className = 'block no-underline';
        card.innerHTML = `
          <div class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-4 hover:shadow-md hover:border-[var(--border-default)] transition-all h-full">
            <div class="text-xl mb-2">${item.icon}</div>
            <h3 class="text-sm font-bold text-[var(--text-primary)]">${escHtml(item.label)}</h3>
          </div>
        `;
        $prodGrid.appendChild(card);
      }

      // ── My Publications Card ──
      try {
        const canSubmit = hasPermission(member, 'content.submit_publication');
        if (canSubmit) {
          const { data: allSubs } = await sb.rpc('get_publication_submissions', { p_status: null, p_tribe_id: null });
          const mySubs = (allSubs || []).filter((s: any) =>
            s.primary_author_id === member.id ||
            (s.authors || []).some((a: any) => a.member_id === member.id)
          );
          const $myPubsSection = document.getElementById('wk-my-pubs');
          const $myPubsCard = document.getElementById('wk-my-pubs-card');
          if ($myPubsSection && $myPubsCard) {
            const counts: Record<string, number> = {};
            mySubs.forEach((s: any) => { counts[s.status] = (counts[s.status] || 0) + 1; });
            const STATUS_PT: Record<string, string> = {
              draft: 'rascunho', submitted: 'submetidos', under_review: 'em revisão',
              revision_requested: 'revisão solicitada', accepted: 'aceitos',
              rejected: 'rejeitados', published: 'publicados', presented: 'apresentados',
            };
            const parts = Object.entries(counts).map(([k, v]) => `${v} ${STATUS_PT[k] || k}`);
            $myPubsCard.innerHTML = `
              <div class="flex items-center justify-between">
                <p class="text-sm text-[var(--text-secondary)]">${mySubs.length > 0 ? parts.join(' &middot; ') : 'Nenhuma submissão ainda'}</p>
                <a href="/publications" class="text-xs font-bold text-teal no-underline hover:underline">Ver todas &rarr;</a>
              </div>
            `;
            $myPubsSection.classList.remove('hidden');
          }
        }
      } catch (e) {
        console.warn('Workspace: my publications load failed:', e);
      }

      // ── Quick Check-in Banner ──
      try {
        const { data: nearEvents } = await sb.rpc('get_near_events', { p_member_id: member.id });
        const banner = document.getElementById('wk-checkin-banner')!;
        if (nearEvents?.length) {
          const unchecked = nearEvents.filter((ev: any) => !ev.already_checked_in);
          if (unchecked.length > 0) {
            const ev = unchecked[0];
            const evDate = new Date(ev.event_date + 'T00:00:00');
            const diffMin = Math.round((Date.now() - evDate.getTime()) / 60000);
            const timeLabel = diffMin > 0
              ? i18n.checkinStarted.replace('{m}', String(diffMin))
              : i18n.checkinStartsSoon.replace('{m}', String(Math.abs(diffMin)));

            banner.innerHTML = `
              <div class="bg-teal/10 border-2 border-teal rounded-2xl p-3 sm:p-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 sm:gap-3 animate-pulse-border relative">
                <button type="button" id="wk-checkin-dismiss" class="absolute top-1.5 right-2 text-[var(--text-muted)] hover:text-[var(--text-primary)] bg-transparent border-0 cursor-pointer text-base leading-none" aria-label="Dismiss">&times;</button>
                <div class="flex-1 min-w-0">
                  <div class="font-bold text-[var(--text-primary)] text-sm truncate">${escHtml(ev.event_title)}</div>
                  <div class="text-xs text-[var(--text-secondary)] mt-0.5">${timeLabel}</div>
                </div>
                <button type="button" id="wk-quick-checkin-btn"
                  class="w-full sm:w-auto px-3 sm:px-4 py-2 bg-teal text-white rounded-xl text-sm font-bold border-0 cursor-pointer hover:opacity-90 transition-all flex-shrink-0"
                  data-event-id="${ev.event_id}">
                  ${i18n.checkinBanner}
                </button>
              </div>
            `;
            banner.classList.remove('hidden');

            document.getElementById('wk-quick-checkin-btn')?.addEventListener('click', async () => {
              const btn = document.getElementById('wk-quick-checkin-btn') as HTMLElement;
              btn.textContent = '...';
              btn.setAttribute('disabled', 'true');
              try {
                const { data: result, error } = await sb.rpc('register_own_presence', { p_event_id: ev.event_id });
                if (error) throw error;
                if (result?.success) {
                  banner.innerHTML = `
                    <div class="bg-green-50 border-2 border-green-400 rounded-2xl p-4 text-center">
                      <span class="font-bold text-green-700 text-sm">${i18n.checkinDone}</span>
                    </div>
                  `;
                  const safePH = (window as any).__safePH;
                  safePH?.('capture', 'quick_checkin_used', { source: 'workspace', event_id: ev.event_id });
                  setTimeout(() => banner.classList.add('hidden'), 3000);
                } else {
                  (window as any).toast?.(result?.message || result?.error || 'Error', 'error');
                  btn.textContent = i18n.checkinBanner;
                  btn.removeAttribute('disabled');
                }
              } catch (e: any) {
                (window as any).toast?.(e?.message || 'Error', 'error');
                btn.textContent = i18n.checkinBanner;
                btn.removeAttribute('disabled');
              }
            });
            document.getElementById('wk-checkin-dismiss')?.addEventListener('click', () => {
              banner.classList.add('hidden');
            });
          }
        }
      } catch (e) {
        console.warn('Workspace: failed to load near events:', e);
      }

      // ── Load Onboarding Checklist ──
      try {
        // Uses RPC wrapper to avoid direct query on RLS deny-all table
        {
          const { data: onbStatus } = await sb.rpc('get_my_onboarding');
          const appId = onbStatus?.application_id;

          if (onbStatus && onbStatus.steps?.length > 0) {
            const $onbSection = document.getElementById('wk-onboarding')!;
            const $onbSteps = document.getElementById('wk-onb-steps')!;
            const $onbLabel = document.getElementById('wk-onb-label')!;
            const $onbPct = document.getElementById('wk-onb-pct')!;
            const $onbBar = document.getElementById('wk-onb-bar')!;
            const $onbDone = document.getElementById('wk-onb-done')!;

            const pct = onbStatus.total_steps > 0 ? Math.round((onbStatus.completed_steps / onbStatus.total_steps) * 100) : 0;
            $onbLabel.textContent = `${onbStatus.completed_steps}/${onbStatus.total_steps} ${i18n.onbProgress}`;
            $onbPct.textContent = `${pct}%`;
            $onbBar.style.width = `${pct}%`;

            if (onbStatus.is_fully_complete) {
              $onbSteps.classList.add('hidden');
              $onbDone.classList.remove('hidden');
            } else {
              const _wkLang = location.pathname.startsWith('/en') ? 'en' : location.pathname.startsWith('/es') ? 'es' : (new URLSearchParams(location.search).get('lang') || localStorage.getItem('preferred_locale') || 'pt-BR').startsWith('en') ? 'en' : 'pt';
              for (const step of onbStatus.steps) {
                const isDone = step.status === 'completed' || step.status === 'skipped';
                const isOverdue = step.is_overdue;
                const stepEl = document.createElement('div');
                stepEl.className = `flex items-center gap-3 p-3 rounded-xl border ${
                  isDone ? 'bg-green-50 border-green-200' :
                  isOverdue ? 'bg-red-50 border-red-200' :
                  'bg-[var(--surface-section-cool)] border-[var(--border-subtle)]'
                }`;

                const statusIcon = isDone ? '✅' : isOverdue ? '⚠️' : '⏳';
                const slaLabel = !isDone && step.sla_deadline
                  ? (() => {
                      const deadline = new Date(step.sla_deadline);
                      const daysLeft = Math.ceil((deadline.getTime() - Date.now()) / 86400000);
                      return daysLeft > 0
                        ? `<span class="text-[.65rem] text-amber-600">${daysLeft}d restantes</span>`
                        : `<span class="text-[.65rem] text-red-600 font-bold">${i18n.onbOverdue}</span>`;
                    })()
                  : '';

                const stepLabel = _wkLang === 'en' ? (step.label_en || step.label_pt || step.step_key || '') : _wkLang === 'es' ? (step.label_es || step.label_pt || step.step_key || '') : (step.label_pt || step.step_key || '');
                const stepDesc = _wkLang === 'en' ? (step.description_en || step.description_pt || '') : _wkLang === 'es' ? (step.description_es || step.description_pt || '') : (step.description_pt || '');
                stepEl.innerHTML = `
                  <span class="text-base">${step.icon || statusIcon}</span>
                  <div class="flex-1 min-w-0">
                    <div class="text-sm font-semibold text-[var(--text-primary)]">${escHtml(stepLabel)}</div>
                    ${stepDesc ? `<div class="text-[.68rem] text-[var(--text-muted)] mt-0.5">${escHtml(stepDesc)}</div>` : ''}
                    ${slaLabel}
                  </div>
                  ${!isDone ? `<button class="onb-mark-btn px-3 py-1.5 text-[.7rem] font-bold rounded-lg bg-teal text-white border-0 cursor-pointer hover:opacity-90" data-app="${appId}" data-step="${step.step_id || step.step_key}">${i18n.onbMarkDone}</button>` : `<span class="text-[.65rem] text-green-600 font-semibold">${i18n.onbCompleted}</span>`}
                `;
                $onbSteps.appendChild(stepEl);
              }

              // Attach mark-done handlers
              $onbSteps.querySelectorAll('.onb-mark-btn').forEach((btn: Element) => {
                btn.addEventListener('click', async () => {
                  const el = btn as HTMLButtonElement;
                  const aId = el.dataset.app!;
                  const sKey = el.dataset.step!;
                  el.textContent = '...';
                  el.disabled = true;
                  try {
                    const { data: res, error } = await sb.rpc('update_onboarding_step', {
                      p_application_id: aId, p_step_key: sKey, p_status: 'completed',
                    });
                    if (error) throw error;
                    if (res?.success) {
                      const parent = el.closest('div.flex')!;
                      parent.classList.remove('bg-[var(--surface-section-cool)]', 'border-[var(--border-subtle)]', 'bg-red-50', 'border-red-200');
                      parent.classList.add('bg-green-50', 'border-green-200');
                      parent.querySelector('span.text-base')!.textContent = '✅';
                      el.replaceWith(Object.assign(document.createElement('span'), {
                        className: 'text-[.65rem] text-green-600 font-semibold',
                        textContent: i18n.onbCompleted,
                      }));
                      // Update progress bar
                      $onbLabel.textContent = `${res.completed_steps}/${res.total_steps} ${i18n.onbProgress}`;
                      const newPct = res.total_steps > 0 ? Math.round((res.completed_steps / res.total_steps) * 100) : 0;
                      $onbPct.textContent = `${newPct}%`;
                      $onbBar.style.width = `${newPct}%`;
                      if (res.all_done) {
                        $onbSteps.classList.add('hidden');
                        $onbDone.classList.remove('hidden');
                      }
                    }
                  } catch (e: any) {
                    (window as any).toast?.(e?.message || 'Error', 'error');
                    el.textContent = i18n.onbMarkDone;
                    el.disabled = false;
                  }
                });
              });
            }

            $onbSection.classList.remove('hidden');
          }
        }
      } catch (e) {
        console.warn('Workspace: failed to load onboarding:', e);
      }

      // ── Show KPI + Attendance sections ──
      document.getElementById('wk-dropout-risk')?.classList.remove('hidden');
      document.getElementById('wk-kpis')?.classList.remove('hidden');
      document.getElementById('wk-attendance')?.classList.remove('hidden');

      // Show AttendanceForm for GP/leader
      const canRegister = hasPermission(member, 'event.create');
      if (canRegister) {
        document.getElementById('wk-attendance-form')?.classList.remove('hidden');
      }

      // ── Done: show content ──
      $loading.classList.add('hidden');
      // Observer mode: show banner, hide main operational content
      if (member?.member_status === 'observer') {
        document.getElementById('wk-observer-banner')?.classList.remove('hidden');
      }
      $content.classList.remove('hidden');
      try { if ((window as any).posthog) (window as any).posthog.capture('workspace_visited', { tribe_id: member?.tribe_id || null }); } catch {}
      } // end loadWorkspaceData

      // ── Start loading ──
      await loadWorkspaceData();
    })();
  </script>
</BaseLayout>
