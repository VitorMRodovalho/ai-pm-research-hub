---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromURL, type Lang } from '../i18n/utils';
import ImpactPageIsland from '../components/islands/ImpactPageIsland';

const lang: Lang = getLangFromURL(Astro.url.pathname + Astro.url.search);
---

<BaseLayout
  title="Sobre o Núcleo — IA & Gerenciamento de Projetos"
  description="Iniciativa colaborativa entre 5 capítulos do PMI® no Brasil. 44+ pesquisadores, 8 tribos de pesquisa, 10+ artigos publicados."
  activePage="about"
>
  <div class="max-w-[1100px] mx-auto px-4 py-8">
    <ImpactPageIsland client:load lang={lang} />
  </div>
</BaseLayout>

<!-- SEO: Open Graph + Schema.org injected via inline script -->
<script is:inline>
  // Add OG meta tags dynamically (Astro BaseLayout doesn't have head slot)
  const metas = [
    { property: 'og:title', content: 'Núcleo de Estudos e Pesquisa em IA & Gerenciamento de Projetos' },
    { property: 'og:description', content: 'Iniciativa colaborativa entre 5 capítulos do PMI® no Brasil. 44+ pesquisadores, 8 tribos de pesquisa, 10+ artigos publicados.' },
    { property: 'og:type', content: 'website' },
    { property: 'og:url', content: 'https://nucleoia.vitormr.dev/about' },
  ];
  metas.forEach(m => {
    if (!document.querySelector(`meta[property="${m.property}"]`)) {
      const el = document.createElement('meta');
      el.setAttribute('property', m.property);
      el.setAttribute('content', m.content);
      document.head.appendChild(el);
    }
  });
  // Schema.org
  if (!document.querySelector('script[type="application/ld+json"]')) {
    const s = document.createElement('script');
    s.type = 'application/ld+json';
    s.textContent = JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ResearchOrganization",
      "name": "Núcleo de Estudos e Pesquisa em IA & Gerenciamento de Projetos",
      "description": "Iniciativa colaborativa entre capítulos do PMI® no Brasil",
      "url": "https://nucleoia.vitormr.dev",
      "parentOrganization": { "@type": "Organization", "name": "Project Management Institute" },
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": 44 }
    });
    document.head.appendChild(s);
  }
</script>
