---
import '../styles/global.css';
import Nav from '../components/nav/Nav.astro';
import AnnouncementBanner from '../components/ui/AnnouncementBanner.astro';
import AuthModal from '../components/ui/AuthModal.astro';
// TierViewerBar disabled — feature incomplete, never worked reliably
import HelpFloatingButton from '../components/help/HelpFloatingButton';
import PrivacyGateModal from '../components/privacy/PrivacyGateModal';
import MilestoneCelebration from '../components/milestones/MilestoneCelebration';
import { t, getRoleLabelsMap, localePath, type Lang } from '../i18n/utils';
import { ACTIVE_TRIBE_COUNT } from '../data/tribes';

interface Props {
  title?: string;
  description?: string;
  activePage?: string;
  lang?: Lang;
}

const {
  activePage = '',
  lang = 'pt-BR',
} = Astro.props;

const {
  title = t('meta.title', lang),
  // #1136: meta.description deriva a contagem de tribos do SSOT (ACTIVE_TRIBE_COUNT).
  // O replace é no-op quando o placeholder não está presente (outras páginas passam sua própria description).
  description = t('meta.description', lang).replace('{tribeCount}', String(ACTIVE_TRIBE_COUNT)),
} = Astro.props;

const roleLabels = JSON.stringify(getRoleLabelsMap(lang));

// og:image precisa de URL ABSOLUTA (WhatsApp/Telegram não resolvem path
// relativo); Astro.url carrega o host canônico em runtime.
const ogImage = new URL('/assets/og-image.png', Astro.url).href;

// Global i18n bundle for React islands in Nav/Layout (GlobalSearch, etc.)
import { buildPageI18n } from '../i18n/pageI18n';
const globalI18nBundle = buildPageI18n(['comp.globalSearch', 'comp.common'], lang);

// SIM_I18N removed — tier simulator disabled
---

<!doctype html>
<html lang={lang === 'pt-BR' ? 'pt-BR' : lang === 'es-LATAM' ? 'es' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:site_name" content="Núcleo IA & GP" />
  <meta property="og:locale" content={lang === 'en-US' ? 'en_US' : lang === 'es-LATAM' ? 'es_419' : 'pt_BR'} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={t('meta.ogImageAlt', lang)} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <slot name="head" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script is:inline>
    (() => {
      const key = 'ui_theme';
      const saved = localStorage.getItem(key);
      const theme = saved === 'dark' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <!-- Browser language auto-detection (W128) -->
  <script is:inline>
    (function() {
      // Skip if already on a localized path or if user has been here before
      if (localStorage.getItem('preferred_language')) return;
      var path = window.location.pathname;
      if (path.startsWith('/en/') || path.startsWith('/es/')) return;
      // Check URL param override
      var urlLang = new URLSearchParams(window.location.search).get('lang');
      if (urlLang) {
        if (urlLang === 'en') { localStorage.setItem('preferred_language', 'en'); window.location.href = '/en/' + path.replace(/^\//, ''); return; }
        if (urlLang === 'es') { localStorage.setItem('preferred_language', 'es'); window.location.href = '/es/' + path.replace(/^\//, ''); return; }
        localStorage.setItem('preferred_language', 'pt');
        return;
      }
      // Auto-detect from browser
      var browserLang = (navigator.language || '').slice(0, 2);
      if (browserLang === 'en') {
        localStorage.setItem('preferred_language', 'en');
        window.location.href = '/en/' + path.replace(/^\//, '');
      } else if (browserLang === 'es') {
        localStorage.setItem('preferred_language', 'es');
        window.location.href = '/es/' + path.replace(/^\//, '');
      } else {
        localStorage.setItem('preferred_language', 'pt');
      }
    })();
  </script>

  <!-- Sentry Error Monitoring (W126) -->
  <script>
    import { initSentry } from '../lib/sentry';
    initSentry();
  </script>

  <!-- Sentry: Global error handlers — catches errors outside React islands -->
  <script>
    import { Sentry } from '../lib/sentry';
    window.addEventListener('error', (event) => {
      try {
        Sentry.captureException(event.error || new Error(event.message), {
          tags: { source: 'window.onerror' },
          extra: { filename: event.filename, lineno: event.lineno, colno: event.colno }
        });
      } catch {}
    });
    window.addEventListener('unhandledrejection', (event) => {
      try {
        Sentry.captureException(
          event.reason instanceof Error ? event.reason : new Error(String(event.reason)),
          { tags: { source: 'unhandledrejection' } }
        );
      } catch {}
    });
  </script>

  <!-- PostHog Analytics -->
  <script>
    // @ts-nocheck
    import { sanitizeAnalyticsProperties } from '../lib/analytics';

    const CONSENT_KEY = 'analytics_consent';
    const __phKey = import.meta.env.PUBLIC_POSTHOG_KEY;
    const __phHost = import.meta.env.PUBLIC_POSTHOG_HOST;

    /** Safe wrapper — only calls PostHog methods when the real SDK has loaded */
    function safePH(method: string, ...args: any[]) {
      const ph = (window as any).posthog;
      if (ph && typeof ph[method] === 'function') {
        try { return ph[method](...args); } catch {}
      }
    }
    (window as any).__safePH = safePH;
    (window as any).__nucleoAnalyticsSanitize = sanitizeAnalyticsProperties;
    (window as any).__nucleoTrack = (eventName: string, properties?: Record<string, any>) => {
      return safePH('capture', eventName, sanitizeAnalyticsProperties(properties));
    };

    if (__phKey && __phHost) {
      !function(t,e){var o,n,p,r;e.__SV||((window as any).posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageviewId".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,(window as any).posthog||[]);

      safePH('init', __phKey, {
        api_host: __phHost,
        person_profiles: 'identified_only',
        capture_pageview: true,
        capture_pageleave: true,
        autocapture: true,
      });
    }

    function consentValue() {
      const v = localStorage.getItem(CONSENT_KEY);
      return v === 'granted' || v === 'denied' ? v : 'denied';
    }

    function applyAnalyticsConsent() {
      if (!(window as any).posthog?.__SV) return; // PostHog not initialized
      const consent = consentValue();
      if (consent === 'granted') {
        safePH('opt_in_capturing');
        safePH('startSessionRecording');
      } else {
        safePH('opt_out_capturing');
        safePH('stopSessionRecording');
      }
    }

    applyAnalyticsConsent();
    window.addEventListener('analytics:consent-changed', applyAnalyticsConsent as EventListener);
  </script>
</head>
<body class="bg-[var(--surface-base)] text-[var(--text-primary)] transition-colors">
  <!-- Role labels for client-side i18n -->
  <script id="role-labels-data" type="application/json" set:html={roleLabels}></script>
  <!-- Global i18n bundle for React islands. usePageI18n() reads BOTH this tag
       and any page-i18n tag the page emits inside <slot/>, then merges them.
       The previous inline merge ran synchronously during HTML parse — before
       the slot was parsed — and ended up creating a phantom page-i18n in
       <head> with only the global keys. That phantom shadowed the real
       page-i18n inside the slot for getElementById callers. Removing the
       inline merge fixes the race; merging is now done client-side in the
       hook. -->
  <script id="global-i18n" type="application/json" set:html={globalI18nBundle}></script>
  
  <Nav activePage={activePage} lang={lang} />
  <AnnouncementBanner />
  <AuthModal lang={lang} />
  <!-- Tier Viewer: disabled — never worked reliably (feature incomplete) -->
  <!-- <div id="tier-viewer-mount" class="hidden">
    <TierViewerBar client:load i18n={SIM_I18N} />
  </div> -->
  <slot />
  <!-- Profile drawer (populated by nav client script) -->
  <div id="pd-overlay" class="hidden fixed inset-0 z-[500]"></div>
  <div id="pd-drawer"
    class="fixed top-[60px] right-4 z-[501] bg-[var(--surface-elevated)] rounded-2xl shadow-2xl border border-[var(--border-subtle)]
           p-4 min-w-[230px] max-h-[calc(100vh-80px)] opacity-0 pointer-events-none scale-95 transition-all duration-200 flex flex-col
           data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:scale-100">
    <div id="pd-inner" class="flex flex-col overflow-y-auto min-h-0"></div>
  </div>

  <!-- Tier Viewer: show mount only for superadmins -->
  <script>
    function showTierViewer() {
      const m = (window as any).navGetMember?.();
      if (m?.is_superadmin) {
        document.getElementById('tier-viewer-mount')?.classList.remove('hidden');
      }
    }
    // Also show if sim_tier cookie exists (already simulating)
    if (document.cookie.includes('sim_tier=')) {
      document.getElementById('tier-viewer-mount')?.classList.remove('hidden');
    }
    window.addEventListener('nav:member', showTierViewer);
  </script>

  <!-- PostHog: identify authenticated user -->
  <script>
    window.addEventListener('nav:member', (e) => {
      const m = (e as CustomEvent).detail;
      const safePH = (window as any).__safePH;
      if (!m || !m.id || !safePH || localStorage.getItem('analytics_consent') !== 'granted') return;
      const opRole = m.operational_role || m.role || 'guest';
      safePH('identify', `member:${m.id}`, (window as any).__nucleoAnalyticsSanitize({
        chapter: m.chapter || '',
        operational_role: opRole,
        designations: (m.designations || []).join(','),
        is_superadmin: m.is_superadmin || false,
        cycle_active: m.current_cycle_active || false,
      }));
      safePH('group', 'chapter', m.chapter || 'unknown');
    });
  </script>

  <!-- Member activity tracker (non-blocking, fire-and-forget) -->
  <script>
    (() => {
      const THROTTLE_KEY = 'hub_activity_ts';
      const THROTTLE_MS = 5 * 60 * 1000; // 5 minutes
      const lastTs = parseInt(sessionStorage.getItem(THROTTLE_KEY) || '0');
      if (Date.now() - lastTs < THROTTLE_MS) return;

      const run = () => {
        const sb = (window as any).navGetSb?.();
        const m = (window as any).navGetMember?.();
        if (!sb || !m) return;
        sessionStorage.setItem(THROTTLE_KEY, Date.now().toString());
        sb.rpc('record_member_activity', { p_page: window.location.pathname }).then(() => {}, () => {});
      };

      if ((window as any).navGetMember?.()) { run(); }
      else { window.addEventListener('nav:member', run, { once: true }); }
    })();
  </script>

  <!-- Help Floating Button (authenticated users only, rendered client-side) -->
  <HelpFloatingButton client:load locale={lang} />

  <!-- #766 PR3 — server-side milestone celebrations (first_attendance / first_deliverable).
       Bottom-left so it clears the bottom-right HelpFloatingButton; below the privacy gate. -->
  <MilestoneCelebration client:load lang={lang} />

  <!-- LGPD Privacy Gate (consent acceptance + annual revalidation) -->
  <PrivacyGateModal client:load lang={lang} />

  <!-- Site Footer with Privacy Link -->
  <footer class="bg-[#200F3B] text-white/40 py-8 px-6 text-center text-[.78rem]">
    <!-- Redes sociais oficiais do Núcleo (handles = comms_channel_config; Spotify = podcast) -->
    <nav aria-label="Redes sociais oficiais do Núcleo" class="flex items-center justify-center gap-5 mb-4">
      <a href="https://www.youtube.com/@nucleo_ia" target="_blank" rel="noopener noreferrer" aria-label="YouTube"
         class="text-white/50 hover:text-[#05BFE0] transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      <a href="https://www.linkedin.com/company/nucleo-ia/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
         class="text-white/50 hover:text-[#05BFE0] transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://www.instagram.com/nucleo.ia.gp" target="_blank" rel="noopener noreferrer" aria-label="Instagram"
         class="text-white/50 hover:text-[#05BFE0] transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
      </a>
      <a href="https://open.spotify.com/show/2DYjPd9dhwXqy6ZnZnAq7c" target="_blank" rel="noopener noreferrer" aria-label="Spotify (podcast)"
         class="text-white/50 hover:text-[#05BFE0] transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
      </a>
      <a href="https://github.com/VitorMRodovalho/ai-pm-research-hub" target="_blank" rel="noopener noreferrer" aria-label="GitHub"
         class="text-white/50 hover:text-[#05BFE0] transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
    </nav>
    <!-- R5 (Ciclo 4): links públicos demovidos da ResourcesSection da home para o rodapé real -->
    <nav aria-label={t('footer.resourcesTitle', lang)} class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 mb-4 text-[.72rem]">
      <a href={localePath('/library', lang)} class="text-white/55 no-underline hover:text-[#05BFE0] hover:underline">{t('nav.library', lang)}</a>
      <span class="text-white/20" aria-hidden="true">·</span>
      <a href={localePath('/blog', lang)} class="text-white/55 no-underline hover:text-[#05BFE0] hover:underline">{t('nav.blog', lang)}</a>
      <span class="text-white/20" aria-hidden="true">·</span>
      <a href="https://youtube.com/playlist?list=PLQJVKrw1fcrx3fD2ug1hnps6TklcMT1dc" target="_blank" rel="noopener noreferrer" class="text-white/55 no-underline hover:text-[#05BFE0] hover:underline">{t('footer.webinars', lang)}</a>
      <span class="text-white/20" aria-hidden="true">·</span>
      <a href="https://www.youtube.com/playlist?list=PLQJVKrw1fcrymIpRMT4efnR0G1TJRaMWI" target="_blank" rel="noopener noreferrer" class="text-white/55 no-underline hover:text-[#05BFE0] hover:underline">{t('footer.meetings', lang)}</a>
      <span class="text-white/20" aria-hidden="true">·</span>
      <a href="https://www.pmi.org/learning/ai-in-project-management" target="_blank" rel="noopener noreferrer" class="text-white/55 no-underline hover:text-[#05BFE0] hover:underline">{t('footer.courses', lang)}</a>
      <span class="text-white/20" aria-hidden="true">·</span>
      <a href="mailto:nucleoia@pmigo.org.br" class="text-white/55 no-underline hover:text-[#05BFE0] hover:underline">{t('footer.contact', lang)}</a>
    </nav>
    <p>{t('footer.line1', lang)}</p>
    <p class="mt-1">{t('footer.chapters', lang)}</p>
    <p class="mt-2 text-[.68rem]">{t('footer.trademarks', lang)}</p>
    <p class="mt-1">
      <a href="https://github.com/VitorMRodovalho/ai-pm-research-hub" class="text-[#05BFE0] no-underline hover:underline">GitHub</a>
      · {t('footer.gp', lang)}
      · <a href={localePath('/privacy', lang)} class="text-[#05BFE0] no-underline hover:underline">{t('footer.privacy', lang)}</a>
      · <a href={localePath('/changelog', lang)} class="text-[#05BFE0] no-underline hover:underline">{t('nav.changelog', lang)}</a>
      · <span id="footer-version" class="text-white/25 text-[.65rem]">development</span>
    </p>
  </footer>
  <script>
    (async () => {
      let sb = (window as any).navGetSb?.();
      if (!sb) {
        await new Promise<void>(r => {
          const check = () => { sb = (window as any).navGetSb?.(); if (sb) r(); else setTimeout(check, 300); };
          setTimeout(check, 300);
          setTimeout(r, 3000);
        });
      }
      if (!sb) return;
      try {
        const { data } = await sb.rpc('get_current_release');
        if (data?.version) {
          const el = document.getElementById('footer-version');
          if (el) el.textContent = data.version;
        }
      } catch {}
    })();
  </script>

  <!-- Cookie Consent Banner (W126) -->
  <div id="consent-banner"
    class="fixed bottom-0 left-0 right-0 z-[600] bg-[var(--surface-elevated)] border-t border-[var(--border-default)] shadow-lg px-4 py-3 flex items-center justify-center gap-3 text-sm hidden">
    <span class="text-[var(--text-secondary)]">{t('consent.message', lang)}</span>
    <a href={localePath('/privacy', lang)} class="text-teal hover:underline text-xs font-semibold">{t('consent.privacyLink', lang)}</a>
    <button id="consent-accept" class="px-3 py-1.5 rounded-lg bg-teal text-white text-xs font-semibold hover:opacity-90">
      {t('consent.accept', lang)}
    </button>
  </div>
  <script is:inline>
    (function() {
      var KEY = 'cookie_consent_accepted';
      if (localStorage.getItem(KEY)) return;
      var banner = document.getElementById('consent-banner');
      if (banner) banner.classList.remove('hidden');
      var btn = document.getElementById('consent-accept');
      if (btn) btn.addEventListener('click', function() {
        localStorage.setItem(KEY, '1');
        if (banner) banner.classList.add('hidden');
      });
    })();
  </script>
</body>
</html>
