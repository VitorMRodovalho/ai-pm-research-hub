---
import '../styles/global.css';
import Nav from '../components/nav/Nav.astro';
import AnnouncementBanner from '../components/ui/AnnouncementBanner.astro';
import AuthModal from '../components/ui/AuthModal.astro';
import TierViewerBar from '../components/admin/TierViewerBar';
import { t, getRoleLabelsMap, type Lang } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  activePage?: string;
  lang?: Lang;
}

const {
  title = 'Núcleo IA & GP — Ciclo 03',
  description = 'The AI & PM Study and Research Hub — A Joint Initiative of the PMI Brazilian Chapters',
  activePage = '',
  lang = 'pt-BR',
} = Astro.props;

const roleLabels = JSON.stringify(getRoleLabelsMap(lang));

const SIM_I18N = {
  title: t('simulation.title', lang),
  banner: t('simulation.banner', lang),
  viewingAs: t('simulation.viewing_as', lang),
  writesWarning: t('simulation.writes_warning', lang),
  exit: t('simulation.exit', lang),
  selectTier: t('simulation.select_tier', lang),
  designationsLabel: t('simulation.designations', lang),
  tribeScope: t('simulation.tribe_scope', lang),
  noTribe: t('simulation.no_tribe', lang),
  start: t('simulation.start', lang),
};
---

<!doctype html>
<html lang={lang === 'pt-BR' ? 'pt-BR' : lang === 'es-LATAM' ? 'es' : 'en'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <script is:inline>
    (() => {
      const key = 'ui_theme';
      const saved = localStorage.getItem(key);
      const theme = saved === 'dark' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <!-- Browser language auto-detection (W128) -->
  <script is:inline>
    (function() {
      // Skip if already on a localized path or if user has been here before
      if (localStorage.getItem('preferred_language')) return;
      var path = window.location.pathname;
      if (path.startsWith('/en/') || path.startsWith('/es/')) return;
      // Check URL param override
      var urlLang = new URLSearchParams(window.location.search).get('lang');
      if (urlLang) {
        if (urlLang === 'en') { localStorage.setItem('preferred_language', 'en'); window.location.href = '/en/' + path.replace(/^\//, ''); return; }
        if (urlLang === 'es') { localStorage.setItem('preferred_language', 'es'); window.location.href = '/es/' + path.replace(/^\//, ''); return; }
        localStorage.setItem('preferred_language', 'pt');
        return;
      }
      // Auto-detect from browser
      var browserLang = (navigator.language || '').slice(0, 2);
      if (browserLang === 'en') {
        localStorage.setItem('preferred_language', 'en');
        window.location.href = '/en/' + path.replace(/^\//, '');
      } else if (browserLang === 'es') {
        localStorage.setItem('preferred_language', 'es');
        window.location.href = '/es/' + path.replace(/^\//, '');
      } else {
        localStorage.setItem('preferred_language', 'pt');
      }
    })();
  </script>

  <!-- Sentry Error Monitoring (W126) -->
  <script>
    import { initSentry } from '../lib/sentry';
    initSentry();
  </script>

  <!-- PostHog Analytics -->
  <script>
    // @ts-nocheck
    const CONSENT_KEY = 'analytics_consent';
    const __phKey = import.meta.env.PUBLIC_POSTHOG_KEY;
    const __phHost = import.meta.env.PUBLIC_POSTHOG_HOST;

    /** Safe wrapper — only calls PostHog methods when the real SDK has loaded */
    function safePH(method: string, ...args: any[]) {
      const ph = (window as any).posthog;
      if (ph && typeof ph[method] === 'function') {
        try { return ph[method](...args); } catch {}
      }
    }
    (window as any).__safePH = safePH;

    if (__phKey && __phHost) {
      !function(t,e){var o,n,p,r;e.__SV||((window as any).posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey getNextSurveyStep identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageviewId".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,(window as any).posthog||[]);

      safePH('init', __phKey, {
        api_host: __phHost,
        person_profiles: 'identified_only',
        capture_pageview: true,
        capture_pageleave: true,
        autocapture: true,
      });
    }

    function consentValue() {
      const v = localStorage.getItem(CONSENT_KEY);
      return v === 'granted' || v === 'denied' ? v : 'denied';
    }

    function applyAnalyticsConsent() {
      if (!(window as any).posthog?.__SV) return; // PostHog not initialized
      const consent = consentValue();
      if (consent === 'granted') {
        safePH('opt_in_capturing');
        safePH('startSessionRecording');
      } else {
        safePH('opt_out_capturing');
        safePH('stopSessionRecording');
      }
    }

    applyAnalyticsConsent();
    window.addEventListener('analytics:consent-changed', applyAnalyticsConsent as EventListener);
  </script>
</head>
<body class="bg-[var(--surface-base)] text-[var(--text-primary)] transition-colors">
  <!-- Role labels for client-side i18n -->
  <script id="role-labels-data" type="application/json" set:html={roleLabels}></script>
  
  <Nav activePage={activePage} lang={lang} />
  <AnnouncementBanner />
  <AuthModal lang={lang} />
  <!-- Tier Viewer: only visible for superadmins (checked client-side) -->
  <div id="tier-viewer-mount" class="hidden">
    <TierViewerBar client:load i18n={SIM_I18N} />
  </div>
  <slot />
  <!-- Profile drawer (populated by nav client script) -->
  <div id="pd-overlay" class="hidden fixed inset-0 z-[500]"></div>
  <div id="pd-drawer"
    class="fixed top-[60px] right-4 z-[501] bg-[var(--surface-elevated)] rounded-2xl shadow-2xl border border-[var(--border-subtle)]
           p-4 min-w-[230px] opacity-0 pointer-events-none scale-95 transition-all duration-200
           data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto data-[open=true]:scale-100">
    <div id="pd-inner"></div>
  </div>

  <!-- Tier Viewer: show mount only for superadmins -->
  <script>
    function showTierViewer() {
      const m = (window as any).navGetMember?.();
      if (m?.is_superadmin) {
        document.getElementById('tier-viewer-mount')?.classList.remove('hidden');
      }
    }
    // Also show if sim_tier cookie exists (already simulating)
    if (document.cookie.includes('sim_tier=')) {
      document.getElementById('tier-viewer-mount')?.classList.remove('hidden');
    }
    window.addEventListener('nav:member', showTierViewer);
  </script>

  <!-- PostHog: identify authenticated user -->
  <script>
    window.addEventListener('nav:member', (e) => {
      const m = (e as CustomEvent).detail;
      const safePH = (window as any).__safePH;
      if (!m || !m.id || !safePH || localStorage.getItem('analytics_consent') !== 'granted') return;
      const opRole = m.operational_role || m.role || 'guest';
      safePH('identify', m.id, {
        chapter: m.chapter || '',
        operational_role: opRole,
        designations: (m.designations || []).join(','),
        is_superadmin: m.is_superadmin || false,
        cycle_active: m.current_cycle_active || false,
      });
      safePH('group', 'chapter', m.chapter || 'unknown');
    });
  </script>

  <!-- Member activity tracker (non-blocking, fire-and-forget) -->
  <script>
    (() => {
      const THROTTLE_KEY = 'hub_activity_ts';
      const THROTTLE_MS = 5 * 60 * 1000; // 5 minutes
      const lastTs = parseInt(sessionStorage.getItem(THROTTLE_KEY) || '0');
      if (Date.now() - lastTs < THROTTLE_MS) return;

      const run = () => {
        const sb = (window as any).navGetSb?.();
        const m = (window as any).navGetMember?.();
        if (!sb || !m) return;
        sessionStorage.setItem(THROTTLE_KEY, Date.now().toString());
        sb.rpc('record_member_activity', { p_page: window.location.pathname }).then(() => {}, () => {});
      };

      if ((window as any).navGetMember?.()) { run(); }
      else { window.addEventListener('nav:member', run, { once: true }); }
    })();
  </script>

  <!-- Site Footer with Privacy Link -->
  <footer class="bg-[#200F3B] text-white/40 py-8 px-6 text-center text-[.78rem]">
    <p>{t('footer.line1', lang)}</p>
    <p class="mt-1">{t('footer.chapters', lang)}</p>
    <p class="mt-2 text-[.68rem]">{t('footer.trademarks', lang)}</p>
    <p class="mt-1">
      <a href="https://github.com/VitorMRodovalho/ai-pm-research-hub" class="text-[#05BFE0] no-underline hover:underline">GitHub</a>
      · {t('footer.gp', lang)}
      · <a href="/privacy" class="text-[#05BFE0] no-underline hover:underline">{t('footer.privacy', lang)}</a>
      · <span id="footer-version" class="text-white/25 text-[.65rem]">development</span>
    </p>
  </footer>
  <script>
    (async () => {
      let sb = (window as any).navGetSb?.();
      if (!sb) {
        await new Promise<void>(r => {
          const check = () => { sb = (window as any).navGetSb?.(); if (sb) r(); else setTimeout(check, 300); };
          setTimeout(check, 300);
          setTimeout(r, 3000);
        });
      }
      if (!sb) return;
      try {
        const { data } = await sb.rpc('get_current_release');
        if (data?.version) {
          const el = document.getElementById('footer-version');
          if (el) el.textContent = data.version;
        }
      } catch {}
    })();
  </script>

  <!-- Cookie Consent Banner (W126) -->
  <div id="consent-banner"
    class="fixed bottom-0 left-0 right-0 z-[600] bg-[var(--surface-elevated)] border-t border-[var(--border-default)] shadow-lg px-4 py-3 flex items-center justify-center gap-3 text-sm hidden">
    <span class="text-[var(--text-secondary)]">{t('consent.message', lang)}</span>
    <a href="/privacy" class="text-teal hover:underline text-xs font-semibold">{t('consent.privacyLink', lang)}</a>
    <button id="consent-accept" class="px-3 py-1.5 rounded-lg bg-teal text-white text-xs font-semibold hover:opacity-90">
      {t('consent.accept', lang)}
    </button>
  </div>
  <script is:inline>
    (function() {
      var KEY = 'cookie_consent_accepted';
      if (localStorage.getItem(KEY)) return;
      var banner = document.getElementById('consent-banner');
      if (banner) banner.classList.remove('hidden');
      var btn = document.getElementById('consent-accept');
      if (btn) btn.addEventListener('click', function() {
        localStorage.setItem(KEY, '1');
        if (banner) banner.classList.add('hidden');
      });
    })();
  </script>
</body>
</html>
