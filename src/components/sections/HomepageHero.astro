---
import { CHAPTER_CODES } from '../../data/chapters';
---

<section class="hero relative min-h-screen flex items-center justify-center overflow-hidden pt-14" id="hero">
  <div class="absolute -top-1/2 -right-[30%] w-[80vw] h-[80vw] rounded-full bg-[radial-gradient(circle,rgba(5,191,224,.08)_0%,transparent_60%)] pointer-events-none"></div>
  <div class="absolute -bottom-[20%] -left-[20%] w-[60vw] h-[60vw] rounded-full bg-[radial-gradient(circle,rgba(255,97,15,.06)_0%,transparent_50%)] pointer-events-none"></div>

  <!-- ═══ VISITOR HERO ═══ -->
  <div id="hero-visitor" class="relative z-10 text-center max-w-[900px] px-6 py-8">
    <div class="inline-block bg-orange/15 text-orange text-[.78rem] font-semibold px-5 py-1.5 rounded-full border border-orange/30 mb-6 tracking-wider uppercase">
      Ciclo 3 · 2026
    </div>

    <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-extrabold text-white leading-[1.15] mb-2">
      Núcleo de Estudos e Pesquisa em<br>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#05BFE0] to-[#B465FF]">
        Inteligência Artificial
      </span><br>
      & Gestão de Projetos
    </h1>

    <h2 class="text-[clamp(.9rem,2.5vw,1.3rem)] text-white/60 font-normal mb-8">
      IA aplicada à Gestão de Projetos — pesquisa colaborativa entre capítulos PMI do Brasil
    </h2>

    <!-- Stats counters -->
    <div class="flex flex-wrap justify-center gap-6 sm:gap-10 mb-8">
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-extrabold text-[#05BFE0]" id="stat-members">--</div>
        <div class="text-[.7rem] text-white/50 uppercase tracking-wider mt-1">pesquisadores</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-extrabold text-[#05BFE0]" id="stat-tribes">--</div>
        <div class="text-[.7rem] text-white/50 uppercase tracking-wider mt-1">tribos</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-extrabold text-[#05BFE0]" id="stat-chapters">--</div>
        <div class="text-[.7rem] text-white/50 uppercase tracking-wider mt-1">capítulos PMI</div>
      </div>
      <div class="text-center">
        <div class="text-3xl sm:text-4xl font-extrabold text-[#05BFE0]" id="stat-hours">--</div>
        <div class="text-[.7rem] text-white/50 uppercase tracking-wider mt-1">horas de impacto</div>
      </div>
    </div>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-3 mb-6">
      <a href="#nucleo" class="px-6 py-3 bg-white/10 border border-white/20 text-white rounded-xl text-[.9rem] font-semibold no-underline hover:bg-white/15 transition-all">
        Conhecer o Núcleo ↓
      </a>
      <button id="hero-auth-btn" class="px-6 py-3 bg-[#05BFE0] text-navy rounded-xl text-[.9rem] font-bold border-0 cursor-pointer hover:opacity-90 transition-all">
        Entrar / Criar conta
      </button>
    </div>

    <!-- Cycle status -->
    <div class="inline-flex items-center gap-2 text-[.82rem] text-white/60">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      Ciclo 3 em andamento
    </div>

    <div class="flex flex-wrap justify-center gap-2 mt-5">
      {CHAPTER_CODES.map((c) => (
        <span class="bg-white/8 border border-white/12 text-white/80 px-3 py-1 rounded-lg text-[.72rem] font-semibold">
          {c}
        </span>
      ))}
    </div>
  </div>

  <!-- ═══ MEMBER HERO ═══ -->
  <div id="hero-member" class="hidden relative z-10 w-full max-w-[900px] px-6 py-8">
    <h2 class="text-[clamp(1.5rem,4vw,2.5rem)] font-extrabold text-white mb-6 text-center">
      Olá, <span id="hero-name" class="text-[#05BFE0]">...</span> 👋
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-[700px] mx-auto">
      <!-- Next General Meeting -->
      <div class="bg-white/8 border border-white/10 rounded-2xl p-5">
        <div class="text-[.75rem] font-bold text-white/50 uppercase tracking-wider mb-2">📅 Próxima Geral</div>
        <div id="hero-general-date" class="text-lg font-bold text-[#05BFE0]">...</div>
        <div id="hero-general-time" class="text-sm text-white/60 mt-0.5">19:30 BRT</div>
        <a id="hero-general-link" href="#" target="_blank" rel="noopener"
          class="hidden mt-3 inline-flex items-center gap-1.5 px-4 py-2 bg-[#05BFE0] text-navy rounded-lg text-[.8rem] font-bold no-underline hover:opacity-90 transition-all">
          Entrar no Meet →
        </a>
      </div>

      <!-- Tribe Info -->
      <div class="bg-white/8 border border-white/10 rounded-2xl p-5">
        <div class="text-[.75rem] font-bold text-white/50 uppercase tracking-wider mb-2">🔬 Sua Tribo</div>
        <div id="hero-tribe-info">
          <div class="text-sm text-white/40">Carregando...</div>
        </div>
      </div>

      <!-- Attendance Mini -->
      <div class="bg-white/8 border border-white/10 rounded-2xl p-5">
        <div class="text-[.75rem] font-bold text-white/50 uppercase tracking-wider mb-2">📊 Sua Assiduidade</div>
        <div id="hero-att-info">
          <div class="text-sm text-white/40">Carregando...</div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="bg-white/8 border border-white/10 rounded-2xl p-5">
        <div class="text-sm font-bold text-[var(--text-primary)] mb-2">⚡ Quick Actions</div>
        <div class="space-y-2">
          <a href="/attendance" class="block px-3 py-2 rounded-lg bg-navy/5 text-navy text-xs font-semibold hover:bg-navy/10 no-underline">📅 Criar Evento</a>
          <a href="/attendance" class="block px-3 py-2 rounded-lg bg-navy/5 text-navy text-xs font-semibold hover:bg-navy/10 no-underline">✅ Registrar Presença</a>
          <a href="/gamification" class="block px-3 py-2 rounded-lg bg-navy/5 text-navy text-xs font-semibold hover:bg-navy/10 no-underline">🏆 Ver Ranking</a>
        </div>
      </div>
    </div>

    <!-- Dropout risk (GP only) -->
    <div id="hero-dropout-alert" class="hidden mt-4 text-center">
      <span class="inline-flex items-center gap-2 text-sm font-semibold text-amber-400 bg-amber-900/20 border border-amber-500/30 px-4 py-2 rounded-xl"></span>
    </div>

    <!-- Cycle badge -->
    <div class="text-center mt-5">
      <div class="inline-flex items-center gap-2 text-[.82rem] text-white/60">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Ciclo 3 em andamento
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 text-[.75rem] animate-bounce">
    ↓ Scroll
  </div>
</section>

<script>
  import { hasPermission } from '../../lib/permissions';
  (async () => {
    const DAY_NAMES = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
    const DAY_NAMES_FULL = ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'];

    // Wait for supabase
    function waitSb(): Promise<any> {
      return new Promise(resolve => {
        const sb = (window as any).navGetSb?.();
        if (sb) return resolve(sb);
        const interval = setInterval(() => {
          const s = (window as any).navGetSb?.();
          if (s) { clearInterval(interval); resolve(s); }
        }, 200);
      });
    }

    const sb = await waitSb();

    // ── Load homepage stats (public, no auth) ──
    try {
      const { data: stats } = await sb.rpc('get_homepage_stats');
      if (stats) {
        animateCounter('stat-members', stats.members);
        animateCounter('stat-tribes', stats.tribes);
        animateCounter('stat-chapters', stats.chapters);
        animateCounter('stat-hours', stats.impact_hours, 'h');
      }
    } catch (e) { console.warn('homepage stats:', e); }

    // ── Auth detection ──
    function onMember(member: any) {
      const visitorEl = document.getElementById('hero-visitor');
      const memberEl = document.getElementById('hero-member');
      if (!visitorEl || !memberEl) return;

      visitorEl.classList.add('hidden');
      memberEl.classList.remove('hidden');

      // Name
      const nameEl = document.getElementById('hero-name');
      if (nameEl) nameEl.textContent = (member.name || '').split(' ')[0] || member.name || 'Membro';

      // Next general meeting — from real events in DB
      const _locale = location.pathname.startsWith('/en') ? 'en-US' : location.pathname.startsWith('/es') ? 'es' : 'pt-BR';
      const dateEl = document.getElementById('hero-general-date');
      const timeEl = document.getElementById('hero-general-time');
      const linkEl = document.getElementById('hero-general-link') as HTMLAnchorElement;

      sb.from('events')
        .select('id, title, date, meeting_link, recording_url, duration_minutes')
        .eq('type', 'geral')
        .gte('date', new Date(Date.now() - 86400000).toISOString().slice(0,10))
        .order('date', { ascending: true })
        .limit(1)
        .then(({ data: evts }: any) => {
          const ev = evts?.[0];
          if (ev && dateEl) {
            const evDate = new Date(ev.date + 'T19:30:00');
            const isToday = ev.date === new Date().toISOString().slice(0,10);
            dateEl.textContent = isToday
              ? (_locale === 'en-US' ? 'Today' : _locale === 'es' ? 'Hoy' : 'Hoje') + ' 🔴'
              : evDate.toLocaleDateString(_locale, { weekday: 'long', day: '2-digit', month: 'short' });
            if (timeEl) timeEl.textContent = '19:30 BRT';
            if (ev.meeting_link && linkEl) {
              linkEl.href = ev.meeting_link;
              linkEl.classList.remove('hidden');
            }
          } else if (dateEl) {
            dateEl.textContent = _locale === 'en-US' ? 'No upcoming meetings' : _locale === 'es' ? 'Sin reuniones próximas' : 'Sem reuniões próximas';
            if (timeEl) timeEl.textContent = '';
          }
        });

      // Tribe info
      if (member.tribe_id) {
        Promise.all([
          sb.from('tribes').select('name, name_i18n, meeting_link').eq('id', member.tribe_id).single(),
          sb.from('tribe_meeting_slots').select('day_of_week, time_start, time_end')
            .eq('tribe_id', member.tribe_id).eq('is_active', true),
        ]).then(([tribeRes, slotRes]: [any, any]) => {
          const tribe = tribeRes.data;
          const slots = slotRes.data || [];
          const infoEl = document.getElementById('hero-tribe-info');
          if (!infoEl) return;

          const _sl = location.pathname.startsWith('/en') ? 'en' : location.pathname.startsWith('/es') ? 'es' : 'pt';
          const _tribeName = tribe?.name_i18n?.[_sl] || tribe?.name || '...';
          let html = `<div class="text-lg font-bold text-[#05BFE0]">T${member.tribe_id}: ${escHtml(_tribeName)}</div>`;
          if (slots.length) {
            const slotLabels = slots.map((s: any) => {
              const start = (s.time_start || '').substring(0,5).replace(/:00$/, 'h').replace(/:(\d\d)$/, 'h$1');
              const end = (s.time_end || '').substring(0,5).replace(/:00$/, 'h').replace(/:(\d\d)$/, 'h$1');
              return `${DAY_NAMES[s.day_of_week]} · ${start}–${end}`;
            }).join(' · ');
            html += `<div class="text-sm text-white/60 mt-1">${slotLabels}</div>`;
          }
          if (tribe?.meeting_link) {
            html += `<a href="${escHtml(tribe.meeting_link)}" target="_blank" rel="noopener"
              class="mt-3 inline-flex items-center gap-1.5 px-4 py-2 bg-[#05BFE0] text-navy rounded-lg text-[.8rem] font-bold no-underline hover:opacity-90 transition-all">
              Entrar no Meet →</a>`;
          }
          infoEl.innerHTML = html;
        });
      } else {
        const infoEl = document.getElementById('hero-tribe-info');
        if (infoEl) {
          infoEl.innerHTML = `<div class="text-sm text-white/50">Sem tribo atribuída</div>
            <a href="/workspace" class="mt-2 text-[.8rem] text-[#05BFE0] font-semibold no-underline hover:underline">Acesse o Workspace →</a>`;
        }
      }

      // Attendance — uses get_attendance_panel (W140 corrected calc)
      sb.rpc('get_attendance_panel').then(({ data }: any) => {
        const attEl = document.getElementById('hero-att-info');
        if (!attEl || !data) { if (attEl) attEl.innerHTML = '<div class="text-sm text-white/50">Sem dados ainda</div>'; return; }
        const myRow = data.find((r: any) => r.member_id === member.id);
        if (!myRow) { attEl.innerHTML = '<div class="text-sm text-white/50">Sem dados ainda</div>'; return; }
        const gPct = myRow.general_pct || 0;
        const tPct = myRow.tribe_pct || 0;
        const tribeEvents = myRow.tribe_events_count ?? myRow.tribe_total ?? 0;
        const tribeDisplay = tribeEvents > 0 ? `${tPct}%` : '—';
        const combined = myRow.combined_pct || 0;
        const color = combined >= 75 ? '#10B981' : combined >= 50 ? '#F59E0B' : '#EF4444';
        attEl.innerHTML = `
          <div class="text-sm text-white/60">Geral: <b class="text-white">${gPct}%</b> · Tribo: <b class="text-white">${tribeDisplay}</b></div>
          <div class="text-xl font-extrabold mt-1" style="color:${color}">Combinado: ${combined}%</div>`;
      }).catch(() => {});

      // Dropout risk (GP only)
      const isGP = hasPermission(member, 'admin.access');
      if (isGP) {
        sb.rpc('get_dropout_risk_members', { p_threshold: 3 }).then(({ data }: any) => {
          if (data?.length > 0) {
            const alertEl = document.getElementById('hero-dropout-alert');
            if (alertEl) {
              alertEl.classList.remove('hidden');
              const span = alertEl.querySelector('span');
              if (span) span.textContent = `⚠️ ${data.length} membro${data.length > 1 ? 's' : ''} em risco de dropout`;
            }
          }
        }).catch(() => {});
      }
    }

    // Check if already logged in
    const m = (window as any).navGetMember?.();
    if (m) { onMember(m); }
    window.addEventListener('nav:member', ((e: CustomEvent) => {
      if (e.detail) onMember(e.detail);
    }) as EventListener);

    // Auth button
    document.getElementById('hero-auth-btn')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-auth-modal'));
    });

    // ── Helpers ──
    function getNextWeekday(dayIndex: number): Date {
      const now = new Date();
      const today = now.getDay();
      let diff = (dayIndex - today + 7) % 7;
      // If today IS the target day and before 20:00 BRT, show today
      if (diff === 0) {
        const brtHour = new Date(now.toLocaleString('en-US', { timeZone: 'America/Sao_Paulo' })).getHours();
        if (brtHour >= 20) diff = 7;
      }
      if (diff === 0) diff = 0; // today
      const next = new Date(now);
      next.setDate(now.getDate() + diff);
      return next;
    }

    function animateCounter(id: string, target: number, suffix = '') {
      const el = document.getElementById(id);
      if (!el) return;
      const duration = 1200;
      const start = performance.now();
      function step(now: number) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
        el!.textContent = Math.round(target * eased) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }
      // Use IntersectionObserver for scroll-triggered animation
      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          requestAnimationFrame(step);
        }
      }, { threshold: 0.3 });
      observer.observe(el);
    }

    function escHtml(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }
  })();
</script>

<style>
  .hero {
    background: var(--hero-gradient);
  }
</style>
