---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;
const langPrefix = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';
---

<section class="py-16 px-6 bg-[var(--surface-section-warm)]" id="agenda">
  <div class="max-w-[900px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('schedule.label', lang)}
    </div>
    <h2 class="text-[clamp(1.5rem,3.5vw,2.2rem)] font-extrabold text-[var(--text-primary)] leading-tight mb-8">
      {t('schedule.title', lang)}
    </h2>

    <!-- Next General Meeting -->
    <div class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-2xl p-5 mb-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
          <div class="text-[.7rem] font-bold uppercase tracking-wider text-teal mb-1">{t('schedule.generalMeeting', lang)}</div>
          <div class="text-lg font-bold text-[var(--text-primary)]" id="schedule-general-date">
            {t('schedule.generalSchedule', lang)}
          </div>
        </div>
        <a id="schedule-general-link" href="#" target="_blank" rel="noopener"
          class="hidden px-5 py-2.5 bg-teal text-white rounded-xl text-[.85rem] font-bold no-underline hover:opacity-90 transition-all flex-shrink-0">
          {t('hero.joinMeet', lang)} →
        </a>
        <span id="schedule-general-login-hint" class="text-xs text-[var(--text-muted)] italic">
          {t('schedule.loginHint', lang)}
        </span>
      </div>
      <div class="mt-4 pt-4 border-t border-[var(--border-subtle)]">
        <a href={`${langPrefix}/reunioes-gerais`}
          class="inline-flex items-center gap-1.5 text-[.85rem] font-bold text-orange no-underline hover:underline">
          ⭐ {t('comp.agendaViva.homeCta', lang)} →
        </a>
      </div>
    </div>

    <!-- Tribe Meetings by Day -->
    <h3 class="text-sm font-bold text-[var(--text-secondary)] mb-3 uppercase tracking-wider">
      {t('schedule.tribeMeetings', lang)}
    </h3>
    <div id="schedule-tribe-grid" class="space-y-2">
      <div class="text-sm text-[var(--text-muted)] py-4 text-center">{t('common.loading', lang)}</div>
    </div>
  </div>
</section>

<span id="schedule-i18n-yourTribe" class="hidden">{t('schedule.yourTribe', lang)}</span>
<span id="schedule-i18n-noMeetings" class="hidden">{t('schedule.noMeetings', lang)}</span>

<script>
  (() => {
    const _locale = location.pathname.startsWith('/en') ? 'en' : location.pathname.startsWith('/es') ? 'es' : 'pt';
    const DAY_NAMES_MAP: Record<string, string[]> = {
      pt: ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'],
      en: ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'],
      es: ['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'],
    };
    const DAY_NAMES = DAY_NAMES_MAP[_locale] || DAY_NAMES_MAP.pt;
    const DAY_ORDER = [1, 2, 3, 4, 5, 6, 0];
    const i18nYourTribe = document.getElementById('schedule-i18n-yourTribe')?.textContent || 'sua tribo';
    const i18nNoMeetings = document.getElementById('schedule-i18n-noMeetings')?.textContent || 'Nenhuma reunião agendada.';

    // Data-driven general-meeting line (public RPC, anon OK): renders the actual next
    // occurrence from the events table instead of a hardcoded cadence string. The i18n
    // text stays as SSR fallback if the RPC fails. events.date is a calendar date
    // (midnight UTC) — render it as-is (timeZone UTC), never shift to BRT.
    function formatGeneralMeeting(gm: any): string | null {
      if (!gm?.date || !gm?.time_start) return null;
      const LOCALES: Record<string, string> = { pt: 'pt-BR', en: 'en-US', es: 'es' };
      const day = new Intl.DateTimeFormat(LOCALES[_locale] || 'pt-BR', {
        weekday: 'short', day: '2-digit', month: '2-digit', timeZone: 'UTC',
      }).format(new Date(`${gm.date}T12:00:00Z`));
      const start = String(gm.time_start).slice(0, 5);
      let range = start;
      const dur = Number(gm.duration_minutes);
      if (Number.isFinite(dur) && dur > 0) {
        const [h, m] = start.split(':').map(Number);
        const endMin = h * 60 + m + dur;
        const end = `${String(Math.floor(endMin / 60) % 24).padStart(2, '0')}:${String(endMin % 60).padStart(2, '0')}`;
        range = `${start}–${end}`;
      }
      return `${day} · ${range} BRT`;
    }

    // One-shot (public + deterministic data — no need to re-fetch on nav:member re-fires).
    let gmLoaded = false;
    function loadGeneralMeeting() {
      const sb = (window as any).navGetSb?.();
      if (!sb) { setTimeout(loadGeneralMeeting, 300); return; }
      if (gmLoaded) return;
      gmLoaded = true;
      sb.rpc('get_next_general_meeting').then(({ data: gm }: any) => {
        const formatted = formatGeneralMeeting(gm);
        const el = document.getElementById('schedule-general-date');
        if (formatted && el) el.textContent = formatted;
      }).catch(() => {});
    }
    loadGeneralMeeting();

    async function loadSchedule() {
      const sb = (window as any).navGetSb?.();
      if (!sb) { setTimeout(loadSchedule, 300); return; }

      try {

        const { data: slots } = await sb
          .from('tribe_meeting_slots')
          .select('tribe_id, day_of_week, time_start, time_end')
          .eq('is_active', true)
          .order('time_start');

        const { data: tribes } = await sb
          .from('tribes')
          .select('id, name, name_i18n, meeting_link')
          .eq('is_active', true);

        if (!slots || !tribes) return;

        const tribeMap = new Map<number, any>();
        tribes.forEach((t: any) => tribeMap.set(t.id, t));

        const byDay = new Map<number, any[]>();
        for (const slot of slots) {
          const tribe = tribeMap.get(slot.tribe_id);
          if (!tribe) continue;
          if (!byDay.has(slot.day_of_week)) byDay.set(slot.day_of_week, []);
          byDay.get(slot.day_of_week)!.push({ ...slot, tribe_name: tribe.name_i18n?.[_locale] || tribe.name, meeting_link: tribe.meeting_link });
        }

        const member = (window as any).navGetMember?.();
        const myTribeId = member?.tribe_id;
        const isAuth = !!member;

        const grid = document.getElementById('schedule-tribe-grid');
        if (!grid) return;

        let html = '';
        for (const day of DAY_ORDER) {
          const entries = byDay.get(day);
          if (!entries?.length) continue;

          html += `<div class="bg-[var(--surface-card)] border border-[var(--border-subtle)] rounded-xl px-4 py-3">
            <div class="text-[.72rem] font-bold text-[var(--text-muted)] uppercase tracking-wider mb-2">${DAY_NAMES[day]}</div>
            <div class="flex flex-wrap gap-x-4 gap-y-2">`;

          for (const entry of entries) {
            const isMine = myTribeId === entry.tribe_id;
            const highlight = isMine ? 'font-bold text-teal' : 'text-[var(--text-primary)]';
            const badge = isMine ? ` <span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded-full bg-teal/10 text-teal">${i18nYourTribe}</span>` : '';

            if (isAuth && entry.meeting_link) {
              html += `<a href="${escHtml(entry.meeting_link)}" target="_blank" rel="noopener"
                class="text-[.82rem] ${highlight} no-underline hover:underline">
                T${entry.tribe_id}: ${escHtml(entry.tribe_name)} (${entry.time_start})${badge}
              </a>`;
            } else {
              html += `<span class="text-[.82rem] ${highlight}">
                T${entry.tribe_id}: ${escHtml(entry.tribe_name)} (${entry.time_start})${badge}
              </span>`;
            }
          }

          html += '</div></div>';
        }

        grid.innerHTML = html || `<div class="text-sm text-[var(--text-muted)] text-center py-4">${i18nNoMeetings}</div>`;

        if (isAuth) {
          const { data: configData } = await sb
            .from('site_config').select('value').eq('key', 'general_meeting_link').single();
          if (configData?.value) {
            const link = document.getElementById('schedule-general-link') as HTMLAnchorElement;
            const hint = document.getElementById('schedule-general-login-hint');
            if (link) {
              try { link.href = JSON.parse(configData.value); } catch { link.href = String(configData.value); }
              link.classList.remove('hidden');
            }
            if (hint) hint.classList.add('hidden');
          }
        }
      } catch (e) { console.warn('schedule load:', e); }
    }

    loadSchedule();
    window.addEventListener('nav:member', () => loadSchedule());

    function escHtml(s: string): string {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }
  })();
</script>
