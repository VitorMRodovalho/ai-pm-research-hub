---
/**
 * TeamSection.astro — Sprint 2 + S-RM1 update
 * Team gallery with 6 sub-sections loaded from Supabase.
 * Uses operational_role + designations (3-axis model) for grouping.
 */

import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;

const ROLE_COLORS: Record<string, string> = {
  manager:         '#FF610F',
  deputy_manager:  '#FF610F',
  tribe_leader:    '#4F17A8',
  researcher:      '#EC4899',
  facilitator:     '#EC4899',
  communicator:    '#EC4899',
  ambassador:      '#10B981',
  curator:         '#D97706',
  sponsor:         '#BE2027',
  founder:         '#7C3AED',
  comms_team:      '#06B6D4',
  comms_leader:    '#06B6D4',
  comms_member:    '#06B6D4',
  chapter_liaison: '#0284C7',
};
---

<section class="py-16 px-6 bg-[var(--surface-section-dark)] text-white" id="team">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-[#05BFE0] mb-2">
      {t('team.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-3 text-white">
      {t('team.title', lang)}
    </h2>
    <p class="text-base text-white/60 max-w-[700px] mb-10">
      {t('team.subtitle', lang)}
    </p>

    <div id="teamGrid" class="flex flex-wrap gap-4 justify-center">
      <p class="text-white/50 text-[.85rem]">{t('team.loading', lang)}</p>
    </div>

    <!-- Role legend -->
    <div class="mt-6 flex gap-6 justify-center flex-wrap text-[.7rem] text-white/50">
      {Object.entries(ROLE_COLORS).filter(([k]) =>
        ['manager','deputy_manager','tribe_leader','researcher','ambassador','curator','sponsor','founder','comms_team','comms_leader','comms_member','chapter_liaison'].includes(k)
      ).map(([role, color]) => (
        <span class="inline-flex items-center gap-1">
          <span class="w-[9px] h-[9px] rounded-full inline-block" style={`background:${color}`}></span>
          {t(`role.${role}`, lang)}
        </span>
      ))}
    </div>
  </div>
</section>

<!-- i18n for client JS -->
<script id="team-i18n" type="application/json" set:html={JSON.stringify({
  leaders: t('team.leaders', lang),
  leadersSub: t('team.leaders.sub', lang),
  researchers: t('team.researchers', lang),
  researchersSub: t('team.researchers.sub', lang),
  ambassadors: t('team.ambassadors', lang),
  ambassadorsSub: t('team.ambassadors.sub', lang),
  curators: t('team.curators', lang),
  curatorsSub: t('team.curators.sub', lang),
  sponsors: t('team.sponsors', lang),
  sponsorsSub: t('team.sponsors.sub', lang),
  founders: t('team.founders', lang),
  foundersSub: t('team.founders.sub', lang),
  projectTeam: t('team.projectTeam', lang),
  projectTeamSub: t('team.projectTeam.sub', lang),
  projectManagement: t('team.projectManagement', lang),
  commsTeam: t('team.commsTeam', lang),
  otherChapter: t('team.otherChapter', lang),
  gpLabel: t('team.gpLabel', lang),
  deputyPmLabel: t('team.deputyPmLabel', lang),
})}></script>

<script>
  const ROLE_COLORS: Record<string, string> = {
    manager: '#FF610F', deputy_manager: '#FF610F', tribe_leader: '#4F17A8', researcher: '#EC4899',
    facilitator: '#EC4899', communicator: '#EC4899', ambassador: '#10B981',
    curator: '#D97706', sponsor: '#BE2027', founder: '#7C3AED', comms_team: '#06B6D4', comms_leader: '#06B6D4', comms_member: '#06B6D4', chapter_liaison: '#0284C7',
  };

  const HEADING_COLORS: Record<string, string> = {
    purple: '#B465FF', pink: '#F9A8D4', emerald: '#6EE7B7',
    amber: '#FCD34D', crimson: '#FCA5A5', violet: '#C4B5FD',
  };

  const CHAPTER_LOGOS: Record<string, string> = {
    'PMI-GO': '/assets/logos/pmigo.png', 'PMI-CE': '/assets/logos/pmice.jpg',
    'PMI-DF': '/assets/logos/pmidf.png', 'PMI-MG': '/assets/logos/pmimg.png',
    'PMI-RS': '/assets/logos/pmirs.png',
  };
  const CHAPTER_ORDER = ['PMI-GO','PMI-CE','PMI-DF','PMI-MG','PMI-RS'];

  // Read i18n
  const teamI18nEl = document.getElementById('team-i18n');
  const i18n = teamI18nEl ? JSON.parse(teamI18nEl.textContent || '{}') : {};

  // Read role labels from BaseLayout's role-labels-data
  function getRoleLabel(role: string): string {
    try {
      const el = document.getElementById('role-labels-data');
      if (el) {
        const labels = JSON.parse(el.textContent || '{}');
        if (labels[role]) return labels[role];
      }
    } catch {}
    return role;
  }

  interface Member {
    name: string;
    chapter: string;
    operational_role: string | null;
    designations: string[] | null;
    photo_url: string | null;
    linkedin_url: string | null;
    tribe_id: number | null;
    current_cycle_active: boolean;
  }

  // ── 3-axis helpers ──

  /** Get operational role (source of truth field) */
  function getOpRole(m: Member): string {
    return m.operational_role && m.operational_role !== 'guest' ? m.operational_role : 'none';
  }

  /** Get designations (source of truth field) */
  function getDesigs(m: Member): string[] {
    return m.designations && m.designations.length > 0 ? m.designations : [];
  }

  /** Check if member has a specific designation */
  function hasDesig(m: Member, d: string): boolean {
    return getDesigs(m).includes(d);
  }

  /** Check if member has an operational role in the given list */
  function hasOpRole(m: Member, roles: string[]): boolean {
    return roles.includes(getOpRole(m));
  }

  /** Get all role dots (operational + designations) */
  function getRoleDots(m: Member): string {
    const opRole = getOpRole(m);
    const desigs = getDesigs(m);
    const all = [...(opRole !== 'none' ? [opRole] : []), ...desigs];
    return all
      .filter(r => ROLE_COLORS[r])
      .map(r => `<span title="${getRoleLabel(r)}" style="width:8px;height:8px;border-radius:50%;background:${ROLE_COLORS[r]};display:inline-block"></span>`)
      .join('');
  }

  function memberCard(m: Member, subtitle?: string): string {
    const safeName = String(m?.name || 'Membro sem nome');
    const initials = safeName.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
    const photo = m.photo_url
      ? `<img src="${m.photo_url}" class="w-16 h-16 rounded-full object-cover border-2 border-white/10" alt="" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
        + `<div style="display:none" class="w-16 h-16 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.8rem]">${initials}</div>`
      : `<div class="w-16 h-16 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.8rem]">${initials}</div>`;
    const li = m.linkedin_url
      ? `<a href="${m.linkedin_url}" target="_blank" class="text-teal text-[.65rem] no-underline">🔗</a>`
      : '';
    const dots = getRoleDots(m);
    const sub = subtitle
      ? `<div class="text-[.55rem] font-bold uppercase tracking-wider mt-0.5" style="color:#FF610F">${subtitle}</div>`
      : `<div class="text-[.6rem] text-[var(--text-muted)]">${m.chapter || ''}</div>`;
    return `<div class="text-center w-[90px]">
      ${photo}
      <div class="text-[.7rem] font-semibold mt-1.5 leading-tight">${safeName.split(' ').slice(0, 2).join(' ')} ${li}</div>
      ${sub}
      <div class="flex justify-center gap-[3px] mt-1">${dots}</div>
    </div>`;
  }

  function teamSection(id: string, label: string, sublabel: string, headingColor: string, members: Member[]): string {
    if (!members.length) return '';
    return `<div id="${id}" class="mt-10 w-full">
      <div class="flex items-baseline gap-2.5 mb-3">
        <h3 class="text-[1.05rem] font-extrabold" style="color:${headingColor}">${label}</h3>
        <span class="text-[.75rem] text-white/50">${sublabel}</span>
      </div>
      <div class="flex flex-wrap gap-4 justify-center">
        ${members.map(m => memberCard(m)).join('')}
      </div>
    </div>`;
  }

  function sponsorsSection(sponsors: Member[]): string {
    if (!sponsors.length) return '';
    const byChapter: Record<string, Member[]> = {};
    sponsors.forEach(m => {
      const ch = m.chapter || (i18n.otherChapter || 'Outros');
      if (!byChapter[ch]) byChapter[ch] = [];
      byChapter[ch].push(m);
    });
    const sorted = [...CHAPTER_ORDER.filter(c => byChapter[c]), ...Object.keys(byChapter).filter(c => !CHAPTER_ORDER.includes(c))];

    const inner = sorted.map(ch => {
      const logo = CHAPTER_LOGOS[ch];
      const logoEl = logo
        ? `<img src="${logo}" class="h-9 max-w-[120px] object-contain mb-2" alt="${ch}" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
           <div style="display:none" class="text-[.85rem] font-extrabold mb-2" style="color:${HEADING_COLORS.crimson}">${ch}</div>`
        : `<div class="text-[.8rem] font-extrabold mb-2" style="color:${HEADING_COLORS.crimson}">${ch}</div>`;
      return `<div class="bg-white/5 border border-white/10 rounded-2xl px-5 py-4 min-w-[160px]">
        <div class="text-center mb-3">${logoEl}</div>
        <div class="flex flex-wrap gap-3 justify-center">${byChapter[ch].map(m => memberCard(m)).join('')}</div>
      </div>`;
    }).join('');

    return `<div id="team-sponsors" class="mt-10 w-full">
      <div class="flex items-baseline gap-2.5 mb-3">
        <h3 class="text-[1.05rem] font-extrabold" style="color:${HEADING_COLORS.crimson}">${i18n.sponsors}</h3>
        <span class="text-[.75rem] text-white/50">${i18n.sponsorsSub}</span>
      </div>
      <div class="flex flex-wrap gap-4">${inner}</div>
    </div>`;
  }

  function projectTeamSection(gp: Member[], commsTeam: Member[]): string {
    if (!gp.length && !commsTeam.length) return '';
    let inner = '';

    // GP sub-section — original GP (founder + manager since pilot) first, then Co-GP
    if (gp.length) {
      const sorted = [...gp].sort((a, b) => {
        // manager (GP) before deputy_manager/co_gp (Co-GP)
        const aIsGP = getOpRole(a) === 'manager' ? 0 : 1;
        const bIsGP = getOpRole(b) === 'manager' ? 0 : 1;
        return aIsGP - bIsGP || a.name.localeCompare(b.name);
      });
      let gpIdx = 0;
      const gpCards = sorted.map(m => {
        const isMainGP = getOpRole(m) === 'manager';
        const label = isMainGP ? (i18n.gpLabel || 'GP') + ' · ' + (m.chapter || '') : (i18n.deputyPmLabel || 'Deputy PM') + ' · ' + (m.chapter || '');
        gpIdx++;
        return memberCard(m, label);
      }).join('');
      inner += `<div class="mb-4">
        <div class="text-[.7rem] font-bold text-white/40 uppercase tracking-wider mb-2">${i18n.projectManagement}</div>
        <div class="flex flex-wrap gap-4 justify-center">${gpCards}</div>
      </div>`;
    }

    // Comms team sub-section
    if (commsTeam.length) {
      inner += `<div>
        <div class="text-[.7rem] font-bold text-white/40 uppercase tracking-wider mb-2">${i18n.commsTeam}</div>
        <div class="flex flex-wrap gap-4 justify-center">${commsTeam.map(m => memberCard(m)).join('')}</div>
      </div>`;
    }

    return `<div id="team-project" class="mt-10 w-full">
      <div class="flex items-baseline gap-2.5 mb-3">
        <h3 class="text-[1.05rem] font-extrabold" style="color:${HEADING_COLORS.purple}">${i18n.projectTeam}</h3>
        <span class="text-[.75rem] text-white/50">${i18n.projectTeamSub}</span>
      </div>
      <div class="bg-white/5 border border-white/10 rounded-2xl px-5 py-4">${inner}</div>
    </div>`;
  }

  function renderTeam(allMembers: Member[]) {
    const el = document.getElementById('teamGrid');
    if (!el || !allMembers.length) return;

    // ── Grouping using 3-axis model ──

    // GP: operational_role = manager/deputy_manager OR designation co_gp, active
    const gp = allMembers.filter(m =>
      m.current_cycle_active &&
      (hasOpRole(m, ['manager', 'deputy_manager']) || hasDesig(m, 'co_gp'))
    );

    // Comms Team: designation includes comms_leader, comms_member, or legacy comms_team
    const commsTeam = allMembers.filter(m =>
      m.current_cycle_active &&
      (hasDesig(m, 'comms_leader') || hasDesig(m, 'comms_member') || hasDesig(m, 'comms_team'))
    );

    // Tribe Leaders: operational_role = tribe_leader OR designation tribe_leader, active
    const tribeLeaders = allMembers.filter(m =>
      m.current_cycle_active &&
      (hasOpRole(m, ['tribe_leader']) || hasDesig(m, 'tribe_leader'))
    );

    // Researchers: operational_role = researcher/facilitator/communicator, active
    const researchers = allMembers.filter(m =>
      m.current_cycle_active &&
      hasOpRole(m, ['researcher', 'facilitator', 'communicator'])
    );

    // Ambassadors: designation includes ambassador (ALL — no duplicate filtering)
    const ambassadors = allMembers.filter(m => hasDesig(m, 'ambassador'));

    // Curators: designation includes curator
    const curators = allMembers.filter(m => hasDesig(m, 'curator'));

    // Sponsors + Chapter Liaisons: grouped together in chapter cards
    const sponsors = allMembers.filter(m => hasDesig(m, 'sponsor') || hasDesig(m, 'chapter_liaison'));

    // Founders: designation includes founder
    const founders = allMembers.filter(m => hasDesig(m, 'founder'));

    el.innerHTML =
      projectTeamSection(gp, commsTeam)
      + teamSection('team-leaders', i18n.leaders, i18n.leadersSub, HEADING_COLORS.purple, tribeLeaders)
      + teamSection('team-researchers', i18n.researchers, i18n.researchersSub, HEADING_COLORS.pink, researchers)
      + teamSection('team-ambassadors', i18n.ambassadors, i18n.ambassadorsSub, HEADING_COLORS.emerald, ambassadors)
      + teamSection('team-curators', i18n.curators, i18n.curatorsSub, HEADING_COLORS.amber, curators)
      + sponsorsSection(sponsors)
      + teamSection('team-founders', i18n.founders, i18n.foundersSub, HEADING_COLORS.violet, founders);
  }

  // ── Boot ──
  async function bootTeam() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(bootTeam, 200); return; }
    const { data } = await sb.from('public_members')
      .select('name, chapter, operational_role, designations, photo_url, linkedin_url, tribe_id, current_cycle_active')
      .neq('operational_role', 'guest')
      .order('name');
    if (data) renderTeam(data);
  }

  bootTeam();
</script>
