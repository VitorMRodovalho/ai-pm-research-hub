---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; deadline?: string | null; }
const { lang = 'pt-BR', deadline = null } = Astro.props;

function formatPlaylistDeadline(iso: string, currentLang: Lang): string | null {
  try {
    const date = new Date(iso);
    if (Number.isNaN(date.getTime())) return null;
    const formatted = new Intl.DateTimeFormat(currentLang, {
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit',
      hour12: currentLang !== 'pt-BR',
      timeZone: 'America/Sao_Paulo',
    }).format(date);
    return `${formatted} BRT`;
  } catch {
    return null;
  }
}

const playlistDeadline = typeof deadline === 'string' ? formatPlaylistDeadline(deadline, lang) : null;
const playlistDescription = playlistDeadline
  ? `${t('resources.playlist.descPrefix', lang)} ${playlistDeadline}.`
  : t('resources.playlist.desc', lang);

const resources = [
  {
    icon: '▶️',
    iconBg: 'rgba(213,52,11,.1)',
    title: t('resources.playlist.title', lang),
    text: playlistDescription,
    url: 'https://youtube.com/playlist?list=PLQJVKrw1fcrx3fD2ug1hnps6TklcMT1dc',
    linkText: t('resources.playlist.linkText', lang),
  },
  {
    icon: '📘',
    iconBg: 'rgba(0,121,158,.1)',
    title: t('resources.manual.title', lang),
    text: t('resources.manual.text', lang),
    url: 'https://www.canva.com/design/DAG1Nc3jhC4/gWGhQCJyv7axeCbKozD1gg/view',
    linkText: t('resources.manual.linkText', lang),
  },
  {
    icon: '🎓',
    iconBg: 'rgba(79,23,168,.1)',
    title: t('resources.courses.title', lang),
    text: t('resources.courses.text', lang),
    url: 'https://www.pmi.org/learning/ai-in-project-management',
    linkText: t('resources.courses.linkText', lang),
  },
  {
    icon: '💻',
    iconBg: 'rgba(112,173,71,.1)',
    title: t('resources.github.title', lang),
    text: t('resources.github.text', lang),
    url: 'https://github.com/VitorMRodovalho/ai-pm-research-hub',
    linkText: t('resources.github.linkText', lang),
  },
  {
    icon: '📧',
    iconBg: 'rgba(255,97,15,.1)',
    title: t('resources.email.title', lang),
    text: t('resources.email.text', lang),
    url: 'mailto:nucleoiagp@gmail.com',
    linkText: t('resources.email.linkText', lang),
  },
  {
    icon: '✅',
    iconBg: 'rgba(0,121,158,.1)',
    title: t('resources.portal.title', lang),
    text: t('resources.portal.text', lang),
    url: 'https://volunteer.pmi.org',
    linkText: t('resources.portal.linkText', lang),
  },
];

const iconMap: Record<string, { icon: string; bg: string }> = {
  'Curso':      { icon: '🎓', bg: 'rgba(79,23,168,.1)' },
  'Referência': { icon: '📘', bg: 'rgba(0,121,158,.1)' },
  'Webinar':    { icon: '▶️', bg: 'rgba(213,52,11,.1)' },
  'Outro':      { icon: '📎', bg: 'rgba(112,173,71,.1)' },
};
---

<section class="py-16 px-6 bg-[var(--surface-section-cool)]" id="resources">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('resources.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-10">
      {t('resources.title', lang)}
    </h2>

    <div id="resources-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {resources.map((r) => (
        <div class="bg-[var(--surface-card)] rounded-2xl p-5 border border-[var(--border-subtle)] flex items-start gap-3">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[1.3rem] flex-shrink-0"
               style={`background: ${r.iconBg}`}>
            {r.icon}
          </div>
          <div>
            <h4 class="text-[.9rem] font-bold mb-0.5">{r.title}</h4>
            <p class="text-[.78rem] text-[var(--text-secondary)]">{r.text}</p>
            <a href={r.url} target="_blank" rel="noopener"
               class="text-teal text-[.78rem] font-semibold no-underline hover:underline">
              {r.linkText}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ iconMap, linkText: t('resources.linkText', lang), noResources: t('resources.noResources', lang) }}>
  (async () => {
    const grid = document.getElementById('resources-grid');
    if (!grid) return;

    try {
      const sb = window.navGetSb?.();
      if (!sb) return;

      const { data, error } = await sb
        .from('hub_resources')
        .select('id, asset_type, title, description, url')
        .eq('is_active', true)
        .order('created_at', { ascending: true });

      if (error || !data || data.length === 0) return;

      const defaultIcon = { icon: '📎', bg: 'rgba(112,173,71,.1)' };

      const html = data.map((r) => {
        const meta = iconMap[r.asset_type] || defaultIcon;
        const desc = r.description
          ? (r.description.length > 80 ? r.description.slice(0, 77) + '…' : r.description)
          : '';
        const href = r.url || '#';

        return `<div class="bg-[var(--surface-card)] rounded-2xl p-5 border border-[var(--border-subtle)] flex items-start gap-3">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[1.3rem] flex-shrink-0"
               style="background:${meta.bg}">
            ${meta.icon}
          </div>
          <div>
            <h4 class="text-[.9rem] font-bold mb-0.5">${r.title}</h4>
            <p class="text-[.78rem] text-[var(--text-secondary)]">${desc}</p>
            ${href !== '#' ? `<a href="${href}" target="_blank" rel="noopener"
               class="text-teal text-[.78rem] font-semibold no-underline hover:underline">
              ${linkText}
            </a>` : ''}
          </div>
        </div>`;
      }).join('');

      grid.innerHTML = html;
    } catch (_) {
      // keep static fallback visible
    }
  })();
</script>
