---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;

// R5 (Ciclo 4): seção demovida para a ZONA DE MEMBRO no fim da home.
// Links públicos (playlist/biblioteca/cursos/contato) migraram para o rodapé (BaseLayout)
// e a biblioteca curada (hub_resources, 231+ itens) vive em /library.
// Aqui ficam apenas os recursos OPERACIONAIS de membro/voluntário.
const resources = [
  {
    icon: '📘',
    iconBg: 'rgba(0,121,158,.1)',
    title: t('resources.manual.title', lang),
    text: t('resources.manual.text', lang),
    url: 'https://www.canva.com/design/DAG1Nc3jhC4/gWGhQCJyv7axeCbKozD1gg/view',
    linkText: t('resources.manual.linkText', lang),
  },
  {
    icon: '💻',
    iconBg: 'rgba(112,173,71,.1)',
    title: t('resources.github.title', lang),
    text: t('resources.github.text', lang),
    url: 'https://github.com/VitorMRodovalho/ai-pm-research-hub',
    linkText: t('resources.github.linkText', lang),
  },
  {
    icon: '✅',
    iconBg: 'rgba(0,121,158,.1)',
    title: t('resources.portal.title', lang),
    text: t('resources.portal.text', lang),
    url: 'https://volunteer.pmi.org',
    linkText: t('resources.portal.linkText', lang),
  },
  {
    icon: '🔬',
    iconBg: 'rgba(79,23,168,.1)',
    title: t('resources.volunteerResearcher.title', lang),
    text: t('resources.volunteerResearcher.text', lang),
    url: 'https://volunteer.pmi.org/opportunities/64967',
    linkText: t('resources.volunteerResearcher.linkText', lang),
  },
  {
    icon: '🧭',
    iconBg: 'rgba(255,97,15,.1)',
    title: t('resources.volunteerLeader.title', lang),
    text: t('resources.volunteerLeader.text', lang),
    url: 'https://volunteer.pmi.org/opportunities/64966',
    linkText: t('resources.volunteerLeader.linkText', lang),
  },
];
---

<section class="py-16 px-6 bg-[var(--surface-section-cool)]" id="resources">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('resources.memberLabel', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-10">
      {t('resources.memberTitle', lang)}
    </h2>

    <div id="resources-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {resources.map((r) => (
        <div class="bg-[var(--surface-card)] rounded-2xl p-5 border border-[var(--border-subtle)] flex items-start gap-3">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[1.3rem] flex-shrink-0"
               style={`background: ${r.iconBg}`}>
            {r.icon}
          </div>
          <div>
            <h4 class="text-[.9rem] font-bold mb-0.5">{r.title}</h4>
            <p class="text-[.78rem] text-[var(--text-secondary)]">{r.text}</p>
            <a href={r.url} target="_blank" rel="noopener"
               class="text-teal text-[.78rem] font-semibold no-underline hover:underline">
              {r.linkText}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
