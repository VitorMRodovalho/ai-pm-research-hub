---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; deadline?: string | null; }
const { lang = 'pt-BR', deadline = null } = Astro.props;

function formatAgendaDeadline(iso: string, currentLang: Lang): string | null {
  try {
    const date = new Date(iso);
    if (Number.isNaN(date.getTime())) return null;
    const formatted = new Intl.DateTimeFormat(currentLang, {
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit',
      hour12: currentLang !== 'pt-BR',
      timeZone: 'America/Sao_Paulo',
    }).format(date);
    return `${formatted} BRT`;
  } catch {
    return null;
  }
}

const agendaDeadline = typeof deadline === 'string' ? formatAgendaDeadline(deadline, lang) : null;
const agendaItem3Desc = agendaDeadline
  ? `${t('agenda.item3.descPrefix', lang)} ${agendaDeadline}.`
  : t('agenda.item3.desc', lang);

const AGENDA = [
  { time: '00-15', unit: t('agenda.unit', lang), title: t('agenda.item1.title', lang), desc: t('agenda.item1.desc', lang) },
  { time: '15-30', unit: t('agenda.unit', lang), title: t('agenda.item2.title', lang), desc: t('agenda.item2.desc', lang) },
  { time: '30-45', unit: t('agenda.unit', lang), title: t('agenda.item3.title', lang), desc: agendaItem3Desc },
  { time: '45-60', unit: t('agenda.unit', lang), title: t('agenda.item4.title', lang), desc: t('agenda.item4.desc', lang) },
  { time: '60-75', unit: t('agenda.unit', lang), title: t('agenda.item5.title', lang), desc: t('agenda.item5.desc', lang) },
  { time: '75-90', unit: t('agenda.unit', lang), title: t('agenda.item6.title', lang), desc: t('agenda.item6.desc', lang) },
];
---

<section class="py-16 px-6 bg-[#F7F4EF]" id="agenda">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('agenda.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-3">
      {t('agenda.title', lang)}
    </h2>
    <p class="text-base text-[var(--text-secondary)] max-w-[700px] mb-10">
      {t('agenda.subtitle', lang)}
    </p>

    <div class="grid gap-3">
      {AGENDA.map((item) => (
        <div class="grid grid-cols-[75px_1fr] gap-5 p-5 bg-[var(--surface-card)] rounded-2xl border border-black/5
                    hover:-translate-y-px hover:shadow-md transition-all duration-200">
          <div class="text-[.82rem] font-bold text-teal bg-teal/8 p-2 rounded-xl text-center
                      flex flex-col items-center justify-center">
            {item.time}
            <small class="text-[.6rem] text-[var(--text-secondary)] font-medium">{item.unit}</small>
          </div>
          <div>
            <div class="font-bold text-base mb-0.5">{item.title}</div>
            <div class="text-[.85rem] text-[var(--text-secondary)]">{item.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
