---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;

const AGENDA = [
  { time: '00-15', unit: 'min', title: t('agenda.item1.title', lang), desc: t('agenda.item1.desc', lang) },
  { time: '15-30', unit: 'min', title: t('agenda.item2.title', lang), desc: t('agenda.item2.desc', lang) },
  { time: '30-45', unit: 'min', title: t('agenda.item3.title', lang), desc: t('agenda.item3.desc', lang) },
  { time: '45-60', unit: 'min', title: t('agenda.item4.title', lang), desc: t('agenda.item4.desc', lang) },
  { time: '60-75', unit: 'min', title: t('agenda.item5.title', lang), desc: t('agenda.item5.desc', lang) },
  { time: '75-90', unit: 'min', title: t('agenda.item6.title', lang), desc: t('agenda.item6.desc', lang) },
];
---

<section class="py-16 px-6 bg-[#F7F4EF]" id="agenda">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('agenda.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-3">
      {t('agenda.title', lang)}
    </h2>
    <p class="text-base text-slate-500 max-w-[700px] mb-10">
      {t('agenda.subtitle', lang)}
    </p>

    <div class="grid gap-3">
      {AGENDA.map((item) => (
        <div class="grid grid-cols-[75px_1fr] gap-5 p-5 bg-white rounded-2xl border border-black/5
                    hover:-translate-y-px hover:shadow-md transition-all duration-200">
          <div class="text-[.82rem] font-bold text-teal bg-teal/8 p-2 rounded-xl text-center
                      flex flex-col items-center justify-center">
            {item.time}
            <small class="text-[.6rem] text-slate-500 font-medium">{item.unit}</small>
          </div>
          <div>
            <div class="font-bold text-base mb-0.5">{item.title}</div>
            <div class="text-[.85rem] text-slate-500" id={item.time === '30-45' ? 'agenda-item3-desc' : undefined}>{item.desc}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ lang }}>
  async function loadAgendaScheduleHint() {
    const sb = window.navGetSb?.();
    if (!sb) { setTimeout(loadAgendaScheduleHint, 300); return; }

    const el = document.getElementById('agenda-item3-desc');
    if (!el) return;

    const { data: schedule } = await sb.from('home_schedule')
      .select('selection_deadline_at')
      .eq('id', 1)
      .maybeSingle();

    if (!schedule?.selection_deadline_at) return;

    const locale = lang === 'pt-BR' ? 'pt-BR' : lang === 'es-LATAM' ? 'es-ES' : 'en-US';
    const deadline = new Date(schedule.selection_deadline_at);
    const datePart = deadline.toLocaleDateString(locale, {
      weekday: 'short',
      day: '2-digit',
      month: 'short',
      timeZone: 'America/Sao_Paulo',
    });
    const timePart = deadline.toLocaleTimeString(locale, {
      hour: '2-digit',
      minute: '2-digit',
      hour12: lang === 'en-US',
      timeZone: 'America/Sao_Paulo',
    });

    if (lang === 'pt-BR') {
      el.textContent = `8 vídeos. Escolha sua tribo até ${datePart} ${timePart} BRT.`;
      return;
    }
    if (lang === 'es-LATAM') {
      el.textContent = `8 videos. Elige tu línea hasta ${datePart} ${timePart} BRT.`;
      return;
    }
    el.textContent = `8 videos. Choose your stream by ${datePart} ${timePart} BRT.`;
  }

  loadAgendaScheduleHint();
</script>
