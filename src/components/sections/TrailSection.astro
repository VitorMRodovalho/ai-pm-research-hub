---
/**
 * TrailSection.astro — Sprint 2
 * PMI AI certification trail with course list + member ranking from Supabase.
 */
import { coreCourses, extraCourses, TOTAL_COURSES } from '../../data/trail';
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;

let core = [] as ReturnType<typeof coreCourses>;
let extra = [] as ReturnType<typeof extraCourses>;
try {
  const coreResolved = coreCourses();
  const extraResolved = extraCourses();
  core = Array.isArray(coreResolved) ? coreResolved : [];
  extra = Array.isArray(extraResolved) ? extraResolved : [];
} catch {
  core = [];
  extra = [];
}
---

<section class="py-16 px-6" id="trail">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('trail.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-3">
      {t('trail.title', lang)}
    </h2>
    <p class="text-base text-slate-500 max-w-[700px] mb-10">
      {t('trail.subtitle', lang)}
    </p>

    <!-- Course lists -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <!-- Core -->
      <div class="bg-[#F7F4EF] rounded-2xl p-6 border-l-4 border-teal">
        <div class="text-[.7rem] font-bold text-teal uppercase tracking-wider mb-4">
          {t('trail.core', lang)}
        </div>
        {core.map((c, i) => (
          <a href={c.url} target="_blank" rel="noopener"
             class="flex items-center gap-3 py-2 border-b border-black/5 no-underline text-slate-800 hover:text-teal transition-colors">
            <span class="w-[22px] h-[22px] rounded-md bg-teal text-white flex items-center justify-center
                         text-[.65rem] font-bold flex-shrink-0">
              {i + 1}
            </span>
            <span class="text-[.82rem] font-medium">{c.name}</span>
          </a>
        ))}
        {!core.length && (
          <p class="text-[.82rem] text-slate-500">{t('trail.coreUnavailable', lang)}</p>
        )}
      </div>

      <!-- Extra -->
      <div class="bg-[#F7F4EF] rounded-2xl p-6 border-l-4 border-purple">
        <div class="text-[.7rem] font-bold text-purple uppercase tracking-wider mb-4">
          {t('trail.extra', lang)}
        </div>
        {extra.map((c, i) => (
          <a href={c.url} target="_blank" rel="noopener"
             class="flex items-center gap-3 py-2 border-b border-black/5 no-underline text-slate-800 hover:text-purple transition-colors">
            <span class="w-[22px] h-[22px] rounded-md bg-purple text-white flex items-center justify-center
                         text-[.65rem] font-bold flex-shrink-0">
              {i + 5}
            </span>
            <span class="text-[.82rem] font-medium">{c.name}</span>
          </a>
        ))}
        {!extra.length && (
          <p class="text-[.82rem] text-slate-500">{t('trail.extraUnavailable', lang)}</p>
        )}
      </div>
    </div>

    <!-- Ranking panel -->
    <div class="bg-navy rounded-3xl p-8 text-white">
      <div class="flex justify-between items-center flex-wrap gap-4 mb-6">
        <div>
          <div class="text-[1.1rem] font-extrabold">{t('trail.ranking.title', lang)}</div>
          <div class="text-[.82rem] text-white/50">{t('trail.ranking.sub', lang)}</div>
        </div>
        <div id="trailKPI" class="text-center">
          <div class="text-[2rem] font-extrabold text-[#05BFE0]">--</div>
          <div class="text-[.7rem] text-white/50">{t('trail.ranking.avg', lang)}</div>
        </div>
      </div>

      <div id="rankingContainer"
           class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))] gap-3">
        <div class="text-white/40 text-[.85rem]">{t('common.loading', lang)}</div>
      </div>
    </div>
  </div>
</section>

<span id="trail-i18n-avg" class="hidden">{t('trail.ranking.avg', lang)}</span>
<span id="trail-i18n-completed" class="hidden">{t('trail.completed', lang)}</span>
<span id="trail-i18n-inprogress" class="hidden">{t('trail.inProgress', lang)}</span>

<script>
  const TOTAL = 8;
  const trailRankingAvg = document.getElementById('trail-i18n-avg')?.textContent || 'Overall average';
  const trailCompleted = document.getElementById('trail-i18n-completed')?.textContent || 'completed';
  const trailInProgress = document.getElementById('trail-i18n-inprogress')?.textContent || 'in progress';

  async function bootTrail() {
    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(bootTrail, 200); return; }

    const [progressRes, coursesRes, membersRes] = await Promise.all([
      sb.from('course_progress').select('member_id, course_id, status'),
      sb.from('courses').select('id, code'),
      sb.from('public_members').select('id, name, photo_url').eq('current_cycle_active', true).order('name'),
    ]);

    const progress = progressRes.data;
    const courses = coursesRes.data;
    const members = membersRes.data;
    if (!progress || !courses || !members) return;

    // Per-member stats
    const mp: Record<string, { completed: number; in_progress: number }> = {};
    progress.forEach((p: any) => {
      if (!mp[p.member_id]) mp[p.member_id] = { completed: 0, in_progress: 0 };
      if (p.status === 'completed') mp[p.member_id].completed++;
      else if (p.status === 'in_progress') mp[p.member_id].in_progress++;
    });

    const ranked = members.map((m: any) => ({
      name: m.name,
      photo: m.photo_url,
      completed: mp[m.id]?.completed || 0,
      inProgress: mp[m.id]?.in_progress || 0,
      pct: Math.round((mp[m.id]?.completed || 0) / TOTAL * 100),
    })).sort((a: any, b: any) => b.pct - a.pct || b.inProgress - a.inProgress);

    // KPI
    const avg = ranked.length > 0
      ? Math.round(ranked.reduce((s: number, r: any) => s + r.pct, 0) / ranked.length)
      : 0;
    const kpiColor = avg >= 70 ? '#70AD47' : avg >= 30 ? '#FF610F' : '#D5340B';
    const kpiEl = document.getElementById('trailKPI');
    if (kpiEl) {
      kpiEl.innerHTML = `<div style="font-size:2rem;font-weight:800;color:${kpiColor}">${avg}%</div>
        <div style="font-size:.7rem;color:rgba(255,255,255,.5)">${trailRankingAvg}</div>`;
    }

    // Ranking cards
    const container = document.getElementById('rankingContainer');
    if (!container) return;
    container.innerHTML = ranked.map((r: any) => {
      const safeName = String(r?.name || 'Membro sem nome');
      const initials = safeName.split(' ').map((w: string) => w[0]).join('').substring(0, 2).toUpperCase();
      const photoEl = r.photo
        ? `<img src="${r.photo}" class="w-8 h-8 rounded-full object-cover" alt="">`
        : `<div class="w-8 h-8 rounded-full bg-teal flex items-center justify-center text-white text-[.65rem] font-bold">${initials}</div>`;
      const barColor = r.pct >= 100 ? '#70AD47' : r.pct >= 50 ? '#05BFE0' : r.pct > 0 ? '#FF610F' : 'rgba(255,255,255,.1)';
      const badge = r.pct >= 100 ? ' ⭐' : r.pct >= 50 ? ' 🔥' : '';
      return `<div class="bg-white/[.06] rounded-xl p-3 flex items-center gap-2.5">
        ${photoEl}
        <div class="flex-1 min-w-0">
          <div class="text-[.78rem] font-semibold truncate">${safeName.split(' ').slice(0, 2).join(' ')}${badge}</div>
          <div class="bg-white/10 rounded h-1.5 mt-1 overflow-hidden">
            <div class="h-full rounded transition-all duration-500" style="width:${r.pct}%;background:${barColor}"></div>
          </div>
          <div class="text-[.6rem] text-white/40 mt-0.5">${r.completed}/${TOTAL} ${trailCompleted}${r.inProgress > 0 ? ` · ${r.inProgress} ${trailInProgress}` : ''}</div>
        </div>
        <div class="text-base font-extrabold" style="color:${barColor}">${r.pct}%</div>
      </div>`;
    }).join('');
  }

  bootTrail();
</script>
