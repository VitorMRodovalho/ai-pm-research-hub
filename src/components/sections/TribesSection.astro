---
/**
 * TribesSection.astro — Sprint 2
 * Gamified tribe selection with realtime slot tracking.
 * Dynamic data (counts, leader photos, user selection) from Supabase via window.navGetSb().
 * Static structure (tribe names, descriptions) from data/tribes.ts.
 */
import { MAX_SLOTS, MIN_SLOTS } from '../../data/tribes';
import { buildTribesViewModel } from '../../data/tribesViewModel';
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; deadline?: string | null; }
const { lang = 'pt-BR', deadline: deadlineProp } = Astro.props;

const QUAD_COLORS: Record<string, string> = {
  q1: '#00799E',
  q2: '#FF610F',
  q3: '#4F17A8',
  q4: '#10B981',
};

const viewModel = buildTribesViewModel(lang);
const safeQuadrants = viewModel.quadrants;
const safeTribes = viewModel.tribes;
const viewWarnings = viewModel.warnings;
const parsedDeadline = typeof deadlineProp === 'string' && !Number.isNaN(new Date(deadlineProp).getTime())
  ? deadlineProp
  : null;
const TRIBE_SELECTION_DEADLINE_ISO = parsedDeadline;
const selectionState = !parsedDeadline
  ? 'pending'
  : new Date(parsedDeadline) > new Date()
    ? 'open'
    : 'closed';

function formatDeadline(iso: string, prefix: string, currentLang: Lang): string | null {
  try {
    const date = new Date(iso);
    if (Number.isNaN(date.getTime())) return null;
    const formatted = new Intl.DateTimeFormat(currentLang, {
      day: '2-digit',
      month: 'short',
      hour: '2-digit',
      minute: '2-digit',
      hour12: currentLang !== 'pt-BR',
      timeZone: 'America/Sao_Paulo',
    }).format(date);
    return `${prefix} ${formatted} BRT`;
  } catch {
    return null;
  }
}
const deadlineFormatted = TRIBE_SELECTION_DEADLINE_ISO
  ? formatDeadline(TRIBE_SELECTION_DEADLINE_ISO, t('tribes.deadlinePrefix', lang), lang)
  : null;
const selectionStateLabel = selectionState === 'open'
  ? t('tribes.open', lang)
  : selectionState === 'closed'
    ? t('tribes.closed', lang)
    : t('tribes.pending', lang);
const selectionStateClasses = selectionState === 'open'
  ? 'bg-green-100 text-green-700 animate-pulse'
  : selectionState === 'closed'
    ? 'bg-[var(--surface-section-cool)] text-[var(--text-primary)]'
    : 'bg-amber-100 text-amber-700';
const selectionNotice = selectionState === 'open'
  ? t('tribes.deadlineNotice', lang)
  : selectionState === 'closed'
    ? t('tribes.deadlineNoticeClosed', lang)
    : t('tribes.deadlineNoticePending', lang);
// i18n for client-side toast/UI (inject via define:vars; no import in script per .cursorrules)
const TRIBES_MSG = {
  onlyParticipants: t('tribes.onlyParticipants', lang),
  leadersAssigned: t('tribes.leadersAssigned', lang),
  selectionClosed: t('tribes.selectionClosed', lang),
  selectionRemoved: t('tribes.selectionRemoved', lang),
  tribeFull: t('tribes.tribeFull', lang),
  errorRemove: t('tribes.errorRemove', lang),
  errorSelect: t('tribes.errorSelect', lang),
  selectedSuccess: t('tribes.selectedSuccess', lang),
  selectionUnavailable: t('tribes.selectionUnavailable', lang),
  selectBtn: t('tribes.select', lang),
  selected: t('tribes.selected', lang),
  fullCaps: t('tribes.fullCaps', lang),
  full: t('tribes.full', lang),
  loading: t('tribes.loading', lang),
  trailsUnavailable: t('tribes.trailsUnavailable', lang),
};
// SSR: slot counts come from Supabase client-side; use 0 until hydrated
const initialCounts: Record<number, number> = {};
const TRIBE_IDS = safeTribes.map(tr => tr.id);
---

<section class="py-16 px-6 bg-[var(--surface-section-warm)]" id="tribes">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('tribes.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-3">
      {t('tribes.title', lang)}
    </h2>
    <div class="text-base text-[var(--text-secondary)] max-w-[700px] mb-2">
      <span id="tribes-selection-state" class:list={['inline-block px-2.5 py-0.5 rounded-md text-[.68rem] font-bold', selectionStateClasses]}>
        {selectionStateLabel}
      </span>
      <span id="tribes-deadline-badge" class="inline-block px-2.5 py-0.5 rounded-md text-[.68rem] font-bold bg-red-50 text-red-600 ml-1">
        {deadlineFormatted || t('tribes.deadlinePending', lang)}
      </span>
      <span id="tribes-selection-notice" class="block mt-2 text-[.75rem] font-semibold text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-2.5 py-2">
        {selectionNotice}
      </span>
      <br>
      {t('tribes.slots', lang)}
      <span id="loginPrompt" class="block mt-2 font-semibold text-orange">
        {t('tribes.loginPrompt', lang)}
      </span>
    </div>
    {viewWarnings.length > 0 && (
      <div class="mb-4 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-[.72rem] text-amber-800">
        ⚠️ {t('tribes.partialContentWarning', lang)}
      </div>
    )}

    <div id="tribesContainer">
      {safeQuadrants.map((quad) => {
        const tribes = safeTribes.filter((tr) => tr.quadrant === quad.key);
        if (!tribes.length) return null;
        return (
          <>
            {/* Quadrant header */}
            <div class="mt-8 mb-4 pl-2" style={`border-left: 4px solid ${QUAD_COLORS[quad.key]}`}>
              <div class="text-[.7rem] font-bold tracking-wider uppercase"
                   style={`color: ${QUAD_COLORS[quad.key]}`}>
                {quad.label}
              </div>
              <div class="text-[1.15rem] font-extrabold mt-0.5">{quad.title}</div>
              <div class="text-[.82rem] text-[var(--text-secondary)]">{quad.subtitle}</div>
            </div>

            {/* Tribe cards */}
            {tribes.map((tr) => (
              <div class="bg-[var(--surface-card)] rounded-2xl overflow-hidden border border-[var(--border-subtle)] mb-4
                          hover:shadow-md transition-all duration-300"
                   id={`t-${tr.id}`}
                   data-quadrant={tr.quadrant}>
                {/* Header — always visible */}
                <div class="flex items-center gap-4 px-5 py-4 cursor-pointer"
                     data-tribe-header={tr.id}>
                  <div class="w-[42px] h-[42px] rounded-xl flex items-center justify-center
                              text-white font-extrabold text-base flex-shrink-0"
                       id={`tp-${tr.id}`}
                       style={`background: ${QUAD_COLORS[tr.quadrant]}`}>
                    {String(tr.id).padStart(2, '0')}
                  </div>

                  <div class="flex-1 min-w-0">
                    <h3 id={`tn-${tr.id}`} class="text-[.95rem] font-bold truncate">{tr.name}</h3>
                    <div class="text-[.82rem] text-[var(--text-secondary)]">
                      {tr.leader}
                      {tr.leaderLinkedIn && (
                        <a href={tr.leaderLinkedIn} target="_blank" rel="noopener"
                           class="text-teal no-underline text-[.75rem] ml-1"
                           data-stop-propagation>🔗</a>
                      )}
                    </div>
                  </div>

                  <div class="flex-shrink-0 text-center">
                    <div class="flex gap-[3px] mb-0.5" id={`sl-${tr.id}`}>
                      {Array.from({ length: MAX_SLOTS }).map((_, i) => (
                        <div class="w-3.5 h-3.5 rounded-full border-2 border-gray-300 transition-all duration-300"
                             style={i < (initialCounts[tr.id] || 0) ? 'background:#70AD47;border-color:#70AD47' : ''}></div>
                      ))}
                    </div>
                    <div class="text-[.68rem] text-[var(--text-secondary)] font-semibold" id={`st-${tr.id}`}>
                      {initialCounts[tr.id] || 0}/{MAX_SLOTS}
                    </div>
                  </div>
                </div>

                <div class="max-h-0 overflow-hidden transition-all duration-400 px-5"
                     id={`tb-${tr.id}`}>
                  <div class="pb-5 pt-3 border-t border-[var(--border-subtle)]">
                    <p id={`td-${tr.id}`} class="text-[.88rem] text-[var(--text-secondary)] mb-3">{tr.description}</p>

                    <div class="mb-3">
                      <strong class="text-[.85rem]">{t('tribes.deliverables', lang)}</strong>
                      <ul class="mt-1.5 ml-5 text-[.84rem] text-[var(--text-secondary)] list-disc">
                        {(tr.deliverables || []).map((d: string) => <li class="mb-1">{d}</li>)}
                      </ul>
                    </div>

                    <p class="text-[.82rem] mb-3" id={`ms-${tr.id}`}>
                      <strong>{t('tribes.meetings', lang)}</strong> <span class="text-[var(--text-muted)]">{tr.meetingSchedule || t('tribes.loading', lang)}</span>
                    </p>

                    <div class="flex gap-3 flex-wrap items-center mt-4">
                      <a href={tr.videoUrl} target="_blank" rel="noopener"
                         class="inline-flex items-center gap-1.5 bg-crimson text-white px-4 py-2
                                rounded-xl no-underline text-[.82rem] font-semibold
                                hover:opacity-85 transition-opacity"
                         data-stop-propagation>
                        ▶ Vídeo ({tr.videoDuration})
                      </a>
                      <button class="tribe-select-btn w-full sm:w-auto px-4 py-2.5 rounded-xl
                                     text-[.82rem] font-semibold text-white bg-teal
                                     hover:bg-teal/80 transition-all cursor-pointer border-0
                                     disabled:opacity-50 disabled:cursor-not-allowed"
                              id={`sb-${tr.id}`}
                              data-tribe-id={tr.id}
                              style="display:none">
                        {t('tribes.select', lang)}
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </>
        );
      })}
      {(!safeQuadrants.length || !safeTribes.length) && (
        <div class="bg-[var(--surface-card)] rounded-2xl border border-[var(--border-subtle)] p-5 text-sm text-[var(--text-secondary)]">
          {t('tribes.trailsUnavailable', lang)}
        </div>
      )}
    </div>

    <div class="text-center mt-6">
      <a href="https://youtube.com/playlist?list=PLQJVKrw1fcrx3fD2ug1hnps6TklcMT1dc"
         target="_blank" rel="noopener"
         class="text-crimson font-bold text-[.95rem] no-underline hover:underline">
        {t('tribes.playlist', lang)}
      </a>
    </div>
  </div>
</section>

<script define:vars={{ tribeSelectionDeadline: TRIBE_SELECTION_DEADLINE_ISO, hasSelectionDeadline: !!TRIBE_SELECTION_DEADLINE_ISO, TRIBES_MSG, MAX_SLOTS, MIN_SLOTS, TRIBE_IDS }}>
  // ── Tribe selection logic ──
  // Uses window.navGetSb() and nav:member event per established Astro patterns.
  // MAX_SLOTS, MIN_SLOTS from data/tribes via define:vars (single source of truth)

  const DEADLINE = hasSelectionDeadline ? new Date(tribeSelectionDeadline) : null;

  function isHighMgmt(member) {
    return !!(member && (
      member.is_superadmin === true ||
      member.operational_role === 'manager' ||
      member.operational_role === 'deputy_manager'
    ));
  }

  document.querySelectorAll('[data-stop-propagation]').forEach((el) => {
    el.addEventListener('click', (event) => event.stopPropagation());
  });

  let tribeCounts = {};
  let userTribe = null;
  let member = null;

  function getSb() {
    return window.navGetSb?.();
  }

  function getRole(member) {
    return member?.operational_role || member?.role || 'guest';
  }

  // ── Accordion toggle ──
  document.querySelectorAll('[data-tribe-header]').forEach((el) => {
    el.addEventListener('click', () => {
      const id = el.getAttribute('data-tribe-header');
      const body = document.getElementById(`tb-${id}`);
      if (!body) return;
      const wasOpen = body.style.maxHeight && body.style.maxHeight !== '0px';
      // Close all
      document.querySelectorAll('[id^="tb-"]').forEach((b) => {
        b.style.maxHeight = '0px';
      });
      if (!wasOpen) {
        body.style.maxHeight = body.scrollHeight + 'px';
      }
    });
  });

  // ── Load tribe slot counts via RPC (SECURITY DEFINER, works for anon) ──
  async function loadTribeCounts() {
    const sb = getSb();
    if (!sb) return;
    const { data, error } = await sb.rpc('count_tribe_slots');
    if (error) {
      console.error('tribes.loadTribeCounts failed', error);
      return;
    }
    tribeCounts = {};
    if (data && typeof data === 'object') {
      Object.entries(data).forEach(function(pair) {
        tribeCounts[Number(pair[0])] = pair[1];
      });
    }
    updateUI();
  }

  // ── Load leader photos (with fallback for tribes without a tribe_leader) ──
  async function loadLeaderPhotos() {
    const sb = getSb();
    if (!sb) return;
    const { data } = await sb.from('public_members')
      .select('tribe_id, photo_url, operational_role')
      .in('operational_role', ['tribe_leader', 'deputy_manager', 'manager'])
      .not('photo_url', 'is', null);
    if (!data) return;
    const ROLE_PRIO = { tribe_leader: 0, deputy_manager: 1, manager: 2 };
    const best = {};
    data.forEach((m) => {
      if (!m.tribe_id || !m.photo_url) return;
      const prio = ROLE_PRIO[m.operational_role] ?? 9;
      if (!best[m.tribe_id] || prio < best[m.tribe_id].prio) {
        best[m.tribe_id] = { photo_url: m.photo_url, prio };
      }
    });
    Object.entries(best).forEach(([tid, info]) => {
      const el = document.getElementById('tp-' + tid);
      if (el) {
        el.innerHTML = '<img src="' + info.photo_url + '" class="w-[42px] h-[42px] rounded-full object-cover" alt="">';
        el.className = 'flex-shrink-0';
      }
    });
  }

  // ── Select / deselect tribe ──
  async function selectTribe(id) {
    const sb = getSb();
    if (!sb) return;
    if (!member) {
      document.dispatchEvent(new CustomEvent('open-auth'));
      return;
    }
    const role = getRole(member);
    if (role === 'guest') {
      window.toast?.(TRIBES_MSG.onlyParticipants, 'error');
      return;
    }
    if (role === 'tribe_leader') {
      window.toast?.(TRIBES_MSG.leadersAssigned, 'info');
      return;
    }
    // R3: QA bypass — high management can select tribes past deadline
    var canBypassSchedule = isHighMgmt(member);
    if (!DEADLINE && !canBypassSchedule) {
      window.toast?.(TRIBES_MSG.selectionUnavailable, 'error');
      return;
    }
    if (DEADLINE && new Date() > DEADLINE && !canBypassSchedule) {
      window.toast?.(TRIBES_MSG.selectionClosed, 'error');
      return;
    }

    // Deselect if clicking current tribe
    if (userTribe === id) {
      try {
        const { data } = await sb.rpc('deselect_tribe');
        if (data?.success) {
          userTribe = null;
          window.toast?.(TRIBES_MSG.selectionRemoved, 'info');
          await loadTribeCounts();
        } else {
          window.toast?.(data?.error || TRIBES_MSG.errorRemove, 'error');
        }
      } catch (e) {
        window.toast?.('Erro: ' + (e?.message || 'falha inesperada'), 'error');
      }
      return;
    }

    // Select / switch
    const count = tribeCounts[id] || 0;
    if (count >= MAX_SLOTS) {
      window.toast?.(TRIBES_MSG.tribeFull, 'error');
      return;
    }

    try {
      const { data } = await sb.rpc('select_tribe', { p_tribe_id: id });
      if (data?.success) {
        userTribe = id;
        window.toast?.(TRIBES_MSG.selectedSuccess.replace('{id}', String(id)), 'success');
        await loadTribeCounts();
      } else {
        window.toast?.(data?.error || TRIBES_MSG.errorSelect, 'error');
      }
    } catch (e) {
      window.toast?.('Erro: ' + (e?.message || 'falha inesperada'), 'error');
    }
  }

  // ── Bind select buttons ──
  document.querySelectorAll('.tribe-select-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = Number(btn.dataset.tribeId);
      selectTribe(id);
    });
  });

  // ── Update UI based on counts + auth ──
  function updateUI() {
    for (const tid of TRIBE_IDS) {
      const count = tribeCounts[tid] || 0;
      const dots = document.querySelectorAll(`#sl-${tid} > div`);
      const text = document.getElementById(`st-${tid}`);
      const btn = document.getElementById(`sb-${tid}`);

      // Dots
      dots.forEach((d, i) => {
        d.style.background = i < count ? '#70AD47' : '';
        d.style.borderColor = i < count ? '#70AD47' : '';
      });

      // Text
      if (text) {
        if (count >= MAX_SLOTS) {
          text.innerHTML = '<span class="text-red-600 font-bold">' + TRIBES_MSG.fullCaps + '</span>';
        } else if (count >= MIN_SLOTS) {
          text.innerHTML = `${count}/${MAX_SLOTS} ✓`;
          text.style.color = '#70AD47';
        } else {
          text.textContent = `${count}/${MAX_SLOTS}`;
          text.style.color = '';
        }
      }

      // Button
      if (btn) {
        const isSelected = userTribe === tid;
        const isFull = count >= MAX_SLOTS && !isSelected;
        const role = getRole(member);
        const canBypassSchedule = isHighMgmt(member);
        const canSelect = member
          && role !== 'guest'
          && role !== 'tribe_leader'
          && member.is_active !== false
          && (hasSelectionDeadline || canBypassSchedule);

        if (isSelected) {
          btn.textContent = TRIBES_MSG.selected;
          btn.style.background = '#70AD47';
          btn.disabled = false;
        } else if (isFull) {
          btn.textContent = TRIBES_MSG.full;
          btn.style.background = '';
          btn.disabled = true;
        } else {
          btn.textContent = TRIBES_MSG.selectBtn;
          btn.style.background = '';
          btn.disabled = false;
        }
        btn.style.display = canSelect ? '' : 'none';
      }
    }

    // Login prompt
    const prompt = document.getElementById('loginPrompt');
    if (prompt) prompt.style.display = member ? 'none' : 'block';
  }

  // ── Realtime subscription ──
  function subscribeRealtime() {
    const sb = getSb();
    if (!sb) return;
    sb.channel('tribe_changes')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'tribe_selections' },
          () => loadTribeCounts())
      .subscribe();
  }

  // ── Boot ──
  async function bootTribes() {
    // Wait for nav to initialize
    const sb = getSb();
    if (!sb) {
      setTimeout(bootTribes, 200);
      return;
    }
    await loadTribeCounts();
    await loadLeaderPhotos();
    await loadMeetingSlots();
    subscribeRealtime();

    // Load user tribe selection if logged in
    member = window.navGetMember?.();
    if (member?.id) {
      const { data: sel } = await sb.from('tribe_selections')
        .select('tribe_id')
        .eq('member_id', member.id)
        .maybeSingle();
      if (sel) userTribe = sel.tribe_id;
    }
    updateUI();
  }

  // ── Load meeting slots from DB ──
  const DAY_NAMES = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];

  async function loadMeetingSlots() {
    const sb = getSb();
    if (!sb) return;

    const [{ data: slots }, { data: tribes }] = await Promise.all([
      sb.from('tribe_meeting_slots')
        .select('tribe_id, day_of_week, time_start, time_end')
        .eq('is_active', true)
        .order('day_of_week'),
      sb.from('tribes')
        .select('id, name, notes, whatsapp_url, is_active')
    ]);

    // Group slots by tribe
    const slotMap = {};
    (slots || []).forEach((s) => {
      if (!slotMap[s.tribe_id]) slotMap[s.tribe_id] = [];
      slotMap[s.tribe_id].push(s);
    });

    // Notes map
    const notesMap = {};
    const waMap = {};
    const activeMap = {};
    const nameMap = {};
    (tribes || []).forEach((t) => {
      if (t.notes) notesMap[t.id] = t.notes;
      if (t.whatsapp_url) waMap[t.id] = t.whatsapp_url;
      if (typeof t.is_active === 'boolean') activeMap[t.id] = t.is_active;
      if (t.name) nameMap[t.id] = t.name;
    });

    // Update each tribe's meeting schedule display
    for (const tid of TRIBE_IDS) {
      const card = document.getElementById(`t-${tid}`);
      if (card && activeMap[tid] === false) {
        card.style.display = 'none';
        continue;
      }
      if (card && activeMap[tid] !== false) {
        card.style.display = '';
      }
      const title = document.getElementById(`tn-${tid}`);
      if (title && nameMap[tid]) title.textContent = String(nameMap[tid]);

      const el = document.getElementById(`ms-${tid}`);
      if (!el) continue;

      const tribeSlots = slotMap[tid];
      let scheduleHtml = '';

      if (tribeSlots?.length) {
        const formatted = tribeSlots.map((s) => {
          const day = DAY_NAMES[s.day_of_week] || '?';
          const start = s.time_start.substring(0, 5);
          const end = s.time_end.substring(0, 5);
          return `${day} ${start}–${end}`;
        }).join(' · ');
        scheduleHtml = formatted;
      } else if (notesMap[tid]) {
        scheduleHtml = `<span class="text-[var(--text-muted)] italic">${notesMap[tid]}</span>`;
      } else {
        scheduleHtml = '<span class="text-[var(--text-muted)] italic">A definir</span>';
      }

      // Add WhatsApp link if available
      const waLink = waMap[tid]
        ? ` <a href="${waMap[tid]}" target="_blank" rel="noopener" class="text-emerald-600 no-underline text-[.75rem] ml-1" data-stop-propagation>💬 WhatsApp</a>`
        : '';

      el.innerHTML = `<strong>📅 Encontros:</strong> ${scheduleHtml}${waLink}`;
    }
  }

  // Listen for auth changes
  window.addEventListener('nav:member', (e) => {
    member = e.detail;
    if (member?.id) {
      getSb()?.from('tribe_selections')
        .select('tribe_id')
        .eq('member_id', member.id)
        .maybeSingle()
        .then(({ data }) => {
          userTribe = data?.tribe_id ?? null;
          updateUI();
        });
    } else {
      userTribe = null;
      updateUI();
    }
  });

  bootTribes();
</script>
