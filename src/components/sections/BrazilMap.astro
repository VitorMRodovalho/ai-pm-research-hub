---
// Mapa de cobertura nacional (R9 — Ciclo 4). SSR, FE-puro: recebe os UFs com
// capítulo ativo (do registry, via ChaptersSection) e colore os estados ao vivo.
// Nada hardcoded — `activeUFs`/`founderUF` vêm da query de capítulos.
//
// Geometria SVG do Brasil por UF: luisdalmolin/mapa-brasil-svg (MIT License,
// © Luis Dalmolin) — coordenadas reduzidas a 1 casa decimal + atributos de
// stroke movidos para CSS para enxugar o inline. IDs = sigla UF (GO, SP, ...).
interface Props {
  activeUFs: string[];
  founderUF?: string | null;
  ariaLabel: string;
  class?: string;
}
const { activeUFs, founderUF = null, ariaLabel, class: className = '' } = Astro.props;

// CSS escopado pelo container `.nia-brmap` (renderizado via set:html p/ alcançar
// os ids globais do SVG sem o scoping do Astro). Founder depois do active → vence.
const activeSel = activeUFs.map((uf) => `.nia-brmap #${uf}`).join(',');
const css = `
.nia-brmap svg{width:100%;height:auto;display:block;max-width:420px;margin:0 auto}
.nia-brmap .state{fill:var(--map-inactive,#D7DEE3);stroke:var(--surface-section-cool,#fff);stroke-width:.5;stroke-linejoin:round;transition:fill .15s ease}
${activeSel ? `${activeSel}{fill:var(--color-teal)}` : ''}
.nia-brmap .state:hover{fill:var(--color-purple)}
${founderUF ? `.nia-brmap #${founderUF}{fill:var(--color-orange)}` : ''}
`;
---
