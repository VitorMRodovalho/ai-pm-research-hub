---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;
---

<section class="py-16 px-6 bg-[var(--surface-section-cool)]" id="nucleo">
  <div class="max-w-[900px] mx-auto text-center">
    <h2 class="text-[clamp(1.5rem,3.5vw,2.2rem)] font-extrabold text-[var(--text-primary)] leading-tight mb-4">
      {t('nucleo.title', lang)}
    </h2>
    <p class="text-[1rem] text-[var(--text-secondary)] leading-relaxed max-w-[700px] mx-auto">
      {t('nucleo.desc', lang)}
    </p>
  </div>
</section>
