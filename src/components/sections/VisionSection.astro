---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;

const cards = [
  { key: 'benchmarking', border: '#00799E', hasHtml: false },
  { key: 'bimodal',      border: '#FF610F', hasHtml: true },
  { key: 'cpmai',        border: '#4F17A8', hasHtml: false },
  { key: 'roadmap',      border: '#10B981', hasHtml: true },
];
---

<section class="py-16 px-6 bg-[var(--surface-section-warm)]" id="vision">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('vision.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-3">
      {t('vision.title', lang)}
    </h2>
    <p class="text-base text-[var(--text-secondary)] max-w-[700px] mb-10">
      {t('vision.subtitle', lang)}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {cards.map((c) => (
        <div class="bg-[var(--surface-card)] rounded-2xl p-6" style={`border-top: 4px solid ${c.border}`}>
          <h3 class="text-base font-bold mb-2">{t(`vision.${c.key}.title`, lang)}</h3>
          {c.hasHtml
            ? <p class="text-[.85rem] text-[var(--text-secondary)]" set:html={t(`vision.${c.key}.html`, lang)} />
            : <p class="text-[.85rem] text-[var(--text-secondary)]">{t(`vision.${c.key}.text`, lang)}</p>
          }
        </div>
      ))}
    </div>
  </div>
</section>
