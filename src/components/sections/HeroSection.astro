---
/**
 * HeroSection.astro — Sprint 2
 * Migrated from v1 index.html hero section.
 * Countdown runs client-side; everything else is static Astro.
 */
import { CHAPTER_CODES } from '../../data/chapters';

interface Props {
  /** ISO date string for tribe selection deadline */
  deadline?: string;
}

const { deadline = '2026-03-08T15:00:00Z' } = Astro.props;
---

<section class="hero relative min-h-screen flex items-center justify-center overflow-hidden pt-14" id="hero">
  <!-- Radial decorative blurs -->
  <div class="absolute -top-1/2 -right-[30%] w-[80vw] h-[80vw] rounded-full bg-[radial-gradient(circle,rgba(5,191,224,.08)_0%,transparent_60%)] pointer-events-none"></div>
  <div class="absolute -bottom-[20%] -left-[20%] w-[60vw] h-[60vw] rounded-full bg-[radial-gradient(circle,rgba(255,97,15,.06)_0%,transparent_50%)] pointer-events-none"></div>

  <div class="relative z-10 text-center max-w-[900px] px-6 py-8">
    <!-- Badge -->
    <div class="inline-block bg-orange/15 text-orange text-[.78rem] font-semibold px-5 py-1.5 rounded-full border border-orange/30 mb-6 tracking-wider uppercase">
      KICK-OFF OFICIAL — CICLO 03 (2026/1)
    </div>

    <!-- Title -->
    <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-extrabold text-white leading-[1.15] mb-2">
      Núcleo de Estudos e Pesquisa em<br>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#05BFE0] to-[#B465FF]">
        Inteligência Artificial
      </span><br>
      e Gerenciamento de Projetos
    </h1>

    <!-- Subtitle -->
    <h2 class="text-[clamp(.9rem,2.5vw,1.3rem)] text-white/60 font-normal mb-6">
      The AI &amp; PM Study and Research Hub — A Joint Initiative of the PMI Brazilian Chapters
    </h2>

    <!-- Date -->
    <div class="inline-flex items-center gap-2 bg-white/6 border border-white/10 px-5 py-2.5 rounded-xl text-white text-[.9rem] font-medium">
      📅 5 de Março de 2026 · 19:30 BRT · Google Meet
    </div>

    <!-- Chapter badges -->
    <div class="flex flex-wrap justify-center gap-2 mt-6">
      {CHAPTER_CODES.map((c) => (
        <span class="bg-white/8 border border-white/12 text-white/80 px-3 py-1 rounded-lg text-[.78rem] font-semibold">
          {c}
        </span>
      ))}
    </div>

    <!-- Countdown -->
    <div class="mt-8 bg-white/6 border border-white/10 rounded-2xl px-6 py-4 inline-flex items-center gap-5 flex-wrap justify-center"
         id="countdown-bar">
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-d">--</div>
        <div class="text-[.65rem] text-white/50 uppercase tracking-wider">Dias</div>
      </div>
      <div class="text-2xl text-white/20">:</div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-h">--</div>
        <div class="text-[.65rem] text-white/50 uppercase tracking-wider">Horas</div>
      </div>
      <div class="text-2xl text-white/20">:</div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-m">--</div>
        <div class="text-[.65rem] text-white/50 uppercase tracking-wider">Min</div>
      </div>
      <div class="text-2xl text-white/20">:</div>
      <div class="text-center">
        <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-s">--</div>
        <div class="text-[.65rem] text-white/50 uppercase tracking-wider">Seg</div>
      </div>
      <div class="text-[.72rem] text-white/50">para escolher sua tribo</div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 text-[.75rem] animate-bounce">
    ▼ Role para começar
  </div>
</section>

<!-- Countdown client script -->
<script define:vars={{ deadline }}>
  var dl = new Date(deadline);
  function tick() {
    var diff = dl - new Date();
    if (diff <= 0) {
      ['cd-d','cd-h','cd-m','cd-s'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.textContent = '00';
      });
      return;
    }
    var d = document.getElementById('cd-d');
    var h = document.getElementById('cd-h');
    var m = document.getElementById('cd-m');
    var s = document.getElementById('cd-s');
    if (d) d.textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
    if (h) h.textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
    if (m) m.textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
    if (s) s.textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
  }
  tick();
  setInterval(tick, 1000);
</script>

<style>
  .hero {
    background: linear-gradient(135deg, #003B5C 0%, #200F3B 40%, #0a1628 100%);
  }
</style>
