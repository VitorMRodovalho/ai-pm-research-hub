---
import { CHAPTER_CODES } from '../../data/chapters';
import { t, type Lang } from '../../i18n/utils';
import type { HomeScheduleConfig } from '../../lib/schedule';

interface Props {
  deadline?: string | null;
  schedule?: HomeScheduleConfig | null;
  lang?: Lang;
}

const { deadline = null, schedule = null, lang = 'pt-BR' } = Astro.props;
const hasDeadline = typeof deadline === 'string' && !Number.isNaN(new Date(deadline).getTime());

const WEEKDAY_LABELS: Record<Lang, string[]> = {
  'pt-BR': ['Domingos', 'Segundas', 'Terças', 'Quartas', 'Quintas', 'Sextas', 'Sábados'],
  'en-US': ['Sundays', 'Mondays', 'Tuesdays', 'Wednesdays', 'Thursdays', 'Fridays', 'Saturdays'],
  'es-LATAM': ['Domingos', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábados'],
};

function formatKickoffBadge(homeSchedule: HomeScheduleConfig | null, currentLang: Lang): string | null {
  if (!homeSchedule?.kickoffAt) return null;
  try {
    const formatted = new Intl.DateTimeFormat(currentLang, {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      timeZone: 'America/Sao_Paulo',
    }).format(new Date(homeSchedule.kickoffAt));
    return `${formatted} BRT${homeSchedule.platformLabel ? ` · ${homeSchedule.platformLabel}` : ''}`;
  } catch {
    return null;
  }
}

function formatRecurringSchedule(homeSchedule: HomeScheduleConfig | null, currentLang: Lang): string | null {
  if (
    homeSchedule?.recurringWeekday === null ||
    homeSchedule?.recurringWeekday === undefined ||
    !homeSchedule.recurringStartBrt ||
    !homeSchedule.recurringEndBrt
  ) return null;
  const weekday = WEEKDAY_LABELS[currentLang]?.[homeSchedule.recurringWeekday];
  if (!weekday) return null;
  return `${weekday} · ${homeSchedule.recurringStartBrt} → ${homeSchedule.recurringEndBrt} BRT`;
}

const kickoffBadge = formatKickoffBadge(schedule, lang) || t('hero.date', lang);
const recurringSchedule = formatRecurringSchedule(schedule, lang) || t('hero.meetingSchedule', lang);
const recurringMeeting = `${t('hero.recurringMeetingPrefix', lang)} · ${recurringSchedule}`;
---

<section class="hero relative min-h-screen flex items-center justify-center overflow-hidden pt-14" id="hero">
  <div class="absolute -top-1/2 -right-[30%] w-[80vw] h-[80vw] rounded-full bg-[radial-gradient(circle,rgba(5,191,224,.08)_0%,transparent_60%)] pointer-events-none"></div>
  <div class="absolute -bottom-[20%] -left-[20%] w-[60vw] h-[60vw] rounded-full bg-[radial-gradient(circle,rgba(255,97,15,.06)_0%,transparent_50%)] pointer-events-none"></div>

  <div class="relative z-10 text-center max-w-[900px] px-6 py-8">
    <div class="inline-block bg-orange/15 text-orange text-[.78rem] font-semibold px-5 py-1.5 rounded-full border border-orange/30 mb-6 tracking-wider uppercase">
      {t('hero.badge', lang)}
    </div>

    <h1 class="text-[clamp(2rem,5vw,3.5rem)] font-extrabold text-white leading-[1.15] mb-2">
      {t('hero.title.line1', lang)}<br>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#05BFE0] to-[#B465FF]">
        {t('hero.title.accent', lang)}
      </span><br>
      {t('hero.title.line3', lang)}
    </h1>

    <h2 class="text-[clamp(.9rem,2.5vw,1.3rem)] text-white/60 font-normal mb-6">
      {t('hero.subtitle', lang)}
    </h2>

    <!-- Event info area (populated by JS) -->
    <div id="hero-event-area">
      <div class="inline-flex items-center gap-2 bg-white/6 border border-white/10 px-5 py-2.5 rounded-xl text-white text-[.9rem] font-medium">
        📅 {kickoffBadge}
      </div>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mt-6">
      {CHAPTER_CODES.map((c) => (
        <span class="bg-white/8 border border-white/12 text-white/80 px-3 py-1 rounded-lg text-[.78rem] font-semibold">
          {c}
        </span>
      ))}
    </div>

    <!-- Countdown / Cycle Status area -->
    <div id="hero-countdown-area" class:list={{ hidden: !hasDeadline }}>
      <div class="mt-8 bg-white/6 border border-white/10 rounded-2xl px-6 py-4 inline-flex items-center gap-5 flex-wrap justify-center" id="countdown-bar">
        <div class="text-center">
          <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-d">--</div>
          <div class="text-[.65rem] text-white/50 uppercase tracking-wider">{t('hero.countdown.days', lang)}</div>
        </div>
        <div class="text-2xl text-white/20">:</div>
        <div class="text-center">
          <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-h">--</div>
          <div class="text-[.65rem] text-white/50 uppercase tracking-wider">{t('hero.countdown.hours', lang)}</div>
        </div>
        <div class="text-2xl text-white/20">:</div>
        <div class="text-center">
          <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-m">--</div>
          <div class="text-[.65rem] text-white/50 uppercase tracking-wider">{t('hero.countdown.min', lang)}</div>
        </div>
        <div class="text-2xl text-white/20">:</div>
        <div class="text-center">
          <div class="text-3xl font-extrabold text-[#05BFE0] leading-none" id="cd-s">--</div>
          <div class="text-[.65rem] text-white/50 uppercase tracking-wider">{t('hero.countdown.sec', lang)}</div>
        </div>
        <div class="text-[.72rem] text-white/50" id="countdown-label">{t('hero.countdown.label', lang)}</div>
      </div>
    </div>

    <!-- Cycle Status bar (replaces countdown after kickoff) -->
    <div id="hero-cycle-status" class="hidden mt-6">
      <div class="bg-white/6 border border-[#05BFE0]/20 rounded-2xl px-6 py-4 inline-flex items-center gap-4 flex-wrap justify-center">
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 rounded-full bg-green-400 animate-pulse"></span>
          <span class="text-[.85rem] font-bold text-white" id="cycle-label">{t('hero.cycleActive', lang)}</span>
        </div>
        <span class="text-white/20">|</span>
        <span class="text-[.78rem] text-white/60" id="cycle-tribe-count"></span>
        <span class="text-white/20">|</span>
        <span class="text-[.78rem] text-white/60" id="cycle-member-count"></span>
        <span class="text-white/20 hidden" id="cycle-observer-sep">|</span>
        <span class="text-[.78rem] text-white/60 hidden" id="cycle-observer-count"></span>
      </div>
    </div>

    <!-- Next Meeting bar (shown after kickoff for logged-in users) -->
    <div id="hero-meeting-bar" class="hidden mt-4"></div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/30 text-[.75rem] animate-bounce">
    {t('hero.scroll', lang)}
  </div>
</section>

<!-- i18n for client JS -->
<script id="hero-i18n" type="application/json" set:html={JSON.stringify({
  dateLocale: t('hero.dateLocale', lang),
  hasDeadline,
  kickoffAt: schedule?.kickoffAt ?? null,
  platformLabel: schedule?.platformLabel ?? null,
  watchRecording: t('hero.watchRecording', lang),
  recurringMeeting,
  kickoffHeldOn: t('hero.kickoffHeldOn', lang),
  kickoffDoneRecordingSoon: t('hero.kickoffDoneRecordingSoon', lang),
  nextGeneralMeeting: t('hero.nextGeneralMeeting', lang),
  meetingSchedule: recurringSchedule,
  joinMeet: t('hero.joinMeet', lang),
  cycleActive: t('hero.cycleActive', lang),
  cycleTribes: t('hero.cycleTribes', lang),
  cycleMembers: t('hero.cycleMembers', lang),
})}></script>

<script define:vars={{ deadline, hasDeadline }}>
  // ── Countdown (for tribe selection deadline) ──
  var dl = hasDeadline ? new Date(deadline) : null;
  function tick() {
    if (!dl) {
      var noDeadlineBar = document.getElementById('countdown-bar');
      if (noDeadlineBar) noDeadlineBar.style.display = 'none';
      return;
    }
    var diff = dl - new Date();
    if (diff <= 0) {
      var bar = document.getElementById('countdown-bar');
      if (bar) bar.style.display = 'none';
      return;
    }
    var d = document.getElementById('cd-d');
    var h = document.getElementById('cd-h');
    var m = document.getElementById('cd-m');
    var s = document.getElementById('cd-s');
    if (d) d.textContent = String(Math.floor(diff / 86400000)).padStart(2, '0');
    if (h) h.textContent = String(Math.floor((diff % 86400000) / 3600000)).padStart(2, '0');
    if (m) m.textContent = String(Math.floor((diff % 3600000) / 60000)).padStart(2, '0');
    if (s) s.textContent = String(Math.floor((diff % 60000) / 1000)).padStart(2, '0');
  }
  tick();
  if (dl) setInterval(tick, 1000);
</script>

<script>
  // ── Dynamic event info from DB ──
  const heroI18nEl = document.getElementById('hero-i18n');
  const hi18n = heroI18nEl ? JSON.parse(heroI18nEl.textContent || '{}') : {};
  const heroHasDeadline = hi18n.hasDeadline === true;
  const heroKickoffDate = typeof hi18n.kickoffAt === 'string' ? new Date(hi18n.kickoffAt) : null;
  const heroKickoffPassed = !!heroKickoffDate
    && !Number.isNaN(heroKickoffDate.getTime())
    && heroKickoffDate.getTime() < Date.now();

  function formatKickoffDateLabel() {
    if (!heroKickoffDate || Number.isNaN(heroKickoffDate.getTime())) return null;
    const dateLocale = hi18n.dateLocale || 'pt-BR';
    return heroKickoffDate.toLocaleDateString(dateLocale, {
      day: '2-digit',
      month: 'long',
      year: 'numeric',
    });
  }

  function kickoffFallbackHtml(dateStr: string | null): string {
    return `
      <div class="flex flex-wrap gap-3 justify-center">
        <div class="inline-flex items-center gap-2 bg-white/6 border border-white/10 px-5 py-2.5 rounded-xl text-white text-[.9rem] font-medium">
          ${hi18n.kickoffDoneRecordingSoon || '✅ Kick-off realizado · Gravação em breve'}
        </div>
        ${hi18n.platformLabel ? `
        <div class="inline-flex items-center gap-2 bg-white/6 border border-white/10 px-5 py-2.5 rounded-xl text-white text-[.9rem] font-medium">
          📅 ${hi18n.platformLabel}
        </div>` : ''}
      </div>
      ${dateStr ? `<div class="text-[.72rem] text-white/40 mt-2">${hi18n.kickoffHeldOn || 'Kick-off realizado em'} ${dateStr}</div>` : ''}`;
  }

  function meetingBarHtml(meetLink: string): string {
    return `
      <div class="bg-white/6 border border-[#05BFE0]/20 rounded-xl px-5 py-3 inline-flex items-center gap-3 flex-wrap justify-center">
        <span class="text-[.78rem] text-white/60">📅 ${hi18n.nextGeneralMeeting || 'Próxima reunião geral:'}</span>
        <span class="text-[.85rem] font-semibold text-[#05BFE0]">${hi18n.meetingSchedule || 'Cronograma recorrente do ciclo'}</span>
        <a href="${meetLink}" target="_blank" rel="noopener"
          class="px-4 py-1.5 bg-[#05BFE0] text-navy rounded-lg text-[.78rem] font-bold no-underline hover:opacity-90 transition-all">
          ${hi18n.joinMeet || 'Entrar no Meet'}
        </a>
      </div>`;
  }

  async function loadHeroEvent() {
    const eventArea = document.getElementById('hero-event-area');
    if (!eventArea) return;

    const dateStr = formatKickoffDateLabel();
    if (heroKickoffPassed) {
      eventArea.innerHTML = kickoffFallbackHtml(dateStr);
    }

    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(loadHeroEvent, 300); return; }

    try {
      // ADR-0015: filter cross-cutting events via initiative_id IS NULL (Phase 3-safe).
      // Semantically narrower than tribe_id IS NULL — excludes events bound to
      // a specific non-tribe initiative (correct: HeroSection shows chapter-wide
      // kick-off/recurring meetings, not initiative-specific ones).
      const { data: events } = await sb.from('events')
        .select('id, date, meeting_link, youtube_url, duration_minutes, duration_actual')
        .is('initiative_id', null)
        .order('date', { ascending: false })
        .limit(1);

      const ev = events?.[0];
      if (!ev) return;

      if (heroKickoffPassed && ev.youtube_url) {
        const duration = ev.duration_actual || ev.duration_minutes || 90;
        eventArea.innerHTML = `
          <div class="flex flex-wrap gap-3 justify-center">
            <a href="${ev.youtube_url}" target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 bg-red-600/90 hover:bg-red-600 text-white px-5 py-2.5 rounded-xl text-[.9rem] font-semibold no-underline transition-all">
              ▶️ ${hi18n.watchRecording || 'Assistir Gravação'} · ${Math.round(duration)}min
            </a>
            ${ev.meeting_link ? `
            <a href="${ev.meeting_link}" target="_blank" rel="noopener"
              class="inline-flex items-center gap-2 bg-white/6 border border-white/10 hover:bg-white/12 text-white px-5 py-2.5 rounded-xl text-[.9rem] font-medium no-underline transition-all">
              📅 ${hi18n.recurringMeeting || 'Reunião recorrente do ciclo'}
            </a>` : ''}
          </div>
          ${dateStr ? `<div class="text-[.72rem] text-white/40 mt-2">${hi18n.kickoffHeldOn || 'Kick-off realizado em'} ${dateStr}</div>` : ''}`;
      }

      const member = (window as any).navGetMember?.();
      if (member && ev.meeting_link && heroKickoffPassed) {
        const meetBar = document.getElementById('hero-meeting-bar');
        if (meetBar) {
          meetBar.classList.remove('hidden');
          meetBar.innerHTML = meetingBarHtml(ev.meeting_link);
        }
      }

      window.addEventListener('nav:member', () => {
        const m = (window as any).navGetMember?.();
        if (m && ev.meeting_link && heroKickoffPassed) {
          const meetBar = document.getElementById('hero-meeting-bar');
          if (meetBar && meetBar.classList.contains('hidden')) {
            meetBar.classList.remove('hidden');
            meetBar.innerHTML = meetingBarHtml(ev.meeting_link);
          }
        }
      });
    } catch (error) {
      console.warn('hero event:', error);
    }
  }

  loadHeroEvent();

  async function loadCycleStatus() {
    const cdArea = document.getElementById('hero-countdown-area');
    const csArea = document.getElementById('hero-cycle-status');
    const bar = document.getElementById('countdown-bar');

    if (csArea && (!heroHasDeadline || (bar && bar.style.display === 'none'))) {
      csArea.classList.remove('hidden');
      if (cdArea) cdArea.classList.add('hidden');
    }

    const sb = (window as any).navGetSb?.();
    if (!sb) { setTimeout(loadCycleStatus, 400); return; }

    try {
      const [{ count: tribeCount }, { count: memberCount }] = await Promise.all([
        sb.from('tribes').select('id', { count: 'exact', head: true }).eq('is_active', true),
        sb.from('public_members').select('id', { count: 'exact', head: true })
          .eq('current_cycle_active', true),
      ]);
      const tribesEl = document.getElementById('cycle-tribe-count');
      const membersEl = document.getElementById('cycle-member-count');
      if (tribesEl) tribesEl.textContent = (tribeCount || 0) + ' ' + (hi18n.cycleTribes || 'tribos ativas');
      if (membersEl) membersEl.textContent = (memberCount || 0) + ' ' + (hi18n.cycleMembers || 'pesquisadores');
      // Observer count
      const { count: observerCount } = await sb.from('public_members').select('id', { count: 'exact', head: true }).eq('member_status', 'observer');
      if (observerCount && observerCount > 0) {
        const obsEl = document.getElementById('cycle-observer-count');
        const obsSep = document.getElementById('cycle-observer-sep');
        if (obsEl) { obsEl.textContent = observerCount + ' observers'; obsEl.classList.remove('hidden'); }
        if (obsSep) obsSep.classList.remove('hidden');
      }
    } catch (e) { console.warn('cycle status:', e); }
  }

  setTimeout(loadCycleStatus, 1500);
</script>

<style>
  .hero {
    background: var(--hero-gradient);
  }
</style>
