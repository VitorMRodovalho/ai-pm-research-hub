---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;
---

<section class="py-16 px-6 bg-[var(--surface-section-warm)]" id="breakout">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('networking.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-10">
      {t('networking.title', lang)}
    </h2>
    <div class="bg-gradient-to-br from-teal to-navy text-white rounded-3xl p-10 text-center max-w-[700px] mx-auto">
      <h3 class="text-[1.4rem] font-extrabold mb-3">{t('networking.question.title', lang)}</h3>
      <div class="text-[1.15rem] italic text-white/85 bg-black/15 p-5 rounded-2xl my-5 border-l-4 border-orange">
        {t('networking.question', lang)}
      </div>
      <p class="text-[.88rem] opacity-80">{t('networking.cta', lang)}</p>
    </div>
  </div>
</section>
