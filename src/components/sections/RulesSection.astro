---
import { t, type Lang } from '../../i18n/utils';

interface Props { lang?: Lang; }
const { lang = 'pt-BR' } = Astro.props;

const rules = [
  { icon: '⏱', title: t('rules.hours.title', lang), text: t('rules.hours.text', lang) },
  { icon: '📊', title: t('rules.dashboard.title', lang), text: t('rules.dashboard.text', lang) },
  { icon: '📝', title: t('rules.curation.title', lang), text: t('rules.curation.text', lang) },
  { icon: '🏆', title: t('rules.recognition.title', lang), text: t('rules.recognition.text', lang) },
];

const milestones = [
  { label: t('rules.m1.label', lang), title: t('rules.m1.title', lang), text: t('rules.m1.text', lang), color: '#00799E' },
  { label: t('rules.m2.label', lang), title: t('rules.m2.title', lang), text: t('rules.m2.text', lang), color: '#FF610F' },
  { label: t('rules.m3.label', lang), title: t('rules.m3.title', lang), text: t('rules.m3.text', lang), color: '#4F17A8' },
  { label: t('rules.m4.label', lang), title: t('rules.m4.title', lang), text: t('rules.m4.text', lang), color: '#10B981' },
];
---

<section class="py-16 px-6" id="rules">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-2">
      {t('rules.label', lang)}
    </div>
    <h2 class="text-[clamp(1.7rem,4vw,2.5rem)] font-extrabold leading-tight mb-10">
      {t('rules.title', lang)}
    </h2>

    <!-- Rules grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {rules.map((r) => (
        <div>
          <h3 class="text-[1.05rem] font-bold mb-3">{r.title}</h3>
          <p class="text-[.88rem] text-slate-500">{r.text}</p>
        </div>
      ))}
    </div>

    <!-- Value journey -->
    <div class="text-[.73rem] font-bold tracking-[.15em] uppercase text-orange mb-5">
      {t('rules.journey', lang)}
    </div>

    <div class="relative pl-8 border-l-[3px] border-transparent"
         style="border-image: linear-gradient(to bottom, #00799E, #4F17A8, #FF610F) 1;">
      {milestones.map((m) => (
        <div class="relative pb-7 pl-6">
          <div class="absolute -left-[2.35rem] top-1 w-[13px] h-[13px] rounded-full border-[3px] border-white"
               style={`background: ${m.color}`}></div>
          <div class="text-[.72rem] font-bold tracking-wider" style={`color: ${m.color}`}>
            {m.label}
          </div>
          <h4 class="text-[.95rem] font-bold mt-0.5 mb-0.5">{m.title}</h4>
          <p class="text-[.82rem] text-slate-500">{m.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
