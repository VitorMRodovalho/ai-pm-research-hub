---
/**
 * AdminNav.astro — Sidebar de navegação interna do painel Admin.
 * Lê permissões de navigation.config.ts via tier + designations do membro.
 * Renderiza links para sub-rotas do admin com destaque na página ativa.
 */
import { t, type Lang } from '../../i18n/utils';

interface Props { activeSub?: string; lang?: Lang; }
const { activeSub = 'panel', lang = 'pt-BR' } = Astro.props;

const ADMIN_LINKS = [
  { key: 'panel',     labelKey: 'nav.adminPanel',     href: '/admin',           minTier: 'observer' as const },
  { key: 'analytics', labelKey: 'nav.adminAnalytics', href: '/admin/analytics', minTier: 'admin' as const, allowedDesignations: ['sponsor', 'chapter_liaison', 'curator'] },
  { key: 'portfolio', labelKey: 'nav.adminPortfolio', href: '/admin/portfolio', minTier: 'admin' as const, allowedDesignations: ['sponsor', 'chapter_liaison', 'curator', 'co_gp'] },
  { key: 'comms',     labelKey: 'nav.adminComms',      href: '/admin/comms',     minTier: 'admin' as const, allowedDesignations: ['comms_leader', 'comms_member'] },
  { key: 'curatorship', labelKey: 'nav.adminCuratorship', href: '/admin/curatorship', minTier: 'observer' as const },
  { key: 'cycle-report', labelKey: 'nav.adminCycleReport', href: '/admin/cycle-report', minTier: 'admin' as const, allowedDesignations: ['sponsor', 'chapter_liaison'] },
  { key: 'cross-tribes', labelKey: 'nav.adminCrossTribes', href: '/admin/tribes', minTier: 'admin' as const },
  { key: 'tribe-dashboard', labelKey: 'nav.adminTribeDashboard', href: '/admin/tribe/1', minTier: 'leader' as const, allowedDesignations: ['sponsor', 'chapter_liaison'] },
  { key: 'selection', labelKey: 'nav.adminSelection', href: '/admin/selection', minTier: 'admin' as const },
  { key: 'chapter-report', labelKey: 'nav.adminChapterReport', href: '/admin/chapter-report', minTier: 'observer' as const, allowedDesignations: ['sponsor', 'chapter_liaison'] },
  { key: 'sustainability', labelKey: 'nav.adminSustainability', href: '/admin/sustainability', minTier: 'admin' as const, allowedDesignations: ['sponsor', 'chapter_liaison', 'curator'] },
  { key: 'campaigns', labelKey: 'nav.adminCampaigns', href: '/admin/campaigns', minTier: 'admin' as const, allowedDesignations: ['comms_team'] },
  { key: 'blog',      labelKey: 'nav.adminBlog',      href: '/admin/blog',      minTier: 'admin' as const, allowedDesignations: ['comms_team'] },
  { key: 'pilots',    labelKey: 'nav.adminPilots',    href: '/admin/pilots',    minTier: 'admin' as const },
  { key: 'settings',  labelKey: 'nav.adminSettings',  href: '/admin/settings',  minTier: 'superadmin' as const },
  { key: 'help',      labelKey: 'nav.adminHelp',       href: '/help',            minTier: 'member' as const },
];

const adminLinksJson = JSON.stringify(ADMIN_LINKS);
---

<nav class="flex gap-2 mb-6 flex-wrap" id="admin-subnav">
  {ADMIN_LINKS.map(link => (
    <a href={link.href}
       id={`admin-nav-${link.key}`}
       data-admin-nav={link.key}
       style={link.minTier !== 'observer' ? 'display:none' : ''}
       class:list={[
         "px-4 py-2 rounded-xl text-[13px] font-semibold no-underline transition-all",
         activeSub === link.key
           ? "bg-navy text-white"
           : "bg-[var(--admin-subnav-bg)] text-[var(--admin-subnav-text)] hover:bg-[var(--surface-hover)]"
       ]}>
      {t(link.labelKey, lang)}
    </a>
  ))}
</nav>

<script is:inline define:vars={{ adminLinksJson }}>
  window.__ADMIN_LINKS = JSON.parse(adminLinksJson);
</script>
<script>
  import { resolveTierFromMember, hasMinimumTier, type AccessTier } from '../../lib/admin/constants';
  import { TIER_RANK } from '../../lib/navigation.config';
  import { hasPermission, setSimulation, type OperationalTier, type Designation, TIER_LABELS } from '../../lib/permissions';

  // Map admin nav keys to permission strings
  const NAV_PERMISSION_MAP: Record<string, string> = {
    'panel': 'admin.access',
    'analytics': 'admin.analytics',
    'portfolio': 'admin.portfolio',
    'comms': 'admin.campaigns',
    'curatorship': 'admin.curation',
    'cycle-report': 'admin.analytics',
    'cross-tribes': 'admin.access',
    'tribe-dashboard': 'workspace.view_tribe_dashboard',
    'selection': 'admin.members.manage',
    'chapter-report': 'admin.analytics.chapter',
    'sustainability': 'admin.sustainability',
    'campaigns': 'admin.campaigns',
    'blog': 'admin.blog',
    'pilots': 'admin.portfolio',
    'settings': 'system.global_config',
    'help': 'workspace.access',
  };

  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp(`(?:^|; )${name}=([^;]*)`));
    return match ? decodeURIComponent(match[1]) : null;
  }

  function updateAdminNav() {
    const member = (window as any).navGetMember?.();
    if (!member) return;

    // Check for active simulation via cookies
    const simTier = getCookie('sim_tier') as OperationalTier | null;
    const isSimulating = !!simTier && member.is_superadmin && !!TIER_LABELS[simTier];

    if (isSimulating) {
      const simDesig = getCookie('sim_designations');
      const simTribe = getCookie('sim_tribe');
      setSimulation({
        active: true,
        tier: simTier!,
        designations: simDesig ? JSON.parse(simDesig) : [],
        tribe_id: simTribe ? parseInt(simTribe) : null,
      });
    }

    // Build effective member for permission checks
    const effectiveMember = isSimulating
      ? { operational_role: simTier!, designations: getCookie('sim_designations') ? JSON.parse(getCookie('sim_designations')!) : [], is_superadmin: false, tribe_id: getCookie('sim_tribe') ? parseInt(getCookie('sim_tribe')!) : null }
      : member;

    const links: any[] = (window as any).__ADMIN_LINKS || [];

    links.forEach((link: any) => {
      const el = document.getElementById(`admin-nav-${link.key}`);
      if (!el) return;

      const perm = NAV_PERMISSION_MAP[link.key];
      if (perm) {
        el.style.display = hasPermission(effectiveMember, perm as any) ? '' : 'none';
      } else {
        // Fallback to legacy tier check
        const tier = resolveTierFromMember(isSimulating ? effectiveMember : member);
        const desigs: string[] = effectiveMember.designations || [];
        const meetsMinTier = (TIER_RANK[tier] ?? 0) >= (TIER_RANK[link.minTier as AccessTier] ?? 0);
        const hasDesig = link.allowedDesignations?.some((d: string) => desigs.includes(d)) ?? false;
        el.style.display = (meetsMinTier || hasDesig) ? '' : 'none';
      }

      // Resolve tribe dashboard link for tribe leaders
      if (link.key === 'tribe-dashboard') {
        const tribeId = isSimulating && getCookie('sim_tribe') ? parseInt(getCookie('sim_tribe')!) : member.tribe_id;
        if (tribeId) (el as HTMLAnchorElement).href = `/admin/tribe/${tribeId}`;
      }
    });
  }

  function bootAdminNav() {
    const m = (window as any).navGetMember?.();
    if (m) { updateAdminNav(); return; }
    window.addEventListener('nav:member', () => updateAdminNav());
    window.addEventListener('simulation:changed', () => updateAdminNav());
    setTimeout(() => {
      if ((window as any).navGetMember?.()) updateAdminNav();
    }, 500);
  }

  bootAdminNav();
</script>
