---
/**
 * GOVERNANÇA: A atualização da árvore de navegação neste arquivo é
 * Critério de Aceite obrigatório para qualquer nova feature ou página.
 *
 * A estrutura de menus é lida de src/lib/navigation.config.ts.
 * Não hardcode regras de acesso aqui — use minTier e allowedDesignations no config.
 */
import { t, type Lang } from '../../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import { NAV_ITEMS, type NavItem } from '../../lib/navigation.config';

interface Props { activePage?: string; lang?: Lang; }
const { activePage = '', lang = 'pt-BR' } = Astro.props;
const currentPath = Astro.url.pathname;

const base = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

const mainItems = NAV_ITEMS.filter(i => i.section === 'main' || i.section === 'both');
const publicMainItems = mainItems.filter(i => !i.requiresAuth);
const authMainItems = mainItems.filter(i => i.requiresAuth);

function resolveLabel(item: NavItem): string {
  return t(item.labelKey, lang);
}

function resolveHref(item: NavItem): string {
  if (item.dynamic) return '#';
  return base + item.href;
}

function badgeClasses(item: NavItem, isActive: boolean): string {
  const map: Record<string, { active: string; inactive: string }> = {
    crimson: {
      active:   'bg-crimson/30 border border-crimson/50 text-white',
      inactive: 'bg-crimson/20 border border-crimson/40 text-white hover:bg-crimson/30',
    },
    purple: {
      active:   'bg-purple/30 border border-purple/50 text-white',
      inactive: 'bg-purple/20 border border-purple/40 text-white hover:bg-purple/30',
    },
    teal: {
      active:   'bg-teal/30 border border-teal/50 text-white',
      inactive: 'bg-teal/20 border border-teal/40 text-white hover:bg-teal/30',
    },
  };
  const badge = item.badge;
  if (!badge || !map[badge]) {
    return 'text-white/70 hover:text-white hover:bg-white/10';
  }
  return isActive ? map[badge].active : map[badge].inactive;
}

const jsI18n = JSON.stringify({
  login: t('nav.login', lang),
  profile: t('nav.profile', lang),
  attendance: t('nav.attendanceLink', lang),
  admin: t('nav.adminLink', lang),
  adminPanel: t('nav.adminPanel', lang),
  adminAnalytics: t('nav.adminAnalytics', lang),
  adminComms: t('nav.adminComms', lang),
  adminHelp: t('nav.adminHelp', lang),
  help: t('nav.adminHelp', lang),
  onboarding: t('nav.onboarding', lang),
  adminWebinars: t('nav.adminWebinars', lang),
  adminCuratorship: t('nav.adminCuratorship', lang),
  adminSelection: t('nav.adminSelection', lang),
  adminSettings: t('nav.adminSettings', lang),
  presentations: t('nav.presentations', lang),
  myTribe: t('nav.myTribe', lang),
  exploreTribes: t('nav.exploreTribes', lang),
  tribePrefix: t('workspace.tribePrefix', lang),
  logout: t('nav.logout', lang),
  user: t('nav.user', lang),
  guestNotFound: t('guest.navNotFound', lang),
});

const navConfigJson = JSON.stringify(NAV_ITEMS);
---

<nav class="sticky top-0 z-[200] bg-navy/97 backdrop-blur-md border-b-2 border-orange
            px-4 sm:px-6 flex items-center justify-between h-14">
  <a href={base + "/"} class="text-white font-bold text-sm no-underline flex-shrink-0">
    <Fragment set:html={t('nav.brand', lang).replace('IA & GP', '<span class="text-orange">IA & GP</span>')} />
  </a>

  <!-- Desktop links -->
  <div class="hidden lg:flex items-center gap-0.5" id="nav-links">
    {publicMainItems.map(item => (
      <a href={resolveHref(item)}
         class={`text-[.73rem] font-medium px-2 py-1.5 rounded-md no-underline transition-all duration-150 ${badgeClasses(item, false)}`}>
        {resolveLabel(item)}
      </a>
    ))}
    {authMainItems.map(item => (
      <a href={resolveHref(item)}
         id={`nav-item-${item.key}`}
         style="display:none"
         data-nav-key={item.key}
         class={`text-[.73rem] font-semibold px-2 py-1.5 rounded-md no-underline transition-all ${badgeClasses(item, activePage === item.key)}`}>
        {resolveLabel(item)}
      </a>
    ))}
  </div>

  <div class="flex items-center gap-2">
    <LangSwitcher currentLang={lang} currentPath={currentPath} />

    <!-- Auth area: populated by client script -->
    <div id="nav-auth" class="flex items-center gap-2 flex-shrink-0">
      <button data-action="open-auth"
              class="px-3 py-1.5 rounded-lg bg-white/10 border border-white/20
                     text-white text-[.78rem] font-semibold hover:bg-white/20 transition-all cursor-pointer"
              id="nav-login-btn">
        {t('nav.login', lang)}
      </button>
    </div>

    <!-- Mobile hamburger button -->
    <button id="mobile-menu-btn"
            class="lg:hidden flex items-center justify-center w-9 h-9 rounded-lg bg-white/10 border border-white/20
                   text-white hover:bg-white/20 transition-all cursor-pointer"
            aria-label={t('nav.menu', lang)}>
      <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-menu-overlay" class="hidden fixed inset-0 bg-black/50 z-[199] lg:hidden"></div>

<!-- Mobile menu drawer -->
<div id="mobile-menu" class="hidden fixed top-14 left-0 right-0 z-[199] bg-navy border-b-2 border-orange
                              max-h-[calc(100vh-3.5rem)] overflow-y-auto lg:hidden">
  <div class="p-4 flex flex-col gap-1">
    {publicMainItems.map(item => (
      <a href={resolveHref(item)}
         data-action="close-mobile"
         class="text-white/80 no-underline text-sm font-medium px-3 py-2.5 rounded-lg
                hover:text-white hover:bg-white/10 transition-all">
        {resolveLabel(item)}
      </a>
    ))}
    <hr class="border-white/10 my-2">
    {authMainItems.map(item => (
      <a href={resolveHref(item)}
         id={`mobile-item-${item.key}`}
         data-action="close-mobile"
         data-nav-key={item.key}
         style="display:none"
         class={`text-white no-underline text-sm font-semibold px-3 py-2.5 rounded-lg transition-all ${
           item.badge === 'crimson' ? 'bg-crimson/20 border border-crimson/40 hover:bg-crimson/30' :
           item.badge === 'purple'  ? 'bg-purple/20 border border-purple/40 hover:bg-purple/30' :
           item.badge === 'teal'    ? 'bg-teal/20 border border-teal/40 hover:bg-teal/30' :
           'hover:bg-white/10'
         }`}>
        {resolveLabel(item)}
      </a>
    ))}
  </div>
</div>

<!-- Pass config and i18n to client -->
<script id="nav-i18n-data" type="application/json" set:html={jsI18n}></script>
<script id="nav-config-data" type="application/json" set:html={navConfigJson}></script>

<script>
  import { getSupabase, ROLE_COLORS } from '../../lib/supabase';
  import { getMemberRole } from '../../lib/routing';
  import { resolveTierFromMember, hasMinimumTier, type AccessTier } from '../../lib/admin/constants';
  import { TIER_RANK } from '../../lib/navigation.config';
  import { canExploreTribes, canSeeInactiveTribes } from '../../lib/tribes/access';

  const sb = getSupabase();
  let _member: any = null;
  let _user: any = null;
  let _tribesCache: any[] | null = null;

  async function loadTribesForDropdown(): Promise<any[]> {
    if (_tribesCache) return _tribesCache;
    try {
      const currentTribeId = Number(_member?.tribe_id || _member?.selected_tribe_id || 0);
      const [{ data: tribes, error: tribesError }, { data: members, error: membersError }] = await Promise.all([
        sb.from('tribes').select('id, name, whatsapp_url').order('id'),
        sb.from('public_members')
          .select('tribe_id, current_cycle_active, is_active')
          .eq('current_cycle_active', true)
          .eq('is_active', true),
      ]);
      if (tribesError) throw tribesError;
      if (membersError) throw membersError;
      const activeCounts = new Map<number, number>();
      (members || []).forEach((member: any) => {
        const tribeId = Number(member?.tribe_id || 0);
        if (tribeId > 0) {
          activeCounts.set(tribeId, (activeCounts.get(tribeId) || 0) + 1);
        }
      });
      _tribesCache = (tribes || []).map((tribe: any) => {
        const activeMembers = activeCounts.get(tribe.id) || 0;
        return {
          ...tribe,
          active_members: activeMembers,
          derived_active: activeMembers > 0 || (currentTribeId > 0 && currentTribeId === tribe.id),
        };
      });
    } catch (error) {
      console.warn('tribe dropdown load failed', error);
      _tribesCache = [];
    }
    return _tribesCache;
  }

  const i18nEl = document.getElementById('nav-i18n-data');
  const i18n = i18nEl ? JSON.parse(i18nEl.textContent || '{}') : {};

  const configEl = document.getElementById('nav-config-data');
  const navConfig: any[] = configEl ? JSON.parse(configEl.textContent || '[]') : [];

  const TIER_LABELS: Record<string, string> = {
    visitor: 'Visitante', member: 'Membro', observer: 'Observador',
    leader: 'Líder', admin: 'Admin', superadmin: 'Superadmin',
  };

  function getItemAccessClient(item: any, tier: AccessTier, designations: string[]): { visible: boolean, enabled: boolean } {
    const meetsMinTier = (TIER_RANK[tier] ?? 0) >= (TIER_RANK[item.minTier as AccessTier] ?? 0);
    const hasDesig = item.allowedDesignations?.length
      ? item.allowedDesignations.some((d: string) => designations.includes(d))
      : false;
    const enabled = meetsMinTier || hasDesig;
    if (item.lgpdSensitive && !enabled) return { visible: false, enabled: false };
    return { visible: true, enabled };
  }

  function isItemVisibleClient(item: any, tier: AccessTier, designations: string[]): boolean {
    return getItemAccessClient(item, tier, designations).visible;
  }

  function resolveMyTribeHref(): string | null {
    if (!_member) return null;
    const tribeId = _member.tribe_id || _member.selected_tribe_id;
    if (!tribeId) return null;
    return `${getNavBase()}/tribe/${tribeId}`;
  }

  function getNavBase(): string {
    return document.documentElement.lang === 'pt-BR' || document.documentElement.lang === 'pt' ? '' :
      document.documentElement.lang === 'en' ? '/en' : '/es';
  }

  function getVisibleTribesForMember(tribes: any[]): any[] {
    if (canSeeInactiveTribes(_member)) return tribes;
    return tribes.filter((tribe: any) => tribe.derived_active !== false);
  }

  function tribeLabel(tribe: any): string {
    return tribe.name || `${i18n.tribePrefix || 'Tribo'} ${tribe.id}`;
  }

  function renderDesktopTribeDropdown(tribes: any[]): string {
    const visibleTribes = getVisibleTribesForMember(tribes);
    if (!visibleTribes.length) {
      return '<div class="px-3 py-2 text-slate-400 text-xs">Nenhuma tribo ativa disponível.</div>';
    }
    const base = getNavBase();
    return visibleTribes.map((tribe: any) => {
      const isInactive = tribe.derived_active === false;
      const countBadge = tribe.active_members > 0
        ? '<span class="ml-auto text-[.62rem] font-bold text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded-full shrink-0">' + tribe.active_members + '</span>'
        : '';
      if (isInactive) {
        return '<div class="flex items-center gap-2 px-3 py-2 text-[.78rem] text-slate-400 font-medium opacity-60 cursor-default" title="Tribo sem membros ativos neste ciclo">'
          + '<span class="w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center text-[.6rem] font-bold text-slate-500 shrink-0">' + tribe.id + '</span>'
          + '<span class="truncate">' + tribeLabel(tribe) + '</span>'
          + '<span class="ml-auto text-[.7rem] shrink-0">&#x1F512;</span>'
          + '</div>';
      }
      return '<a href="' + base + '/tribe/' + tribe.id + '" class="flex items-center gap-2 px-3 py-2 text-[.78rem] text-slate-700 font-medium hover:bg-slate-50 no-underline transition-all">'
        + '<span class="w-5 h-5 rounded-full bg-navy/10 flex items-center justify-center text-[.6rem] font-bold text-navy shrink-0">' + tribe.id + '</span>'
        + '<span class="truncate">' + tribeLabel(tribe) + '</span>'
        + countBadge
        + '</a>';
    }).join('') + '<hr class="border-slate-100 my-1"><a href="' + base + '/#tribes" class="flex items-center gap-2 px-3 py-2 text-[.7rem] text-slate-400 font-medium hover:bg-slate-50 no-underline transition-all"><span class="w-5 h-5 flex items-center justify-center text-[.7rem]">&#x1F30D;</span>' + (i18n.exploreTribes || 'Ver todas') + '</a>';
  }

  function renderDrawerTribeDropdown(tribes: any[]): string {
    const visibleTribes = getVisibleTribesForMember(tribes);
    if (!visibleTribes.length) {
      return '<div class="px-2 py-1.5 text-[.7rem] text-slate-400">Nenhuma tribo ativa disponível.</div>';
    }
    const base = getNavBase();
    return visibleTribes.map((tribe: any) => {
      const isInactive = tribe.derived_active === false;
      if (isInactive) {
        return '<div class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[.73rem] text-slate-400 font-medium opacity-60 cursor-default" title="Tribo sem membros ativos neste ciclo">'
          + '<span class="w-4 h-4 rounded-full bg-slate-200 flex items-center justify-center text-[.55rem] font-bold text-slate-500 shrink-0">' + tribe.id + '</span>'
          + tribeLabel(tribe)
          + ' &#x1F512;'
          + '</div>';
      }
      return '<a href="' + base + '/tribe/' + tribe.id + '" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[.73rem] text-slate-600 font-medium no-underline hover:bg-slate-50 transition-all">'
        + '<span class="w-4 h-4 rounded-full bg-navy/10 flex items-center justify-center text-[.55rem] font-bold text-navy shrink-0">' + tribe.id + '</span>'
        + tribeLabel(tribe)
        + '</a>';
    }).join('');
  }

  function renderMobileTribeDropdown(tribes: any[]): string {
    const visibleTribes = getVisibleTribesForMember(tribes);
    if (!visibleTribes.length) {
      return '<div class="px-4 py-2.5 text-white/50 text-sm">Nenhuma tribo ativa disponível.</div>';
    }
    const base = getNavBase();
    return visibleTribes.map((tribe: any) => {
      const isInactive = tribe.derived_active === false;
      if (isInactive) {
        return '<div class="flex items-center gap-2 px-4 py-2.5 text-white/30 text-sm font-medium opacity-50 cursor-default" title="Tribo sem membros ativos neste ciclo">'
          + '<span class="w-5 h-5 rounded-full bg-white/10 flex items-center justify-center text-[.6rem] font-bold shrink-0">' + tribe.id + '</span>'
          + tribeLabel(tribe)
          + ' &#x1F512;'
          + '</div>';
      }
      return '<a href="' + base + '/tribe/' + tribe.id + '" data-action="close-mobile" class="flex items-center gap-2 px-4 py-2.5 text-white/80 text-sm font-medium no-underline hover:bg-white/10 transition-all">'
        + '<span class="w-5 h-5 rounded-full bg-white/10 flex items-center justify-center text-[.6rem] font-bold shrink-0">' + tribe.id + '</span>'
        + tribeLabel(tribe)
        + '</a>';
    }).join('');
  }

  function updateNavVisibility() {
    if (!_member) return;
    const tier = resolveTierFromMember(_member);
    const desigs: string[] = _member.designations || [];

    navConfig.forEach((item: any) => {
      if (!item.requiresAuth) return;

      const access = getItemAccessClient(item, tier, desigs);

      const desktopEl = document.getElementById(`nav-item-${item.key}`);
      const mobileEl = document.getElementById(`mobile-item-${item.key}`);

      if (desktopEl) {
        desktopEl.style.display = access.visible ? 'inline-flex' : 'none';
        if (access.visible && !access.enabled) {
          desktopEl.classList.add('opacity-40', 'pointer-events-none');
          desktopEl.setAttribute('title', `Requer ${TIER_LABELS[item.minTier] || item.minTier}`);
          desktopEl.setAttribute('aria-disabled', 'true');
          desktopEl.innerHTML = (desktopEl.textContent || '') + ' <svg class="w-3 h-3 inline-block ml-0.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>';
        } else if (access.visible && access.enabled) {
          desktopEl.classList.remove('opacity-40', 'pointer-events-none');
          desktopEl.removeAttribute('aria-disabled');
        }
      }
      if (mobileEl) {
        mobileEl.style.display = access.visible ? 'block' : 'none';
        if (access.visible && !access.enabled) {
          mobileEl.classList.add('opacity-40', 'pointer-events-none');
          mobileEl.setAttribute('title', `Requer ${TIER_LABELS[item.minTier] || item.minTier}`);
        } else if (access.visible && access.enabled) {
          mobileEl.classList.remove('opacity-40', 'pointer-events-none');
        }
      }

      if (access.visible && access.enabled && item.dynamic && item.resolver === 'resolveMyTribeHref') {
        const href = resolveMyTribeHref();
        const canBrowseTribes = canExploreTribes(_member);
        if (href) {
          if (desktopEl) { desktopEl.setAttribute('href', href); desktopEl.classList.remove('opacity-50', 'pointer-events-none'); desktopEl.textContent = i18n.myTribe || 'Minha Tribo'; }
          if (mobileEl) { mobileEl.setAttribute('href', href); mobileEl.classList.remove('opacity-50', 'pointer-events-none'); if (mobileEl.querySelector('span')) { mobileEl.querySelector('span')!.textContent = i18n.myTribe || 'Minha Tribo'; } }
        } else if (canBrowseTribes) {
          // Desktop: inject dropdown trigger
          if (desktopEl) {
            desktopEl.style.display = 'inline-flex';
            desktopEl.classList.remove('opacity-50', 'pointer-events-none');
            desktopEl.removeAttribute('href');
            desktopEl.setAttribute('data-action', 'toggle-tribe-dropdown');
            desktopEl.setAttribute('role', 'button');
            desktopEl.setAttribute('aria-haspopup', 'true');
            desktopEl.setAttribute('aria-expanded', 'false');
            desktopEl.innerHTML = (i18n.exploreTribes || 'Explorar Tribos') + ' <span class="text-[.55rem] ml-0.5 opacity-60">&#x25BE;</span>';
            // Create dropdown container if missing
            if (!document.getElementById('tribe-dropdown')) {
              var dd = document.createElement('div');
              dd.id = 'tribe-dropdown';
              dd.className = 'hidden absolute top-full mt-1 right-0 w-56 bg-white rounded-xl shadow-xl border border-slate-200 py-1.5 z-[300] max-h-[60vh] overflow-y-auto';
              dd.innerHTML = '<div class="px-3 py-2 text-slate-400 text-xs">Loading...</div>';
              desktopEl.style.position = 'relative';
              desktopEl.appendChild(dd);
            }
          }
          // Mobile: same approach
          if (mobileEl) {
            mobileEl.style.display = 'block';
            mobileEl.classList.remove('opacity-50', 'pointer-events-none');
            mobileEl.removeAttribute('href');
            mobileEl.setAttribute('data-action', 'toggle-tribe-dropdown-mobile');
            mobileEl.setAttribute('role', 'button');
            if (mobileEl.querySelector('span')) { mobileEl.querySelector('span')!.textContent = (i18n.exploreTribes || 'Explorar Tribos') + ' ▾'; }
            else { mobileEl.textContent = (i18n.exploreTribes || 'Explorar Tribos') + ' ▾'; }
            if (!document.getElementById('tribe-dropdown-mobile')) {
              var ddm = document.createElement('div');
              ddm.id = 'tribe-dropdown-mobile';
              ddm.className = 'hidden mt-1 bg-white/10 rounded-lg overflow-hidden';
              mobileEl.parentElement?.insertBefore(ddm, mobileEl.nextSibling);
            }
          }
        } else {
          if (desktopEl) { desktopEl.setAttribute('href', '/#tribes'); desktopEl.classList.add('opacity-50', 'pointer-events-none'); desktopEl.style.display = 'inline-flex'; }
          if (mobileEl) { mobileEl.setAttribute('href', '/#tribes'); mobileEl.classList.add('opacity-50', 'pointer-events-none'); mobileEl.style.display = 'block'; }
        }
      }
    });
  }

  function getRoleLabel(role: string): string {
    const roleLabelsEl = document.getElementById('role-labels-data');
    if (roleLabelsEl) {
      const labels = JSON.parse(roleLabelsEl.textContent || '{}');
      return labels[role] || role;
    }
    return role;
  }

  function renderAuth() {
    if (!_member || getMemberRole(_member) === 'guest') {
      if (_user) { renderGuestWithSession(); } else { renderLoggedOut(); }
      return;
    }
    const name = _member.name || i18n.user || 'User';
    const first = name.split(' ')[0];
    const initials = name.split(' ').map((w: string) => w[0]).join('').substring(0,2).toUpperCase();
    const pic = _user?.user_metadata?.avatar_url;
    const r = getMemberRole(_member);
    const color = ROLE_COLORS[r] || '#64748B';
    const label = getRoleLabel(r);

    const el = document.getElementById('nav-auth');
    if (!el) return;
    el.innerHTML = `
      <button data-action="toggle-pd"
        class="flex items-center gap-1.5 px-1.5 py-1 rounded-lg hover:bg-white/10 transition-all cursor-pointer border-0 bg-transparent">
        ${pic
          ? `<img src="${pic}" class="w-7 h-7 rounded-full object-cover" onerror="this.style.display='none'">`
          : `<div class="w-7 h-7 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.65rem]">${initials}</div>`
        }
        <span class="text-white text-[.8rem] font-semibold hidden sm:inline">${first}</span>
        <span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded uppercase hidden sm:inline" style="background:${color}33;color:${color}">${label}</span>
        <span class="text-white/40 text-[.6rem]">▾</span>
      </button>`;

    updateNavVisibility();
    buildDrawer();
  }

  function renderLoggedOut() {
    const el = document.getElementById('nav-auth');
    if (el) el.innerHTML = `
      <button data-action="open-auth"
        class="px-3 py-1.5 rounded-lg bg-white/10 border border-white/20 text-white text-[.78rem] font-semibold hover:bg-white/20 transition-all cursor-pointer">
        ${i18n.login || 'Sign In'}
      </button>`;
  }

  function renderGuestWithSession() {
    const el = document.getElementById('nav-auth');
    if (!el) return;
    el.innerHTML = `
      <div class="flex items-center gap-2">
        <span class="text-amber-400 text-[.73rem] font-semibold hidden sm:inline">${i18n.guestNotFound || 'Conta não cadastrada'}</span>
        <button data-action="logout"
          class="px-2.5 py-1 rounded-lg bg-white/10 border border-white/20 text-white text-[.7rem] font-semibold hover:bg-white/20 transition-all cursor-pointer">
          ${i18n.logout || '↩ Sair'}
        </button>
      </div>`;
  }

  function buildDrawer() {
    const el = document.getElementById('pd-inner');
    if (!el || !_member) return;

    const name = _member.name || i18n.user || 'User';
    const initials = name.split(' ').map((w: string) => w[0]).join('').substring(0,2).toUpperCase();
    const pic = _user?.user_metadata?.avatar_url;
    const r = getMemberRole(_member);
    const color = ROLE_COLORS[r] || '#64748B';
    const tier = resolveTierFromMember(_member);
    const desigs: string[] = _member.designations || [];
    const base = document.documentElement.lang === 'pt-BR' || document.documentElement.lang === 'pt' ? '' :
                 document.documentElement.lang === 'en' ? '/en' : '/es';

    const drawerItems = navConfig.filter((item: any) =>
      (item.section === 'drawer' || item.section === 'both') &&
      item.requiresAuth &&
      getItemAccessClient(item, tier, desigs).visible
    );

    const profileItems = drawerItems.filter((i: any) => i.group === 'profile');
    const memberItems = drawerItems.filter((i: any) => i.group === 'member');
    const adminItems = drawerItems.filter((i: any) => i.group === 'admin');
    const adminSubItems = drawerItems.filter((i: any) => i.group === 'admin-sub');

    const DRAWER_ICONS: Record<string, string> = {
      profile: '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>',
      attendance: '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>',
      'my-tribe': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
      admin: '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
      'admin-comms': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>',
      'admin-webinars': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>',
      'admin-analytics': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
      'admin-curatorship': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      'admin-selection': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
      'admin-settings': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
      'admin-help': '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      help: '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
      onboarding: '<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>',
    };

    function drawerLink(item: any, extraClass: string = ''): string {
      const access = getItemAccessClient(item, tier, desigs);
      let href = base + item.href;
      let disabledClass = '';
      let labelOverride = '';
      let lockSuffix = '';
      if (access.visible && !access.enabled) {
        disabledClass = ' opacity-40 pointer-events-none';
        lockSuffix = ' <svg class="w-3 h-3 inline-block ml-auto opacity-50 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>';
      }
      if (item.dynamic && item.resolver === 'resolveMyTribeHref') {
        const resolved = resolveMyTribeHref();
        if (!resolved) {
          href = '/#tribes';
          if (canExploreTribes(_member)) {
            labelOverride = i18n.exploreTribes || 'Explorar Tribos';
            const icon = DRAWER_ICONS[item.key] || '';
            return '<div class="drawer-tribe-group">'
              + '<button data-action="toggle-drawer-tribes" class="flex items-center gap-2 w-full px-2 py-1.5 rounded-lg text-[.78rem] font-semibold cursor-pointer border-0 bg-transparent transition-all ' + extraClass + '">'
              + icon + '<span>' + labelOverride + '</span><span class="ml-auto text-[.6rem] opacity-50 drawer-tribe-chevron">&#x25B6;</span></button>'
              + '<div id="drawer-tribe-list" class="hidden ml-6 mt-1 flex flex-col gap-0.5"></div>'
              + '</div>';
          } else {
            disabledClass = ' opacity-50 pointer-events-none';
          }
        } else {
          href = resolved;
        }
      }
      const label = labelOverride || i18n[toCamelKey(item.key)] || item.labelKey;
      const icon = DRAWER_ICONS[item.key] || '';
      const titleAttr = !access.enabled ? ' title="Requer ' + (TIER_LABELS[item.minTier] || item.minTier) + '"' : '';
      return '<a href="' + href + '"' + titleAttr + ' class="flex items-center gap-2 w-full px-2 py-1.5 rounded-lg text-[.78rem] font-semibold no-underline transition-all ' + extraClass + disabledClass + '">' + icon + '<span>' + label + '</span>' + lockSuffix + '</a>';
    }

    function toCamelKey(key: string): string {
      return key.replace(/-([a-z])/g, (_, c) => c.toUpperCase());
    }

    let html = `
      <div class="flex items-center gap-3 mb-2">
        ${pic
          ? `<img src="${pic}" class="w-12 h-12 rounded-full object-cover flex-shrink-0">`
          : `<div class="w-12 h-12 rounded-full bg-teal flex items-center justify-center text-white font-bold text-sm flex-shrink-0">${initials}</div>`
        }
        <div class="min-w-0">
          <div class="font-bold text-[.9rem] text-navy">${name}</div>
          <span class="text-[.62rem] font-bold px-1.5 py-0.5 rounded inline-block mt-0.5" style="background:${color}22;color:${color}">${getRoleLabel(r)}</span>
          <div class="text-[.67rem] text-slate-500 truncate mt-0.5">${_member.email||''}</div>
        </div>
      </div>
      <hr class="border-slate-100 my-2">`;

    profileItems.forEach((item: any) => { html += drawerLink(item, 'text-slate-800 hover:bg-slate-50'); });
    memberItems.forEach((item: any) => { html += drawerLink(item, 'text-slate-800 hover:bg-slate-50'); });

    if (adminItems.length || adminSubItems.length) {
      html += '<hr class="border-slate-100 my-2">';
      adminItems.forEach((item: any) => { html += drawerLink(item, 'text-purple hover:bg-purple/5'); });
      adminSubItems.forEach((item: any) => { html += drawerLink(item, 'text-slate-600 hover:bg-slate-50 pl-4'); });
    }

    html += `<hr class="border-slate-100 my-2">
      <button data-action="logout" class="flex items-center gap-2 w-full px-2 py-1.5 rounded-lg text-[.78rem] font-semibold text-crimson hover:bg-red-50 cursor-pointer border-0 bg-transparent transition-all">${i18n.logout || '↩ Sign Out'}</button>`;

    el.innerHTML = html;
  }

  // ── Event delegation (no inline onclick per .cursorrules) ──
  document.addEventListener('click', (e: MouseEvent) => {
    const target = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
    if (!target) return;
    const action = target.dataset.action;

    if (action === 'toggle-tribe-dropdown') {
      e.preventDefault(); e.stopPropagation();
      var dd = document.getElementById('tribe-dropdown');
      if (!dd) return;
      var isOpen = !dd.classList.contains('hidden');
      dd.classList.toggle('hidden');
      target.setAttribute('aria-expanded', String(!isOpen));
      if (!isOpen) {
        loadTribesForDropdown().then(function(tribes) {
          dd!.innerHTML = renderDesktopTribeDropdown(tribes);
        });
      }
    }
    if (action === 'toggle-drawer-tribes') {
      e.preventDefault();
      var dtl = document.getElementById('drawer-tribe-list');
      var chev = target.querySelector('.drawer-tribe-chevron');
      if (!dtl) return;
      var isOpenD = !dtl.classList.contains('hidden');
      dtl.classList.toggle('hidden');
      if (chev) chev.innerHTML = isOpenD ? '&#x25B6;' : '&#x25BC;';
      if (!isOpenD && !dtl.dataset.loaded) {
        dtl.dataset.loaded = '1';
        loadTribesForDropdown().then(function(tribes) {
          dtl!.innerHTML = renderDrawerTribeDropdown(tribes);
        });
      }
    }
    if (action === 'toggle-tribe-dropdown-mobile') {
      e.preventDefault();
      var ddm = document.getElementById('tribe-dropdown-mobile');
      if (!ddm) return;
      var isOpenM = !ddm.classList.contains('hidden');
      ddm.classList.toggle('hidden');
      if (!isOpenM) {
        loadTribesForDropdown().then(function(tribes) {
          ddm!.innerHTML = renderMobileTribeDropdown(tribes);
        });
      }
    }
    if (action === 'open-auth') {
      document.dispatchEvent(new CustomEvent('open-auth'));
    }
    if (action === 'toggle-pd') {
      (window as any).togglePD?.();
    }
    if (action === 'close-mobile') {
      (window as any).closeMobileMenu?.();
    }
    if (action === 'toggle-mobile') {
      (window as any).toggleMobileMenu?.();
    }
    if (action === 'logout') {
      (window as any).doLogout?.();
    }
  });

  // ── Mobile menu ──
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    (window as any).toggleMobileMenu?.();
  });
  document.getElementById('mobile-menu-overlay')?.addEventListener('click', () => {
    (window as any).closeMobileMenu?.();
  });

  (window as any).toggleMobileMenu = () => {
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-menu-overlay');
    const hamburger = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    if (!menu) return;
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    overlay?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  };
  (window as any).closeMobileMenu = () => {
    document.getElementById('mobile-menu')?.classList.add('hidden');
    document.getElementById('mobile-menu-overlay')?.classList.add('hidden');
    document.getElementById('hamburger-icon')?.classList.remove('hidden');
    document.getElementById('close-icon')?.classList.add('hidden');
  };

  // ── Profile drawer globals ──
  (window as any).togglePD = () => {
    const d = document.getElementById('pd-drawer');
    const o = document.getElementById('pd-overlay');
    if (!d) return;
    const on = d.dataset.open !== 'true';
    d.dataset.open = String(on);
    o?.classList.toggle('hidden', !on);
  };
  (window as any).closePD = () => {
    const d = document.getElementById('pd-drawer');
    const o = document.getElementById('pd-overlay');
    if (d) d.dataset.open = 'false';
    o?.classList.add('hidden');
  };
  document.getElementById('pd-overlay')?.addEventListener('click', () => {
    (window as any).closePD?.();
  });
  (window as any).doLogout = async () => {
    await sb.auth.signOut();
    location.href = '/';
  };
  (window as any).openAuthModal = () => {
    document.getElementById('auth-modal')?.classList.remove('hidden');
  };
  (window as any).navGetMember = () => _member;
  (window as any).navGetUser = () => _user;
  (window as any).navGetSb = () => sb;

  // ── Boot ──
  // Close tribe dropdown on outside click
  document.addEventListener('click', function(ev: MouseEvent) {
    var dd = document.getElementById('tribe-dropdown');
    if (dd && !dd.classList.contains('hidden')) {
      var trigger = dd.parentElement;
      if (trigger && !trigger.contains(ev.target as Node)) {
        dd.classList.add('hidden');
        trigger.setAttribute('aria-expanded', 'false');
      }
    }
  }, true);

  // Close on Escape
  document.addEventListener('keydown', function(ev: KeyboardEvent) {
    if (ev.key === 'Escape') {
      var dd = document.getElementById('tribe-dropdown');
      if (dd && !dd.classList.contains('hidden')) {
        dd.classList.add('hidden');
        dd.parentElement?.setAttribute('aria-expanded', 'false');
      }
    }
  });

  async function bootNav() {
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      _user = session.user;
      const { data } = await sb.rpc('get_member_by_auth');
      _member = data;
      renderAuth();
      window.dispatchEvent(new CustomEvent('nav:member', { detail: _member }));
      if (!_member || getMemberRole(_member) === 'guest') {
        window.dispatchEvent(new CustomEvent('nav:guest-with-session', { detail: { user: _user } }));
      }
    }
    sb.auth.onAuthStateChange(async (event, session) => {
      if (event === 'INITIAL_SESSION' || event === 'SIGNED_IN') {
        _user = session?.user ?? null;
        if (_user && !_member) {
          const { data } = await sb.rpc('get_member_by_auth');
          _member = data;
          renderAuth();
          window.dispatchEvent(new CustomEvent('nav:member', { detail: _member }));
          if (!_member || getMemberRole(_member) === 'guest') {
            window.dispatchEvent(new CustomEvent('nav:guest-with-session', { detail: { user: _user } }));
          }
        }
      }
      if (event === 'SIGNED_OUT') {
        _member = null; _user = null;
        renderLoggedOut();
        window.dispatchEvent(new CustomEvent('nav:member', { detail: null }));
      }
    });
  }

  bootNav();
</script>
