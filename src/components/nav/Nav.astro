---
/**
 * GOVERNANÇA: A atualização da árvore de navegação neste arquivo é
 * Critério de Aceite obrigatório para qualquer nova feature ou página.
 *
 * A estrutura de menus é lida de src/lib/navigation.config.ts.
 * Não hardcode regras de acesso aqui — use minTier e allowedDesignations no config.
 */
import { t, type Lang } from '../../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import GlobalSearchIsland from '../ui/GlobalSearchIsland';
import { NAV_ITEMS, type NavItem } from '../../lib/navigation.config';

interface Props { activePage?: string; lang?: Lang; }
const { activePage = '', lang = 'pt-BR' } = Astro.props;
const currentPath = Astro.url.pathname;

const base = lang === 'pt-BR' ? '' : lang === 'en-US' ? '/en' : '/es';

const mainItems = NAV_ITEMS.filter(i => i.section === 'main' || i.section === 'both');
const publicMainItems = mainItems.filter(i => !i.requiresAuth);
const authMainItems = mainItems.filter(i => i.requiresAuth);

function resolveLabel(item: NavItem): string {
  return t(item.labelKey, lang);
}

function resolveHref(item: NavItem): string {
  if (item.disabled) return '#';
  if (item.dynamic) return '#';
  return base + item.href;
}

function badgeClasses(item: NavItem, isActive: boolean): string {
  const map: Record<string, { active: string; inactive: string }> = {
    crimson: {
      active:   'bg-crimson/30 border border-crimson/50 text-white',
      inactive: 'bg-crimson/20 border border-crimson/40 text-white hover:bg-crimson/30',
    },
    purple: {
      active:   'bg-purple/30 border border-purple/50 text-white',
      inactive: 'bg-purple/20 border border-purple/40 text-white hover:bg-purple/30',
    },
    teal: {
      active:   'bg-teal/30 border border-teal/50 text-white',
      inactive: 'bg-teal/20 border border-teal/40 text-white hover:bg-teal/30',
    },
  };
  const badge = item.badge;
  if (!badge || !map[badge]) {
    return 'text-white/70 hover:text-white hover:bg-white/10';
  }
  return isActive ? map[badge].active : map[badge].inactive;
}

const jsI18n = JSON.stringify({
  login: t('nav.login', lang),
  profile: t('nav.profile', lang),
  attendance: t('nav.attendanceLink', lang),
  admin: t('nav.adminLink', lang),
  adminPanel: t('nav.adminPanel', lang),
  adminAnalytics: t('nav.adminAnalytics', lang),
  adminComms: t('nav.adminComms', lang),
  adminCommsOps: t('nav.adminCommsOps', lang),
  adminPortfolio: t('nav.adminPortfolio', lang),
  adminBoardGovernance: t('nav.adminBoardGovernance', lang),
  adminHelp: t('nav.adminHelp', lang),
  help: t('nav.adminHelp', lang),
  onboarding: t('nav.onboarding', lang),
  adminWebinars: t('nav.adminWebinars', lang),
  adminCuratorship: t('nav.adminCuratorship', lang),
  adminSelection: t('nav.adminSelection', lang),
  adminSettings: t('nav.adminSettings', lang),
  adminCycleReport: t('nav.adminCycleReport', lang),
  adminPartnerships: t('nav.adminPartnerships', lang),
  adminChapterReport: t('nav.adminChapterReport', lang),
  adminSustainability: t('nav.adminSustainability', lang),
  adminCrossTribes: t('nav.adminCrossTribes', lang),
  adminTribeDashboard: t('nav.adminTribeDashboard', lang),
  adminCampaigns: t('nav.adminCampaigns', lang),
  adminBlog: t('nav.adminBlog', lang),
  notifications: t('nav.notifications', lang),
  webinars: t('nav.adminWebinars', lang),
  publications: t('nav.publications', lang),
  boardComms: t('nav.boardComms', lang),
  boardPublications: t('nav.boardPublications', lang),
  presentations: t('nav.presentations', lang),
  myTribe: t('nav.myTribe', lang),
  exploreTribes: t('nav.exploreTribes', lang),
  tribePrefix: t('workspace.tribePrefix', lang),
  logout: t('nav.logout', lang),
  privacy: t('nav.privacy', lang),
  help: t('nav.help', lang),
  user: t('nav.user', lang),
  guestNotFound: t('guest.navNotFound', lang),
  drawerMeuEspaco: t('nav.drawerSection.meuEspaco', lang),
  drawerMinhaTribo: t('nav.drawerSection.minhaTribo', lang),
  drawerProducao: t('nav.drawerSection.producao', lang),
  drawerExplorar: t('nav.drawerSection.explorar', lang),
  drawerAdmin: t('nav.drawerSection.admin', lang),
  sectionsDropdown: t('nav.sectionsDropdown', lang),
  workspace: t('nav.workspace', lang),
  tierVisitor: t('comp.nav.visitor', lang),
  tierMember: t('comp.nav.member', lang),
  tierObserver: t('comp.nav.observer', lang),
  tierLeader: t('nav.tribeLeader', lang),
  tierAdmin: 'Admin',
  tierSuperadmin: 'Superadmin',
});

const homeAnchorItems = mainItems.filter(i => i.group === 'home-anchors');
const primaryPublicItems = publicMainItems.filter(i => (i as any).navSlot === 'primary');
const primaryAuthItems = authMainItems.filter(i => (i as any).navSlot === 'primary');
const isHomePage = currentPath === '/' || currentPath === '/en/' || currentPath === '/es/';
const visitorNavItems = isHomePage
  ? primaryPublicItems
  : [...homeAnchorItems.filter(i => ['tribes', 'trail'].includes(i.key)), ...primaryPublicItems];

const navConfigJson = JSON.stringify(NAV_ITEMS);
const runtimeEnv = ((Astro.locals as any)?.runtime?.env ?? {}) as Record<string, string | undefined>;
const NAV_PUBLIC_SUPABASE_URL = (import.meta.env.PUBLIC_SUPABASE_URL || runtimeEnv.PUBLIC_SUPABASE_URL || '').trim();
const NAV_PUBLIC_SUPABASE_ANON_KEY = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY || runtimeEnv.PUBLIC_SUPABASE_ANON_KEY || '').trim();
---

<nav class="sticky top-0 z-[200] bg-navy/97 backdrop-blur-md border-b-2 border-orange
            px-4 sm:px-6 flex items-center justify-between h-14">
  <a href={base + "/"} class="text-white font-bold text-sm no-underline flex-shrink-0">
    <Fragment set:html={t('nav.brand', lang).replace('IA & GP', '<span class="text-orange">IA & GP</span>')} />
  </a>

  <!-- Desktop links -->
  <div class="hidden lg:flex items-center gap-0.5" id="nav-links">
    {isHomePage && (
      <div class="relative" id="sections-dropdown-wrapper">
        <button data-action="toggle-sections-dropdown"
          class="text-[.73rem] font-medium px-2 py-1.5 rounded-md text-white/70 hover:text-white hover:bg-white/10 transition-all cursor-pointer border-0 bg-transparent flex items-center gap-0.5">
          {t('nav.sectionsDropdown', lang)} <span class="text-[.55rem] opacity-60">▾</span>
        </button>
        <div id="sections-dropdown" class="hidden absolute top-full left-0 mt-1 w-48 bg-[var(--surface-elevated)] rounded-xl shadow-xl border border-[var(--border-default)] py-1.5 z-[300]">
          {homeAnchorItems.map(item => (
            <a href={resolveHref(item)} class="block px-3 py-1.5 text-[.78rem] text-[var(--text-primary)] font-medium hover:bg-[var(--surface-hover)] no-underline transition-all">
              {resolveLabel(item)}
            </a>
          ))}
        </div>
      </div>
    )}
    {visitorNavItems.map(item => (
      item.disabled ? (
        <span class={`text-[.73rem] font-medium px-2 py-1.5 rounded-md transition-all duration-150 opacity-50 cursor-default ${badgeClasses(item, false)}`}>
          {resolveLabel(item)}
        </span>
      ) : (
        <a href={resolveHref(item)}
           class={`text-[.73rem] font-medium px-2 py-1.5 rounded-md no-underline transition-all duration-150 ${badgeClasses(item, false)}`}>
          {resolveLabel(item)}
        </a>
      )
    ))}
    {primaryAuthItems.map(item => (
      <a href={resolveHref(item)}
         id={`nav-item-${item.key}`}
         style="display:none"
         data-nav-key={item.key}
         class={`text-[.73rem] font-semibold px-2 py-1.5 rounded-md no-underline transition-all ${badgeClasses(item, activePage === item.key)}`}>
        {resolveLabel(item)}
      </a>
    ))}
  </div>

  <div class="flex items-center gap-2">
    <div class="hidden sm:block">
      <GlobalSearchIsland client:load />
    </div>
    <LangSwitcher currentLang={lang} currentPath={currentPath} />

    <!-- Auth area: populated by client script -->
    <div id="nav-auth" class="flex items-center gap-2 flex-shrink-0">
      <button data-action="open-auth"
              class="px-3 py-1.5 rounded-lg bg-white/10 border border-white/20
                     text-white text-[.78rem] font-semibold hover:bg-white/20 transition-all cursor-pointer"
              id="nav-login-btn">
        {t('nav.login', lang)}
      </button>
    </div>

    <!-- Mobile hamburger button -->
    <button id="mobile-menu-btn"
            class="lg:hidden flex items-center justify-center w-9 h-9 rounded-lg bg-white/10 border border-white/20
                   text-white hover:bg-white/20 transition-all cursor-pointer"
            aria-label={t('nav.menu', lang)}>
      <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-menu-overlay" class="hidden fixed inset-0 bg-black/50 z-[199] lg:hidden"></div>

<!-- Mobile menu drawer -->
<div id="mobile-menu" class="hidden fixed top-14 left-0 right-0 z-[199] bg-navy border-b-2 border-orange
                              max-h-[calc(100vh-3.5rem)] overflow-y-auto lg:hidden">
  <div class="p-4 flex flex-col gap-1">
    {isHomePage && (
      <div class="mb-1">
        <div class="text-white/40 text-[.6rem] font-bold uppercase tracking-wider px-3 py-1">{t('nav.sectionsDropdown', lang)}</div>
        {homeAnchorItems.map(item => (
          <a href={resolveHref(item)}
             data-action="close-mobile"
             class="text-white/80 no-underline text-sm font-medium px-3 py-2.5 rounded-lg
                    hover:text-white hover:bg-white/10 transition-all block">
            {resolveLabel(item)}
          </a>
        ))}
        <hr class="border-white/10 my-2">
      </div>
    )}
    {visitorNavItems.map(item => (
      item.disabled ? (
        <span class="text-white/60 text-sm font-medium px-3 py-2.5 rounded-lg opacity-50 cursor-default">
          {resolveLabel(item)}
        </span>
      ) : (
        <a href={resolveHref(item)}
           data-action="close-mobile"
           class="text-white/80 no-underline text-sm font-medium px-3 py-2.5 rounded-lg
                  hover:text-white hover:bg-white/10 transition-all">
          {resolveLabel(item)}
        </a>
      )
    ))}
    <hr class="border-white/10 my-2">
    {primaryAuthItems.map(item => (
      <a href={resolveHref(item)}
         id={`mobile-item-${item.key}`}
         data-action="close-mobile"
         data-nav-key={item.key}
         style="display:none"
         class={`text-white no-underline text-sm font-semibold px-3 py-2.5 rounded-lg transition-all ${
           item.badge === 'crimson' ? 'bg-crimson/20 border border-crimson/40 hover:bg-crimson/30' :
           item.badge === 'purple'  ? 'bg-purple/20 border border-purple/40 hover:bg-purple/30' :
           item.badge === 'teal'    ? 'bg-teal/20 border border-teal/40 hover:bg-teal/30' :
           'hover:bg-white/10'
         }`}>
        {resolveLabel(item)}
      </a>
    ))}
  </div>
</div>

<!-- Pass config and i18n to client -->
<script id="nav-i18n-data" type="application/json" set:html={jsI18n}></script>
<script id="nav-config-data" type="application/json" set:html={navConfigJson}></script>
<script is:inline define:vars={{ NAV_PUBLIC_SUPABASE_URL, NAV_PUBLIC_SUPABASE_ANON_KEY }}>
  window.__PUBLIC_SUPABASE_URL = NAV_PUBLIC_SUPABASE_URL || '';
  window.__PUBLIC_SUPABASE_ANON_KEY = NAV_PUBLIC_SUPABASE_ANON_KEY || '';
</script>

<script>
  import { getSupabase, ROLE_COLORS, setSupabaseRuntimeConfig } from '../../lib/supabase';
  import { getMemberRole } from '../../lib/routing';
  import { resolveTierFromMember, hasMinimumTier, type AccessTier } from '../../lib/admin/constants';
  import { TIER_RANK } from '../../lib/navigation.config';
  import { canExploreTribes, canSeeInactiveTribes } from '../../lib/tribes/access';
  import { buildTribeLabel, isRuntimeTribeActive } from '../../lib/tribes/catalog';

  // Ensure runtime-injected env is available before creating the client.
  setSupabaseRuntimeConfig(
    String((window as any).__PUBLIC_SUPABASE_URL || ''),
    String((window as any).__PUBLIC_SUPABASE_ANON_KEY || '')
  );
  const sb = getSupabase();
  let _member: any = null;
  let _user: any = null;
  let _tribesCache: any[] | null = null;

  async function loadTribesForDropdown(): Promise<any[]> {
    if (_tribesCache) return _tribesCache;
    try {
      const currentTribeId = Number(_member?.tribe_id || _member?.selected_tribe_id || 0);
      const [{ data: tribes, error: tribesError }, { data: members, error: membersError }] = await Promise.all([
        sb.from('tribes').select('id, name, whatsapp_url, quadrant, quadrant_name, is_active, workstream_type').order('id'),
        sb.from('public_members')
          .select('tribe_id, current_cycle_active, is_active')
          .eq('current_cycle_active', true)
          .eq('is_active', true),
      ]);
      if (tribesError) throw tribesError;
      if (membersError) throw membersError;
      const activeCounts = new Map<number, number>();
      (members || []).forEach((member: any) => {
        const tribeId = Number(member?.tribe_id || 0);
        if (tribeId > 0) {
          activeCounts.set(tribeId, (activeCounts.get(tribeId) || 0) + 1);
        }
      });
      _tribesCache = (tribes || []).map((tribe: any) => {
        const activeMembers = activeCounts.get(tribe.id) || 0;
        const explicitlyActive = isRuntimeTribeActive(tribe);
        return {
          ...tribe,
          active_members: activeMembers,
          derived_active: explicitlyActive && (activeMembers > 0 || (currentTribeId > 0 && currentTribeId === tribe.id)),
          is_active: explicitlyActive,
        };
      });
    } catch (error) {
      console.warn('tribe dropdown load failed', error);
      _tribesCache = [];
    }
    return _tribesCache;
  }

  const i18nEl = document.getElementById('nav-i18n-data');
  const i18n = i18nEl ? JSON.parse(i18nEl.textContent || '{}') : {};

  const configEl = document.getElementById('nav-config-data');
  const navConfig: any[] = configEl ? JSON.parse(configEl.textContent || '[]') : [];

  const TIER_LABELS: Record<string, string> = {
    visitor: i18n.tierVisitor || 'Visitante',
    member: i18n.tierMember || 'Membro',
    observer: i18n.tierObserver || 'Observador',
    leader: i18n.tierLeader || 'Líder',
    admin: i18n.tierAdmin || 'Admin',
    superadmin: i18n.tierSuperadmin || 'Superadmin',
  };

  function getItemAccessClient(item: any, tier: AccessTier, designations: string[]): { visible: boolean, enabled: boolean } {
    const meetsMinTier = (TIER_RANK[tier] ?? 0) >= (TIER_RANK[item.minTier as AccessTier] ?? 0);
    const hasDesig = item.allowedDesignations?.length
      ? item.allowedDesignations.some((d: string) => designations.includes(d))
      : false;
    const hasOpRole = item.allowedOperationalRoles?.length
      ? item.allowedOperationalRoles.includes(String(_member?.operational_role || ''))
      : false;
    const enabled = meetsMinTier || hasDesig || hasOpRole;
    if (item.lgpdSensitive && !enabled) return { visible: false, enabled: false };
    return { visible: true, enabled };
  }

  function isItemVisibleClient(item: any, tier: AccessTier, designations: string[]): boolean {
    return getItemAccessClient(item, tier, designations).visible;
  }

  function resolveMyTribeHref(): string | null {
    if (!_member) return null;
    const tribeId = _member.tribe_id || _member.selected_tribe_id;
    if (!tribeId) return null;
    return `${getNavBase()}/tribe/${tribeId}?tab=board`;
  }

  function getNavBase(): string {
    return document.documentElement.lang === 'pt-BR' || document.documentElement.lang === 'pt' ? '' :
      document.documentElement.lang === 'en' ? '/en' : '/es';
  }

  function getVisibleTribesForMember(tribes: any[]): any[] {
    if (canSeeInactiveTribes(_member)) return tribes;
    return tribes.filter((tribe: any) => tribe.is_active !== false);
  }

  function getResearchTribes(tribes: any[]): any[] {
    return getVisibleTribesForMember(tribes).filter((tribe: any) => String(tribe.workstream_type || 'research') === 'research');
  }

  function tribeLabel(tribe: any): string {
    return buildTribeLabel(tribe, { prefix: i18n.tribePrefix || 'Tribo' });
  }

  function categorizeTribeGroups(tribes: any[]): { research: any[], operational: any[], legacy: any[] } {
    const visible = getVisibleTribesForMember(tribes);
    return {
      research: visible.filter((t: any) => t.is_active !== false && String(t.workstream_type || 'research') === 'research'),
      operational: visible.filter((t: any) => t.is_active !== false && String(t.workstream_type || '') === 'operational'),
      legacy: visible.filter((t: any) => t.is_active === false),
    };
  }

  function renderDesktopTribeDropdown(tribes: any[]): string {
    const { research, operational, legacy } = categorizeTribeGroups(tribes);
    const base = getNavBase();
    let html = '';

    function tribeRow(tribe: any, inactive?: boolean): string {
      const countBadge = tribe.active_members > 0
        ? '<span class="ml-auto text-[.62rem] font-bold text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded-full shrink-0">' + tribe.active_members + '</span>'
        : '';
      if (inactive) {
        return '<div class="flex items-center gap-2 px-3 py-1.5 text-[.75rem] text-[var(--text-muted)] font-medium opacity-60 cursor-default">'
          + '<span class="w-5 h-5 rounded-full bg-[var(--surface-section-cool)] flex items-center justify-center text-[.6rem] font-bold text-[var(--text-secondary)] shrink-0">' + tribe.id + '</span>'
          + '<span class="truncate">' + tribeLabel(tribe) + '</span>'
          + '</div>';
      }
      return '<a href="' + base + '/tribe/' + tribe.id + '" class="flex items-center gap-2 px-3 py-1.5 text-[.78rem] text-[var(--text-primary)] font-medium hover:bg-[var(--surface-hover)] no-underline transition-all">'
        + '<span class="w-5 h-5 rounded-full bg-navy/10 flex items-center justify-center text-[.6rem] font-bold text-navy shrink-0">' + tribe.id + '</span>'
        + '<span class="truncate">' + tribeLabel(tribe) + '</span>'
        + countBadge
        + '</a>';
    }

    if (research.length) {
      html += '<div class="px-3 pt-2 pb-1 text-[.6rem] font-bold uppercase tracking-wider text-[var(--text-muted)]">Tribos de Pesquisa</div>';
      html += research.map((t: any) => tribeRow(t)).join('');
    }
    if (operational.length) {
      html += '<hr class="border-[var(--border-subtle)] my-1">';
      html += '<div class="px-3 pt-1 pb-1 text-[.6rem] font-bold uppercase tracking-wider text-purple">Operacional</div>';
      html += operational.map((t: any) => tribeRow(t)).join('');
    }
    if (legacy.length) {
      html += '<hr class="border-[var(--border-subtle)] my-1">';
      html += '<div class="px-3 pt-1 pb-1 text-[.6rem] font-bold uppercase tracking-wider text-[var(--text-muted)]">Ciclos Anteriores</div>';
      html += legacy.map((t: any) => tribeRow(t, true)).join('');
    }
    html += '<hr class="border-[var(--border-subtle)] my-1"><a href="' + base + '/#tribes" class="flex items-center gap-2 px-3 py-1.5 text-[.7rem] text-[var(--text-muted)] font-medium hover:bg-[var(--surface-hover)] no-underline transition-all"><span class="w-5 h-5 flex items-center justify-center text-[.7rem]">&#x1F30D;</span>' + (i18n.exploreTribes || 'Ver todas') + '</a>';
    return html || '<div class="px-3 py-2 text-[var(--text-muted)] text-xs">Nenhuma tribo disponível.</div>';
  }

  function renderDrawerTribeDropdown(tribes: any[]): string {
    const { research, operational, legacy } = categorizeTribeGroups(tribes);
    const base = getNavBase();
    let html = '';

    function row(tribe: any, inactive?: boolean): string {
      if (inactive) {
        return '<div class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[.73rem] text-[var(--text-muted)] font-medium opacity-60 cursor-default">'
          + '<span class="w-4 h-4 rounded-full bg-[var(--surface-section-cool)] flex items-center justify-center text-[.55rem] font-bold text-[var(--text-secondary)] shrink-0">' + tribe.id + '</span>'
          + tribeLabel(tribe)
          + '</div>';
      }
      return '<a href="' + base + '/tribe/' + tribe.id + '" class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-[.73rem] text-[var(--text-secondary)] font-medium no-underline hover:bg-[var(--surface-hover)] transition-all">'
        + '<span class="w-4 h-4 rounded-full bg-navy/10 flex items-center justify-center text-[.55rem] font-bold text-navy shrink-0">' + tribe.id + '</span>'
        + tribeLabel(tribe)
        + '</a>';
    }

    if (research.length) {
      html += '<div class="px-2 pt-1 pb-0.5 text-[.55rem] font-bold uppercase tracking-wider text-[var(--text-muted)]">Pesquisa</div>';
      html += research.map((t: any) => row(t)).join('');
    }
    if (operational.length) {
      html += '<div class="px-2 pt-2 pb-0.5 text-[.55rem] font-bold uppercase tracking-wider text-purple">Operacional</div>';
      html += operational.map((t: any) => row(t)).join('');
    }
    if (legacy.length) {
      html += '<div class="px-2 pt-2 pb-0.5 text-[.55rem] font-bold uppercase tracking-wider text-[var(--text-muted)]">Ciclos Anteriores</div>';
      html += legacy.map((t: any) => row(t, true)).join('');
    }
    return html || '<div class="px-2 py-1.5 text-[.7rem] text-[var(--text-muted)]">Nenhuma tribo disponível.</div>';
  }

  function renderMobileTribeDropdown(tribes: any[]): string {
    const { research, operational, legacy } = categorizeTribeGroups(tribes);
    const base = getNavBase();
    let html = '';

    function row(tribe: any, inactive?: boolean): string {
      if (inactive) {
        return '<div class="flex items-center gap-2 px-4 py-2 text-white/30 text-sm font-medium opacity-50 cursor-default">'
          + '<span class="w-5 h-5 rounded-full bg-white/10 flex items-center justify-center text-[.6rem] font-bold shrink-0">' + tribe.id + '</span>'
          + tribeLabel(tribe)
          + '</div>';
      }
      return '<a href="' + base + '/tribe/' + tribe.id + '" data-action="close-mobile" class="flex items-center gap-2 px-4 py-2 text-white/80 text-sm font-medium no-underline hover:bg-white/10 transition-all">'
        + '<span class="w-5 h-5 rounded-full bg-white/10 flex items-center justify-center text-[.6rem] font-bold shrink-0">' + tribe.id + '</span>'
        + tribeLabel(tribe)
        + '</a>';
    }

    if (research.length) {
      html += '<div class="px-4 pt-2 pb-1 text-[.6rem] font-bold uppercase tracking-wider text-white/40">Pesquisa</div>';
      html += research.map((t: any) => row(t)).join('');
    }
    if (operational.length) {
      html += '<div class="px-4 pt-2 pb-1 text-[.6rem] font-bold uppercase tracking-wider text-purple-300">Operacional</div>';
      html += operational.map((t: any) => row(t)).join('');
    }
    if (legacy.length) {
      html += '<div class="px-4 pt-2 pb-1 text-[.6rem] font-bold uppercase tracking-wider text-white/30">Ciclos Anteriores</div>';
      html += legacy.map((t: any) => row(t, true)).join('');
    }
    return html || '<div class="px-4 py-2.5 text-white/50 text-sm">Nenhuma tribo disponível.</div>';
  }

  function updateNavVisibility() {
    if (!_member) return;
    const tier = resolveTierFromMember(_member);
    const desigs: string[] = _member.designations || [];

    navConfig.forEach((item: any) => {
      if (!item.requiresAuth) return;

      const access = getItemAccessClient(item, tier, desigs);

      const desktopEl = document.getElementById(`nav-item-${item.key}`);
      const mobileEl = document.getElementById(`mobile-item-${item.key}`);

      if (desktopEl) {
        desktopEl.style.display = access.visible ? 'inline-flex' : 'none';
        if (access.visible && !access.enabled) {
          desktopEl.classList.add('opacity-40', 'pointer-events-none');
          desktopEl.setAttribute('title', `Requer ${TIER_LABELS[item.minTier] || item.minTier}`);
          desktopEl.setAttribute('aria-disabled', 'true');
          desktopEl.innerHTML = (desktopEl.textContent || '') + ' <svg class="w-3 h-3 inline-block ml-0.5 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>';
        } else if (access.visible && access.enabled) {
          desktopEl.classList.remove('opacity-40', 'pointer-events-none');
          desktopEl.removeAttribute('aria-disabled');
        }
      }
      if (mobileEl) {
        mobileEl.style.display = access.visible ? 'block' : 'none';
        if (access.visible && !access.enabled) {
          mobileEl.classList.add('opacity-40', 'pointer-events-none');
          mobileEl.setAttribute('title', `Requer ${TIER_LABELS[item.minTier] || item.minTier}`);
        } else if (access.visible && access.enabled) {
          mobileEl.classList.remove('opacity-40', 'pointer-events-none');
        }
      }

      if (access.visible && access.enabled && item.dynamic && item.resolver === 'resolveMyTribeHref') {
        const href = resolveMyTribeHref();
        const canBrowseTribes = canExploreTribes(_member);
        if (href) {
          if (desktopEl) { desktopEl.setAttribute('href', href); desktopEl.classList.remove('opacity-50', 'pointer-events-none'); desktopEl.textContent = i18n.myTribe || 'Minha Tribo'; }
          if (mobileEl) { mobileEl.setAttribute('href', href); mobileEl.classList.remove('opacity-50', 'pointer-events-none'); if (mobileEl.querySelector('span')) { mobileEl.querySelector('span')!.textContent = i18n.myTribe || 'Minha Tribo'; } }
        } else if (canBrowseTribes) {
          // Desktop: inject dropdown trigger
          if (desktopEl) {
            desktopEl.style.display = 'inline-flex';
            desktopEl.classList.remove('opacity-50', 'pointer-events-none');
            desktopEl.removeAttribute('href');
            desktopEl.setAttribute('data-action', 'toggle-tribe-dropdown');
            desktopEl.setAttribute('role', 'button');
            desktopEl.setAttribute('aria-haspopup', 'true');
            desktopEl.setAttribute('aria-expanded', 'false');
            desktopEl.innerHTML = (i18n.exploreTribes || 'Explorar Tribos') + ' <span class="text-[.55rem] ml-0.5 opacity-60">&#x25BE;</span>';
            // Create dropdown container if missing
            if (!document.getElementById('tribe-dropdown')) {
              var dd = document.createElement('div');
              dd.id = 'tribe-dropdown';
              dd.className = 'hidden absolute top-full mt-1 right-0 w-[calc(100vw-2rem)] sm:w-56 bg-[var(--surface-elevated)] rounded-xl shadow-xl border border-[var(--border-default)] py-1.5 z-[300] max-h-[60vh] overflow-y-auto';
              dd.innerHTML = '<div class="px-3 py-2 text-[var(--text-muted)] text-xs">Loading...</div>';
              desktopEl.style.position = 'relative';
              desktopEl.appendChild(dd);
            }
          }
          // Mobile: same approach
          if (mobileEl) {
            mobileEl.style.display = 'block';
            mobileEl.classList.remove('opacity-50', 'pointer-events-none');
            mobileEl.removeAttribute('href');
            mobileEl.setAttribute('data-action', 'toggle-tribe-dropdown-mobile');
            mobileEl.setAttribute('role', 'button');
            if (mobileEl.querySelector('span')) { mobileEl.querySelector('span')!.textContent = (i18n.exploreTribes || 'Explorar Tribos') + ' ▾'; }
            else { mobileEl.textContent = (i18n.exploreTribes || 'Explorar Tribos') + ' ▾'; }
            if (!document.getElementById('tribe-dropdown-mobile')) {
              var ddm = document.createElement('div');
              ddm.id = 'tribe-dropdown-mobile';
              ddm.className = 'hidden mt-1 bg-white/10 rounded-lg overflow-hidden';
              mobileEl.parentElement?.insertBefore(ddm, mobileEl.nextSibling);
            }
          }
        } else {
          if (desktopEl) { desktopEl.setAttribute('href', '/#tribes'); desktopEl.classList.add('opacity-50', 'pointer-events-none'); desktopEl.style.display = 'inline-flex'; }
          if (mobileEl) { mobileEl.setAttribute('href', '/#tribes'); mobileEl.classList.add('opacity-50', 'pointer-events-none'); mobileEl.style.display = 'block'; }
        }
      }
    });
  }

  function getRoleLabel(role: string): string {
    const roleLabelsEl = document.getElementById('role-labels-data');
    if (roleLabelsEl) {
      const labels = JSON.parse(roleLabelsEl.textContent || '{}');
      return labels[role] || role;
    }
    return role;
  }

  const THEME_KEY = 'ui_theme';
  function getTheme(): 'light' | 'dark' {
    return localStorage.getItem(THEME_KEY) === 'dark' ? 'dark' : 'light';
  }
  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem(THEME_KEY, theme);
    const btn = document.getElementById('pd-theme-toggle');
    if (btn) {
      btn.textContent = theme === 'dark' ? '☀️ Modo claro' : '🌙 Modo escuro';
    }
  }
  function toggleTheme() {
    applyTheme(getTheme() === 'dark' ? 'light' : 'dark');
  }

  function renderAuth() {
    if (!_member || getMemberRole(_member) === 'guest') {
      if (_user) { renderGuestWithSession(); } else { renderLoggedOut(); }
      return;
    }
    const name = _member.name || i18n.user || 'User';
    const first = name.split(' ')[0];
    const initials = name.split(' ').map((w: string) => w[0]).join('').substring(0,2).toUpperCase();
    const pic = _user?.user_metadata?.avatar_url;
    const r = getMemberRole(_member);
    const color = ROLE_COLORS[r] || '#64748B';
    const label = getRoleLabel(r);

    // XSS: sanitize avatar_url against domain allowlist
    const ALLOWED_AVATAR_DOMAINS = [
      'lh3.googleusercontent.com',
      'avatars.githubusercontent.com',
      'platform-lookaside.fbsbx.com',
      'media.licdn.com',
    ];
    function sanitizeAvatarUrl(url: string | null | undefined): string | null {
      if (!url) return null;
      try {
        const parsed = new URL(url);
        if (ALLOWED_AVATAR_DOMAINS.includes(parsed.hostname)) return url;
        return null;
      } catch { return null; }
    }
    // XSS: escape HTML in text content
    function escapeHtml(str: string): string {
      const div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    const safePic = sanitizeAvatarUrl(pic);
    const safeFirst = escapeHtml(first);
    const safeInitials = escapeHtml(initials);
    const safeLabel = escapeHtml(label);

    const el = document.getElementById('nav-auth');
    if (!el) return;
    el.innerHTML = `
      <a href="/help" title="${i18n.help || 'Central de Ajuda'}"
        class="w-8 h-8 rounded-full flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 transition-all no-underline text-sm font-bold">?</a>
      <button data-action="toggle-pd"
        class="flex items-center gap-1.5 px-1.5 py-1 rounded-lg hover:bg-white/10 transition-all cursor-pointer border-0 bg-transparent">
        ${safePic
          ? `<img src="${safePic}" class="w-7 h-7 rounded-full object-cover" onerror="this.style.display='none'">`
          : `<div class="w-7 h-7 rounded-full bg-teal flex items-center justify-center text-white font-bold text-[.65rem]">${safeInitials}</div>`
        }
        <span class="text-white text-[.8rem] font-semibold hidden sm:inline">${safeFirst}</span>
        <span class="text-[.6rem] font-bold px-1.5 py-0.5 rounded uppercase hidden sm:inline" style="background:${color}33;color:${color}">${safeLabel}</span>
        <span id="notif-badge" class="hidden w-4 h-4 rounded-full bg-red-500 text-white text-[.55rem] font-bold flex items-center justify-center"></span>
        <span class="text-white/40 text-[.6rem]">▾</span>
      </button>`;

    updateNavVisibility();
    buildDrawer();
    startNotifBadgePolling();
  }

  function renderLoggedOut() {
    const el = document.getElementById('nav-auth');
    if (el) el.innerHTML = `
      <button data-action="open-auth"
        class="px-3 py-1.5 rounded-lg bg-white/10 border border-white/20 text-white text-[.78rem] font-semibold hover:bg-white/20 transition-all cursor-pointer">
        ${i18n.login || 'Sign In'}
      </button>`;
  }

  function renderGuestWithSession() {
    const el = document.getElementById('nav-auth');
    if (!el) return;
    el.innerHTML = `
      <div class="flex items-center gap-2">
        <span class="text-amber-400 text-[.73rem] font-semibold hidden sm:inline">${i18n.guestNotFound || 'Conta não cadastrada'}</span>
        <button data-action="logout"
          class="px-2.5 py-1 rounded-lg bg-white/10 border border-white/20 text-white text-[.7rem] font-semibold hover:bg-white/20 transition-all cursor-pointer">
          ${i18n.logout || '↩ Sair'}
        </button>
      </div>`;
  }

  // ── Notification badge polling ──
  let notifInterval: ReturnType<typeof setInterval> | null = null;
  async function updateNotifBadge() {
    if (!sb) return;
    try {
      const { data } = await sb.rpc('get_notification_count');
      const badge = document.getElementById('notif-badge');
      if (badge) {
        if (data && data > 0) {
          badge.textContent = data > 9 ? '9+' : String(data);
          badge.classList.remove('hidden');
          badge.classList.add('flex');
        } else {
          badge.classList.add('hidden');
          badge.classList.remove('flex');
        }
      }
    } catch (e) { /* silent */ }
  }
  function startNotifBadgePolling() {
    updateNotifBadge();
    if (notifInterval) clearInterval(notifInterval);
    notifInterval = setInterval(updateNotifBadge, 60000);
  }
  (window as any).__updateNotifBadge = updateNotifBadge;

