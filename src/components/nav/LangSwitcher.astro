---
/**
 * LangSwitcher.astro — Sprint 5
 * Dropdown language selector for the Nav bar.
 */
import { LANGUAGES, type Lang } from '../../i18n/utils';

interface Props {
  currentLang: Lang;
  currentPath?: string;
}

const { currentLang, currentPath = '/' } = Astro.props;

function buildHref(prefix: string): string {
  // For index pages, just use the prefix
  if (currentPath === '/' || currentPath === '') {
    return prefix ? `/${prefix}/` : '/';
  }
  // For other pages, prepend prefix
  return prefix ? `/${prefix}${currentPath}` : currentPath;
}
---

<div class="relative" id="lang-switcher">
  <button onclick="document.getElementById('lang-menu').classList.toggle('hidden')"
          class="flex items-center gap-1 px-2 py-1 rounded-md bg-white/10 border border-white/20
                 text-white text-[.72rem] font-semibold hover:bg-white/20 transition-all cursor-pointer">
    {LANGUAGES.find(l => l.code === currentLang)?.flag}
    <span class="text-white/60 text-[.6rem]">▾</span>
  </button>
  <div id="lang-menu" class="hidden absolute right-0 top-full mt-1 bg-white rounded-lg shadow-xl border border-slate-200
                              min-w-[140px] py-1 z-50">
    {LANGUAGES.map(l => (
      <a href={buildHref(l.prefix)}
         class:list={[
           "flex items-center gap-2 px-3 py-1.5 text-[.78rem] font-medium no-underline transition-all",
           l.code === currentLang
             ? "bg-navy/5 text-navy font-bold"
             : "text-slate-600 hover:bg-slate-50"
         ]}>
        <span>{l.flag}</span>
        <span>{l.label}</span>
        {l.code === currentLang && <span class="text-[.6rem] text-teal ml-auto">✓</span>}
      </a>
    ))}
  </div>
</div>

<script>
  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    const switcher = document.getElementById('lang-switcher');
    const menu = document.getElementById('lang-menu');
    if (switcher && menu && !switcher.contains(e.target as Node)) {
      menu.classList.add('hidden');
    }
  });
</script>
