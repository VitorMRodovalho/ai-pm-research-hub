<!-- ConfirmDialog — S11 UI Polish
     Usage from JS:
       window.showConfirm({
         title: 'Remover membro?',
         message: 'Esta ação não pode ser desfeita.',
         confirmText: 'Remover',
         confirmClass: 'bg-crimson',
         onConfirm: () => doDelete()
       });
-->
<div id="confirm-dialog" class="hidden fixed inset-0 bg-black/50 z-[600] items-center justify-center p-4">
  <div class="bg-white rounded-2xl w-full max-w-[380px] overflow-hidden shadow-2xl">
    <div class="p-6 text-center">
      <div class="text-3xl mb-3" id="confirm-icon">⚠️</div>
      <h3 class="text-base font-bold text-navy mb-2" id="confirm-title">Confirmar ação</h3>
      <p class="text-sm text-slate-500" id="confirm-message">Tem certeza?</p>
    </div>
    <div class="px-5 py-3.5 border-t border-slate-200 flex justify-end gap-2">
      <button id="confirm-cancel-btn"
        class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-slate-200 text-slate-600 bg-transparent hover:bg-slate-50 cursor-pointer">
        Cancelar
      </button>
      <button id="confirm-btn"
        class="px-4 py-2 rounded-lg text-[13px] font-semibold text-white border-0 hover:opacity-90 cursor-pointer bg-crimson">
        Confirmar
      </button>
    </div>
  </div>
</div>

<script>
  let _confirmCallback: (() => void) | null = null;

  interface ConfirmOptions {
    title?: string;
    message?: string;
    confirmText?: string;
    confirmClass?: string;
    icon?: string;
    onConfirm: () => void;
  }

  (window as any).showConfirm = (opts: ConfirmOptions) => {
    const dialog = document.getElementById('confirm-dialog')!;
    document.getElementById('confirm-icon')!.textContent = opts.icon || '⚠️';
    document.getElementById('confirm-title')!.textContent = opts.title || 'Confirmar ação';
    document.getElementById('confirm-message')!.textContent = opts.message || 'Tem certeza?';
    const btn = document.getElementById('confirm-btn')!;
    btn.textContent = opts.confirmText || 'Confirmar';
    btn.className = `px-4 py-2 rounded-lg text-[13px] font-semibold text-white border-0 hover:opacity-90 cursor-pointer ${opts.confirmClass || 'bg-crimson'}`;
    _confirmCallback = opts.onConfirm;
    btn.onclick = () => { // @ts-ignore
      closeConfirm(); _confirmCallback?.(); };
    dialog.classList.remove('hidden');
    dialog.classList.add('flex');
  };

  (window as any).closeConfirm = () => {
    const dialog = document.getElementById('confirm-dialog')!;
    dialog.classList.add('hidden');
    dialog.classList.remove('flex');
    _confirmCallback = null;
  };

  document.getElementById('confirm-cancel-btn')?.addEventListener('click', () => {
    (window as any).closeConfirm();
  });
</script>
