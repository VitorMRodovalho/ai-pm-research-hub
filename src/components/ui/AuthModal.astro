---
import { t, type Lang } from '../../i18n/utils';

interface Props {
  redirectTo?: string;
  lang?: Lang;
}

const { redirectTo = '/', lang = 'pt-BR' } = Astro.props;

const ui = {
  title: t('authModal.title', lang),
  subtitle: t('authModal.subtitle', lang),
  google: t('authModal.google', lang),
  linkedin: t('authModal.linkedin', lang),
  or: t('authModal.or', lang),
  emailPlaceholder: t('authModal.emailPlaceholder', lang),
  magic: t('authModal.magic', lang),
  enterEmail: t('authModal.enterEmail', lang),
  wait: t('authModal.wait', lang),
  sent: t('authModal.sent', lang),
  errorPrefix: t('authModal.errorPrefix', lang),
};
---

<div id="auth-modal"
  class="hidden fixed inset-0 z-[300] flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
  <div class="bg-white rounded-2xl p-8 max-w-sm w-full shadow-2xl relative">
    <button id="auth-close-btn"
            class="absolute top-4 right-4 text-slate-400 hover:text-slate-700 cursor-pointer border-0 bg-transparent text-xl">✕</button>
    <div class="text-3xl mb-3 text-center">🔐</div>
    <h2 class="text-xl font-extrabold text-center text-navy mb-1">{ui.title}</h2>
    <p class="text-sm text-slate-500 text-center mb-6">{ui.subtitle}</p>
    <button id="btn-google"
      class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-navy text-white
             rounded-xl font-semibold text-sm hover:opacity-90 transition-all cursor-pointer border-0 mb-3">
      <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#fff" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#fff" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#fff" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      {ui.google}
    </button>
    <button id="btn-linkedin"
      class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-[#0A66C2] text-white
             rounded-xl font-semibold text-sm hover:opacity-90 transition-all cursor-pointer border-0 mb-3">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      {ui.linkedin}
    </button>
    <div class="relative my-3">
      <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-200"></div></div>
      <div class="relative flex justify-center"><span class="px-3 bg-white text-slate-400 text-xs">{ui.or}</span></div>
    </div>
    <input type="email" id="magic-email" placeholder={ui.emailPlaceholder}
      class="w-full px-3 py-2.5 border-2 border-slate-200 rounded-xl text-sm mb-2 focus:outline-none focus:border-teal transition-all" />
    <button id="btn-magic"
      class="w-full px-4 py-2.5 border-2 border-slate-200 text-slate-700 rounded-xl font-semibold text-sm
             hover:border-teal hover:text-teal transition-all cursor-pointer bg-transparent mb-2">
      {ui.magic}
    </button>
    <div id="auth-msg" class="text-xs text-center min-h-[1.2rem]"></div>
  </div>
</div>

<script define:vars={{ redirectTo, ui }}>
  document.addEventListener('open-auth', function() {
    document.getElementById('auth-modal').classList.remove('hidden');
  });

  document.getElementById('auth-close-btn')?.addEventListener('click', function() {
    document.getElementById('auth-modal')?.classList.add('hidden');
  });

  document.getElementById('btn-google').addEventListener('click', async function() {
    var sb = window.navGetSb && window.navGetSb();
    if (!sb) return;
    await sb.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: location.origin + redirectTo }
    });
  });

  document.getElementById('btn-linkedin').addEventListener('click', async function() {
    var sb = window.navGetSb && window.navGetSb();
    if (!sb) return;
    await sb.auth.signInWithOAuth({
      provider: 'linkedin_oidc',
      options: { redirectTo: location.origin + redirectTo }
    });
  });
  document.getElementById('btn-magic').addEventListener('click', async function() {
    var sb = window.navGetSb && window.navGetSb();
    var email = document.getElementById('magic-email').value.trim();
    var msg = document.getElementById('auth-msg');
    if (!email) { msg.style.color='#BE2027'; msg.textContent=ui.enterEmail; return; }
    if (!sb) { msg.style.color='#BE2027'; msg.textContent=ui.wait; return; }
    var res = await sb.auth.signInWithOtp({
      email: email,
      options: { emailRedirectTo: location.origin + redirectTo }
    });
    if (res.error) { msg.style.color='#BE2027'; msg.textContent=ui.errorPrefix + res.error.message; }
    else { msg.style.color='#10B981'; msg.textContent=ui.sent; }
  });
</script>
