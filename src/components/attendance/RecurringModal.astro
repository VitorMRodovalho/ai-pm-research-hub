---
/**
 * RecurringModal.astro — W140
 * Modal for creating recurring weekly events with multi-tag and audience selection.
 */
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-recurring">
  <div class="bg-[var(--surface-card)] rounded-2xl w-full max-w-[560px] overflow-hidden max-h-[90vh] flex flex-col">
    <div class="px-5 py-4 border-b border-[var(--border-default)] flex justify-between items-center flex-shrink-0">
      <h3 class="text-base font-bold text-navy">{t('attendance.modal.recurringTitle', lang)}</h3>
      <button type="button" class="bg-transparent border-0 text-xl cursor-pointer text-[var(--text-muted)]" data-action="close-modal" data-modal-id="modal-recurring">✕</button>
    </div>
    <form id="recurring-event-form" class="p-5 overflow-y-auto flex-1">
      <div class="bg-[var(--surface-base)] rounded-lg px-3.5 py-3 text-[13px] text-navy flex items-center gap-2 mb-4">
        {t('attendance.modal.recurringHint', lang).replace('{n}', '{n}').replace('{date}', '{date}')}
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.templateTitle', lang)}</label>
          <input type="text" id="rec-title" value="Reunião Geral — Núcleo IA & GP | Semana &#123;n&#125;"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <!-- W140: Multi-tag selector (replaces single type dropdown) -->
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">Tags</label>
          <div id="rec-tags-container" class="flex flex-wrap gap-1.5 min-h-[36px] px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] bg-[var(--surface-card)] cursor-pointer" data-action="toggle-tag-picker" data-target="rec-tag-picker">
            <span class="text-[12px] text-[var(--text-muted)]">Clique para selecionar tags...</span>
          </div>
          <div id="rec-tag-picker" class="hidden mt-1 max-h-[200px] overflow-y-auto rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] shadow-lg">
            <!-- Populated dynamically by JS -->
          </div>
          <input type="hidden" id="rec-selected-tags" value="">
        </div>
        <!-- Legacy type field (hidden, auto-derived from primary tag) -->
        <input type="hidden" id="rec-type" value="general_meeting">
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.audience', lang)}</label>
          <select id="rec-audience"
                  class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
            <option value="all">Todos os operacionais ativos</option>
            <option value="tribe">Tribo específica</option>
            <option value="leadership">Por papel (liderança)</option>
            <option value="curators">Curadores</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.startDate', lang)}</label>
          <input type="date" id="rec-start"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.durationMin', lang)}</label>
          <input type="number" id="rec-duration" value="90" min="15" max="480"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.weeks', lang)}</label>
          <input type="number" id="rec-weeks" value="12" min="1" max="52"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.recurringLink', lang)}</label>
          <input type="url" id="rec-link" placeholder="https://meet.google.com/..." value="https://meet.google.com/dzo-phoj-tid"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="flex items-center gap-2 text-[13px] font-medium cursor-pointer">
            <input type="checkbox" id="rec-recorded" checked class="w-4 h-4 accent-navy">
            {t('attendance.modal.recordedMeetings', lang)}
          </label>
        </div>
      </div>
    </form>
    <div class="px-5 py-3.5 border-t border-[var(--border-default)] flex justify-end gap-2 flex-shrink-0">
      <button type="button" class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--surface-hover)] cursor-pointer" data-action="close-modal" data-modal-id="modal-recurring">{t('attendance.modal.cancel', lang)}</button>
      <button type="submit" form="recurring-event-form" class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer">{t('attendance.modal.createSeries', lang)}</button>
    </div>
  </div>
</div>
