---
/**
 * RosterModal.astro — Sprint 3 FINAL
 */
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-roster">
  <div class="bg-[var(--surface-card)] rounded-2xl w-full max-w-[680px] flex flex-col overflow-hidden" style="max-height:85vh">
    <!-- Header -->
    <div class="px-5 py-4 border-b border-[var(--border-default)] flex-shrink-0">
      <div class="flex justify-between items-center mb-3">
        <h3 class="text-base font-bold text-navy" id="roster-title">{t('attendance.modal.rosterTitle', lang)}</h3>
        <button type="button" class="bg-transparent border-0 text-xl cursor-pointer text-[var(--text-muted)]" data-action="close-modal" data-modal-id="modal-roster">✕</button>
      </div>
      <div class="flex items-center gap-3">
        <input type="text" id="roster-search" placeholder={t('attendance.modal.searchName', lang)}
               class="flex-1 px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        <div class="text-[12px] font-bold text-emerald-600 flex-shrink-0 whitespace-nowrap" id="roster-count"></div>
      </div>
    </div>
    <!-- Scrollable table area -->
    <div class="overflow-y-auto" style="max-height:calc(85vh - 150px)">
      <table class="w-full border-collapse text-[13px]">
        <thead class="sticky top-0 z-10 bg-[var(--surface-base)]">
          <tr>
            <th class="text-left px-3 py-2 text-[var(--text-secondary)] text-[11px] font-bold uppercase tracking-wider">{t('attendance.modal.colCollaborator', lang)}</th>
            <th class="text-left px-3 py-2 text-[var(--text-secondary)] text-[11px] font-bold uppercase tracking-wider">{t('attendance.modal.colRole', lang)}</th>
            <th class="text-center px-3 py-2 text-[var(--text-secondary)] text-[11px] font-bold uppercase tracking-wider w-24">{t('attendance.modal.colPresent', lang)}</th>
          </tr>
        </thead>
        <tbody id="roster-body"></tbody>
      </table>
    </div>
    <!-- Showcases section -->
    <div class="px-5 py-3 border-t border-[var(--border-default)] flex-shrink-0" id="roster-showcase-section">
      <div class="flex items-center justify-between mb-2">
        <h4 class="text-[12px] font-bold text-[var(--text-secondary)] uppercase tracking-wider">🎤 Showcases</h4>
        <button type="button" id="roster-add-showcase-btn" class="hidden px-2.5 py-1 rounded-lg text-[11px] font-semibold bg-red-600 text-white border-0 cursor-pointer hover:bg-red-700 transition-colors" data-action="toggle-showcase-form">
          + {t('eventDetail.addShowcase', lang)}
        </button>
      </div>
      <div id="roster-showcase-list" class="space-y-1.5 mb-2"></div>
      <div id="roster-showcase-form" class="hidden p-3 rounded-lg bg-[var(--surface-base)] border border-[var(--border-subtle)] space-y-2">
        <div class="flex gap-2 flex-wrap items-end">
          <div class="flex-1 min-w-[140px]">
            <label class="text-[10px] font-semibold text-[var(--text-muted)] mb-0.5 block">{t('eventDetail.showcaseMember', lang)}</label>
            <select id="showcase-member-select" class="w-full bg-[var(--surface-card)] border border-[var(--border-default)] rounded-lg px-2 py-1.5 text-[12px]">
              <option value="">—</option>
            </select>
          </div>
          <div class="min-w-[130px]">
            <label class="text-[10px] font-semibold text-[var(--text-muted)] mb-0.5 block">{t('eventDetail.showcaseType', lang)}</label>
            <select id="showcase-type-select" class="w-full bg-[var(--surface-card)] border border-[var(--border-default)] rounded-lg px-2 py-1.5 text-[12px]">
              <option value="case_study">🎓 {t('showcase.type.case_study', lang)} (25 XP)</option>
              <option value="tool_review" selected>🔧 {t('showcase.type.tool_review', lang)} (20 XP)</option>
              <option value="prompt_week">💡 {t('showcase.type.prompt_week', lang)} (20 XP)</option>
              <option value="quick_insight">⚡ {t('showcase.type.quick_insight', lang)} (15 XP)</option>
              <option value="awareness">🌍 {t('showcase.type.awareness', lang)} (15 XP)</option>
            </select>
          </div>
        </div>
        <div class="flex gap-2 items-end">
          <div class="flex-1">
            <label class="text-[10px] font-semibold text-[var(--text-muted)] mb-0.5 block">{t('eventDetail.showcaseTitle', lang)}</label>
            <input type="text" id="showcase-title-input" placeholder="Ex: PM Strategic Analyzer" class="w-full bg-[var(--surface-card)] border border-[var(--border-default)] rounded-lg px-2 py-1.5 text-[12px]">
          </div>
          <div class="w-16">
            <label class="text-[10px] font-semibold text-[var(--text-muted)] mb-0.5 block">Min</label>
            <input type="number" id="showcase-duration-input" placeholder="min" class="w-full bg-[var(--surface-card)] border border-[var(--border-default)] rounded-lg px-2 py-1.5 text-[12px]">
          </div>
        </div>
        <div class="flex gap-2">
          <button type="button" class="px-3 py-1.5 rounded-lg text-[11px] font-semibold bg-red-600 text-white border-0 cursor-pointer hover:bg-red-700 disabled:opacity-50" data-action="save-showcase">
            {t('eventDetail.save', lang)}
          </button>
          <button type="button" class="px-3 py-1.5 rounded-lg text-[11px] border border-[var(--border-default)] text-[var(--text-muted)] bg-transparent cursor-pointer" data-action="toggle-showcase-form">
            {t('eventDetail.cancel', lang)}
          </button>
        </div>
      </div>
    </div>
    <!-- Footer -->
    <div class="px-5 py-3 border-t border-[var(--border-default)] flex items-center justify-between flex-shrink-0">
      <div class="flex items-center gap-2">
        <button type="button" id="roster-bulk-all" class="hidden px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-teal text-white border-0 cursor-pointer hover:opacity-90 transition-opacity" data-action="roster-bulk-all">
          {t('attendance.modal.selectAll', lang)}
        </button>
        <button type="button" id="roster-bulk-confirm" class="hidden px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-navy text-white border-0 cursor-pointer hover:opacity-90 transition-opacity" data-action="roster-bulk-confirm">
          {t('attendance.modal.bulkConfirm', lang)}
        </button>
      </div>
      <button type="button" class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--surface-hover)] cursor-pointer" data-action="close-modal" data-modal-id="modal-roster">{t('attendance.modal.close', lang)}</button>
    </div>
  </div>
</div>

<style is:global>
  .toggle-btn {
    width: 44px; height: 24px; border-radius: 99px; border: none;
    cursor: pointer; position: relative; transition: background .2s;
  }
  .toggle-btn.on  { background: #10B981; }
  .toggle-btn.off { background: #CBD5E1; }
  .toggle-btn::after {
    content: ''; position: absolute; top: 3px; left: 3px;
    width: 18px; height: 18px; border-radius: 50%; background: white;
    transition: transform .2s;
  }
  .toggle-btn.on::after { transform: translateX(20px); }
</style>
