---
/**
 * EditEventModal.astro — W140
 * Modal for editing an existing event with multi-tag and audience selection.
 */
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-edit-event">
  <div class="bg-[var(--surface-card)] rounded-2xl w-full max-w-[560px] overflow-hidden max-h-[90vh] flex flex-col">
    <div class="px-5 py-4 border-b border-[var(--border-default)] flex justify-between items-center flex-shrink-0">
      <h3 class="text-base font-bold text-navy">{t('attendance.modal.editEventTitle', lang)}</h3>
      <button type="button" class="bg-transparent border-0 text-xl cursor-pointer text-[var(--text-muted)]" data-action="close-modal" data-modal-id="modal-edit-event">✕</button>
    </div>
    <form id="edit-event-form" class="p-5 overflow-y-auto flex-1">
      <input type="hidden" id="edit-ev-id">
      <div id="edit-ev-context" class="hidden mb-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-[.78rem] text-amber-900"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.title', lang)}</label>
          <input type="text" id="edit-ev-title"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <!-- W140: Multi-tag selector -->
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">Tags</label>
          <div id="edit-ev-tags-container" class="flex flex-wrap gap-1.5 min-h-[36px] px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] bg-[var(--surface-card)] cursor-pointer" data-action="toggle-tag-picker" data-target="edit-ev-tag-picker">
            <span class="text-[12px] text-[var(--text-muted)]">Clique para selecionar tags...</span>
          </div>
          <div id="edit-ev-tag-picker" class="hidden mt-1 max-h-[200px] overflow-y-auto rounded-lg border border-[var(--border-default)] bg-[var(--surface-card)] shadow-lg">
            <!-- Populated dynamically by JS -->
          </div>
          <input type="hidden" id="edit-ev-selected-tags" value="">
        </div>
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.audienceType', lang)} *</label>
          <select id="edit-ev-type" required
                  class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
            <option value="geral">Geral</option>
            <option value="tribo">Tribo</option>
            <option value="lideranca">Liderança</option>
            <option value="kickoff">Kickoff</option>
            <option value="comms">Comunicação</option>
            <option value="parceria">Parceria</option>
            <option value="entrevista">Entrevista</option>
            <option value="1on1">1-on-1</option>
            <option value="evento_externo">Evento Externo</option>
          </select>
        </div>
        <div id="edit-ev-tribe-wrapper" class="hidden flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.whichTribe', lang)} *</label>
          <select id="edit-ev-tribe-select" class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)]">
            <option value="">— select —</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.nature', lang)}</label>
          <select id="edit-ev-nature" class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)]">
            <option value="avulsa">Avulsa</option>
            <option value="recorrente">Recorrente</option>
            <option value="kickoff">Kickoff</option>
            <option value="encerramento">Encerramento</option>
            <option value="workshop">Workshop</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.date', lang)}</label>
          <input type="date" id="edit-ev-date"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.timeStart', lang) || 'Horário'}</label>
          <input type="time" id="edit-ev-time-start"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.durationMin', lang)}</label>
          <input type="number" id="edit-ev-duration" min="15" max="480"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.meetingLink', lang)}</label>
          <input type="url" id="edit-ev-link"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
        </div>
      </div>
      <!-- Advanced section (collapsible) -->
      <details id="edit-ev-advanced" class="mt-4 border border-[var(--border-default)] rounded-xl">
        <summary class="px-4 py-2.5 text-[12px] font-semibold text-[var(--text-secondary)] cursor-pointer select-none hover:bg-[var(--surface-hover)] rounded-xl">{t('attendance.modal.advanced', lang)}</summary>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5 px-4 pb-4 pt-2">
          <div class="flex flex-col gap-1.5">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.visibility', lang)}</label>
            <select id="edit-ev-visibility"
                    class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
              <option value="public">Público</option>
              <option value="leadership">Liderança</option>
              <option value="gp_only">GP only</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.audience', lang)}</label>
            <select id="edit-ev-audience"
                    class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] bg-[var(--surface-card)] focus:outline-none focus:border-navy">
              <option value="all">Todos os operacionais ativos</option>
              <option value="tribe">Tribo específica</option>
              <option value="leadership">Por papel (liderança)</option>
              <option value="curators">Curadores</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.recordingUrl', lang)}</label>
            <input type="url" id="edit-ev-recording-url" placeholder="https://..."
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.youtubeLink', lang)}</label>
            <input type="url" id="edit-ev-youtube" placeholder="https://youtu.be/..."
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.notes', lang) || 'Notas'}</label>
            <textarea id="edit-ev-notes" rows="2" placeholder="Observações sobre este evento..."
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy resize-y"></textarea>
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label class="text-[12px] font-semibold text-[var(--text-secondary)]">{t('attendance.modal.externalAttendees', lang)}</label>
            <input type="text" id="edit-ev-external-attendees" placeholder="email1@example.com, email2@example.com"
                   class="px-3 py-2 rounded-lg border-[1.5px] border-[var(--border-default)] text-[13px] focus:outline-none focus:border-navy">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="flex items-center gap-2 text-[13px] font-medium cursor-pointer">
              <input type="checkbox" id="edit-ev-recorded" class="w-4 h-4 accent-navy">
              {t('attendance.modal.recordedMeeting', lang)}
            </label>
          </div>
        </div>
      </details>
    </form>
    <div class="px-5 py-3.5 border-t border-[var(--border-default)] flex justify-end gap-2 flex-shrink-0">
      <button type="button" class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-[var(--surface-hover)] cursor-pointer" data-action="close-modal" data-modal-id="modal-edit-event">{t('attendance.modal.cancel', lang)}</button>
      <button type="submit" form="edit-event-form" class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer">{t('attendance.modal.save', lang)}</button>
    </div>
  </div>
</div>
