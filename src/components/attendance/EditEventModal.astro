---
/**
 * EditEventModal.astro — Sprint 3
 * Modal for editing an existing event.
 */
import { t, getLangFromURL, type Lang } from '../../i18n/utils';
const lang: Lang = getLangFromURL(Astro.url.pathname);
---

<div class="hidden fixed inset-0 bg-black/50 z-[100] items-center justify-center p-4" id="modal-edit-event">
  <div class="bg-white rounded-2xl w-full max-w-[560px] overflow-hidden max-h-[90vh] flex flex-col">
    <div class="px-5 py-4 border-b border-slate-200 flex justify-between items-center flex-shrink-0">
      <h3 class="text-base font-bold text-navy">{t('attendance.modal.editEventTitle', lang)}</h3>
      <button type="button" class="bg-transparent border-0 text-xl cursor-pointer text-slate-400" data-action="close-modal" data-modal-id="modal-edit-event">✕</button>
    </div>
    <form id="edit-event-form" class="p-5 overflow-y-auto flex-1">
      <input type="hidden" id="edit-ev-id">
      <div id="edit-ev-context" class="hidden mb-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-[.78rem] text-amber-900"></div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3.5">
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-slate-500">{t('attendance.modal.title', lang)}</label>
          <input type="text" id="edit-ev-title"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-slate-500">{t('attendance.modal.date', lang)}</label>
          <input type="date" id="edit-ev-date"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-slate-500">{t('attendance.modal.durationMin', lang)}</label>
          <input type="number" id="edit-ev-duration" min="15" max="480"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-slate-500">{t('attendance.modal.meetingLink', lang)}</label>
          <input type="url" id="edit-ev-link"
                 class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5 sm:col-span-2">
          <label class="text-[12px] font-semibold text-slate-500">{t('attendance.modal.youtubeLink', lang)}</label>
          <input type="url" id="edit-ev-youtube" placeholder="https://youtu.be/..."
                 class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] focus:outline-none focus:border-navy">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-[12px] font-semibold text-slate-500">{t('attendance.modal.audience', lang)}</label>
          <select id="edit-ev-audience"
                  class="px-3 py-2 rounded-lg border-[1.5px] border-slate-200 text-[13px] bg-white focus:outline-none focus:border-navy">
            <option value="all">{t('attendance.modal.audienceAll', lang)}</option>
            <option value="leadership">{t('attendance.modal.audienceLeadership', lang)}</option>
            <option value="tribe">{t('attendance.modal.audienceTribe', lang)}</option>
            <option value="curators">{t('attendance.modal.audienceCurators', lang)}</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="flex items-center gap-2 text-[13px] font-medium cursor-pointer">
            <input type="checkbox" id="edit-ev-recorded" class="w-4 h-4 accent-navy">
            {t('attendance.modal.recordedMeeting', lang)}
          </label>
        </div>
      </div>
    </form>
    <div class="px-5 py-3.5 border-t border-slate-200 flex justify-end gap-2 flex-shrink-0">
      <button type="button" class="px-4 py-2 rounded-lg text-[13px] font-semibold border-[1.5px] border-navy text-navy bg-transparent hover:bg-slate-50 cursor-pointer" data-action="close-modal" data-modal-id="modal-edit-event">{t('attendance.modal.cancel', lang)}</button>
      <button type="submit" form="edit-event-form" class="px-4 py-2 rounded-lg text-[13px] font-semibold bg-navy text-white border-0 hover:bg-navy/90 cursor-pointer">{t('attendance.modal.save', lang)}</button>
    </div>
  </div>
</div>
