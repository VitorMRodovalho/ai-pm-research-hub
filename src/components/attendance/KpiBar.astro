---
/**
 * KpiBar.astro — Sprint 3
 * 4 KPI cards: impact hours, progress %, total events, total attendances.
 * Data loaded client-side from Supabase view `impact_hours_total`.
 */
---

<div class="bg-navy px-6 pb-5 grid grid-cols-2 lg:grid-cols-4 gap-3">
  <div class="bg-white/[.08] rounded-xl p-4 border border-white/10">
    <div class="text-[11px] font-semibold uppercase tracking-wider text-blue-300">Horas de Impacto</div>
    <div class="text-white text-[26px] font-bold mt-1" id="kpi-hours">—</div>
    <div class="text-slate-400 text-[12px]">Meta: 1.800h anuais</div>
    <div class="mt-2 bg-white/15 rounded-full h-1.5 overflow-hidden">
      <div class="h-full bg-red-500 rounded-full transition-all duration-600" id="kpi-bar" style="width:0%"></div>
    </div>
  </div>
  <div class="bg-white/[.08] rounded-xl p-4 border border-white/10">
    <div class="text-[11px] font-semibold uppercase tracking-wider text-blue-300">Progresso</div>
    <div class="text-white text-[26px] font-bold mt-1" id="kpi-pct">—</div>
    <div class="text-slate-400 text-[12px]">da meta anual</div>
  </div>
  <div class="bg-white/[.08] rounded-xl p-4 border border-white/10">
    <div class="text-[11px] font-semibold uppercase tracking-wider text-blue-300">Total de Eventos</div>
    <div class="text-white text-[26px] font-bold mt-1" id="kpi-events">—</div>
    <div class="text-slate-400 text-[12px]">Ciclo 3</div>
  </div>
  <div class="bg-white/[.08] rounded-xl p-4 border border-white/10">
    <div class="text-[11px] font-semibold uppercase tracking-wider text-blue-300">Presenças Registradas</div>
    <div class="text-white text-[26px] font-bold mt-1" id="kpi-att">—</div>
    <div class="text-slate-400 text-[12px]">participantes × evento</div>
  </div>
</div>
