{
  "name": "ai-pm-hub-v2",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/verify-build-pages.mjs",
    "clean": "rm -rf dist",
    "build": "npm run clean && astro build && node scripts/patch-worker-polyfill.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node --test tests/credly.test.mjs tests/cycle-history.test.mjs tests/gamification.test.mjs tests/routing.test.mjs tests/attendance-ui.test.mjs tests/permissions-matrix.test.mjs tests/ui-stabilization.test.mjs tests/contracts/route-acl.test.mjs tests/contracts/rpc-acl.test.mjs tests/contracts/navigation-visibility.test.mjs tests/contracts/kpi-portfolio-health.test.mjs tests/contracts/selection-blind-eval.test.mjs tests/contracts/selection-interview-decision.test.mjs tests/contracts/selection-onboarding-diversity.test.mjs tests/contracts/tribe-dashboard.test.mjs tests/contracts/security-lgpd.test.mjs tests/contracts/impact-crosstribe.test.mjs",
    "test:contracts": "node --test tests/contracts/route-acl.test.mjs tests/contracts/rpc-acl.test.mjs tests/contracts/navigation-visibility.test.mjs tests/contracts/kpi-portfolio-health.test.mjs tests/contracts/selection-blind-eval.test.mjs tests/contracts/selection-interview-decision.test.mjs tests/contracts/selection-onboarding-diversity.test.mjs tests/contracts/tribe-dashboard.test.mjs tests/contracts/security-lgpd.test.mjs tests/contracts/impact-crosstribe.test.mjs",
    "test:browser:guards": "node tests/browser-guards.test.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "qa:kanban": "./scripts/qa_kanban_dark_release_gate.sh",
    "audit:dark:baseline": "./scripts/audit_dark_mode_visual_baseline.sh",
    "audit:dark:contrast": "./scripts/audit_dark_mode_contrast_snapshots.sh",
    "audit:permissions": "./scripts/audit_permissions_matrix_sync.sh",
    "lint:i18n": "eslint src/components/boards/**/*.tsx src/pages/admin/portfolio.astro",
    "test:visual:dark": "playwright test tests/visual/dark-mode.spec.ts --config=playwright.config.ts",
    "test:e2e:lifecycle": "playwright test tests/e2e/user-lifecycle.spec.ts --config=playwright.config.ts",
    "screenshots:multilang": "node scripts/screenshots-multilang.mjs",
    "screenshots:setup": "npx playwright install chromium",
    "db:types": "supabase gen types typescript --linked > src/lib/database.gen.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/react": "^5.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.17.1",
    "chart.js": "^4.5.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/parser": "^8.57.0",
    "astro-eslint-parser": "^1.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-react": "^7.37.5",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  }
}
